# Print essential info + full response for downstream analysis
print(f"[+] {method} {url}")
print(f"[+] Status: {response.status_code} | Length: {len(response.content)}B | Time: {response.elapsed.total_seconds()}s")
print(f"[+] Headers: {dict(response.headers)}")
