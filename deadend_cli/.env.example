# Copy to .env and adjust. Loaded from current directory or ~/.config/deadend/.env
# See: deadend_cli/__init__.py (_load_env_files)

# --- Phoenix OTLP (optional) ---
# Enable by setting PHOENIX_COLLECTOR_ENDPOINT or DEADEND_PHOENIX_OTEL_ENABLED=true
# If set, traces are sent to Phoenix; otherwise agent uses its own telemetry (stderr/file/OTLP).

# Phoenix server URL. /v1/traces is appended for HTTP. Example:
# PHOENIX_COLLECTOR_ENDPOINT=https://phoenix:6006
# Or enable with default endpoint (http://phoenix:6006/v1/traces):
# DEADEND_PHOENIX_OTEL_ENABLED=true

# Project name in Phoenix (default: deadend)
# PHOENIX_PROJECT_NAME=deadend

# Phoenix API key (if your collector requires auth)
# PHOENIX_API_KEY=your-api-key
