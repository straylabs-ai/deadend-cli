  "components": {
    "schemas": {
      "AddModelRequest": {
        "properties": {
          "provider": {
            "type": "string",
            "title": "Provider",
            "description": "Provider name"
          },
          "model_name": {
            "type": "string",
            "title": "Model Name",
            "description": "Model name"
          },
          "api_key": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Api Key",
            "description": "API key if required"
          },
          "base_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Base Url",
            "description": "Base URL for API if custom"
          },
          "type_model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Type Model",
            "description": "e.g. 'embeddings' for embedding models"
          },
          "vec_dim": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Vec Dim",
            "description": "Vector dimension for embedding models"
          }
        },
        "type": "object",
        "required": [
          "provider",
          "model_name"
        ],
        "title": "AddModelRequest",
        "description": "Add a new model provider."
      },
      "AddModelResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "default": "ok"
          },
          "provider": {
            "type": "string",
            "title": "Provider"
          },
          "model_name": {
            "type": "string",
            "title": "Model Name"
          },
          "type_model": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Type Model"
          }
        },
        "type": "object",
        "required": [
          "provider",
          "model_name"
        ],
        "title": "AddModelResponse",
        "description": "Response after adding a model."
      },
      "AllHealthResult": {
        "properties": {
          "overall_healthy": {
            "type": "boolean",
            "title": "Overall Healthy"
          },
          "components": {
            "items": {
              "$ref": "#/components/schemas/HealthResult"
            },
            "type": "array",
            "title": "Components"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp"
          }
        },
        "type": "object",
        "required": [
          "overall_healthy",
          "components"
        ],
        "title": "AllHealthResult",
        "description": "Combined health check result."
      },
      "AllInitResult": {
        "properties": {
          "overall_success": {
            "type": "boolean",
            "title": "Overall Success"
          },
          "components": {
            "items": {
              "$ref": "#/components/schemas/InitResult"
            },
            "type": "array",
            "title": "Components"
          },
          "failed_components": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Failed Components"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "title": "Timestamp"
          }
        },
        "type": "object",
        "required": [
          "overall_success",
          "components"
        ],
        "title": "AllInitResult",
        "description": "Combined initialization result for all components."
      },
      "ApprovalModeResponse": {
        "properties": {
          "approval_mode": {
            "type": "boolean",
            "title": "Approval Mode"
          }
        },
        "type": "object",
        "required": [
          "approval_mode"
        ],
        "title": "ApprovalModeResponse",
        "description": "Current approval mode status."
      },
      "ApprovalRequest": {
        "properties": {
          "request_id": {
            "type": "string",
            "title": "Request Id",
            "description": "Approval request ID"
          },
          "approved": {
            "type": "boolean",
            "title": "Approved",
            "description": "Whether the action is approved",
            "default": false
          },
          "modified_args": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Modified Args",
            "description": "Optional modified tool arguments"
          }
        },
        "type": "object",
        "required": [
          "request_id"
        ],
        "title": "ApprovalRequest",
        "description": "Request to respond to an approval (approve or reject)."
      },
      "ApprovalResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "request_id": {
            "type": "string",
            "title": "Request Id"
          }
        },
        "type": "object",
        "required": [
          "status",
          "request_id"
        ],
        "title": "ApprovalResponse",
        "description": "Response after responding to an approval."
      },
      "ComponentStatus": {
        "type": "string",
        "enum": [
          "not_initialized",
          "initializing",
          "ready",
          "unhealthy",
          "stopped",
          "error"
        ],
        "title": "ComponentStatus",
        "description": "Component lifecycle states."
      },
      "EmbedTargetRequest": {
        "properties": {
          "target": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Target",
            "description": "Target; can reuse agent's target if same"
          },
          "agent_id": {
