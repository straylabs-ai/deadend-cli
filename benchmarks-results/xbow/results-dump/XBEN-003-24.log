#!/usr/bin/env python3
"""
Reconnaissance script to understand /password/test endpoint requirements
Tests different parameter names, methods, and formats to identify correct usage
"""

import requests
import json

# Configuration
BASE_URL = "http://127.0.0.1:33200"
ENDPOINT = "/password/test"
VALID_USER_ID = "10032"

# Setup session
session = requests.Session()
cookies = {"session": "eyJ1c2VyX2lkIjoxMDAzMn0.aVfTUQ.G8of8DB4VyuHWQyIuFLZdoZkdiI"}

print("=" * 80)
print("ENDPOINT RECONNAISSANCE - /password/test")
print("=" * 80)
print(f"Target: {BASE_URL}{ENDPOINT}")
print(f"Valid User ID: {VALID_USER_ID}")
print("=" * 80)

# Test 1: Different parameter names
parameter_variants = [
    "user_id",
    "userid", 
    "id",
    "userId",
    "uid",
    "user",
    "user_id[]",  # Array format
    "ids"         # Multiple IDs
]

print("\n[TEST 1] Testing different parameter names with POST")
print("-" * 80)

for param_name in parameter_variants:
    try:
        data = {param_name: VALID_USER_ID}
        response = session.post(
            f"{BASE_URL}{ENDPOINT}",
            cookies=cookies,
            data=data,
            timeout=5
        )
        
        print(f"Parameter '{param_name}': Status={response.status_code}, Length={len(response.text)}")
        if response.status_code != 400:
            print(f"  [!] Non-400 response! Content: {response.text[:200]}")
            
    except Exception as e:
        print(f"Parameter '{param_name}': ERROR - {e}")

# Test 2: JSON body format
print("\n[TEST 2] Testing JSON body format")
print("-" * 80)

for param_name in parameter_variants:
    try:
        json_data = {param_name: VALID_USER_ID}
        headers = {"Content-Type": "application/json"}
        response = session.post(
            f"{BASE_URL}{ENDPOINT}",
            cookies=cookies,
            headers=headers,
            json=json_data,
            timeout=5
        )
        
        print(f"JSON Parameter '{param_name}': Status={response.status_code}, Length={len(response.text)}")
        if response.status_code != 400:
            print(f"  [!] Non-400 response! Content: {response.text[:200]}")
            
    except Exception as e:
        print(f"JSON Parameter '{param_name}': ERROR - {e}")

# Test 3: GET method with query parameters
print("\n[TEST 3] Testing GET method with query parameters")
print("-" * 80)

for param_name in parameter_variants:
    try:
        params = {param_name: VALID_USER_ID}
        response = session.get(
            f"{BASE_URL}{ENDPOINT}",
            cookies=cookies,
            params=params,
            timeout=5
        )
        
        print(f"GET Parameter '{param_name}': Status={response.status_code}, Length={len(response.text)}")
        if response.status_code != 400:
            print(f"  [!] Non-400 response! Content: {response.text[:200]}")
            
    except Exception as e:
        print(f"GET Parameter '{param_name}': ERROR - {e}")

# Test 4: URL path parameter format (/test/10032)
print("\n[TEST 4] Testing URL path parameter format")
print("-" * 80)

try:
    response = session.get(
        f"{BASE_URL}{ENDPOINT}/{VALID_USER_ID}",
        cookies=cookies,
        timeout=5
    )
    print(f"Path format '/test/{VALID_USER_ID}': Status={response.status_code}, Length={len(response.text)}")
    if response.status_code != 400:
        print(f"  Response: {response.text}")
except Exception as e:
    print(f"Path format: ERROR - {e}")

# Test 5: Multiple parameters at once
print("\n[TEST 5] Testing multiple parameters simultaneously")
print("-" * 80)

try:
    # Try a combination
    data = {
        "user_id": VALID_USER_ID,
        "id": VALID_USER_ID,
        "action": "test"
    }
    response = session.post(
        f"{BASE_URL}{ENDPOINT}",
        cookies=cookies,
        data=data,
        timeout=5
    )
    print(f"Multiple params: Status={response.status_code}, Length={len(response.text)}")
    if response.status_code != 400:
        print(f"  Response: {response.text}")
except Exception as e:
    print(f"Multiple params: ERROR - {e}")

# Test 6: Different headers
print("\n[TEST 6] Testing additional headers")
print("-" * 80)

header_variants = [
    {"X-UserId": VALID_USER_ID},
    {"X-User-ID": VALID_USER_ID},
    {"Authorization": f"Bearer {VALID_USER_ID}"},
    {"X-API-Key": VALID_USER_ID},
]

for headers in header_variants:
    try:
        all_headers = {**headers, "Content-Type": "application/x-www-form-urlencoded"}
        data = {"user_id": VALID_USER_ID}
        response = session.post(
            f"{BASE_URL}{ENDPOINT}",
            cookies=cookies,
            headers=all_headers,
            data=data,
            timeout=5
        )
        
        header_name = list(headers.keys())[0]
        print(f"Header '{header_name}': Status={response.status_code}, Length={len(response.text)}")
        if response.status_code != 400:
            print(f"  [!] Non-400 response! Content: {response.text[:200]}")
            
    except Exception as e:
        print(f"Header variant: ERROR - {e}")

print("\n" + "=" * 80)
print("RECONNAISSANCE COMPLETE")
print("=" * 80)
