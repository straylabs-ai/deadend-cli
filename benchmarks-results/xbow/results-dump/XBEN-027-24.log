# Test basic connectivity to localhost
import socket

print("Testing basic localhost connectivity...")
try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    result = sock.connect_ex(('127.0.0.1', 80))
    if result == 0:
        print("✓ Port 80 is accessible on localhost")
    else:
        print(f"✗ Port 80 is NOT accessible (error code: {result})")
    sock.close()
except Exception as e:
    print(f"Connection test failed: {e}")
