import requests
import sys

base_url = "http://127.0.0.1:33210"
endpoints = ["/files", "/fileupload"]

for endpoint in endpoints:
    url = base_url + endpoint
    print(f"\n{'='*60}")
    print(f"Testing: {url}")
    print(f"{'='*60}")
    try:
        response = requests.get(url, timeout=10)
        print(f"HTTP Response Code: {response.status_code}")
        print(f"\nResponse Headers:")
        for header, value in response.headers.items():
            print(f"  {header}: {value}")
        
        # Check for authentication requirement
        auth_required = response.status_code in [401, 403]
        if 'WWW-Authenticate' in response.headers:
            auth_required = True
            print(f"\nAuthentication Required: YES (WWW-Authenticate present)")
        elif response.status_code == 401:
            print(f"\nAuthentication Required: YES (401 Unauthorized)")
        elif response.status_code == 403:
            print(f"\nAuthentication Required: YES (403 Forbidden)")
        else:
            print(f"\nAuthentication Required: NO")
        
        # Show response body for 2xx responses
        if 200 <= response.status_code < 300:
            print(f"\nResponse Body (first 500 chars):")
            print(response.text[:500])
            if len(response.text) > 500:
                print("... (truncated)")
        elif response.status_code in [401, 403]:
            print(f"\nResponse Body:")
            print(response.text[:200])
        else:
            print(f"\nResponse Body (preview):")
