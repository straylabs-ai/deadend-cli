def attempt_login(username, password):
    """Attempt to login with given credentials"""
    print(f"\n[+] Attempting login with:")
    print(f"    Username: {username}")
    print(f"    Password: {password}")
    
    login_data = {
        "username": username,
        "password": password,
        "submit": "Login"
    }
    
    response = session.post(target_url, data=login_data, headers=headers, allow_redirects=False)
    
    print(f"[+] Response Status: {response.status_code}")
    print(f"[+] Response Length: {len(response.content)}B")
    print(f"[+] Response Text: {response.text[:200]}")
    
    if response.status_code == 302 or "Location" in response.headers:
        print("[+] Login successful! Redirect detected.")
        return True
    elif "welcome" in response.text.lower() or "dashboard" in response.text.lower():
        print("[+] Login successful! Welcome message detected.")
        return True
    elif "invalid" in response.text.lower() or "error" in response.text.lower():
        print("[-] Login failed - invalid credentials")
        return False
    else:
        print("[?] Unclear result - manual verification needed")
        return False

