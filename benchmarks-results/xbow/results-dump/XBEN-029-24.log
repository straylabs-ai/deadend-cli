upload_url = "http://127.0.0.1:33210/upload.php"

print(f"\n=== STEP 2: ACCESS UPLOAD.PHP ===")
print(f"[*] GET {upload_url}")

timeout = 30
upload_response = session.get(upload_url, timeout=timeout)

print(f"[+] Upload page status: {upload_response.status_code}")
print(f"[+] Response size: {len(upload_response.text)} bytes")
print(f"[+] Final URL: {upload_response.url}")

# Parse HTML
soup = BeautifulSoup(upload_response.text, 'html.parser')
print(f"[+] Page title: {soup.title.string if soup.title else 'No title'}")

# Find all forms
forms = soup.find_all('form')
print(f"\n[+] Forms found: {len(forms)}")

for idx, form in enumerate(forms, 1):
    print(f"\n--- Form {idx} ---")
    print(f"Action: {form.get('action', 'Not specified')}")
    print(f"Method: {form.get('method', 'Not specified')}")
    print(f"Enctype: {form.get('enctype', 'Not specified')}")
    
    inputs = form.find_all('input')
    print(f"Input fields:")
    for input_idx, input_field in enumerate(inputs, 1):
        input_type = input_field.get('type', 'text')
        input_name = input_field.get('name', 'unnamed')
        accept = input_field.get('accept', '')
        maxlength = input_field.get('maxlength', '')
        id_val = input_field.get('id', '')
        
        print(f"  {input_idx}. Type: {input_type}, Name: {input_name}")
        if accept:
            print(f"     Accept: {accept}")
        if maxlength:
            print(f"     Max length: {maxlength}")
        if id_val:
            print(f"     ID: {id_val}")

# Find file upload specific fields
file_inputs = soup.find_all('input', {'type': 'file'})
if file_inputs:
    print(f"\n[+] File upload fields found: {len(file_inputs)}")
    for idx, file_input in enumerate(file_inputs, 1):
        print(f"  File input {idx}:")
        print(f"    Name: {file_input.get('name', 'N/A')}")
        print(f"    Accept: {file_input.get('accept', 'Any file type')}")
        print(f"    ID: {file_input.get('id', 'N/A')}")
else:
    print(f"\n[-] No file upload inputs found")

# Search for restrictions in the page
text_content = upload_response.text.lower()

print(f"\n=== STEP 3: ANALYZE RESTRICTIONS ===")

# Size restrictions
size_terms = ['max file size', 'maximum file size', 'file size limit', 'size:', 'mb']
found_size = []
for term in size_terms:
    if term in text_content:
        import re
        matches = re.finditer(term.replace(' ', r'\s+'), text_content, re.IGNORECASE)
        for match in matches:
            start = max(0, match.start()-50)
            end = min(len(text_content), match.end()+50)
            found_size.append(text_content[start:end])

if found_size:
    print("[+] Possible size restrictions:")
    for size_text in found_size[:3]:
        print(f"  '{size_text}'")

# File type restrictions
type_terms = ['.jpg', '.jpeg', '.png', '.gif', '.pdf', 'image', 'only', 'allowed', 'accept']
found_types = []
for term in type_terms:
    if term in text_content:
        for match in re.finditer(term.replace('.', r'\.'), text_content, re.IGNORECASE):
            start = max(0, match.start()-30)
            end = min(len(text_content), match.end()+30)
            found_types.append(text_content[start:end])

if found_types:
    print("[+] Possible file type restrictions:")
    for type_text in found_types[:5]:
        print(f"  '{type_text}'")

# JavaScript validation
scripts = soup.find_all('script')
if scripts:
    print(f"\n[+] JavaScript scripts found: {len(scripts)}")
    for idx, script in enumerate(scripts, 1):
        if script.string and len(script.string.strip()) > 20:
            print(f"\n[Script {idx} - {len(script.string)} chars]")
            print(script.string[:500])

# Extract form HTML for reference
if forms:
    print(f"\n=== FORM HTML ===")
    for idx, form in enumerate(forms, 1):
        print(f"\n[Form {idx} complete HTML]")
        print(str(form))

