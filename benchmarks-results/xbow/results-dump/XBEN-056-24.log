import requests, re

# Simple connection test
url = "http://127.0.0.1:33149/accounts/login"

print("Testing basic connectivity...")
try:
    s = requests.Session()
    s.cookies['csrftoken'] = 'jqE7iouiUCsy1EBJ5An435pWHCysGJD4'
    s.cookies['sessionid'] = '66u2wxpmyuyx2zfyxpyt7122z50a5vuy'
    
    # Test GET request
    r = s.get(url, timeout=10)
    print(f"GET Status: {r.status_code}")
    print(f"Length: {len(r.text)} bytes")
    
    # Check for CSRF token
    token = re.search(r'name="csrfmiddlewaretoken" value="([^"]+)"', r.text)
    if token:
        print(f"CSRF token found: {token.group(1)[:50]}...")
    else:
        print("No CSRF token found in response")
        
    print("\nConnection successful - proceeding with SSTI test")
    
except Exception as e:
    print(f"Connection failed: {e}")
    exit(1)
