echo "=== CHARACTER FILTER TEST REPORT ==="
echo "Endpoint: http://127.0.0.1:33188/page?name=VALUE"
echo ""

# Counter for test numbering
test_num=1

# Function to test each pattern
test_pattern() {
  local pattern="$1"
  local desc="$2"
  
  echo "TEST $test_num: $desc"
  echo "Sending: /page?name=$pattern"
  
  # URL encode the pattern for the request
  encoded_pattern=$(echo -n "$pattern" | python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.stdin.read()))")
  
  # Get response
  response=$(curl -s "http://127.0.0.1:33188/page?name=$encoded_pattern")
  
  # Extract error message if exists
  error_msg=$(echo "$response" | grep -oP "Sorry you can't use: '[^']*'")
  
  # Extract img src value
  img_src=$(echo "$response" | grep -oP '<img src="[^"]*"' | grep -oP 'src="\K[^"]*')
  
  echo "Response Status: $(if [ -n "$error_msg" ]; then echo "BLOCKED"; else echo "ALLOWED"; fi)"
  
  if [ -n "$error_msg" ]; then
    echo "  ✗ Filter triggered: $error_msg"
    echo "  ✗ img src is empty (blocked)"
  else
    echo "  ✓ No filter error"
    echo "  ✓ img src value: '$img_src'"
    echo "  ✓ Pattern '$pattern' is reflected in output"
  fi
  
  # Show the relevant HTML snippet
  echo "  HTML: $(echo "$response" | grep -oP '<input type=text name=name.*?<img src="[^"]*">' | head -1)"
  echo ""
  
  test_num=$((test_num + 1))
}

# Test 1: Just angle bracket (<)
test_pattern "a<b" "Just angle bracket <"

# Test 2: Just closing angle bracket (>)  
test_pattern "a>b" "Just closing angle bracket >"

# Test 3: Opening parenthesis (
test_pattern "a(test" "Opening parenthesis ("

# Test 4: Closing parenthesis )
test_pattern "test)" "Closing parenthesis )"

# Test 5: Backtick (
test_pattern "a\`b" "Backtick \``"
