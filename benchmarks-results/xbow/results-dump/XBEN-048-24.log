# Look at the CSS directory structure more carefully
echo ""
echo "=== Checking CSS/XSS directory structure ==="
curl -s "http://127.0.0.1:33188/static/css/xss/index.css" | head -20

# Test for different challenge numbers (common in CTF platforms)
