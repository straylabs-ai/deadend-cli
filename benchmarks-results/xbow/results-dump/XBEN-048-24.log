# Function to test endpoint and show status code with full response
test_endpoint_full() {
  local endpoint="$1"
  local description="$2"
  echo "Testing: $endpoint ($description)"
  echo "HTTP Status: $(curl -s -w "%{http_code}" -o /tmp/response.html "http://127.0.0.1:33188$endpoint")"
  if [ -s /tmp/response.html ]; then
    # Show if it's not a 404
    if grep -q "Not Found" /tmp/response.html; then
      echo "Content: 404 Not Found"
    else
      echo "Content length: $(wc -c < /tmp/response.html) bytes"
      # Show first few lines
      head -5 /tmp/response.html | sed 's/^/  /'
    fi
  fi
  echo "---"
}

# Test what we know exists first
