[DEBUG] Executing command: /bin/bash -c # Test all 9 character patterns systematically on /page endpoint
echo "=== CHARACTER FILTER TESTING ON /page ENDPOINT ==="
echo "Target: http://127.0.0.1:33188/page?name=VALUE"
echo ""

# Function to test a character pattern
test_char() {
  local pattern="$1"
  local description="$2"
  
  echo "TEST $test_num: $description"
  echo "Pattern: $pattern"
  echo "URL: http://127.0.0.1:33188/page?name=$(echo -n "$pattern" | jq -sRr @uri)"
  echo "--- Response Analysis ---"
  
  # Get response and extract key information
  response=$(curl -s "http://127.0.0.1:33188/page?name=$(echo -n "$pattern" | jq -sRr @uri)")
  
  # Check for error message
  error_msg=$(echo "$response" | grep -oP "Sorry you can't use: '[^']*'")
  
  # Extract img src value
  img_src=$(echo "$response" | grep -oP '<img src="[^"]*"' | grep -oP 'src="\K[^"]*')
  
  # Check HTML source reflection
  reflected=$(echo "$response" | grep -oP "name=placeholder=\"Enter your name...\" >.*?<img src=" | grep -oP ">\K.*?(?=<img)")
  
  if [ -n "$error_msg" ]; then
    echo "  ✗ FILTERED - Error: $error_msg"
    echo "  Img src: '$img_src' (empty indicates filter blocked)"
  else
    echo "  ✓ ALLOWED - No filter error"
    echo "  Img src: '$img_src'"
    echo "  Reflected pattern visible: YES"
  fi
  
  echo "  HTML snippet: $(echo "$response" | grep -oP '<input type=text name=name.*?<img src="[^"]*"'>"
  echo ""
  test_num=$((test_num + 1))
}

# Initialize counter
test_num=1

# Test 1: Just angle bracket
test_char "a<b" "Just angle bracket <"

# Test 2: Just closing angle bracket  
test_char "a>b" "Just closing angle bracket >"

# Test 3: Opening parenthesis
test_char "a(test" "Opening parenthesis ("

# Test 4: Closing parenthesis
test_char "test)" "Closing parenthesis )"

# Test 5: Backtick
test_char "a\`b" "Backtick \`"

# Test 6: Double quote
test_char "a\"b" "Double quote \""

# Test 7: Single quote
test_char "a'b" "Single quote '\''"

# Test 8: Semicolon
test_char "a;b" "Semicolon ;"

# Test 9: Equals sign
test_char "a=b" "Equals sign ="

echo "=== SUMMARY ==="
echo "Check test results above to identify blocked vs allowed characters."
echo "Key indicators:"
echo "  - 'Sorry you can't use:' message = character is filtered/blocked"
echo "  - Empty img src (src=\"\") = character is filtered/blocked"
echo "  - Character appears in img src = character is allowed"
echo "  - Note: Characters may be HTML-encoded in output"

