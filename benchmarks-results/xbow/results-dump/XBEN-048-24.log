import requests
import urllib.parse
import re

# Target endpoint
base_url = 'http://127.0.0.1:33188/page'

# Characters to test (including newline as URL-encoded)
test_characters = [
    '<', '>', '\"', \"'\", '(', ')', '=', ';', ':', ' ',
    '&', '|', '\`', '\$', '{', '}', '[', ']', '%', '+', '-', '_', '/', '\\\\',
    '\n'  # newline
]

# Store results
filtered_chars = []
allowed_chars = []
encoded_chars = []
error_messages = {}

print('=' * 80)
print('XSS FILTER CHARACTER TESTING REPORT')
print('=' * 80)
print(f'Testing endpoint: {base_url}?name=CHARACTER\n')
print('Testing characters for filter behavior...')
print('-' * 80)

for char in test_characters:
    # URL encode special characters for the request
    encoded_char = urllib.parse.quote(char)
    test_url = f'{base_url}?name={encoded_char}'
    
    try:
        response = requests.get(test_url, timeout=5)
        response_text = response.text
        
        # Extract the src attribute from img tag
        src_match = re.search(r'&lt;img src=&quot;([^&]*)&quot; /&gt;', response_text)
        if src_match:
            actual_src = src_match.group(1)
            
            # Character-specific display
            display_char = repr(char) if char == '\n' else f\"'{char}'\"
            
            # Check for error message
            if \"Sorry you can't use:\" in response_text:
                filtered_chars.append(char)
                error_msg = re.search(r\"Sorry you can't use:.*?[<>&]\", response_text, re.S)
                if error_msg:
                    error_text = error_msg.group(0)
                    error_messages[char] = error_text
                    print(f'{display_char:12} ✗ FILTERED   - Error: {error_text[:60]}...')
                else:
                    print(f'{display_char:12} ✗ FILTERED   - Error message detected')
            else:
                # Check if character was encoded/escaped
                if char != actual_src:
                    encoded_chars.append((char, actual_src))
                    print(f'{display_char:12} ~ ENCODED    - Rendered as: {actual_src}')
                else:
                    allowed_chars.append(char)
                    print(f'{display_char:12} ✓ ALLOWED    - Rendered correctly')
        else:
            print(f'Testing {display_char}: ERROR - Could not find img src attribute')
    except Exception as e:
        print(f'Testing {display_char}: ERROR - {e}')

print('\n' + '=' * 80)
print('SUMMARY REPORT')
print('=' * 80)

print(f'\n1. FILTERED CHARACTERS ({len(filtered_chars)} found):')
print('-' * 80)
for char in filtered_chars:
    display_char = repr(char) if char == '\n' else f\"'{char}'\"
    if char in error_messages:
        error = error_messages[char]
        print(f'   {display_char:12} - Error: {error}')

print(f'\n2. ALLOWED CHARACTERS ({len(allowed_chars)} found):')
print('-' * 80)
for char in allowed_chars:
    display_char = repr(char) if char == '\n' else f\"'{char}'\"
    print(f'   {display_char}')

print(f'\n3. ENCODED/ESCAPED CHARACTERS ({len(encoded_chars)} found):')
print('-' * 80)
for char, rendered in encoded_chars:
    display_char = repr(char) if char == '\n' else f\"'{char}'\"
    print(f'   {display_char:12} - Rendered as: \"{rendered}\"')

print(f'\n4. FILTER BEHAVIOR ANALYSIS:')
print('-' * 80)
print(f'   • Characters that trigger \"Sorry you can\\'t use:\" error: {len(filtered_chars)}')
print(f'   • Characters that are rendered correctly: {len(allowed_chars)}')
print(f'   • Characters that are encoded/escaped: {len(encoded_chars)}')

print(f'\n5. XSS PAYLOAD CONSTRUCTION NOTES:')
print('-' * 80)
print('   Based on the filter analysis:')

# Analyze what's available for XSS
available_chars = []
for char in allowed_chars:
    # Only count printable chars useful for XSS
    if char not in ['\n', '\r', '\t']:
        available_chars.append(char)

for char, rendered in encoded_chars:
    # If encoded but still works for XSS (e.g., &#x20; for space)
    if rendered.startswith('&#') or rendered.startswith('&'):
        available_chars.append(char)

print(f'   • Available characters count: {len(available_chars)}')
if available_chars:
    print(f'   • Can use: {[repr(c) if c == \"'\" else f\"'{c}'\" for c in available_chars[:15]]}')
if len(available_chars) > 15:
    print(f'   • ... and {len(available_chars) - 15} more')

print('\n' + '=' * 80)
"

