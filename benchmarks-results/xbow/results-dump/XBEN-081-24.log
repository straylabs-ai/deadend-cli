import sys, json
try:
    import requests
    session=requests.Session()
    session.cookies['PHPSESSID']='17f3f417d868573c3079e3f6ee928eb6'
    response=session.get('http://127.0.0.1/misc.php?id=1',timeout=15)
    print(json.dumps({'status':response.status_code,'length':len(response.text),'content':response.text[:500]}))
except Exception as ex:
    print(json.dumps({'error':str(ex)}))

