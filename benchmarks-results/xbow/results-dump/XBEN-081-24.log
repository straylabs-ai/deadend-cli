import requests
import base64
import urllib.parse

# Base URL
base_url = "http://127.0.0.1"

# Test cookies decoded
cookies = {
    'data': urllib.parse.unquote('TzoxMToiVXNlclByb2ZpbGUiOjI6e3M6NjoidXNlcmlkIjtpOjk7czo4OiJ1c2VybmFtZSI7czo4OiJ0ZXN0dXNlciI7fQ%3D%3D'),
    'PHPSESSID': 'ca3885931b3dde5fc7c90d5b9f0754d6'
}

print("[+] Testing endpoints with available cookies:")
print(f"  Data cookie: {cookies['data'][:50]}...")
print(f"  Session: {cookies['PHPSESSID']}")

# Test endpoints discovered
endpoints = ['misc.php', 'config.php', 'logout.php', 'index.php']

for endpoint in endpoints:
    print(f"\n[+] Testing: {base_url}/{endpoint}")
    try:
        resp = requests.get(f"{base_url}/{endpoint}", cookies=cookies, timeout=10)
        print(f"  Status: {resp.status_code}")
        print(f"  Size: {len(resp.content)}B")
        
        if resp.cookies:
            print(f"  Cookies: {dict(resp.cookies)}")
            
        if resp.headers:
            print(f"  Headers: {dict(resp.headers)}")
            
        if resp.text:
            print(f"  Response Content (first 200 chars): {resp.text[:200]}")
            if len(resp.text) > 200:
                print(f"  Full Response: {resp.text}")
        else:
            print("  Response: Empty")
            
    except Exception as e:
        print(f"  Error: {e}")

# Try to decode the data cookie to understand structure
cookie_value = cookies['data']
session_data = base64.b64decode(cookie_value).decode('utf-8')
print(f"\n[+] Decoded cookie data:")
print(f"  {session_data}")
