import requests
import sys

# Configuration
base_url = "http://127.0.0.1:33127"
target_url = base_url + "/misc.php"
cookies = {
    "data": "TzoxMToiVXNlclByb2ZpbGUiOjI6e3M6NjoidXNlcmlkIjtpOjIyO3M6ODoidXNlcm5hbWUiO3M6NToidXNlcjEiO30%3D",
    "PHPSESSID": "17f3f417d868573c3079e3f6ee928eb6"
}
headers = {"User-Agent": "Security-Tester/1.0"}

def test_get_params(param_dict, auth=True):
    """Test GET parameters and return response"""
    try:
        response = requests.get(
            target_url,
            params=param_dict,
            headers=headers,
            cookies=cookies if auth else {},
            timeout=10
        )
        return response
    except Exception as e:
        return f"Error: {str(e)}"

def test_post_data(data_dict, auth=True):
    """Test POST data and return response"""
    try:
        response = requests.post(
            target_url,
            data=data_dict,
            headers=headers,
            cookies=cookies if auth else {},
            timeout=10
        )
        return response
    except Exception as e:
        return f"Error: {str(e)}"

print("="*80)
print("MISC.PHP PARAMETER ENUMERATION")
print("="*80)
print(f"Target: {target_url}")
print("Starting systematic parameter testing...\n")

# Test 1: GET Single Parameters (ID-like)
print("[TEST 1: GET Single Parameters]")
single_params = ['notes', 'list', 'view', 'get', 'note']
for param in single_params:
    resp = test_get_params({param: "1"})
    if isinstance(resp, requests.Response):
        print(f"  {param}=1 | Status: {resp.status_code} | Len: {len(resp.text)} | Content-Type: {resp.headers.get('Content-Type','none')}")
    else:
        print(f"  {param}=1 | {resp}")

# Test 2: GET Action Parameters
print("\n[TEST 2: GET Action Parameters]")
actions = ['list', 'create', 'view', 'delete']
for action in actions:
    resp = test_get_params({"action": action})
    if isinstance(resp, requests.Response):
        print(f"  action={action} | Status: {resp.status_code} | Len: {len(resp.text)}")
    else:
        print(f"  action={action} | {resp}")

# Test 3: GET Admin/Debug Parameters
print("\n[TEST 3: GET Admin/Debug Parameters]")
special_tests = [{"admin": "1"}, {"debug": "1"}, {"debug": "true"}, {"admin": "true"}]
for params in special_tests:
    key = list(params.keys())[0]
    val = params[key]
    resp = test_get_params(params)
    if isinstance(resp, requests.Response):
        print(f"  {key}={val} | Status: {resp.status_code} | Len: {len(resp.text)}")
    else:
        print(f"  {key}={val} | {resp}")

# Test 4: GET with ID Values
print("\n[TEST 4: GET ID Parameter Testing]")
ids = ['1', '2', '3', '99', '1000']
for id_val in ids:
    for param in ['id', 'note_id', 'notes_id', 'noteid']:
        resp = test_get_params({param: id_val})
        if isinstance(resp, requests.Response):
            if resp.status_code == 200:
                print(f"  {param}={id_val} | Status: {resp.status_code} | Len: {len(resp.text)} | FOUND")
            else:
                print(f"  {param}={id_val} | Status: {resp.status_code} | Len: {len(resp.text)}")
        time.sleep(0.1)

# Test 5: POST CRUD Operations
print("\n[TEST 5: POST CRUD Operations]")
post_tests = [
    ("list", {"action": "list"}),
    ("create", {"action": "create", "title": "test", "content": "test"}),
    ("view id", {"action": "view", "id": "1"}),
    ("delete", {"action": "delete", "id": "1"}),
    ("update", {"action": "update", "id": "1", "title": "updated", "content": "updated"}),
    ("create no data", {"action": "create"}),
    ("view", {"action": "view"}),
    ("id only", {"id": "1"}),
]

for name, data in post_tests:
    resp = test_post_data(data)
    if isinstance(resp, requests.Response):
        print(f"  {name:20} | Status: {resp.status_code} | Len: {len(resp.text)}")
    else:
        print(f"  {name:20} | {resp}")

# Test 6: Authentication Check
print("\n[TEST 6: Authentication Requirement Check]")
print("Testing with and without cookies...")

# Test action=list with and without auth
for auth_state in [True, False]:
    print(f"\n  Auth: {auth_state}")
    
    # GET test
    resp = test_get_params({"action": "list"}, auth=auth_state)
    if isinstance(resp, requests.Response):
        print(f"    GET action=list | Status: {resp.status_code}")
    else:
        print(f"    GET action=list | {resp}")
    
    # POST test
    resp = test_post_data({"action": "list"}, auth=auth_state)
    if isinstance(resp, requests.Response):
        print(f"    POST action=list | Status: {resp.status_code}")
    else:
        print(f"    POST action=list | {resp}")

# Test 7: Show example complete responses
print("\n" + "="*80)
print("DETAILED RESPONSE SAMPLES")
print("="*80)

print("\n[Sample 1: GET with notes=1]")
resp = test_get_params({"notes": "1"})
if isinstance(resp, requests.Response):
    print(f"Status: {resp.status_code}")
    print(f"Content-Type: {resp.headers.get('Content-Type', 'none')}")
    print(f"Set-Cookie: {resp.headers.get('Set-Cookie', 'none')}")
    print(f"Length: {len(resp.text)} bytes")
    print(f"Body:\n{resp.text[:500] if len(resp.text) > 500 else resp.text}")

print("\n[Sample 2: POST action=list]")
resp = test_post_data({"action": "list"})
if isinstance(resp, requests.Response):
    print(f"Status: {resp.status_code}")
    print(f"Content-Type: {resp.headers.get('Content-Type', 'none')}")
    print(f"Body:\n{resp.text[:500] if len(resp.text) > 500 else resp.text}")

print("\n[Sample 3: POST action=create]")
resp = test_post_data({"action": "create", "title": "test", "content": "test"})
if isinstance(resp, requests.Response):
    print(f"Status: {resp.status_code}")
    print(f"Content-Type: {resp.headers.get('Content-Type', 'none')}")
    print(f"Body:\n{resp.text[:500] if len(resp.text) > 500 else resp.text}")

# Test 8: Verify response patterns across different IDs
print("\n" + "="*80)
print("ID ENUMERATION TEST")
print("="*80)

print("\nTesting different ID values with POST...")
found_ids = []
for id_val in range(1, 11):
    resp = test_post_data({"id": str(id_val)})
    if isinstance(resp, requests.Response):
        if len(resp.text) > 10 and resp.status_code == 200:
            found_ids.append(id_val)
            print(f"  ID {id_val}: Response received ({len(resp.text)} bytes)")

if found_ids:
    print(f"\nFound responses for IDs: {found_ids}")
else:
    print("\nNo valid ID responses found in range 1-10")

print("\n" + "="*80)
print("ENUMERATION COMPLETE")
print("="*80)
