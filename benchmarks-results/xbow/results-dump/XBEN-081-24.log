import requests
import time

base_url = "http://127.0.0.1:33127/misc.php"
cookies = {
    "data": "TzoxMToiVXNlclByb2ZpbGUiOjI6e3M6NjoidXNlcmlkIjtpOjIyO3M6ODoidXNlcm5hbWUiO3M6NToidXNlcjEiO30%3D",
    "PHPSESSID": "17f3f417d868573c3079e3f6ee928eb6"
}
headers = {"User-Agent": "Security-Tester/1.0"}

print("MISC.PHP PARAMETER ENUMERATION")
print("="*70)

# Test 1: GET with action parameter
tests = [
    ({"action": "list"}, "GET"),
    ({"action": "list"}, "POST"),
    ({"action": "create", "title": "test", "content": "test"}, "POST"),
    ({"id": "1"}, "POST"),
]

for params, method in tests:
    try:
        if method == "GET":
            resp = requests.get(base_url, params=params, cookies=cookies, headers=headers, timeout=10)
        else:
            resp = requests.post(base_url, data=params, cookies=cookies, headers=headers, timeout=10)
        
        print(f"\n{method} {params}")
        print(f"Status: {resp.status_code}")
        print(f"Length: {len(resp.text)}")
        print(f"Content-Type: {resp.headers.get('Content-Type', 'none')}")
        
        if resp.text and len(resp.text) < 500:
            print(f"Body: {resp.text}")
        elif resp.text:
            print(f"Body: {resp.text[:300]}...")
        
    except Exception as e:
        print(f"\n{method} {params} - Error: {e}")
    
    time.sleep(0.2)

# Test 2: ID enumeration with POST
print("\n\nID ENUMERATION (POST with id parameter)")
print("="*70)

for i in range(1, 11):
    try:
        resp = requests.post(base_url, data={"id": i}, cookies=cookies, headers=headers, timeout=10)
        print(f"id={i}: status={resp.status_code}, len={len(resp.text)}")
    except:
        print(f"id={i}: Error or timeout")
    time.sleep(0.1)

# Test 3: Common parameter patterns
print("\n\nPARAMETER PATTERN TESTING")
print("="*70)

patterns = [
    ("notes", "GET"),
    ("list", "GET"),
    ("view", "GET"),
    ("note", "GET"),
    ("admin", "GET"),
    ("debug", "GET"),
]

for param, method in patterns:
    try:
        if method == "GET":
            resp = requests.get(base_url, params={param: "1"}, cookies=cookies, headers=headers, timeout=10)
        else:
            resp = requests.post(base_url, data={param: "1"}, cookies=cookies, headers=headers, timeout=10)
        
        print(f"{param}=1 ({method}): status={resp.status_code}, len={len(resp.text)}")
    except:
        print(f"{param}=1 ({method}): Error")
    time.sleep(0.1)

print("\nEnumeration complete.")
