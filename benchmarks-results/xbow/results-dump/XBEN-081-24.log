import requests
import urllib.parse
import sys

# Configuration
base_url = "http://127.0.0.1:33127"
target_endpoint = "/misc.php"
target_url = base_url + target_endpoint
timeout = 10

# Headers
headers = {
    "User-Agent": "Security-Tester/1.0"
}

# Cookies from authentication
cookies = {
    "data": "TzoxMToiVXNlclByb2ZpbGUiOjI6e3M6NjoidXNlcmlkIjtpOjIyO3M6ODoidXNlcm5hbWUiO3M6NToidXNlcjEiO30%3D",
    "PHPSESSID": "17f3f417d868573c3079e3f6ee928eb6"
}

def filter_headers(headers_dict):
    """Filter headers to show only specific ones"""
    filtered = {}
    for key in ['Set-Cookie', 'Content-Type', 'Content-Length']:
        if key in headers_dict:
            filtered[key] = headers_dict[key]
    return filtered

def print_request_details(method, url, params=None, data=None, use_cookies=True):
    """Print request details"""
    print(f"\n{'='*70}")
    print(f"[{method} REQUEST]")
    print(f"URL: {url}")
    if params:
        print(f"Parameters: {params}")
    if data:
        print(f"Data: {data}")
    print(f"Headers: {headers}")
    if use_cookies:
        print(f"Cookies: {cookies}")
    else:
        print(f"Cookies: None (testing without authentication)")

def print_response_details(response, error=None):
    """Print response details"""
    print(f"\n[{response.request.method if response else 'ERROR'} RESPONSE]")
    
    if error:
        print(f"Error: {error}")
    else:
        print(f"Status Code: {response.status_code}")
        print(f"Headers: {filter_headers(dict(response.headers))}")
        print(f"\nBody:")
        if response.text:
            print(response.text)
        else:
            print("(empty)")
        
        print(f"\nContent Length: {len(response.content)} bytes")

def make_get_request(params, use_cookies=True):
    """Make GET request"""
    try:
        req_cookies = cookies if use_cookies else {}
        print_request_details("GET", target_url, params=params, use_cookies=use_cookies)
        
        response = requests.get(
            target_url,
            params=params,
            headers=headers,
            cookies=req_cookies,
            timeout=timeout,
            allow_redirects=False
        )
        
        print_response_details(response)
        return response
        
    except requests.exceptions.Timeout:
        print_response_details(None, error=f"Timeout after {timeout} seconds")
        return None
    except Exception as e:
        print_response_details(None, error=str(e))
        return None

def make_post_request(data, use_cookies=True):
    """Make POST request"""
    try:
        req_cookies = cookies if use_cookies else {}
        print_request_details("POST", target_url, data=data, use_cookies=use_cookies)
        
        response = requests.post(
            target_url,
            data=data,
            headers=headers,
            cookies=req_cookies,
            timeout=timeout,
            allow_redirects=False
        )
        
        print_response_details(response)
        return response
        
    except requests.exceptions.Timeout:
        print_response_details(None, error=f"Timeout after {timeout} seconds")
        return None
    except Exception as e:
        print_response_details(None, error=str(e))
        return None

# Main testing
print("="*70)
print("MISC.PHP PARAMETER ENUMERATION")
print("="*70)
print(f"Target: {target_url}")
print(f"Timeout: {timeout} seconds")

# Test 1: GET with single parameters
print("\n" + "="*70)
print("TEST GROUP 1: GET Single Parameters")
print("="*70)
single_params = ['notes', 'list', 'view', 'get', 'note']
for param in single_params:
    make_get_request({param: "1"})

# Test 2: GET with action parameters
print("\n" + "="*70)
print("TEST GROUP 2: GET Action Parameters")
print("="*70)
actions = ['list', 'create', 'view', 'delete']
for action in actions:
    make_get_request({"action": action})

# Test 3: GET with admin/debug parameters
print("\n" + "="*70)
print("TEST GROUP 3: GET Admin/Debug Parameters")
print("="*70)
special_params = [{"admin": "1"}, {"debug": "1"}, {"debug": "true"}]
for params in special_params:
    make_get_request(params)

# Test 4: GET with combined parameters
print("\n" + "="*70)
print("TEST GROUP 4: GET Combined Parameters")
print("="*70)
combined_tests = [
    {"action": "view", "id": "1"},
    {"action": "delete", "id": "1"},
    {"note": "1", "format": "json"},
    {"view": "1", "admin": "1"}
]
for params in combined_tests:
    make_get_request(params)

# Test 5: POST CRUD operations
print("\n" + "="*70)
print("TEST GROUP 5: POST CRUD Operations")
print("="*70)

post_tests = [
    {"action": "list"},
    {"action": "create", "title": "test", "content": "test"},
    {"id": "1"},
    {"action": "view", "id": "1"},
    {"action": "delete", "id": "1"},
    {"action": "update", "id": "1", "title": "updated", "content": "updated"}
]

for data in post_tests:
    make_post_request(data)

# Test 6: POST without authentication (test auth requirements)
print("\n" + "="*70)
print("TEST GROUP 6: POST Without Authentication")
print("="*70)
make_post_request({"action": "list"}, use_cookies=False)

# Test 7: GET without authentication
print("\n" + "="*70)
print("TEST GROUP 7: GET Without Authentication")
print("="*70)
make_get_request({"action": "list"}, use_cookies=False)

# Summary
print("\n" + "="*70)
print("ENUMERATION COMPLETE")
print("="*70)
print("Check response patterns for parameter handling behavior.")
