import requests
from bs4 import BeautifulSoup, Comment
import re
import json

def analyze_endpoint(url):
    print(f"\n{'='*80}")
    print(f"Analyzing endpoint: {url}")
    print(f"{'='*80}")
    
    try:
        response = requests.get(url, timeout=10)
        response.raise_for_status()
        
        print(f"Status Code: {response.status_code}")
        print(f"Content-Type: {response.headers.get('content-type', 'N/A')}")
        print(f"Content Length: {len(response.text)} bytes")
        
        soup = BeautifulSoup(response.text, 'html.parser')
        
        # Extract forms
        forms = soup.find_all('form')
        print(f"\n[FORMS] Found {len(forms)} form(s)")
        
        form_data = []
        for idx, form in enumerate(forms, 1):
            action = form.get('action', '')
            method = form.get('method', 'GET').upper()
            
            print(f"\n  Form #{idx}:")
            print(f"    Action: {action}")
            print(f"    Method: {method}")
            
            # Extract all input fields
            inputs = form.find_all('input')
            print(f"    Inputs ({len(inputs)}):")
            
            input_data = []
            for input_field in inputs:
                input_info = {
                    'name': input_field.get('name', ''),
                    'type': input_field.get('type', 'text'),
                    'value': input_field.get('value', ''),
                    'placeholder': input_field.get('placeholder', ''),
                    'required': input_field.has_attr('required'),
                    'disabled': input_field.has_attr('disabled'),
                    'pattern': input_field.get('pattern', ''),
                    'maxlength': input_field.get('maxlength', ''),
                    'min': input_field.get('min', ''),
                    'max': input_field.get('max', '')
                }
                
                input_data.append(input_info)
                print(f"      - Input: name={input_info['name']}, type={input_info['type']}, value={input_info['value']}")
            
            # Extract hidden fields separately
            hidden_inputs = [inp for inp in input_data if inp['type'] == 'hidden']
            if hidden_inputs:
                print(f"    Hidden Fields ({len(hidden_inputs)}):")
                for hidden in hidden_inputs:
                    print(f"      - {hidden['name']} = {hidden['value']}")
            
            # Extract select dropdowns
            selects = form.find_all('select')
            print(f"    Selects ({len(selects)}):")
            
            select_data = []
            for select in selects:
                select_info = {
                    'name': select.get('name', ''),
                    'options': []
                }
                
                options = select.find_all('option')
                for option in options:
                    option_value = option.get('value', option.text)
                    option_text = option.text.strip()
                    selected = option.has_attr('selected')
                    select_info['options'].append({
                        'value': option_value,
                        'text': option_text,
                        'selected': selected
                    })
                
                select_data.append(select_info)
                print(f"      - Select name={select_info['name']} with {len(select_info['options'])} options")
            
            # Extract textareas
            textareas = form.find_all('textarea')
            print(f"    Textareas ({len(textareas)}):")
            
            textarea_data = []
            for textarea in textareas:
                textarea_info = {
                    'name': textarea.get('name', ''),
                    'placeholder': textarea.get('placeholder', ''),
                    'required': textarea.has_attr('required'),
                    'disabled': textarea.has_attr('disabled'),
                    'maxlength': textarea.get('maxlength', ''),
                    'rows': textarea.get('rows', ''),
                    'cols': textarea.get('cols', ''),
                    'value': textarea.text.strip()
                }
                
                textarea_data.append(textarea_info)
                print(f"      - Textarea name={textarea_info['name']}")
            
            # Extract buttons
            buttons = form.find_all('button')
            print(f"    Buttons ({len(buttons)}):")
            
            button_data = []
            for button in buttons:
                button_info = {
                    'type': button.get('type', 'submit'),
                    'name': button.get('name', ''),
                    'value': button.get('value', button.text.strip()),
                    'disabled': button.has_attr('disabled')
                }
                
                button_data.append(button_info)
                print(f"      - Button type={button_info['type']}, name={button_info['name']}, value={button_info['value']}")
            
            form_info = {
                'id': idx,
                'action': action,
                'method': method,
                'inputs': input_data,
                'selects': select_data,
                'textareas': textarea_data,
                'buttons': button_data
            }
            form_data.append(form_info)
        
        # Extract links
        links = []
        print(f"\n[LINKS] Extracting all href values...")
        for link in soup.find_all('a', href=True):
            href = link['href']
            text = link.text.strip()
            links.append({'href': href, 'text': text})
            print(f"  - href='{href}' text='{text}'")
        
        # Extract script sources
        scripts = []
        print(f"\n[SCRIPTS] Extracting all script sources...")
        for script in soup.find_all('script', src=True):
            src = script['src']
            scripts.append(src)
            print(f"  - src='{src}'")
        
        # Extract inline scripts
        inline_scripts = []
        for script in soup.find_all('script', src=False):
            if script.string:
                code = script.string.strip()
                if code:
                    inline_scripts.append(code[:200] + '...' if len(code) > 200 else code)
                    print(f"  - Inline script (preview): {code[:100]}...")
        
        # Extract HTML comments
        comments = []
        print(f"\n[HTML COMMENTS] Extracting comments...")
        for comment in soup.find_all(string=lambda text: isinstance(text, Comment)):
            comment_text = comment.strip()
            if comment_text and len(comment_text) > 3:  # Skip short comments
                comments.append(comment_text)
                print(f"  - Comment: {comment_text[:200]}")
        
        # Look for CSRF tokens or security tokens
        csrf_tokens = []
        print(f"\n[CSRF/SECURITY TOKENS] Looking for security tokens...")
        
        # Check hidden inputs for tokens
        for input_field in soup.find_all('input', {'type': 'hidden'}):
            name = input_field.get('name', '').lower()
            if any(token in name for token in ['csrf', 'token', '_token', 'authenticity']):
                csrf_tokens.append({
                    'name': input_field.get('name'),
                    'value': input_field.get('value', ''),
                    'element': 'input'
                })
                print(f"  - Token: {input_field.get('name')}={input_field.get('value')}")
        
        return {
            'url': url,
            'status_code': response.status_code,
            'forms': form_data,
            'links': links,
            'scripts': scripts,
            'inline_scripts': inline_scripts,
            'comments': comments,
            'csrf_tokens': csrf_tokens
        }
        
    except requests.exceptions.RequestException as e:
        print(f"[!] Error fetching {url}: {e}")
        return {'url': url, 'error': str(e)}

# Analyze endpoints
endpoints = [
    'http://127.0.0.1:33204/',
    'http://127.0.0.1:33204/page'
]

results = []
for endpoint in endpoints:
    result = analyze_endpoint(endpoint)
    results.append(result)

print(f"\n{'='*80}")
print("SUMMARY")
print(f"{'='*80}")
for result in results:
    if 'error' in result:
        print(f"[-] {result['url']}: ERROR - {result['error']}")
    else:
        print(f"[+] {result['url']}: {result['status_code']} | Forms: {len(result['forms'])} | Links: {len(result['links'])} | Scripts: {len(result['scripts'])}")
