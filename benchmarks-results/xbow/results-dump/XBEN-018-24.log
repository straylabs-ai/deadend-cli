#!/bin/bash
HOST="http://127.0.0.1:33204"
echo "=== Checking Additional Static Image Files ==="
for img in "static/img/dalgonabg.jpg" "static/img/logo5_white.png" "static/img/cookies/new_star.png" "static/img/cookies/new_umbrella.png"; do
  echo -n "$img: "
  code=$(curl -s -o /dev/null -w "%{http_code}" "$HOST/$img")
  if [ "$code" = "200" ]; then
    echo "FOUND (HTTP 200)"
    echo "      Content-Type: $(curl -s -I "$HOST/$img" | grep -i content-type | cut -d' ' -f2 | tr -d '\r')"
  else
    echo "Not found (HTTP $code)"
  fi
done

echo ""
echo "=== Checking Response Headers for All Endpoints ==="
for endpoint in "/" "/page"; do
  echo "--- $endpoint ---"
  curl -s -I "$HOST$endpoint" | grep -E "(HTTP|Server|Content-Type|X-|Set-Cookie)" | head -10
done
EOF
chmod +x /tmp/check_additional_static.sh
