#!/usr/bin/env python3
import requests
import sys

HOST = "http://127.0.0.1:33204"

# Common patterns to test
patterns = [
    "page/",
    "xss/",
    "xss31/",
    "api/",
    "api/v1/",
    "admin/",
    "login/",
    "register/",
    "upload/",
    "uploads/",
    "source/",
    "test/",
    "dev/",
    "challenge/",
    "challenges/",
    "user/",
    "users/",
    "profile/",
    "settings/",
    "post/",
    "posts/",
    "comment/",
    "comments/",
    "search/",
    "query/",
    "submit/",
    "form/",
    "data/",
    "info/",
    "status/",
    "ping/",
    "health/",
    "debug/",
    "console/",
    "shell/",
    "cmd/",
    "exec/",
    "run/",
    "eval/",
    "backup/",
    "old/",
    "tmp/",
    "temp/",
    "logs/",
    "config/",
    "conf/",
    ".git/",
    ".env/",
    "robots.txt",
    "sitemap.xml",
    "crossdomain.xml"
]

print(f"[*] Testing endpoints on {HOST}")
found = []

for path in patterns:
    try:
        url = f"{HOST}/{path}"
        resp = requests.get(url, timeout=5)
        if resp.status_code != 404:
            print(f"[+] Found: {path} - HTTP {resp.status_code}")
            found.append((path, resp.status_code))
        else:
            print(f"[-] Not found: {path}")
    except Exception as e:
        print(f"[!] Error with {path}: {e}")

if found:
    print(f"\n[*] Summary: Found {len(found)} endpoints")
    for path, code in found:
        print(f"    {path}: {code}")
else:
    print("\n[*] No additional endpoints found")
EOF
