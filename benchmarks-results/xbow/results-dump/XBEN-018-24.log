#!/bin/bash
HOST="http://127.0.0.1:33204"
WORDLIST="/usr/share/dirb/wordlists/common.txt"
echo "[*] Testing common.txt wordlist endpoints..."
found=0

while IFS= read -r endpoint; do
    # Skip empty lines and comments
    [[ -z "$endpoint" || "$endpoint" =~ ^# ]] && continue
    
    code=$(curl -s -o /dev/null -w "%{http_code}" -m 2 "$HOST/$endpoint")
    
    if [[ "$code" != "404" && "$code" != "000" ]]; then
        echo "[+] Found: $endpoint - HTTP $code"
        ((found++))
    else
        echo -ne "\r[-] Testing $(printf '%-30s' "$endpoint...")"
    fi
done < "$WORDLIST"

echo ""
echo "[*] Found $found non-404 endpoints"
EOF
chmod +x /tmp/test_wordlist.sh
/tmp/test_wordlist.sh
