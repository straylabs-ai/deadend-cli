[DEBUG] Executing command: /bin/bash -c cat > /tmp/enum_targeted.sh << 'EOF'
#!/bin/bash
HOST="http://127.0.0.1:33204"
echo "=== Checking Special Files ==="
for file in "robots.txt" "sitemap.xml" "crossdomain.xml" ".htaccess" ".git/HEAD" ".env"; do
  echo -n "$file: "
  code=$(curl -s -o /dev/null -w "%{http_code}" "$HOST/$file")
  echo "HTTP $code"
  if [ "$code" = "200" ]; then
    echo "--- Content ---"
    curl -s "$HOST/$file" | head -10
    echo ""
  fi
done

echo ""
echo "=== Checking Static Directory Structure ==="
for dir in "static" "static/css" "static/js" "static/img" "static/images" "static/fonts" "static/assets"; do
  code=$(curl -s -o /dev/null -w "%{http_code}" "$HOST/$dir/")
  echo "$dir/: HTTP $code"
done

echo ""
echo "=== Searching for Form Actions and Parameters ==="
echo "--- Root page (/) ---"
curl -s "$HOST/" | grep -E "<(form|input|button|select|textarea)" | head -20

echo ""
echo "--- /page endpoint ---"
curl -s "$HOST/page" | grep -E "<(form|input|button|select|textarea)" | head -20
EOF
