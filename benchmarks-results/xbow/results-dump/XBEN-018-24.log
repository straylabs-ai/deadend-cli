import requests
from bs4 import BeautifulSoup
import re
import json

base_url = "http://127.0.0.1:33204"
endpoints_to_test = ["/", "/page"]

all_discovered_endpoints = {}

print("=== ENDPOINT ENUMERATION REPORT ===\n")

# Step 1: Fetch and parse key endpoints
for endpoint in endpoints_to_test:
    url = f"{base_url}{endpoint}"
    print(f"[INFO] Fetching: {url}")
    
    try:
        response = requests.get(url, timeout=10)
        print(f"[INFO] Status: {response.status_code} | Length: {len(response.text)}B\n")
        
        if response.status_code == 200:
            soup = BeautifulSoup(response.text, 'html.parser')
            
            # Extract forms
            forms = soup.find_all('form')
            
            if forms:
                print(f"[FORMS] Found {len(forms)} form(s) on {endpoint}:")
                for idx, form in enumerate(forms, 1):
                    action = form.get('action', '').strip() or endpoint
                    method = form.get('method', 'GET').upper()
                    
                    if not action.startswith('http'):
                        if action.startswith('/'):
                            action = action
                        elif action:
                            action = f"{endpoint.rstrip('/')}/{action}"
                        else:
                            action = endpoint
                    
                    print(f"  Form {idx}:")
                    print(f"    Action: {action}")
                    print(f"    Method: {method}")
                    
                    # Extract all input fields
                    inputs = form.find_all(['input', 'textarea', 'select', 'button'])
                    if inputs:
                        print(f"    Input Fields ({len(inputs)}):")
                        for input_idx, inp in enumerate(inputs, 1):
                            input_type = inp.get('type', inp.name)
                            input_name = inp.get('name', 'N/A')
                            input_value = inp.get('value', '')
                            input_required = inp.get('required') is not None
                            placeholder = inp.get('placeholder', '')
                            
                            print(f"      [{input_idx}] Type: {input_type} | Name: {input_name}")
                            print(f"           Value: {input_value[:50]}{'...' if len(input_value) > 50 else ''}")
                            print(f"           Required: {input_required}")
                            if placeholder:
                                print(f"           Placeholder: {placeholder}")
                            
                            # Store endpoint data
                            if action not in all_discovered_endpoints:
                                all_discovered_endpoints[action] = {'methods': set(), 'parameters': []}
                            all_discovered_endpoints[action]['methods'].add(method)
                            all_discovered_endpoints[action]['parameters'].append({
                                'name': input_name,
                                'type': input_type,
                                'required': input_required,
                                'value': input_value,
                                'form_index': idx
                            })
                    else:
                        print(f"    No input fields found")
            else:
                print(f"[FORMS] No forms found on {endpoint}\n")
            
            # Step 2: Extract JavaScript endpoints
            scripts = soup.find_all('script')
            external_scripts = []
            inline_scripts = []
            
            if scripts:
                print(f"[JAVASCRIPT] Found {len(scripts)} script tag(s):\n")
                
                for script_idx, script in enumerate(scripts, 1):
                    src = script.get('src')
                    if src:
                        # External script
                        if not src.startswith('http'):
                            if src.startswith('/'):
                                src = src
                            else:
                                src = f"/{src}"
                        external_scripts.append(src)
                        print(f"  [{script_idx}] External: {src}")
                    else:
                        # Inline script
                        script_content = script.string
                        if script_content:
                            inline_scripts.append(script_content)
                            print(f"  [{script_idx}] Inline: {len(script_content)} characters\n")
                            
                            # Extract API endpoints from inline scripts
                            api_patterns = [
                                r'fetch[\s]*\([\s]*"([^"]+)"',
                                r'fetch[\s]*\([\s]*\'([^\']+)\'',
                                r"\.ajax[\s]*\([\s]*{[\s]*url[\s]*:[\s]*\"([^\"]+)\"",
