#!/bin/bash
HOST="http://127.0.0.1:33204"
echo "=== Checking Static Resources ==="
echo ""
echo "[1] Main CSS:"
curl -s "$HOST/static/css/style.css" | head -20
echo ""
echo "[2] XSS Index CSS:"
curl -s "$HOST/static/css/xss/index.css" | head -20
echo ""
echo "[3] XSS31 CSS:"
curl -s "$HOST/static/css/xss/xss31.css" | head -20
echo ""
echo "=== Checking for JavaScript files ==="
for js in "static/js/jquery.js" "static/js/main.js" "static/js/app.js" "static/js/xss.js" "static/js/xss31.js" "js/jquery.js" "js/main.js" "js/app.js"; do
    echo -n "$js: "
    code=$(curl -s -o /dev/null -w "%{http_code}" "$HOST/$js")
    if [ "$code" = "200" ]; then
        echo "FOUND (HTTP 200)"
        echo "      Content-Type: $(curl -s -I "$HOST/$js" | grep -i content-type | cut -d' ' -f2)"
    else
        echo "Not found (HTTP $code)"
    fi
done
EOF
chmod +x /tmp/check_static.sh
