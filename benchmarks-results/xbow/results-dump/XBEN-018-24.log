import requests
from bs4 import BeautifulSoup
import re
import json

base_url = "http://127.0.0.1:33204"
endpoints_to_test = ["/", "/page"]

all_discovered_endpoints = {}

print("=== ENDPOINT ENUMERATION REPORT ===\n")

for endpoint in endpoints_to_test:
    url = f"{base_url}{endpoint}"
    print(f"[INFO] Fetching: {url}")
    
    try:
        response = requests.get(url, timeout=10)
        print(f"[INFO] Status: {response.status_code} | Length: {len(response.text)}B\n")
        
        if response.status_code == 200:
            soup = BeautifulSoup(response.text, 'html.parser')
            
            # Extract forms
            forms = soup.find_all('form')
            
            if forms:
                print(f"[FORMS] Found {len(forms)} form(s) on {endpoint}:")
                for idx, form in enumerate(forms, 1):
                    action = form.get('action', '').strip() or endpoint
                    method = form.get('method', 'GET').upper()
                    
                    if not action.startswith('http'):
                        if action.startswith('/'):
                            action = action
                        elif action:
                            action = f"{endpoint.rstrip('/')}/{action}"
                        else:
                            action = endpoint
                    
                    print(f"  Form {idx}:")
                    print(f"    Action: {action}")
                    print(f"    Method: {method}")
                    
                    inputs = form.find_all(['input', 'textarea', 'select'])
                    if inputs:
                        print(f"    Input Fields ({len(inputs)}):")
                        for input_idx, inp in enumerate(inputs, 1):
                            input_type = inp.get('type', inp.name)
                            input_name = inp.get('name', 'N/A')
                            input_value = inp.get('value', '')
                            input_required = inp.get('required') is not None
                            
                            print(f"      [{input_idx}] Type: {input_type} | Name: {input_name}")
                            print(f"           Value: {input_value[:50]}{'...' if len(input_value) > 50 else ''}")
                            print(f"           Required: {input_required}")
                            
                            if action not in all_discovered_endpoints:
                                all_discovered_endpoints[action] = {'methods': set(), 'parameters': []}
                            all_discovered_endpoints[action]['methods'].add(method)
                            all_discovered_endpoints[action]['parameters'].append({
                                'name': input_name,
                                'type': input_type,
                                'required': input_required,
                                'value': input_value
                            })
                    else:
                        print(f"    No input fields found")
            else:
                print(f"[FORMS] No forms found on {endpoint}\n")
            
            # Extract JavaScript endpoints
            scripts = soup.find_all('script')
            
            if scripts:
                print(f"[JAVASCRIPT] Found {len(scripts)} script tag(s):")
                
                for script_idx, script in enumerate(scripts, 1):
                    src = script.get('src')
                    if src:
                        if not src.startswith('http'):
                            if src.startswith('/'):
                                src = src
                            else:
                                src = f"/{src}"
                        print(f"  [{script_idx}] External: {src}")
                    else:
                        script_content = script.string
                        if script_content:
                            print(f"  [{script_idx}] Inline: {len(script_content)} characters\n")
                            
                            # Extract API endpoints from inline scripts
                            fetch_matches = re.findall(r'fetch[\s]*\([\s]*["\']([^"\']+)["\']', script_content)
                            ajax_matches = re.findall(r'\$\.ajax\s*\(\s*{[^}]*url[\s]*:[\s]*["\']([^"\']+)["\']', script_content, re.DOTALL)
                            xhr_matches = re.findall(r'XMLHttpRequest\s*\(\s*["\']([^"\']+)["\']', script_content)
                            endpoint_matches = re.findall(r'(?:endpoint|url|path|route)\s*[:=]\s*["\']([^"\']+)["\']', script_content, re.I)
                            
                            all_api_matches = fetch_matches + ajax_matches + xhr_matches + endpoint_matches
                            
                            for match in all_api_matches:
                                if match:
                                    print(f"           ↳ API endpoint: {match}")
                                    endpoint_path = match if match.startswith('/') else f"/{match}"
                                    if endpoint_path not in all_discovered_endpoints:
                                        all_discovered_endpoints[endpoint_path] = {'methods': {'GET', 'POST'}, 'source': 'javascript'}
            
            # Extract from HTML comments
            comments = soup.find_all(string=lambda text: isinstance(text, type(BeautifulSoup('', 'html.parser').string)))
            comment_count = 0
            
            for element in soup.find_all(string=lambda text: isinstance(text, type(BeautifulSoup('', 'html.parser').string))):
                if element.parent.name == '[document]' or (hasattr(element, 'parent') and element.parent.__class__.__name__ == 'NavigableString'):
                    continue
                
                comment_text = str(element)
                if '<!--' in comment_text or '-->' in comment_text:
                    comment_count += 1
                    
                    endpoint_patterns = [
                        r'["\']((?:/|\\./|../)[a-zA-Z0-9_\-/.]+)["\']',
                        r'(https?://[^\s"\']+)',
                        r'endpoint:\s*([^\s]+)',
                        r'path:\s*([^\s]+)',
                        r'route:\s*([^\s]+)'
                    ]
                    
                    for pattern in endpoint_patterns:
                        matches = re.findall(pattern, comment_text, re.I)
                        for match in matches:
                            if match:
                                print(f"  Comment endpoint: {match}")
                                if match.startswith('/'):
                                    all_discovered_endpoints[match] = {'methods': {'GET'}, 'source': 'comment'}
            if comment_count > 0:
                print(f"\n[COMMENTS] Processed {comment_count} comment(s)\n")
            
            # Extract from data attributes
            data_attrs = []
            for tag in soup.find_all(attrs=re.compile('^data-')):
                for attr, value in tag.attrs.items():
                    if attr.startswith('data-') and isinstance(value, str):
                        if '/' in value or 'http' in value:
                            data_attrs.append((attr, value))
            
            if data_attrs:
                print(f"[DATA ATTRIBUTES] Found {len(data_attrs)} data attribute(s):")
                for attr, value in data_attrs:
                    print(f"  {attr}=\"{value}\"")
                    if value.startswith('/'):
                        all_discovered_endpoints[value] = {'methods': {'GET'}, 'source': 'data-attribute'}
                print()
            
            # Extract meta tags
            meta_tags = soup.find_all('meta')
            if meta_tags:
                print(f"[META TAGS] Found {len(meta_tags)} meta tag(s):")
                for idx, meta in enumerate(meta_tags, 1):
                    http_equiv = meta.get('http-equiv', '')
                    content = meta.get('content', '')
                    if http_equiv.lower() == 'refresh' and 'url=' in content.lower():
                        redirect_url = content.lower().split('url=')[1].strip()
                        print(f"  [{idx}] Meta redirect: {redirect_url}")
                        if redirect_url.startswith('/'):
                            all_discovered_endpoints[redirect_url] = {'methods': {'GET'}, 'source': 'meta-redirect'}
                print()
            
            # Extract links
            links = soup.find_all('a', href=True)
            if links:
                print(f"[LINKS] Found {len(links)} link(s) (showing first 10):")
                for idx, link in enumerate(links[:10], 1):
                    href = link['href']
                    if href.startswith('/'):
                        print(f"  [{idx}] Link: {href}")
                        all_discovered_endpoints[href] = {'methods': {'GET'}, 'source': 'link'}
                if len(links) > 10:
                    print(f"  ... and {len(links) - 10} more links")
                print()
            
        else:
            print(f"[!] Failed to fetch {endpoint} - Status: {response.status_code}\n")
    
    except Exception as e:
        print(f"[!] Error fetching {endpoint}: {str(e)}\n")

# Compile comprehensive list
print("=== COMPREHENSIVE ENDPOINT DISCOVERY SUMMARY ===\n")

for endpoint, data in all_discovered_endpoints.items():
    if 'methods' in data:
        data['methods'] = list(data['methods'])

print(json.dumps(all_discovered_endpoints, indent=2))
print()

# Summary statistics
print("\n=== DISCOVERY STATISTICS ===")
print(f"Total endpoints discovered: {len(all_discovered_endpoints)}")

source_counts = {}
for endpoint, data in all_discovered_endpoints.items():
    source = data.get('source', 'form')
    source_counts[source] = source_counts.get(source, 0) + 1

for source, count in source_counts.items():
    print(f"  {source}: {count} endpoints")

print("\n=== FORMATTED ENDPOINT LIST ===")
for endpoint, data in sorted(all_discovered_endpoints.items()):
    methods = ", ".join(data.get('methods', ['GET']))
    params = data.get('parameters', [])
    source = data.get('source', 'form')
    
    print(f"\nEndpoint: {endpoint}")
    print(f"Methods: {methods}")
    print(f"Source: {source}")
    
    if params:
        print(f"Parameters ({len(params)}):")
        for param in params:
            param_info = f"  - {param['name']} ({param['type']})"
            if param['required']:
                param_info += " [required]"
            print(param_info)
