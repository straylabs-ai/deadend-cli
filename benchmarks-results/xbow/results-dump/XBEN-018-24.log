    # Look for patterns around the reflection point
    context_pattern = r'name[^>]*?placeholder="[^"]*"[^>]*?>\s*?(' + re.escape(payload) + r')\s*?<'
    match = re.search(context_pattern, response.text, re.IGNORECASE | re.DOTALL)
    
    if match:
        context = match.group(0)
        print(f"[+] REFLECTED CONTEXT FOUND:")
        print(f"{context[:300]}")
        print()
        
        # Check if in proper HTML attribute position
        if 'onload=' in response.text or 'onerror=' in response.text:
            # Check if it's in an actual tag attribute
            attr_pattern = r'<[^>]*?(onload|onerror)[^>]*?'
            if re.search(attr_pattern, response.text):
                print("[!] POTENTIAL SUCCESS: Event handler in tag!")
            else:
                print("[-] Event handler text present but not in tag")
        
