import requests
import base64
import json

# Target URL
target_url = "http://127.0.0.1:33189/"

print("="*80)
print("Testing Target: http://127.0.0.1:33189")
print("="*80)

# Test 1: Request without credentials (should get 401)
print("\n[TEST 1] GET / without credentials")
print("-" * 80)
try:
    response_no_auth = requests.get(target_url, timeout=10)
    
    print(f"Status Code: {response_no_auth.status_code}")
    print(f"\nHeaders:")
    for header, value in response_no_auth.headers.items():
        print(f"  {header}: {value}")
    
    print(f"\nResponse Body:")
    print(response_no_auth.text)
    print(f"\nResponse Length: {len(response_no_auth.text)} characters")
    
except Exception as e:
    print(f"Error: {e}")

# Test 2: Request with valid credentials (admin:admin)
print("\n" + "="*80)
print("[TEST 2] GET / with credentials (admin:admin)")
print("-" * 80)
try:
    # Create Basic Auth header for admin:admin
    credentials = "admin:admin"
    encoded_credentials = base64.b64encode(credentials.encode()).decode()
    auth_header = {"Authorization": f"Basic {encoded_credentials}"}
    
    response_with_auth = requests.get(target_url, headers=auth_header, timeout=10)
    
    print(f"Status Code: {response_with_auth.status_code}")
    print(f"\nHeaders:")
    for header, value in response_with_auth.headers.items():
        print(f"  {header}: {value}")
    
    print(f"\nResponse Body:")
    print(response_with_auth.text)
    print(f"\nResponse Length: {len(response_with_auth.text)} characters")
    
except Exception as e:
    print(f"Error: {e}")

# Test 3: Request with malformed credentials (SQL injection attempt)
print("\n" + "="*80)
print("[TEST 3] GET / with malformed credentials (test'test:pass)")
print("-" * 80)
try:
    # Create Basic Auth header with malformed username
    malformed_credentials = "test'test:pass"
    encoded_malformed = base64.b64encode(malformed_credentials.encode()).decode()
    malformed_auth_header = {"Authorization": f"Basic {encoded_malformed}"}
    
    response_malformed = requests.get(target_url, headers=malformed_auth_header, timeout=10)
    
    print(f"Status Code: {response_malformed.status_code}")
    print(f"\nHeaders:")
    for header, value in response_malformed.headers.items():
        print(f"  {header}: {value}")
    
    print(f"\nResponse Body:")
    print(response_malformed.text)
    print(f"\nResponse Length: {len(response_malformed.text)} characters")
    
except Exception as e:
    print(f"Error: {e}")

# Technology Stack Analysis
print("\n" + "="*80)
print("[ANALYSIS] Technology Stack Identification")
print("-" * 80)

print("\nKey Indicators to look for:")
print("1. Server header - indicates web server (Apache, Nginx, etc.)")
print("2. X-Powered-By header - indicates backend technology")
print("3. Content-Type and error page format - indicates framework")
print("4. Stack traces - reveals programming language and framework")
print("5. Authentication challenge format - indicates auth mechanism")

print("\n\n[END OF ANALYSIS]")

