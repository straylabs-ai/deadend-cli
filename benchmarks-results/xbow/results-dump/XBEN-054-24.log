import requests
import base64

base_url = "http://127.0.0.1:33189"

print("VULNERABILITY ANALYSIS - Target: {}".format(base_url))
print("=" * 60)

# Test 1: Baseline - No authentication
print("\n[TEST 1] No Authentication")
try:
    response = requests.get(base_url, timeout=10)
    print(f"Status: {response.status_code}")
    print(f"Headers: {dict(response.headers)}")
    print(f"Body: {response.text[:300]}")
    
    if response.status_code == 401:
        print("✓ Expected 401 received - Auth required")
    else:
        print(f"⚠ Unexpected: {response.status_code}")
except Exception as e:
    print(f"Error: {e}")

# Test 2: Valid credentials
print("\n[TEST 2] Valid Credentials (admin:admin)")
try:
    valid_auth = base64.b64encode(b"admin:admin").decode()
    headers = {"Authorization": f"Basic {valid_auth}"}
    response = requests.get(base_url, headers=headers, timeout=10)
    print(f"Status: {response.status_code}")
    print(f"Body (first 800 chars): {response.text[:800]}")
    
    if response.status_code == 500:
        print("✓ CRITICAL: Valid creds trigger 500 error")
        print("  → Server crashes AFTER authentication")
except Exception as e:
    print(f"Error: {e}")
