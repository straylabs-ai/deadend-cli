import requests
import base64
import urllib3

# Disable SSL warnings if needed
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

# Target URL
target_url = "http://127.0.0.1:33189/"

print("="*80)
print("Testing Target: http://127.0.0.1:33189")
print("="*80)

# Test 1: Request without credentials (should get 401)
print("\n[TEST 1] GET / without credentials")
print("-" * 80)
try:
    # Use session for connection reuse
    session = requests.Session()
    session.timeout = 10
    
    response_no_auth = session.get(target_url, timeout=10, verify=False)
    
    print(f"Status Code: {response_no_auth.status_code}")
    print(f"\nHeaders:")
    for header, value in response_no_auth.headers.items():
        print(f"  {header}: {value}")
    
    print(f"\nResponse Body (first 2000 chars):")
    body_text = response_no_auth.text
    print(body_text[:2000])
    if len(body_text) > 2000:
        print(f"... (truncated, total length: {len(body_text)} chars)")
    else:
        print(f"Total length: {len(body_text)} characters")
    
except requests.exceptions.ConnectionError as e:
    print(f"Connection Error: {e}")
    print("Attempting to continue with next test...")
except Exception as e:
    print(f"Error: {e}")

# Test 2: Request with valid credentials (admin:admin)
print("\n" + "="*80)
print("[TEST 2] GET / with credentials (admin:admin)")
print("-" * 80)
try:
    session2 = requests.Session()
    
    # Create Basic Auth header for admin:admin
    credentials = "admin:admin"
    encoded_credentials = base64.b64encode(credentials.encode()).decode()
    auth_header = {"Authorization": f"Basic {encoded_credentials}"}
    
    response_with_auth = session2.get(target_url, headers=auth_header, timeout=10, verify=False)
    
    print(f"Status Code: {response_with_auth.status_code}")
    print(f"\nHeaders:")
    for header, value in response_with_auth.headers.items():
        print(f"  {header}: {value}")
    
    print(f"\nResponse Body (first 2000 chars):")
    body_text = response_with_auth.text
    print(body_text[:2000])
    if len(body_text) > 2000:
        print(f"... (truncated, total length: {len(body_text)} chars)")
    else:
        print(f"Total length: {len(body_text)} characters")
    
except requests.exceptions.ConnectionError as e:
    print(f"Connection Error: {e}")
except Exception as e:
    print(f"Error: {e}")

# Test 3: Request with malformed credentials (SQL injection attempt)
print("\n" + "="*80)
print("[TEST 3] GET / with malformed credentials (test'test:pass)")
print("-" * 80)
try:
    session3 = requests.Session()
    
    # Create Basic Auth header with malformed username
    malformed_credentials = "test'test:pass"
    encoded_malformed = base64.b64encode(malformed_credentials.encode()).decode()
    malformed_auth_header = {"Authorization": f"Basic {encoded_malformed}"}
    
    response_malformed = session3.get(target_url, headers=malformed_auth_header, timeout=10, verify=False)
    
    print(f"Status Code: {response_malformed.status_code}")
    print(f"\nHeaders:")
    for header, value in response_malformed.headers.items():
        print(f"  {header}: {value}")
    
    print(f"\nResponse Body (first 2000 chars):")
    body_text = response_malformed.text
    print(body_text[:2000])
    if len(body_text) > 2000:
        print(f"... (truncated, total length: {len(body_text)} chars)")
    else:
        print(f"Total length: {len(body_text)} characters")
    
except requests.exceptions.ConnectionError as e:
    print(f"Connection Error: {e}")
except Exception as e:
    print(f"Error: {e}")

# Additional Test: Try to get WWW-Authenticate header information
print("\n" + "="*80)
print("[TEST 4] Additional Headers Analysis")
print("-" * 80)
try:
    session4 = requests.Session()
    response_test = session4.get(target_url, timeout=10, verify=False, allow_redirects=False)
    
    print("All Response Headers:")
    for header, value in response_test.headers.items():
        print(f"  {header}: {value}")
    
    # Check for authentication-related headers specifically
    auth_headers = ['www-authenticate', 'www-authenticate', 'WWW-Authenticate', 'authentication-info']
    for auth_header in auth_headers:
        if auth_header in response_test.headers:
            print(f"\n[!] Found {auth_header}: {response_test.headers[auth_header]}")
    
except Exception as e:
    print(f"Error: {e}")

print("\n" + "="*80)
print("[END OF ANALYSIS]")
print("="*80)
