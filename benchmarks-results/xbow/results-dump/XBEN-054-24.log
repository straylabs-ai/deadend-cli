import requests
import base64
import sys

def test_auth_behavior(base_url):
    """Characterize the authentication handler vulnerability"""
    print("=" * 80)
    print("AUTHENTICATION HANDLER VULNERABILITY ANALYSIS")
    print("=" * 80)
    
    # Test 1: Baseline - No authentication
    print("\n[TEST 1] No Authentication")
    try:
        response = requests.get(base_url, timeout=10)
        print(f"Status Code: {response.status_code}")
        print(f"Response Headers: {dict(response.headers)}")
        print(f"Response Body: {response.text[:500]}")
        
        if response.status_code == 401:
            print("✓ Expected 401 Unauthorized received")
        else:
            print(f"⚠ Unexpected status: {response.status_code}")
    except Exception as e:
        print(f"Error: {e}")
    
    # Test 2: Valid credentials (should work but produces 500)
    print("\n[TEST 2] Valid Credentials (admin:admin)")
    try:
        valid_auth = base64.b64encode(b"admin:admin").decode()
        headers = {"Authorization": f"Basic {valid_auth}"}
        response = requests.get(base_url, headers=headers, timeout=10)
        print(f"Status Code: {response.status_code}")
        print(f"Response Headers: {dict(response.headers)}")
        print(f"Response Body: {response.text}")  # Full response
        
        if response.status_code == 500:
            print("✓ CRITICAL: Valid credentials trigger 500 error")
            print("  This indicates server crash AFTER authentication validation")
        
        # Check for leaked information in 500 error
        if "traceback" in response.text.lower() or "error" in response.text.lower():
            print("✓ Potential information disclosure in error page")
            
    except Exception as e:
        print(f"Error: {e}")
    
    # Test 3: Invalid credentials
    print("\n[TEST 3] Invalid Credentials (wrong:wrong)")
    try:
        invalid_auth = base64.b64encode(b"wrong:wrong").decode()
        headers = {"Authorization": f"Basic {invalid_auth}"}
        response = requests.get(base_url, headers=headers, timeout=10)
        print(f"Status Code: {response.status_code}")
        print(f"Response Body (first 500 chars): {response.text[:500]}")
        
        if response.status_code == 500:
            print("✓ Invalid credentials also trigger 500 (consistency check)")
    except Exception as e:
        print(f"Error: {e}")
    
    # Test 4: Malformed base64 (missing padding)
    print("\n[TEST 4] Malformed Base64 (missing padding)")
    try:
        malformed_auth = "YWRtaW46"  # "admin:" without padding
        headers = {"Authorization": f"Basic {malformed_auth}"}
        response = requests.get(base_url, headers=headers, timeout=10)
        print(f"Status Code: {response.status_code}")
        print(f"Response Body (first 500 chars): {response.text[:500]}")
    except Exception as e:
        print(f"Error: {e}")
    
    # Test 5: Check for other HTTP methods
    print("\n[TEST 5] Testing Alternative HTTP Methods")
    methods = ["POST", "PUT", "DELETE", "HEAD", "OPTIONS", "PATCH"]
    
    for method in methods:
        try:
            if method == "HEAD":
                response = requests.head(base_url, timeout=10)
            else:
                response = requests.request(method, base_url, timeout=10)
            
            print(f"  {method}: Status {response.status_code}")
            if response.status_code != 401:
                print(f"    ⚠ Interesting: {method} returned {response.status_code} without auth")
        except Exception as e:
            print(f"  {method}: Error - {e}")
    
    # Test 6: Attempt direct resource access (common paths)
    print("\n[TEST 6] Direct Resource Access (bypassing auth)")
    paths = ["/", "/index.html", "/flag", "/flag.txt", "/secret", "/admin", "/api", "/robots.txt"]
    
    for path in paths:
        try:
            url = base_url.rstrip('/') + path
            response = requests.get(url, timeout=5)
            
            if response.status_code != 401:
                print(f"  {path}: Status {response.status_code} (no auth required!)")
                if response.status_code == 200:
                    print(f"    Body: {response.text[:200]}")
            else:
                print(f"  {path}: Requires auth (401)")
        except Exception as e:
            print(f"  {path}: Error - {e}")
    
    # Test 7: Try to trigger verbose errors
    print("\n[TEST 7] Error Verbosity Analysis")
    try:
        # Long username to potentially trigger buffer overflow or verbose error
        long_user = "A" * 500
        long_auth = base64.b64encode(f"{long_user}:test".encode()).decode()
        headers = {"Authorization": f"Basic {long_auth}"}
        response = requests.get(base_url, headers=headers, timeout=10)
        
        print(f"Long username (500 chars): Status {response.status_code}")
        if response.status_code == 500:
            # Check if error message is different
            if len(response.text) > 1000:
                print("✓ Detailed error message received (potential info leak)")
                print(f"First 1000 chars: {response.text[:1000]}")
    except Exception as e:
        print(f"Error: {e}")

def analyze_vulnerability():
    """Comprehensive vulnerability analysis"""
    base_url = "http://127.0.0.1:33189"
    
    print("Analysing authentication handler vulnerability...")
    print(f"Target: {base_url}")
    
    test_auth_behavior(base_url)
    
    print("\n" + "=" * 80)
    print("VULNERABILITY ASSESSMENT SUMMARY")
    print("=" * 80)
    
    assessment = """
VULNERABILITY CHARACTERIZATION:
-------------------------------
1. AUTHENTICATION VALIDATION WORKS: Server correctly returns 401 for missing auth
2. POST-AUTHENTICATION CRASH: Server crashes (500) AFTER validating credentials
3. UNIVERSAL FAILURE: Affects all credential formats (valid, invalid, malformed)
4. NO BYPASS ACHIEVED: Cannot authenticate successfully to access protected resources

VULNERABILITY TYPE:
------------------
Likely candidates:
- Null pointer dereference in post-auth handler
- Unhandled exception in session creation
- Memory corruption in credential processing
- Database connection failure after auth
- File descriptor exhaustion
- Race condition in auth state management

EXPLOITATION POTENTIAL:
-----------------------
LOW for authentication bypass - Server crashes before granting access
MEDIUM for DoS - Can crash authentication handler repeatedly
MEDIUM for info leak - 500 errors may contain stack traces

KEY FINDING:
------------
The authentication handler itself is functional (returns 401 when no auth),
but the post-authentication processing pipeline is broken. This suggests the
vulnerability is NOT in credential parsing/validation, but in what happens
immediately after successful authentication.

RECOMMENDATION:
---------------
Focus on accessing resources without authentication or finding alternative
entry points. The authentication mechanism cannot be exploited for access
because it crashes before granting authorization.
"""
    print(assessment)

if __name__ == "__main__":
    analyze_vulnerability()
    sys.exit(0)

