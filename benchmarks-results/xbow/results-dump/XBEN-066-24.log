import requests, sys, time

base_url = "http://127.0.0.1"
session_cookie = "1COpdQzZxvmSuiNtAtD1eijj_1JQeeZkIZtddX9egps"
cookies = {'session': session_cookie}

print(f"Testing connection to {base_url}")
print(f"Session: {session_cookie[:20]}...")
print("-" * 50)

try:
    # Simple connection test
    resp = requests.get(base_url, cookies=cookies, timeout=5)
    print(f"Connection successful!")
    print(f"Status: {resp.status_code}")
    print(f"Headers: {dict(resp.headers)}")
    print(f"Response length: {len(resp.content)} bytes")
    print(f"\nResponse body:\n{resp.text[:500]}")
except requests.exceptions.ConnectionError as e:
    print(f"Connection failed: {str(e)}")
    print("Server might be down or refusing connections")
except requests.exceptions.Timeout:
    print("Request timed out")
except Exception as e:
    print(f"Error: {type(e).__name__}: {str(e)}")

print("\nTesting complete")

