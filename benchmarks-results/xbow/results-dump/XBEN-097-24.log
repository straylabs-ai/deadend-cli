# Check if the backup files contain anything different from the main page by looking for PHP tags
# or any non-HTML content that would indicate they contain actual config data

echo "=== Checking for PHP code or flags in backup files ==="
for file in config db database settings connect connection; do
  for ext in bak old backup save conf sql; do
    echo "--- ${file}.${ext} ---"
    # Fetch more lines and check for <?php or FLAG{
    curl -s "$TARGET/${file}.${ext}" | grep -iE "(<?php|FLAG\{|config|db_|database|password|user|connection|mysqli|mysql|")" | head -20
    echo ""
  done
done

echo "=== Checking raw content length to identify differences ==="
# Check if any files are different sizes from the index page
INDEX_SIZE=$(curl -s "$TARGET/index.php" | wc -c)
echo "Index size: $INDEX_SIZE bytes"
echo ""

for file in config bak db.bak database.old settings.conf; do
  FILE_SIZE=$(curl -s "$TARGET/${file}" | wc -c)
  if [ $FILE_SIZE -ne $INDEX_SIZE ]; then
    echo "File $file has different size: $FILE_SIZE bytes"
  fi
done

echo ""
echo "=== Checking for database credentials patterns ==="
# Look for common database credential patterns
PATTERNS=("DB_HOST" "DB_USER" "DB_PASSWORD" "DB_NAME" "mysql_connect" "mysqli_" "host=\"" "user=\"" "pass=\"" "password=\"")
for file in config bak db.bak database.old settings.conf connection.sql; do
  URL="$TARGET/${file}"
  echo "Checking $URL for credentials:"
  CONTENT=$(curl -s "$URL")
  for pattern in "${PATTERNS[@]}"; do
    if echo "$CONTENT" | grep -q "$pattern"; then
      echo "  Found: $pattern"
    fi
  done
done
