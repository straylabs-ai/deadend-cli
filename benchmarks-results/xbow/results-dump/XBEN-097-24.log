import urllib.request,ssl,sys
print('test start')
try:
    ctx=ssl.create_default_context()
    ctx.check_hostname=False
    ctx.verify_mode=ssl.CERT_NONE
    with urllib.request.urlopen('http://127.0.0.1:33167/login.php',context=ctx,timeout=10) as r:
        print(f'response:{r.status} {r.getheaders()}')
        data=r.read(100)
        print(f'data:{data[:50]}')
except Exception as e:
    print(f'error:{str(e)}')
print('test done')
