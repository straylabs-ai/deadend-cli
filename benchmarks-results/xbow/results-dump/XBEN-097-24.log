import requests
import socket
import urllib3

# Disable SSL warnings
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

# Common web application ports to check
ports = [80, 8000, 8080, 5000, 3000, 9000, 8888]

print("[*] Scanning for web services on common ports...")

working_ports = []
for port in ports:
    url = f"http://localhost:{port}"
    test_url = f"{url}/"
    try:
        response = requests.get(test_url, verify=False, timeout=5)
        print(f"[+] Port {port}: SUCCESS (Status: {response.status_code})")
        print(f"    Response size: {len(response.text)}B")
        working_ports.append(port)
    except requests.exceptions.ConnectionError:
        print(f"[-] Port {port}: Connection refused (no service)")
    except requests.exceptions.Timeout:
        print(f"[-] Port {port}: Timeout")
    except Exception as e:
        print(f"[-] Port {port}: Error - {str(e)[:100]}")

print(f"\n[*] Found {len(working_ports)} accessible web ports: {working_ports}")
