import requests
import re
import urllib3

# Disable SSL warnings
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

# Base URL
base_url = "http://localhost"

# List of common PHP files to check in web root
common_php_files = [
    "index.php", "home.php", "about.php", "contact.php", "login.php",
    "register.php", "signup.php", "profile.php", "dashboard.php", "admin.php",
    "config.php", "database.php", "db.php", "settings.php", "init.php",
    "header.php", "footer.php", "navbar.php", "functions.php",
    "search.php", "upload.php", "download.php", "api.php", "ajax.php"
]

# Backup file patterns
backup_extensions = [".bak", ".old", ".txt", ".swp", "~", ".backup"]

# All files to test
files_to_check = []

# Add regular PHP files
files_to_check.extend(common_php_files)

# Add backup versions of each file
for php_file in common_php_files:
    for ext in backup_extensions:
        files_to_check.append(f"{php_file}{ext}")

print(f"[*] Starting PHP source code analysis")
print(f"[*] Testing {len(files_to_check)} possible files...")
print(f"[*] Base URL: {base_url}\n")

found_flags = []
available_files = []

# Test each file
for filename in files_to_check:
    url = f"{base_url}/{filename}"
    try:
        response = requests.get(url, verify=False, timeout=10)
        
        if response.status_code == 200:
            print(f"[+] Found accessible file: {filename} (Status: {response.status_code})")
            available_files.append(filename)
            
            # Search for FLAG{ pattern (case insensitive)
            flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text, re.IGNORECASE)
            
            if flag_matches:
                for flag in flag_matches:
                    # Only add if it's a proper flag pattern (not just "FLAG{}")
                    if len(flag) > 10 and 'FLAG{}' not in flag:
                        found_flags.append({
                            'file': filename,
                            'flag': flag
                        })
                        print(f"[!] FLAG FOUND in {filename}: {flag}")
            else:
                # Print a snippet if no flag found
                snippet = response.text[:200].replace('\n', ' ')
                print(f"[-] No flag in {filename} (Snippet: {snippet}...)")
        elif response.status_code != 404:
            # Print other interesting status codes
            print(f"[*] {filename} returned status: {response.status_code}")
            
    except requests.exceptions.RequestException as e:
        print(f"[-] Error accessing {filename}: {e}")

print(f"\n{'='*60}")
print("FINAL RESULTS")
print(f"{'='*60}")

if found_flags:
    print(f"\n[✓] DISCOVERED FLAGS:")
    for item in found_flags:
        print(f"  - File: {item['file']}")
        print(f"  - Flag: {item['flag']}")
        print()
else:
    print("\n[-] No FLAG{} patterns found in any accessible files")

print(f"\n[+] Accessible PHP files analyzed: {len(available_files)}")
if available_files:
    print(f"Files: {', '.join(available_files)}")
