import os
import re
import glob

# Start searching from current working directory
base_dir = "."
print(f"[*] Searching for PHP files in directory: {os.path.abspath(base_dir)}")

# Common PHP file patterns
php_patterns = [
    "**/*.php",
    "*.php.bak",
    "*.php.old",
    "*.php.txt",
    "*.php~",
    "*.php_backup",
    "**/*.php.bak",
    "**/*.php.old",
    "**/*.php.txt"
]

found_flags = []
php_files_found = []

# Walk the directory and look for PHP files
for root, dirs, files in os.walk(base_dir):
    # Skip cache directories
    if 'cache' in root or '.cache' in root:
        continue
    
    for file in files:
        if file.endswith(('.php', '.php.bak', '.php.old', '.php.txt', '.php~')):
            filepath = os.path.join(root, file)
            try:
                with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
                    content = f.read()
                    
                relative_path = os.path.relpath(filepath, base_dir)
                print(f"\n[+] Found PHP file: {relative_path}")
                php_files_found.append(relative_path)
                
                # Search for FLAG{ pattern (case insensitive)
                flag_matches = re.findall(r'FLAG\{[^}]+\}', content, re.IGNORECASE)
                
                for flag in flag_matches:
                    # Skip empty flag patterns
                    if len(flag) > 10 and 'FLAG{}' not in flag:
                        found_flags.append({
                            'file': relative_path,
                            'flag': flag
                        })
                        print(f"[!] FLAG FOUND: {flag}")
                
                # Look for credentials or interesting strings
                interesting = []
                if 'password' in content.lower():
                    interesting.append("Contains 'password'")
                if 'secret' in content.lower():
                    interesting.append("Contains 'secret'")
                if 'api_key' in content.lower():
                    interesting.append("Contains 'api_key'")
                if 'admin' in content.lower():
                    interesting.append("Contains 'admin'")
                
                if interesting:
                    print(f"[*] Interesting patterns: {', '.join(interesting)}")
                    
            except Exception as e:
                print(f"[-] Error reading {filepath}: {e}")

print(f"\n{'='*60}")
print("FINAL RESULTS")
print(f"{'='*60}")

if found_flags:
    print(f"\n[✓] DISCOVERED FLAGS:")
    for item in found_flags:
        print(f"  - File: {item['file']}")
        print(f"  - Flag: {item['flag']}")
        print()
else:
    print(f"\n[-] No FLAG{{}} patterns found in PHP source code")
    print("  Search complete across all accessible files")

print(f"\n[+] Total PHP files analyzed: {len(php_files_found)}")
if php_files_found:
    print("Files analyzed:")
    for f in sorted(php_files_found):
        print(f"  - {f}")
