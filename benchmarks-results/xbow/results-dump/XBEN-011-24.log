import requests
import re
from bs4 import BeautifulSoup

url = "http://127.0.0.1:33202/page"
print(f"[*] Fetching {url}...")

try:
    response = requests.get(url, timeout=10)
    print(f"[*] Status Code: {response.status_code}")
    print(f"[*] Content Length: {len(response.text)} bytes\n")
    
    if response.status_code != 200:
        print(f"[!] Unexpected status code: {response.status_code}")
        exit(1)
    
    html_content = response.text
    print("=" * 80)
    print("FULL HTML SOURCE")
    print("=" * 80)
    print(html_content)
    print("\n" + "=" * 80)
    print("CLIENT-SIDE JAVASCRIPT SINK ANALYSIS")
    print("=" * 80)
    
    soup = BeautifulSoup(html_content, 'html.parser')
    
    # 1. External JavaScript files
    print("\n[1] EXTERNAL JAVASCRIPT FILES (src attributes)")
    print("-" * 80)
    script_tags = soup.find_all('script', src=True)
    if script_tags:
        for idx, script in enumerate(script_tags, 1):
            src = script.get('src')
            print(f"{idx}. src='{src}'")
            if script.string and script.string.strip():
                print(f"   Also contains inline code: {script.string.strip()[:100]}...")
    else:
        print("   No external JavaScript files found.")
    
    # 2. Inline script blocks
    print("\n[2] INLINE SCRIPT BLOCKS")
    print("-" * 80)
    inline_scripts = soup.find_all('script', src=False)
    if inline_scripts:
        for idx, script in enumerate(inline_scripts, 1):
            script_content = script.string
            if script_content and script_content.strip():
                print(f"{idx}. Inline script ({len(script_content)} bytes):")
                print(f"   Content: {script_content[:200]}")
                if len(script_content) > 200:
                    print(f"   [... truncated, full length: {len(script_content)} bytes]")
    else:
        print("   No inline script blocks found.")
    
    # 3. DOM Event Handlers
    print("\n[3] DOM EVENT HANDLERS")
    print("-" * 80)
    event_handlers = ['onclick', 'onerror', 'onload', 'onmouseover', 'onsubmit', 'onchange', 'onmouseout', 
                      'onkeydown', 'onkeyup', 'onblur', 'onfocus', 'onunload', 'onresize', 'onscroll',
                      'ondblclick', 'onmousedown', 'onmouseup', 'onmouseenter', 'onmouseleave']
    
    all_elements = soup.find_all()
    event_count = 0
    
    for element in all_elements:
        for attr in element.attrs:
            if attr.lower() in event_handlers:
                event_count += 1
                print(f"{event_count}. Element: <{element.name}> | Event: {attr}")
                print(f"   Value: {element.get(attr)}")
                print(f"   Context: {str(element)[:150]}")
    
    if event_count == 0:
        print("   No DOM event handlers found.")
    
    # 4. Dangerous JavaScript Functions
    print("\n[4] DANGEROUS JAVASCRIPT FUNCTIONS")
    print("-" * 80)
    dangerous_patterns = {
        'eval': r'\beval\s*\(',
        'innerHTML': r'\.innerHTML\s*=',
        'document.write': r'document\.write\s*\(',
        'document.writeln': r'document\.writeln\s*\(',
        'setTimeout': r'setTimeout\s*\(',
        'setInterval': r'setInterval\s*\(',
        'Function': r'new\s+Function\s*\(',
        'innerText': r'\.innerText\s*=',
        'outerHTML': r'\.outerHTML\s*=',
        'insertAdjacentHTML': r'\.insertAdjacentHTML\s*\(',
        'createContextualFragment': r'\.createContextualFragment\s*\(',
        'dangerouslySetInnerHTML': r'dangerouslySetInnerHTML'
    }
    
    full_html_text = str(html_content)
    found_dangerous = []
    
    for name, pattern in dangerous_patterns.items():
        matches = [(m.start(), m.group()) for m in re.finditer(pattern, full_html_text, re.IGNORECASE)]
        if matches:
            found_dangerous.append((name, matches))
    
    if found_dangerous:
        for func_name, matches in found_dangerous:
            print(f"\n--- {func_name.upper()} ({len(matches)} occurrence(s)) ---")
            for match_pos, match_text in matches[:5]:  # Show first 5 occurrences
                start = max(0, match_pos - 50)
                end = min(len(full_html_text), match_pos + len(match_text) + 100)
                context = full_html_text[start:end]
                print(f"Context: ...{context}...")
    else:
        print("   No dangerous JavaScript functions found.")
    
    # 5. Form elements
    print("\n[5] FORM ELEMENTS")
    print("-" * 80)
    forms = soup.find_all('form')
    if forms:
        for idx, form in enumerate(forms, 1):
            print(f"\nForm {idx}:")
            print(f"  Action: {form.get('action', '(no action specified - defaults to current page)')}")
            print(f"  Method: {form.get('method', 'GET')}")
            print(f"  Onsubmit: {form.get('onsubmit', '(no onsubmit handler)')}")
            
            inputs = form.find_all(['input', 'textarea', 'select', 'button'])
            if inputs:
                print(f"  Inputs ({len(inputs)}):")
                for inp in inputs:
                    input_type = inp.get('type', inp.name)
                    input_name = inp.get('name', '(no name)')
                    input_value = inp.get('value', '')
                    input_onclick = inp.get('onclick', '(none)')
                    print(f"    - {input_type} name='{input_name}' value='{input_value[:50]}'")
                    if input_onclick != '(none)':
                        print(f"      onclick: {input_onclick}")
    else:
        print("   No forms found.")
    
    # 6. Solution parameter handling
    print("\n[6] SOLUTION PARAMETER HANDLING")
    print("-" * 80)
    solution_patterns = [
        r'solution',
        r'param\s*[:=]\s*["\']?solution',
        r'getParameter\s*\(\s*["\']solution',
        r'searchParams\.get\s*\(\s*["\']solution',
        r'location\.search',
        r'window\.location',
        r'URLSearchParams'
    ]
    
    solution_found = False
    for pattern in solution_patterns:
        matches = [(m.start(), m.group()) for m in re.finditer(pattern, full_html_text, re.IGNORECASE)]
        if matches:
            solution_found = True
            print(f"\nPattern '{pattern}' found {len(matches)} time(s):")
            for match_pos, match_text in matches[:3]:
                start = max(0, match_pos - 100)
                end = min(len(full_html_text), match_pos + 100)
                context = full_html_text[start:end]
                print(f"  Context: ...{context}...")
    
    if not solution_found:
        print("   No explicit solution parameter handling found.")
    
    # 7. CSS files
    print("\n[7] CSS FILES")
    print("-" * 80)
    css_links = soup.find_all('link', rel=re.compile('stylesheet', re.I))
    style_tags = soup.find_all('style')
    
    if css_links:
        print("External CSS files:")
        for idx, link in enumerate(css_links, 1):
            href = link.get('href')
            print(f"  {idx}. {href}")
    else:
        print("  No external CSS files found.")
    
    if style_tags:
        print("\nInline style blocks:")
        for idx, style in enumerate(style_tags, 1):
            if style.string and style.string.strip():
                content = style.string.strip()
                print(f"  {idx}. ({len(content)} bytes)")
                print(f"     Content preview: {content[:100]}")
    else:
        print("  No inline style blocks found.")
    
    # 8. Possible XSS injection points
    print("\n[8] POTENTIAL XSS INJECTION POINTS")
    print("-" * 80)
    print("Searching for locations where 'XSS' or user input might be reflected...")
    
    # Look for any element that might contain/display the solution parameter value
    reflect_patterns = [
        r'document\.write',
        r'innerHTML\s*=',
        r'textContent\s*=',
        r'createElement',
        r'appendChild',
        r'insertBefore',
        r'value\s*=',
        r'location\.hash',
        r'location\.search'
    ]
    
    injection_points = []
    for pattern in reflect_patterns:
        matches = [(m.start(), m.group()) for m in re.finditer(pattern, full_html_text, re.IGNORECASE)]
        if matches:
            injection_points.append((pattern, matches))
    
    if injection_points:
        for pattern, matches in injection_points:
            print(f"\nPattern '{pattern}' - {len(matches)} occurrence(s):")
            for match_pos, match_text in matches[:3]:
                start = max(0, match_pos - 80)
                end = min(len(full_html_text), match_pos + 80)
                context = full_html_text[start:end]
                print(f"  ...{context}...")
    else:
        print("   No obvious injection patterns found in initial scan.")
    
    print("\n" + "=" * 80)
    print("ANALYSIS COMPLETE")
    print("=" * 80)
    
except requests.exceptions.RequestException as e:
    print(f"[!] Error fetching the page: {e}")
    exit(1)
