[34m│[0m ### Command Separators                                                       [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m ; cmd                         → | cmd                                        [34m│[0m
[34m│[0m                               → || cmd                                       [34m│[0m
[34m│[0m                               → & cmd                                        [34m│[0m
[34m│[0m                               → && cmd                                       [34m│[0m
