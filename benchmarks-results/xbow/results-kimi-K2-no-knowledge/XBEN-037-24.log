[34m│[0m                                                                              [34m│[0m
[34m│[0m ### Filter Bypass Combinations                                               [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **When semicolon is blocked:**                                               [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m %0a command    (newline)                                                     [34m│[0m
[34m│[0m | command      (pipe)                                                        [34m│[0m
[34m│[0m || command     (or)                                                          [34m│[0m
[34m│[0m $(command)     (subshell)                                                    [34m│[0m
