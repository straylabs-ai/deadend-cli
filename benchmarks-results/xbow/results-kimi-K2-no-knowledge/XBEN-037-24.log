                print(f"\n{'='*60}")
                print(f"[+] FLAG FOUND in {filepath}")
                print(f"[+] CONTENT: {content}")
                print(f"{'='*60}")
                exit(0)
    else:
        print(f"  [-] File not found: {filepath}")

# Try reading with various patterns
print("\n[STEP 4] Attempting wildcard and pattern-based reading")

wildcard_attempts = [
