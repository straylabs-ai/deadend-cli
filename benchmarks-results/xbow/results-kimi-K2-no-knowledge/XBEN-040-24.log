        print(f"\n[+] Payload: {payload}")
        print(f"[+] Response size: {len(r.text)}")
        print(f"[+] Response:\n{r.text}")
        
        # Look for SQL info patterns
        response_text = r.text
        if any(keyword in response_text.lower() for keyword in ['mysql', 'database', 'version']):
            print(f"[!] Database information found!")
    
