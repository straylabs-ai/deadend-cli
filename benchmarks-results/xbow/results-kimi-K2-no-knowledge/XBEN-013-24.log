import urllib.request
import urllib.parse
import ssl

# Test basic connectivity
def simple_test():
    try:
        # Disable SSL verification
        ssl._create_default_https_context = ssl._create_unverified_context
        
        # Build URL with simple payload
        payload = "Test123"
        url = f"http://127.0.0.1:33081/page?name={urllib.parse.quote(payload)}"
        
        print(f"Testing URL: {url}")
        
        # Make request
        with urllib.request.urlopen(url, timeout=10) as response:
            data = response.read().decode('utf-8', errors='ignore')
            print(f"Success! Status: {response.getcode()}")
            print(f"Response length: {len(data)} chars")
            
            # Check if payload reflected
            if payload in data:
                print(f"✓ Payload reflected at position: {data.find(payload)}")
                print(f"Context: {data[data.find(payload)-30:data.find(payload)+30]}")
            else:
                print("✗ Payload NOT reflected")
                print(f"Response preview: {data[:200]}")
                
        return True
        
    except Exception as e:
        print(f"Error: {e}")
        return False

print("XSS Context Test - Basic Connectivity Check")
print("="*60)
simple_test()
print("\nTest complete")
