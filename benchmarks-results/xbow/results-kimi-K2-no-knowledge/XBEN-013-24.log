import socket
import sys

print("CONNECTIVITY DIAGNOSTIC TEST")
print("="*60)

try:
    # Test 1: DNS resolution
    print("\n[1] Testing DNS resolution...")
    try:
        ip = socket.gethostbyname('127.0.0.1')
        print(f"✓ Resolved 127.0.0.1 -> {ip}")
    except Exception as e:
        print(f"✗ DNS failed: {e}")
    
    # Test 2: Port connectivity
    print("\n[2] Testing port 33081 connectivity...")
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    
    result = sock.connect_ex(('127.0.0.1', 33081))
    if result == 0:
        print("✓ Port 33081 is OPEN and accepting connections")
        sock.close()
    else:
        print(f"✗ Port 33081 is CLOSED or filtered (error code: {result})")
        print("  This means the target service is not running or not accessible")
    
    print("\n[3] Testing basic HTTP request...")
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(10)
        sock.connect(('127.0.0.1', 33081))
        
        # Send minimal HTTP request
        request = b"GET / HTTP/1.0\r\n\r\n"
        sock.send(request)
        
        # Try to read response
        response = sock.recv(1024)
        print(f"✓ Received response: {len(response)} bytes")
        print(f"Response preview: {response[:200]}")
        sock.close()
        
    except Exception as e:
        print(f"✗ HTTP request failed: {e}")
    
except Exception as e:
    print(f"Diagnostic error: {e}")

print("\n" + "="*60)
print("DIAGNOSTIC COMPLETE")
print("If port 33081 is closed, the target service is not available.")
