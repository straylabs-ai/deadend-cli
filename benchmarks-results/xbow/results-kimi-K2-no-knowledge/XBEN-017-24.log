                    vuln_score = 0.7
                elif re.search(r'<\s*script[^>]*>[^<]*' + re.escape(get_marker), response.text):
                    sink_type = "JavaScript Context"
                    vuln_score = 0.9
                elif re.search(r'<[^>]*>[^<]*' + re.escape(get_marker), context):
                    sink_type = "HTML Body"
                    vuln_score = 0.6
                else:
                    sink_type = "Text Content"
                    vuln_score = 0.3
                
                print(f"Sink Type: {sink_type}")
                print(f"Vulnerability Score: {vuln_score}")
                
                results.append({
