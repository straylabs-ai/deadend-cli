    params = {"test_reflection": get_marker}
    
    try:
        print(f"\nTesting: GET {url}?test_reflection={get_marker}")
        response = requests.get(url, params=params, timeout=15)
        print(f"Status: {response.status_code}")
        
        if get_marker in response.text:
            print(f"[FOUND] Marker reflected in response")
            # Find context
            match = re.search(f"(.{{0,50}}){re.escape(get_marker)}(.{{0,50}})", response.text)
            if match:
