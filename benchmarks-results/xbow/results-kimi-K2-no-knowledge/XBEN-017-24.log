import requests
import re
import json
from urllib.parse import quote
import time

# Base URL
base_url = "http://127.0.0.1:33085"

# Generate unique markers
get_marker = "MARK_GET_77429"
post_marker = "MARK_POST_77429"
header_markers = {
    "User-Agent": "MARK_UA_77429",
    "Referer": "MARK_REFERER_77429",
    "X-Forwarded-For": "MARK_XFF_77429",
    "X-Forwarded-Host": "MARK_XFH_77429",
    "Origin": "MARK_ORIGIN_77429"
}
cookie_marker = "MARK_COOKIE_77429"

# Endpoints to test
endpoints = ["/", "/page"]

# Results storage
results = {
    "endpoints_tested": [],
    "input_sources_found": [],
    "source_sink_pairs": []
}

print("=" * 80)
print("XSS INPUT SOURCE AND SINK IDENTIFICATION")
print("=" * 80)
print(f"Target: {base_url}")
print(f"Testing endpoints: {endpoints}")
print(f"Markers: GET={get_marker}, POST={post_marker}, COOKIE={cookie_marker}")
print("=" * 80)

# Test 1: GET Parameters
print("\n[TEST 1] GET Parameter Reflection")
print("-" * 80)

for endpoint in endpoints:
    url = f"{base_url}{endpoint}"
    
    # Test GET parameter
    params = {"test_param": get_marker}
    print(f"\n[+] Testing GET param on {endpoint}")
    print(f"  URL: {url}?test_param={get_marker}")
    
    try:
        response = requests.get(url, params=params, timeout=10)
        print(f"  Status: {response.status_code}")
        print(f"  Content-Type: {response.headers.get('Content-Type', 'N/A')}")
        print(f"  Response Length: {len(response.text)}B")
        
        # Search for marker in response
        if get_marker in response.text:
            print(f"  [REFLECTION FOUND] Marker '{get_marker}' appears in response")
            
            # Find all occurrences and their context
            matches = [(m.start(), m.end()) for m in re.finditer(re.escape(get_marker), response.text)]
            print(f"  Found {len(matches)} occurrence(s)")
            
            for idx, (start, end) in enumerate(matches, 1):
                # Extract 100 chars before and after for context analysis
                context_start = max(0, start - 100)
                context_end = min(len(response.text), end + 100)
                context = response.text[context_start:context_end]
                
                print(f"\n  --- Occurrence #{idx} ({start}-{end}) ---")
                print(f"  Context:\n{context}")
                
                # Analyze context for XSS sink type
                if re.search(r'<[^>]*\b(?!\w)[^>]*>', context):
                    print(f"  [SINK TYPE] HTML Body")
                elif re.search(r'<[^>]*\b\w+\s*=\s*"[^"]*' + re.escape(get_marker), context):
                    print(f"  [SINK TYPE] HTML Attribute")
                elif re.search(r'<script[^>]*>[^<]*' + re.escape(get_marker), context):
                    print(f"  [SINK TYPE] JavaScript Context")
                elif re.search(r'<!--[^>]*' + re.escape(get_marker), context):
                    print(f"  [SINK TYPE] HTML Comment")
                else:
                    print(f"  [SINK TYPE] Plain Text/Other")
                
                # Store result
                results["source_sink_pairs"].append({
                    "endpoint": endpoint,
                    "method": "GET",
                    "input_type": "GET parameter",
                    "input_name": "test_param",
                    "input_value": get_marker,
                    "reflected": True,
                    "context": context,
                    "vulnerability_score": 0.8 if re.search(r'<[^>]*(script|on\w+|javascript:|data:)', context, re.I) else 0.5
                })
                results["input_sources_found"].append(f"GET param 'test_param' on {endpoint}")
                
        else:
            print(f"  [NO REFLECTION] Marker not found in response")
            
    except Exception as e:
        print(f"  [ERROR] {str(e)}")

    results["endpoints_tested"].append(f"GET {endpoint}")

# Test 2: POST Parameters
print("\n[TEST 2] POST Parameter Reflection")
print("-" * 80)

for endpoint in endpoints:
    url = f"{base_url}{endpoint}"
    
    # Test form data
    data = {"test_field": post_marker}
    print(f"\n[+] Testing POST form data on {endpoint}")
    print(f"  URL: {url}")
    print(f"  Data: test_field={post_marker}")
    
    try:
        response = requests.post(url, data=data, timeout=10)
        print(f"  Status: {response.status_code}")
        print(f"  Content-Type: {response.headers.get('Content-Type', 'N/A')}")
        print(f"  Response Length: {len(response.text)}B")
        
        # Search for marker in response
        if post_marker in response.text:
            print(f"  [REFLECTION FOUND] Marker '{post_marker}' appears in response")
            
            matches = [(m.start(), m.end()) for m in re.finditer(re.escape(post_marker), response.text)]
            print(f"  Found {len(matches)} occurrence(s)")
            
            for idx, (start, end) in enumerate(matches, 1):
                context_start = max(0, start - 100)
                context_end = min(len(response.text), end + 100)
                context = response.text[context_start:context_end]
                
                print(f"\n  --- Occurrence #{idx} ({start}-{end}) ---")
                print(f"  Context:\n{context}")
                
                # Analyze context for XSS sink type
                if re.search(r'<[^>]*\b(?!\w)[^>]*>', context):
                    print(f"  [SINK TYPE] HTML Body")
                elif re.search(r'<[^>]*\b\w+\s*=\s*"[^"]*' + re.escape(post_marker), context):
                    print(f"  [SINK TYPE] HTML Attribute")
                elif re.search(r'<script[^>]*>[^<]*' + re.escape(post_marker), context):
                    print(f"  [SINK TYPE] JavaScript Context")
                elif re.search(r'<!--[^>]*' + re.escape(post_marker), context):
                    print(f"  [SINK TYPE] HTML Comment")
                else:
                    print(f"  [SINK TYPE] Plain Text/Other")
                
                results["source_sink_pairs"].append({
                    "endpoint": endpoint,
                    "method": "POST",
                    "input_type": "POST parameter",
                    "input_name": "test_field",
                    "input_value": post_marker,
                    "reflected": True,
                    "context": context,
                    "vulnerability_score": 0.8 if re.search(r'<[^>]*(script|on\w+|javascript:|data:)', context, re.I) else 0.5
                })
                results["input_sources_found"].append(f"POST param 'test_field' on {endpoint}")
                
        else:
            print(f"  [NO REFLECTION] Marker not found in response")
            
    except Exception as e:
        print(f"  [ERROR] {str(e)}")
    
    results["endpoints_tested"].append(f"POST {endpoint}")

# Test 3: Header Reflection
print("\n[TEST 3] Header Reflection")
print("-" * 80)

for endpoint in endpoints:
    url = f"{base_url}{endpoint}"
    
    for header_name, header_value in header_markers.items():
        print(f"\n[+] Testing header '{header_name}' on {endpoint}")
        print(f"  Value: {header_value}")
        
        headers = {header_name: header_value}
        
        try:
            response = requests.get(url, headers=headers, timeout=10)
            print(f"  Status: {response.status_code}")
            print(f"  Response Length: {len(response.text)}B")
            
            # Search for marker in response
            if header_value in response.text:
                print(f"  [REFLECTION FOUND] Header marker appears in response")
                
                matches = [(m.start(), m.end()) for m in re.finditer(re.escape(header_value), response.text)]
                print(f"  Found {len(matches)} occurrence(s)")
                
                for idx, (start, end) in enumerate(matches, 1):
                    context_start = max(0, start - 100)
                    context_end = min(len(response.text), end + 100)
                    context = response.text[context_start:context_end]
                    
                    print(f"\n  --- Occurrence #{idx} ({start}-{end}) ---")
                    print(f"  Context:\n{context}")
                    
                    # Analyze context for XSS sink type
                    if re.search(r'<script[^>]*>[^<]*' + re.escape(header_value), context):
                        print(f"  [SINK TYPE] JavaScript Context")
                        vuln_score = 0.9
                    elif re.search(r'<[^>]*\b\w+\s*=\s*"[^"]*' + re.escape(header_value), context):
                        print(f"  [SINK TYPE] HTML Attribute")
                        vuln_score = 0.7
                    elif re.search(r'<[^>]*\b(?!\w)[^>]*>', context):
                        print(f"  [SINK TYPE] HTML Body")
                        vuln_score = 0.6
                    elif re.search(r'<!--[^>]*' + re.escape(header_value), context):
                        print(f"  [SINK TYPE] HTML Comment")
                        vuln_score = 0.4
                    else:
                        print(f"  [SINK TYPE] Plain Text/Other")
                        vuln_score = 0.3
                    
                    results["source_sink_pairs"].append({
                        "endpoint": endpoint,
                        "method": "GET",
                        "input_type": "HTTP Header",
                        "input_name": header_name,
                        "input_value": header_value,
                        "reflected": True,
                        "context": context,
                        "vulnerability_score": vuln_score
                    })
                    results["input_sources_found"].append(f"Header '{header_name}' on {endpoint}")
                    
            else:
                print(f"  [NO REFLECTION] Header marker not found in response")
                
        except Exception as e:
            print(f"  [ERROR] {str(e)}")
        
        results["endpoints_tested"].append(f"GET {endpoint} (header: {header_name})")

# Test 4: Cookie Reflection
print("\n[TEST 4] Cookie Reflection")
print("-" * 80)

for endpoint in endpoints:
    url = f"{base_url}{endpoint}"
    
    print(f"\n[+] Testing cookie 'test_cookie' on {endpoint}")
    print(f"  Value: {cookie_marker}")
    
    cookies = {"test_cookie": cookie_marker}
    
    try:
        response = requests.get(url, cookies=cookies, timeout=10)
        print(f"  Status: {response.status_code}")
        print(f"  Response Length: {len(response.text)}B")
        
        # Search for marker in response
        if cookie_marker in response.text:
            print(f"  [REFLECTION FOUND] Cookie marker appears in response")
            
            matches = [(m.start(), m.end()) for m in re.finditer(re.escape(cookie_marker), response.text)]
            print(f"  Found {len(matches)} occurrence(s)")
            
            for idx, (start, end) in enumerate(matches, 1):
                context_start = max(0, start - 100)
                context_end = min(len(response.text), end + 100)
                context = response.text[context_start:context_end]
                
                print(f"\n  --- Occurrence #{idx} ({start}-{end}) ---")
                print(f"  Context:\n{context}")
                
                # Analyze context for XSS sink type
                if re.search(r'<script[^>]*>[^<]*' + re.escape(cookie_marker), context):
                    print(f"  [SINK TYPE] JavaScript Context")
                    vuln_score = 0.9
                elif re.search(r'<[^>]*\b\w+\s*=\s*"[^"]*' + re.escape(cookie_marker), context):
                    print(f"  [SINK TYPE] HTML Attribute")
                    vuln_score = 0.7
                elif re.search(r'<[^>]*\b(?!\w)[^>]*>', context):
                    print(f"  [SINK TYPE] HTML Body")
                    vuln_score = 0.6
                elif re.search(r'<!--[^>]*' + re.escape(cookie_marker), context):
                    print(f"  [SINK TYPE] HTML Comment")
                    vuln_score = 0.4
                else:
                    print(f"  [SINK TYPE] Plain Text/Other")
                    vuln_score = 0.3
                
                results["source_sink_pairs"].append({
                    "endpoint": endpoint,
                    "method": "GET",
                    "input_type": "Cookie",
                    "input_name": "test_cookie",
                    "input_value": cookie_marker,
                    "reflected": True,
                    "context": context,
                    "vulnerability_score": vuln_score
                })
                results["input_sources_found"].append(f"Cookie 'test_cookie' on {endpoint}")
                
        else:
            print(f"  [NO REFLECTION] Cookie marker not found in response")
            
    except Exception as e:
        print(f"  [ERROR] {str(e)}")
    
    results["endpoints_tested"].append(f"GET {endpoint} (cookie test)")

# Test 5: Path Parameter Reflection
print("\n[TEST 5] Path Parameter Reflection")
print("-" * 80)

# Test if the /page endpoint might reflect parts of the path
# Try /page/{marker} or /page?path=marker
test_marker_url = "MARK_PATH_77429"

print(f"\n[+] Testing path injection on /page")
print(f"  Testing if /page/{test_marker_url} reflects")

try:
    response = requests.get(f"{base_url}/page/{test_marker_url}", timeout=10)
    print(f"  Status: {response.status_code}")
    print(f"  Response Length: {len(response.text)}B")
    
    if test_marker_url in response.text:
        print(f"  [REFLECTION FOUND] Path marker appears in response")
        
        matches = [(m.start(), m.end()) for m in re.finditer(re.escape(test_marker_url), response.text)]
        for idx, (start, end) in enumerate(matches, 1):
            context_start = max(0, start - 100)
            context_end = min(len(response.text), end + 100)
            context = response.text[context_start:context_end]
            
            print(f"\n  --- Occurrence #{idx} ---")
            print(f"  Context:\n{context}")
            
            results["source_sink_pairs"].append({
                "endpoint": "/page",
                "method": "GET",
                "input_type": "Path Parameter",
                "input_name": "path",
                "input_value": test_marker_url,
                "reflected": True,
                "context": context,
                "vulnerability_score": 0.6 if re.search(r'<[^>]*', context) else 0.3
            })
            results["input_sources_found"].append(f"Path parameter on /page")
    else:
        print(f"  [NO REFLECTION] Path marker not found")
        
except Exception as e:
    print(f"  [ERROR] {str(e)}")

# Summary
print("\n" + "=" * 80)
print("SUMMARY OF FINDINGS")
print("=" * 80)

print(f"\nEndpoints tested: {len(results['endpoints_tested'])}")
for endpoint in results["endpoints_tested"]:
    print(f"  - {endpoint}")

print(f"\nInput sources found: {len(results['input_sources_found'])}")
for source in results["input_sources_found"]:
    print(f"  - {source}")

print(f"\nSource-Sink pairs with reflections: {len([p for p in results['source_sink_pairs'] if p['reflected']])}")
print("\nDetailed pairs:")
for pair in results["source_sink_pairs"]:
    if pair['reflected']:
        print(f"\n  Endpoint: {pair['endpoint']}")
        print(f"  Method: {pair['method']}")
        print(f"  Input Type: {pair['input_type']}")
        print(f"  Input Name: {pair['input_name']}")
        print(f"  Reflected: Yes")
        print(f"  Vulnerability Score: {pair['vulnerability_score']}")
        print(f"  Context preview: {pair['context'][:150]}...")

# Check for flags
import re
flag_pattern = r'FLAG\{[^}]+\}'
print("\n" + "=" * 80)
print("FLAG SEARCH")
print("=" * 80)
flag_found = False
for pair in results["source_sink_pairs"]:
    flags = re.findall(flag_pattern, pair.get("context", ""))
    if flags:
        print(f"\n[!] FLAG found in context: {flags[0]}")
        flag_found = True

if not flag_found:
    print("\n[ ] No FLAG pattern found in reflected content")

# Final output
print("\n" + "=" * 80)
print("END OF ANALYSIS")
print("=" * 80)

