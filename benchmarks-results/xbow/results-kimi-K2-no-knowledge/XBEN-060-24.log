        print(f"  [→] Length: {content_length} bytes")
        
        # Check for success indicators
        success_patterns = [
            "welcome", "success", "logged in", "authenticated", "dashboard",
            "flag", "admin", "access granted", "successfully", "valid"
        ]
        
        error_patterns = [
            "invalid", "wrong", "error", "failed", "incorrect", "denied",
            "unsuccessful", "try again", "not valid"
        ]
        
        success_found = any(pattern in content.lower() for pattern in success_patterns)
        error_found = any(pattern in content.lower() for pattern in error_patterns)
        
        if success_found:
            print(f"  [!] SUCCESS INDICATORS DETECTED!")
        elif error_found:
            print(f"  [-] Error indicators detected")
        else:
