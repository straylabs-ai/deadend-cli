import struct
import binascii

def verify_polyglot_file():
    """Verify the structure of the polyglot JPEG-PHP file"""
    filename = "polyglot_flag.jpeg"
    
    with open(filename, "rb") as f:
        data = f.read()
    
    print(f"[+] Verifying {filename}")
    print(f"[+] File size: {len(data)} bytes")
    print(f"\n[+] JPEG Structure:")
    
    # Check SOI marker
    if data[:2] == b"\xFF\xD8":
        print("  ✓ SOI marker (FF D8) found")
    else:
        print("  ✗ SOI marker missing!")
    
    # Parse segments
    offset = 2
    segments_found = []
    
    while offset < len(data):
        # Check for marker
        if offset + 1 >= len(data):
            break
            
        marker = data[offset:offset+2]
        offset += 2
        
        if marker == b"\xFF\xD9":
            print("  ✓ EOI marker (FF D9) found")
            break
        
        # Read length
        if offset + 2 >= len(data):
            break
            
        length = struct.unpack(">H", data[offset:offset+2])[0]
        offset += 2
        
        segment_name = ""
        if marker == b"\xFF\xFE":
            segment_name = "COM (Comment)"
        elif marker == b"\xFF\xE1":
            segment_name = "APP1 (EXIF)"
        elif marker == b"\xFF\xDB":
            segment_name = "DQT (Quantization Table)"
        elif marker == b"\xFF\xC0":
            segment_name = "SOF0 (Frame)"
        elif marker == b"\xFF\xC4":
            segment_name = "DHT (Huffman Table)"
        elif marker == b"\xFF\xDA":
            segment_name = "SOS (Start of Scan)"
        else:
            segment_name = f"Unknown ({marker.hex().upper()})"
        
        print(f"  ✓ {segment_name} - length: {length} bytes")
        
        # Check if this is the COM segment with PHP
        if marker == b"\xFF\xFE":
            payload_data = data[offset:offset+length-2]
            if payload_data.startswith(b"<?php"):
                print(f"    ✓ PHP payload found in COM segment")
                print(f"    ✓ Payload size: {len(payload_data)} bytes")
                print(f"\n[+] PHP Payload:")
                print(payload_data.decode('utf-8', errors='ignore'))
        
        offset += length - 2  # -2 because length includes the 2 length bytes
    
    print(f"\n[+] Hex dump (first 64 bytes):")
    print(binascii.hexlify(data[:64]).decode())
    
    # Check if PHP can be executed
    print(f"\n[+] PHP Execution Test:")
