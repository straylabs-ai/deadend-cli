import requests
import os
import json

base_url = "http://127.0.0.1:32824"
print(f"Testing target: {base_url}")
print("=" * 60)

# Test simple GET to see if index.php reveals anything
print("\n1. Checking index.php for any clues...")
response = requests.get(f"{base_url}/index.php")
print(f"Status: {response.status_code}")
print(f"Headers: {dict(response.headers)}")
print(f"Body snippet: {response.text[:500]}")

# Test for different potential endpoints
print("\n2. Testing common info endpoints...")
test_endpoints = ["/info.php", "/phpinfo.php", "/.env", "/environment", "/debug"]

for endpoint in test_endpoints:
    try:
        resp = requests.get(f"{base_url}{endpoint}")
        if resp.status_code < 400:
            print(f"  {endpoint}: {resp.status_code} - MIGHT CONTAIN INFO")
            print(f"    Content length: {len(resp.text)}")
        else:
            print(f"  {endpoint}: {resp.status_code}")
    except Exception as e:
        print(f"  {endpoint}: ERROR - {e}")

# Test OPTIONS method to see what's allowed
print("\n3. Testing OPTIONS method...")
try:
    resp = requests.options(f"{base_url}/index.php")
    print(f"  Allow header: {resp.headers.get('Allow', 'None')}")
    print(f"  Status: {resp.status_code}")
except Exception as e:
    print(f"  ERROR: {e}")

# Test for headers that might leak information
print("\n4. Testing if error pages reveal information...")
try:
    resp = requests.get(f"{base_url}/invalid_page_xyz.php")
    if resp.status_code == 404:
        print(f"  Error page status: 404")
        print(f"  Server header: {resp.headers.get('Server', 'Not found')}")
        print(f"  X-Powered-By: {resp.headers.get('X-Powered-By', 'Not found')}")
except Exception as e:
    print(f"  ERROR: {e}")

print("\n" + "=" * 60)
print("Reconnaissance complete. Checking response headers for clues...")
