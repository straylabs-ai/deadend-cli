import struct

def test_jpeg_structure():
    """Test that the created JPEG file has proper structure"""
    with open("payload_env.jpeg", "rb") as f:
        data = f.read()
    
    print("=== JPEG Structure Analysis ===")
    print(f"Total size: {len(data)} bytes")
    
    # Check SOI (Start of Image)
    soi = data[0:2]
    print(f"SOI marker: {soi.hex()} {'(VALID)' if soi == b'\xFF\xD8' else '(INVALID)'}")
    
    # Check APP0
    app0_marker = data[2:4]
    print(f"APP0 marker: {app0_marker.hex()}")
    
    # Find comment segment (where PHP is embedded)
    comment_pos = data.find(b'\xFF\xFE')
    if comment_pos != -1:
        print(f"Comment segment found at offset: {comment_pos}")
        # Read comment length
        comment_length = struct.unpack('>H', data[comment_pos+2:comment_pos+4])[0]
        print(f"Comment length: {comment_length} bytes")
        
        # Check if PHP marker is present in comment
        php_start = data.find(b'<?php', comment_pos)
        if php_start != -1:
            print(f"PHP code starts at offset: {php_start}")
            print("[✓] PHP payload successfully embedded in JPEG comment")
        
        # Extract and show first part of PHP code
        comment_data = data[comment_pos+4:comment_pos+4+comment_length-2]
        print(f"First 100 bytes of comment/PHP: {comment_data[:100]}")
    else:
        print("[✗] Comment segment not found")
    
    # Check for EOI (End of Image)
    eoi_pos = data.rfind(b'\xFF\xD9')
    if eoi_pos != -1:
        print(f"EOI marker found at offset: {eoi_pos}")
    
    # Check file extension handling
    print(f"\n=== Server Requirements ===")
    print("For this payload to work, the target server must:")
    print("1. Accept .jpeg files (extension validation passed)")
    print("2. Verify JPEG magic bytes (FF D8) - structure validation passed")
    print("3. Execute PHP code in uploaded files (misconfiguration/vulnerability)")
    print("4. Allow PHP in non-.php files (e.g., .jpeg extension)")
    
    return data

def hex_dump_sample():
    """Show hex dump of critical sections"""
    with open("payload_env.jpeg", "rb") as f:
        data = f.read()
    
    print(f"\n=== Hex Dump - First 64 bytes ===")
    for i in range(0, min(64, len(data)), 16):
        chunk = data[i:i+16]
        hex_str = ' '.join(f'{b:02x}' for b in chunk)
        ascii_str = ''.join(chr(b) if 32 <= b < 127 else '.' for b in chunk)
        print(f"{i:04x}: {hex_str:<48} {ascii_str}")
    
    # Find PHP section
    php_pos = data.find(b'<?php')
    if php_pos != -1:
        print(f"\n=== Hex Dump - PHP Section (offset {php_pos}) ===")
        start = max(0, php_pos - 8)
        end = min(len(data), php_pos + 64)
        for i in range(start, end, 16):
            chunk = data[i:i+16]
            hex_str = ' '.join(f'{b:02x}' for b in chunk)
            ascii_str = ''.join(chr(b) if 32 <= b < 127 else '.' for b in chunk)
            print(f"{i:04x}: {hex_str:<48} {ascii_str}")

# Run analysis
test_jpeg_structure()
hex_dump_sample()

print(f"\n=== Payload Summary ===")
