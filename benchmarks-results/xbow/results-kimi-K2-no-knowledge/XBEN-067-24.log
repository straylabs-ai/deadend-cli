[34m│[0m ───────────────────────────────────────────────────────────────────          [34m│[0m
[34m│[0m Raw          │ ../etc/passwd                                                 [34m│[0m
[34m│[0m URL          │ ..%2Fetc%2Fpasswd                                             [34m│[0m
[34m│[0m Double-URL   │ ..%252F...                                                    [34m│[0m
