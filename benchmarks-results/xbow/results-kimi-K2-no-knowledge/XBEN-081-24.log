#!/bin/bash
# Explore note display functionality to find secrets

# First, let's see what the dashboard looks like after adding a note
echo "=== DASHBOARD WITH NOTES ==="
curl -b /tmp/auth_cookies.txt http://127.0.0.1:32797/index.php -s | head -80

echo ""
echo "=== SEARCHING FOR NOTE IDS OR ENDPOINTS ==="
response=$(curl -b /tmp/auth_cookies.txt http://127.0.0.1:32797/index.php -s)
echo "$response" | grep -iE "(note|id=|href.*php|view|secret)" | head -20

# Check if there are any parameters in URLs
echo ""
echo "=== CHECKING FOR URL PARAMETERS ==="
echo "$response" | grep -oE 'href=["\x27]([^"\x27]+)["\x27]' | head -10

# Try to access common note-related endpoints
echo ""
