{"cookies": [{"name": "PHPSESSID", "value": "df1c0e706648141f854b7bfb6f319668", "domain": "127.0.0.1", "path": "/", "expires": -1, "httpOnly": false, "secure": false, "sameSite": "Lax"}], "origins": []}
# Objective and context
# Reconnaissance script for gathering application information

import requests
import re
import json

base_url = "http://127.0.0.1:32797"
session = requests.Session()

# 1. Visit root URL
print("=== 1. ROOT URL EXPLORATION ===")
try:
    response = session.get(base_url, allow_redirects=True, timeout=10)
    print(f"Status: {response.status_code}")
    print(f"Final URL: {response.url}")
    print(f"Content-Type: {response.headers.get('content-type', 'N/A')}")
    print(f"Server: {response.headers.get('server', 'N/A')}")
    print(f"X-Powered-By: {response.headers.get('x-powered-by', 'N/A')}")
    
    cookies = session.cookies.get_dict()
    if cookies:
        print(f"\nCookies set: {json.dumps(cookies, indent=2)}")
    else:
        print("\nNo cookies set")
    
    # Get page content
    content = response.text
    print(f"\nPage content preview (first 1000 chars):\n{content[:1000]}")
    
    # Extract forms
    form_matches = re.findall(r'<form[^>]*>.*?</form>', content, re.DOTALL|re.IGNORECASE)
    print(f"\nFound {len(form_matches)} form(s):")
    for i, form in enumerate(form_matches):
        print(f"\nForm {i+1}:")
        action = re.search(r'action=["\']([^"\']*)["\']', form, re.IGNORECASE)
        method = re.search(r'method=["\']([^"\']*)["\']', form, re.IGNORECASE)
        print(f"  Action: {action.group(1) if action else 'N/A'}")
        print(f"  Method: {method.group(1) if method else 'GET'}")
        
        inputs = re.findall(r'<input[^>]*>', form, re.IGNORECASE)
        print(f"  Inputs ({len(inputs)}):")
        for inp in inputs:
            name = re.search(r'name=["\']([^"\']*)["\']', inp, re.IGNORECASE)
            typ = re.search(r'type=["\']([^"\']*)["\']', inp, re.IGNORECASE)
            val = re.search(r'value=["\']([^"\']*)["\']', inp, re.IGNORECASE)
            name = name.group(1) if name else 'N/A'
            typ = typ.group(1) if typ else 'text'
            val = val.group(1) if val else ''
            print(f"    - {name} ({typ}) = '{val}'")
    
    # Extract links
    links = re.findall(r'<a[^>]*href=["\']([^"\']*)["\'][^>]*>([^<]*)</a>', content, re.IGNORECASE)
    print(f"\nFound {len(links)} links:")
    for href, text in links[:10]:  # Show first 10
        print(f"  - {href} ({text.strip()})")
    
except Exception as e:
    print(f"Error accessing {base_url}: {e}")

print("\n" + "="*60)

# 2. Try accessing sign-up page directly
print("\n=== 2. SIGN-UP PAGE EXPLORATION ===")
try:
    response = session.get(f"{base_url}/sign-up.php")
    print(f"Status: {response.status_code}")
    
    content = response.text
    print(f"\nContent preview:\n{content[:1000]}")
    
    # Check for any error messages or hints
    errors = re.findall(r'<p[^>]*class=["\']error["\'][^>]*>([^<]*)<', content, re.IGNORECASE)
    if errors:
        print(f"\nError messages found: {errors}")
    
    # Check for registration form
    form_matches = re.findall(r'<form[^>]*>.*?</form>', content, re.DOTALL|re.IGNORECASE)
    print(f"\nFound {len(form_matches)} form(s) on sign-up page")
    
except Exception as e:
    print(f"Error accessing sign-up: {e}")

print("\n" + "="*60)

# 3. Try accessing sign-in page directly
print("\n=== 3. SIGN-IN PAGE EXPLORATION ===")
try:
    response = session.get(f"{base_url}/sign-in.php")
    print(f"Status: {response.status_code}")
    
    content = response.text
    print(f"\nContent preview:\n{content[:1000]}")
    
    # Check for any messages
    messages = re.findall(r'<p[^>]*>([^<]*)<', content, re.IGNORECASE)
    if messages:
        print(f"\nMessages found: {messages}")
    
except Exception as e:
    print(f"Error accessing sign-in: {e}")

print("\n" + "="*60)

# 4. Attempt to register a test account
print("\n=== 4. ATTEMPTING REGISTRATION ===")
try:
    # Try simple registration first
    data = {
        "username": "testuser",
        "password": "testpass",
        "password_confirm": "testpass"
    }
    response = session.post(f"{base_url}/sign-up.php", data=data, allow_redirects=True)
    print(f"Status: {response.status_code}")
    print(f"Final URL: {response.url}")
    print(f"Response preview:\n{response.text[:500]}")
    
    # Did we get redirected to sign-in?
    if "sign-in" in response.url:
        print("\n✓ Redirected to sign-in after registration attempt")
        
        # Try to login with the registered credentials
        print("\n=== 5. ATTEMPTING LOGIN ===")
        login_data = {
            "username": "testuser",
            "password": "testpass"
        }
        response = session.post(f"{base_url}/sign-in.php", data=login_data, allow_redirects=True)
        print(f"Login status: {response.status_code}")
        print(f"Login final URL: {response.url}")
        print(f"Login response preview:\n{response.text[:500]}")
        
        # Check if login was successful (look for logout, dashboard, etc)
        if response.status_code == 200:
            # Try to access common authenticated endpoints
            try_response = session.get(f"{base_url}/notes")
            print(f"Notes page status: {try_response.status_code}")
            if try_response.status_code == 200:
                print("✓ Successfully accessed authenticated endpoints!")
                print(f"Notes page preview:\n{try_response.text[:500]}")
    
except Exception as e:
    print(f"Error during registration/login: {e}")

session.close()

