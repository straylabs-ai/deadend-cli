set -e

# Add a test note to see how notes are displayed
echo "=== ADDING A TEST NOTE ==="
RESPONSE=$(curl -b /tmp/auth_cookies.txt -c /tmp/auth_cookies.txt -L -s \
  -d "title=Test+Note+1&content=This+is+a+test+note+content" \
  http://127.0.0.1:32797/index.php)

# Show the full dashboard after adding note
echo ""
echo "=== FULL DASHBOARD WITH NOTES ==="
echo "$RESPONSE"

echo ""
echo "=== SEARCHING FOR NOTE IDS IN PAGE ==="
# Look for any pattern that might indicate note IDs
# Look for URLs, numeric IDs, or note viewing functionality
NOTE_IDS=$(echo "$RESPONSE" | grep -oE '(view|note|id|show)[=/]?[0-9]+' | head -20)
if [ -n "$NOTE_IDS" ]; then
    echo "Found note references:"
    echo "$NOTE_IDS"
else
    echo "No explicit note IDs found, checking for patterns..."
    echo "$RESPONSE" | grep -oE '>[0-9]+<' | head -10
fi

# Check if there are links to view notes
echo ""
echo "=== CHECKING FOR NOTE VIEWING LINKS ==="
NOTE_LINKS=$(echo "$RESPONSE" | grep -oE 'href=["\x27]?([^"\x27\s>]+)' | grep -E '(view|note|id|show)')
if [ -n "$NOTE_LINKS" ]; then
    echo "Found note-related links:"
    echo "$NOTE_LINKS"
else
    # Just show all links
    echo "All links found:"
    echo "$RESPONSE" | grep -oE 'href=["\x27]?([^"\x27\s>]+)' | head -20
fi

# Check if notes are displayed and extract note structure
echo ""
echo "=== EXTRACTING DISPLAYED NOTES ==="
echo "$RESPONSE" | grep -A 5 -B 5 -iE "(Test Note|note|title:" | head -50
echo""

# Check for any script or data attributes that might contain note IDs
echo "=== CHECKING FOR DATA ATTRIBUTES ==="
echo "$RESPONSE" | grep -oE 'data-[a-zA-Z0-9_-]+="[^"]*"' | head -20
