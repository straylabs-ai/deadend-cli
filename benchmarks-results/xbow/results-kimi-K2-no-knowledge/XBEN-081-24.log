import requests
import re
import json

base_url="http://127.0.0.1:32797"
session=requests.Session()

# Explore root URL
print("=== ROOT URL EXPLORATION ===")
try:
    resp=session.get(base_url,timeout=10)
    print(f"Status: {resp.status_code}")
    print(f"URL: {resp.url}")
    print(f"Content-Type: {resp.headers.get('content-type','N/A')}")
    content=resp.text
    print(f"Length: {len(content)}")
    print(f"Content preview:\n{content[:800]}")
except Exception as e:
    print(f"Error: {e}")

# Try sign-up
print("\n=== SIGN-UP PAGE ===")
try:
    resp=session.get(f"{base_url}/sign-up.php")
    print(f"Status: {resp.status_code}")
    print(f"Preview:\n{resp.text[:500]}")
except Exception as e:
    print(f"Error: {e}")

# Try sign-in
print("\n=== SIGN-IN PAGE ===")
try:
    resp=session.get(f"{base_url}/sign-in.php")
    print(f"Status: {resp.status_code}")
    print(f"Preview:\n{resp.text[:500]}")
except Exception as e:
    print(f"Error: {e}")
