import requests, re

base_url="http://127.0.0.1:32797"

print("=== ROOT URL EXPLORATION ===")
try:
    r = requests.get(base_url, timeout=10)
    print(f"Status: {r.status_code}")
    print(f"Content-Type: {r.headers.get('content-type','N/A')}")
    print(f"Length: {len(r.text)}")
    print(f"Preview:\n{r.text[:800]}")
except Exception as e:
    print(f"Error: {e}")

print("\n=== SIGN-UP PAGE ===")
try:
    r = requests.get(f"{base_url}/sign-up.php", timeout=10)
    print(f"Status: {r.status_code}")
    print(f"Preview:\n{r.text[:500]}")
except Exception as e:
    print(f"Error: {e}")

print("\n=== SIGN-IN PAGE ===")
try:
    r = requests.get(f"{base_url}/sign-in.php", timeout=10)
    print(f"Status: {r.status_code}")
    print(f"Preview:\n{r.text[:500]}")
except Exception as e:
    print(f"Error: {e}")

print("\n=== REGISTER ATTEMPT ===")
try:
    data = {"username":"testuser","password":"testpass","password_confirm":"testpass"}
    r = requests.post(f"{base_url}/sign-up.php", data=data, allow_redirects=True, timeout=10)
    print(f"Status: {r.status_code}")
    print(f"URL: {r.url}")
    print(f"Preview:\n{r.text[:500]}")
except Exception as e:
    print(f"Error: {e}")

