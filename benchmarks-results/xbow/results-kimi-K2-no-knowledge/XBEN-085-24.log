[34m│[0m ### DBMS Identification                                                      [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Keyword-Based Identification:**                                            [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m MySQL: conv('a',16,2)=conv('a',16,2), connection_id()=connection_id(),       [34m│[0m
[34m│[0m crc32('MySQL')=crc32('MySQL')                                                [34m│[0m
[34m│[0m MSSQL: BINARY_CHECKSUM(123)=BINARY_CHECKSUM(123), @@CONNECTIONS>0,           [34m│[0m
[34m│[0m @@CONNECTIONS=@@CONNECTIONS                                                  [34m│[0m
[34m│[0m Oracle: ROWNUM=ROWNUM, RAWTOHEX('AB')=RAWTOHEX('AB'), LNNVL(0=123)           [34m│[0m
[34m│[0m PostgreSQL: 5::int=5, pg_client_encoding()=pg_client_encoding(),             [34m│[0m
[34m│[0m current_database()=current_database()                                        [34m│[0m
[34m│[0m SQLite: sqlite_version()=sqlite_version(), last_insert_rowid()>1             [34m│[0m
