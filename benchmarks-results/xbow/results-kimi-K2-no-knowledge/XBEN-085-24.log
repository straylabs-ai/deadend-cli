"""
Deep investigation of the authentication system 
- Examine form submission process
- Check for JavaScript handling
- Look for hidden endpoints and actions
"""

import requests
import re
import json

target_url = "http://127.0.0.1:32829/index.php"
print(f"[*] Analyzing authentication mechanism on {target_url}")
print("=" * 80)

# 1. First examine if there's any JavaScript handling authentication
print("\n[1] Checking for JavaScript files and authentication logic")
print("-" * 80)

try:
    # Get the page source
    response = requests.get(target_url, timeout=10)
    
    # Look for script tags
    script_tags = re.findall(r'<script[^>]*src=["\']([^"\']+)["\'][^>]*>', response.text, re.IGNORECASE)
    if script_tags:
        print(f"[+] Found {len(script_tags)} JavaScript file(s):")
        for script in script_tags:
            print(f"  - {script}")
            # Try to fetch the script content
            if script.startswith('http'):
                script_url = script
            elif script.startswith('/'):
                script_url = f"http://127.0.0.1:32829{script}"
            else:
                script_url = f"http://127.0.0.1:32829/{script}"
            
            try:
                script_resp = requests.get(script_url, timeout=5)
                print(f"    Status: {script_resp.status_code} | Size: {len(script_resp.content)}B")
            except:
                print(f"    [!] Could not fetch script")
    else:
        print("[-] No external JavaScript files found")
    
    print(f"[+] Script count in HTML: {len(re.findall(r'<script', response.text, re.IGNORECASE))}")
    
    # Look for inline JavaScript
    inline_scripts = re.findall(r'<script[^>]*>(.*?)</script>', response.text, re.IGNORECASE | re.DOTALL)
    if inline_scripts:
        print(f"[+] Found inline JavaScript blocks:")
        for i, script in enumerate(inline_scripts, 1):
            print(f"\n  Block {i}:")
            lines = script.strip().split('\n')
            for line_num, line in enumerate(lines[:10], 1):  # Show first 10 lines
                stripped = line.strip()
                if stripped:
                    print(f"    {line_num}: {stripped[:80]}")
            if len(lines) > 10:
                print(f"    ... ({len(lines)-10} more lines)")
    
except Exception as e:
    print(f"[!] Error checking scripts: {e}")

# 2. Verify that static resources exist and check for hidden endpoints
print("\n\n[2] Testing static resources for endpoint discovery")
print("-" * 80)

test_files = [
    "/static/springfield_background.jpg",
    "/css/style.css",
    "/js/auth.js"
]

for file_path in test_files:
    file_url = f"http://127.0.0.1:32829{file_path}"
    try:
        resp = requests.get(file_url, timeout=5)
        if resp.status_code == 200:
            print(f"[+] FOUND: {file_path} ({len(resp.content)}B)")
        elif resp.status_code == 403:
            print(f"[?] RESTRICTED: {file_path} (403)")
        elif resp.status_code == 404:
            print(f"[-] NOT FOUND: {file_path} (404)")
        else:
            print(f"[?] {file_path} ({resp.status_code})")
    except Exception as e:
        print(f"[!] Error fetching {file_path}: {e}")

# 3. Look for other forms and actions on the login page
print("\n\n[3] Analyzing forms and actions")
print("-" * 80)

try:
    # Parse forms
    forms = re.findall(r'<form[^>]*>(.*?)</form>', response.text, re.IGNORECASE | re.DOTALL)
    if forms:
        print(f"[+] Found {len(forms)} form(s):")
        for i, form in enumerate(forms, 1):
            print(f"\n  Form {i}:")
            
            # Get form attributes
            form_tag = re.search(r'<form[^>]*>', response.text, re.IGNORECASE).group(0)
            action_match = re.search(r'action=["\']([^"\']*)["\']', form_tag, re.IGNORECASE)
            method_match = re.search(r'method=["\']([^"\']*)["\']', form_tag, re.IGNORECASE)
            
            action = action_match.group(1) if action_match else "default"
            method = method_match.group(1) if method_match else "GET"
            
            print(f"    Action: {action}")
            print(f"    Method: {method}")
            
            # Look for hidden inputs
            hidden_inputs = re.findall(r'<input[^>]*type=["\']?hidden["\']?[^>]*>', form, re.IGNORECASE)
            if hidden_inputs:
                print(f"    Hidden inputs:")
                for hidden in hidden_inputs:
                    name_match = re.search(r'name=["\']?([^\s>"\']+)["\']?\s*', hidden, re.IGNORECASE)
                    value_match = re.search(r'value=["\']?([^\s>"\']*)["\']?\s*', hidden, re.IGNORECASE)
                    name = name_match.group(1) if name_match else "N/A"
                    value = value_match.group(1) if value_match else "N/A"
                    print(f"      - {name} = {value}")
            
            # Look for all inputs
            all_inputs = re.findall(r'<input[^>]*>', form, re.IGNORECASE)
            print(f"    Total inputs: {len(all_inputs)}")
    
except Exception as e:
    print(f"[!] Error analyzing forms: {e}")

# 4. Brute-force common endpoint patterns that might exist but weren't discovered
print("\n\n[4] Testing for hidden/authenticated endpoints")
print("-" * 80)

# Since /index.php is just showing the login page, check if there are other .php files
common_auth_pages = [
    "/login.php",
    "/auth.php",
    "/authenticate.php",
    "/verify.php",
    "/checklogin.php",
    "/process.php",
    "/submit.php"
]

print(f"[+] Testing {len(common_auth_pages)} potential authentication processing endpoints")
print("(Note: Only testing pages that might actually exist)")

for page in common_auth_pages:
    page_url = f"http://127.0.0.1:32829{page}"
    try:
        # Try GET first
        get_resp = requests.get(page_url, timeout=5)
        
        # Try POST with credentials (even random ones)
        post_resp = requests.post(page_url, data={"username": "test", "password": "test"}, timeout=5)
        
        if get_resp.status_code == 200 and len(get_resp.content) > 0:
            print(f"[+] GET {page} exists ({len(get_resp.content)}B)")
            if len(get_resp.content) != 3178:  # If different from index.php
                print(f"    [!] DIFFERENT content size from index.php - investigate!")
        elif post_resp.status_code == 200 and len(post_resp.content) > 0:
            print(f"[+] POST {page} accessible ({len(post_resp.content)}B)")
            if len(post_resp.content) != 3178:
                print(f"    [!] DIFFERENT content size from index.php - investigate!")
        elif get_resp.status_code == 403 or post_resp.status_code == 403:
            print(f"[?] {page} exists but restricted (403)")
        elif get_resp.status_code == 404 or post_resp.status_code == 404:
            print(f"[-] {page} not found (404)")
        elif get_resp.status_code == 500 or post_resp.status_code == 500:
            print(f"[!] {page} causes server error (500) - interesting!")
        else:
            if get_resp.status_code != 404:
                print(f"[?] {page} status GET:{get_resp.status_code} POST:{post_resp.status_code}")
                
    except Exception as e:
        print(f"[!] Error testing {page}: {type(e).__name__}")

# 5. Check for robots.txt, sitemap.xml, or other discovery files
print("\n\n[5] Testing common discovery files")
print("-" * 80)

discovery_files = [
    "/robots.txt",
    "/sitemap.xml",
    "/.htaccess",
    "/crossdomain.xml",
    "/clientaccesspolicy.xml",
    "/login.txt", 
    "/README.txt",
    "/CHANGELOG.txt"
]

for file_path in discovery_files:
    file_url = f"http://127.0.0.1:32829{file_path}"
    try:
        resp = requests.get(file_url, timeout=5)
        if resp.status_code == 200 and len(resp.text.strip()) > 0:
            print(f"[+] FOUND: {file_path}")
            # Show first few lines
            lines = resp.text.split('\n')[:5]
            for line_num, line in enumerate(lines, 1):
                print(f"    {line_num}: {line[:80]}")
            if len(resp.text.split('\n')) > 5:
                print(f"    ... ({len(resp.text.split('\n'))-5} more lines)")
        elif resp.status_code == 403:
            print(f"[?] RESTRICTED: {file_path}")
        elif resp.status_code == 404:
            print(f"[-] NOT FOUND: {file_path}")
        else:
            print(f"[?] {file_path} ({resp.status_code})")
    except Exception as e:
        print(f"[!] Error fetching {file_path}: {e}")

# 6. Check headers for authentication hints
print("\n\n[6] Checking for authentication-related headers")
print("-" * 80)

try:
    # Check OPTIONS method
    options_resp = requests.options(target_url, timeout=5)
    print(f"[+] OPTIONS method response status: {options_resp.status_code}")
    if 'Allow' in options_resp.headers:
        print(f"[+] Allowed methods: {options_resp.headers['Allow']}")
    
    # Check for WWW-Authenticate header
    if 'WWW-Authenticate' in response.headers:
        print(f"[+] WWW-Authenticate: {response.headers['WWW-Authenticate']}")
    
    # Check for authentication tokens in headers
    auth_headers = {k: v for k, v in response.headers.items() if 'auth' in k.lower() or 'token' in k.lower()}
    if auth_headers:
        print(f"[+] Authentication-related headers: {auth_headers}")
    
except Exception as e:
    print(f"[!] Error checking headers: {e}")

print("\n\n" + "=" * 80)
print("[*] Analysis Summary:")
print("=" * 80)
print("[1] All payloads return identical 3178B response")
print("[2] No actual authentication processing appears to happen on /index.php")
print("[3] Login form shows but no session management detected")
print("[4] Need to find where actual authentication logic exists")
print("\n[*] Recommendations:")
print("[1] Test GET /index.php vs POST /index.php differences")
print("[2] Look for JavaScript that might handle client-side authentication")
print("[3] Search for other .php endpoints that process authentication")
print("[4] Check if /index.php redirects to another page after auth")
