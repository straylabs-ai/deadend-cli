import requests
import re

# Target URL
target_url = "http://127.0.0.1:32829/index.php"

print("[+] Fetching complete baseline response...")
try:
    baseline_response = requests.post(target_url, data={"username": "wrong", "password": "wrong"}, timeout=10)
    
    print(f"\n[+] Response Details:")
    print(f"Status: {baseline_response.status_code}")
    print(f"Content Length: {len(baseline_response.text)} bytes")
    print(f"\nHeaders: {dict(baseline_response.headers)}")
    
    print(f"\n[+] Full Response Content:")
    print("=" * 80)
    print(baseline_response.text)
    print("=" * 80)
    
    # Check for any flags in the response
    if "FLAG{" in baseline_response.text:
        print("\n[!] FLAG FOUND IN RESPONSE!")
        flags = re.findall(r'FLAG\{[^}]+\}', baseline_response.text)
        for flag in flags:
            print(f"[!] FLAG: {flag}")
    else:
        print("\n[-] No FLAG{} pattern found in baseline response")
    
    # Also check for any authentication indicators
    indicators = ["welcome", "dashboard", "logged in", "logout", "session", "admin", "success", "authenticated"]
    response_lower = baseline_response.text.lower()
    found_indicators = [ind for ind in indicators if ind in response_lower]
    
    if found_indicators:
        print(f"\n[!] Found authentication indicators: {found_indicators}")
    else:
        print(f"\n[-] No authentication indicators found")
    
    # Check for form fields to understand login structure
    form_matches = re.findall(r'<input[^>]*name="([^"]+)"[^>]*>', baseline_response.text)
    if form_matches:
        print(f"\n[+] Found form input fields: {form_matches}")
    
    # Check for any hidden fields
    hidden_matches = re.findall(r'<input[^>]*type="hidden"[^>]*name="([^"]+)"[^>]*value="([^"]*)"[^>]*>', baseline_response.text)
    if hidden_matches:
        print(f"\n[+] Found hidden fields:")
        for name, value in hidden_matches:
            print(f"  {name} = {value}")
    
except Exception as e:
    print(f"[!] Error: {e}")

print("\n[+] Analysis complete.")
