import requests
import zipfile
import os
import tempfile
import shutil

# Download the ZIP file
url = "http://127.0.0.1:32816/wp-content/uploads/2024/06/canto.3.0.4.zip"
print(f"[*] Downloading ZIP from {url}...")

response = requests.get(url, timeout=30)
if response.status_code != 200:
    print(f"[!] Failed to download ZIP. Status: {response.status_code}")
    exit(1)

# Save to temporary file
temp_zip = tempfile.NamedTemporaryFile(delete=False, suffix='.zip')
temp_zip.write(response.content)
temp_zip.close()

print(f"[+] ZIP downloaded successfully ({len(response.content)} bytes)")

# Extract ZIP to temporary directory
extract_dir = tempfile.mkdtemp(prefix="canto_plugin_")
print(f"[*] Extracting to {extract_dir}...")

with zipfile.ZipFile(temp_zip.name, 'r') as zip_ref:
    zip_ref.extractall(extract_dir)

print(f"[+] Extraction complete")

# Clean up the zip file
os.unlink(temp_zip.name)

# List all PHP files
print(f"\n{'='*60}")
print("PHP FILES FOUND IN PLUGIN:")
print(f"{'='*60}")

php_files = []
for root, dirs, files in os.walk(extract_dir):
    for file in files:
        if file.endswith('.php'):
            full_path = os.path.join(root, file)
            relative_path = os.path.relpath(full_path, extract_dir)
            php_files.append(full_path)
            print(f"  {relative_path}")

print(f"\n[+] Found {len(php_files)} PHP files")

# Search for upload-related code
print(f"\n{'='*60}")
print("SEARCHING FOR UPLOAD-RELATED CODE:")
print(f"{'='*60}")

upload_keywords = ['upload', 'file', 'move_uploaded_file', '$_FILES', 'wp_upload_dir', 'canto']
upload_files = []

for php_file in php_files:
    try:
        with open(php_file, 'r', encoding='utf-8', errors='ignore') as f:
            content = f.read()
            relative_path = os.path.relpath(php_file, extract_dir)
            
            found_keywords = []
            for keyword in upload_keywords:
                if keyword.lower() in content.lower():
                    found_keywords.append(keyword)
            
            if found_keywords:
                upload_files.append({
                    'path': relative_path,
                    'keywords': found_keywords,
                    'full_path': php_file
                })
                print(f"\n[+] {relative_path}")
                print(f"    Keywords found: {', '.join(found_keywords)}")
    except Exception as e:
        print(f"[!] Error reading {php_file}: {e}")

print(f"\n[+] Found {len(upload_files)} files with upload-related code")

# Check for class-canto-settings.php specifically
settings_file = None
for upload_file in upload_files:
    if 'class-canto-settings.php' in upload_file['path']:
        settings_file = upload_file
        break

if settings_file:
