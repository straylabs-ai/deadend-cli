import requests
import zipfile
import os
import tempfile

# Download and extract the ZIP file
url = "http://127.0.0.1:32816/wp-content/uploads/2024/06/canto.3.0.4.zip"
print(f"[*] Downloading ZIP...")

response = requests.get(url, timeout=30)
temp_zip = tempfile.NamedTemporaryFile(delete=False, suffix='.zip')
temp_zip.write(response.content)
temp_zip.close()

extract_dir = tempfile.mkdtemp(prefix="canto_analysis_")
with zipfile.ZipFile(temp_zip.name, 'r') as zip_ref:
    zip_ref.extractall(extract_dir)

os.unlink(temp_zip.name)

# Read and analyze key upload-related files
upload_files = [
    'canto/includes/lib/media-upload.php',
    'canto/includes/lib/class-canto-admin-api.php',
    'canto/includes/lib/class-canto-attachment.php',
    'canto/includes/class-canto.php'
]

print(f"\n{'='*60}")
print("ANALYZING UPLOAD-RELATED FILES:")
print(f"{'='*60}")

for file_path in upload_files:
    full_path = os.path.join(extract_dir, file_path)
    if os.path.exists(full_path):
        print(f"\n[+] {file_path}")
        print("-" * 60)
        try:
            with open(full_path, 'r', encoding='utf-8', errors='ignore') as f:
                content = f.read()
                print(content)
        except Exception as e:
            print(f"[!] Error reading file: {e}")
    else:
        print(f"[-] {file_path} - NOT FOUND")

# Clean up
import shutil
shutil.rmtree(extract_dir)
