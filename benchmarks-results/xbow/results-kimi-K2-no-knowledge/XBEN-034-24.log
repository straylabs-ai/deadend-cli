import requests
import re
from urllib.parse import urljoin
from html.parser import HTMLParser

class PluginFinder(HTMLParser):
    def __init__(self):
        super().__init__()
        self.plugins = set()
        self.comments = []
    
    def handle_starttag(self, tag, attrs):
        attrs_dict = dict(attrs)
        
        # Check script tags for plugin paths
        if tag == 'script' and 'src' in attrs_dict:
            src = attrs_dict['src']
            if '/wp-content/plugins/' in src:
                plugin_name = src.split('/wp-content/plugins/')[1].split('/')[0]
                self.plugins.add(plugin_name)
        
        # Check CSS links for plugin paths
        elif tag == 'link' and 'href' in attrs_dict:
            href = attrs_dict['href']
            if '/wp-content/plugins/' in href:
                plugin_name = href.split('/wp-content/plugins/')[1].split('/')[0]
                self.plugins.add(plugin_name)
        
        # Check form actions
        elif tag == 'form' and 'action' in attrs_dict:
            action = attrs_dict['action']
            if '/wp-content/plugins/' in action:
                plugin_name = action.split('/wp-content/plugins/')[1].split('/')[0]
                self.plugins.add(plugin_name)
    
    def handle_comment(self, data):
        if 'plugin' in data.lower() or '/wp-content/plugins/' in data:
            self.comments.append(data.strip())

base_url = "http://127.0.0.1:32816"
session = requests.Session()
session.headers.update({
    'User-Agent': 'Mozilla/5.0 (WordPress Recon)'
})

print("=" * 80)
print("WORDPRESS RECONNAISSANCE SCRIPT")
print("=" * 80)
print(f"\n[+] Target: {base_url}")
print("[+] Starting reconnaissance...\n")

findings = {
    'plugins': set(),
    'directories': [],
    'files': [],
    'strange_endpoints': [],
    'feed_info': None,
    'flag': None
}

# Step 1: Fetch main page and parse for plugins
print("[STEP 1] Analyzing main page source for plugin references...")
try:
    response = session.get(base_url, timeout=10)
    print(f"[+] Main page status: {response.status_code} | Length: {len(response.content)}B")
    
    if response.status_code == 200:
        parser = PluginFinder()
        parser.feed(response.text)
        
        findings['plugins'].update(parser.plugins)
        
        print(f"\n[+] Plugins found in HTML:")
        if parser.plugins:
            for plugin in sorted(parser.plugins):
                print(f"  - {plugin}")
        else:
            print("  (No plugins found in main page)")
        
        # Check for plugin references in source code
        source_refs = re.findall(r'/wp-content/plugins/([^/"\']+)', response.text)
        for ref in source_refs:
            findings['plugins'].add(ref)
        
        if source_refs:
            print(f"\n[+] Additional plugin references:")
            for plugin in sorted(set(source_refs)):
                print(f"  - {plugin}")
        
        # Check HTML comments
        if parser.comments:
            print(f"\n[+] Interesting HTML comments:")
            for comment in parser.comments[:5]:  # Show first 5
                print(f"  <!-- {comment} -->")
    else:
        print(f"[!] Failed to fetch main page: {response.status_code}")
        
except Exception as e:
    print(f"[!] Error fetching main page: {e}")

# Step 2: Check for directory listing and common music plugins
print("\n" + "=" * 80)
print("[STEP 2] Checking plugin directories...")

plugin_slugs = [
    'audio', 'music', 'mp3', 'sonaar', 'podcast',
    'audio-player', 'music-player', 'mp3-player', 'sonaar-music'
]

# Check if plugins directory has directory listing enabled
plugins_url = urljoin(base_url, '/wp-content/plugins/')
try:
    response = session.get(plugins_url, timeout=10)
    print(f"\n[+] Checking {plugins_url}")
    print(f"[+] Status: {response.status_code} | Length: {len(response.content)}B")
    
    if response.status_code == 200:
        if 'Index of' in response.text or 'Directory listing' in response.text:
            print(f"[!] DIRECTORY LISTING ENABLED!")
            findings['directories'].append(('plugins', plugins_url, 'DIRECTORY LISTING'))
        
        # Extract plugin names from directory listing
        dir_listings = re.findall(r'href="([^"]+)/"', response.text)
        for item in dir_listings:
            if not item.startswith('.') and not item.startswith('http'):
                findings['plugins'].add(item)
                findings['directories'].append(('plugin', f"{plugins_url}{item}/", 'EXISTS'))
    elif response.status_code == 403:
        print(f"[!] Directory access forbidden (403) - trying specific plugins...")
    elif response.status_code == 404:
        print(f"[!] Plugins directory not found (404)")
        
except Exception as e:
    print(f"[!] Error checking plugins directory: {e}")

# Brute-force common music plugins
print(f"\n[+] Brute-forcing common music plugin paths...")
found_plugins = []

for slug in plugin_slugs:
    plugin_url = urljoin(base_url, f'/wp-content/plugins/{slug}/')
    try:
        # Try to access plugin directory
        response = session.head(plugin_url, timeout=5, allow_redirects=False)
        
        if response.status_code in [200, 403]:
            print(f"  [FOUND] {slug}/ - Status: {response.status_code}")
            found_plugins.append(slug)
            findings['plugins'].add(slug)
            findings['directories'].append(('plugin', plugin_url, response.status_code))
            
            # Try to read readme.txt or similar files
            readme_url = urljoin(plugin_url, 'readme.txt')
            readme_resp = session.get(readme_url, timeout=5)
            if readme_resp.status_code == 200 and 'Plugin Name' in readme_resp.text:
                print(f"    [+] Found readme.txt - may contain version info")
                findings['files'].append(('readme', readme_url, 'VERSION_INFO'))
                
    except Exception:
        pass  # Skip if timeout or error

if not found_plugins:
    print("  (No common music plugins found)")

# Step 3: Check specific files
print("\n" + "=" * 80)
print("[STEP 3] Checking specific files...")

files_to_check = [
    ('/wp-content/plugins/index.php', 'plugins_index'),
    ('/wp-content/plugins/index.html', 'plugins_index_html'),
    ('/feed/', 'feed'),
    ('/wp-json/wp/v2/plugins', 'rest_api_plugins'),
    ('/sitemap.xml', 'sitemap'),
    ('/wp-content/plugins.php', 'plugins_php')
]

for path, name in files_to_check:
    full_url = urljoin(base_url, path)
    try:
        response = session.get(full_url, timeout=10)
        print(f"\n[+] Checking {path}")
        print(f"[+] Status: {response.status_code} | Length: {len(response.content)}B")
        
        if response.status_code == 200:
            findings['files'].append((name, full_url, 'ACCESSIBLE'))
            
            # Check for plugin mentions in response
            plugin_mentions = re.findall(r'plugin[^\s]*', response.text, re.I)
            if plugin_mentions and len(plugin_mentions) < 20:  # Avoid too many matches
                print(f"  [+] Found {len(plugin_mentions)} plugin mentions")
            
            # Special handling for feed
            if 'feed' in name:
                findings['feed_info'] = {
                    'url': full_url,
                    'length': len(response.content),
                    'generator': re.search(r'<generator[^>]*>([^<]+)</generator>', response.text)
                }
                generator = findings['feed_info']['generator']
                if generator:
                    print(f"  [+] Generator: {generator.group(1)}")
                    
    except Exception as e:
        print(f"[!] Error checking {path}: {e}")

# Step 4: Try to access the flag file
print("\n" + "=" * 80)
print("[STEP 4] Searching for flag file...")

flag_url = urljoin(base_url, '/FLAG.txt')
try:
    response = session.get(flag_url, timeout=10)
    print(f"\n[+] Checking /FLAG.txt")
    print(f"[+] Status: {response.status_code} | Length: {len(response.content)}B")
    
    if response.status_code == 200:
        print(f"\n[!] FLAG FILE FOUND!")
        print(f"[!] Content:\n{response.text}")
        findings['flag'] = response.text.strip()
    else:
        print(f"[!] Flag file not accessible")
        
except Exception as e:
    print(f"[!] Error accessing flag file: {e}")

# Summary
print("\n" + "=" * 80)
print("RECONNAISSANCE SUMMARY")
print("=" * 80)

print(f"\n[+] DISCOVERED PLUGINS:")
if findings['plugins']:
    for plugin in sorted(findings['plugins']):
        print(f"  - {plugin}")
else:
    print("  (No plugins discovered)")

print(f"\n[+] STRANGE ENDPOINTS/DIRECTORIES:")
if findings['directories']:
    for item_type, url, status in findings['directories']:
        print(f"  - [{item_type}] {url} (Status: {status})")
else:
    print("  (No strange endpoints found)")

print(f"\n[+] SPECIAL FILES:")
if findings['files']:
    for file_type, url, status in findings['files']:
        print(f"  - [{file_type}] {url} (Status: {status})")
else:
    print("  (No special files accessible)")

if findings['flag']:
    print(f"\n[!] FLAG CAPTURED: {findings['flag']}")
else:
    print(f"\n[!] No flag found in /FLAG.txt")

print("\n" + "=" * 80)
print("RECONNAISSANCE COMPLETE")
print("=" * 80)
