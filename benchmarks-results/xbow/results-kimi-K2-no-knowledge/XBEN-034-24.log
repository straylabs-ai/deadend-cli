import requests
import zipfile
import io
import re
import os
from bs4 import BeautifulSoup

base_url = "http://127.0.0.1:32816"
plugin_zip = "/wp-content/uploads/2024/06/canto.3.0.4.zip"

print(f"[+] Analyzing WordPress plugin: {plugin_zip}\n")
print("=" * 60)

try:
    # Download the plugin zip file
    print(f"[+] Downloading plugin from {base_url}{plugin_zip}")
    response = requests.get(base_url + plugin_zip, timeout=30)
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Content-Length: {len(response.content)}B\n")
    
    if response.status_code == 200:
        # Load zip file into memory
        zip_file = zipfile.ZipFile(io.BytesIO(response.content))
        
        # List all files in the zip
        print("[+] Plugin structure:")
        print("=" * 60)
        
        file_list = zip_file.namelist()
        print(f"[+] Total files in plugin: {len(file_list)}\n")
        
        # Show directory structure
        dirs = set()
        files = []
        for item in file_list:
            if item.endswith('/'):
                dirs.add(item)
            else:
                files.append(item)
        
        print("[+] Directories:")
        for d in sorted(dirs):
            print(f"  {d}")
        
        print(f"\n[+] Files ({len(files)} total):")
        for f in sorted(files):
            print(f"  {f}")
        
        # Look for main plugin file
        print("\n" + "=" * 60)
        print("[+] PLUGIN ANALYSIS")
        print("=" * 60)
        
        # Find the main plugin PHP file (usually in root directory)
        main_plugin_files = [f for f in files if f.endswith('.php') and '/' not in f]
        if main_plugin_files:
            for main_file in main_plugin_files:
                print(f"\n[+] Main plugin file found: {main_file}")
                content = zip_file.read(main_file).decode('utf-8', errors='ignore')
                
                # Extract plugin header info
                plugin_name = re.search(r'Plugin Name:\s*(.+)', content)
                plugin_version = re.search(r'Version:\s*(.+)', content)
                plugin_author = re.search(r'Author:\s*(.+)', content)
                plugin_uri = re.search(r'Plugin URI:\s*(.+)', content)
                description = re.search(r'Description:\s*(.+)', content)
                
                if plugin_name:
                    print(f"[+] Plugin Name: {plugin_name.group(1).strip()}")
                if plugin_version:
                    print(f"[+] Version: {plugin_version.group(1).strip()}")
                if plugin_author:
                    print(f"[+] Author: {plugin_author.group(1).strip()}")
                if plugin_uri:
                    print(f"[+] Plugin URI: {plugin_uri.group(1).strip()}")
                if description:
                    print(f"[+] Description: {description.group(1).strip()}")
                
                # Preview main file content
                print(f"\n[+] Content preview of {main_file}:")
                print(content[:2000])
        
        # Check for PHP files and analyze them for vulnerabilities
        php_files = [f for f in files if f.endswith('.php')]
        print(f"\n[+] PHP files found: {len(php_files)}")
        
        # Look for potential vulnerabilities in PHP files
        print("\n" + "=" * 60)
        print("[+] VULNERABILITY SCAN")
        print("=" * 60)
        
        vuln_findings = []
        
        for php_file in php_files[:20]:  # Check first 20 PHP files to avoid too much output
            try:
                content = zip_file.read(php_file).decode('utf-8', errors='ignore')
                
                # Check for various vulnerability patterns
                if re.search(r'\$_GET\[.*\].*eval\(', content, re.I):
                    vuln_findings.append(f"[!] POTENTIAL RCE in {php_file}: eval() with user input")
                if re.search(r'\$_POST\[.*\].*eval\(', content, re.I):
                    vuln_findings.append(f"[!] POTENTIAL RCE in {php_file}: eval() with user input")
                if re.search(r'\$_REQUEST\[.*\].*eval\(', content, re.I):
                    vuln_findings.append(f"[!] POTENTIAL RCE in {php_file}: eval() with user input")
                
                if re.search(r'system\(.*\$_GET\[', content, re.I):
                    vuln_findings.append(f"[!] POTENTIAL COMMAND INJECTION in {php_file}: system() with GET")
                if re.search(r'system\(.*\$_POST\[', content, re.I):
                    vuln_findings.append(f"[!] POTENTIAL COMMAND INJECTION in {php_file}: system() with POST")
                
                if re.search(r'include\(.*\$_GET\[', content, re.I) or re.search(r'require\(.*\$_GET\[', content, re.I):
                    vuln_findings.append(f"[!] POTENTIAL LFI in {php_file}: include/require with user input")
                
                if re.search(r\"\$_GET\[.*\].*mysql_query\(|\$_GET\[.*\].*mysqli_query\(\", content, re.I):
                    vuln_findings.append(f"[!] POTENTIAL SQLi in {php_file}: mysql query with GET")
                
                if re.search(r\"\$_POST\[.*\].*mysql_query\(|\$_POST\[.*\].*mysqli_query\(\", content, re.I):
                    vuln_findings.append(f"[!] POTENTIAL SQLi in {php_file}: mysql query with POST")
                    
            except Exception as e:
                pass
        
        if vuln_findings:
            print("\n".join(vuln_findings))
        else:
            print("[i] No obvious vulnerabilities detected in scanned files")
        
        # Search for FLAG patterns in all files
        print("\n" + "=" * 60)
        print("[+] FLAG SEARCH")
        print("=" * 60)
        
        flags_found = []
        for file_path in files:
            try:
                content = zip_file.read(file_path).decode('utf-8', errors='ignore')
                flags = re.findall(r'FLAG\{[^}]+\}', content)
                if flags:
                    for flag in flags:
                        flags_found.append(f"[+] FLAG found in {file_path}: {flag}")
            except:
                pass
        
        if flags_found:
            print("\n".join(flags_found))
        else:
            print("[-] No FLAG found in plugin files")
        
        # Check for sensitive patterns
        print("\n" + "=" * 60)
        print("[+] SENSITIVE DATA SEARCH")
        print("=" * 60)
        
        sensitive_findings = []
        for file_path in files:
            try:
                content = zip_file.read(file_path).decode('utf-8', errors='ignore')
                
                if 'DB_PASSWORD' in content or 'DB_USER' in content:
                    sensitive_findings.append(f"[!] Database credentials in {file_path}")
                if 'SECRET_KEY' in content:
                    sensitive_findings.append(f"[!] Secret keys in {file_path}")
                if 'API_KEY' in content or 'api_key' in content:
                    sensitive_findings.append(f"[!] API keys in {file_path}")
                if 'password' in file_path.lower():
                    sensitive_findings.append(f"[!] File with 'password' in name: {file_path}")
                    
            except:
                pass
        
        if sensitive_findings:
            print("\n".join(sensitive_findings))
        else:
            print("[i] No sensitive data patterns found")
            
        # Summary
        print("\n" + "=" * 60)
        print("[SUMMARY]")
        print("=" * 60)
        print(f"[+] Plugin file: {plugin_zip}")
        print(f"[+] Total files: {len(file_list)}")
        print(f"[+] PHP files: {len(php_files)}")
        print(f"[+] Vulnerabilities found: {len(vuln_findings)}")
        print(f"[+] Flags found: {len(flags_found)}")
        print(f"[+] Sensitive findings: {len(sensitive_findings)}")
        
    else:
        print(f"[-] Failed to download plugin: {response.status_code}")
        print(f"[-] Response: {response.text[:500]}")
        
except Exception as e:
    print(f"[-] Error analyzing plugin: {e}")
    import traceback
    traceback.print_exc()
