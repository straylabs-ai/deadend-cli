    zip_file.extractall(extract_dir)

print(f"[+] Extraction complete")

# List all PHP files
print(f"\n{'='*60}")
print("PHP FILES FOUND IN PLUGIN:")
print(f"{'='*60}")

php_files = []
for root, dirs, files in os.walk(extract_dir):
    for file in files:
        if file.endswith('.php'):
            full_path = os.path.join(root, file)
            relative_path = os.path.relpath(full_path, extract_dir)
            php_files.append({
                'path': full_path,
                'relative': relative_path
            })
            print(f"  {relative_path}")

print(f"\n[+] Found {len(php_files)} PHP files")

# Search for upload handling code
print(f"\n{'='*60}")
print("SEARCHING FOR UPLOAD-RELATED CODE:")
print(f"{'='*60}")

upload_keywords = ['upload', 'file', 'move_uploaded_file', '$_FILES', 'wp_upload_dir', 'canto']
vulnerability_indicators = ['$_FILES', 'move_uploaded_file', 'file_get_contents', 'file_put_contents', 'unlink', 'copy', 'rename']

suspicious_files = []

for php_file in php_files:
    try:
        with open(php_file['path'], 'r', encoding='utf-8', errors='ignore') as f:
            content = f.read()
            
            found_keywords = []
            found_indicators = []
            
            for keyword in upload_keywords:
                if keyword.lower() in content.lower():
                    found_keywords.append(keyword)
            
            for indicator in vulnerability_indicators:
                if indicator in content:
                    found_indicators.append(indicator)
            
            if found_keywords or found_indicators:
                suspicious_files.append({
                    'relative': php_file['relative'],
                    'keywords': found_keywords,
                    'indicators': found_indicators,
                    'content': content
                })
                
                print(f"\n[+] {php_file['relative']}")
                if found_keywords:
                    print(f"    Upload keywords: {', '.join(found_keywords)}")
                if found_indicators:
                    print(f"    Vulnerability indicators: {', '.join(found_indicators)}")
    except Exception as e:
        print(f"[!] Error reading {php_file['relative']}: {e}")

print(f"\n[+] Found {len(suspicious_files)} files with upload-related code")

# Print directory structure
print(f"\n{'='*60}")
print("DIRECTORY STRUCTURE:")
print(f"{'='*60}")

for root, dirs, files in os.walk(extract_dir):
    level = root.replace(extract_dir, '').count(os.sep)
    indent = ' ' * 2 * level
    print(f"{indent}{os.path.basename(root)}/")
    
    sub_indent = ' ' * 2 * (level + 1)
    for file in files:
        print(f"{sub_indent}{file}")

# Read and display key PHP files related to file uploads
key_files = [
    'canto/includes/lib/media-upload.php',
    'canto/includes/lib/class-canto-admin-api.php',
    'canto/includes/lib/class-canto-attachment.php',
    'canto/includes/class-canto-settings.php',
    'canto/includes/class-canto.php'
