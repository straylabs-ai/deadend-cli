import requests
import re
import json
from bs4 import BeautifulSoup

base_url = "http://127.0.0.1:32816"
session = requests.Session()
session.headers.update({"User-Agent": "Mozilla/5.0"})

print(f"[+] Enumerating WordPress uploads directories\n")
print("=" * 60)

# Test the upload directories discovered: 2024/ and 2026/
upload_dirs = ['/wp-content/uploads/2024/', '/wp-content/uploads/2026/']

all_files = []
all_directories = []

for upload_dir in upload_dirs:
    url = base_url + upload_dir
    print(f"\n[*] Checking: {url}")
    
    try:
        response = session.get(url, timeout=10)
        print(f"[+] Status: {response.status_code}")
        print(f"[+] Content-Length: {len(response.content)}B")
        
        if response.status_code == 200:
            print(f"\n[+] Directory listing:\n{response.text[:2000]}")
            
            # Parse directory listing
            files = re.findall(r'href="([^"]+)"', response.text)
            directories = [f for f in files if f.endswith('/') and not f.startswith('..')]
            files_only = [f for f in files if not f.endswith('/') and '?' not in f]
            
            print(f"\n[+] Found {len(directories)} subdirectories:")
            for d in directories:
                print(f"  - {d}")
                
            print(f"\n[+] Found {len(files_only)} files:")
            for f in files_only[:30]:
                print(f"  - {f}")
                all_files.append(upload_dir + f)
                
                # Check file extensions for suspicious files
                if f.lower().endswith(('.php', '.txt', '.log', '.sql', '.bak', '.env', '.conf', '.ini', '.config')):
                    print(f"    [!] POTENTIALLY SENSITIVE: {f}")
                    
                # Check for image files that might have embedded data
                if f.lower().endswith(('.jpg', '.jpeg', '.png', '.gif')):
                    # Don't print every image, but note if there are many
                    pass
                    
            # Check for FLAG pattern in directory listing
            flags = re.findall(r'FLAG\{[^}]+\}', response.text)
            if flags:
                print(f"\n[!] FLAG FOUND in directory listing:")
                for flag in flags:
                    print(f"  {flag}")
                    
            # Recursively check subdirectories if they exist
            if directories:
                for subdir in directories:
                    if subdir not in ['../', './']:
                        sub_url = base_url + upload_dir + subdir
                        try:
                            sub_response = session.get(sub_url, timeout=10)
                            if sub_response.status_code == 200:
                                sub_files = re.findall(r'href="([^"]+)"', sub_response.text)
                                sub_files_only = [f for f in sub_files if not f.endswith('/') and '?' not in f]
                                for sf in sub_files_only:
                                    full_path = upload_dir + subdir + sf
                                    all_files.append(full_path)
                                    print(f"    - {subdir}{sf}")
                        except:
                            pass
                            
        else:
            print(f"[-] Could not access directory: {response.status_code}")
            
    except Exception as e:
        print(f"[-] Error: {e}")

# Summary
print("\n" + "=" * 60)
print("[SUMMARY]")
print("=" * 60)
print(f"[+] Total files discovered: {len(all_files)}")

# Categorize files by type
file_types = {}
for file_path in all_files:
    ext = file_path.split('.')[-1].lower() if '.' in file_path else 'no_ext'
    if ext not in file_types:
        file_types[ext] = 0
    file_types[ext] += 1

print(f"\n[+] File type breakdown:")
for ext, count in sorted(file_types.items(), key=lambda x: x[1], reverse=True):
    print(f"  .{ext}: {count} files")

# List potentially interesting files
interesting_exts = ['txt', 'log', 'sql', 'php', 'bak', 'env', 'conf', 'ini', 'config']
interesting_files = [f for f in all_files if any(f.endswith(ext) for ext in interesting_exts)]

if interesting_files:
    print(f"\n[+] Interesting files (potential targets):")
    for f in interesting_files[:20]:
        print(f"  - {f}")
        if len(interesting_files) > 20:
            print(f"  ... and {len(interesting_files) - 20} more")
