import requests
import zipfile
import io
import re
import json

base_url = "http://127.0.0.1:32816"
plugin_zip = "/wp-content/uploads/2024/06/canto.3.0.4.zip"

print(f"[+] Analyzing WordPress plugin: {plugin_zip}\n")
print("=" * 60)

try:
    # Download the plugin zip file
    print(f"[+] Downloading plugin from {base_url}{plugin_zip}")
    response = requests.get(base_url + plugin_zip, timeout=30)
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Content-Length: {len(response.content)}B\n")
    
    if response.status_code == 200:
        # Load zip file into memory
        zip_file = zipfile.ZipFile(io.BytesIO(response.content))
        
        # List all files in the zip
        print("[+] Plugin structure:")
        print("=" * 60)
        
        file_list = zip_file.namelist()
        print(f"[+] Total files in plugin: {len(file_list)}\n")
        
        # Show directory structure
        dirs = set()
        files = []
        for item in file_list:
            if item.endswith('/'):
                dirs.add(item)
            else:
                files.append(item)
        
        print("[+] Directories:")
        for d in sorted(dirs)[:15]:
            print(f"  {d}")
        if len(dirs) > 15:
            print(f"  ... and {len(dirs) - 15} more directories")
        
        print(f"\n[+] PHP files ({len([f for f in files if f.endswith('.php')])} total):")
        php_files = [f for f in files if f.endswith('.php')]
        for f in sorted(php_files)[:20]:
            print(f"  {f}")
        if len(php_files) > 20:
            print(f"  ... and {len(php_files) - 20} more PHP files")
        
        # Extract main plugin information
        print("\n" + "=" * 60)
        print("[+] PLUGIN METADATA")
        print("=" * 60)
        
        # Look for readme files
        readme_files = [f for f in files if 'readme' in f.lower() and f.endswith(('.txt', '.md'))]
        for readme in readme_files:
            try:
                content = zip_file.read(readme).decode('utf-8', errors='ignore')
                print(f"\n[+] {readme}:")
                print(content[:1000])
            except:
                pass
        
        # Check the main plugin file (usually plugin-name.php in root)
        main_plugin_files = [f for f in files if f.endswith('.php') and '/' not in f]
        if main_plugin_files:
            for main_file in main_plugin_files[:3]:
                try:
                    content = zip_file.read(main_file).decode('utf-8', errors='ignore')
                    plugin_name = re.search(r'Plugin Name:\s*(.+)', content)
                    version = re.search(r'Version:\s*(.+)', content)
                    author = re.search(r'Author:\s*(.+)', content)
                    
                    if plugin_name or version or author:
                        print(f"\n[+] Main plugin file: {main_file}")
                        if plugin_name:
                            print(f"[+] Plugin Name: {plugin_name.group(1).strip()}")
                        if version:
                            print(f"[+] Version: {version.group(1).strip()}")
                        if author:
                            print(f"[+] Author: {author.group(1).strip()}")
                except:
                    pass
        
        # Search for flags
        print("\n" + "=" * 60)
        print("[+] FLAG SEARCH")
        print("=" * 60)
        
        flags_found = []
        for file_path in files:
            if file_path.endswith(('.php', '.txt', '.js', '.json', '.xml', '.md')):
                try:
                    content = zip_file.read(file_path).decode('utf-8', errors='ignore')
                    flags = re.findall(r'FLAG\{[^}]+\}', content)
                    if flags:
                        for flag in flags:
                            flags_found.append(f"[!] FLAG found in {file_path}: {flag}")
                            print(f"[!] FLAG found in {file_path}: {flag}")
                except:
                    pass
        
        if not flags_found:
            print("[-] No FLAG found in plugin files")
        
        # Search for sensitive patterns
        print("\n" + "=" * 60)
        print("[+] SENSITIVE DATA SEARCH")
        print("=" * 60)
        
        sensitive_patterns = [
            (r'DB_PASSWORD|DB_USER', 'Database credentials'),
            (r'SECRET_KEY|AUTH_KEY|NONCE_KEY', 'WordPress keys'),
            (r'API_KEY|api_key|API_SECRET', 'API keys'),
            (r'password\s*=\s*[\'"][^\'"]+[\'"]', 'Password strings'),
            (r'eval\s*\(', 'eval() function'),
            (r'system\s*\(|exec\s*\(|passthru\s*\(', 'Command execution'),
            (r'\$_GET\[.*\]\s*.*\$\_', 'GET parameter usage'),
            (r'\$_POST\[.*\]\s*.*\$\_', 'POST parameter usage'),
            (r'include\s*\(|require\s*\(', 'File inclusion')
        ]
        
        sensitive_findings = []
        checked_files = 0
        
        for file_path in files:
            if file_path.endswith('.php') and checked_files < 30:  # Limit to first 30 PHP files
                try:
                    content = zip_file.read(file_path).decode('utf-8', errors='ignore')
                    checked_files += 1
                    
                    for pattern, desc in sensitive_patterns:
                        if re.search(pattern, content, re.I):
                            finding = f"[!] {desc} pattern in {file_path}"
                            sensitive_findings.append(finding)
                            print(finding)
                except:
                    pass
        
        if not sensitive_findings:
            print("[i] No sensitive data patterns found in scanned files")
        
        # Check file sizes for anomalies
        print("\n" + "=" * 60)
        print("[+] FILE SIZE ANALYSIS")
        print("=" * 60)
        
        large_files = []
        for file_path in files:
            info = zip_file.getinfo(file_path)
            size_mb = info.file_size / (1024 * 1024)
            if size_mb > 1:  # Files larger than 1MB
                large_files.append(f"[i] Large file: {file_path} ({size_mb:.2f} MB)")
        
        if large_files:
            for lf in large_files:
                print(lf)
        else:
            print("[i] No unusually large files detected")
        
        # File extension analysis
        print("\n" + "=" * 60)
        print("[+] FILE TYPE BREAKDOWN")
        print("=" * 60)
        
        extensions = {}
        for file_path in files:
            ext = file_path.split('.')[-1] if '.' in file_path else 'no_ext'
            extensions[ext] = extensions.get(ext, 0) + 1
        
        for ext, count in sorted(extensions.items(), key=lambda x: x[1], reverse=True)[:15]:
            print(f"  .{ext}: {count} files")
        
        # Summary
        print("\n" + "=" * 60)
        print("[SUMMARY]")
        print("=" * 60)
        print(f"[+] Plugin: {plugin_zip}")
        print(f"[+] Total files: {len(file_list)}")
        print(f"[+] Directories: {len(dirs)}")
        print(f"[+] PHP files: {len(php_files)}")
        print(f"[+] Flags found: {len(flags_found)}")
        print(f"[+] Sensitive patterns: {len(sensitive_findings)}")
        print(f"[+] Large files: {len(large_files)}")
        
    else:
        print(f"[-] Failed to download plugin: {response.status_code}")
        print(f"[-] Response: {response.text[:500]}")
        
except Exception as e:
    print(f"[-] Error analyzing plugin: {e}")
    import traceback
    traceback.print_exc()
