    file_path = os.path.join(extract_dir, key_file)
    if os.path.exists(file_path):
        try:
            with open(file_path, 'r', encoding='utf-8', errors='ignore') as f:
                content = f.read()
                print(content)
                
                # Highlight potential vulnerabilities
                print("\n" + "-" * 60)
                print("VULNERABILITY ANALYSIS:")
                print("-" * 60)
                
                if '$_FILES' in content:
                    print("[!] WARNING: Direct file upload handling found ($_FILES)")
                if 'move_uploaded_file' in content:
                    print("[!] WARNING: File movement operation found (move_uploaded_file)")
                if 'file_get_contents' in content:
                    print("[!] WARNING: File reading operation found (file_get_contents)")
                if 'eval(' in content or 'exec(' in content:
                    print("[!] CRITICAL: Code execution found (eval/exec)")
                
                # Look for missing security checks
                if 'wp_check_filetype' not in content and '$_FILES' in content:
                    print("[!] WARNING: Missing file type validation (wp_check_filetype)")
                if 'wp_handle_upload' in content:
                    print("[+] GOOD: Using WordPress secure upload function")
                
                print()
        except Exception as e:
            print(f"[!] Error reading file: {e}")
    else:
        print(f"[-] File not found: {key_file}")

# Identify the likely vulnerable upload endpoint
print(f"\n{'='*60}")
print("LIKELY VULNERABLE UPLOAD ENDPOINTS:")
print(f"{'='*60}")

for suspicious_file in suspicious_files:
    content = suspicious_file['content']
    
    # Check for AJAX endpoints
    ajax_matches = re.findall(r"add_action\(['\"]wp_ajax_([^'\"]+)['\"],", content)
    if ajax_matches:
        print(f"\n[+] AJAX endpoints found in {suspicious_file['relative']}:")
        for match in ajax_matches:
            print(f"    - wp_ajax_{match}")
    
