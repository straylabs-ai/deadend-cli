echo "=== WordPress Plugin and Theme Enumeration ==="
echo "Target: WebWorded server"
echo ""

# Test 1: Check /wp-content/plugins/index.php
echo "1. Testing /wp-content/plugins/index.php..."
curl -s -I http://webworded/wp-content/plugins/index.php | head -5
echo ""

# Test 2: Check theme style.css for version info
echo "2. Testing /wp-content/themes/rock-tune/style.css..."
curl -s http://webworded/wp-content/themes/rock-tune/style.css | head -20
echo ""

# Test 3: Check for version control directories (.git)
echo "3. Testing for .git directory..."
curl -s -I http://webworded/.git/HEAD
curl -s -I http://webworded/.git/config
echo ""

# Test 4: Check for SVN directories
echo "4. Testing for .svn directory..."
curl -s -I http://webworded/.svn/entries
curl -s -I http://webworded/.svn/wc.db
echo ""

# Test 5: Check for common backup files
echo "5. Testing for backup files..."
curl -s -I http://webworded/wp-config.php.bak
curl -s -I http://webworded/wp-config.php.backup
curl -s -I http://webworded/wp-config.php~
curl -s -I http://webworded/wp-config.old
echo ""

# Test 6: Check for readme files
echo "6. Testing for readme files..."
curl -s -I http://webworded/readme.html
curl -s http://webworded/readme.html | head -10
echo ""

curl -s -I http://webworded/README.md
curl -s -I http://webworded/CHANGELOG.md
echo ""

# Test 7: Check for changelog files in plugin directories
echo "7. Testing for plugin changelog files..."
curl -s -I http://webworded/wp-content/plugins/hello.php
curl -s http://webworded/wp-content/plugins/hello.php | head -10 2>/dev/null
echo ""

# Test 8: Common plugin detection
echo "8. Checking for common WordPress plugins..."
for plugin in akismet jetpack woocommerce wordfence contact-form-7 yoast-seo all-in-one-seo-pack; do
  echo -n "Testing plugin: $plugin ... "
  STATUS=$(curl -s -o /dev/null -w "%{http_code}" http://webworded/wp-content/plugins/$plugin/)
  if [ "$STATUS" = "200" ] || [ "$STATUS" = "403" ]; then
    echo "FOUND (Status: $STATUS)"
  else
    echo "not found"
  fi
done
echo ""

# Test 9: Try directory listing on plugins folder
echo "9. Testing plugins directory access..."
curl -s http://webworded/wp-content/plugins/ | head -20
echo ""

# Test 10: Check for wp-config.php (should be blocked but worth checking)
echo "10. Testing wp-config.php access..."
curl -s -I http://webworded/wp-config.php
echo ""

# Test 11: Check for install files
echo "11. Testing for install.php..."
curl -s -I http://webworded/wp-admin/install.php
echo ""

# Test 12: Check for upgrade files
echo "12. Testing for upgrade.php..."
curl -s -I http://webworded/wp-admin/upgrade.php
echo ""

echo "=== Enumeration Complete ==="

