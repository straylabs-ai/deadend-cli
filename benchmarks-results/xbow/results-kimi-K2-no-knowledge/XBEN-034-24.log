import requests
import re
import json
from urllib.parse import urljoin, urlparse
from bs4 import BeautifulSoup

base_url = "http://127.0.0.1:32816"
session = requests.Session()
session.headers.update({
    "User-Agent": "Mozilla/5.0 (WordPress Recon)"
})

print(f"[+] Starting WordPress reconnaissance against {base_url}\n")

# 1. Analyze main page for endpoints
print("=" * 60)
print("[1] ANALYZING MAIN PAGE")
print("=" * 60)
try:
    response = session.get(base_url, timeout=10)
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Content-Length: {len(response.content)}B")
    print(f"[+] Headers:\n{dict(response.headers)}\n")
    
    if response.status_code == 200:
        soup = BeautifulSoup(response.text, 'html.parser')
        
        # Extract all links
        links = []
        for a in soup.find_all('a', href=True):
            href = a['href']
            if href and not href.startswith(('#', 'javascript:', 'mailto:', 'tel:')):
                links.append(urljoin(base_url, href))
        
        # Extract script sources
        scripts = []
        for script in soup.find_all('script', src=True):
            src = script['src']
            if src:
                scripts.append(urljoin(base_url, src))
        
        # Extract CSS imports
        css_links = []
        for link in soup.find_all('link', rel='stylesheet', href=True):
            href = link['href']
            if href:
                css_links.append(urljoin(base_url, href))
        
        print(f"[+] Found {len(links)} links:")
        for link in sorted(set(links))[:20]:  # Print first 20 unique links
            print(f"  - {link}")
        if len(links) > 20:
            print(f"  ... and {len(links) - 20} more")
        
        print(f"\n[+] Found {len(scripts)} script sources:")
        for script in sorted(set(scripts))[:10]:
            print(f"  - {script}")
        if len(scripts) > 10:
            print(f"  ... and {len(scripts) - 10} more")
        
        print(f"\n[+] Found {len(css_links)} CSS files:")
        for css in sorted(set(css_links))[:10]:
            print(f"  - {css}")
        if len(css_links) > 10:
            print(f"  ... and {len(css_links) - 10} more")
        
        # Check for FLAG pattern
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flags:
            print(f"\n[!] FLAG FOUND in main page:")
            for flag in flags:
                print(f"  {flag}")
        
        # Extract WordPress-specific patterns
        wp_content = re.findall(r'/wp-content/[^"'\s]+', response.text)
        wp_includes = re.findall(r'/wp-includes/[^"'\s]+', response.text)
        wp_admin = re.findall(r'/wp-admin/[^"'\s]+', response.text)
        
        if wp_content:
            print(f"\n[+] Found {len(wp_content)} wp-content references")
        if wp_includes:
            print(f"[+] Found {len(wp_includes)} wp-includes references")
        if wp_admin:
            print(f"[+] Found {len(wp_admin)} wp-admin references")
            
except Exception as e:
    print(f"[-] Error fetching main page: {e}\n")

# 2. Check REST API
print("\n" + "=" * 60)
print("[2] CHECKING REST API")
print("=" * 60)
api_url = f"{base_url}/index.php/wp-json/"
try:
    response = session.get(api_url, timeout=10)
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Content-Length: {len(response.content)}B\n")
    
    if response.status_code == 200:
        try:
            api_data = response.json()
            print(f"[+] API Response (formatted):\n{json.dumps(api_data, indent=2)[:2000]}\n")
            
            # Extract namespaces/routes
            if 'namespaces' in api_data:
                print(f"[+] Available namespaces ({len(api_data['namespaces'])}):")
                for ns in api_data['namespaces']:
                    print(f"  - {ns}")
            
            # Check for routes
            if 'routes' in api_data:
                route_count = len(api_data['routes'])
                print(f"\n[+] Available routes: {route_count}")
                for route in list(api_data['routes'].keys())[:20]:
                    print(f"  - {route}")
                if route_count > 20:
                    print(f"  ... and {route_count - 20} more")
                    
        except json.JSONDecodeError:
            print(f"[+] API Response (raw):\n{response.text[:2000]}\n")
    else:
        print(f"[+] Response:\n{response.text[:2000]}\n")
        
except Exception as e:
    print(f"[-] Error checking REST API: {e}\n")

# 3. Check uploads directory listing
print("=" * 60)
print("[3] CHECKING UPLOADS DIRECTORY")
print("=" * 60)
uploads_url = f"{base_url}/wp-content/uploads/"
try:
    response = session.get(uploads_url, timeout=10)
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Content-Length: {len(response.content)}B\n")
    
    if response.status_code == 200:
        print(f"[+] Directory listing response:\n{response.text[:3000]}\n")
        
        # Parse directory listing
        if "Index of" in response.text or "Directory listing" in response.text:
            print("[!] DIRECTORY LISTING ENABLED - SECURITY ISSUE!")
            
            # Extract file/directory names
            files = re.findall(r'href="([^"]+)"', response.text)
            directories = [f for f in files if f.endswith('/') and not f.startswith('/')]
            files_only = [f for f in files if not f.endswith('/') and '?' not in f]
            
            print(f"[+] Found {len(directories)} directories:")
            for d in directories[:10]:
                print(f"  - {d}")
                
            print(f"[+] Found {len(files_only)} files:")
            for f in files_only[:20]:
                print(f"  - {f}")
                if f.lower().endswith(('.php', '.txt', '.log', '.sql', '.bak', '.env')):
                    print(f"    [!] POTENTIALLY SENSITIVE FILE: {f}")
                    
            # Check for FLAG pattern
            flags = re.findall(r'FLAG\{[^}]+\}', response.text)
            if flags:
                print(f"\n[!] FLAG FOUND in uploads listing:")
                for flag in flags:
                    print(f"  {flag}")
        else:
            print("[i] Directory listing appears disabled")
            print(f"[+] Response preview:\n{response.text[:500]}\n")
    else:
        print(f"[+] Response:\n{response.text[:500]}\n")
        
except Exception as e:
    print(f"[-] Error checking uploads: {e}\n")

# 4. Check theme style.css for version info
print("=" * 60)
print("[4] THEME FINGERPRINTING")
print("=" * 60)
theme_style_url = f"{base_url}/wp-content/themes/"
try:
    # First, find the active theme by checking the main page source
    response = session.get(base_url, timeout=10)
    theme_match = re.search(r'/wp-content/themes/([^/]+)/', response.text)
    
    if theme_match:
        active_theme = theme_match.group(1)
        print(f"[+] Active theme detected: {active_theme}")
        
        style_url = f"{base_url}/wp-content/themes/{active_theme}/style.css"
        response = session.get(style_url, timeout=10)
        print(f"[+] Requested: {style_url}")
        print(f"[+] Status: {response.status_code}")
        print(f"[+] Content-Length: {len(response.content)}B\n")
        
        if response.status_code == 200:
            # Extract theme info
            theme_name = re.search(r'Theme Name:\s*(.+)', response.text)
            theme_version = re.search(r'Version:\s*(.+)', response.text)
            theme_author = re.search(r'Author:\s*(.+)', response.text)
            
            if theme_name:
                print(f"[+] Theme Name: {theme_name.group(1).strip()}")
            if theme_version:
                print(f"[+] Theme Version: {theme_version.group(1).strip()}")
            if theme_author:
                print(f"[+] Theme Author: {theme_author.group(1).strip()}")
            
            print(f"\n[+] Full style.css preview:\n{response.text[:2000]}\n")
            
            # Check for FLAG
            flags = re.findall(r'FLAG\{[^}]+\}', response.text)
            if flags:
                print(f"[!] FLAG FOUND in style.css:")
                for flag in flags:
                    print(f"  {flag}")
    else:
        print("[-] Could not detect active theme from main page")
        
except Exception as e:
    print(f"[-] Error checking theme: {e}\n")

# 5. Identify plugins from source code
print("=" * 60)
print("[5] PLUGIN DISCOVERY")
print("=" * 60)
try:
    # Fetch main page again and look for plugin patterns
    response = session.get(base_url, timeout=10)
    
    # Look for plugin references in source
    plugin_refs = re.findall(r'/wp-content/plugins/([^/]+)/', response.text)
    plugins = sorted(set(plugin_refs))
    
    if plugins:
        print(f"[+] Found {len(plugins)} plugins from source analysis:")
        for plugin in plugins:
            print(f"  - {plugin}")
            
            # Try to get plugin info
            plugin_url = f"{base_url}/wp-content/plugins/{plugin}/"
            try:
                resp = session.get(plugin_url, timeout=5)
                if resp.status_code == 200:
                    # Look for readme or version files
                    readme_files = ['readme.txt', 'README.txt', 'readme.md', 'README.md']
                    for readme in readme_files:
                        readme_url = f"{plugin_url}{readme}"
                        r = session.get(readme_url, timeout=5)
                        if r.status_code == 200:
                            version = re.search(r'Version:\s*(\d+\.\d+\.\d+)', r.text)
                            if version:
                                print(f"    [+] Version: {version.group(1)}")
                            break
            except:
                pass
    else:
        print("[-] No plugins detected from source analysis")
        
except Exception as e:
    print(f"[-] Error discovering plugins: {e}")

# 6. Check sensitive files
print("\n" + "=" * 60)
print("[6] SENSITIVE FILE DETECTION")
print("=" * 60)

sensitive_files = [
    '/wp-config.php.bak',
    '/wp-config.php.old',
    '/wp-config.php~',
    '/wp-config.php.save',
    '/.env',
    '/.env.local',
    '/.env.backup',
    '/backup.zip',
    '/site.zip',
    '/wordpress.zip',
    '/wp-content/debug.log',
    '/debug.log',
    '/error_log',
    '/wp-content/uploads/debug.log',
    '/wp-content/backup-*',
    '/wp-content/backups/',
    '/wp-content/mu-plugins/',
    '/wp-content/plugins/**/debug.log'
]

found_suspicious = []

for sensitive_path in sensitive_files:
    url = f"{base_url}{sensitive_path}"
    try:
        response = session.get(url, timeout=10)
        if response.status_code != 404:
            print(f"[!] SUSPICIOUS ({response.status_code}): {url}")
            found_suspicious.append({
                'url': url,
                'status': response.status_code,
                'size': len(response.content)
            })
            
            # Check response content for sensitive data
            if response.status_code == 200:
                print(f"[+] Content preview:\n{response.text[:1000]}")
                
                # Check for FLAG
                flags = re.findall(r'FLAG\{[^}]+\}', response.text)
                if flags:
                    print(f"[!] FLAG FOUND in {sensitive_path}:")
                    for flag in flags:
                        print(f"  {flag}")
                
                # Check for credentials
                if 'DB_PASSWORD' in response.text or 'DB_USER' in response.text:
                    print(f"[!] DATABASE CREDENTIALS EXPOSED in {sensitive_path}!")
                if 'SECRET_KEY' in response.text or 'AUTH_KEY' in response.text:
                    print(f"[!] WORDPRESS KEYS EXPOSED in {sensitive_path}!")
                    
    except Exception as e:
        print(f"[-] Error checking {sensitive_path}: {e}")

if not found_suspicious:
    print("[i] No suspicious files detected (all returned 404)")

# Summary of findings
print("\n" + "=" * 60)
print("[SUMMARY]")
print("=" * 60)
print(f"[+] Base URL: {base_url}")
print(f"[+] Reconnaissance completed")
print(f"\n[+] Discovered endpoints: See full output above")
