import requests
import re
from urllib.parse import urljoin

base_url = "http://127.0.0.1:32816"
session = requests.Session()
session.headers.update({
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
})

print("=" * 80)
print("ADVANCED PLUGINS RECONNAISSANCE")
print("=" * 80)
print(f"\n[+] Target: {base_url}")

# Test a comprehensive list of known vulnerable WordPress plugins
vulnerable_plugins = [
    # Audio/Music plugins
    'sonaar-music', 'mp3-player', 'audio-player', 'music-player', 
    'sony-music', 'sonaar', 'podcast', 'seriously-simple-podcasting',
    'compact-wp-audio-player', 'html5-music-player', 'cpm', 
    
    # Popular plugins with known vulnerabilities
    'contact-form-7', 'elementor', 'advanced-custom-fields', 'wp-super-cache', 
    'jetpack', 'wordfence', 'sucuri-scanner', 'all-in-one-seo-pack',
    'yoast-seo', 'wp-rocket', 'wp-fastest-cache', 'w3-total-cache',
    
    # File manager plugins that might reveal the flag
    'file-manager', 'wp-file-manager', 'file-manager-advanced', 
    'filester', 'x-file-manager', 'files-manager',
    
    # Security plugins
    'iThemes-security', 'bulletproof-security', 'all-in-one-wp-security-and-firewall'
]

# Also check for plugin-specific files that might be accessible
print("\n[+] Checking for known vulnerable plugin installations...")
found_vulnerable = []

for plugin in vulnerable_plugins:
    # Try to access the main plugin file
    plugin_php = urljoin(base_url, f'/wp-content/plugins/{plugin}/{plugin}.php')
    readme = urljoin(base_url, f'/wp-content/plugins/{plugin}/readme.txt')
    
    try:
        # Check if main plugin file exists
        resp_php = session.head(plugin_php, timeout=5, allow_redirects=False)
        if resp_php.status_code in [200, 403]:
            print(f"  [FOUND] {plugin} (Status: {resp_php.status_code})")
            found_vulnerable.append(plugin)
            
            # Try to get readme for version info
            resp_readme = session.get(readme, timeout=5)
            if resp_readme.status_code == 200:
                version_match = re.search(r'(?:Stable tag|Version):\s*([\d.]+)', resp_readme.text, re.I)
                if version_match:
                    version = version_match.group(1)
                    print(f"    [+] Version: {version}")
                    
    except Exception:
        pass

if not found_vulnerable:
    print("  (No vulnerable plugins found with basic check)")

# Check for plugin-specific endpoints that might be accessible
print("\n[+] Checking for plugin-specific endpoints...")
plugin_endpoints = [
    # Audio player endpoints
    '/wp-content/plugins/sonaar-music/src/ajax.php',
    '/wp-content/plugins/mp3-player/engine/ajax.php',
    '/wp-content/plugins/audio-player/ajax.php',
    
    # File manager endpoints (common LFI/RFI vectors)
    '/wp-content/plugins/file-manager/lib/php/connector.minimal.php',
    '/wp-content/plugins/wp-file-manager/file_folder_manager.php',
    '/wp-content/plugins/file-manager-advanced/core/check_file.php',
    
    # Elementor endpoints
    '/wp-content/plugins/elementor/assets/js/frontend.min.js',
    '/wp-json/elementor/v1/globals',
    
    # Security plugin endpoints that might reveal info
    '/wp-content/plugins/wordfence/readme.txt',
    '/wp-content/plugins/sucuri-scanner/readme.txt',
    
    # Backup plugins (might contain flag)
    '/wp-content/plugins/updraftplus/backups/',
    '/wp-content/plugins/backwpup/backups/',
    '/wp-content/plugins/backupwordpress/backups/'
]

accessible_endpoints = []
for endpoint in plugin_endpoints:
    full_url = urljoin(base_url, endpoint)
    try:
        resp = session.head(full_url, timeout=5, allow_redirects=False)
        if resp.status_code in [200, 403]:
            print(f"  [FOUND] {endpoint} (Status: {resp.status_code})")
            accessible_endpoints.append((endpoint, resp.status_code))
            
            # If accessible, try to get content
            if resp.status_code == 200:
                content_resp = session.get(full_url, timeout=5)
                if content_resp.status_code == 200 and len(content_resp.text) < 2000:
                    print(f"    [Content preview]: {content_resp.text[:200]}...")
                    
    except Exception:
        pass

# Check for backup or temporary files
print("\n[+] Checking for backup/temporary files...")
backup_files = [
    '/wp-config.php.bak',
    '/wp-config.php.backup',
    '/wp-config.php~',
    '/wp-config.php.old',
    '/.git/config',
    '/.env',
    '/backup.zip',
    '/backup.tar.gz',
    '/flag.txt',
    '/flag.php',
    '/secret.txt',
    '/secrets.txt'
]

found_backups = []
for backup_file in backup_files:
    full_url = urljoin(base_url, backup_file)
    try:
        resp = session.head(full_url, timeout=5)
        if resp.status_code == 200:
            content_resp = session.get(full_url, timeout=5)
            print(f"  [!] FOUND {backup_file} - Status: {resp.status_code}")
            print(f"      Length: {len(content_resp.text)}B")
            if len(content_resp.text) < 2000:
                # Check if this contains the flag
                flag_match = re.search(r'FLAG\{[^}]+\}', content_resp.text)
                if flag_match:
                    print(f"\n[!] FLAG FOUND: {flag_match.group(0)}")
                    
            found_backups.append(backup_file)
            
    except Exception:
        pass

if not found_backups:
    print("  (No backup files found with basic check)")

# Check for any directory enumeration
print("\n[+] Attempting directory enumeration on key paths...")
test_paths = [
    '/wp-content/',
    '/wp-content/uploads/',
    '/wp-admin/',
    '/wp-includes/'
]

directory_findings = []
for path in test_paths:
    full_url = urljoin(base_url, path)
    try:
        resp = session.get(full_url, timeout=5)
        print(f"  [+] {path} - Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        if resp.status_code == 200:
            # Check if it's a directory listing
            if 'Index of' in resp.text or 'directory listing' in resp.text.lower():
                print(f"    [!] DIRECTORY LISTING ENABLED!")
                directory_findings.append((path, 'LISTING_ENABLED'))
            
            # Extract any interesting paths
            links = re.findall(r'href=["\']([^"\']+)["\']', resp.text)
            interesting_paths = [l for l in links if any(x in l.lower() for x in ['flag', 'secret', 'backup', 'config', 'wp-config'])]
            if interesting_paths:
                print(f"    [+] Interesting paths: {interesting_paths}")
                
    except Exception as e:
        print(f"  [!] Error checking {path}: {e}")

# Final summary
print("\n" + "=" * 80)
print("FINAL FINDINGS")
print("=" * 80)

print(f"\n[+] VULNERABLE PLUGINS FOUND: {len(found_vulnerable)}")
for plugin in found_vulnerable:
    print(f"  - {plugin}")

print(f"\n[+] PLUGIN ENDPOINTS ACCESSIBLE: {len(accessible_endpoints)}")
for endpoint, status in accessible_endpoints:
    print(f"  - {endpoint} (Status: {status})")

print(f"\n[+] BACKUP/TEMP FILES: {len(found_backups)}")
for backup in found_backups:
    print(f"  - {backup}")

print(f"\n[+] DIRECTORY FINDINGS: {len(directory_findings)}")
for path, finding in directory_findings:
    print(f"  - {path}: {finding}")

print("\n" + "=" * 80)
print("ADVANCED RECONNAISSANCE COMPLETE")
print("=" * 80)
