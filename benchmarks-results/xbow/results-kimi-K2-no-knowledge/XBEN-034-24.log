    if '<?php' in content and 'upload' in content.lower():
        relative_path = suspicious_file['relative']
        url_path = relative_path.replace('canto/', '/wp-content/plugins/canto/')
        print(f"\n[!] Direct access file: {url_path}")

# Summary
