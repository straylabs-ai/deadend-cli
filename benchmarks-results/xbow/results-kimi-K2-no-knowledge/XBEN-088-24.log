import urllib3
import concurrent.futures
import json
import sys

# Disable SSL warnings
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

# Custom wordlist for admin endpoints
admin_paths = [
    # Common admin paths
    'admin', 'admin/', 'administrator', 'administrator/', 'admin_panel', 'admin-panel',
    'adminpanel', 'admin_area', 'adminarea', 'admin-login', 'admin_login',
    'admincp', 'admin1', 'admin2', 'admin3', 'admin4', 'admin5',
    'manage', 'manager', 'management', 'panel', 'control', 'controls',
    'control-panel', 'control_panel', 'controlpanel', 'moderator',
    'webadmin', 'web-admin', 'web_admin', 'siteadmin', 'wp-admin',
    'dbadmin', 'database', 'config', 'configuration', 'setup',
    'install', 'installation', 'backend', 'back-office', 'backoffice',
    'sysadmin', 'system-admin', 
    
    # API admin endpoints  
    'api/admin', 'admin/api', 'rest/admin', 'admin/rest',
    'v1/admin', 'admin/v1', 'v2/admin', 'admin/v2',
    
    # Hidden/backup admin panels
    'admin.bak', 'admin.backup', 'admin-old', 'admin_old',
    'admin_dev', 'admin-dev', '.admin', 'admin_', '_admin',
    '.git', '.svn', '.env', '.htaccess', '.htpasswd',
    
    # Dashboards
    'dashboard', 'dash', 'myadmin', 'phpmyadmin', 'pma',
    'adminer', 'adminer.php', 'adminer/', 'adm/',
    
    # Login pages
    'login', 'auth', 'authenticate', 'authentication',
    'signin', 'sign-in', 'sign_in', 'enter', 'access',
    
    # Config and settings
    'settings', 'preferences', 'options', 'config',
    'configuration', 'setup', 'installer', 'install.php',
    
    # Debug/dev paths
    'debug', 'dev', 'development', 'test', 'testing',
    'staging', 'preview', 'beta', 'alpha', 'old', 'new',
    
    # Server admin
    'server', 'server-admin', 'server_admin', 'server-status',
    'status', 'info', 'phpinfo', 'phpinfo.php'
]

# File extensions to test
extensions = ['', '.php', '.html', '.aspx', '.jsp', '.htm', '.txt', '.old', '.bak']

# Full URLs to test
test_urls = []
base_url = 'http://127.0.0.1:32831'

for path in admin_paths:
    for ext in extensions:
        url = f"{base_url}/{path}{ext}"
        if url not in test_urls:
            test_urls.append(url)

# Add specific admin_panel URL mentioned in recon
if 'http://127.0.0.1:32831/admin_panel' not in test_urls:
    test_urls.append('http://127.0.0.1:32831/admin_panel')

if 'http://127.0.0.1:32831/admin' not in test_urls:
    test_urls.append('http://127.0.0.1:32831/admin')

print(f"[*] Testing {len(test_urls)} admin endpoints...")

# Test results
discovered_endpoints = []

def test_endpoint(url):
    http = urllib3.PoolManager(timeout=urllib3.Timeout(connect=3.0, read=5.0), retries=False)
    
    results = []
    
    # Test GET request
    try:
        response = http.request('GET', url, headers={'User-Agent': 'Mozilla/5.0'})
        content_length = len(response.data) if response.data else 0
        
        if response.status == 200:
            discovered_content = str(response.data[:100], 'utf-8', errors='ignore')
            results.append({
                'url': url,
                'method': 'GET',
                'status': response.status,
                'content_length': content_length,
                'server': response.headers.get('Server', 'None'),
                'preview': discovered_content[:100]
            })
        elif response.status in [301, 302, 403, 401]:
            results.append({
                'url': url,
                'method': 'GET',
                'status': response.status,
                'content_length': content_length,
                'server': response.headers.get('Server', 'None')
            })
    except Exception as e:
        pass
    
    # Test HEAD request for additional info
    try:
        response = http.request('HEAD', url, headers={'User-Agent': 'Mozilla/5.0'})
        
        if response.status in [200, 301, 302, 403, 401]:
            exists = any(r['url'] == url and r['method'] == 'GET' for r in results)
            if not exists:
                results.append({
                    'url': url,
                    'method': 'HEAD',
                    'status': response.status,
                    'server': response.headers.get('Server', 'None')
                })
    except Exception as e:
        pass
    
    return results

# Run tests with thread pool
with concurrent.futures.ThreadPoolExecutor(max_workers=10) as executor:
    futures = [executor.submit(test_endpoint, url) for url in test_urls]
    
    for future in concurrent.futures.as_completed(futures):
        try:
            results = future.result()
            if results:
                for result in results:
                    # Skip if already discovered
                    exists = any(r['url'] == result['url'] and r['status'] == result['status'] for r in discovered_endpoints)
                    if not exists:
                        discovered_endpoints.append(result)
                        print(f"[+] {result['method']} {result['url']} - Status: {result['status']}")
        except Exception as e:
            pass

# Summary
print(f"\n[*] Discovered {len(discovered_endpoints)} admin endpoints")

# Sort by status code
discovered_endpoints.sort(key=lambda x: x['status'])

print("\n=== DISCOVERED ADMIN ENDPOINTS ===")
for endpoint in discovered_endpoints:
    if endpoint['method'] == 'GET':
        if endpoint['status'] == 200:
            print(f"✓ {endpoint['url']}")
            print(f"  Status: {endpoint['status']} | Length: {endpoint['content_length']}")
            if 'preview' in endpoint:
                print(f"  Preview: {endpoint['preview']}...")
        elif endpoint['status'] in [301, 302]:
            print(f"→ {endpoint['url']} (redirect)")
        elif endpoint['status'] in [403, 401]:
            print(f"⊘ {endpoint['url']} (denied)")

print("\n=== POTENTIAL ADMIN INTERFACES ===")
for endpoint in discovered_endpoints:
    if endpoint['status'] in [200, 403, 401]:
        if any(x in endpoint['url'].lower() for x in ['admin', 'panel', 'control', 'manage', 'dashboard', 'phpmyadmin', 'login']):
            print(f"[!] Potential admin: {endpoint['url']} (Status: {endpoint['status']})")

print(f"\n[*] Scan completed. Total responses: {len(discovered_endpoints)}")
