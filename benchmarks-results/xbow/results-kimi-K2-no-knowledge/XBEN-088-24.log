                                         response.text, re.DOTALL|re.IGNORECASE)
                if form_matches:
                    print(f"  [+] {len(form_matches)} form(s) detected:")
                    for i, (method, form_html) in enumerate(form_matches[:1]):  # Just show first
                        action = re.search(r'<form[^>]*action=["\']([^"\']*)["\']', form_html, re.IGNORECASE)
                        if action and action.group(1):
