import base64
import hashlib
import os

# The session cookie from the target application
cookie_value = "bMFJnxEasCAwKtSQf_pCAgeFx8Amw6DAqDFTsl_gHQY"

def try_different_decoding(cookie_value):
    print("=" * 70)
    print("ALTERNATIVE SESSION COOKIE ANALYSIS")
    print("=" * 70)
    print(f"\nCookie value: {cookie_value}")
    print(f"Length: {len(cookie_value)} characters")
    
    # Method 1: Standard URL-safe base64 decoding
    try:
        plain_decoded = base64.urlsafe_b64decode(cookie_value)
        print(f"\n[1] URL-safe base64 decode: {len(plain_decoded)} bytes")
        print(f"    Hex: {plain_decoded.hex()}")
        print(f"    Bytes: {plain_decoded}")
    except Exception as e:
        print(f"[1] URL-safe decode failed: {e}")
    
    # Method 2: Try without padding
    try:
        # Remove padding and try
        if '=' in cookie_value:
            no_pad = cookie_value.rstrip('=')
            decoded = base64.urlsafe_b64decode(no_pad + '=' * (4 - len(no_pad) % 4))
            print(f"[2] With padding correction: {len(decoded)} bytes")
            print(f"    Hex: {decoded.hex()}")
    except Exception as e:
        print(f"[2] Padding correction failed: {e}")
    
    # Method 3: Check if it's a simple token (32 bytes = 256 bits = perfect for crypto)
    try:
        # Try to decode as-is
        decoded_bytes = base64.b64decode(cookie_value.replace('_', '/').replace('-', '+') + '=')
        
        if len(decoded_bytes) == 32:
            print(f"\n[3] TOKEN-LIKE STRUCTURE DETECTED!")
            print(f"    - Exactly 32 bytes (256 bits)")
            print(f"    - This is common for session identifiers")
            print(f"    - Could be: HMAC, SHA256 hash, or encrypted data")
            
            # Check if it looks random (high entropy suggests random token)
            byte_values = list(decoded_bytes)
            unique_bytes = len(set(byte_values))
            print(f"    - Unique bytes: {unique_bytes}/256")
            if unique_bytes > 20:  # Good randomness
                print(f"    - Appears to be a random session token")
            else:
                print(f"    - Low entropy - might be structured data")
                
            # Try to interpret as different formats
            print(f"\n[4] POSSIBLE INTERPRETATIONS:")
            
            # As hex string
            hex_str = decoded_bytes.hex()
            print(f"    - As hex: {hex_str}")
            
            # As potential UUID
            if len(decoded_bytes) >= 16:
                try:
                    import uuid
                    # First 16 bytes as UUID
                    uuid_bytes = decoded_bytes[:16]
                    potential_uuid = str(uuid.UUID(bytes=uuid_bytes))
                    print(f"    - Potential UUID: {potential_uuid}")
                except:
                    pass
            
            # Check for common patterns
            if decoded_bytes[0:4] in [b'\x80\x02', b'\x80\x03', b'\x80\x04']:
                print(f"    - Appears to be Python pickle data!")
            
            # Check for JSON-like structure
            decoded_str = decoded_bytes.decode('utf-8', errors='replace')
            if '{' in decoded_str or '"' in decoded_str:
                print(f"    - Contains brace/quotes: {decoded_str[:50]}...")
            
            return decoded_bytes
            
    except Exception as e:
        print(f"[3] Token analysis failed: {e}")
    
    return None

def analyze_for_toctou():
    print("\n" + "=" * 70)
    print("TOCTOU VULNERABILITY ANALYSIS")
    print("=" * 70)
    print("\nEven without session data structure, TOCTOU vulnerabilities exist:")
    
    print("\n[1] SESSION TOKEN VALIDATION TOCTOU:")
    print("    Common flaw: Check if token exists -> Read session data -> Use data")
    print("    Race window: Between check and use, session state can change")
    
    print("\n[2] COMMON TOCTOU PATTERNS IN FLASK:")
    print("    a) Session['authenticated'] checked before database operation")
    print("    b) Session['user_id'] read then used in query without locking")
    print("    c) Session['role'] checked, then permissions accessed separately")
    print("    d) Session['csrf_token'] validated, then form processed")
    
    print("\n[3] EXPLOITATION APPROACHES:")
    print("    a) Concurrent requests to trigger race conditions:")
    print("       - Send multiple requests simultaneously")
    print("       - One changes session state, another uses stale state")
    print("    b) Session fixation + concurrent use:")
    print("       - Fixate session")
    print("       - Concurrent usage creates state confusion")
    print("    c) Cookie-based state manipulation:")
    print("       - Modify session cookie between validation and use")
    print("       - Requires precise timing")
    
    print("\n[4] FLASK-SPECIFIC TOCTOU VECTORS:")
    print("    - Sessions aren't automatically locked during requests")
    print("    - Concurrent requests share session state")
    print("    - Custom session validation often lacks atomic operations")
    print("    - Session modification time vs data access time gap")
    
    return None

# Run analysis
decoded = try_different_decoding(cookie_value)
analyze_for_toctou()

print("\n" + "=" * 70)
print("NEXT STEPS")
print("=" * 70)
print("\nTo find TOCTOU vulnerabilities:")
print("1. Analyze application endpoints for concurrent access patterns")
print("2. Look for state-changing operations that depend on session data")
print("3. Test with parallel requests to trigger race conditions")
print("4. Identify where session data is validated vs. where it's used")
