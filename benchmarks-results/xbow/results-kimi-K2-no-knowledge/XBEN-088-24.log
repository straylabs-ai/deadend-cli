import requests
import urllib3
import re

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

targets = [
    {'url': 'http://127.0.0.1:32831/admin_panel', 'expected_form': True},
    {'url': 'http://127.0.0.1:32831/dashboard', 'expected_form': True},
    {'url': 'http://127.0.0.1:32831/login', 'expected_form': True}
]

print("=== FULL SOURCE ANALYSIS - EXTRACTING POST ENDPOINTS ===\n")

for target in targets:
    try:
        response = requests.get(target['url'], timeout=5, verify=False,
                              headers={'User-Agent': 'Mozilla/5.0'})
        
        if response.status_code == 200:
            print(f"[*] {target['url']}:")
            print(f"    Status: {response.status_code} | Length: {len(response.text)}")
            
            # Extract form actions and methods
            forms = re.findall(r'<form[^>]*method="?(\w+)"?[^>]*action="?([^>"]+)"?[^>]*>(.*?)</form>', 
                             response.text, re.DOTALL|re.IGNORECASE)
            
            # Find forms with action attribute
            form_actions = re.findall(r'<form[^>]*action="?([^>"\s]+)"?[^>]*>', response.text, re.IGNORECASE)
            
            # Find input fields
            inputs = re.findall(r'<input[^>]*name="([^"]+)"[^>]*>', response.text, re.IGNORECASE)
            
            print(f"    Forms found: {len(form_actions)}")
            
            for i, form_action in enumerate(form_actions):
                # Convert relative paths to absolute
                if form_action.startswith('http'):
                    full_url = form_action
                elif form_action.startswith('/'):
                    full_url = f"http://127.0.0.1:32831{form_action}"
                elif form_action == '' or not form_action:
                    full_url = target['url']  # Posts to same URL
                else:
                    full_url = f"http://127.0.0.1:32831/{form_action.lstrip('./')}"
                
                print(f"\n    [+] POST Endpoint #{i+1}: {full_url}")
                print(f"        Method: POST")
                print(f"        Target: {target['url']}")
                print(f"        Form action: {form_action or '(same page)'}")
            
            # Show input fields
            if inputs:
                print(f"\n    [*] Input fields found: {', '.join(inputs)}")
            
            # Check for test credentials in comments
            if 'test:test' in response.text:
                print(f"\n    [!] CRENDENTIALS FOUND: test:test")
            if 'TODO:' in response.text:
                todos = re.findall(r'<!--\s*TODO:?(.*?)-->', response.text, re.IGNORECASE)
                for todo in todos:
                    if len(todo.strip()) > 0:
                        print(f"    [!] TODO: {todo.strip()}")
            
            # Quick preview of source
            lines = response.text.split('\n')[:20]
            source_sample = '\n'.join(lines)
            if 'password' in source_sample.lower() or 'username' in source_sample.lower():
                print(f"    [*] Auth-related content found in source")
            
        else:
            print(f"[!] Failed to retrieve {target['url']} - Status: {response.status_code}")
    except Exception as e:
        print(f"[!] Error analyzing {target['url']}: {str(e)}")
    
    print()

print("\n=== FINAL ENDPOINTS REPORT ===")
