import requests
import threading
import time
import json
from concurrent.futures import ThreadPoolExecutor, as_completed

# Target configuration
BASE_URL = "http://127.0.0.1:5000"
SESSION_COOKIE = "bMFJnxEasCAwKtSQf_pCAgeFx8Amw6DAqDFTsl_gHQY"

# Common Flask endpoints that might have TOCTOU issues
TEST_ENDPOINTS = [
    "/",
    "/home",
    "/dashboard",
    "/profile",
    "/account",
    "/settings",
    "/api/user",
    "/api/profile",
    "/api/status",
    "/user/profile",
    "/user/settings",
    "/auth/status",
    "/check-auth"
]

def make_request(endpoint, cookie_value):
    """Make a single request with the session cookie"""
    try:
        cookies = {'session': cookie_value}
        headers = {'User-Agent': 'Mozilla/5.0 TOCTOU-Tester'}
        
        response = requests.get(
            f"{BASE_URL}{endpoint}",
            cookies=cookies,
            headers=headers,
            timeout=5,
            allow_redirects=True
        )
        
        return {
            'endpoint': endpoint,
            'status': response.status_code,
            'length': len(response.content),
            'cookies': dict(response.cookies),
            'headers': dict(response.headers),
            'text': response.text[:500] if response.text else "",
            'redirects': len(response.history)
        }
    except Exception as e:
        return {
            'endpoint': endpoint,
            'error': str(e),
            'status': None
        }

def test_endpoints():
    """Test all endpoints to find accessible ones"""
    print("=" * 70)
    print("ENDPOINT DISCOVERY")
    print("=" * 70)
    print(f"Testing {len(TEST_ENDPOINTS)} common Flask endpoints...\n")
    
    results = []
    accessible_endpoints = []
    
    for endpoint in TEST_ENDPOINTS:
        result = make_request(endpoint, SESSION_COOKIE)
        results.append(result)
        
        if result.get('status') == 200:
            print(f"[✓] {endpoint:20} - 200 OK ({result['length']} bytes)")
            accessible_endpoints.append(endpoint)
        elif result.get('status') in [301, 302, 303, 307]:
            print(f"[→] {endpoint:20} - Redirect {result['status']}")
        elif result.get('status') == 401:
            print(f"[✗] {endpoint:20} - 401 Unauthorized")
        elif result.get('status') == 403:
            print(f"[✗] {endpoint:20} - 403 Forbidden")
        elif 'error' in result:
            print(f"[✗] {endpoint:20} - Error: {result['error']}")
        else:
            print(f"[?] {endpoint:20} - Status: {result.get('status')}")
    
    print(f"\n[SUMMARY] Accessible endpoints: {len(accessible_endpoints)}")
    for ep in accessible_endpoints:
        print(f"    - {ep}")
    
    return accessible_endpoints

def test_toctou_race_condition(endpoint, iterations=50):
    """Test for TOCTOU race conditions using concurrent requests"""
    print("\n" + "=" * 70)
    print(f"TOCTOU RACE CONDITION TEST")
    print("=" * 70)
    print(f"Endpoint: {endpoint}")
    print(f"Iterations: {iterations}")
    print(f"Concurrent threads: 10\n")
    
    anomalies = []
    response_times = []
    
    def concurrent_request():
        start = time.time()
        result = make_request(endpoint, SESSION_COOKIE)
        end = time.time()
        return result, (end - start)
    
    for i in range(iterations):
        # Send 10 concurrent requests
        with ThreadPoolExecutor(max_workers=10) as executor:
            futures = [executor.submit(concurrent_request) for _ in range(10)]
            
            batch_results = []
            batch_times = []
            
            for future in as_completed(futures):
                result, req_time = future.result()
                batch_results.append(result)
                batch_times.append(req_time)
                response_times.append(req_time)
            
            # Check for anomalies in this batch
            statuses = [r.get('status') for r in batch_results if 'status' in r]
            lengths = [r.get('length', 0) for r in batch_results if 'length' in r]
            
            # Look for inconsistent responses
            if len(set(statuses)) > 1:
                print(f"[ANOMALY] Batch {i+1:2d}: Multiple status codes: {set(statuses)}")
                anomalies.append({
                    'batch': i+1,
                    'type': 'status_inconsistency',
                    'data': batch_results
                })
            
            if len(set(lengths)) > 1:
                print(f"[ANOMALY] Batch {i+1:2d}: Different response sizes: {set(lengths)}")
                anomalies.append({
                    'batch': i+1,
                    'type': 'size_inconsistency',
                    'data': batch_results
                })
            
            # Look for errors that might indicate race conditions
            errors = [r.get('error') for r in batch_results if 'error' in r]
            if errors:
                print(f"[ERROR] Batch {i+1:2d}: {len(errors)} request(s) failed")
                anomalies.append({
                    'batch': i+1,
                    'type': 'errors',
                    'errors': errors
                })
        
        if (i + 1) % 10 == 0:
            avg_time = sum(response_times) / len(response_times)
            print(f"      Progress: {i+1}/{iterations} | Avg response: {avg_time:.3f}s")
    
    # Analyze response time patterns
    if response_times:
        avg_time = sum(response_times) / len(response_times)
        max_time = max(response_times)
        min_time = min(response_times)
        
        print(f"\n[RESPONSE TIME ANALYSIS]")
        print(f"    Average: {avg_time:.3f}s")
        print(f"    Min:     {min_time:.3f}s")
        print(f"    Max:     {max_time:.3f}s")
        print(f"    Range:   {max_time - min_time:.3f}s")
        
        # Check for timing anomalies
        slow_requests = [t for t in response_times if t > avg_time * 2]
        if len(slow_requests) > len(response_times) * 0.1:  # More than 10% are slow
            print(f"    [WARNING] {len(slow_requests)} unusually slow responses detected")
            print(f"              This might indicate server-side locking or race conditions!")
    
    print(f"\n[TOTAL ANOMALIES DETECTED: {len(anomalies)}]")
    return anomalies

def analyze_session_validation_patterns(accessible_endpoints):
    """Analyze how endpoints validate and use session data"""
    print("\n" + "=" * 70)
    print("SESSION VALIDATION PATTERN ANALYSIS")
    print("=" * 70)
    print("\nChecking for authentication/status endpoints...\n")
    
    # Look for status/auth endpoints
    status_endpoints = [ep for ep in accessible_endpoints if 'status' in ep or 'auth' in ep or 'check' in ep]
    
    if status_endpoints:
        print(f"Found {len(status_endpoints)} status/auth endpoints:")
        for ep in status_endpoints:
            result = make_request(ep, SESSION_COOKIE)
            print(f"\n[+] {ep}")
            print(f"    Status: {result.get('status')}")
            if result.get('text'):
                print(f"    Response: {result['text'][:100]}...")
    else:
        print("No obvious status/auth endpoints found, testing all accessible endpoints...")
        for ep in accessible_endpoints[:3]:  # Test first 3
            result = make_request(ep, SESSION_COOKIE)
            print(f"\n[+] {ep}")
            print(f"    Status: {result.get('status')}")
            print(f"    Length: {result.get('length')} bytes")
            if 'text' in result:
                print(f"    Response preview: {result['text'][:150]}...")

def main():
    """Main testing function"""
    print("Flask Session Cookie TOCTOU Analysis")
    print(f"Target: {BASE_URL}")
    print(f"Cookie: {SESSION_COOKIE[:20]}...")
    print("=" * 70)
    
    try:
        # Step 1: Discover accessible endpoints
        accessible = test_endpoints()
        
        if not accessible:
            print("\n[!] No accessible endpoints found with this session cookie")
            print("    The cookie may be invalid or expired.")
            return
        
        # Step 2: Analyze session validation patterns
        analyze_session_validation_patterns(accessible)
        
        # Step 3: Test most promising endpoint for TOCTOU
        target_endpoint = accessible[0]  # Test the first accessible endpoint
        print(f"\n[SELECTED TOCTOU TEST TARGET: {target_endpoint}]")
        
        anomalies = test_toctou_race_condition(target_endpoint, iterations=30)
        
        if anomalies:
            print(f"\n[!] RACE CONDITION ANOMALIES DETECTED!")
            print(f"    {len(anomalies)} anomalous response patterns found")
            print(f"\nThis suggests a TOCTOU vulnerability may exist!")
            print(f"The server is showing inconsistent behavior under concurrent load.")
        else:
            print(f"\n[-] No obvious race condition patterns detected in basic test")
            print(f"    More sophisticated testing may be needed.")
            
    except Exception as e:
        print(f"\n[ERROR] Testing failed: {e}")
        import traceback
        traceback.print_exc()

if __name__ == "__main__":
    main()
