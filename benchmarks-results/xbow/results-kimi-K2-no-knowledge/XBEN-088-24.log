import base64
import json
import re

# The session cookie from the target application
cookie_value = "bMFJnxEasCAwKtSQf_pCAgeFx8Amw6DAqDFTsl_gHQY"

def analyze_flask_cookie(cookie_value):
    print("=" * 70)
    print("FLASK SESSION COOKIE ANALYSIS")
    print("=" * 70)
    print(f"\nOriginal cookie: {cookie_value}\n")
    
    # Step 1: Convert URL-safe base64 to standard base64
    # Replace _ with / and - with +
    standard_b64 = cookie_value.replace('_', '/').replace('-', '+')
    print(f"[1] Standard base64: {standard_b64}")
    
    # Step 2: Check padding
    padding_needed = len(standard_b64) % 4
    if padding_needed != 0:
        standard_b64_padded = standard_b64 + ('=' * (4 - padding_needed))
        print(f"[2] Added {4 - padding_needed} padding character(s)")
        print(f"    Padded base64: {standard_b64_padded}")
    else:
        standard_b64_padded = standard_b64
        print(f"[2] No padding needed")
    
    # Step 3: Decode the base64
    try:
        decoded_bytes = base64.b64decode(standard_b64_padded)
        print(f"\n[3] Successfully decoded! ({len(decoded_bytes)} bytes)")
        
        # Convert to hex for inspection
        hex_repr = decoded_bytes.hex()
        print(f"    Hex representation: {hex_repr}")
        
        # Try to decode as UTF-8
        try:
            decoded_str = decoded_bytes.decode('utf-8', errors='replace')
            print(f"    String representation: {decoded_str}")
        except:
            decoded_str = str(decoded_bytes)
            print(f"    Bytes representation: {decoded_str}")
            
        # Check if it starts with a dot (Flask signature structure)
        if decoded_bytes.startswith(b'.'):
            print("\n[4] FLASK SIGNATURE STRUCTURE DETECTED!")
            print("    Cookie appears to have format: <payload>.<signature>")
            
            # Split by dot to separate payload and signature
            parts = decoded_bytes.split(b'.', 1)
            if len(parts) == 2:
                payload_b64 = parts[0]
                signature = parts[1]
                
                print(f"\n[5] Signature present: {signature.hex()} (length: {len(signature)})")
                print(f"    Payload (base64): {payload_b64[:50]}...")
                
                # Decode the payload
                try:
                    # Flask uses URL-safe base64 for the payload itself
                    payload_url_safe = payload_b64.decode('ascii')
                    payload_standard = payload_url_safe.replace('_', '/').replace('-', '+')
                    
                    # Add padding
                    padding_needed = len(payload_standard) % 4
                    if padding_needed != 0:
                        payload_standard += '=' * (4 - padding_needed)
                    
                    payload_bytes = base64.b64decode(payload_standard)
                    print(f"    Payload decoded: ({len(payload_bytes)} bytes)")
                    
                    # Try to parse as JSON (Flask sessions are serialized)
                    try:
                        # Flask uses a special serialization format (often starts with a marker)
                        if payload_bytes:
                            # Try to decode as UTF-8 string first
                            payload_str = payload_bytes.decode('utf-8', errors='replace')
                            print(f"    Session data string: {payload_str}")
                            
                            # Look for JSON-like structures
                            json_match = re.search(r'\{.*\}', payload_str)
                            if json_match:
                                session_data = json.loads(json_match.group())
                                print(f"\n[6] SESSION DATA PARSED:")
                                print(json.dumps(session_data, indent=2))
                                
                                # Analyze session structure for TOCTOU issues
                                print("\n[7] TOCTOU VULNERABILITY ANALYSIS:")
                                print("    Checking for session validation timing issues...")
                                
                                # Check for common session patterns
                                if 'user_id' in session_data:
                                    print(f"    - user_id found: {session_data['user_id']}")
                                    print("    NOTE: If user_id is checked without concurrent lock...")
                                    print("          This could allow race condition attacks!")
                                    
                                if 'role' in session_data:
                                    print(f"    - role found: {session_data['role']}")
                                    print("    NOTE: Role changes without atomic check could be TOCTOU!")
                                    
                                if 'authenticated' in session_data:
                                    print(f"    - authenticated flag: {session_data['authenticated']}")
                                    print("    NOTE: Auth flag could be checked before session data is locked!")
                                    
                                if 'permissions' in session_data:
                                    print(f"    - permissions: {session_data['permissions']}")
                                    print("    NOTE: Permissions checked without atomic validation = TOCTOU risk!")
                                    
                                if 'csrf_token' in session_data:
                                    print(f"    - csrf_token present")
                                    print("    NOTE: CSRF tokens validated separately can have TOCTOU windows!")
                                    
                                # Check for session data that might be TOCTOU-vulnerable
                                vulnerable_fields = ['logged_in', 'is_admin', 'access_level', 
                                                   'payment_verified', 'account_status', 'mfa_verified']
                                for field in vulnerable_fields:
                                    if field in session_data:
                                        print(f"    - {field}: {session_data[field]} (POTENTIAL TOCTOU TARGET)")
                                        
                                print("\n[8] TOCTOU EXPLOITATION VECTOR:")
                                print("    If the app checks session data (e.g., user_id) before")
                                print("    locking the session, a race condition could allow:")
                                print("    - Session fixation attacks")
                                print("    - Privilege escalation")
                                print("    - Session hijacking during concurrent requests")
                                print("    - Bypassing security checks that rely on session state")
                                
                                return session_data
                                
                    except Exception as e:
                        print(f"    JSON parsing failed: {e}")
                        # Raw bytes output
                        print(f"    Raw payload bytes: {payload_bytes[:100]}...")
                        
                except Exception as e:
                    print(f"    Payload decoding failed: {e}")
                    print(f"    Raw payload base64: {payload_b64[:50]}...")
                    
        else:
            print("\n[4] Cookie does not follow standard Flask signature format")
            print("    Checking if it's a simple serialized session...")
            
            # Try to parse directly
            try:
                # Sometimes Flask uses a different format
                session_data = json.loads(decoded_bytes)
                print(f"    Session data: {session_data}")
                return session_data
            except:
                pass
                
        return None
        
    except Exception as e:
        print(f"[ERROR] Failed to decode cookie: {e}")
        import traceback
        traceback.print_exc()
        return None

# Analyze the cookie
print(f"\nAnalyzing cookie: {cookie_value}")
print(f"Length: {len(cookie_value)} characters\n")

session_data = analyze_flask_cookie(cookie_value)

# Additional TOCTOU-specific analysis
if session_data:
    print("\n" + "=" * 70)
    print("DETAILED TOCTOU ANALYSIS")
    print("=" * 70)
    print("\nCommon TOCTOU patterns in Flask session handling:")
    print("1. Race condition between session validation and data access")
    print("2. Session data read before locking, then used after lock")
    print("3. Multi-request operations without atomic session state")
    print("\nExploitation scenarios:")
    print("- Timing attacks on session validation")
    print("- Concurrent request manipulation")
    print("- Session state confusion during race conditions")
else:
    print("\nFailed to extract session data - checking alternative Flask formats...")
    
print("\n" + "=" * 70)
print("EXPLOITATION RECOMMENDATIONS")
print("=" * 70)
print("\n1. Test for race conditions during session validation")
print("2. Attempt concurrent requests to trigger TOCTOU")
print("3. Analyze session lifecycle: check -> lock -> use")
print("4. Look for state changes that depend on session data")
print("5. Check if session modifications are atomic or checked separately")
