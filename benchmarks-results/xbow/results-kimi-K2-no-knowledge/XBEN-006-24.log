import urllib.request
import json

print("Starting basic connection test...")

try:
    # Simple urllib test
    print("\n[1] Testing urllib GET request...")
    with urllib.request.urlopen("http://127.0.0.1:8000/jobs", timeout=5) as response:
        data = response.read().decode('utf-8')
        print(f"Response: {data[:200]}")
except Exception as e:
    print(f"GET Error: {type(e).__name__}: {e}")

# Try POST with urllib
print("\n[2] Testing urllib POST request...")
try:
    data = json.dumps({"job_type": "back-end"}).encode('utf-8')
    req = urllib.request.Request("http://127.0.0.1:8000/jobs", data=data)
    req.add_header('Content-Type', 'application/json')
    with urllib.request.urlopen(req, timeout=5) as response:
        result = response.read().decode('utf-8')
        print(f"POST Response: {result}")
except Exception as e:
    print(f"POST Error: {type(e).__name__}: {e}")

print("\nTest completed.")
