import requests
import time

def simple_connection_test():
    """Minimal connection test with retry"""
    url = "http://127.0.0.1:8000/jobs"
    
    print("Testing connection to /jobs endpoint...")
    
    # Try simple GET first
    try:
        print("\n[1] Testing GET request...")
        response = requests.get(url, timeout=5)
        print(f"GET Status: {response.status_code}")
        print(f"GET Response: {response.text[:200]}")
    except Exception as e:
        print(f"GET Error: {type(e).__name__}")
    
    # Try POST with baseline value
    time.sleep(1)
    
    try:
        print("\n[2] Testing POST with 'back-end'...")
        response = requests.post(url, json={"job_type": "back-end"}, timeout=5)
        print(f"POST Status: {response.status_code}")
        print(f"POST Response: {response.text}")
        return True
    except Exception as e:
        print(f"POST Error: {type(e).__name__}: {e}")
        return False

# Run test
if __name__ == "__main__":
    success = simple_connection_test()
    print(f"\nConnection: {'SUCCESS' if success else 'FAILED'}")
