import requests
import json

url = "http://127.0.0.1:8000/jobs"
headers = {"Content-Type": "application/json"}

def test_payload(description, payload):
    """Test a payload and print results"""
    try:
        response = requests.post(url, headers=headers, json=payload, timeout=10)
        response_text = response.text[:200]
        
        print(f"Test: {description}")
        print(f"Payload: {json.dumps(payload)}")
        print(f"Status: {response.status_code}")
        print(f"Response: {response_text}")
        print("-" * 80)
        
        return response.status_code
    except Exception as e:
        print(f"Test: {description}")
        print(f"Payload: {json.dumps(payload)}")
        print(f"Error: {str(e)}")
        print("-" * 80)
        return None

print("=" * 80)
print("Testing VALID cases (baseline)")
print("=" * 80)

# Baseline valid cases
test_payload("Valid case - back-end", {"job_type": "back-end"})
test_payload("Valid case - front-end", {"job_type": "front-end"})
test_payload("Valid case - private", {"job_type": "private"})

print("\n" + "=" * 80)
print("Testing Case Variations")
print("=" * 80)

test_payload("Case variation - Back-end", {"job_type": "Back-end"})
test_payload("Case variation - BACK-END", {"job_type": "BACK-END"})
test_payload("Case variation - Back-End", {"job_type": "Back-End"})

print("\n" + "=" * 80)
print("Testing Whitespace Variations")
print("=" * 80)

test_payload("Whitespace - leading space", {"job_type": " back-end"})
test_payload("Whitespace - trailing space", {"job_type": "back-end "})
test_payload("Whitespace - trailing tab", {"job_type": "back-end\t"})
test_payload("Whitespace - trailing newline", {"job_type": "back-end\n"})

print("\n" + "=" * 80)
print("Testing JSON Encoding Tricks")
print("=" * 80)

test_payload("JSON encoding - unicode escape dash", {"job_type": "back\u002dend"})
test_payload("JSON encoding - null byte", {"job_type": "back-end\u0000"})

print("\n" + "=" * 80)
print("Testing Comment Injection")
print("=" * 80)

test_payload("Comment - SQL comment", {"job_type": "back-end--"})
test_payload("Comment - inline comment", {"job_type": "back-end/*test*/"})

print("\n" + "=" * 80)
print("Testing Alternative Quoting")
print("=" * 80)

test_payload("Quote - single quote in value", {"job_type": "back-end'"})
test_payload("Quote - back-end in single quotes", {"job_type": 'back-end'})

print("\n" + "=" * 80)
print("ANALYSIS")
print("=" * 80)
print("Review the status codes above. Consider:")
print("1. Which variations returned 200 OK?")
print("2. Those that pass might allow SQL injection if not properly quoted")
print("3. Check responses for differences in size/content")
print("=" * 80)
