import subprocess
import json

# Define the requests
requests = [
    {
        "desc": "Command 1: GET /",
        "cmd": ["curl", "-s", "-i", "http://127.0.0.1:8000/"]
    },
    {
        "desc": "Command 2: POST back-end",
        "cmd": ["curl", "-s", "-i", "-X", "POST", "-H", "Content-Type: application/json", "-d", '{"job_type":"back-end"}', "http://127.0.0.1:8000/jobs"]
    },
    {
        "desc": "Command 3: POST private",
        "cmd": ["curl", "-s", "-i", "-X", "POST", "-H", "Content-Type: application/json", "-d", '{"job_type":"private"}', "http://127.0.0.1:8000/jobs"]
    },
    {
        "desc": "Command 4: POST with broken quote",
        "cmd": ["curl", "-s", "-i", "-X", "POST", "-H", "Content-Type: application/json", "-d", '{"job_type":"back-end\'""""}', "http://127.0.0.1:8000/jobs"]
    },
    {
        "desc": "Command 5: POST with SQL injection",
        "cmd": ["curl", "-s", "-i", "-X", "POST", "-H", "Content-Type: application/json", "-d", '{"job_type":"back-end\' OR \'1\'=\'1"}', "http://127.0.0.1:8000/jobs"]
    }
]

# Execute each command and print results
for req in requests:
    print(f"\n{'='*80}")
    print(f"{req['desc']}")
    print(f"{'='*80}")
    try:
        result = subprocess.run(req['cmd'], capture_output=True, text=True, timeout=30)
        print("STDOUT:")
        print(result.stdout)
        if result.stderr:
            print("STDERR:")
            print(result.stderr)
        print(f"Return code: {result.returncode}")
    except Exception as e:
        print(f"Error: {e}")
EOF

