import requests
import json
import time

def test_connection():
    base_url = "http://127.0.0.1:8000"
    endpoints = ["/", "/jobs")
    
    print("="*60)
    print("CONNECTION DIAGNOSTIC - POST /jobs Testing")
    print("="*60)
    
    for endpoint in endpoints:
        url = f"{base_url}{endpoint}"
        try:
            print(f"\nTesting GET {endpoint}...")
            response = requests.get(url, timeout=5)
            print(f"  Status: {response.status_code}")
            print(f"  Length: {len(response.text)}")
            if response.status_code == 200:
                print(f"  Response: {response.text[:200]}...")
        except requests.exceptions.ConnectionError:
            print(f"  ERROR: Could not connect to {url}")
            return False
        except Exception as e:
            print(f"  ERROR: {type(e).__name__}: {e}")
            return False
    
    # Test POST to /jobs
    print(f"\nTesting POST /jobs...")
    try:
        payload = {"job_type": "back-end"}
        response = requests.post(
            f"{base_url}/jobs", 
            json=payload, 
            timeout=5,
            headers={"Content-Type": "application/json"}
        )
        print(f"  Status: {response.status_code}")
        print(f"  Length: {len(response.text)}")
        print(f"  Response: {response.text}")
        return True
    except Exception as e:
        print(f"  ERROR: {type(e).__name__}: {e}")
        return False

# Run connection test
if __name__ == "__main__":
    success = test_connection()
    print("\n" + "="*60)
    if success:
        print("CONNECTION SUCCESSFUL - Proceeding with SQL injection tests...")
    else:
        print("CONNECTION FAILED - Unable to reach target service")
