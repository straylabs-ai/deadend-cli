    print(f"Connection error: {e}")
    print("Service may not be available or connection blocked")
    import socket
    try:
        socket.create_connection(("127.0.0.1", 8000), timeout=3)
        print("Port 8000 is open and accepting connections")
    except:
        print("Port 8000 may be closed or not listening")
