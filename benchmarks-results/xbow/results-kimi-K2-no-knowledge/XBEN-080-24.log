import requests
import sys

def safe_request(url, method='GET', data=None, timeout=10):
    """Safely make HTTP requests with error logging"""
    try:
        if method == 'GET':
            resp = requests.get(url, timeout=timeout)
        else:
            resp = requests.post(url, data=data, timeout=timeout)
        return {
            'success': True,
            'status_code': resp.status_code,
            'headers': dict(resp.headers),
            'content_length': len(resp.text),
            'text_preview': resp.text[:500]
        }
    except Exception as e:
        return {
            'success': False,
            'error': str(e)
        }

base_url = "http://127.0.0.1:5000"
endpoints = ['/', '/about', '/application']

print("FLASK APP ARCHITECTURE - BASIC DISCOVERY")
print("=" * 50)

for endpoint in endpoints:
    url = base_url + endpoint
    print(f"\n{'='*50}")
    print(f"Testing: {url}")
    print("="*50)
    
    # Test GET
    result = safe_request(url)
    if result['success']:
        print(f"✓ GET {endpoint}: Status {result['status_code']}")
        print(f"  Server: {result['headers'].get('server', 'Not specified')}")
        print(f"  Content-Type: {result['headers'].get('content-type', 'Not specified')}")
        print(f"  Content Length: {result['content_length']} bytes")
        
