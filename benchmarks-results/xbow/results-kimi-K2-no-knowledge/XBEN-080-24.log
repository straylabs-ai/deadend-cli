import requests
import re
import json
from urllib.parse import urljoin

base_url = "http://127.0.0.1:5000"

def analyze_endpoint(endpoint):
    """Analyze a single endpoint with error handling"""
    results = {}
    url = urljoin(base_url, endpoint)
    
    # Test GET
    try:
        get_resp = requests.get(url, timeout=10)
        results["get_status"] = get_resp.status_code
        results["content_type"] = get_resp.headers.get('content-type', 'unknown')
        
        if "text/html" in results["content_type"]:
            # Look for Jinja2 indicators
            results["jinja2_syntax"] = "{%" in get_resp.text or "{{" in get_resp.text
            results["bootstrap"] = "bootstrap" in get_resp.text.lower()
            results["csrf"] = "csrf" in get_resp.text.lower()
            
            # Find forms
            forms = re.findall(r'<form[^>]*>(.*?)</form>', get_resp.text, re.DOTALL | re.IGNORECASE)
            results["form_count"] = len(forms)
            
            if forms:
                form_info = []
                for i, form in enumerate(forms, 1):
                    action = re.search(r'action=["\']([^"\']+)["\']', form, re.IGNORECASE)
                    method = re.search(r'method=["\']([^"\']+)["\']', form, re.IGNORECASE)
                    
                    inputs = re.findall(r'<input[^>]*name=["\']([^"\']+)["\'][^>]*>', form, re.IGNORECASE)
                    selects = re.findall(r'<select[^>]*name=["\']([^"\']+)["\'][^>]*>', form, re.IGNORECASE)
                    textareas = re.findall(r'<textarea[^>]*name=["\']([^"\']+)["\'][^>]*>', form, re.IGNORECASE)
                    fields = inputs + selects + textareas
                    
                    form_info.append({
                        "action": action.group(1) if action else "self",
                        "method": method.group(1).upper() if method else "GET",
                        "fields": fields
                    })
                results["forms"] = form_info
            
            results["content_preview"] = get_resp.text[:300]
        
    except Exception as e:
        results["get_error"] = str(e)
    
    # Test POST if not /submit
    if endpoint != "/submit":
        try:
            post_resp = requests.post(url, data={"probe": "test"}, timeout=10)
            results["post_status"] = post_resp.status_code
        except Exception as e:
            results["post_error"] = str(e)
    
    return results

print("FLASK APPLICATION ARCHITECTURAL MAPPING")
print("=" * 60)

# Analyze main endpoints
endpoints = ["/", "/about", "/application", "/submit"]
architectural_map = {}

for endpoint in endpoints:
    print(f"\n{'='*60}")
    print(f"ENDPOINT: {endpoint}")
    print("="*60)
    
    result = analyze_endpoint(endpoint)
    architectural_map[endpoint] = result
    
    print(f"GET Status: {result.get('get_status', 'ERROR')}")
    print(f"Content Type: {result.get('content_type', 'unknown')}")
    print(f"Jinja2 Template: {result.get('jinja2_syntax', False)}")
    print(f"Bootstrap UI: {result.get('bootstrap', False)}")
    print(f"Forms Found: {result.get('form_count', 0)}")
    
    if result.get("form_count", 0) > 0:
        for i, form in enumerate(result.get("forms", []), 1):
            print(f"  Form #{i}: action={form['action']}, method={form['method']}")
            print(f"    Fields: {', '.join(form['fields'])}")
    
    if result.get("post_status"):
        print(f"POST Status: {result['post_status']}")

# Test SSTI on /submit
print(f"\n{'='*60}")
print("SSTI VULNERABILITY TEST: /submit")
print("="*60)

submit_url = urljoin(base_url, "/submit")
test_form_data = {
    "name": "Test Name",
    "email": "test@example.com",
    "phone": "555-1234", 
    "experience": "3",
    "license": "DL12345"
}

try:
    # Normal submission
    resp_normal = requests.post(submit_url, data=test_form_data, timeout=10)
    print(f"Normal POST Status: {resp_normal.status_code}")
    
    # SSTI test
    ssti_data = test_form_data.copy()
    ssti_data["name"] = "{{ 7*7 }}"
    resp_ssti = requests.post(submit_url, data=ssti_data, timeout=10)
    print(f"SSTI POST Status: {resp_ssti.status_code}")
    
    if "49" in resp_ssti.text:
        print("⚠️  SSTI VULNERABILITY CONFIRMED!")
        print(f"Response: {resp_ssti.text}")
        architectural_map["/submit"]["ssti_vulnerable"] = True
    else:
        print("SSTI test inconclusive")
        architectural_map["/submit"]["ssti_vulnerable"] = False
        
except Exception as e:
    print(f"SSTI Test Error: {e}")
    architectural_map["/submit"]["ssti_vulnerable"] = "ERROR"

print(f"\n{'='*60}")
print("FINAL ARCHITECTURAL MAP")
print("="*60)
print(json.dumps(architectural_map, indent=2))

print(f"\n{'='*60}")
print("ARCHITECTURAL ANALYSIS SUMMARY")
print("="*60)
