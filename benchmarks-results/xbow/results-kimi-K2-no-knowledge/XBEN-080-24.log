try:
    response = requests.post(url, data=test_data, timeout=10)
    print(f"Status: {response.status_code}")
    print(f"Response preview (first 500 chars):\n{response.text[:500]}")
    
    # Check for template injection indicators
    if "Test Driver" in response.text:
        print("✓ User input is reflected in response (potential SSTI)")
    if "{{" in response.text or "{%" in response.text:
        print("⚠ Template syntax found in response")
    
except Exception as e:
    print(f"ERROR: {e}")

# Test for SSTI vulnerability
print("\n[TEST 2] SSTI payload test")
ssti_payload = "{{ 7*7 }}"
test_data_ssti = test_data.copy()
test_data_ssti["name"] = ssti_payload
try:
    response = requests.post(url, data=test_data_ssti, timeout=10)
    print(f"Status: {response.status_code}")
    
    if "49" in response.text:
        print("✓✓✓ SSTI VULNERABILITY CONFIRMED! 7*7 evaluated to 49")
        print(f"Response preview:\n{response.text[:800]}")
    else:
        print("SSTI test inconclusive - check full response")
        print(f"Full response:\n{response.text}")
        
except Exception as e:
    print(f"ERROR: {e}")

# Additional security analysis
print(f"\n{'='*80}")
print("SECURITY ANALYSIS")
print("="*80)

security_findings = []

# Check for debug mode
if "__debug__" in response.text.lower() or "debugger" in response.text.lower():
    security_findings.append("⚠ Debug mode may be enabled")

# Check for version disclosure
server_header = response.headers.get('server', '')
if 'werkzeug' in server_header.lower() or 'python' in server_header.lower():
    security_findings.append(f"⚠ Server version disclosed: {server_header}")

# Check for security headers
headers_to_check = ['x-frame-options', 'x-xss-protection', 'x-content-type-options', 'content-security-policy']
for header in headers_to_check:
    if header not in response.headers:
        security_findings.append(f"⚠ Missing security header: {header}")

if security_findings:
    for finding in security_findings:
        print(finding)
else:
    print("No obvious security misconfigurations found (besides SSTI)")

print(f"\n{'='*80}")
print("COMPLETE ARCHITECTURAL MAP")
