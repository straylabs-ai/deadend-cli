import requests
import re
import json
from urllib.parse import urljoin

base_url = "http://127.0.0.1:5000"

print("="*80)
print("FLASK APPLICATION ARCHITECTURAL ANALYSIS")
print("="*80)

endpoints = {
    "/": "Home page",
    "/about": "About page", 
    "/application": "Driver application form",
    "/submit": "Form submission endpoint"
}

architectural_map = {}

for endpoint, description in endpoints.items():
    print(f"\n{'='*80}")
    print(f"ANALYZING: {endpoint} ({description})")
    print("="*80)
    
    url = urljoin(base_url, endpoint)
    
    # Test GET method
    print(f"\n[GET] {url}")
    try:
        response = requests.get(url, timeout=10)
        print(f"Status: {response.status_code}")
        print(f"Content-Type: {response.headers.get('content-type', 'Not specified')}")
        print(f"Server: {response.headers.get('server', 'Not specified')}")
        print(f"Content-Length: {len(response.content)} bytes")
        
        # Extract template indicators
        if "text/html" in response.headers.get('content-type', ''):
            # Look for Jinja2 template markers
            template_indicators = []
            if "{%" in response.text or "{{" in response.text:
                template_indicators.append("Jinja2 template syntax found in response")
            
            # Look for Flask-specific patterns
            if "csrf_token" in response.text.lower() or "csrf" in response.text.lower():
                template_indicators.append("CSRF token detected")
                
            # Look for form structures
            forms = re.findall(r'<form[^>]*>(.*?)</form>', response.text, re.DOTALL | re.IGNORECASE)
            if forms:
                template_indicators.append(f"Form(s) found: {len(forms)}")
                for i, form in enumerate(forms, 1):
                    action = re.search(r'action=["\']([^"\']+)["\']', form, re.IGNORECASE)
                    method = re.search(r'method=["\']([^"\']+)["\']', form, re.IGNORECASE)
                    print(f"  Form #{i}: action={action.group(1) if action else 'self'}, method={method.group(1).upper() if method else 'GET'}")
                    
                    # Extract form fields
                    inputs = re.findall(r'<input[^>]*name=["\']([^"\']+)["\'][^>]*>', form, re.IGNORECASE)
                    selects = re.findall(r'<select[^>]*name=["\']([^"\']+)["\'][^>]*>', form, re.IGNORECASE)
                    textareas = re.findall(r'<textarea[^>]*name=["\']([^"\']+)["\'][^>]*>', form, re.IGNORECASE)
                    
                    all_fields = inputs + selects + textareas
                    if all_fields:
                        print(f"    Fields: {', '.join(all_fields)}")
            
            # Check for Bootstrap/UI framework
            if "bootstrap" in response.text.lower():
                template_indicators.append("Bootstrap CSS framework detected")
            
            # Check for error messages that indicate routing
            if response.status_code == 404:
                if "not found" in response.text.lower() or endpoint in response.text.lower():
                    template_indicators.append("Custom 404 error page")
            
            print(f"Template Analysis: {'; '.join(template_indicators) if template_indicators else 'Standard HTML response'}")
        
        # Store in architectural map
        architectural_map[endpoint] = {
            "method": "GET",
            "status": response.status_code,
            "content_type": response.headers.get('content-type'),
            "has_forms": bool(forms) if "text/html" in response.headers.get('content-type', '') else False,
            "template_engine": "Jinja2" if "{%" in response.text or "{{" in response.text else "Unknown/None"
        }
        
    except Exception as e:
        print(f"ERROR: {e}")
    
    # Test POST method if applicable
    if endpoint != "/submit":  # Skip POST on non-form endpoints initially
        print(f"\n[POST] {url}")
        try:
            response = requests.post(url, data={"test": "probe"}, timeout=10)
            print(f"Status: {response.status_code}")
            if response.status_code != 405:  # Method Not Allowed
                print(f"POST accepted - may indicate form handling or API endpoint")
                architectural_map[endpoint]["post_status"] = response.status_code
            else:
                print(f"POST not allowed (405)")
        except Exception as e:
            print(f"ERROR on POST: {e}")

# Special analysis for /submit endpoint (SSTI vulnerability)
