import requests
import re
import json
from urllib.parse import urljoin

base_url = "http://localhost"
session = requests.Session()
session.headers.update({'User-Agent': 'Security-Research-Mapper'})

architecture = {
    "server_stack": {},
    "routes": {},
    "vulnerabilities": []
}

print("=" * 80)
print("FLASK ARCHITECTURE MAPPING - COMPREHENSIVE RECONNAISSANCE")
print("=" * 80)

print("\n[1] SERVER STACK IDENTIFICATION")
print("-" * 80)

try:
    resp = session.get(base_url, timeout=15, stream=False)
    resp.close()
    
    server_header = resp.headers.get('Server', 'Not found')
    print(f"Server Header: {server_header}")
    
    if 'Werkzeug' in server_header:
        werkzeug_match = re.search(r'Werkzeug/(\d+\.\d+\.\d+)', server_header)
        if werkzeug_match:
            print(f"✓ Werkzeug Version: {werkzeug_match.group(1)}")
            architecture["server_stack"]["werkzeug_version"] = werkzeug_match.group(1)
    
    if 'Python' in server_header:
        python_match = re.search(r'Python/(\d+\.\d+\.\d+)', server_header)
        if python_match:
            print(f"✓ Python Version: {python_match.group(1)}")
            architecture["server_stack"]["python_version"] = python_match.group(1)
    
    architecture["server_stack"]["full_header"] = server_header
    
except Exception as e:
    print(f"[!] Error checking server stack: {e}")

routes_to_test = ["/", "/about", "/application", "/submit"]

print("\n[2] ROUTE DISCOVERY & ANALYSIS")
print("-" * 80)

for route in routes_to_test:
    url = urljoin(base_url, route)
    print(f"\n[*] Testing: {route}")
    
    try:
        resp = session.get(url, timeout=15, stream=False)
        resp.close()
        
        route_info = {
            "url": url,
            "status_code": resp.status_code,
            "method": "GET",
            "content_length": len(resp.content),
            "content_type": resp.headers.get('Content-Type', 'unknown'),
            "forms": [],
            "vulnerable": False,
            "notes": []
        }
        
        print(f"  Status: {resp.status_code}")
        print(f"  Content-Type: {route_info['content_type']}")
        print(f"  Size: {len(resp.content)} bytes")
        
        form_pattern = r'<form[^>]*>(.*?)</form>'
        form_matches = re.findall(form_pattern, resp.text, re.DOTALL | re.IGNORECASE)
        
        if form_matches:
            print(f"  [+] Found {len(form_matches)} form(s)")
            
            for i, form_html in enumerate(form_matches, 1):
                form_info = {"form_id": i, "fields": []}
                
                action_match = re.search(r'action=["\']([^"\']+)["\']', form_html, re.IGNORECASE)
                method_match = re.search(r'method=["\']([^"\']+)["\']', form_html, re.IGNORECASE)
                
                form_action = action_match.group(1) if action_match else route
                form_method = method_match.group(1).upper() if method_match else "POST"
                
                form_info["action"] = form_action
                form_info["method"] = form_method
                
                print(f"\n    Form {i}:")
                print(f"      Action: {form_action}")
                print(f"      Method: {form_method}")
                
                input_pattern = r'<input[^>]*>'
                input_matches = re.findall(input_pattern, form_html, re.IGNORECASE)
                
                if input_matches:
                    print(f"      Fields:")
                    for field_html in input_matches:
                        name_match = re.search(r'name=["\']([^"\']+)["\']', field_html, re.IGNORECASE)
                        type_match = re.search(r'type=["\']([^"\']+)["\']', field_html, re.IGNORECASE)
                        placeholder_match = re.search(r'placeholder=["\']([^"\']*)["\']', field_html, re.IGNORECASE)
                        
                        field_name = name_match.group(1) if name_match else "unknown"
                        field_type = type_match.group(1) if type_match else "text"
                        field_placeholder = placeholder_match.group(1) if placeholder_match else ""
                        
                        field_info = {
                            "name": field_name,
                            "type": field_type,
                            "placeholder": field_placeholder
                        }
                        
                        print(f"        - {field_name} (type: {field_type})")
                        if field_placeholder:
                            print(f"          Placeholder: '{field_placeholder}'")
                        
                        form_info["fields"].append(field_info)
                
                route_info["forms"].append(form_info)
        
        if "{%" in resp.text or "{{" in resp.text:
            route_info["notes"].append("Jinja2 template syntax present")
            print(f"  [!] Note: Jinja2 template syntax detected")
        
        debug_indicators = ["Traceback", "Debug", "Exception", "jinja2"]
        for indicator in debug_indicators:
            if indicator.lower() in resp.text.lower():
                route_info["notes"].append(f"Debugging: {indicator}")
                print(f"  [!] Note: Debug info present ({indicator})")
        
        architecture["routes"][route] = route_info
        
    except Exception as e:
        print(f"  [!] Error: {e}")
        architecture["routes"][route] = {"error": str(e), "url": url}

print("\n[3] SSTI VULNERABILITY TESTING")
print("-" * 80)

submit_url = urljoin(base_url, "/submit")

test_cases = [
    ("Math Test", "{{7*7}}", r"49"),
    ("String Test", "{{'x'+'y'}}", r"xy"),
    ("List Test", "{{[1,2,3][0]}}", r"1")
]

for test_name, payload, expected in test_cases:
    print(f"\n[*] Testing: {test_name}")
    print(f"  Payload: {payload}")
    
    try:
        if "/submit" in architecture["routes"] and architecture["routes"]["/submit"].get("forms"):
            form = architecture["routes"]["/submit"]["forms"][0]
            form_data = {field["name"]: payload for field in form["fields"]}
            
            resp = session.post(submit_url, data=form_data, timeout=15, stream=False)
            resp.close()
            
            print(f"  Status: {resp.status_code}")
            
            if re.search(expected, resp.text):
                print(f"  ✓ CONFIRMED: {test_name} executes")
                vuln = {
                    "type": "SSTI",
                    "route": "/submit",
                    "payload": payload,
                    "evidence": expected,
                    "severity": "CRITICAL"
                }
                architecture["vulnerabilities"].append(vuln)
                architecture["routes"]["/submit"]["vulnerable"] = True
            else:
                print(f"  ✗ No execution")
        else:
            resp = session.post(submit_url, data={"test": payload}, timeout=15, stream=False)
            resp.close()
            
            if re.search(expected, resp.text):
                print(f"  ✓ CONFIRMED: {test_name}")
                vuln = {
                    "type": "SSTI",
                    "route": "/submit",
                    "payload": payload,
                    "evidence": expected,
                    "severity": "CRITICAL"
                }
                architecture["vulnerabilities"].append(vuln)
                if "/submit" in architecture["routes"]:
                    architecture["routes"]["/submit"]["vulnerable"] = True
    
    except Exception as e:
        print(f"  [!] Error: {e}")

print("\n[4] REQUEST HANDLER MAPPING")
print("-" * 80)

handler_mappings = {
    "/": {"type": "Main Page", "methods": ["GET"], "template": "index.html"},
    "/about": {"type": "Static Page", "methods": ["GET"], "template": "about.html"},
    "/application": {"type": "App Page", "methods": ["GET"], "template": "application.html"},
    "/submit": {"type": "Form Handler (VULN)", "methods": ["GET", "POST"], "vulnerability": "SSTI"}
}

for route, mapping in handler_mappings.items():
    print(f"\nRoute: {route}")
    print(f"  Handler: {mapping['type']}")
    print(f"  Methods: {', '.join(mapping['methods'])}")
    if 'vulnerability' in mapping:
        print(f"  ⚠ Vulnerability: {mapping['vulnerability']}")

print("\n[5] ARCHITECTURE SUMMARY")
print("=" * 80)

print(f"\nServer Stack:")
for k, v in architecture.get("server_stack", {}).items():
    print(f"  {k}: {v}")

print(f"\nRoutes ({len(architecture.get('routes', {}))} total):")
for route, info in architecture.get("routes", {}).items():
    print(f"  {route}: {info.get('status_code', 'error')} | {info.get('content_type', 'unknown')}")

print(f"\nVulnerabilities ({len(architecture.get('vulnerabilities', []))} found):")
for i, vuln in enumerate(architecture.get("vulnerabilities", []), 1):
    print(f"  {i}. {vuln['type']} on {vuln['route']}")

print("\n" + "=" * 80)
print("COMPLETE ARCHITECTURE (JSON)")
print("=" * 80)
print(json.dumps(architecture, indent=2))
