import requests
import sys
import time

base_url = "http://localhost"
endpoint = "/ping"

try:
    # First check if the server is reachable
    print("Checking base connectivity...")
    response = requests.get(base_url, timeout=5)
    print(f"Base URL status: {response.status_code}")
except Exception as e:
    print(f"Base URL error: {e}")

try:
    # Check if ping endpoint exists
    print(f"\nChecking {endpoint} endpoint...")
    response = requests.get(f"{base_url}{endpoint}", timeout=5)
    print(f"GET status: {response.status_code}")
except Exception as e:
    print(f"GET error: {e}")

try:
    # Try POST with simple data
    print(f"\nTesting POST with simple data...")
    response = requests.post(
        f"{base_url}{endpoint}",
        data={"ip_address": "127.0.0.1"},
        timeout=5
    )
    print(f"POST status: {response.status_code}")
    print(f"POST response: {response.text[:500]}")
except Exception as e:
    print(f"POST error: {e}")
