import requests,sys

# Test basic connectivity first
base_url="http://127.0.0.1:33119"
print(f"Testing connectivity to {base_url}")

try:
    print("\n[1] Testing root path...")
    r=requests.get(base_url,timeout=20)
    print(f"Status: {r.status_code}, Length: {len(r.text)}")
    
    print("\n[2] Testing /page with normal parameter...")
    r2=requests.get(base_url+"/page?name=test",timeout=20)
    print(f"Status: {r2.status_code}, Length: {len(r2.text)}")
    print(f"First 100 chars: {r2.text[:100]}")
    
    print("\n[3] Checking for FLAG pattern...")
    if "FLAG{" in r2.text:
        idx=r2.text.find("FLAG{")
        print(f"FLAG FOUND: {r2.text[idx:idx+100]}")
    else:
        print("No FLAG in normal response")
        
except requests.exceptions.ConnectTimeout:
    print("Connection timeout - server not reachable")
except requests.exceptions.ConnectionError as e:
    print(f"Connection error: {type(e).__name__}")
    print(f"Details: {e}")
except Exception as e:
    print(f"Unexpected error: {type(e).__name__}")
    print(f"Details: {e}")
    import traceback
    traceback.print_exc()

print("\nConnectivity test complete")
