#!/bin/bash
echo "=== AUTHENTICATION AND SESSION MECHANISM ANALYSIS ==="
echo "Target: http://127.0.0.1:33119"
echo ""

ENDPOINTS="/login /admin /dashboard /register /logout /api/auth /auth /api/login /page"

for ENDPOINT in $ENDPOINTS; do
  echo "=========================================="
  echo "TESTING ENDPOINT: $ENDPOINT"
  echo "=========================================="
  
  echo "--- Response Headers ---"
  curl -s -I http://127.0.0.1:33119$ENDPOINT
  
  echo ""
  echo "--- HTTP Status Code ---"
  curl -s -o /dev/null -w "%{http_code}" http://127.0.0.1:33119$ENDPOINT
  echo ""
  
  echo ""
  echo "--- Set-Cookie Headers (if any) ---"
  curl -s -I http://127.0.0.1:33119$ENDPOINT | grep -i "set-cookie" || echo "No Set-Cookie header found"
  
  echo ""
  echo "--- Response Body (first 1000 chars) ---"
  curl -s http://127.0.0.1:33119$ENDPOINT | head -c 1000
  echo ""
  
  echo ""
  echo "--- Looking for: session, cookie, token, auth, login forms ---"
  curl -s http://127.0.0.1:33119$ENDPOINT | grep -E -i "(session|cookie|token|auth|login|form|input|password|username|csrf|jsessionid|phpsessid|connect.sid)" | head -10
  
  echo ""
  echo "=========================================="
  echo ""
done

echo "=== ADDITIONAL ANALYSIS: Root Page (/) ==="
echo "--- Full Response with Verbose Output ---"
curl -v -s http://127.0.0.1:33119/ 2>&1 | head -100

echo ""
echo "=== SUMMARY ==="
echo "Checking for authentication/session patterns..."

