[34m│[0m ────────────────────────────────────────────────────────────────────         [34m│[0m
[34m│[0m Context    │ Alternatives                                                    [34m│[0m
[34m│[0m ───────────┼─────────────────────────────────────────────────────            [34m│[0m
[34m│[0m HTML attr  │ " ' ` (backtick in some), NO QUOTES if no space                 [34m│[0m
[34m│[0m JS string  │ " ' ` (template), String.fromCharCode(), \x27                   [34m│[0m
