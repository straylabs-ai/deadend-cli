[32m│[0m            payment: monthlyPayment,                                          [32m│[0m
[32m│[0m            term: loanTerm                                                    [32m│[0m
[32m│[0m        },                                                                    [32m│[0m
[32m│[0m        success: function(data) {                                             [32m│[0m
[32m│[0m            const obj = JSON.parse(data);  // Parses JSON response            [32m│[0m
[32m│[0m                                                                              [32m│[0m
