                # Check if tag appears without attributes
                tag_name = payload.split('<')[1].split('>')[0].split()[0]
                if f"<{tag_name}" in response_text or f"<{tag_name.upper()}" in response_text.upper():
                    print(f"\n[-] TAG PRESENT BUT ATTRIBUTES REMOVED: {payload}")
                    print(f"    Status: {response.status_code}")
                    results["partially_filtered"].append({
                        "category": category,
                        "payload": payload,
                        "status": response.status_code,
                        "note": "Attributes removed"
                    })
                else:
                    print(f"\n[-] FULLY BLOCKED: {payload}")
                    print(f"    Status: {response.status_code}")
                    results["fully_blocked"].append({
                        "category": category,
                        "payload": payload,
                        "status": response.status_code
                    })
            
            # Check for common filter indicators in response
            if "filtered" in response_text.lower():
                print("    [!] Filter indication found in response")
            
            # Rate limiting pause
            time.sleep(0.5)
            
