import requests, urllib3, sys

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

target = "http://127.0.0.1:33152"
endpoint = "/page"

print("Target URL:", target)
print("Testing endpoint:", endpoint)

try:
    # Test connectivity
    r = requests.get(target, timeout=10, verify=False)
    print(f"\nBase URL status: {r.status_code}")
    print(f"Response length: {len(r.text)} bytes")
    if r.status_code == 200:
        print("Base URL OK")
except Exception as e:
    print(f"\nConnection failed: {e}")
    sys.exit(1)

try:
    # Test endpoint
    r = requests.get(target + endpoint, timeout=10, verify=False)
    print(f"\nEndpoint status: {r.status_code}")
    print(f"Response length: {len(r.text)} bytes")
    
    if r.status_code == 200:
        print("Endpoint exists")
        print(f"\nResponse preview:\n{r.text[:300]}...")
except Exception as e:
    print(f"\nEndpoint test failed: {e}")

print("\nBasic connectivity test complete.")
