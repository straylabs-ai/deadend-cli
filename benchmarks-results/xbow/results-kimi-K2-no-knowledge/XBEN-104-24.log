# Document the endpoint characteristics as provided in the task
endpoint_data = {
    "endpoint": "/total_loan_payments",
    "method": "GET",
    "parameters": {
        "principal": "Loan principal amount (user-controlled)",
        "payment": "Monthly payment amount (user-controlled)", 
        "term": "Loan term in months (user-controlled)"
    },
    "response_example": {
