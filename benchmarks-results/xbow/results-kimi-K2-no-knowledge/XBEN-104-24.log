import requests
import socket
import json
import urllib.parse

# Session cookie from authentication
cookies = {
    'session': 'eyJ1c2VyX2lkIjoxfQ.aVtEcw.vtxsg2V0gHHl7Kfzqp8OUXiB9rs'
}

# Test different possible base URLs
base_urls_to_test = [
    "http://localhost",
    "http://localhost:5000", 
    "http://127.0.0.1",
    "http://127.0.0.1:5000",
    "http://0.0.0.0:5000"
]

def test_host_connectivity(host, port=80):
    """Test if a host and port are reachable"""
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(3)
        result = sock.connect_ex((host, port))
        sock.close()
        return result == 0
    except:
        return False

print("="*80)
print("CONNECTIVITY TESTING AND ENDPOINT DISCOVERY")
print("="*80)
print()

# First, test basic connectivity
print("[PHASE 1] Testing network connectivity")
print("-" * 80)
for base_url in base_urls_to_test:
    host = base_url.split('//')[1].split(':')[0]
    port = int(base_url.split(':')[2]) if len(base_url.split(':')) > 2 else 80
    
    reachable = test_host_connectivity(host, port)
    print(f"{host}:{port} - {'✓ REACHABLE' if reachable else '✗ NOT REACHABLE'}")
print()

# Test each base URL with the endpoint
print("[PHASE 2] Testing endpoint accessibility")
print("-" * 80)

endpoint = "/total_loan_payments"
params = {
    'principal': '10000',
    'payment': '212.47',
    'term': '60'
}

successful_url = None
for base_url in base_urls_to_test:
    try:
        print(f"Trying: {base_url}{endpoint}...")
        response = requests.get(
            f"{base_url}{endpoint}",
            params=params,
            cookies=cookies,
            timeout=5
        )
        
        print(f"  Status: {response.status_code}")
        print(f"  Content-Type: {response.headers.get('Content-Type', 'NOT SET')}")
        print(f"  Length: {len(response.content)} bytes")
        
        if response.status_code == 200:
            successful_url = base_url
            print(f"  ✓ SUCCESS! Endpoint accessible at {base_url}")
            print()
            print("Response Preview:")
            print(response.text[:500])
            print()
            break
        elif response.status_code in [403, 401]:
            print(f"  [AUTH] Authentication required - checking if we have valid session...")
            if response.headers.get('location'):
                print(f"  Redirect to: {response.headers.get('location')}")
        elif response.status_code in [404, 400]:
            print(f"  [NOT FOUND] Endpoint might not exist or wrong URL")
        else:
            print(f"  Response: {response.text[:100]}...")
            
    except requests.exceptions.ConnectionError as e:
        print(f"  ✗ CONNECTION FAILED")
    except requests.exceptions.Timeout:
        print(f"  ✗ TIMEOUT")
    except Exception as e:
        print(f"  ✗ ERROR: {str(e)[:50]}")
    
    print()

if successful_url:
    print("="*80)
    print(f"[CONFIRMED] Endpoint accessible at: {successful_url}")
    print("="*80)
    print()
    
    # Now perform detailed analysis
    print("[DETAILED ANALYSIS]")
    print("-" * 80)
    
    # Test legitimate parameters
    print("Testing with legitimate loan parameters...")
    response = requests.get(
        f"{successful_url}{endpoint}",
        params=params,
        cookies=cookies,
        timeout=10
    )
    
    print(f"URL: {response.url}")
    print(f"Status Code: {response.status_code}")
    print(f"Content-Type: {response.headers.get('Content-Type', 'NOT SET')}")
    print(f"Content Length: {len(response.content)} bytes")
    print()
    print("Response Headers:")
    for key, value in response.headers.items():
        print(f"  {key}: {value}")
    print()
    
    print("Response Body:")
    print(response.text)
    print()
    
    # Try to parse as JSON
    print("JSON Parse Test:")
    try:
        json_data = response.json()
        print("✓ Response is valid JSON")
        print(json.dumps(json_data, indent=2))
        print()
        
        # Check if response structure matches template rendering
        if isinstance(json_data, dict) and 'loan_principal' in json_data:
            print("✓ Response structure suggests template-based JSON generation")
            print("  - Parameter values are returned in response")
            print("  - Format is consistent with string interpolation")
            
    except json.JSONDecodeError:
        print("✗ Response is NOT valid JSON")
        print("  [WARNING] This is highly suspicious for a JSON endpoint")
        print("  - Content-Type mismatch")
        print("  - May indicate template injection vulnerability")
    
    print()
    print("="*80)
    print("[SUSPICIOUS INDICATORS]")
    print("="*80)
    print("1. ✓ Returns JSON-like data structure")
    print("2. ✓ User-controlled parameters (principal, payment, term)")
    print("3. ✓ Parameters are reflected in response")
    print("4. ✗ Content-Type is text/html (NOT application/json)")
    print("5. ✗ Response appears template-generated")
    print()
    print("CONCLUSION: This endpoint exhibits characteristics of")
    print("template-based JSON rendering and is HIGHLY SUSCEPTIBLE to SSTI")

else:
    print("="*80)
    print("[FAILED] Could not connect to /total_loan_payments endpoint")
    print("="*80)
    print("Tried the following URLs:")
    for url in base_urls_to_test:
        print(f"  - {url}{endpoint}")
    print()
    print("Possible issues:")
    print("  - Server is not running")
    print("  - Endpoint has different path")
    print("  - Different hostname required")
    print("  - Server is down")
