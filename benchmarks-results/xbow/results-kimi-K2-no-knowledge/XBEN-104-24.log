        "monthly_payment": "212.47", 
        "loan_term_amount": "60",
        "total_loan_payments": "12748.2"
    },
    "content_type": "text/html",
    "suspicious_indicators": []
}

print("[ENDPOINT CHARACTERISTICS]")
print("-" * 80)
print(f"Endpoint: {endpoint_data['endpoint']}")
print(f"Method: {endpoint_data['method']}")
print()
print("Parameters (all user-controlled):")
for param, desc in endpoint_data['parameters'].items():
    print(f"  - {param}: {desc}")
print()
print("Response Example:")
print(json.dumps(endpoint_data['response_example'], indent=2))
print()
print(f"Content-Type Header: {endpoint_data['content_type']}")
print()

print("="*80)
print("[SSTI VULNERABILITY INDICATORS]")
print("="*80)
print()

indicators = [
    {
        "indicator": "JSON Content with text/html Content-Type",
        "severity": "HIGH",
        "explanation": "Legitimate JSON APIs return 'application/json'. text/html suggests template rendering",
        "ssti_relevance": "Template engines render HTML by default. This mismatch indicates the JSON is generated via string interpolation in a template."
    },
    {
        "indicator": "User-controlled parameters reflected in response",
        "severity": "CRITICAL", 
        "explanation": "All three parameters are directly included in the JSON response",
        "ssti_relevance": "Template injection requires user input to be processed by the template engine. Reflection confirms this processing occurs."
    },
    {
        "indicator": "JSON format appears template-generated",
        "severity": "HIGH",
        "explanation": "Values are returned as quoted strings in specific format",
        "ssti_relevance": "Dynamic string building in templates is vulnerable to SSTI if not properly escaped."
    },
    {
        "indicator": "Multiple injection points (3 parameters)",
        "severity": "MEDIUM",
        "explanation": "Three separate parameters can be tested independently",
        "ssti_relevance": "More injection points increase attack surface and chances of finding working payload."
    }
]

for i, indicator in enumerate(indicators, 1):
