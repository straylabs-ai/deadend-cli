import requests
import json
import sys

base_url = "http://127.0.0.1:32841"
cookies = {"session": "eyJ1c2VyX2lkIjoxfQ.aVtEcw.vtxsg2V0gHHl7Kfzqp8OUXiB9rs"}
headers = {"User-Agent": "Mozilla/5.0"}

# List of endpoints to test
endpoints_to_test = [
    "/home",
    "/api",
    "/search",
    "/user",
    "/profile",
    "/data",
    "/users",
    "/products",
    "/orders",
    "/items",
    "/settings",
    "/info",
    "/status",
    "/dashboard",
    "/content"
]

# Parameters to test
params_to_test = {
    "username": "test",
    "query": "test", 
    "id": "1",
    "user": "1",
    "page": "1"
}

json_endpoints = []
print(f"[*] Testing {len(endpoints_to_test)} endpoints for JSON responses")
print(f"[*] Using session cookie: {cookies}\n")

# Test each endpoint
for endpoint in endpoints_to_test:
    try:
        full_url = f"{base_url}{endpoint}"
        print(f"\n[+] Testing endpoint: {endpoint}")
        
        # Test without parameters
        print(f"  [+] GET {full_url}")
        response = requests.get(full_url, cookies=cookies, headers=headers, timeout=10)
        content_type = response.headers.get('Content-Type', '').lower()
        
        print(f"  [+] Status: {response.status_code}")
        print(f"  [+] Content-Type: {content_type}")
        print(f"  [+] Response length: {len(response.text)} bytes")
        
        # Check if response is JSON
        is_json = False
        accepts_params = False
        
        # Check Content-Type header
        if 'json' in content_type:
            is_json = True
            print(f"  [!] JSON detected via Content-Type header")
        
        # Try to parse as JSON
        try:
            json_data = response.json()
            is_json = True
            print(f"  [!] Successfully parsed as JSON")
            print(f"  [!] JSON preview: {str(json_data)[:200]}")
        except:
            # Not valid JSON
            pass
        
        # If not JSON, try with parameters
        if not is_json:
            print(f"  [+] Testing with parameters...")
            for param_name, param_value in params_to_test.items():
                param_url = f"{full_url}?{param_name}={param_value}"
                print(f"    [+] GET {param_url}")
                
                try:
                    param_response = requests.get(param_url, cookies=cookies, headers=headers, timeout=10)
                    param_content_type = param_response.headers.get('Content-Type', '').lower()
                    
                    # Check if this version returns JSON
                    param_is_json = False
                    
                    if 'json' in param_content_type:
                        param_is_json = True
                    
                    try:
                        json_data = param_response.json()
                        param_is_json = True
                    except:
                        pass
                    
                    if param_is_json:
                        is_json = True
                        accepts_params = True
                        print(f"    [!] JSON detected with parameter {param_name}={param_value}")
                        print(f"    [!] Status: {param_response.status_code}")
                        try:
                            json_data = param_response.json()
                            print(f"    [!] JSON preview: {str(json_data)[:200]}")
                        except:
                            pass
                        
                except requests.exceptions.RequestException as e:
                    print(f"    [-] Error with parameter {param_name}: {e}")
        
        # Record results
        if is_json:
            json_endpoints.append({
                'endpoint': endpoint,
                'url': full_url,
                'accepts_params': accepts_params,
                'status_code': response.status_code
            })
            print(f"  [✓] {endpoint} returns JSON")
        else:
            print(f"  [-] {endpoint} does not return JSON")
            
    except requests.exceptions.RequestException as e:
        print(f"  [-] Error accessing {endpoint}: {e}")
    except Exception as e:
        print(f"  [-] Unexpected error: {e}")

# Summary
print("\n" + "="*60)
print("SUMMARY: Endpoints returning JSON")
print("="*60)

if json_endpoints:
    for idx, ep in enumerate(json_endpoints, 1):
        print(f"\n{idx}. {ep['endpoint']}")
        print(f"   URL: {ep['url']}")
        print(f"   Accepts Parameters: {ep['accepts_params']}")
        print(f"   Status Code: {ep['status_code']}")
else:
    print("No JSON endpoints found among tested patterns.")

print(f"\n[*] Tested {len(endpoints_to_test)} endpoints, found {len(json_endpoints)} JSON endpoints")
