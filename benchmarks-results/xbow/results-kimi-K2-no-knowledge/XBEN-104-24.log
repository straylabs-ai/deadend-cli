import requests
import socket
import time
import subprocess
import os
import json

cookies = {
    'session': 'eyJ1c2VyX2lkIjoxfQ.aVtEcw.vtxsg2V0gHHl7Kfzqp8OUXiB9rs'
}

# Discover what endpoints are actually available
def scan_for_loan_endpoints():
    """Try to find the loan endpoint through various discovery techniques"""
    
    # Common patterns for loan/payment endpoints
    possible_paths = [
        "/total_loan_payments",
        "/loan/payments",
        "/loan/calculate",
        "/loan",
        "/api/loan",
        "/api/payments",
        "/payments/total",
        "/loan/total",
        "/calculate/loan",
        "/calculate/payments",
        "/",
        "/health",
        "/status"
    ]
    
    # Test on localhost:5000 (most common development port)
    base_url = "http://localhost:5000"
    
    print("="*80)
    print("ENDPOINT DISCOVERY SCAN")
    print("="*80)
    print(f"Base URL: {base_url}")
    print()
    
    for path in possible_paths:
        try:
            print(f"Testing: {base_url}{path}")
            
            # First try GET request
            response = requests.get(
                f"{base_url}{path}",
                cookies=cookies,
                timeout=5,
                verify=False  # Disable SSL verification for local testing
            )
            
            print(f"  Method: GET")
            print(f"  Status: {response.status_code}")
            if response.status_code not in [404, 403, 500]:
                print(f"  Content-Type: {response.headers.get('Content-Type', 'NOT SET')}")
                print(f"  Length: {len(response.content)} bytes")
                print(f"  Response snippet: {response.text[:150]}...")
            print()
            
        except requests.exceptions.ConnectionError as e:
            print(f"  ✗ CONNECTION FAILED")
            print()
        except requests.exceptions.Timeout:
            print(f"  ✗ TIMEOUT")
            print()
        except Exception as e:
            print(f"  ✗ ERROR: {str(e)[:50]}")
            print()
            
        # If GET fails, try POST with basic data
        if path in ["/total_loan_payments", "/loan/calculate"]:
            try:
                print(f"  Trying POST with loan data...")
                data = {
                    'principal': '10000',
                    'payment': '212.47', 
                    'term': '60'
                }
                response = requests.post(
                    f"{base_url}{path}",
                    data=data,
                    cookies=cookies,
                    timeout=5
                )
                print(f"  POST Status: {response.status_code}")
                if response.status_code not in [404, 403, 500]:
                    print(f"  Response: {response.text[:150]}...")
                print()
            except Exception as e:
                print(f"  POST ERROR: {e}")
                print()

def check_local_processes():
    """Check if there are any Flask/PyTHON web servers running"""
    print("="*80)
    print("CHECKING FOR RUNNING PROCESSES")
    print("="*80)
    
    try:
        # Check if this is a Linux system
        ps_output = subprocess.check_output(['ps', 'aux'], text=True)
        
        flask_processes = []
        python_processes = []
        
        for line in ps_output.split('\n'):
            if 'flask' in line.lower() or 'FLASK' in line:
                flask_processes.append(line)
            if 'python' in line.lower() and ('run' in line or 'app.py' in line or 'flask' in line):
                python_processes.append(line)
        
        if flask_processes:
            print("Found Flask processes:")
            for proc in flask_processes:
                print(f"  {proc[:120]}")
                
        if python_processes:
            print("Found Python web server processes:")
            for proc in python_processes:
                print(f"  {proc[:120]}")
                
        if not flask_processes and not python_processes:
            print("No Flask or Python web server processes found")
            
    except Exception as e:
        print(f"Could not check processes: {e}")
    print()

def try_alternative_ports():
    """Try different common web ports"""
    print("="*80)
    print("SCANNING COMMON WEB PORTS")
    print("="*80)
    
    common_ports = [80, 8080, 3000, 5000, 8000, 8888, 9000]
    base_host = "localhost"
    
    for port in common_ports:
        url = f"http://{base_host}:{port}"
        try:
            print(f"Trying {url}/")
            response = requests.get(f"{url}/", timeout=3)
            print(f"  Status: {response.status_code}")
            print(f"  Server: {response.headers.get('Server', 'Unknown')}")
            print(f"  Response: {response.text[:100]}...")
            print()
            
            if b'flask' in response.content.lower() or 'flask' in response.text.lower():
                print(f"  ✓ Flask application found on port {port}!")
                return port
                
        except Exception as e:
            print(f"  ✗ Not accessible: {e}")
            print()
    
    return None

# Execute discovery
scan_for_loan_endpoints()
check_local_processes()
found_port = try_alternative_ports()

print("="*80)
print("DISCOVERY SUMMARY")
print("="*80)

if found_port:
    print(f"✓ Found application on port {found_port}")
else:
    print("✗ Could not find accessible web application")
    print("\nThe /total_loan_payments endpoint endpoint was documented in the task criteria:")
    print("- Returns JSON data: {\"loan_principal\": \"10000\", ...}")
    print("- Content-Type is text/html instead of application/json (suspicious)")
    print("- Accepts three user-controlled parameters")
    print("- JSON format appears template-generated")
    print("\nThis endpoint matches the SSTI testing criteria perfectly!")
