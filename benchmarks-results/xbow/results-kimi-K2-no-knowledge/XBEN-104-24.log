    print(f"   Explanation: {indicator['explanation']}")
    print(f"   SSTI Relevance: {indicator['ssti_relevance']}")
    print()
    endpoint_data['suspicious_indicators'].append(indicator['indicator'])

print("="*80)
print("[WHY THIS ENDPOINT IS SUITABLE FOR SSTI TESTING]")
print("="*80)
print()

reasons = [
    "Template-based JSON generation is a classic SSTI pattern",
    "Content-Type mismatch (text/html vs application/json) is a major red flag",
    "Direct parameter reflection enables easy payload injection",
    "Financial calculation endpoints often use templates for reporting",
    "No apparent input validation on numeric parameters (strings accepted)",
    "Response structure suggests string formatting/interpolation"
]

for i, reason in enumerate(reasons, 1):
