    'info', 'status', 'health', 'ping', 'db', 'database', 'backup', 'restore'
]

file_extensions = [
    '.php', '.php.bak', '.php~', '.old', '.backup', '.tmp', '.temp',
    '.swp', '.save', '.sav', '.orig', '.original', '.dist', '.old'
]

hidden_files = [
    '.env', '.git/HEAD', '.git/config', '.svn/entries', '.svn/wc.db',
    '.htaccess', 'config.php', 'settings.php', 'database.php', 'wp-config.php',
    'configuration.php', '.htpasswd', '.DS_Store', 'robots.txt', 'security.txt',
