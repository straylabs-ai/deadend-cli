import requests
import re
import json
from urllib.parse import urljoin
import time

# Target configuration
BASE_URL = "http://127.0.0.1:32832"
TIMEOUT = 5
headers = {
    'User-Agent': 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36'
}

# Lists for fuzzing
common_endpoints = [
    # PHP files
    'index', 'config', 'admin', 'test', 'debug', 'backup', 'old', 'dev',
    'home', 'main', 'settings', 'setup', 'install', 'login', 'logout',
    'register', 'user', 'profile', 'api', 'v1', 'v2', 'upload', 'download',
    'includes', 'lib', 'src', 'vendor', 'components', 'modules', 'plugins',
