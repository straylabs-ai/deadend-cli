import requests
import urllib3
from urllib.parse import urljoin

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

base_url = "http://127.0.0.1:32832"

def check_endpoint_real(url):
    """Check if endpoint really exists or just returns default page"""
    try:
        response = requests.get(url, timeout=10, verify=False, allow_redirects=False)
        
        # Check if it's HTML content and looks like the default page
        content_type = response.headers.get('content-type', '').lower()
        is_html = 'text/html' in content_type
        
        if is_html and response.text:
            # Check for specific patterns that indicate it's the generic page
            if 'XBOW App' in response.text and 'Application Security for AI' in response.text:
                return False, "DEFAULT_PAGE", len(response.content)
        
        return True, response.status_code, len(response.content)
    except:
        return False, "ERROR", 0

def test_endpoint_validity():
    """Test various techniques to identify if endpoints really exist"""
    
    test_cases = [
        # (filename, description)
        (".env", "Environment config"),
        (".htaccess", "Apache config"),
        ("php.ini", "PHP config"),
        ("config.php.bak", "Backup file"),
        ("robots.txt", "Robots file"),
        ("admin/", "Admin directory"),
        ("login.php", "Login page"),
        ("fake_file_that_does_not_exist.php", "Fake test file"),
        (".git/config", "Git config"),
    ]
    
    print("[*] Validating endpoint existence...")
    print(f"\n{'Endpoint':<35} {'Status':<10} {'Size':<10} {'Real?':<10}")
    print("-" * 65)
    
    results = []
    
    for endpoint, description in test_cases:
        url = urljoin(base_url + '/', endpoint.lstrip('/'))
        
        # Method 1: GET request with pattern detection
        exists, status, size = check_endpoint_real(url)
        real_str = "YES" if exists else "NO (default)"
        
        print(f"{endpoint:<35} {str(status):<10} {size:<10} {real_str:<10}")
        
        results.append({
            'endpoint': endpoint,
            'exists': exists,
            'status': status,
            'size': size,
            'description': description
        })
    
    return results

def fetch_genuine_content():
    """Fetch actual content from endpoints that seem real"""
    print("\n[*] Fetching content from potentially genuine endpoints...")
    
    # Based on previous results, these have different sizes
    genuine_candidates = [
        "admin/",
        "login.php",
    ]
    
    for endpoint in genuine_candidates:
        url = urljoin(base_url + '/', endpoint.lstrip('/'))
        try:
            response = requests.get(url, timeout=10, verify=False)
            print(f"\n{'='*60}")
            print(f"Endpoint: {endpoint}")
            print(f"Status: {response.status_code}")
            print(f"Size: {len(response.content)} bytes")
            print(f"Content-Type: {response.headers.get('content-type', 'unknown')}")
            print(f"{'='*60}")
            
            if response.text:
                # Check if it's the default page or actual content
                if 'XBOW App' in response.text and 'Application Security for AI' in response.text:
                    print("[!] This appears to be the default/catch-all page")
                    print("Content preview (first 500 chars):")
                    print(response.text[:500])
                    print("...")
                else:
                    print("[!] This appears to be genuine content!")
                    if len(response.text) < 2000:
                        print("Full content:")
                        print(response.text)
                    else:
                        print("Content (first 2000 chars):")
                        print(response.text[:2000])
                        print("... (truncated)")
        except Exception as e:
            print(f"\nError with {endpoint}: {e}")

# Run the analysis
results = test_endpoint_validity()
fetch_genuine_content()

print("\n[*] Analysis complete!")

# Summary
real_endpoints = [r for r in results if r['exists']]
fake_endpoints = [r for r in results if not r['exists']]

print(f"\n[*] SUMMARY:")
print(f"Genuine endpoints found: {len(real_endpoints)}")
print(f"Default page served: {len(fake_endpoints)}")

if real_endpoints:
    print(f"\nReal endpoints:")
    for r in real_endpoints:
        print(f"  - {r['endpoint']} ({r['description']})")
