]

directories = [
    'admin', 'config', 'includes', 'lib', 'src', 'api', 'v1', 'v2', 'backup',
    'uploads', 'files', 'data', 'logs', 'temp', 'tmp', 'dev', 'debug', 'test',
    'private', 'secure', 'vendor', 'components', 'modules', 'controllers',
    'models', 'views', 'static', 'assets', 'resources', 'public', 'private'
]

parameters = [
    'id', 'page', 'file', 'user', 'uid', 'username', 'email', 'name',
    'action', 'do', 'cmd', 'view', 'path', 'url', 'redirect', 'next',
    'lang', 'locale', 'debug', 'test', 'dev', 'trace', 'profile', 'mode',
    'format', 'type', 'category', 'product', 'item', 'article', 'post',
    'search', 'query', 'q', 'keyword', 'ref', 'source', 'callback',
    'jsonp', 'method', 'function', 'class', 'component', 'template'
]

rest_endpoints = [
    'api/users', 'api/posts', 'api/products', 'api/items', 'api/v1/users',
    'api/v2/users', 'api/v1/posts', 'api/v2/posts', 'rest/users', 'rest/posts',
    'user/list', 'user/show', 'post/list', 'product/list', 'item/list'
]

# Track findings
unique_endpoints = set()
catch_all_size = 5609  # Known catch-all response size

print("=" * 80)
print("COMPREHENSIVE APPLICATION ARCHITECTURE ANALYSIS")
print(f"Target: {BASE_URL}")
print("=" * 80)

def analyze_response(url, response):
    """Analyze response for interesting content"""
    findings = []
    
    # Check response size anomaly
    if len(response.content) > 0 and len(response.content) != catch_all_size:
        findings.append(f"Non-catch-all response ({len(response.content)}B)")
    
    # Look for PHP errors
    if 'PHP' in response.text:
        findings.append("PHP error/stack trace found")
    
    # Look for version information
    version_patterns = [
        r'\bphp/\d+\.\d+\.\d+\b', r'\bnginx/\d+\.\d+\.\d+\b',
        r'\bapache/\d+\.\d+\.\d+\b', r'X-Powered-By:.*?\n',
        r'Server:.*?\n', r'version.*?\d+\.\d+\.\d+.*?\n'
    ]
    for pattern in version_patterns:
        if re.search(pattern, response.text, re.I):
            match = re.search(pattern, response.text, re.I)
            findings.append(f"Version info: {match.group(0) if match else pattern}")
    
    # Look for HTML comments
    html_comments = re.findall(r'<!--(.*?)-->', response.text, re.S)
    if html_comments:
        for comment in html_comments[:3]:  # Show first 3
            comment_clean = comment.strip()[:100]
            if len(comment.strip()) > 0 and 'DOCTYPE' not in comment:
                findings.append(f"HTML comment: {comment_clean}...")
    
    # Look for form actions and hidden inputs
    form_actions = re.findall(r'<form[^>]*action=["\']([^"\']*)["\']', response.text, re.I)
    if form_actions:
        findings.append(f"Form actions: {form_actions}")
    
    hidden_inputs = re.findall(r'<input[^>]*type=["\']?hidden["\']?[^>]*>', response.text, re.I)
    if hidden_inputs:
        findings.append(f"Hidden inputs found: {len(hidden_inputs)}")
        for inp in hidden_inputs[:2]:
            findings.append(f"  -> {inp}")
    
    # Look for includes and file references
    includes = re.findall(r'(include|require|include_once|require_once)[\s\("\']+([^\s"\')]+)', response.text, re.I)
    if includes:
        findings.append(f"File includes: {[inc[1] for inc in includes[:3]]}")
    
    # Look for credentials or sensitive patterns
    sensitive_patterns = [
        r'database\s*=\s*', r'db_password\s*=\s*', r'api_key\s*=\s*',
        r'secret\s*=\s*', r'token\s*=\s*', r'password\s*=\s*',
        r'private_key\s*=\s*'
    ]
    for pattern in sensitive_patterns:
        if re.search(pattern, response.text, re.I):
            findings.append(f"Possible sensitive data: {pattern}")
    
    # Look for JavaScript API endpoints
    js_endpoints = re.findall(r'fetch\(["\']([^"\']+)["\']', response.text)
    if not js_endpoints:
        js_endpoints = re.findall(r'\.ajax\([\s\{]*url:[\s\'"]*([^\'"\s]+)', response.text)
    if js_endpoints:
        unique_endpoints = list(set(js_endpoints))[:3]
        findings.append(f"JS API endpoints: {unique_endpoints}")
    
    # Look for tech signatures
    if 'laravel' in response.text.lower():
        findings.append("Laravel framework detected")
    if 'wordpress' in response.text.lower():
        findings.append("WordPress detected")
    if 'drupal' in response.text.lower():
        findings.append("Drupal detected")
    if 'jquery' in response.text.lower():
        findings.append("jQuery detected")
    if 'bootstrap' in response.text.lower():
        findings.append("Bootstrap detected")
    
    return findings

def is_catch_all(response):
    """Check if response is the catch-all page"""
    return len(response.content) == catch_all_size

print("\n[1] Testing Common PHP Files")
print("-" * 80)
for endpoint in common_endpoints:
    for ext in ['.php'] + file_extensions[1:]:  # Test .php and then variations
        url = f"{BASE_URL}/{endpoint}{ext}"
        try:
            resp = requests.get(url, timeout=TIMEOUT, headers=headers, allow_redirects=False)
            if resp.status_code != 404 and not is_catch_all(resp):
                print(f"[+] FOUND: {url}")
                print(f"    Status: {resp.status_code} | Size: {len(resp.content)}B")
                findings = analyze_response(url, resp)
                for finding in findings:
                    print(f"    - {finding}")
                unique_endpoints.add(url)
                break  # Move to next endpoint after finding one
        except Exception as e:
            pass

print("\n[2] Testing Hidden Directories")
print("-" * 80)
for directory in directories:
    for ext in ['', '.php', '/index.php']:
        url = f"{BASE_URL}/{directory}{ext}"
        try:
            resp = requests.get(url, timeout=TIMEOUT, headers=headers, allow_redirects=False)
            if resp.status_code != 404 and not is_catch_all(resp):
                print(f"[+] FOUND: {url}")
                print(f"    Status: {resp.status_code} | Size: {len(resp.content)}B")
                findings = analyze_response(url, resp)
                for finding in findings:
                    print(f"    - {finding}")
                unique_endpoints.add(url)
        except Exception as e:
            pass

print("\n[3] Testing Hidden Configuration Files")
print("-" * 80)
for filename in hidden_files:
    url = f"{BASE_URL}/{filename}"
    try:
        resp = requests.get(url, timeout=TIMEOUT, headers=headers, allow_redirects=False)
        if resp.status_code != 404 and not is_catch_all(resp):
            print(f"[!] CRITICAL: {url}")
            print(f"    Status: {resp.status_code} | Size: {len(resp.content)}B")
            print(f"\n    --- RESPONSE START ---")
            print(f"    {resp.text[:500]}...")  # Show first 500 chars
            print(f"    --- RESPONSE END ---\n")
            unique_endpoints.add(url)
    except Exception as e:
        pass

print("\n[4] Testing REST API Endpoints")
print("-" * 80)
for endpoint in rest_endpoints:
    url = f"{BASE_URL}/{endpoint}"
    try:
        resp = requests.get(url, timeout=TIMEOUT, headers=headers, allow_redirects=False)
        if resp.status_code != 404 and not is_catch_all(resp):
            print(f"[+] FOUND: {url}")
            print(f"    Status: {resp.status_code} | Size: {len(resp.content)}B")
            findings = analyze_response(url, resp)
            for finding in findings:
                print(f"    - {finding}")
            unique_endpoints.add(url)
    except Exception as e:
        pass

print("\n[5] Testing Common Parameters on Root")
print("-" * 80)
for param in parameters[:10]:  # Test first 10 parameters
    url = f"{BASE_URL}/?{param}=test"
    try:
        resp = requests.get(url, timeout=TIMEOUT, headers=headers, allow_redirects=False)
        if not is_catch_all(resp) and ('test' in resp.text or resp.status_code != 200):
            print(f"[+] PARAMETER RESPONSE: {param}")
            print(f"    URL: {url}")
            print(f"    Status: {resp.status_code} | Size: {len(resp.content)}B")
            if 'test' in resp.text:
                print(f"    - Parameter reflects in response (possible XSS/SSTI)")
    except Exception as e:
        pass

print("\n[6] Checking Base Root Endpoint")
print("-" * 80)
try:
    resp = requests.get(BASE_URL, timeout=TIMEOUT, headers=headers)
    print(f"[+] {BASE_URL}")
    print(f"    Status: {resp.status_code} | Size: {len(resp.content)}B")
    print(f"    Server: {resp.headers.get('Server', 'N/A')}")
    print(f"    X-Powered-By: {resp.headers.get('X-Powered-By', 'N/A')}")
    
    findings = analyze_response(BASE_URL, resp)
    for finding in findings:
        print(f"    - {finding}")
        
    # Look for all links in the page
    links = re.findall(r'href=["\']?([^"\'\s>]+)', resp.text, re.I)
    scripts = re.findall(r'src=["\']?([^"\'\s>]+)', resp.text, re.I)
    
    print(f"\n[+] Links found: {len(links)}")
    for link in links[:10]:
        full_url = urljoin(BASE_URL, link)
        if BASE_URL in full_url:
            print(f"    - {link}")
            
    print(f"\n[+] Scripts found: {len(scripts)}")
    for script in scripts[:10]:
        full_url = urljoin(BASE_URL, script)
        if BASE_URL in full_url and '.js' in script:
            print(f"    - {script}")
            # Try to fetch JavaScript files
            try:
                js_resp = requests.get(full_url, timeout=TIMEOUT, headers=headers)
                if js_resp.status_code == 200:
                    # Look for API endpoints in JS
                    api_calls = re.findall(r'(?:fetch|ajax|get|post)[\s\(]*["\']([^"\']+)["\']', js_resp.text, re.I)
                    if api_calls:
                        print(f"      -> API calls: {list(set(api_calls))[:3]}")
            except:
                pass
except Exception as e:
    print(f"[-] Error accessing root: {e}")

print("\n[7] Testing Debug Modes")
print("-" * 80)
debug_params = {
    'debug': ['1', 'true', 'on'],
    'test': ['1', 'true'],
    'dev': ['1', 'true'],
    'trace': ['1', 'yes'],
    'profile': ['1', 'yes'],
    'echo': ['test', 'hello'],
    'dump': ['1']
}
for param, values in debug_params.items():
    for value in values:
        url = f"{BASE_URL}/?{param}={value}"
        try:
            resp = requests.get(url, timeout=TIMEOUT, headers=headers, allow_redirects=False)
            if not is_catch_all(resp) and resp.status_code != 404:
                size_diff = abs(len(resp.content) - catch_all_size)
                if size_diff > 100:  # Significant difference
                    print(f"[+] DEBUG MODE: {param}={value}")
                    print(f"    Status: {resp.status_code} | Size: {len(resp.content)}B (Δ{size_diff}B)")
        except Exception as e:
            pass

print("\n[8] Testing Alternative HTTP Methods")
print("-" * 80)
methods = ['OPTIONS', 'HEAD', 'TRACE', 'PUT', 'DELETE', 'PATCH']
for method in methods:
    try:
        resp = requests.request(method, BASE_URL, timeout=TIMEOUT, headers=headers)
        if resp.status_code != 405 and resp.status_code != 501:
            print(f"[+] {method} method allowed")
            print(f"    Status: {resp.status_code}")
            if resp.headers.get('Allow'):
                print(f"    Allowed: {resp.headers['Allow']}")
    except Exception as e:
        pass

print("\n[9] Summary of Unique Endpoints Found")
print("-" * 80)
print(f"Total unique valid endpoints: {len(unique_endpoints)}")
for endpoint in sorted(unique_endpoints):
    print(f"    - {endpoint}")

print("\n[10] Checking for Server/PHP Version Disclosure")
print("-" * 80)
try:
    # Try common PHP info files
    info_files = ['phpinfo.php', 'info.php', 'test.php', 'version.php']
    for info_file in info_files:
        url = f"{BASE_URL}/{info_file}"
        resp = requests.get(url, timeout=TIMEOUT, headers=headers)
        if resp.status_code == 200 and 'PHP Version' in resp.text:
            print(f"[!] PHP INFO DISCLOSURE: {url}")
            version_match = re.search(r'PHP Version\s+([\d\.]+)', resp.text)
            if version_match:
                print(f"    PHP Version: {version_match.group(1)}")
except Exception as e:
    print(f"[-] Error checking PHP info: {e}")

print("\n[11] Testing for Source Code Disclosure")
print("-" * 80)
# Try requesting PHP source instead of execution
source_tests = [
    ('index.phps', 'Source disclosure attempt'),
    ('config.phps', 'Config source disclosure'),
    ('.php.swp', 'Vim swap file'),
    ('.php.swo', 'Vim swap file (alt)'),
    ('.php.save', 'Nano save file'),
]
for filename, description in source_tests:
    url = f"{BASE_URL}/{filename}"
    try:
        resp = requests.get(url, timeout=TIMEOUT, headers=headers)
        if resp.status_code == 200 and '<?php' in resp.text[:100]:
            print(f"[!] SOURCE DISCLOSURE: {url}")
            print(f"    {description}")
            print(f"    First 200 chars: {resp.text[:200]}")
    except Exception as e:
        pass

print("\n" + "=" * 80)
print("ARCHITECTURE ANALYSIS COMPLETE")
