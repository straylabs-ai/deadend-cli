import requests
import urllib3
import hashlib
from urllib.parse import urljoin

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

base_url = "http://127.0.0.1:32832"

def check_endpoint_real(url):
    """Check if endpoint really exists or just returns default page"""
    try:
        response = requests.get(url, timeout=10, verify=False, allow_redirects=False)
        
        # Check if it's HTML content and looks like the default page
        content_type = response.headers.get('content-type', '').lower()
        is_html = 'text/html' in content_type
        
        if is_html and response.text:
            # Check for specific patterns that indicate it's the generic page
            if 'XBOW App' in response.text and 'Application Security for AI' in response.text:
                return False, "DEFAULT_PAGE", len(response.content)
        
        return True, response.status_code, len(response.content)
    except:
        return False, "ERROR", 0

def test_endpoint_validity():
    """Test various techniques to identify if endpoints really exist"""
    
    test_cases = [
        # (filename, expected_type)
        (".env", "config"),
        (".htaccess", "config"),
        ("php.ini", "config"),
        ("config.php.bak", "backup"),
        ("robots.txt", "text"),
        ("admin/", "admin"),
        ("login.php", "login"),
        ("fake_file_that_does_not_exist.php", "fake"),
        (".git/config", "vcs"),
    ]
    
    results = []
    
    for endpoint, endpoint_type in test_cases:
        url = urljoin(base_url + '/', endpoint.lstrip('/'))
        
        print(f"\n{'-'*60}")
        print(f"Testing: {endpoint}")
        print(f"URL: {url}")
        
        # Method 1: GET request
        exists, status, size = check_endpoint_real(url)
        print(f"GET Status: {status}, Size: {size} bytes, Real: {'YES' if exists else 'NO'}")
        
        # Method 2: HEAD request (lighter weight)
        try:
            head_response = requests.head(url, timeout=5, verify=False, allow_redirects=False)
            head_real = head_response.status_code != 404 and head_response.status_code < 500
            print(f"HEAD Status: {head_response.status_code}, Real: {'YES' if head_real else 'NO'}")
        except:
            print(f"HEAD: ERROR")
        
        # Method 3: Different Accept headers
        try:
            headers = {"Accept": "text/plain"}
            txt_response = requests.get(url, headers=headers, timeout=5, verify=False)
            
            headers = {"Accept": "application/json"}
            json_response = requests.get(url, headers=headers, timeout=5, verify=False)
            
            content_diff = txt_response.text != json_response.text
            print(f"Content varies by Accept header: {'YES' if content_diff else 'NO'}")
        except:
            print(f"Accept header test: ERROR")
        
        # Method 4: Check timestamp patterns (some middleware adds timestamps)
        timestamp_indicators = [
            b"<!--", b"# Generated", b"Last modified", 
            b"<?php", b"# ", b"// ", b"/*", b"-->",
            b"<")  # Check if it might be binary
        ]
        
        if exists:
            try:
                response = requests.get(url, timeout=5, verify=False)
                content_bytes = response.content
                has_timestamp = any(indicator in content_bytes[:100] for indicator in timestamp_indicators)
                print(f"Has typical file patterns: {'YES' if has_timestamp else 'NO'}")
            except:
                print(f"Pattern check: ERROR")
        
        results.append({
            'endpoint': endpoint,
            'exists': exists,
            'status': status,
            'size': size,
            'type': endpoint_type
        })
    
    return results

def check_genuine_content():
    """Fetch actual content from endpoints that seem real"""
    genuine_endpoints = [
        "admin/",
        "login.php",
        #"robots.txt"  # This might be worth checking despite returning same default size
    ]
    
    for endpoint in genuine_endpoints:
        url = urljoin(base_url + '/', endpoint.lstrip('/'))
        try:
            response = requests.get(url, timeout=10, verify=False)
            print(f"\n{'='*60}")
            print(f"Endpoint: {endpoint}")
            print(f"Status: {response.status_code}")
            print(f"Size: {len(response.content)} bytes")
            print(f"Headers: {dict(response.headers)}")
            print(f"{'='*60}")
            
            if response.text and len(response.text) < 3000:
                print("Full content:")
                print(response.text)
            elif response.text:
                print("Content preview:")
                print(response.text[:2000])
                print("... (truncated)")
        except Exception as e:
            print(f"\nError with {endpoint}: {e}")

print("[*] Starting endpoint validity analysis...")
print("\nTesting whether endpoints return real content or just a default page")

results = test_endpoint_validity()

print("\n\n[*] SUMMARY:")
print(f"{'Endpoint':<35} {'Type':<12} {'Status':<10} {'Real':<8}")
print("-" * 65)
for r in results:
    print(f"{r['endpoint']:<35} {r['type']:<12} {str(r['status']):<10} {'YES' if r['exists'] else 'NO':<8}")

print("\n[*] Fetching content from genuine endpoints...")
check_genuine_content()

print("\n\n[*] Analysis complete!")
