print("\n[3] Following Home.php Redirect")
print("-" * 80)
url = f"{BASE_URL}/home.php"
try:
    resp = requests.get(url, timeout=TIMEOUT, headers=headers, allow_redirects=True)
    print(f"[+] Final redirect URL: {resp.url}")
    print(f"    Status: {resp.status_code} | Size: {len(resp.content)}B")
    print(f"    History: {len(resp.history)} redirects")
    
    # Show preview
    print(f"\n    Response preview:")
    print(f"    {resp.text[:500]}")
    
    if len(resp.content) != catch_all_size:
        print(f"\n    [!] Non-catch-all response - may be accessible endpoint")
        
        # Extract links
        links = re.findall(r'href=["\']?([^\s"\'>]+)', resp.text)
        unique_links = set()
        for link in links:
            if link.startswith('http'):
                if BASE_URL in link:
                    unique_links.add(link)
            elif link.startswith('/'):
                unique_links.add(urljoin(BASE_URL, link))
        
        if unique_links:
            print(f"\n    [i] Internal links found:")
            for link in sorted(unique_links)[:10]:
                print(f"      - {link}")
            
except Exception as e:
    print(f"[-] Error following home.php: {e}")

print("\n[4] Deep Analysis of Login.php")
print("-" * 80)
url = f"{BASE_URL}/login.php"
try:
    resp = requests.get(url, timeout=TIMEOUT, headers=headers)
    print(f"[+] Login page analysis")
    print(f"    Status: {resp.status_code} | Size: {len(resp.content)}B")
    print(f"\n    Full response:")
    print(resp.text)
    
    # Check for all input fields
    inputs = re.findall(r'<input[^>]*>', resp.text, re.I)
    print(f"\n    [i] Input fields found: {len(inputs)}")
    for i, inp in enumerate(inputs):
        # Extract name and type
        name = re.search(r'name=["\']?([^\s"\'>]+)', inp, re.I)
        type_attr = re.search(r'type=["\']?([^\s"\'>]+)', inp, re.I)
        value = re.search(r'value=["\']?([^\s"\'>]+)', inp, re.I)
        
        name_str = name.group(1) if name else 'N/A'
        type_str = type_attr.group(1) if type_attr else 'text'
        value_str = value.group(1) if value else ''
        
        print(f"      {i+1}. Name: {name_str} | Type: {type_str} | Value: {value_str}")
    
    # Look for CSRF tokens or hidden fields
    hidden_fields = re.findall(r'<input[^>]*type=["\']?hidden[^>]*>', resp.text, re.I)
    if hidden_fields:
        print(f"\n    [!] HIDDEN FIELDS: {len(hidden_fields)}")
        for field in hidden_fields:
            print(f"        {field}")
    
    # Check form action
    form_action = re.search(r'<form[^>]*action=["\']?([^\s"\'>]+)[^>]*>', resp.text, re.I)
    if form_action:
        print(f"\n    [i] Form action: {form_action.group(1)}")
        
    # Check form method
    form_method = re.search(r'<form[^>]*method=["\']?([^\s"\'>]+)[^>]*>', resp.text, re.I)
    if form_method:
        print(f"    [i] Form method: {form_method.group(1).upper()}")
        
except Exception as e:
    print(f"[-] Error analyzing login.php: {e}")

