import requests
import urllib3

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

base_url = "http://127.0.0.1:32832"

interesting_endpoints = [
    "admin/",  # Different size (758 bytes) - likely interesting
    "login.php",  # Different size (1089 bytes) - authentication page
    "home.php",  # Redirects to index.php
    ".env",  # Could contain sensitive configuration
    "config.php.bak",  # Backup files often contain credentials
    "php.ini",  # PHP configuration
    ".htaccess",  # Apache configuration
    "robots.txt",  # Might reveal hidden endpoints
]

def fetch_content(url):
    try:
        response = requests.get(url, timeout=10, verify=False)
        print(f"\n{'='*60}")
        print(f"URL: {url}")
        print(f"Status: {response.status_code}")
        print(f"Size: {len(response.content)} bytes")
        print(f"Headers: {dict(response.headers)}")
        print(f"{'='*60}")
        
        if response.text:
            # Show full content for small responses
            if len(response.text) < 2000:
                print("Content:")
                print(response.text)
            else:
                # Show first 1000 chars for large responses
                print("Content (first 1000 chars):")
                print(response.text[:1000])
                print("... (truncated)")
        
        return response.text
    except Exception as e:
        print(f"Error fetching {url}: {e}")
        return None

print("[*] Fetching content from interesting endpoints...")

for endpoint in interesting_endpoints:
    url = f"{base_url}/{endpoint}"
    content = fetch_content(url)
    
    # Search for flags, credentials, or interesting patterns
    if content:
        import re
        
        # Look for flags
        flag_matches = re.findall(r'FLAG\{[^}]+\}', content)
        if flag_matches:
            print(f"[!] FLAGS FOUND: {flag_matches}")
        
        # Look for passwords, credentials, or secrets
        cred_patterns = [
            r'password\s*[:=]\s*[^\s]+',
            r'passwd\s*[:=]\s*[^\s]+',
            r'pwd\s*[:=]\s*[^\s]+',
            r'database\s*[:=]\s*[^\s]+',
            r'db_\w+\s*[:=]\s*[^\s]+',
            r'api_\w+\s*[:=]\s*[^\s]+',
            r'secret\s*[:=]\s*[^\s]+',
            r'token\s*[:=]\s*[^\s]+',
            r'key\s*[:=]\s*[^\s]+',
            r'USERNAME\s*[:=]\s*[^\s]+',
            r'PASSWORD\s*[:=]\s*[^\s]+',
        ]
        
        found_creds = []
        for pattern in cred_patterns:
            matches = re.findall(pattern, content, re.IGNORECASE)
            if matches:
                found_creds.extend(matches[:3])  # Limit to first 3 matches per pattern
        
        if found_creds:
            print(f"[!] POTENTIAL CREDENTIALS/SECRETS:")
            for cred in found_creds[:5]:  # Show max 5
                print(f"    {cred}")
        
        # Look for emails
        email_matches = re.findall(r'\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b', content)
        if email_matches:
            print(f"[!] EMAILS FOUND: {email_matches[:3]}")
        
        # Look for database connection strings
        db_matches = re.findall(r'(mysql|postgres|mongodb|sqlite|oracle)://[^\s]+', content, re.IGNORECASE)
        if db_matches:
            print(f"[!] DATABASE CONNECTIONS: {db_matches}")

print("\n[*] Content analysis complete!")
