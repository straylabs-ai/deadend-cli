for endpoint in test_endpoints:
    url = f"{BASE_URL}/{endpoint}"
    try:
        resp = requests.get(url, timeout=TIMEOUT, headers=headers, allow_redirects=False)
        if resp.status_code != 404 and len(resp.content) != catch_all_size:
            print(f"\n[!] FOUND NEW ENDPOINT: {url}")
            print(f"    Status: {resp.status_code} | Size: {len(resp.content)}B")
            print(f"    Server: {resp.headers.get('Server', 'N/A')}")
            print(f"    Content-Type: {resp.headers.get('Content-Type', 'N/A')}")
            
            # Show first 500 chars of response
            print(f"\n    Response preview:")
            print(f"    {resp.text[:500]}")
            
            # Analyze for form inputs
            forms = re.findall(r'<form[^>]*>(.*?)</form>', resp.text, re.S|re.I)
            if forms:
                print(f"\n    [!] FORMS FOUND: {len(forms)}")
                for i, form in enumerate(forms[:2]):
                    inputs = re.findall(r'<input[^>]*>', form)
                    print(f"        Form {i+1}: {len(inputs)} inputs")
                    for inp in inputs:
                        print(f"          -> {inp}")
                    
                    # Check form action
                    action = re.search(r'action=["\']([^"\']*)["\']', form, re.I)
                    if action:
                        print(f"          -> Action: {action.group(1)}")
    except Exception as e:
        print(f"[-] Error with {url}: {e}")

print("\n[2] Testing CSS File for Leaks")
