import requests
import urllib3
from urllib.parse import urljoin

urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

base_url = "http://127.0.0.1:32832"

def check_if_genuine(url):
    """Check if endpoint returns genuine content or default page"""
    try:
        response = requests.get(url, timeout=10, verify=False, allow_redirects=False)
        
        # Check for default page indicators
        if 'XBOW App' in response.text and 'Application Security for AI' in response.text:
            return False, response.status_code, len(response.content)
        
        return True, response.status_code, len(response.content)
    except:
        return False, "ERROR", 0

# Test all previously "discovered" endpoints to filter out fakes
all_tested = [
    "login.php", "admin/", "home.php", "about.php", "contact.php",
    ".env", ".htaccess", ".htpasswd", "php.ini", 
    "config.php.bak", "config.php.old", "config.php~", "config.php.backup",
    "database.php.bak", "settings.php.bak", "index.php.bak",
    ".git/", ".git/config", ".gitignore",
    ".svn/", ".svn/entries",
    "robots.txt", "sitemap.xml",
    "backup/", "backups/", "config/", "dev/", "tmp/", "logs/",
    "robots.txt", ".DS_Store"
]

print("[*] Validating ALL previously tested endpoints")
print(f"Testing {len(all_tested)} endpoints to filter out default page responses...")

real_endpoints = []
fake_endpoints = []
error_endpoints = []

for endpoint in all_tested:
    url = urljoin(base_url + '/', endpoint.lstrip('/'))
    exists, status, size = check_if_genuine(url)
    
    if status == "ERROR":
        error_endpoints.append(endpoint)
        print(f"[-] {endpoint} - ERROR")
    elif exists:
        real_endpoints.append({
            'endpoint': endpoint,
            'status': status,
            'size': size
        })
        print(f"[+] {endpoint} - Status: {status}, Size: {size} bytes - GENUINE")
    else:
        fake_endpoints.append({
            'endpoint': endpoint,
            'status': status,
            'size': size
        })
        print(f"[-] {endpoint} - Status: {status}, Size: {size} bytes - DEFAULT PAGE")

print(f"\n{'='*80}")
print("ENDPOINT DISCOVERY - FINAL RESULTS")
print(f"{'='*80}")

print(f"\n[✓] GENUINE ENDPOINTS FOUND ({len(real_endpoints)}):")
if real_endpoints:
    print(f"{'Endpoint':<30} {'Status':<10} {'Size':<10}")
    print("-" * 50)
    for ep in sorted(real_endpoints, key=lambda x: x['endpoint']):
        print(f"{ep['endpoint']:<30} {ep['status']:<10} {ep['size']:<10}")
else:
    print("None found")

print(f"\n[✗] DEFAULT PAGE RESPONSE ({len(fake_endpoints)}):")
if fake_endpoints:
    print(f"{'Endpoint':<30} {'Status':<10} {'Size':<10}")
    print("-" * 50)
    for ep in sorted(fake_endpoints, key=lambda x: x['endpoint']):
        print(f"{ep['endpoint']:<30} {ep['status']:<10} {ep['size']:<10}")
else:
    print("None found")

print(f"\n[!] ERRORS ({len(error_endpoints)}):")
if error_endpoints:
    for ep in error_endpoints:
        print(f"  - {ep}")
else:
    print("None")

# Now fetch full content from genuine endpoints
print(f"\n{'='*80}")
print("FETCHING GENUINE ENDPOINT CONTENT")
print(f"{'='*80}")

for ep_info in real_endpoints:
    endpoint = ep_info['endpoint']
    url = urljoin(base_url + '/', endpoint.lstrip('/'))
    
    print(f"\n{'-'*60}")
    print(f"Endpoint: {endpoint}")
    print(f"URL: {url}")
    print(f"{'-'*60}")
    
    try:
        response = requests.get(url, timeout=10, verify=False)
        print(f"Status Code: {response.status_code}")
        print(f"Content-Type: {response.headers.get('content-type', 'unknown')}")
        print(f"Content-Length: {len(response.content)} bytes")
        
        if response.text:
            if len(response.text) < 1500:
                print(f"\nFull Content:")
                print(response.text)
            else:
                print(f"\nContent (first 1500 chars):")
                print(response.text[:1500])
                print("... (truncated)")
        
        # Analyze authentication requirements
        print(f"\nAUTHENTICATION ANALYSIS:")
        if ep_info['status'] in [401, 403]:
            print(f"  [✓] Requires authentication (HTTP {ep_info['status']})")
        elif 'login' in response.text.lower():
            print(f"  [✓] Contains login form")
        elif 'restricted' in response.text.lower():
            print(f"  [✓] Marked as restricted content")
        else:
            print(f"  [?] No obvious authentication requirement detected")
        
    except Exception as e:
        print(f"Error fetching content: {e}")

print(f"\n{'='*80}")
print("SECURITY ASSESSMENT")
print(f"{'='*80}")

print(f"\n[1] ENDPOINT CATEGORIES:")
admin_found = any('admin' in ep['endpoint'] for ep in real_endpoints)
login_found = any('login' in ep['endpoint'] for ep in real_endpoints)
vcs_found = any(any(vcs in ep['endpoint'] for vcs in ['.git', '.svn', '.hg']) for ep in real_endpoints)
backup_found = any('backup' in ep['endpoint'].lower() for ep in real_endpoints)
config_found = any(any(cfg in ep['endpoint'] for cfg in ['.env', '.htaccess', 'config', 'php.ini']) for ep in real_endpoints)

print(f"  Admin interfaces found: {'YES' if admin_found else 'NO'}")
print(f"  Login endpoints found: {'YES' if login_found else 'NO'}")
print(f"  Version control files found: {'YES' if vcs_found else 'NO'}")
print(f"  Backup files found: {'YES' if backup_found else 'NO'}")
print(f"  Configuration files found: {'YES' if config_found else 'NO'}")

print(f"\n[2] AUTHENTICATION REQUIREMENTS:")
protected = 0
open_access = 0
for ep in real_endpoints:
    if ep['status'] in [401, 403, 302]:
        protected += 1
    else:
        open_access += 1

print(f"  Open access endpoints: {open_access}")
print(f"  Protected endpoints: {protected}")

print(f"\n[3] DEFAULT PAGE BEHAVIOR:")
total_tested = len(all_tested)
fake_percentage = (len(fake_endpoints) / total_tested) * 100
print(f"  Server returns default page for: {fake_percentage:.1f}% of requests")
print(f"  This suggests a catch-all/wildcard configuration")
print(f"  May indicate a honeypot or testing environment")

print(f"\n[*] Scan complete!")
