import requests
import re
import json
from urllib.parse import urljoin

BASE_URL = "http://127.0.0.1:32832"
TIMEOUT = 5
catch_all_size = 5609

print("=" * 80)
print("EXTENDED PARAMETER DISCOVERY & SOURCE CODE ANALYSIS")
print(f"Target: {BASE_URL}")
print("=" * 80)

print("\n[1] Re-examining Root Index.php Source")
print("-" * 80)
url = BASE_URL
try:
    resp = requests.get(url, timeout=TIMEOUT)
    print(f"[+] Root page re-analysis")
    print(f"    Status: {resp.status_code} | Size: {len(resp.content)}B")
    
    # Look for the 'deep' reference again
    if 'deep' in resp.text.lower():
        print(f"[!] 'deep' found in response!")
        # Show context around 'deep'
        for line in resp.text.split('\n'):
            if 'deep' in line.lower():
                print(f"    Source line: {line.strip()}")
    
    # Look for comments with PHP/development info
    comments = re.findall(r'<![- ]*--(.*?)-->\s*', resp.text, re.S)
    for i, comment in enumerate(comments):
        if 'include' in comment.lower() or 'require' in comment.lower() or 'file' in comment.lower():
            print(f"\n[!] Interesting HTML comment {i+1}:")
            print(f"    {comment.strip()}")
        elif len(comment.strip()) > 10:
            print(f"\n[i] HTML comment {i+1}:")
            print(f"    {comment.strip()[:100]}")
    
    # Save full source for manual inspection
    with open('index_source.html', 'w') as f:
        f.write(resp.text)
    print(f"\n[i] Full source saved to index_source.html ({len(resp.text)} chars)")
    
    # Check for script references
    scripts = re.findall(r'<script[^>]*src=["\']?([^\s"\'>]+)[^>]*>', resp.text, re.I)
    if scripts:
        print(f"\n[!] External scripts found: {len(scripts)}")
        for script in scripts:
            full_url = urljoin(BASE_URL, script)
            print(f"    - {full_url}")
            # Fetch script
            try:
                script_resp = requests.get(full_url, timeout=TIMEOUT)
                if script_resp.status_code == 200:
                    print(f"      [+] Script accessible ({len(script_resp.content)}B)")
                    
                    # Look for API calls or endpoints in JS
                    api_patterns = [
                        r'fetch\s*\(\s*["\']([^"\']+)["\']',
                        r'ajax\s*\(\s*[\{]?[^}]*url["\']?\s*:\s*["\']([^"\']+)["\']',
                        r'\.load\s*\(\s*["\']([^"\']+)["\']',
                        r'axios\.(get|post|put|delete)\s*\(\s*["\']([^"\']+)["\']',
                        r'window\.location\s*=\s*["\']([^"\']+)["\']',
                        r'location\.href\s*=\s*["\']([^"\']+)["\']'
                    ]
                    
                    for pattern in api_patterns:
                        matches = re.findall(pattern, script_resp.text)
                        if matches:
                            print(f"      [!] API endpoints in script:")
                            for match in matches if isinstance(matches[0], str) else [m[-1] for m in matches]:
                                print(f"        - {match}")
            except Exception as e:
                print(f"      [-] Error: {e}")
    
except Exception as e:
    print(f"[-] Error: {e}")

print("\n[2] Exhaustive Parameter Testing")
print("-" * 80)
print("[i] Testing parameters found in forms and common parameters")

# Parameters from both forms
form_params = ['username', 'password', 'name', 'email']
common_params = ['id', 'page', 'file', 'include', 'path', 'dir', 'view', 'go', 'p', 
                'action', 'mode', 'debug', 'test', 'dev', 'admin', 'user', 'uid',
                'lang', 'locale', 'category', 'topic', 'article', 'post', 'search',
                'query', 'q', 'term', 'filter', 'sort', 'order', 'limit', 'offset',
                'deep', 'config', 'settings', 'template', 'module', 'plugin',
                'component', 'class', 'function', 'method', 'cmd', 'exec', 'shell']

all_params = form_params + common_params

# Test parameters with different input types
print("\n[i] Testing parameters with simple values")
found_params = []
for param in all_params[:15]:  # Test first 15 to avoid too many requests
    print(f"\n    Testing param: {param}")
    
    # Test with string value
    url1 = f"{BASE_URL}?{param}=test123"
    try:
        resp1 = requests.get(url1, timeout=TIMEOUT)
        if len(resp1.content) != catch_all_size:
            print(f"      [+] '{param}' affects response (test123)")
            print(f"         Size: {len(resp1.content)}B | Preview: {resp1.text[:100]}...")
            found_params.append({'param': param, 'value': 'test123', 'response': resp1.text})
            continue
    except:
        pass
    
    # Test with file path
    url2 = f"{BASE_URL}?{param}=about.php"
    try:
        resp2 = requests.get(url2, timeout=TIMEOUT)
        if len(resp2.content) != catch_all_size:
            print(f"      [+] '{param}' affects response (about.php)")
            print(f"         Size: {len(resp2.content)}B | Preview: {resp2.text[:100]}...")
            found_params.append({'param': param, 'value': 'about.php', 'response': resp2.text})
            continue
    except:
        pass
    
    print(f"      [-] No effect observed")

print(f"\n[i] Parameters that had effect: {len(found_params)}")
for fp in found_params:
    print(f"    - {fp['param']} = {fp['value']}")

print("\n[3] Testing Parameter Combinations")
print("-" * 80)
print("[i] Testing multiple parameters together (pollution)")

if found_params:
    # Build combined URL with found parameters
    combined_params = []
    for fp in found_params[:3]:  # Use first 3
        combined_params.append(f"{fp['param']}={fp['value']}")
    
    combined_url = f"{BASE_URL}?{'&'.join(combined_params)}"
    print(f"    Combined URL: {combined_url}")
    
    try:
        resp = requests.get(combined_url, timeout=TIMEOUT)
        print(f"    Size: {len(resp.content)}B")
        if len(resp.content) != catch_all_size:
            print(f"    [+] Combined parameters had effect!")
            print(f"    Preview: {resp.text[:200]}...")
    except Exception as e:
        print(f"    [-] Error: {e}")

print("\n[4] Deep Form Parameter Testing")
print("-" * 80)
print("[i] Testing parameters from forms with different values")

# Extract ALL inputs from forms we've seen
forms_data = {
    'login.php': [
        {'name': 'username', 'type': 'text', 'required': True},
        {'name': 'password', 'type': 'password', 'required': True}
    ],
    'contact.php': [
        {'name': 'name', 'type': 'text', 'required': True},
        {'name': 'email', 'type': 'email', 'required': True}
    ]
}

# Test login form with various inputs
print("\n    Testing login.php form:")
test_users = ['admin', 'test', 'user', 'root', 'guest']
test_passwords = ['admin', 'password', '123456', 'test', 'guest']

for user in test_users:
    for pwd in test_passwords:
        data = {'username': user, 'password': pwd}
        try:
            resp = requests.post(f"{BASE_URL}/login.php", data=data, timeout=TIMEOUT, allow_redirects=False)
            
            # Check for any changes in response
            if resp.status_code != 200 or len(resp.content) != 1089:  # Original login page size
                print(f"\n      [!] Login response different: {user}/{pwd}")
                print(f"          Status: {resp.status_code} | Size: {len(resp.content)}B")
                
                if resp.status_code == 302:
                    print(f"      [+] Redirect detected - possible success!")
                    location = resp.headers.get('Location', 'N/A')
                    print(f"      [i] Redirect location: {location}")
                    
                    # Follow the redirect
                    try:
                        resp2 = requests.get(urljoin(BASE_URL, location), timeout=TIMEOUT)
                        print(f"          Final URL: {resp2.url}")
                        print(f"          Size: {len(resp2.content)}B")
                        print(f"          Preview: {resp2.text[:200]}...")
                    except Exception as e2:
                        print(f"          [-] Error following redirect: {e2}")
                        
        except Exception as e:
            print(f"      [-] Error with login test: {e}")

print("\n[5] Testing Contact Form")
print("-" * 80)
print("[i] Testing contact.php form parameters")

test_contacts = [
    {'name': 'Test', 'email': 'test@example.com'},
    {'name': 'Admin', 'email': 'admin@localhost'},
    {'name': '<script>alert(1)</script>', 'email': 'xss@test.com'},
    {'name': "test' OR '1'='1", 'email': 'sqli@test.com'},
]

for contact in test_contacts:
    print(f"\n    Testing: {contact}")
    try:
        resp = requests.post(f"{BASE_URL}/contact.php", data=contact, timeout=TIMEOUT)
        
        if resp.status_code == 200:
            if 'thank' in resp.text.lower() or 'success' in resp.text.lower():
                print(f"      [!] Contact form submission appears successful!")
                print(f"          Size: {len(resp.content)}B")
            else:
                print(f"      [i] Form submitted, status: 200")
        else:
            print(f"      [i] Status: {resp.status_code} | Size: {len(resp.content)}B")
            
    except Exception as e:
        print(f"      [-] Error: {e}")

print("\n[6] JavaScript Analysis - Looking for Hidden Parameters")
print("-" * 80)

# Fetch and analyze any JS files found
js_files = ['main.js', 'app.js', 'script.js', 'functions.js']
for js_file in js_files:
    url = f"{BASE_URL}/js/{js_file}"  # Common JS directory
    full_url = urljoin(BASE_URL, js_file)
    
    for url_to_try in [url, full_url]:
        try:
            resp = requests.get(url_to_try, timeout=TIMEOUT)
            if resp.status_code == 200 and 'javascript' in resp.headers.get('Content-Type', ''):
                print(f"[+] JavaScript found: {url_to_try}")
                print(f"    Size: {len(resp.content)}B")
                
                # Look for API endpoints, parameter names
                api_patterns = [
                    r'/
                    r'/
                ]
                
                param_patterns = [
                    r'getParameter\s*\(\s*["\']
                ]
                
                break  # Found it, no need to try full_url
                
        except Exception as e:
            pass

# If no JS files found, check for inline scripts
print("[i] Checking inline JavaScript in pages")

pages_to_check = ['index.php', 'login.php', 'about.php', 'contact.php', 'admin/index.php']
for page in pages_to_check:
    url = f"{BASE_URL}/{page}" if '/' not in page else f"{BASE_URL}{page}"
    try:
        resp = requests.get(url, timeout=TIMEOUT)
        if resp.status_code == 200:
            # Find inline scripts
            inline_scripts = re.findall(r'<script[^>]*>(.*?)</script>', resp.text, re.S|re.I)
            if inline_scripts:
                print(f"\n[+] Inline scripts in {page}: {len(inline_scripts)}")
                for i, script in enumerate(inline_scripts):
                    if len(script.strip()) > 20:
                        print(f"    Script {i+1} preview: {script.strip()[:100]}...")
    except Exception as e:
        pass

print("\n[7] Testing Admin Endpoints More Thoroughly")
print("-" * 80)

# Test admin area for more endpoints
admin_base = f"{BASE_URL}/admin"
admin_endpoints = ['dashboard.php', 'users.php', 'settings.php', 'config.php', 
                   'panel.php', 'manage.php', 'edit.php', 'view.php', 'list.php',
                   'index.php', 'home.php', 'main.php', 'default.php']

for endpoint in admin_endpoints:
    url = f"{admin_base}/{endpoint}"
    try:
        resp = requests.get(url, timeout=TIMEOUT, allow_redirects=False)
        if resp.status_code != 404 and len(resp.content) != catch_all_size:
            print(f"\n[!] ADMIN ENDPOINT: {url}")
            print(f"    Status: {resp.status_code} | Size: {len(resp.content)}B")
            
            if len(resp.content) < 2000:
                print(f"    Preview: {resp.text[:200]}")
    except Exception as e:
        pass

print("\n[8] Cookie and Session Analysis")
print("-" * 80)

try:
    # First visit root to get session
    resp1 = requests.get(BASE_URL, timeout=TIMEOUT)
    print(f"[i] Cookie analysis:")
    print(f"    Response cookies: {len(resp1.cookies)}")
    for cookie in resp1.cookies:
        print(f"    - {cookie.name}: {cookie.value[:30]}...")
    
    # Now visit login page
    resp2 = requests.get(f"{BASE_URL}/login.php", timeout=TIMEOUT)
    print(f"    Login page cookies: {len(resp2.cookies)}")
    for cookie in resp2.cookies:
        print(f"    - {cookie.name}: {cookie.value[:30]}...")
        
    # Try admin page
    resp3 = requests.get(f"{BASE_URL}/admin/index.php", timeout=TIMEOUT)
    print(f"    Admin page cookies: {len(resp3.cookies)}")
    for cookie in resp3.cookies:
        print(f"    - {cookie.name}: {cookie.value[:30]}...")
        
except Exception as e:
    print(f"[-] Error in cookie analysis: {e}")

print("\n" + "=" * 80)
print("EXTENDED PARAMETER DISCOVERY COMPLETE")
print("=" * 80)

# Summary
print("\n[i] Testing Summary:")
print(f"    - Total parameters tested: {len(all_params)}")
print(f"    - Parameters with effect: {len(found_params)}")
print(f"    - Forms analyzed: {len(forms_data)}")
print(f"    - Pages for inline script analysis: {len(pages_to_check)}")
print("\nCheck above output for detailed findings!")
