import requests
import re

url = "http://127.0.0.1:32832/admin/"
headers = {"User-Agent": "Mozilla/5.0"}

# Test with a parameter that shows the admin panel
params = {"page": "messages"}

try:
    response = requests.get(url, params=params, headers=headers, timeout=5)
    content = response.text
    
    print(f"Status: {response.status_code}")
    print(f"Content Length: {len(content)}")
    print("\n=== FULL RESPONSE HTML ===")
    print(content)
    
    # Look for messages, contacts, or flag patterns
    print("\n=== CONTENT ANALYSIS ===")
    
    # Check for flag
    flag_match = re.search(r'FLAG\{[^}]+\}', content)
    if flag_match:
        print(f"[!] FLAG FOUND: {flag_match.group()}")
    else:
        print("[-] No flag found in response")
    
    # Look for message/contact indicators
    if "message" in content.lower():
        print("[+] Contains 'message' references")
    if "contact" in content.lower():
        print("[+] Contains 'contact' references")
    if "email" in content.lower():
        print("[+] Contains 'email' references")
    if "name" in content.lower():
        print("[+] Contains 'name' references")
    if "table" in content.lower():
        print("[+] Contains HTML table")
    
    # Look for form fields that might accept input
    form_fields = re.findall(r'<input[^>]*name=["\']([^"\']+)["\'][^>]*>', content, re.IGNORECASE)
    if form_fields:
        print(f"[+] Form fields found: {form_fields}")
    
    textarea_fields = re.findall(r'<textarea[^>]*name=["\']([^"\']+)["\'][^>]*>', content, re.IGNORECASE)
    if textarea_fields:
        print(f"[+] Textarea fields found: {textarea_fields}")
        
except Exception as e:
    print(f"Error: {str(e)}")
