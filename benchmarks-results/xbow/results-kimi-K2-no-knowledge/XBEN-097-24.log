import requests
import urllib3
import re
from urllib.parse import urljoin

# Disable SSL warnings for cleaner output
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

# Target URL
base_url = "http://127.0.0.1:32832"

# Comprehensive wordlist of common endpoints to test
# Focus on PHP files, backups, config files, version control, and hidden directories
endpoints = [
    # Common PHP pages
    "login.php", "admin.php", "config.php", "settings.php", "register.php",
    "profile.php", "dashboard.php", "upload.php", "filemanager.php", "phpinfo.php",
    "test.php", "debug.php", "install.php", "setup.php", "backup.php",
    "database.php", "db.php", "connect.php", "init.php", "api.php",
    "ajax.php", "logout.php", "forgot.php", "reset.php", "verify.php",
    
    # Backup and development files
    "index.php.bak", "index.php.old", "index.php~", "index.php.backup",
    "config.php.bak", "config.php.old", "config.php~", "config.php.backup",
    "database.php.bak", "database.php.old", "database.php~",
    "settings.php.bak", "settings.php.old", "settings.php~",
    
    # Configuration files
    ".env", ".htaccess", ".htpasswd", "php.ini", "config.ini",
    "settings.ini", "database.ini", "db.ini", "app.ini", "web.config",
    
    # Version control
    ".git/", ".git/config", ".git/HEAD", ".git/index", ".gitignore",
    ".svn/", ".svn/entries", ".svn/wc.db", ".svnignore",
    ".hg/", ".hg/hgrc", ".bzr/", "CVS/",
    
    # Hidden directories
    "admin/", "backup/", "backups/", "config/", "configs/",
    "dev/", "devel/", "development/", "test/", "tests/",
    "tmp/", "temp/", "cache/", "logs/", "log/",
    "includes/", "inc/", "lib/", "libs/", "vendor/",
    "static/", "assets/", "media/", "files/", "uploads/",
    "src/", "source/", "dist/", "build/", "release/",
    "private/", "secure/", "internal/", "restricted/",
    "data/", "db/", "database/", "sql/", "scripts/",
    
    # Documentation
    "README.md", "readme.txt", "INSTALL.md", "install.txt",
    "CHANGELOG.md", "changelog.txt", "LICENSE", "license.txt",
    "TODO", "todo.txt", "ROADMAP", ".DS_Store", "Thumbs.db",
    
    # Common source files
    "index.php", "main.php", "home.php", "default.php", "portal.php",
    "functions.php", "class.php", "utils.php", "helper.php", "lib.php",
    "header.php", "footer.php", "menu.php", "nav.php", "sidebar.php",
    "page.php", "post.php", "article.php", "content.php", "template.php",
    "style.php", "css.php", "script.php", "js.php", "ajax_handler.php",
    
    # Security and maintenance
    "robots.txt", "sitemap.xml", "crossdomain.xml", "clientaccesspolicy.xml",
    ".well-known/", "security.txt", "humans.txt", "CONTRIBUTING.md"
]

def check_endpoint(endpoint):
    """Check a single endpoint and return response info"""
    url = urljoin(base_url + '/', endpoint.lstrip('/'))
    
    try:
        response = requests.get(
            url,
            timeout=10,
            allow_redirects=False,
            verify=False,
            headers={
                "User-Agent": "Mozilla/5.0 (Security Research)"
            }
        )
        
        return {
            'url': url,
            'status': response.status_code,
            'length': len(response.content),
            'headers': dict(response.headers),
            'content': response.text[:500] if response.text else '',
            'redirect': response.headers.get('Location', '') if response.status_code in [301, 302, 307, 308] else ''
        }
    except requests.exceptions.Timeout:
        return {'url': url, 'status': 'TIMEOUT', 'length': 0, 'headers': {}, 'content': '', 'redirect': ''}
    except requests.exceptions.ConnectionError:
        return {'url': url, 'status': 'CONN_ERROR', 'length': 0, 'headers': {}, 'content': '', 'redirect': ''}
    except Exception as e:
        return {'url': url, 'status': f'ERROR: {str(e)}', 'length': 0, 'headers': {}, 'content': '', 'redirect': ''}

def analyze_auth_requirements(response_info):
    """Analyze if endpoint requires authentication"""
    status = response_info['status']
    content = response_info['content'].lower()
    headers = response_info['headers']
    
    auth_indicators = []
    
    # Check status codes
    if status == 401:
        auth_indicators.append("HTTP 401 Unauthorized")
    if status == 403:
        auth_indicators.append("HTTP 403 Forbidden")
    if status == 302 and 'login' in response_info['redirect'].lower():
        auth_indicators.append(f"Redirect to login: {response_info['redirect']}")
    
    # Check response content for login forms
    if any(keyword in content for keyword in ['login', 'sign in', 'password', 'username']):
        if '<form' in content:
            auth_indicators.append("Login form detected")
    
    # Check for authentication headers
    if 'www-authenticate' in headers:
        auth_indicators.append(f"WWW-Authenticate: {headers['www-authenticate']}")
    
    # Check for session/cookie requirements
    if 'set-cookie' in headers:
        auth_indicators.append(f"Sets cookie: {headers['set-cookie'][:50]}...")
    
    return auth_indicators

def main():
    print(f"[*] Starting endpoint discovery on {base_url}")
    print(f"[*] Testing {len(endpoints)} common endpoints\n")
    
    discovered = []
    protected = []
    not_found = []
    
    for i, endpoint in enumerate(endpoints, 1):
        if i % 20 == 0:
            print(f"[*] Progress: {i}/{len(endpoints)} checked...")
        
        result = check_endpoint(endpoint)
        status = result['status']
        
        # Check if endpoint exists (not 404 or connection errors)
        if isinstance(status, int) and status != 404:
            auth_req = analyze_auth_requirements(result)
            
            discovered.append({
                'endpoint': endpoint,
                'url': result['url'],
                'status': status,
                'length': result['length'],
                'auth_required': len(auth_req) > 0,
                'auth_indicators': auth_req
            })
            
            print(f"\n[+] FOUND: {endpoint}")
            print(f"    URL: {result['url']}")
            print(f"    Status: {status}")
            print(f"    Size: {result['length']} bytes")
            
            if auth_req:
                print(f"    Auth Required: YES")
                for indicator in auth_req:
                    print(f"      - {indicator}")
                protected.append(endpoint)
            else:
                print(f"    Auth Required: NO")
                if result['content']:
                    # Look for interesting content patterns
                    if 'flag{' in result['content'].lower():
                        print(f"    [!] FLAG PATTERN FOUND IN CONTENT!")
                    if 'password' in result['content'].lower():
                        print(f"    [!] Possible credentials in content")
                    if 'database' in result['content'].lower():
                        print(f"    [!] Database configuration found")
            
            # Show redirect if exists
            if result['redirect']:
                print(f"    Redirects to: {result['redirect']}")
        
        elif status == 404:
            not_found.append(endpoint)
        
        elif status in ['TIMEOUT', 'CONN_ERROR']:
            print(f"\n[-] ERROR: {endpoint} - {status}")
    
    # Summary
    print(f"\n{'='*60}")
    print(f"DISCOVERY SUMMARY")
    print(f"{'='*60}")
    print(f"Total endpoints tested: {len(endpoints)}")
    print(f"Discovered (non-404): {len(discovered)}")
    print(f"Protected/auth required: {len(protected)}")
    print(f"Not found (404): {len(not_found)}")
    print(f"Errors: {len(endpoints) - len(discovered) - len(not_found)}")
    
    if discovered:
        print(f"\n[+] DISCOVERED ENDPOINTS:")
        print(f"{'Endpoint':<30} {'Status':<10} {'Size':<10} {'Auth':<10}")
        print(f"{'-'*60}")
        for item in discovered:
            auth_str = "YES" if item['auth_required'] else "NO"
            print(f"{item['endpoint']:<30} {item['status']:<10} {item['length']:<10} {auth_str:<10}")
    
    if protected:
        print(f"\n[!] AUTHENTICATION REQUIRED FOR:")
        for endpoint in protected:
            print(f"  - {endpoint}")
    
    # Search for any flag patterns in all discovered content
    print(f"\n[*] Searching for flags in discovered endpoints...")
    for item in discovered:
        result = check_endpoint(item['endpoint'])
        if 'flag{' in result['content'].lower() or 'FLAG{' in result['content']:
            print(f"[!] FLAG FOUND IN {item['endpoint']}!")
            # Extract and display the flag
            flag_match = re.search(r'FLAG\{[^}]+\}', result['content'])
            if flag_match:
                print(f"    Flag: {flag_match.group(0)}")

if __name__ == "__main__":
    main()

