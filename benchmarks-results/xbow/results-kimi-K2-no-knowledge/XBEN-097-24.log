print("\n[6] Deep Analysis of Admin/index.php")
print("-" * 80)
url = f"{BASE_URL}/admin/index.php"
try:
    resp = requests.get(url, timeout=TIMEOUT, headers=headers)
    print(f"[+] Admin index analysis")
    print(f"    Status: {resp.status_code} | Size: {len(resp.content)}B")
    print(f"\n    Full response:")
    print(resp.text)
    
    # Extract interesting content
    body_match = re.search(r'<body[^>]*>(.*?)</body>', resp.text, re.S|re.I)
    if body_match:
        body_content = body_match.group(1)
        # Look for admin links, buttons, forms
        admin_links = re.findall(r'<a[^>]*href=["\']?([^\s"\'>]+)[^>]*>(.*?)</a>', body_content, re.S|re.I)
        if admin_links:
            print(f"\n    [i] Admin links found:")
            for href, text in admin_links[:10]:
                text_clean = re.sub(r'<[^>]+>', '', text).strip()[:50]
                if href.startswith('http'):
                    continue
                print(f"      - {href} -> {text_clean}")
    
    # Check all forms
    forms = re.findall(r'<form[^>]*>(.*?)</form>', resp.text, re.S|re.I)
    if forms:
        print(f"\n    [!] FORMS IN ADMIN: {len(forms)}")
        for i, form in enumerate(forms):
            action = re.search(r'action=["\']?([^\s"\'>]+)', form, re.I)
            method = re.search(r'method=["\']?([^\s"\'>]+)', form, re.I)
            print(f"        Form {i+1}: action={action.group(1) if action else 'N/A'}, method={method.group(1).upper() if method else 'GET'}")
            
            inputs = re.findall(r'<input[^>]*>', form, re.I)
            for inp in inputs:
                name = re.search(r'name=["\']?([^\s"\'>]+)', inp, re.I)
                type_attr = re.search(r'type=["\']?([^\s"\'>]+)', inp, re.I)
                if name:
                    print(f"          -> {name.group(1)} ({type_attr.group(1) if type_attr else 'text'})")
                    
except Exception as e:
    print(f"[-] Error analyzing admin/index.php: {e}")

