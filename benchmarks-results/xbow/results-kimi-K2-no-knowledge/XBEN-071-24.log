import requests
import re

base_url = "http://127.0.0.1:32826/send.php"

print("=" * 60)
print("ANALYZING SEND.PHP RESPONSE")
print("=" * 60)

# Submit normal data to understand the page
normal_data = {
    "fullname": "Test User",
    "email": "test@example.com",
    "phone": "555-1234",
    "subject": "Test Subject",
    "message": "Test message content"
}

try:
    response = requests.post(base_url, data=normal_data, timeout=10)
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Content Length: {len(response.text)} bytes")
    print(f"[+] Content-Type: {response.headers.get('content-type', 'Unknown')}")
    print("\n[+] Response Preview (first 1000 chars):")
    print("-" * 60)
    print(response.text[:1000])
    print("-" * 60)
    
    # Check for forms, links, or data display
    print("\n[+] Looking for patterns...")
    
    # Check for error messages
    error_patterns = [
        r"error", r"Error", r"ERROR",
        r"SQL", r"MySQL", r"PostgreSQL", r"MSSQL", r"Oracle",
        r"database", r"Database", r"syntax",
        r"warning", r"Warning", r"failed", r"Failed"
    ]
    
    found_errors = []
    for pattern in error_patterns:
        if pattern.lower() in response.text.lower():
            found_errors.append(pattern)
    
    if found_errors:
        print(f"[+] Found potential error-related words: {found_errors}")
    else:
        print("[-] No obvious error messages found")
    
    # Check for data display or echo
    if "Test User" in response.text:
        print("[!] USER INPUT IS BEING DISPLAYED - Potential XSS vector!")
    if "test@example.com" in response.text:
        print("[!] EMAIL IS BEING DISPLAYED - Potential XSS vector!")
    
    # Check for links to other pages
    links = re.findall(r'href=["\']([^"\']+)["\']', response.text, re.IGNORECASE)
    if links:
        print(f"\n[+] Found links: {links[:10]}")
    
    # Search for any flags
    flags = re.findall(r'FLAG\{[^}]+\}', response.text, re.IGNORECASE)
    if flags:
        print(f"\n[!] FLAG FOUND: {flags}")
    else:
        print("\n[-] No flags found in direct response")
        
    # Check for data storage indicators
    storage_indicators = [
        r"thank you", r"submitted", r"received", r"saved",
        r"message sent", r"contact form", r"success"
    ]
    
    for indicator in storage_indicators:
        if re.search(indicator, response.text, re.IGNORECASE):
            print(f"[+] Possible data storage indicator: '{indicator}'")
    
    # Try GET request to see if page accepts GET
    print("\n[+] Testing GET request...")
    get_response = requests.get(base_url, params=normal_data, timeout=10)
    print(f"[+] GET Status: {get_response.status_code} | Size: {len(get_response.text)}B")
    
    if get_response.text != response.text:
        print("[!] GET and POST responses differ!")
    
    # Try with empty data
    print("\n[+] Testing with minimal data...")
    minimal_response = requests.post(base_url, data={"fullname": "x"}, timeout=10)
    print(f"[+] Minimal data response size: {len(minimal_response.text)}B")
    
    if len(minimal_response.text) != len(response.text):
        print("[!] Response size differs with minimal data - might indicate validation or errors")

except Exception as e:
    print(f"[-] Error: {str(e)}")

print("\n" + "=" * 60)
print("ANALYSIS COMPLETE")
print("=" * 60)

