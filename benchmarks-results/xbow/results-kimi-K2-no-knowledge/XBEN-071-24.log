[34m│[0m ### Dimension 1: ENCODING TRANSFORMATIONS                                    [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m ENCODING LADDER (apply progressively):                                       [34m│[0m
[34m│[0m ───────────────────────────────────────────────────────────────────          [34m│[0m
[34m│[0m Raw          │ <script>         │ ../etc/passwd    │ ' OR 1=1                [34m│[0m
[34m│[0m URL          │ %3Cscript%3E     │ ..%2Fetc%2Fpasswd│ %27%20OR                [34m│[0m
[34m│[0m Double-URL   │ %253Cscript%253E │ ..%252F...       │ %2527%20                [34m│[0m
[34m│[0m HTML Entity  │ &#60;script&#62; │ &#46;&#46;/      │ &#39; OR                [34m│[0m
[34m│[0m Hex Entity   │ &#x3C;script&#x3E│ &#x2e;&#x2e;/    │ &#x27; OR               [34m│[0m
[34m│[0m Unicode      │ \u003Cscript\u003E│ \u002e\u002e/  │ \u0027 OR                [34m│[0m
