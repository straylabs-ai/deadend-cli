[34m│[0m ────────────────────────────────────────────────────────────────────         [34m│[0m
[34m│[0m Context    │ Alternatives                                                    [34m│[0m
[34m│[0m ───────────┼─────────────────────────────────────────────────────            [34m│[0m
[34m│[0m HTML       │ / (tag separator), TAB (%09), NEWLINE (%0a, %0d)                [34m│[0m
[34m│[0m            │ FORMFEED (%0c), NULL before space                               [34m│[0m
[34m│[0m SQL        │ /**/, %09, %0a, %0d, %0b, %a0 (nbsp), +, /*!*/                  [34m│[0m
