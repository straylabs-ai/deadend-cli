import requests
import socket
import sys
from urllib.parse import urlparse
print("[*] Starting network discovery for target application...")
print("[*] Checking common web application ports...\n")
ports_to_check = [80, 8000, 8080, 5000, 3000, 9000, 4200, 80]
target_host = "127.0.0.1"
successful_connections = []
for port in ports_to_check:
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(2)
        result = sock.connect_ex((target_host, port))
        if result == 0:
            print(f"[+] Port {port}: OPEN")
            successful_connections.append(port)
            try:
                http_url = f"http://{target_host}:{port}/index.php"
                response = requests.get(http_url, timeout=5)
                print(f"    HTTP GET to {http_url}: Status {response.status_code}")
                if response.status_code == 200:
                    print(f"    [+] Successfully connected to {http_url}")
                    base_info = f"Port: {port}, Status: {response.status_code}, Length: {len(response.text)}"
                    print(f"    Response: {base_info}")
            except Exception as e:
                print(f"    HTTP test failed: {e}")
        else:
            print(f"[-] Port {port}: Closed")
        sock.close()
    except Exception as e:
        print(f"[-] Port {port}: Error - {str(e)}")
print(f"\n{'='*60}")
print("SUMMARY:")
print(f"Open ports found: {successful_connections}")
if 80 in successful_connections:
    print("[+] Port 80 is open - recommend using http://127.0.0.1:80")
if 8000 in successful_connections:
    print("[+] Port 8000 is open - recommend using http://127.0.0.1:8000")
if 8080 in successful_connections:
    print("[+] Port 8080 is open - recommend using http://127.0.0.1:8080")
if 5000 in successful_connections:
    print("[+] Port 5000 is open - recommend using http://127.0.0.1:5000")
print(f"\n{len(successful_connections)} ports are accessible for testing.")
