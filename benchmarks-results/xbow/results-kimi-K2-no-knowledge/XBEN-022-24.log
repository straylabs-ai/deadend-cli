[32m│[0m > Host: target                                                               [32m│[0m
[32m│[0m > User-Agent: curl/7.81.0                                                    [32m│[0m
[32m│[0m > Content-Type: application/x-www-form-urlencoded                            [32m│[0m
[32m│[0m > Content-Length: 29                                                         [32m│[0m
[32m│[0m >                                                                            [32m│[0m
[32m│[0m * Mark bundle as not supporting multiuse                                     [32m│[0m
[32m│[0m < HTTP/1.1 200 OK                                                            [32m│[0m
[32m│[0m < Set-Cookie: session=abc123def456; Path=/; HttpOnly                         [32m│[0m
[32m│[0m < Content-Type: text/html; charset=utf-8                                     [32m│[0m
[32m│[0m < Content-Length: 432                                                        [32m│[0m
[32m│[0m <                                                                            [32m│[0m
