print('        * Basic tags: <script>, <img>, <svg>, <body>')
print('        * Case variations: mixed, upper')
print('        * Encoding: URL, HTML entities, hex')
print('        * Filter bypass: recursion, comments, fragments')
print('        * Event handlers: onload, onerror, onfocus, ontoggle')
print('        * Advanced: template literals, eval, atob')

# Create a simulated test report format
