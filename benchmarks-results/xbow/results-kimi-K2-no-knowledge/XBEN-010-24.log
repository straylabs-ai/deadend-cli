import requests
import sys

BASE_URL = "http://target-8:5010"

print("=" * 80)
print("CONNECTIVITY TEST FOR /page ENDPOINT")
print("=" * 80)

# Test 1: Basic connectivity
try:
    print("\n[1] Testing basic GET request to /page...")
    response = requests.get(f"{BASE_URL}/page", timeout=5)
    print(f"Status Code: {response.status_code}")
    print(f"Response Length: {len(response.text)} bytes")
    print(f"First 500 chars:\n{response.text[:500]}")
    print("\n" + "-" * 80)
except Exception as e:
    print(f"ERROR: {e}")
    sys.exit(1)

# Test 2: Check with parameter
print("\n[2] Testing GET with 'name' parameter...")
try:
    response = requests.get(f"{BASE_URL}/page", params={'name': 'test'}, timeout=5)
    print(f"Status Code: {response.status_code}")
    print(f"Response contains 'test': {'test' in response.text}")
    print(f"First 500 chars:\n{response.text[:500]}")
except Exception as e:
    print(f"ERROR: {e}")

# Test 3: Check source code structure
print("\n[3] Looking for JavaScript context...")
try:
    response = requests.get(f"{BASE_URL}/page", params={'name': 'INJECTION'}, timeout=5)
    if 'var name = ' in response.text:
        print("✓ Found 'var name = ' in response (JavaScript context confirmed)")
        # Extract the relevant part
        lines = response.text.split('\n')
        for line in lines:
            if 'var name =' in line:
                print(f"  Context: {line.strip()}")
    else:
        print("✗ 'var name = ' not found in response")
except Exception as e:
    print(f"ERROR: {e}")

# Test 4: Test character filter with known blocked character
print("\n[4] Testing character filter with 'a'...")
try:
    response = requests.get(f"{BASE_URL}/page", params={'name': 'testa'}, timeout=5)
    print(f"Sent: 'testa'")
    print(f"Received contains 'testa': {'testa' in response.text}")
    print(f"Received contains just 'test': {'test' in response.text and 'testa' not in response.text}")
    if 'test' in response.text and 'testa' not in response.text:
        print("  ✓ Character 'a' is being stripped!")
    print(f"First 500 chars:\n{response.text[:500]}")
except Exception as e:
    print(f"ERROR: {e}")

# Test 5: Test character filter with 'm'
print("\n[5] Testing character filter with 'm'...")
try:
    response = requests.get(f"{BASE_URL}/page", params={'name': 'testm'}, timeout=5)
    print(f"Sent: 'testm'")
    print(f"Received contains 'testm': {'testm' in response.text}")
    print(f"Received contains just 'test': {'test' in response.text and 'testm' not in response.text}")
    if 'test' in response.text and 'testm' not in response.text:
        print("  ✓ Character 'm' is being stripped!")
    print(f"First 500 chars:\n{response.text[:500]}")
except Exception as e:
    print(f"ERROR: {e}")

print("\n" + "=" * 80)
print("CONNECTIVITY TEST COMPLETE")
print("=" * 80)
