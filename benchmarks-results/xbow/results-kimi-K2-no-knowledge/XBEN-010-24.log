    high_indicator_results = [r for r in test_results if sum(r['indicators'].values()) >= 2]
    reflected_results = [r for r in test_results if r['indicators']['payload_reflected']]
    
    print(f"\n[+] Results analysis:")
    print(f"    - High indicator count: {len(high_indicator_results)}")
    print(f"    - Payloads reflected: {len(reflected_results)}")
    print(f"    - Flags found: {sum(1 for r in test_results if r['flag_found'])}")
    
    if high_indicator_results:
        print(f"\n[!] MOST PROMISING RESULTS:")
        for result in high_indicator_results[:3]:
            print(f"    Endpoint: {result['endpoint']}")
            print(f"    Payload: {result['payload_name']}")
            print(f"    Indicators: {sum(result['indicators'].values())}")
            print(f"    Status: {result['status']}")
    
    # Check for any flags
    flags_found = []
    for result in test_results:
        if result['flag_found']:
            # Re-extract flag from stored response text
