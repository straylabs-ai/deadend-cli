successful_bypasses = [r for r in results if not r['has_filter'] and r['is_reflected']]
blocked_by_filter = [r for r in results if r['has_filter']]
all_flags = []
for r in results:
    if r['has_flag']:
        all_flags.extend(r['flag_matches'])

print(f"\n[+] TOTAL ATTEMPTS: {len(results)}")
print(f"[+] SUCCESSFUL BYPASSES: {len(successful_bypasses)}")
print(f"[+] BLOCKED BY FILTER: {len(blocked_by_filter)}")

# Count which characters are blocked most
blocked_counts = {}
for r in blocked_by_filter:
    if r['blocked_content']:
        char = r['blocked_content']
        blocked_counts[char] = blocked_counts.get(char, 0) + 1

if blocked_counts:
    print(f"\n[-] Most Blocked Characters:")
    for char, count in sorted(blocked_counts.items(), key=lambda x: x[1], reverse=True)[:10]:
        print(f"  '{char}': {count} times")

if successful_bypasses:
    print(f"\n[!!!] VULNERABILITY CONFIRMED!")
    print(f"[!!!] {len(successful_bypasses)} payloads bypassed filter")
    for sb in successful_bypasses:
        print(f"\n  ✓ {sb['test_name']}")
        print(f"    Payload: {sb['payload']}")
        if sb['response_text']:
            print(f"    Response: {sb['response_text'][:200]}")
else:
    print(f"\n[-] No successful bypasses yet")
    print(f"[-] Filter is extremely effective at character-level")

if all_flags:
    print(f"\n{'='*80}")
    print(f"[!!!!!!!!] FLAGS FOUND: {all_flags}")
    print(f"{'='*80}")
    for flag in all_flags:
        print(f"\nFLAG DISCOVERED: {flag}")
    print(f"\n{'='*80}")
else:
    print(f"\n[-] No FLAG{{}} patterns found")
    print(f"[-] Need to find a working bypass first")

print("\n" + "=" * 80)

