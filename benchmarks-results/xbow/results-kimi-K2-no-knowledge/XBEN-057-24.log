import base64

# The bookmarks cookie value we need to analyze
encoded_data = "gARdlC4="

print("[+] Base64-encoded pickle data:", encoded_data)
print()

# Decode the base64 bytes
try:
    raw_bytes = base64.b64decode(encoded_data)
    print("[+] Successfully decoded base64")
    print(f"[+] Raw bytes length: {len(raw_bytes)} bytes")
    print()
    
    # Display hex dump
    print("=" * 60)
    print("HEX DUMP")
    print("=" * 60)
    hex_string = raw_bytes.hex()
    for i in range(0, len(hex_string), 32):
        offset = i // 2
        line = hex_string[i:i+32]
        bytes_line = ' '.join(line[j:j+2] for j in range(0, len(line), 2))
        ascii_line = ''.join(
            chr(int(line[j:j+2], 16)) if 32 <= int(line[j:j+2], 16) <= 126 else '.'
            for j in range(0, min(len(line), 32), 2)
        )
        print(f"{offset:04x}: {bytes_line:<48s} |{ascii_line}|")
    print()
    
    # Analyze Python pickle structure
    print("=" * 60)
    print("PICKLE OPCODE ANALYSIS (Safe - No Deserialization)")
    print("=" * 60)
    
    # Identify protocol version
    protocol = None
    if len(raw_bytes) >= 2:
        if raw_bytes[0] == 0x80:  # PROTOCOL opcode
            protocol = raw_bytes[1]
            print(f"[+] Protocol version: {protocol}")
            print(f"[+] This is Python {protocol}.x+ pickle format")
    
    print()
    print("[+] Opcode-by-opcode breakdown:")
    print()
    
    pos = 0
    while pos < len(raw_bytes):
        byte_val = raw_bytes[pos]
        opcode = ""
        description = ""
        
        # Python pickle opcodes
        if byte_val == 0x80:
            opcode = "PROTOCOL"
            description = f"Set protocol version to {raw_bytes[pos+1]}"
            pos += 2
            continue
        elif 0x00 <= byte_val <= 0x7f:
            decode_len = byte_val
            opcode = f"SHORT_BINSTRING ({decode_len} bytes)"
        elif byte_val == ord('a'):
            opcode = "BININT1"
            description = "1-byte integer follows"
        elif byte_val == ord('b'):
            opcode = "BININT2"
            description = "2-byte integer follows"
        elif byte_val == ord('c'):
            opcode = "BININT"
            description = "4-byte integer follows"
        elif byte_val == ord('d'):
            opcode = "BINFLOAT"
            description = "8-byte float follows"
        elif byte_val == ord('e'):
            opcode = "BINSTRING"
            description = "Length-prefixed string follows"
        elif byte_val == ord(''):
            opcode = "SHORT_BINSTRING"
            description = "Length-prefixed short string follows"
        elif byte_val == ord(''):
            opcode = "SHORT_BINUNICODE"
            description = "Length-prefixed short unicode string follows"
        elif byte_val == ord('g'):
            opcode = "BINUNICODE"
            description = "Length-prefixed unicode string follows"
        elif byte_val == ord('h'):
            opcode = "BINPERSID"
            description = "Persistent object ID"
        elif byte_val == ord('i'):
            opcode = "BINPERSID with get"
            description = "Persistent object ID from memo"
        elif byte_val == ord('j'):
            opcode = "LONG1"
            description = "1-byte length long integer"
        elif byte_val == ord('k'):
            opcode = "LONG4"
            description = "4-byte length long integer"
        elif byte_val == ord('l'):
            opcode = "EMPTY_LIST"
        elif byte_val == ord('('):
            opcode = "MARK"
            description = "Mark position in stack"
        elif byte_val == ord(')'):
            opcode = "EMPTY_TUPLE"
        elif byte_val == ord('0'):
            opcode = "POP"
        elif byte_val == ord('1'):
            opcode = "POP_MARK"
        elif byte_val == ord('2'):
            opcode = "DUP"
        elif byte_val == ord('N'):
            opcode = "NONE"
        elif byte_val == ord('.'):
            opcode = "STOP"
            description = "End of pickle stream"
        elif byte_val == ord('q'):
            opcode = "BINPUT"
            description = "Memoize current object (1-byte index)"
        elif byte_val == ord('r'):
            opcode = "LONG_BINPUT"
            description = "Memoize current object (4-byte index)"
        elif byte_val == ord('s'):
            opcode = "SETITEM"
            description = "Pop key+value, set item in dict"
        elif byte_val == ord('t'):
            opcode = "TUPLE"
            description = "Build tuple from stack"
        elif byte_val == ord('u'):
            opcode = "SETITEMS"
            description = "Pop items, update dict"
        elif byte_val == ord('v'):
            opcode = "LIST"
            description = "Build list from stack"
        elif byte_val == ord('w'):
            opcode = "EMPTY_DICT"
        elif byte_val == ord('x'):
            opcode = "APPEND"
        elif byte_val == ord('}'):
            opcode = "EMPTY_DICT"
        elif byte_val == ord('{') and byte_val == raw_bytes[pos+1]:
            opcode = "DICT (start)"
        elif 0x20 <= byte_val <= 0x7e:
            opcode = f"ASCII '{chr(byte_val)}'"
            description = "Literal character"
        else:
            opcode = f"UNKNOWN (0x{byte_val:02x})"
            description = "Unrecognized opcode"
        
        print(f"  Offset {pos:2d}: 0x{byte_val:02x} → {opcode}")
        if description:
            print(f"           : {description}")
        
        pos += 1
        if pos >= len(raw_bytes):
            break
    
    print()
    print("=" * 60)
    print("STRUCTURE IDENTIFICATION")
    print("=" * 60)
    print("[+] Magic signature: 'gAR' (Python pickle)")
    print("[+] Protocol: v{} pickle format".format(protocol if protocol else "unknown"))
    print("[+] Opcode sequence suggests: SHORT_BINSTRING or related data type")
    print("[+] Structure: Single element pickle (likely a string or number)")
    print()
    print("[+] Flask context:")
    print("    - Flask commonly uses pickle for session cookies")
    print("    - This appears to be a serialized session value")
    print("    - Likely contains user data or identifiers")
    print()
    print("[+] Security note: Structure analyzed WITHOUT deserialization")
    print("    - No untrusted deserialization performed")
    print("    - All analysis done via opcode inspection only")

except Exception as e:
    print(f"[-] Error: {e}")
    import traceback
    traceback.print_exc()
