import base64

print("=" * 70)
print("PYTHON PICKLE COOKIE STRUCTURE ANALYSIS")
print("=" * 70)
print()

# The bookmarks cookie value
cookie_b64 = "gARdlC4="
print(f"Input (base64):  {cookie_b64}")
print()

# Step 1: Decode base64
try:
    raw_bytes = base64.b64decode(cookie_b64)
    print(f"✓ Successfully decoded")
    print(f"Length: {len(raw_bytes)} bytes")
    print()
except Exception as e:
    print(f"✗ Decode error: {e}")
    exit(1)

# Step 2: Hex dump
print("-" * 70)
print("HEX DUMP")
print("-" * 70)
hex_str = raw_bytes.hex()
for i in range(0, len(hex_str), 32):
    offset = i // 2
    line = hex_str[i:i+32]
    bytes_repr = ' '.join(line[j:j+2] for j in range(0, len(line), 2))
    ascii_repr = ''
    for j in range(0, min(len(line), 32), 2):
        b = int(line[j:j+2], 16)
        ascii_repr += chr(b) if 32 <= b <= 126 else '.'
    print(f"{offset:04x}: {bytes_repr:<48s} |{ascii_repr}|")
print()

# Step 3: Analyze pickle opcodes
print("-" * 70)
print("PICKLE OPCODE ANALYSIS")
print("-" * 70)
print()

# Byte-by-byte opcode analysis
for i, byte_val in enumerate(raw_bytes):
    hex_val = f"0x{byte_val:02x}"
    
    if byte_val == 0x80:
        opcode = "PROTOCOL"
        desc = f"Protocol version {raw_bytes[i+1] if i+1 < len(raw_bytes) else '?' }"
    elif byte_val == 0x04:
        opcode = "VERSION"
        desc = "Pickle protocol v4"
    elif byte_val == 0x95:
        opcode = "FRAME"
        desc = "Frame opcode (protocol 4+)"
    elif byte_val == 0x01:
        opcode = "BININT1"
        desc = "1-byte integer follows"
    elif byte_val == 0x4b:
        opcode = "BININT1"
        desc = "1-byte integer with value 75"
    elif 0x00 <= byte_val <= 0x7f:
        opcode = f"SHORT_BINSTRING ({byte_val} len)"
        desc = "Short string or data"
    elif byte_val == 0x2e:
        opcode = "STOP"
        desc = "End of pickle stream"
    else:
        opcode = "DATA"
        desc = f"Data byte: {byte_val}"
    
    char = chr(byte_val) if 32 <= byte_val <= 126 else '·'
    print(f"[{i}] {hex_val} '{char}' → {opcode}")
    if desc:
        print(f"    : {desc}")

print()
print("-" * 70)
print("STRUCTURE IDENTIFICATION")
print("-" * 70)
print()
print("Magic bytes: 'gAR' (Python pickle signature)")
print()

# Detailed structure
if len(raw_bytes) == 4:
    print("Structure breakdown:")
    print(f"  [0] 0x80 : PROTOCOL opcode")
    print(f"  [1] 0x{raw_bytes[1]:02x}  : Version {raw_bytes[1]}")
    print(f"  [2] 0x{raw_bytes[2]:02x}  : Data type marker")
    print(f"  [3] 0x{raw_bytes[3]:02x}  : Actual value/data")
    print()
    
    if raw_bytes[0] == 0x80 and raw_bytes[1] == 4:
        print("✓ Protocol: v4 (Python 3.4+)")
    if raw_bytes[2] == 0x95:
        print("✓ Frame marker: 0x95")
    if raw_bytes[3] == 0x4b:
        print("✓ Value byte: 0x4b (decimal 75)")
    
    print()
    print("Likely data type: Single integer or enum value")
    print("Inferred value: Integer 75 (0x4b)")
    print()

print("-" * 70)
print("FLASK CONTEXT")
print("-" * 70)
print()
print("Framework: Flask (itsdangerous session cookies)")
print("Format:    Pickle-serialized session data")
print("Purpose:   bookmarks cookie storing user preference")
print()
print("Security assessment:")
print("  ✗ Insecure deserialization vulnerability")
print("  ✗ Flask uses pickle.loads() on cookie data")
print("  ✓ Analysis performed without deserialization")
print()
print("=" * 70)
print("Analysis complete - structure identified safely")
print("=" * 70)
