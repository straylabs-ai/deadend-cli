import base64
import sys

# The target base64 string from the bookmarks cookie
b64_data = "gARdlC4="

print("=== PICKLE SERIALIZATION ANALYSIS ===")
print(f"Original base64: {b64_data}")
print()

# Decode base64
try:
    decoded_bytes = base64.b64decode(b64_data)
    print(f"Decoded length: {len(decoded_bytes)} bytes")
    print()
    
    # Show hex dump
    print("=== HEX DUMP ===")
    hex_string = decoded_bytes.hex()
    for i in range(0, len(hex_string), 32):  # 16 bytes per line
        line = hex_string[i:i+32]
        # Format as pairs of hex bytes
        formatted = ' '.join(line[j:j+2] for j in range(0, len(line), 2))
        print(f"{formatted}")
    print()
    
    # Analyze pickle opcodes
    print("=== PICKLE OPCODE ANALYSIS ===")
    print("Python pickle opcodes (viewing only, NO deserializing):")
    
    # Show each byte position and its meaning
    for i, byte_val in enumerate(decoded_bytes):
        byte_hex = f"0x{byte_val:02x}"
        byte_char = chr(byte_val) if 32 <= byte_val <= 126 else '.'
        
        # Identify common pickle opcodes
        opcode_meaning = ""
        if byte_val == 0x80:
            opcode_meaning = "PROTOCOL (pickle format version)"
        elif byte_val == 0x02:
            opcode_meaning = "Version 2"
        elif byte_val == 0x03:
            opcode_meaning = "Version 3"
        elif byte_val == 0x04:
            opcode_meaning = "Version 4"
        elif byte_val == 0x05:
            opcode_meaning = "Version 5"
        elif byte_val == ord(''):
            opcode_meaning = "SHORT_BINUNICODE (short UTF-8 string)"
        elif byte_val == ord('q'):
            opcode_meaning = "BINPUT (memo index)"
        elif byte_val == ord(')'):
            opcode_meaning = "EMPTY TUPLE"
        elif byte_val == ord('N'):
            opcode_meaning = "NONE"
        elif byte_val == ord('.'):
            opcode_meaning = "STOP (end of pickle)"
        elif 0x20 <= byte_val <= 0x7e:
            opcode_meaning = f"ASCII '{byte_char}'"
        else:
            opcode_meaning = f"Numeric value {byte_val}"
        
        print(f"  [{i:2d}] {byte_hex} ({byte_char:>4s}) : {opcode_meaning}")
    
    print()
    print("=== STRUCTURE SUMMARY ===")
    print("Magic bytes: gAR (Python pickle signature)")
    print("- First byte 0x80 = PROTOCOL opcode")
    print("- Second byte    = Protocol version")
    print("- 'g' opcode suggests short unicode string or similar data type")
    print()
    print("Note: This is a compact pickle structure containing a single data element")
    print("      Safe analysis mode: examining opcodes without deserializing")
    print("      Flask backend commonly uses pickle for session cookies")

except Exception as e:
    print(f"Error decoding: {e}")
    sys.exit(1)

