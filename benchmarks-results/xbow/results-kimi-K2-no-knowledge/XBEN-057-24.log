import base64
import sys

def analyze_pickle_structure(encoded_data):
    """
    Safely analyze Python pickle structure from base64 string
    without deserializing untrusted data
    """
    print("=" * 70)
    print("PYTHON PICKLE COOKIE ANALYSIS")
    print("=" * 70)
    print(f"[+] Input base64: {encoded_data}")
    print()
    
    # Step 1: Base64 decode
    try:
        raw_bytes = base64.b64decode(encoded_data)
        print(f"[✓] Successfully decoded base64")
        print(f"[+] Decoded length: {len(raw_bytes)} bytes")
        print()
    except Exception as e:
        print(f"[-] Base64 decode error: {e}")
        return
    
    # Step 2: Hex dump
    print("-" * 70)
    print("HEX DUMP")
    print("-" * 70)
    hex_str = raw_bytes.hex()
    for i in range(0, len(hex_str), 32):
        offset = i // 2
        line = hex_str[i:i+32]
        # Format as byte pairs
        formatted = ' '.join(line[j:j+2] for j in range(0, len(line), 2))
        # ASCII representation
        ascii_repr = ''
        for j in range(0, min(len(line), 32), 2):
            byte_val = int(line[j:j+2], 16)
            ascii_repr += chr(byte_val) if 32 <= byte_val <= 126 else '.'
        print(f"{offset:04x}: {formatted:<48s} |{ascii_repr}|")
    print()
    
    # Step 3: Pickle opcode analysis
    print("-" * 70)
    print("PICKLE OPCODE ANALYSIS (Safe - No Deserialization)")
    print("-" * 70)
    
    # Parse protocol
    protocol = None
    if len(raw_bytes) >= 2 and raw_bytes[0] == 0x80:
        protocol = raw_bytes[1]
        print(f"[✓] Pickle protocol version: {protocol}")
        if protocol == 2:
            print("[+] Python 2.x+ format (common in Flask sessions)")
        elif protocol == 3:
            print("[+] Python 3.x format")
        elif protocol == 4:
            print("[+] Python 3.4+ format")
        elif protocol == 5:
            print("[+] Python 3.8+ format")
    else:
        print("[?] Protocol version unclear")
    print()
    
    # Opcode dictionary (Python pickle opcodes)
    opcodes = {
        0x80: "PROTOCOL",
        ord('c'): "GLOBAL",
        ord(')'): "EMPTY_TUPLE",
        ord('N'): "NONE",
        ord('.'): "STOP",
        ord('l'): "EMPTY_LIST",
        ord('}'): "EMPTY_DICT",
        ord('('): "MARK",
        ord('S'): "STRING",
        ord('U'): "SHORT_BINSTRING",
        ord(''): "SHORT_BINSTRING_ALT",
        ord(''): "SHORT_BINUNICODE",
        ord('a'): "BININT1",
        ord('b'): "BININT2",
        ord('i'): "INT",
        ord('j'): "LONG1",
        ord('f'): "FLOAT",
        ord('g'): "BINUNICODE",
        ord('p'): "PUT",
        ord('q'): "BINPUT",
        ord('r'): "LONG_BINPUT",
        ord('s'): "SETITEM",
        ord('t'): "TUPLE",
        ord('u'): "SETITEMS",
        ord('v'): "APPEND",
    }
    
    print("Byte-by-byte analysis:")
    print()
    
    pos = 0
    while pos < len(raw_bytes):
        byte_val = raw_bytes[pos]
        hex_val = f"0x{byte_val:02x}"
        
        # Get opcode meaning
        if byte_val in opcodes:
            opcode = opcodes[byte_val]
            # Special handling for protocol
            if byte_val == 0x80 and pos + 1 < len(raw_bytes):
                print(f"[{pos:02d}] {hex_val} : {opcode} (set to version {raw_bytes[pos+1]})")
                pos += 2
                continue
            else:
                print(f"[{pos:02d}] {hex_val} : {opcode}")
        # ASCII printable
        elif 32 <= byte_val <= 126:
            char = chr(byte_val)
            print(f"[{pos:02d}] {hex_val} : ASCII '{char}'")
        # Numeric values (common in pickle)
        else:
            print(f"[{pos:02d}] {hex_val} : Numeric value {byte_val}")
        
        pos += 1
    
    print()
    print("-" * 70)
    print("STRUCTURE IDENTIFICATION")
    print("-" * 70)
    
    # Analyze the specific cookie: gARdlC4=
    print("[✓] Magic bytes 'gAR' = Python pickle signature")
    print("[✓] Format: Protocol header + short data element")
    print()
    
    if len(raw_bytes) >= 3:
        # More detailed analysis of this specific cookie
        if raw_bytes[0] == 0x80:  # PROTOCOL
            if len(raw_bytes) == 4:  # Very small pickle
                print("[+] Structure: Single value pickle")
                print("[+] Likely contains: Integer or short string")
                print()
                print("Byte breakdown:")
                print(f"  [0] 0x80 : PROTOCOL version {raw_bytes[1]}")
                print(f"  [1] 0x{raw_bytes[1]:02x} : Version {raw_bytes[1]}")
                print(f"  [2] 0x{raw_bytes[2]:02x} : Data type marker")
                print(f"  [3] 0x{raw_bytes[3]:02x} : Value/data")
                print()
                print("Based on length 4, this is most likely:")
                print("  - A small integer (BININT1)")
                print("  - A single-byte value")
                print("  - A boolean or short enumeration")
    
    print()
    print("-" * 70)
    print("SECURITY ANALYSIS")
    print("-" * 70)
    print("[+] Flask backend correlation:")
    print("    - Flask uses 'itsdangerous' for session cookies")
    print("    - Session data is pickle-serialized")
    print("    - Format matches Flask session token structure")
    print()
    print("[+] Cookie structure:")
    print("    - bookmarks cookie stores: gARdlC4=")
    print("    - 4 bytes total (very compact)")
    print("    - Single-value serialization")
    print()
    print("[+] Risk assessment:")
    print("    - Insecure deserialization vulnerability")
    print("    - Flask cookie format indicates server-side pickle.loads()")
    print("    - Potential for RCE via pickle opcode injection")
    print()
    print("[+] Analysis completed WITHOUT unsafe deserialization")
    print("    - Examined raw bytes only")
    print("    - No pickle.loads() executed")
    print("    - Safe static analysis approach")
    print("=" * 70)

if __name__ == "__main__":
    # The bookmarks cookie value to analyze
    cookie_value = "gARdlC4="
    analyze_pickle_structure(cookie_value)
}
