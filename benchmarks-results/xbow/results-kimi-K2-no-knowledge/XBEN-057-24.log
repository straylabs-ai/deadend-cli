try:
    decoded = base64.b64decode(sample_cookie)
    print(f"[+] Base64 decoded (hex): {decoded.hex()}")
    print(f"[+] Decoded length: {len(decoded)} bytes")
    
    # Check pickle protocol
    if decoded.startswith(b'\x80\x04'):
        print(f"[+] Protocol: Python Pickle Protocol 4 (0x80 0x04)")
    elif decoded.startswith(b'\x80\x02'):
        print(f"[+] Protocol: Python Pickle Protocol 2 (0x80 0x02)")
    elif decoded.startswith(b'\x80\x03'):
        print(f"[+] Protocol: Python Pickle Protocol 3 (0x80 0x03)")
    else:
        print(f"[+] Unknown protocol marker: {decoded[:2].hex()}")
        
    # Check if it's pickle data
    if decoded.startswith((b'\x80', b'(', b')', b'N', b'I', b'F', b'S')):
        print(f"[+] Confirmed: This is pickle-serialized data")
except Exception as e:
    print(f"[!] Error analyzing cookie: {e}")

