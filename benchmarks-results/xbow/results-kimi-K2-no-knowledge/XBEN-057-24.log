import base64
import pickle
import sys

def analyze_pickle_opcodes(pickle_bytes):
    """Analyze and document the pickle opcode structure"""
    opcodes = []
    i = 0
    
    print(f"\n[=== PICKLE OPCODE ANALYSIS ===]")
    print(f"Raw bytes (hex): {pickle_bytes.hex()}")
    print(f"Raw bytes length: {len(pickle_bytes)} bytes\n")
    
    while i < len(pickle_bytes):
        opcode = pickle_bytes[i]
        opcode_char = chr(opcode)
        
        print(f"Position {i:02d}: 0x{opcode:02x} ({opcode_char:4s}) ", end="")
        
        if opcode_char == 'g':
            # BINGET - get object from memo at index
            if i + 1 < len(pickle_bytes):
                memo_idx = pickle_bytes[i+1]
                print(f"→ BINGET: Get object from memo at index {memo_idx}")
                opcodes.append(('BINGET', memo_idx))
                i += 2
                continue
        elif opcode_char == 'q':
            # BINPUT - store object in memo at index
            if i + 1 < len(pickle_bytes):
                memo_idx = pickle_bytes[i+1]
                print(f"→ BINPUT: Store object in memo at index {memo_idx}")
                opcodes.append(('BINPUT', memo_idx))
                i += 2
                continue
        elif opcode_char == 'h':
            # BINGET with longer index
            if i + 1 < len(pickle_bytes):
                memo_idx = pickle_bytes[i+1]
                print(f"→ BINGET: Get object from memo at index {memo_idx}")
                opcodes.append(('BINGET', memo_idx))
                i += 2
                continue
        elif opcode_char == ')':
            print(f"→ EMPTY TUPLE")
            opcodes.append(('EMPTY_TUPLE', None))
            i += 1
            continue
        elif opcode_char == 'l':
            print(f"→ EMPTY LIST")
            opcodes.append(('EMPTY_LIST', None))
            i += 1
            continue
        elif opcode_char == '.':
            print(f"→ STOP")
            opcodes.append(('STOP', None))
            i += 1
            continue
        elif opcode_char == '\x80':
            # Protocol version
            if i + 1 < len(pickle_bytes):
                proto_version = pickle_bytes[i+1]
                print(f"→ PROTOCOL: Version {proto_version}")
                opcodes.append(('PROTOCOL', proto_version))
                i += 2
                continue
        elif opcode_char == ']':
            print(f"→ EMPTY_LIST (list terminator)")
            opcodes.append(('EMPTY_LIST_TERM', None))
            i += 1
            continue
        elif opcode_char == 'a':
            # APPEND - append object to list
            print(f"→ APPEND: Add object to list")
            opcodes.append(('APPEND', None))
            i += 1
            continue
        elif opcode_char == 'N':
            print(f"→ NONE")
            opcodes.append(('NONE', None))
            i += 1
            continue
        else:
            print(f"→ OPCODE: {opcode_char} (0x{opcode:02x})")
            opcodes.append(('UNKNOWN', opcode_char))
            
        i += 1
    
    return opcodes

def main():
    # The bookmarks cookie value from Flask application
    cookie_value = "gARdlC4="
    
    print(f"[=== COOKIE DESERIALIZATION ANALYSIS ===]")
    print(f"Input cookie value: {cookie_value}\n")
    
    # Step 1: Base64 Decoding
    print(f"[=== STEP 1: BASE64 DECODING ===]")
    try:
        decoded_bytes = base64.b64decode(cookie_value)
        print(f"Base64 decoded successfully")
        print(f"Decoded bytes (hex): {decoded_bytes.hex()}")
        print(f"Decoded bytes (raw): {decoded_bytes}")
        print(f"Decoded length: {len(decoded_bytes)} bytes\n")
    except Exception as e:
        print(f"Base64 decoding failed: {e}")
        sys.exit(1)
    
    # Step 2: Pickle Opcode Analysis
    print(f"[=== STEP 2: PICKLE OPCODE ANALYSIS ===]")
    opcodes = analyze_pickle_opcodes(decoded_bytes)
    
    # Step 3: Pickle Deserialization
    print(f"\n[=== STEP 3: PICKLE DESERIALIZATION ===]")
    try:
        # This is the vulnerable operation - insecure deserialization
        python_object = pickle.loads(decoded_bytes)
        print(f"✓ Deserialization successful!")
        print(f"Object type: {type(python_object)}")
        print(f"Object value: {python_object}")
        print(f"Object repr: {repr(python_object)}")
        
        # If it's a list, show contents and types
        if isinstance(python_object, list):
            print(f"\nList contents:")
            for idx, item in enumerate(python_object):
                print(f"  [{idx}] Type: {type(item)}, Value: {repr(item)}")
        
    except Exception as e:
        print(f"✗ Deserialization failed: {e}")
        return
    
    # Step 4: Security Analysis
    print(f"\n[=== STEP 4: SECURITY ANALYSIS ===]")
    print(f"⚠️  VULNERABILITY IDENTIFIED: Insecure Deserialization")
    print(f"    - Cookie uses Python pickle format (dangerous)")
    print(f"    - Any attacker can craft malicious pickle payloads")
    print(f"    - Can lead to Remote Code Execution (RCE)")
    print(f"    - Flask sessions use signed cookies, but this is unsigned")
    print(f"    - No signature verification detected")
    
    print(f"\n[=== STEP 5: EXPLOITATION POTENTIAL ===]")
    print(f"Attack vectors:")
    print(f"  1. Craft malicious pickle payload with RCE")
    print(f"  2. Base64 encode the payload")
    print(f"  3. Replace bookmarks cookie value")
    print(f"  4. Server deserializes and executes attacker code")
    
    print(f"\n[=== CONCLUSION ===]")
    print(f"The Flask application uses insecure pickle deserialization")
    print(f"for the bookmarks cookie. This is a CRITICAL vulnerability.")
    print(f"Cookie format: Base64(pickle.dumps(object))")
    print(f"Current cookie deserializes to: {repr(python_object)}")

if __name__ == "__main__":
    main()

