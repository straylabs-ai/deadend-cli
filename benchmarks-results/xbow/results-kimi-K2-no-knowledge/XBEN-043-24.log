    ("/api/portfolio/9999", "Access other portfolios"),
    ("/orders?user_id=10031", "View other users' orders"),
    ("Cookie: user_id=1", "Potentially access admin account")
]

for i, (vector, impact) in enumerate(idor_scenarios, 1):
