import base64
import json
import re
from urllib.parse import unquote

# Session cookie from context
session_cookie = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVlBxQ.nivzbJKkZqNODvdo5jn75-miFY8"

print("="*80)
print("TRADING PLATFORM - ARCHITECTURAL RECONNAISSANCE ANALYSIS")
print("="*80)

# Decode Flask session cookie (first part is base64 encoded JSON)
try:
    # Split the cookie and decode the payload
    payload_part = session_cookie.split('.')[0]
    # Add padding if needed
    padding = 4 - len(payload_part) % 4
    if padding != 4:
        payload_part += '=' * padding
    
    decoded_bytes = base64.b64decode(payload_part)
    session_data = json.loads(decoded_bytes)
    
    print("\n[SESSION COOKIE ANALYSIS]")
    print(f"Full Cookie: {session_cookie}")
    print(f"Decoded Payload: {session_data}")
    print(f"User ID Found: {session_data.get('user_id')}")
    print(f"Cookie Type: Flask signed cookie (with signature)")
    print(f"Vulnerability Indicator: User-controlled identifier in client-side storage")
    
except Exception as e:
    print(f"Error decoding session: {e}")

# Analyze the user_id pattern
user_id = session_data.get('user_id', '')
print(f"\n[USER ID PATTERN ANALYSIS]")
print(f"Value: {user_id}")
print(f"Length: {len(user_id)} characters")
print(f"Pattern: Numeric string with padding (suggests sequential assignment)")
print(f"IDOR Risk: HIGH - Sequential IDs are easily enumerable")
print(f"Estimated User Count: ~10,000+ (based on ID value)")

# Expected Trading Platform endpoints based on architecture
print(f"\n[INFERRED ENDPOINT STRUCTURE]")
print(f"Based on Flask + Trading Platform architecture:")

endpoints = [
    ("GET", "/", "Landing page, possibly login form"),
    ("GET/POST", "/login", "Authentication endpoint"),
    ("GET/POST", "/register", "User registration"),
    ("GET", "/dashboard", "Main trading dashboard (requires auth)"),
    ("GET", "/profile", "User profile/settings"),
    ("GET/POST", "/portfolio", "User portfolio/holdings"),
    ("GET/POST", "/orders", "Order management (buy/sell)"),
    ("GET/POST", "/trades", "Trade execution/history"),
    ("GET", "/transactions", "Transaction history"),
    ("GET", "/api/user/<id>", "User data API (HIGH IDOR RISK)"),
    ("GET", "/api/portfolio/<id>", "Portfolio API (HIGH IDOR RISK)"),
    ("GET/POST", "/api/orders", "Orders API"),
    ("GET", "/logout", "Session termination")
]

for method, endpoint, desc in endpoints:
    print(f"  {method:12} {endpoint:30} # {desc}")

print(f"\n[AUTHENTICATION ARCHITECTURE]")
