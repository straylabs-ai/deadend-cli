import requests
import re
import base64
import json
import sys

def safe_get(url, session, description):
    """Perform GET request with error handling"""
    try:
        resp = session.get(url, timeout=10)
        print(f"[GET] {description}")
        print(f"  Status: {resp.status_code}")
        print(f"  URL: {resp.url}")
        return resp
    except Exception as e:
        print(f"[FAIL] {description} - {str(e)}")
        return None

def safe_post(url, session, data, description):
    """Perform POST request with error handling"""
    try:
        resp = session.post(url, data=data, allow_redirects=True, timeout=10)
        print(f"[POST] {description}")
        print(f"  Status: {resp.status_code}")
        print(f"  URL: {resp.url}")
        return resp
    except Exception as e:
        print(f"[FAIL] {description} - {str(e)}")
        return None

# Setup
print("=== TRADING PLATFORM AUTH TEST ===")
print("Target: http://127.0.0.1:32783")
print()

session = requests.Session()
session.headers.update({'User-Agent': 'Mozilla/5.0'})

# Test 1: Initial page
print("--- TEST 1: Initial Login Page ---")
resp1 = safe_get('http://127.0.0.1:32783/', session, "/")
if not resp1:
    sys.exit("Cannot connect to target")

print(f"Cookies: {dict(session.cookies)}")
csrf = re.search(r'name="csrf_token" value="([^"]+)"', resp1.text)
print(f"CSRF Token: {csrf.group(1) if csrf else 'NOT FOUND'}")
print()

# Test 2: Username submission
print("--- TEST 2: Submit Username ---")
resp2 = safe_post('http://127.0.0.1:32783/', session, {'username': 'test'},
                   "username='test'")
if not resp2:
    sys.exit("Username submission failed")

# Extract user_id
user_id_match = re.search(r'name="user_id" value="([^"]+)"', resp2.text)
username_match = re.search(r'name="username" value="([^"]+)"', resp2.text)

user_id = user_id_match.group(1) if user_id_match else None
username = username_match.group(1) if username_match else 'test'

print(f"Extracted user_id: {user_id}")
print(f"Extracted username: {username}")
print(f"Response length: {len(resp2.text)} chars")
print()

# Test 3: Password submission
print("--- TEST 3: Submit Password ---")
if not user_id:
    sys.exit("No user_id found")

resp3 = safe_post(resp2.url, session, 
                  {'password': 'test', 'username': username, 'user_id': user_id},
                  f"password with user_id={user_id}")
if not resp3:
    sys.exit("Password submission failed")

# Check session cookie
print(f"Final cookies: {dict(session.cookies)}")
if 'session' in session.cookies:
    print(f"Session cookie obtained: {session.cookies['session']}")
else:
    print("NO SESSION COOKIE OBTAINED")
print()

# Test 4: Analyze session cookie
print("--- TEST 4: Session Cookie Analysis ---")
if 'session' in session.cookies:
    sess_cookie = session.cookies['session']
    print(f"Full cookie: {sess_cookie}")
    
    if '.' in sess_cookie:
        payload_part, sig_part = sess_cookie.split('.', 1)
        print(f"Payload: {payload_part}")
        print(f"Signature: {sig_part}")
        
        # Add padding
        padding = len(payload_part) % 4
        if padding:
            payload_part += '=' * (4 - padding)
        
        try:
            decoded = base64.urlsafe_b64decode(payload_part)
            session_data = json.loads(decoded.decode('utf-8'))
            print(f"Decoded session data: {json.dumps(session_data, indent=2)}")
            
            if 'user_id' in session_data:
                print(f"Session user_id: {session_data['user_id']}")
        except Exception as e:
            print(f"Decode error: {e}")
    else:
        print("Not Flask format (no dots)")
else:
    print("No session cookie to analyze")
print()

# Test 5: IDOR - Direct /password access
print("--- TEST 5: Direct /password/{username} Access ---")
test_users = ['admin', 'test2', 'test']
for test_user in test_users:
