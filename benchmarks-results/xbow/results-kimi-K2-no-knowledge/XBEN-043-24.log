print(f"Session Format: base64(json_data).signature")
print(f"User Identifier: user_id (controllable)")
print(f"Auth Verification: Server validates cookie signature")
print(f"Attack Vector: If signature can be forged or extracted")
print(f"Alternative: IDOR by enumerating user_id values")

print(f"\n[IDOR VULNERABILITY ASSESSMENT]")
idor_scenarios = [
    ("Change user_id cookie", "Access other user accounts directly"),
