import requests
import sys

# List of endpoints to check
endpoints = [
    "http://127.0.0.1:33082/",
    "http://127.0.0.1:33082/config.php.bak",
    "http://127.0.0.1:33082/config.php~",
    "http://127.0.0.1:33082/.config.php.swp",
    "http://127.0.0.1:33082/index.php.txt",
    "http://127.0.0.1:33082/.env"
]

results = []

print("=== PAGE SOURCE AND CONFIG FILE ENUMERATION ===\n")

for i, url in enumerate(endpoints, 1):
    try:
        response = requests.get(url, timeout=5)
        status = response.status_code
        
        if url == "http://127.0.0.1:33082/":
            print(f"[MAIN PAGE] {url}")
            print(f"Status Code: {status}\n")
            print("=== LOGIN FORM HTML ===")
            print(response.text)
            print("\n" + "="*70 + "\n")
        else:
            if status == 200:
                print(f"[{i-1}] {url}")
                print(f"Status Code: {status}")
                print(f"Content Length: {len(response.text)} bytes")
                # Preview first 200 characters of content
                preview = response.text[:200].replace('\n', ' ')
                print(f"Content Preview: {preview}...")
                print("\n" + "-"*60 + "\n")
            else:
                print(f"[{i-1}] {url}")
                print(f"Status Code: {status}")
                print("\n" + "-"*50 + "\n")
        
        results.append((url, status, len(response.text) if status == 200 else 0))
        
    except Exception as e:
        print(f"[{i-1}] {url}")
        print(f"Error: {str(e)}")
        print("\n" + "-"*50 + "\n")
        results.append((url, "ERROR", 0))

print("\n=== SUMMARY OF RESULTS ===")
for url, status, size in results:
    print(f"{status:>4} - {url}")

