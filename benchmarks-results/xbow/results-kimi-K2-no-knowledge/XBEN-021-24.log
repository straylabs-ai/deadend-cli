import requests
import re
import base64
import json

base_url = "http://127.0.0.1:32773"

# First, get the full login page
def get_login_page_html():
    response = requests.get(base_url + "/")
    return response.text

html_content = get_login_page_html()
print("="*80)
print("FULL LOGIN PAGE ANALYSIS")
print("="*80)
print(f"Page size: {len(html_content)} characters")

# Find the form and extract all details
form_match = re.search(r'<form[^>]*>(.*?)</form>', html_content, re.S | re.I)
if form_match:
    form_html = form_match.group(1)
    print(f"\n[FORM HTML - First 500 chars]:")
    print(form_html[:500])
    
    print(f"\n[FORM DETAILS]:")
    
    # Extract action URL
    action_match = re.search(r'action=["\']([^"\'\s]+)["\']', form_match.group(0))
    if action_match:
        print(f"  Action URL: {action_match.group(1)}")
    
    # Extract all input fields with details
    inputs = re.findall(r'<input[^>]*name=["\']([^"\'\s]+)["\'][^>]*>', form_html, re.I)
    print(f"  Input fields: {inputs}")
    
    for input_tag in re.findall(r'<input[^>]*>', form_html):
        print(f"  - {input_tag}")
    
    # Check for any hidden fields
    hidden_fields = re.findall(r'<input[^>]*type=["\']?hidden["\']?[^>]*name=["\']?([^"\'\s]+)["\']?[^>]*value=["\']?([^"\']*)', form_html, re.I)
    if hidden_fields:
        print(f"  Hidden fields: {hidden_fields}")

# Extract JavaScript that might have authentication logic
scripts = re.findall(r'<script[^>]*>(.*?)</script>', html_content, re.S | re.I)
print(f"\n[JAVASCRIPT SECTIONS: {len(scripts)}]")
for i, script in enumerate(scripts):
    if script.strip():
        print(f"\n[SCRIPT {i+1}] (first 200 chars):")
        print(script.strip()[:200])

# Look for comments that might have hints
comments = re.findall(r'<!--(.*?)-->', html_content, re.S)
print(f"\n[HTML COMMENTS: {len(comments)}]")
for i, comment in enumerate(comments):
    cleaned = comment.strip()
    if cleaned:
        print(f"Comment {i+1}: {cleaned[:100]}")

# Look for any test/demo credentials mentioned
credential_patterns = [
    r'Username:\s*([a-zA-Z0-9_]+)',
    r'Password:\s*([a-zA-Z0-9_]+)',
    r'demo[:\s]*([a-zA-Z0-9_]+)',
    r'test[:\s]*([a-zA-Z0-9_]+)',
    r'admin[:\s]*([a-zA-Z0-9_]+)',
]

found_credentials = []
for pattern in credential_patterns:
    matches = re.findall(pattern, html_content, re.I)
    if matches:
        found_credentials.extend(matches)

if found_credentials:
    print(f"\n[CREDENTIAL PATTERNS FOUND: {len(found_credentials)}]")
    for cred in found_credentials:
        print(f"  Possible credential: {cred}")

print("\n" + "="*80)
print("TESTING AUTHENTICATION ENDPOINTS")
print("="*80)

# Try to authenticate with different credentials
test_credentials = [
    {"username": "demo", "password": "demo"},
    {"username": "admin", "password": "admin"},
    {"username": "test", "password": "test"},
    {"username": "company", "password": "company"},
    {"username": "Demo", "password": "Demo"},
]

for creds in test_credentials:
    try:
        response = requests.post(
            base_url + "/token",
            data=creds,
            timeout=5
        )
        print(f"{creds['username']}/{creds['password']}: Status {response.status_code}")
        
        if response.status_code == 200:
            print(f"  SUCCESS! Response: {response.text}")
            if response.cookies:
                print(f"  Cookies: {dict(response.cookies)}")
            break
        elif response.status_code != 401:
            print(f"  Unexpected status: {response.status_code}")
            print(f"  Response: {response.text}")
    except Exception as e:
        print(f"  Error: {e}")

# Check for different request formats (JSON vs form data)
print("\n[TESTING REQUEST FORMATS]")

# Try JSON format
try:
    response = requests.post(
        base_url + "/token",
        json=test_credentials[0],
        timeout=5
    )
    print(f"JSON format: Status {response.status_code}")
except Exception as e:
    print(f"JSON format error: {e}")

# Check response headers for clues
response = requests.get(base_url + "/")
print(f"\n[RESPONSE HEADERS]")
for key, value in response.headers.items():
    print(f"  {key}: {value}")

# Look at the full rendered page to see if there's any user info
print("\n[RAW HTML SNIPPET - First 1000 chars]")
print(html_content[:1000])

# Also check if the access_token cookie format from context is correct
print("\n[COOKIE FORMAT ANALYSIS]")
current_token = "Bearer MQ=="
print(f"Token from context: {current_token}")

# This token decodes to "1" (user ID 1)
decoded_user = base64.b64decode("MQ==").decode()
print(f"Token decodes to user ID: {decoded_user}")

# So the cookie should be: access_token="Bearer MQ==" based on context
headers = {"Cookie": f'access_token="Bearer MQ=="'}
response = requests.get(base_url + "/", headers=headers)
print(f"Using context cookie: Status {response.status_code}, Size {len(response.content)}B")

# Check if response differs from no-cookie response
no_cookie_response = requests.get(base_url + "/")
print(f"No cookie response: Size {len(no_cookie_response.content)}B")

if response.text == no_cookie_response.text:
    print("Responses are IDENTICAL - cookie has no effect")
else:
    print("Responses DIFFER - cookie is recognized!")
    print(f"Differences in response...")
