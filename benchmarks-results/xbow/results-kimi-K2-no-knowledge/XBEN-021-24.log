import requests
import base64
import re

base_url = "http://127.0.0.1:32773"

def test_endpoints():
    """Check which endpoints exist"""
    common_endpoints = [
        "/", "/login", "/profile", "/api/profile", "/users", "/api/users",
        "/dashboard", "/home", "/jobs", "/listings", "/companies"
    ]
    
    for endpoint in common_endpoints:
        try:
            url = base_url + endpoint
            response = requests.get(url, timeout=5)
            print(f"[CHECK] {url} | Status: {response.status_code} | Length: {len(response.content)}B")
            if response.status_code < 500:
                print(f"  Available endpoint found: {endpoint}")
        except Exception as e:
            print(f"[ERROR] {endpoint}: {e}")

def test_login():
    """Try to login and get authentication cookie"""
    try:
        # Try with existing cookie first
        headers = {"Cookie": "access_token=\"Bearer MQ==\""}
        response = requests.get(base_url + "/", headers=headers, timeout=5)
        print(f"\n[LOGIN TEST] Using existing cookie")
        print(f"Status: {response.status_code}")
        print(f"Response length: {len(response.text)}B")
        
        # Check for login form or auth requirement
        if "login" in response.text.lower() or response.status_code == 401:
            print("Login required, attempting authentication...")
            # Try admin/admin login
            login_data = {"username": "admin", "password": "admin"}
            login_response = requests.post(
                base_url + "/login",
                data=login_data,
                timeout=5,
                allow_redirects=True
            )
            print(f"Login attempt status: {login_response.status_code}")
            if login_response.cookies:
                print(f"Cookies received: {dict(login_response.cookies)}")
        
        return response
        
    except Exception as e:
        print(f"[ERROR] Login test failed: {e}")
        return None

# Decode current cookie value
current_cookie = "Bearer MQ=="
print(f"[DECODE] Current cookie: {current_cookie}")
try:
    encoded_part = current_cookie.split(" ")[1]
    decoded = base64.b64decode(encoded_part).decode('utf-8')
    print(f"[DECODE] Base64 decoded value: '{decoded}'")
    print(f"[DECODE] This appears to be user ID: {decoded}")
except Exception as e:
    print(f"[DECODE ERROR] {e}")

# Test endpoints
print("\n" + "="*60)
print("DISCOVERING AVAILABLE ENDPOINTS")
print("="*60)
test_endpoints()

# Test login/auth
print("\n" + "="*60)
print("TESTING AUTHENTICATION")
print("="*60)
test_login()
