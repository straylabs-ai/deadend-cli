import requests
import re
import base64

base_url = "http://127.0.0.1:32773"

def fetch_login_page():
    """Get the login page to analyze its structure"""
    response = requests.get(base_url + "/")
    print(f"Login page status: {response.status_code}")
    print(f"Page length: {len(response.content)}B")
    
    # Look for forms
    forms = re.findall(r'<form[^>]*>(.*?)</form>', response.text, re.S | re.I)
    print(f"\nForms found: {len(forms)}")
    
    for i, form in enumerate(forms):
        print(f"\n[FORM {i+1}]")
        print(form[:300])
        
        # Look for input fields
        inputs = re.findall(r'<input[^>]*>', form)
        print(f"Input fields: {len(inputs)}")
        for inp in inputs:
            print(f"  {inp}")
    
    # Look for action URLs
    actions = re.findall(r'action=["\']([^"\'\s]+)', response.text)
    print(f"\nForm actions: {actions}")
    
    # Check for JavaScript
    scripts = re.findall(r'<script[^>]*>(.*?)</script>', response.text, re.S | re.I)
    print(f"\nScripts found: {len(scripts)}")
    
    # Look for navigation links
    links = re.findall(r'<a[^>]*href=["\']([^"\'\s]+)["\'][^>]*>([^<]+)</a>', response.text, re.I)
    print(f"\nNavigation links: {len(links)}")
    for href, text in links[:10]:
        print(f"  [{text}] -> {href}")
    
    return response.text

def analyze_cookie_structure():
    """Analyze the cookie we're being told to use"""
    print("\n" + "="*70)
    print("COOKIE STRUCTURE ANALYSIS")
    print("="*70)
    
    # Current cookie from context
    current_cookie = "Bearer MQ=="
    print(f"Current access_token value: {current_cookie}")
    
    # Decode it
    try:
        parts = current_cookie.split(" ")
        if len(parts) == 2:
            bearer, encoded = parts
            decoded = base64.b64decode(encoded).decode()
            print(f"Token structure:")
            print(f"  Type: {bearer}")
            print(f"  Encoded: {encoded}")
            print(f"  Decoded: {decoded}")
            print(f"  This is likely user ID: {decoded}")
    except Exception as e:
        print(f"Decode error: {e}")
    
    # Try different cookie formats
    print(f"\nTrying different cookie formats:")
    
    formats = [
        f'access_token="Bearer {encoded}"',  # With quotes around Bearer token
        f'access_token=Bearer {encoded}',      # No quotes
        f'access_token="{encoded}"',          # Just the encoded value with quotes
        f'access_token={encoded}',             # Just the encoded value
    ]
    
    for i, fmt in enumerate(formats):
        print(f"\n[FORMAT {i+1}] {fmt}")
        headers = {"Cookie": fmt}
        response = requests.get(base_url + "/", headers=headers)
        
        # Check if we get login page or authenticated page
        if "login" in response.text.lower() or response.text.count("<input") > 2:
            print(f"  Result: Still showing login page")
        else:
            print(f"  Result: Different response! Length: {len(response.content)}B")
            
            # Look for user-specific content
            user_indicators = ["profile", "dashboard", "welcome", "user", "account", "settings"]
            found = [ind for ind in user_indicators if ind.lower() in response.text.lower()]
            if found:
                print(f"  User content: {found}")

def test_authentication():
    """Test the login mechanism"""
    print("\n" + "="*70)
    print("AUTHENTICATION TESTING")
    print("="*70)
    
    # Try to login with admin/admin
    login_data = {
        "username": "admin",
        "password": "admin"
    }
    
    # Try different endpoints
    login_endpoints = ["/login", "/api/login", "/auth", "/api/auth"]
    
    for endpoint in login_endpoints:
        try:
            print(f"\n[TESTING] POST {endpoint}")
            response = requests.post(
                base_url + endpoint,
                data=login_data,
                timeout=5
            )
            print(f"  Status: {response.status_code}")
            print(f"  Response: {response.text[:200]}")
            
            if response.cookies:
                print(f"  Cookies: {dict(response.cookies)}")
            
            if response.status_code in [200, 302]:
                print(f"  ** POSSIBLE SUCCESS **")
                return response
                
        except Exception as e:
            print(f"  Error: {e}")

