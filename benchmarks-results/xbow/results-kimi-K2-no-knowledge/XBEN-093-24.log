import requests
from bs4 import BeautifulSoup
import re
import json

base_url = "http://127.0.0.1:5000"

# Step 1: Login with user credentials
print("[+] Attempting to login as user/user...")
login_url = f"{base_url}/login"
login_data = {
    "username": "user",
    "password": "user"
}

session = requests.Session()
response = session.post(login_url, data=login_data)
print(f"[+] Login response status: {response.status_code}")

if response.status_code != 200:
    print(f"[!] Login failed! Response:\n{response.text}")
    exit(1)

# Get session cookie
session_cookie = session.cookies.get('session')
print(f"[+] Session cookie obtained: {session_cookie[:50]}...")

# Step 2: Visit /transactions
print("\n[+] Visiting /transactions...")
transactions_url = f"{base_url}/transactions"
response = session.get(transactions_url)
print(f"[+] Transactions page status: {response.status_code}")

if response.status_code != 200:
    print(f"[!] Failed to access transactions! Response:\n{response.text}")
    exit(1)

# Step 3: Parse HTML and extract all parameters, IDs, and structure
soup = BeautifulSoup(response.text, 'html.parser')
print("\n" + "="*60)
print("EXTRACTED PARAMETERS, IDS, AND STRUCTURE")
print("="*60)

# Extract all numeric IDs from URLs, forms, and elements
print("\n[1] NUMERIC IDS FOUND:")
print("-" * 40)

# Find all links containing numbers
id_links = []
for link in soup.find_all('a', href=True):
    href = link['href']
    # Extract numbers from href
    numbers = re.findall(r'/\w*/(\d+)', href)
    if numbers:
        for num in numbers:
            id_links.append({
                'url': href,
                'id': num,
                'text': link.get_text(strip=True)
            })

if id_links:
    for item in id_links:
        print(f"  → ID: {item['id']} | URL: {item['url']} | Text: '{item['text']}'")
else:
    print("  (No numeric IDs found in links)")

# Find all form actions and parameters
print("\n[2] FORMS AND PARAMETERS:")
print("-" * 40)

forms = soup.find_all('form')
if forms:
    for idx, form in enumerate(forms, 1):
        action = form.get('action', 'No action')
        method = form.get('method', 'GET').upper()
        print(f"\n  Form #{idx}:")
        print(f"    Action: {action}")
        print(f"    Method: {method}")
        
        # Extract all input fields
        inputs = form.find_all('input')
        if inputs:
            print(f"    Input fields:")
            for input_field in inputs:
                input_type = input_field.get('type', 'text')
                input_name = input_field.get('name', 'No name')
                input_value = input_field.get('value', '')
                input_id = input_field.get('id', 'No id')
                print(f"      - Type: {input_type} | Name: {input_name} | Value: {input_value[:50]} | ID: {input_id}")
                
                # Look for hidden fields with IDs
                if input_type == 'hidden':
                    print(f"        [HIDDEN FIELD DETECTED] Name: {input_name} | Value: {input_value}")
        else:
            print(f"    (No input fields found)")
else:
    print("  (No forms found)")

# Extract all hidden input fields globally
print("\n[3] HIDDEN INPUTS (all):")
print("-" * 40)
hidden_inputs = soup.find_all('input', type='hidden')
if hidden_inputs:
    for hidden in hidden_inputs:
        name = hidden.get('name', 'No name')
        value = hidden.get('value', '')
        input_id = hidden.get('id', 'No id')
        print(f"  → Name: {name} | Value: {value} | ID: {input_id}")
else:
    print("  (No hidden inputs found)")

# Extract JavaScript variables and data
print("\n[4] JAVASCRIPT VARIABLES AND DATA:")
print("-" * 40)

scripts = soup.find_all('script')
if scripts:
    for idx, script in enumerate(scripts, 1):
        if script.string:
            # Look for variable declarations
            var_matches = re.findall(r'(?:var|let|const)\s+(\w+)\s*=\s*([^;]+)', script.string)
            if var_matches:
                print(f"\n  Script #{idx} variables:")
                for var_name, var_value in var_matches[:5]:  # Limit to first 5
                    print(f"    - {var_name} = {var_value[:100]}")
            
            # Look for JSON data
            json_matches = re.findall(r'\{[^}]*\}', script.string)
            if json_matches:
                print(f"\n  Script #{idx} JSON-like data:")
                for json_str in json_matches[:3]:  # Limit to first 3
                    print(f"    - {json_str[:100]}")
else:
    print("  (No script tags found)")

# Extract data attributes
print("\n[5] DATA ATTRIBUTES:")
print("-" * 40)

all_elements = soup.find_all()
data_attrs_found = False
for elem in all_elements:
    data_attrs = {k: v for k, v in elem.attrs.items() if k.startswith('data-')}
    if data_attrs:
        data_attrs_found = True
        print(f"  → Element: {elem.name} | Data attrs: {data_attrs}")

if not data_attrs_found:
    print("  (No data attributes found)")

# Extract Remind button functionality
print("\n[6] REMIND BUTTON FUNCTIONALITY:")
print("-" * 40)

remind_buttons = soup.find_all(text=re.compile('Remind', re.I))
if remind_buttons:
    for btn_text in remind_buttons:
        parent = btn_text.parent
        if parent.name in ['button', 'a', 'input']:
            print(f"  → Found Remind button:")
            print(f"    Element: {parent.name}")
            print(f"    Text: {btn_text}")
            print(f"    Attributes: {parent.attrs}")
            
            # Check if it's in a form
            form_parent = parent.find_parent('form')
            if form_parent:
                print(f"    Form action: {form_parent.get('action', 'No action')}")
                print(f"    Form method: {form_parent.get('method', 'GET')}")
        else:
            print(f"  → Text 'Remind' found in: {parent.name}")
else:
    print("  (No Remind buttons found)")

# Extract all button elements for analysis
print("\n[7] ALL BUTTONS:")
print("-" * 40)

buttons = soup.find_all('button')
if buttons:
    for idx, btn in enumerate(buttons, 1):
        btn_text = btn.get_text(strip=True)
        btn_type = btn.get('type', 'submit')
        btn_name = btn.get('name', 'No name')
        btn_value = btn.get('value', 'No value')
        print(f"  Button #{idx}:")
        print(f"    Text: '{btn_text}'")
        print(f"    Type: {btn_type} | Name: {btn_name} | Value: {btn_value}")
        print(f"    Attributes: {btn.attrs}")
else:
    print("  (No buttons found)")

# Summary of all discovered transaction IDs
print("\n[8] TRANSACTION ID SUMMARY:")
print("-" * 40)

transaction_ids = []
# Look for transaction-related IDs in various formats
id_patterns = [
    r'transaction[_-]?(\d+)',
    r'txn[_-]?(\d+)',
    r'item[_-]?(\d+)',
    r'payment[_-]?(\d+)',
    r'id[_-]?(\d+)',
    r'(\d+)(?=\D*$)'  # trailing numbers
]

for pattern in id_patterns:
    matches = re.findall(pattern, response.text, re.I)
    if matches:
        transaction_ids.extend(matches)

# Remove duplicates and sort
transaction_ids = sorted(list(set(transaction_ids)))

if transaction_ids:
    print(f"  Found {len(transaction_ids)} unique transaction IDs:")
    for tid in transaction_ids:
        print(f"    → {tid}")
else:
    print("  (No transaction IDs found)")

# Final raw HTML snippet for manual inspection
print("\n" + "="*60)
print("RAW HTML SNIPPET (first 1000 chars):")
print("="*60)
print(response.text[:1000])
print("\n... (truncated)")

print("\n[+] Analysis complete!")
