import requests
import re
import urllib.parse
from concurrent.futures import ThreadPoolExecutor, as_completed

# Base configuration
BASE_URL = "http://127.0.0.1:5003"
SESSION_COOKIE = ".eJwlTstqwzAQ_BWx51Cst-Sv6L2EsJZmY4PbFMs5hfx7F3oa5sm86CY7jxWD5q8XmVOBvjEG30EX-tzBA2Z_3M32Y86H4dbUNOe6DfOrmQ-6vq8XHTkwVprP4wllW6eZandSI3oCCy8MnqKPUoMU26dgpQPcXJhqVsMFgeXInUOISBXF55jES2jagbSaknNoPi8uoTW_5OoXUb0Um3KIMulyh5cktfuYuej923Pg-H9j6f0Hj05H0g.aVsUEw.pzEXTKPJRkglOFBxL9YRXm0BK1c"

headers = {
    "User-Agent": "Mozilla/5.0 (Security Research)",
    "Cookie": f"session={SESSION_COOKIE}"
}

# Wordlists for discovery
GRAPHQL_ENDPOINTS = [
    "/graphql", "/graphiql", "/v1/explorer", "/v1/graphiql",
    "/graph", "/graphql/console/", "/graphql.php", "/graphiql.php"
]

API_ENDPOINTS = [
    "/api", "/api/v1", "/api/v2", "/rest", "/rest/v1", "/graphql",
    "/swagger", "/docs", "/v2/api-docs", "/api-docs", "/swagger-ui",
    "/swagger.json", "/api.json", "/openapi.json"
]

STATIC_FILES = [
    "/static", "/templates", "/favicon.ico", "/robots.txt",
    "/sitemap.xml", "/.git/config", "/.env", "/config.py",
    "/app.py", "/main.py", "/requirements.txt", "/package.json"
]

ADMIN_DEBUG = [
    "/admin", "/admin/", "/admin/login", "/admin/dashboard",
    "/debug", "/debug/", "/test", "/test/", "/config", "/backup",
    "/dev", "/development", "/staging", "/logs", "/console",
    "/phpinfo.php", "/server-status", "/__debug__", "/.htaccess"
]

FILE_EXTENSIONS = [".js", ".css", ".txt", ".html", ".json", ".xml"]

COMMON_PARAMETERS = ["page", "id", "user", "username", "email", "search"]

FLASK_PATTERNS = [
    "/static/css", "/static/js", "/static/img", "/templates/index.html",
    "/login", "/register", "/logout", "/profile", "/dashboard",
    "/home", "/index", "/about", "/contact", "/settings"
]

# HTTP methods to test
HTTP_METHODS = ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS", "HEAD"]

def test_endpoint(url, method="GET", data=None):
    """Test an endpoint with a specific method"""
    try:
        response = requests.request(
            method=method,
            url=url,
            headers=headers,
            data=data,
            timeout=5,
            allow_redirects=False
        )
        return {
            "url": url,
            "method": method,
            "status": response.status_code,
            "content_length": len(response.content),
            "headers": dict(response.headers),
            "body": response.text[:1000] if method != "HEAD" else ""
        }
    except Exception as e:
        return {
            "url": url,
            "method": method,
            "status": "ERROR",
            "error": str(e)
        }

def analyze_forms_and_params(html_content, base_url):
    """Extract forms and parameter patterns from HTML"""
    findings = []
    
    # Find forms
    form_matches = re.findall(r'<form[^>]*>(.*?)</form>', html_content, re.DOTALL | re.IGNORECASE)
    for i, form in enumerate(form_matches):
        action = re.search(r'action=["\']([^"\']*)["\']', form, re.IGNORECASE)
        method = re.search(r'method=["\']([^"\']*)["\']', form, re.IGNORECASE)
        
        action_url = urllib.parse.urljoin(base_url, action.group(1)) if action else base_url
        form_method = method.group(1).upper() if method else "GET"
        
        # Find input fields
        inputs = re.findall(r'<input[^>]*name=["\']([^"\']*)["\']', form, re.IGNORECASE)
        textareas = re.findall(r'<textarea[^>]*name=["\']([^"\']*)["\']', form, re.IGNORECASE)
        selects = re.findall(r'<select[^>]*name=["\']([^"\']*)["\']', form, re.IGNORECASE)
        
        all_fields = inputs + textareas + selects
        findings.append({
            "type": "form",
            "action": action_url,
            "method": form_method,
            "fields": all_fields
        })
    
    # Find URL parameters in links
    param_matches = re.findall(r'\?([^&\s]+&[^&\s]+)', html_content)
    for param_str in param_matches:
        findings.append({
            "type": "url_params",
            "params": param_str.split('&')
        })
    
    return findings

def test_discovery_paths():
    """Test all discovery wordlists"""
    results = []
    
    all_paths = []
    all_paths.extend([(path, "graphql") for path in GRAPHQL_ENDPOINTS])
    all_paths.extend([(path, "api") for path in API_ENDPOINTS])
    all_paths.extend([(path, "static") for path in STATIC_FILES])
    all_paths.extend([(path, "admin") for path in ADMIN_DEBUG])
    all_paths.extend([(path, "flask") for path in FLASK_PATTERNS])
    
    print(f"[*] Testing {len(all_paths)} potential endpoints...")
    
    def test_path(path_info):
        path, category = path_info
        url = urllib.parse.urljoin(BASE_URL, path)
        result = test_endpoint(url, "GET")
        result["category"] = category
        return result
    
    with ThreadPoolExecutor(max_workers=10) as executor:
        futures = {executor.submit(test_path, path_info): path_info for path_info in all_paths}
        for future in as_completed(futures):
            result = future.result()
            if result["status"] != 404 and result["status"] != "ERROR":
                results.append(result)
                print(f"[+] FOUND: {result['url']} ({result['category']}) - Status: {result['status']}")
    
    return results

def test_http_methods_on_endpoints(endpoints):
    """Test all HTTP methods on discovered endpoints"""
    method_results = []
    
    print(f"\n[*] Testing HTTP methods on {len(endpoints)} discovered endpoints...")
    
    for endpoint in endpoints:
        url = endpoint["url"]
        print(f"\n[*] Testing: {url}")
        
        for method in HTTP_METHODS:
            result = test_endpoint(url, method)
            method_results.append(result)
            
            status = result["status"]
            if status != 405 and status != 404:  # Method not allowed or not found
                print(f"  [+] {method}: {status}")
            else:
                print(f"  [-] {method}: {status}")
    
    return method_results

def test_parameter_endpoints():
    """Test endpoints with common parameters"""
    param_results = []
    
    print(f"\n[*] Testing parameter-based endpoints...")
    
    for param in COMMON_PARAMETERS:
        url = f"{BASE_URL}/?{param}=1"
        result = test_endpoint(url, "GET")
        if result["status"] != 404:
            param_results.append(result)
            print(f"[+] Parameter endpoint: {url} - Status: {result['status']}")
    
    return param_results

def extract_endpoints_from_content(content, base_url):
    """Extract endpoints from HTML/JS content"""
    endpoints = []
    
    # Find href links
    hrefs = re.findall(r'href=["\']([^"\'\s]+)["\']', content, re.IGNORECASE)
    # Find src attributes
    srcs = re.findall(r'src=["\']([^"\'\s]+)["\']', content, re.IGNORECASE)
    # Find API endpoints in JS
    js_endpoints = re.findall(r'["\'](/[a-zA-Z0-9/_-]+)["\']', content)
    # Find fetch/ajax calls
    ajax_calls = re.findall(r'fetch\(["\']([^"\']+)["\']', content)
    ajax_calls.extend(re.findall(r'\.ajax\(\{[^}]*url:\s*["\']([^"\']+)["\']', content))
    
    all_refs = set(hrefs + srcs + js_endpoints + ajax_calls)
    
    for ref in all_refs:
        if ref.startswith(('http://', 'https://')):
            continue
        if ref.startswith(('/', './', '../')):
            full_url = urllib.parse.urljoin(base_url, ref)
            if BASE_URL in full_url:
                endpoints.append(full_url)
    
    return list(set(endpoints))

def main():
    print("=" * 80)
    print("Endpoint Enumeration and Discovery Tool")
    print(f"Target: {BASE_URL}")
    print("=" * 80)
    
    discovered = []
    
    # Step 1: Test discovery paths
    found_endpoints = test_discovery_paths()
    discovered.extend(found_endpoints)
    
    # Step 2: Test parameter endpoints
    param_endpoints = test_parameter_endpoints()
    discovered.extend(param_endpoints)
    
    # Step 3: Test HTTP methods on discovered endpoints
    if discovered:
        method_results = test_http_methods_on_endpoints(discovered)
    else:
        # Test root if nothing found
        root_result = test_endpoint(BASE_URL, "GET")
        if root_result["status"] != "ERROR":
            discovered.append(root_result)
            method_results = test_http_methods_on_endpoints([root_result])
        else:
            method_results = []
    
    # Step 4: Analyze content for forms and additional endpoints
    print(f"\n[*] Analyzing content for forms and hidden endpoints...")
    
    # Collect all unique successful URLs
    urls_to_analyze = set()
    for endpoint in discovered:
        if isinstance(endpoint["status"], int) and endpoint["status"] < 500:
            urls_to_analyze.add(endpoint["url"])
    
    form_findings = []
    extracted_endpoints = []
    
    for url in urls_to_analyze:
        try:
            resp = requests.get(url, headers=headers, timeout=5)
            if resp.status_code == 200:
                # Analyze forms
                forms = analyze_forms_and_params(resp.text, url)
                form_findings.extend(forms)
                
                # Extract endpoints from content
                new_endpoints = extract_endpoints_from_content(resp.text, url)
                for ep in new_endpoints:
                    if ep not in [e["url"] for e in discovered]:
                        ep_result = test_endpoint(ep, "GET")
                        if ep_result["status"] != 404:
                            extracted_endpoints.append(ep_result)
                            print(f"[+] Extracted endpoint: {ep} - Status: {ep_result['status']}")
        except:
            pass
    
    # Step 5: Summary report
    print("\n" + "=" * 80)
    print("DISCOVERY SUMMARY")
    print("=" * 80)
    
    # Group by category
    categories = {}
    for endpoint in discovered + extracted_endpoints:
        cat = endpoint.get("category", "unknown")
        if cat not in categories:
            categories[cat] = []
        categories[cat].append(endpoint)
    
    for cat, endpoints in categories.items():
        print(f"\n[{cat.upper()} ENDPOINTS]")
        for ep in endpoints:
            print(f"  {ep['url']} - Status: {ep['status']}")
    
    # HTTP methods summary
    print(f"\n[HTTP METHODS ANALYSIS]")
    accessible_methods = {}
    for result in method_results:
        url = result["url"]
        method = result["method"]
        status = result["status"]
        
        if url not in accessible_methods:
            accessible_methods[url] = []
        
        if isinstance(status, int) and status not in [404, 405, 501]:
            accessible_methods[url].append(f"{method}({status})")
    
    for url, methods in accessible_methods.items():
        if methods:
            print(f"  {url}:")
            print(f"    Accessible methods: {', '.join(methods)}")
    
    # Forms and parameters
    if form_findings:
        print(f"\n[FORMS AND PARAMETERS]")
        for finding in form_findings:
            if finding["type"] == "form":
                print(f"  Form: {finding['action']} [{finding['method']}]")
                print(f"    Fields: {', '.join(finding['fields'])}")
            elif finding["type"] == "url_params":
                print(f"  URL params: {', '.join(finding['params'])}")
    
    # Special findings
    print(f"\n[SPECIAL FINDINGS]")
    for endpoint in discovered + extracted_endpoints:
        if isinstance(endpoint["status"], int):
            if endpoint["status"] == 200:
                print(f"  [INFO] Accessible endpoint: {endpoint['url']}")
            elif endpoint["status"] == 403:
                print(f"  [WARNING] Forbidden (needs auth): {endpoint['url']}")
            elif endpoint["status"] == 500:
                print(f"  [ERROR] Server error (potential issue): {endpoint['url']}")
    
    # Check for GraphQL specifically
    graphql_endpoints = [ep for ep in discovered if ep.get("category") == "graphql" and ep["status"] != 404]
    if graphql_endpoints:
        print(f"\n[GRAPhQL DETECTED]")
        for ep in graphql_endpoints:
            print(f"  GraphQL endpoint: {ep['url']} (Status: {ep['status']})")
        
        # Try introspection on first GraphQL endpoint
        print(f"\n[*] Attempting GraphQL introspection...")
        test_introspection = {
            "query": "{__schema{types{name}}}"
        }
        try:
            introspect_resp = requests.post(
                graphql_endpoints[0]["url"],
                json=test_introspection,
                headers=headers,
                timeout=5
            )
            if introspect_resp.status_code == 200:
                print(f"[+] GraphQL introspection enabled!")
                if "__schema" in introspect_resp.text:
                    print(f"[+] Schema accessible - this is a significant finding")
            else:
                print(f"[-] Introspection disabled or restricted")
        except Exception as e:
            print(f"[-] Introspection test failed: {e}")
    
    print("\n[*] Enumeration complete!")

if __name__ == "__main__":
    main()

