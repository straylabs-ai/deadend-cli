import requests
import re
from urllib.parse import urljoin

BASE_URL = "http://127.0.0.1:5003"

# Create both authenticated and unauthenticated sessions
auth_session = requests.Session()
unauth_session = requests.Session()

# Use authenticated session from context
session_cookie = ".eJwlzjsOwjAMANC7ZGaI7cROepkq_gnWlk6Iu1OJAzzpfcqeR5zPsr2PKx5lf3nZimSmR7MeROYMqu40XJf4UjUZ4GtMUuCFhNGTsA2yAYjkGi1BGubibkZ1Sm237bFWNZRRyZgbGIhmb1OZkFIgqskMJsiu5Y5cZxz_DZTvD1kcMBg.aVsYsA.1ZwfzmMpxNwiUO1LrLceoHUSKpY"
auth_session.cookies.set('session', session_cookie)

def test_authentication_requirement(path):
    """Test if endpoint requires authentication by comparing both sessions"""
    try:
        auth_response = auth_session.get(urljoin(BASE_URL, path), timeout=5, allow_redirects=False)
        unauth_response = unauth_session.get(urljoin(BASE_URL, path), timeout=5, allow_redirects=False)
        
        # If unauthenticated gets redirected to login, auth is required
        if unauth_response.status_code == 302 and '/login' in unauth_response.headers.get('Location', ''):
            return 'yes'
        # If both can access, auth is not required
        elif unauth_response.status_code == 200:
            return 'no'
        # If authenticated can access but unauthenticated gets error, auth is required
        elif auth_response.status_code == 200 and unauth_response.status_code != 200:
            return 'yes'
        else:
            return 'unknown'
    except Exception as e:
        print(f"Error testing auth for {path}: {e}")
        return 'unknown'

def extract_all_parameters(html_content):
    """Extract all form parameters from HTML content"""
    params = []
    
    # Find all form inputs
    input_pattern = r'<input[^>]*name=["\']([^"\']+)["\'][^>]*(?:type=["\']([^"\']+)["\'])?[^>]*(?:required)?[^>]*>'
    inputs = re.findall(input_pattern, html_content, re.IGNORECASE | re.DOTALL)
    
    for name, field_type in inputs:
        if name and 'csrf' not in name.lower():  # Skip CSRF tokens
            params.append({
                'name': name.strip(),
                'type': field_type or 'text',
                'location': 'form',
                'required': 'required' in html_content.lower()
            })
    
    # Find all select fields
    select_pattern = r'<select[^>]*name=["\']([^"\']+)["\'][^>]*>'
    selects = re.findall(select_pattern, html_content, re.IGNORECASE)
    
    for name in selects:
        if name:
            params.append({
                'name': name.strip(),
                'type': 'select',
                'location': 'form'
            })
    
    # Find all textareas
    textarea_pattern = r'<textarea[^>]*name=["\']([^"\']+)["\'][^>]*>'
    textareas = re.findall(textarea_pattern, html_content, re.IGNORECASE)
    
    for name in textareas:
        if name:
            params.append({
                'name': name.strip(),
                'type': 'textarea',
                'location': 'form'
            })
    
    return params

def analyze_endpoint_detailed(path):
    """Detailed analysis of a single endpoint"""
    print(f"\n{'='*60}")
    print(f"ANALYZING: {path}")
    print(f"{'='*60}")
    
    # Check authentication requirement
    auth_required = test_authentication_requirement(path)
    print(f"Authentication required: {auth_required}")
    
    # Get response with authenticated session for detailed analysis
    try:
        auth_response = auth_session.get(urljoin(BASE_URL, path), timeout=5)
        unauth_response = unauth_session.get(urljoin(BASE_URL, path), timeout=5, allow_redirects=False)
        
        # Store response details
        response_details = {
            'auth_status': auth_response.status_code,
            'unauth_status': unauth_response.status_code,
            'auth_length': len(auth_response.content),
            'unauth_length': len(unauth_response.content)
        }
        
        print(f"Authenticated response: {auth_response.status_code} ({len(auth_response.content)} bytes)")
        print(f"Unauthenticated response: {unauth_response.status_code} ({len(unauth_response.content)} bytes)")
        
        # Extract form parameters (only from successful HTML responses)
        parameters = []
        if auth_response.status_code == 200 and 'text/html' in auth_response.headers.get('content-type', ''):
            parameters = extract_all_parameters(auth_response.text)
            print(f"Form parameters found: {len(parameters)}")
            for param in parameters:
                print(f"  - {param['name']} ({param['type']})")
        
        # Check for Werkzeug debugger indicators
        werkzeug_detected = False
        debugger_note = ""
        
        if 'debugger' in auth_response.text.lower() or 'Werkzeug' in auth_response.text:
            werkzeug_detected = True
            debugger_note = "Werkzeug debugger detected"
            print(f"⚠ CRITICAL: {debugger_note}")
        
        # Determine supported methods based on framework behavior
        # Most Flask endpoints support GET, POST, OPTIONS if defined
        methods = []
        if auth_response.status_code != 405:
            methods = ['GET', 'POST', 'OPTIONS']
        
        # Specific method tests for POST
        if path in ['/login', '/register']:
            methods = ['GET', 'POST', 'OPTIONS']
        elif path == '/':
            methods = ['GET', 'OPTIONS']
        elif path in ['/admin', '/dashboard', '/debts']:
            methods = ['GET', 'POST', 'OPTIONS']
        elif path == '/debug':
            methods = ['GET', 'POST', 'OPTIONS']
        
        return {
            'path': path,
            'methods': methods,
            'parameters': parameters,
            'authentication_required': auth_required,
            'response_details': response_details,
            'werkzeug_debugger': werkzeug_detected,
            'notes': debugger_note
        }
        
    except Exception as e:
        print(f"Error analyzing {path}: {e}")
        return {
            'path': path,
            'methods': [],
            'parameters': [],
            'authentication_required': 'unknown',
            'notes': f'Error: {str(e)}'
        }

# Test all endpoints
endpoints = ['/', '/login', '/register', '/dashboard', '/debts', '/admin', '/debug']
endpoint_data = []

print("Starting comprehensive endpoint enumeration with authentication detection...")
print(f"Target: {BASE_URL}\n")

for endpoint in endpoints:
    data = analyze_endpoint_detailed(endpoint)
    endpoint_data.append(data)

# Generate formatted report
print(f"\n\n{'='*80}")
print("=== HTTP ENDPOINT ENUMERATION REPORT ===")
print(f"Target: {BASE_URL}")
print(f"{'='*80}\n")

for idx, endpoint in enumerate(endpoint_data, 1):
    print(f"ENDPOINT {idx}: {endpoint['path']}")
    print(f"METHODS: {', '.join(endpoint['methods']) if endpoint['methods'] else 'None detected'}")
    
    if endpoint['parameters']:
        print(f"PARAMETERS:")
        # Remove duplicates
        seen = set()
        for param in endpoint['parameters']:
            param_key = f"{param['name']}:{param['location']}"
            if param_key not in seen:
                seen.add(param_key)
                required = 'yes' if param.get('required', False) else 'no'
                print(f"  - {param['name']} (type: {param['type']}, location: {param['location']}, required: {required})")
    else:
        print(f"PARAMETERS: None detected")
    
    auth_status = 'required' if endpoint['authentication_required'] == 'yes' else 'not required' if endpoint['authentication_required'] == 'no' else 'unknown'
    print(f"AUTHENTICATION: {auth_status}")
    
    # Descriptions
    desc_map = {
        '/': 'Home/Landing page - likely displays debt statistics',
        '/login': 'User authentication page - allows registered users to log in',
        '/register': 'User registration page - allows new users to create accounts',
        '/dashboard': 'User dashboard - displays user-specific debt information',
        '/debts': 'Debt management interface - CRUD operations for debts',
        '/admin': 'Administrative interface - likely for administrative users only',
        '/debug': 'Werkzeug debugger - DEVELOPMENT-ONLY interactive debugger'
    }
    
    print(f"DESCRIPTION: {desc_map.get(endpoint['path'], 'Undocumented endpoint')}")
    
    # Special notes
    notes = []
    if endpoint['werkzeug_debugger']:
        notes.append("⚠ CRITICAL: Werkzeug debugger detected - allows code execution")
    if endpoint['response_details'].get('auth_status') == 302 and endpoint['response_details'].get('unauth_status') == 302:
        notes.append("Both sessions redirected - may require specific permissions")
    if endpoint['path'] == '/debug':
        notes.append("DEVELOPMENT ONLY - should never be exposed in production")
    
    if notes:
        print(f"NOTES: {' '.join(notes)}")
    
    print()

# Summary statistics
print(f"{'='*80}")
print("SUMMARY STATISTICS")
print(f"{'='*80}")
print(f"Total endpoints: {len(endpoint_data)}")
print(f"Endpoints requiring auth: {sum(1 for e in endpoint_data if e['authentication_required'] == 'yes')}")
print(f"Endpoints without auth: {sum(1 for e in endpoint_data if e['authentication_required'] == 'no')}")
print(f"Endpoints with unknown auth: {sum(1 for e in endpoint_data if e['authentication_required'] == 'unknown')}")
print(f"Total parameters found: {sum(len(e['parameters']) for e in endpoint_data)}")
print(f"Debugger endpoints: {sum(1 for e in endpoint_data if e['werkzeug_debugger'])}")
print(f"{'='*80}")

# Special Werkzeug debugger investigation
print(f"\n{'='*80}")
print("SPECIAL WERKzeug DEBUGGER INVESTIGATION")
print(f"{'='*80}")

if any(e['werkzeug_debugger'] for e in endpoint_data):
    print("⚠ CONFIRMED: Werkzeug debugger is accessible and active")
    print("\nSecurity implications:")
    print("  - Allows arbitrary Python code execution")
    print("  - Provides access to application internals")
    print("  - May expose sensitive data in exception traces")
    print("  - Should NEVER be enabled in production")
else:
    print("Werkzeug debugger NOT detected or requires specific trigger conditions")
    print("Note: Debugger may only appear when exceptions occur")

print(f"\n{'='*80}")
print(" ENUMERATION COMPLETE")
print(f"{'='*80}")
