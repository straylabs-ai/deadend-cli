def test_endpoint(url, method="GET", data=None, json_data=None, params=None):
    """Test an endpoint with a specific method"""
    try:
        response = requests.request(
            method=method,
            url=url,
            headers=headers,
            data=data,
            json=json_data,
            params=params,
            timeout=10,
            allow_redirects=False
        )
        return {
            "url": url,
            "method": method,
            "status": response.status_code,
            "content_length": len(response.content),
            "headers": dict(response.headers),
            "body": response.text,
            "redirect_location": response.headers.get('Location', '')
        }
    except Exception as e:
        return {
            "url": url,
            "method": method,
            "status": "ERROR",
            "error": str(e)
        }

def investigate_console():
    """Deep investigation of the /console endpoint"""
    print("=" * 80)
    print("INVESTIGATING /console ENDPOINT")
    print("=" * 80)
    
    console_url = f"{BASE_URL}/console"
    
    # Test GET request
    print("\n[*] Testing GET /console")
    get_result = test_endpoint(console_url, "GET")
    print(f"Status: {get_result['status']}")
    print(f"Content Length: {get_result['content_length']}B")
    if get_result['status'] == 200:
        print("Response preview:")
        print(get_result['body'][:1000])
        
        # Look for interactive elements
        if "input" in get_result['body'].lower() or "form" in get_result['body'].lower():
            print("\n[+] Form/input elements detected!")
            
        # Look for debug/console patterns
        patterns = ['debug', 'console', 'eval', 'exec', 'command', 'query']
        found_patterns = [p for p in patterns if p in get_result['body'].lower()]
        if found_patterns:
            print(f"[+] Found patterns: {found_patterns}")
    
    # Test POST with various payloads
    print("\n[*] Testing POST /console with different payloads")
    
    test_payloads = [
        {"test": "echo hello"},
        {"query": "SELECT 1"},
        {"cmd": "whoami"},
        {},
        {"debug": "true"},
        {"eval": "1+1"}
    ]
    
    for payload in test_payloads:
        post_result = test_endpoint(console_url, "POST", json_data=payload)
        print(f"Payload: {payload} -> Status: {post_result['status']}")
        if post_result['status'] != 405 and post_result['status'] != 404:
            print(f"  Response: {post_result['body'][:200]}")
    
    # Test different content types
    print("\n[*] Testing different content types")
    
    content_types = [
        "application/json",
        "application/x-www-form-urlencoded",
        "text/plain",
        "application/graphql"
    ]
    
    for ct in content_types:
        custom_headers = headers.copy()
        custom_headers["Content-Type"] = ct
        
        try:
            response = requests.post(
                console_url,
                headers=custom_headers,
                data="test=data" if ct != "application/json" else json.dumps({"test": "data"}),
                timeout=5
            )
            print(f"Content-Type {ct}: Status {response.status_code}")
        except Exception as e:
            print(f"Content-Type {ct}: ERROR - {e}")
    
    return get_result

def investigate_transactions():
    """Investigate the /transactions endpoint"""
    print("\n" + "=" * 80)
    print("INVESTIGATING /transactions ENDPOINT")
    print("=" * 80)
    
    transactions_url = f"{BASE_URL}/transactions"
    
    # Test GET with different parameters
    print("\n[*] Testing GET /transactions with parameters")
    
    test_params = [
        {},
        {"id": "1"},
        {"user_id": "1"},
        {"account": "1"},
        {"all": "true"},
        {"debug": "true"},
        {"page": "1"}
    ]
    
    for params in test_params:
        result = test_endpoint(transactions_url, "GET", params=params)
        print(f"Params {params} -> Status: {result['status']}, Redirect: {result['redirect_location']}")
        
        if result['status'] == 200:
            print(f"  Content: {result['body'][:300]}")
        elif result['redirect_location']:
            # Follow redirect to see where it goes
            redirect_url = urllib.parse.urljoin(BASE_URL, result['redirect_location'])
            redirect_result = test_endpoint(redirect_url, "GET")
            print(f"  -> Redirects to: {redirect_url} (Status: {redirect_result['status']})")
            if redirect_result['status'] == 200:
                print(f"  -> Content preview: {redirect_result['body'][:300]}")
    
    # Test different HTTP methods
    print("\n[*] Testing different HTTP methods on /transactions")
    methods = ["GET", "POST", "PUT", "DELETE", "PATCH"]
    
    for method in methods:
        result = test_endpoint(transactions_url, method, json_data={"test": "data"})
        print(f"{method}: Status {result['status']}, Redirect: {result['redirect_location']}")
    
    # Try to find actual transactions by ID
    print("\n[*] Testing transaction IDs 1-50")
    found_transactions = []
    
    for i in range(1, 51):
        result = test_endpoint(transactions_url, "GET", params={"id": str(i)})
        if result['status'] == 200:
            print(f"[+] Transaction {i} accessible!")
            found_transactions.append((i, result))
        elif result['status'] != 302:  # Something other than redirect
            print(f"[?] Transaction {i}: Status {result['status']}")
    
    if found_transactions:
        print(f"\n[+] Found {len(found_transactions)} accessible transactions")
        for tid, result in found_transactions[:5]:  # Show first 5
            print(f"  Transaction {tid}: {result['body'][:200]}")
    
    return found_transactions

def investigate_login():
    """Investigate the /login endpoint"""
    print("\n" + "=" * 80)
    print("INVESTIGATING /login ENDPOINT")
    print("=" * 80)
    
    login_url = f"{BASE_URL}/login"
    
    # Test GET
    print("\n[*] Testing GET /login")
    get_result = test_endpoint(login_url, "GET")
    print(f"Status: {get_result['status']}")
    if get_result['status'] == 200:
        print("Response preview:")
        print(get_result['body'][:500])
        
        # Look for forms
        forms = re.findall(r'<form[^>]*>(.*?)</form>', get_result['body'], re.DOTALL | re.IGNORECASE)
        if forms:
            print(f"\n[+] Found {len(forms)} form(s)")
            for i, form in enumerate(forms):
                action = re.search(r'action=["\']([^"\']*)["\']', form, re.IGNORECASE)
                method = re.search(r'method=["\']([^"\']*)["\']', form, re.IGNORECASE)
                inputs = re.findall(r'<input[^>]*name=["\']([^"\']*)["\']', form, re.IGNORECASE)
                
                print(f"  Form {i+1}:")
                print(f"    Action: {action.group(1) if action else 'self'}")
                print(f"    Method: {method.group(1).upper() if method else 'GET'}")
                print(f"    Fields: {inputs}")
    
    # Test POST with various credentials
    print("\n[*] Testing POST /login")
    
    # Try with no data
    result = test_endpoint(login_url, "POST")
    print(f"Empty POST -> Status: {result['status']}")
    if result['status'] == 500:
        print(f"  Error response: {result['body'][:500]}")
    
    # Try with common credentials
    test_credentials = [
        {"username": "admin", "password": "admin"},
        {"username": "test", "password": "test"},
        {"username": "user", "password": "password"},
        {"username": "' OR '1'='1", "password": "x"},  # SQL injection test
        {"username": "admin'--", "password": "x"},  # SQL injection test
    ]
    
    for creds in test_credentials:
        result = test_endpoint(login_url, "POST", data=creds)
        print(f"Creds {creds} -> Status: {result['status']}")
        if result['status'] != 500:
            print(f"  Response: {result['body'][:200]}")
    
    return get_result

def search_for_flags_in_all_endpoints():
    """Search for flags across all discovered endpoints"""
    print("\n" + "=" * 80)
    print("SEARCHING FOR FLAGS IN ALL ENDPOINTS")
    print("=" * 80)
    
    endpoints_to_check = [
        f"{BASE_URL}/console",
        f"{BASE_URL}/login",
        f"{BASE_URL}/logout",
        f"{BASE_URL}/transactions"
    ]
    
    # Add 50 transaction IDs
    for i in range(1, 51):
        endpoints_to_check.append(f"{BASE_URL}/transactions?id={i}")
    
    # Add parameter variations
    param_tests = [
        f"{BASE_URL}/?page=1",
        f"{BASE_URL}/?id=1",
        f"{BASE_URL}/?user=1",
        f"{BASE_URL}/?search=test",
        f"{BASE_URL}/?debug=true",
        f"{BASE_URL}/?admin=true"
    ]
    endpoints_to_check.extend(param_tests)
    
    flags_found = []
    
    for url in endpoints_to_check:
        try:
            result = test_endpoint(url, "GET")
            if isinstance(result['status'], int) and result['status'] == 200:
                flag_matches = re.findall(r'FLAG\{[^}]+\}', result['body'], re.IGNORECASE)
                if flag_matches:
                    for flag in flag_matches:
                        flags_found.append((url, flag))
                        print(f"[!] FLAG FOUND at {url}")
                        print(f"    Flag: {flag}")
                        print(f"    Context: {result['body'][result['body'].find(flag)-100:result['body'].find(flag)+len(flag)+100]}")
        except Exception as e:
            print(f"Error checking {url}: {e}")
    
    if not flags_found:
        print("[-] No flags found in basic enumeration")
    
    return flags_found

def test_graphql_like_behavior():
    """Test for GraphQL-like behavior even without /graphql endpoint"""
    print("\n" + "=" * 80)
    print("TESTING FOR GRAPHQL-LIKE PATTERNS")
    print("=" * 80)
    
    # Test if console accepts GraphQL queries
    console_url = f"{BASE_URL}/console"
    
    graphql_queries = [
        '{__schema{types{name}}}',
        '{user(id:1){id,username}}',
        'query{users{id,username}}',
        'mutation{login(username:"test",password:"test"){token}}'
    ]
    
    print("\n[*] Testing GraphQL queries on /console")
    for query in graphql_queries:
        # Test as JSON
        json_result = test_endpoint(console_url, "POST", json_data={"query": query})
        if json_result['status'] != 405:
            print(f"JSON GraphQL query -> Status: {json_result['status']}")
            if json_result['status'] == 200 and len(json_result['body']) > 0:
                print(f"  Response: {json_result['body'][:200]}")
        
        # Test as GraphQL content type
        try:
            resp = requests.post(
                console_url,
                headers={**headers, 'Content-Type': 'application/graphql'},
                data=query,
                timeout=5
            )
            if resp.status_code != 405:
                print(f"GraphQL content-type query -> Status: {resp.status_code}")
                if resp.status_code == 200:
                    print(f"  Response: {resp.text[:200]}")
        except Exception as e:
            pass
    
    # Test common parameter names
    print("\n[*] Testing common GraphQL parameter patterns")
    graphql_params = [
        f"{BASE_URL}/console?query={{__schema{{types{{name}}}}}}",
        f"{BASE_URL}/console?query={{user(id:1){{id,username}}}}",
        f"{BASE_URL}/transactions?query={{transactions{{id,amount}}}}"
    ]
    
    for url in graphql_params:
        result = test_endpoint(url, "GET")
        if result['status'] != 404:
            print(f"GraphQL param test -> Status: {result['status']}")
            if result['status'] == 200:
                print(f"  Response: {result['body'][:200]}")

def main():
    # Investigate each main endpoint
    console_result = investigate_console()
    transactions_result = investigate_transactions()
    login_result = investigate_login()
    
    # Search for flags
    flags = search_for_flags_in_all_endpoints()
    
    # Test GraphQL patterns
    test_graphql_like_behavior()
    
    # Summary
    print("\n" + "=" * 80)
    print("INVESTIGATION SUMMARY")
    print("=" * 80)
    
    print(f"\n[ENDPOINTS INVESTIGATED]")
    print(f"  - /console: {'Interactive' if 'input' in console_result.get('body', '').lower() else 'Static'}")
    print(f"  - /login: {'Has forms' if re.search(r'<form', login_result.get('body', ''), re.I) else 'No forms'}")
    print(f"  - /transactions: {len(transactions_result)} accessible transactions")
    print(f"  - Flags found: {len(flags)}")
    
    if flags:
        print(f"\n[FLAGS DISCOVERED]")
        for url, flag in flags:
            print(f"  {flag} at {url}")
    
    print("\n[*] Investigation complete!")

if __name__ == "__main__":
    main()
