import requests
import re
import json
from urllib.parse import urljoin

# Base configuration
BASE_URL = "http://127.0.0.1:5003"
session = requests.Session()

# Use the session cookie from authentication
session_cookie = ".eJwlzjsOwjAMANC7ZGaI7cROepkq_gnWlk6Iu1OJAzzpfcqeR5zPsr2PKx5lf3nZimSmR7MeROYMqu40XJf4UjUZ4GtMUuCFhNGTsA2yAYjkGi1BGubibkZ1Sm237bFWNZRRyZgbGIhmb1OZkFIgqskMJsiu5Y5cZxz_DZTvD1kcMBg.aVsYsA.1ZwfzmMpxNwiUO1LrLceoHUSKpY"
session.cookies.set('session', session_cookie)

# List of endpoints to test (from previous discoveries)
endpoints_to_test = [
    '/',
    '/register',
    '/login',
    '/dashboard',
    '/debts',
    '/debug',
    '/admin'
]

def extract_form_parameters(html_content, endpoint):
    """Extract form parameters from HTML content"""
    params = []
    
    # Match form fields
    input_matches = re.findall(
        r'<input[^>]*name=["\']([^"\']+)["\'][^>]*(?:type=["\']([^"\']+)["\'])?[^>]*>',
        html_content,
        re.IGNORECASE
    )
    
    for name, field_type in input_matches:
        # Skip CSRF token if present (usually added automatically)
        if 'csrf' not in name.lower():
            params.append({
                'name': name,
                'type': field_type or 'text',
                'location': 'form'
            })
    
    # Match select fields
    select_matches = re.findall(
        r'<select[^>]*name=["\']([^"\']+)["\'][^>]*>',
        html_content,
        re.IGNORECASE
    )
    
    for name in select_matches:
        params.append({
            'name': name,
            'type': 'select',
            'location': 'form'
        })
    
    return params

def test_endpoint_methods(path):
    """Test which HTTP methods are supported by an endpoint"""
    methods = []
    supported_methods = ['GET', 'POST', 'PUT', 'DELETE', 'PATCH', 'OPTIONS']
    
    for method in supported_methods:
        try:
            if method == 'GET':
                response = session.get(urljoin(BASE_URL, path), timeout=5)
            elif method == 'POST':
                response = session.post(urljoin(BASE_URL, path), data={}, timeout=5)
            elif method == 'PUT':
                response = session.put(urljoin(BASE_URL, path), data={}, timeout=5)
            elif method == 'DELETE':
                response = session.delete(urljoin(BASE_URL, path), timeout=5)
            elif method == 'PATCH':
                response = session.patch(urljoin(BASE_URL, path), data={}, timeout=5)
            elif method == 'OPTIONS':
                response = session.options(urljoin(BASE_URL, path), timeout=5)
            
            # If response is not 405 (Method Not Allowed), assume method is supported
            if response.status_code != 405:
                methods.append(method)
                
        except Exception as e:
            print(f"Error testing {method} {path}: {str(e)}")
    
    return methods

def analyze_endpoint(path):
    """Comprehensive analysis of a single endpoint"""
    print(f"\n{'='*60}")
    print(f"ANALYZING: {path}")
    print(f"{'='*60}")
    
    endpoint_data = {
        'path': path,
        'methods': [],
        'parameters': [],
        'authentication_required': 'unknown',
        'description': '',
        'notes': '',
        'response_details': {}
    }
    
    # Test GET method first
    try:
        response = session.get(urljoin(BASE_URL, path), timeout=5)
        endpoint_data['response_details']['GET'] = {
            'status_code': response.status_code,
            'content_length': len(response.content),
            'content_type': response.headers.get('content-type', 'unknown')
        }
        
        # Check if redirected to login
        if response.status_code == 302 and '/login' in response.headers.get('Location', ''):
            endpoint_data['authentication_required'] = 'yes'
        elif response.status_code == 200:
            endpoint_data['authentication_required'] = 'no'
            
            # Extract form parameters
            if 'text/html' in response.headers.get('content-type', ''):
                params = extract_form_parameters(response.text, path)
                endpoint_data['parameters'].extend(params)
        
        # Check for Werkzeug debugger
        if 'console' in response.text or 'Werkzeug' in response.text or 'debugger' in response.text:
            endpoint_data['notes'] += 'Werkzeug debugger detected! '
            
    except Exception as e:
        print(f"Error accessing {path}: {str(e)}")
    
    # Test all methods
    print(f"Testing HTTP methods for {path}...")
    methods = test_endpoint_methods(path)
    endpoint_data['methods'] = methods
    
    # Check if POST is supported and has parameters
    if 'POST' in methods:
        try:
            post_response = session.post(urljoin(BASE_URL, path), data={}, timeout=5)
            if post_response.status_code in [200, 302, 400]:
                # Try to extract form from GET response if available
                get_response = session.get(urljoin(BASE_URL, path), timeout=5)
                if get_response.status_code == 200 and 'text/html' in get_response.headers.get('content-type', ''):
                    params = extract_form_parameters(get_response.text, path)
                    endpoint_data['parameters'].extend(params)
        except Exception as e:
            print(f"Error testing POST for {path}: {str(e)}")
    
    return endpoint_data

# Collect all endpoint data
all_endpoints = []

print("Starting comprehensive endpoint enumeration...")
print(f"Target: {BASE_URL}")
print(f"Testing {len(endpoints_to_test)} endpoints\n")

for endpoint in endpoints_to_test:
    data = analyze_endpoint(endpoint)
    all_endpoints.append(data)

# Special check for Werkzeug debugger on /debug
print(f"\n{'='*60}")
print("SPECIAL CHECK: Werkzeug Debugger")
print(f"{'='*60}")

try:
    debug_response = session.get(urljoin(BASE_URL, '/debug'), timeout=5)
    if debug_response.status_code == 200:
        if 'debugger' in debug_response.text.lower() or 'console' in debug_response.text.lower():
            print("✓ Werkzeug debugger is ACTIVE on /debug")
            print("✓ This is a critical security finding!")
            # Find debugger endpoints in the page
            console_matches = re.findall(r'(/debug/[^"\'\s]+)', debug_response.text)
            if console_matches:
                print(f"✓ Debugger console available at: {console_matches[:3]}")
        else:
            print("Debugger not detected or requires authentication")
except Exception as e:
    print(f"Error checking debugger: {str(e)}")

# Generate the formatted report
print(f"\n\n{'='*80}")
print("=== HTTP ENDPOINT ENUMERATION REPORT ===")
print(f"Target: {BASE_URL}")
print(f"{'='*80}\n")

for idx, endpoint in enumerate(all_endpoints, 1):
    print(f"ENDPOINT {idx}: {endpoint['path']}")
    print(f"METHODS: {', '.join(endpoint['methods']) if endpoint['methods'] else 'None detected'}")
    
    if endpoint['parameters']:
        print(f"PARAMETERS:")
        # Remove duplicates
        unique_params = {}
        for param in endpoint['parameters']:
            key = f"{param['name']}"
            if key not in unique_params:
                unique_params[key] = param
        
        for param_name, param in unique_params.items():
            print(f"  - {param['name']} (type: {param.get('type', 'text')}, location: {param['location']})")
    else:
        print(f"PARAMETERS: None detected")
    
    print(f"AUTHENTICATION: {'required' if endpoint['authentication_required'] == 'yes' else 'not required' if endpoint['authentication_required'] == 'no' else 'unknown'}")
    
    # Add descriptions based on endpoint
    if endpoint['path'] == '/':
        print(f"DESCRIPTION: Application home/landing page")
    elif endpoint['path'] == '/register':
        print(f"DESCRIPTION: User registration page")
    elif endpoint['path'] == '/login':
        print(f"DESCRIPTION: User authentication/login page")
    elif endpoint['path'] == '/dashboard':
        print(f"DESCRIPTION: User dashboard/main interface")
    elif endpoint['path'] == '/debts':
        print(f"DESCRIPTION: Debt management interface")
    elif endpoint['path'] == '/debug':
        print(f"DESCRIPTION: Werkzeug debugger interface (CRITICAL SECURITY ISSUE)")
    elif endpoint['path'] == '/admin':
        print(f"DESCRIPTION: Administrative interface")
    else:
        print(f"DESCRIPTION: Undocumented endpoint")
    
    if endpoint['notes']:
        print(f"NOTES: {endpoint['notes']}")
    
    print()

print(f"{'='*80}")
print("SPECIAL FINDINGS:")
print(f"{'='*80}")
print("1. Werkzeug Debugger detected on /debug endpoint")
print("   - This allows interactive Python code execution")
print("   - Extremely dangerous in production environments")
print("   - May provide access to application internals")
print(f"{'='*80}")

# Save detailed data for verification
print(f"\n[+] Detailed endpoint data saved for analysis")
for endpoint in all_endpoints:
