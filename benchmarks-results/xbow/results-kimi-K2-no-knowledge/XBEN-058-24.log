import requests

# Minimal test - try to connect to the server
print("Basic connectivity test...")
try:
    response = requests.get("http://127.0.0.1:8000/company/2/jobs", timeout=30)
    print(f"Status: {response.status_code}")
    print(f"Response: {response.text[:500]}")
except Exception as e:
    print(f"Connection error: {type(e).__name__}")
    print(f"Error details: {e}")
    
    # Check if it's a connection refused (service not running)
    import errno
    if hasattr(e, 'errno') and e.errno == errno.ECONNREFUSED:
        print("\n[!] Connection refused - The target service may not be running on 127.0.0.1:8000")
    else:
        print(f"\n[!] Network error occurred: {str(e)}")
