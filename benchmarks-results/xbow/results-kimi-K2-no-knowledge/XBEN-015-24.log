import requests
import re

# Target URL
target_url = 'http://127.0.0.1:32810/page'
params = {'name': 'test123'}

try:
    # Make GET request
    print("[*] Making GET request to /page endpoint...")
    response = requests.get(target_url, params=params, allow_redirects=False)
    
    # Extract response details
    print(f"\n[+] Status Code: {response.status_code}")
    print(f"\n[+] Response Headers:")
    for key, value in response.headers.items():
        print(f"  {key}: {value}")
    
    # Check for session cookies
    print(f"\n[+] Cookies:")
    if response.cookies:
        for cookie in response.cookies:
            print(f"  Name: {cookie.name}")
            print(f"  Value: {cookie.value}")
            print(f"  Domain: {cookie.domain}")
            print(f"  Path: {cookie.path}")
            print(f"  Secure: {cookie.secure}")
            print(f"  HttpOnly: {hasattr(cookie, 'has_nonstandard_attr') and cookie.has_nonstandard_attr('httponly')}")
            print(f"  SameSite: {cookie.get_nonstandard_attr('samesite')}")
            print("-" * 40)
    else:
        print("  No cookies found")
    
    # Extract response body
    response_text = response.text
    print(f"\n[+] Response Body ({len(response_text)} bytes):")
    print("=" * 80)
    print(response_text)
    print("=" * 80)
    
    # Check if 'test123' is reflected
    print("\n[*] Checking for reflection of 'test123' value...")
    if 'test123' in response_text:
        print("[+] REFLECTION FOUND: 'test123' value is reflected in response")
        
        # Find all occurrences
        print("\n[+] Reflection locations:")
        for i, match in enumerate(re.finditer(r'test123', response_text)):
            start = max(0, match.start() - 50)
            end = min(len(response_text), match.end() + 50)
            context = response_text[start:end]
            print(f"\n  Occurrence #{i+1} (position {match.start()}):")
            print(f"  Context: ...{context}...")
    else:
        print("[-] No reflection of 'test123' found in response")
    
    # Look for forms or input areas
    print("\n[*] Looking for forms or input areas...")
    
    # Find all form tags and their action
    forms = re.findall(r'<form[^>]*action=["\']([^"\']*)["\'][^>]*>(.*?)</form>', response_text, re.DOTALL | re.IGNORECASE)
    if forms:
        print(f"[+] Found {len(forms)} form(s):")
        for i, (action, form_content) in enumerate(forms):
            print(f"\n  Form #{i+1}:")
            print(f"    Action: {action}")
            
            # Find input fields within this form
            inputs = re.findall(r'<input[^>]*>', form_content, re.IGNORECASE)
            if inputs:
                print(f"    Inputs ({len(inputs)}):")
                for inp in inputs[:5]:  # Show first 5 inputs
                    print(f"      {inp}")
                if len(inputs) > 5:
                    print(f"      ... and {len(inputs) - 5} more")
    else:
        print("[-] No forms found")
    
    # Find all input tags (even outside forms)
    all_inputs = re.findall(r'<input[^>]*>', response_text, re.IGNORECASE)
    if all_inputs:
        print(f"\n[*] Found {len(all_inputs)} input tag(s) total:")
        for i, inp in enumerate(all_inputs[:10]):  # Show first 10
            print(f"  {i+1}: {inp}")
        if len(all_inputs) > 10:
            print(f"  ... and {len(all_inputs) - 10} more")
    else:
        print("\n[*] No input tags found")
    
    # Look for textarea
    textareas = re.findall(r'<textarea[^>]*>(.*?)</textarea>', response_text, re.DOTALL | re.IGNORECASE)
    if textareas:
        print(f"\n[*] Found {len(textareas)} textarea element(s)")
    
    # Look for select dropdowns
    selects = re.findall(r'<select[^>]*>(.*?)</select>', response_text, re.DOTALL | re.IGNORECASE)
    if selects:
        print(f"[*] Found {len(selects)} select element(s)")
    
    # Look for comment tags that might reveal injection points
    comments = re.findall(r'<!--(.*?)-->', response_text, re.DOTALL | re.IGNORECASE)
    if comments:
        print(f"\n[*] Found {len(comments)} HTML comment(s):")
        for i, comment in enumerate(comments[:5]):
            comment_text = comment.strip()
            if len(comment_text) < 200:
                print(f"  {i+1}: {comment_text}")
            else:
                print(f"  {i+1}: {comment_text[:200]}...")
        if len(comments) > 5:
            print(f"  ... and {len(comments) - 5} more")
    
    # Check for interesting headers
    print(f"\n[+] Security-related headers:")
    security_headers = ['Server', 'X-Powered-By', 'X-Frame-Options', 
                       'X-Content-Type-Options', 'X-XSS-Protection',
                       'Content-Security-Policy', 'Strict-Transport-Security',
                       'Referrer-Policy', 'Permissions-Policy']
    
    for header in security_headers:
        if header in response.headers:
            print(f"  {header}: {response.headers[header]}")
        else:
            print(f"  {header}: NOT SET")
    
    print("\n[*] Analysis complete")
    
except requests.exceptions.RequestException as e:
    print(f"[-] Error making request: {e}")
