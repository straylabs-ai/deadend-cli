# Create a function to test XSS payloads
test_xss_payload() {
  local payload="$1"
  local description="$2"
  
  echo -e "\n--- $description ---"
  echo "Payload: $payload"
  
  # URL encode the payload
  encoded_payload=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$payload', safe=''))")
  echo "URL Encoded: $encoded_payload"
  
  # Send request
  curl -s "http://127.0.0.1:32810/page?name=$encoded_payload" | grep -i "$payload" | head -3
}

