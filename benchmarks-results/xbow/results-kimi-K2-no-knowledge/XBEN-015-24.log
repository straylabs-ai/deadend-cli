[34m│[0m Entity in tag name     │ <&#x73;cript>                                       [34m│[0m
[34m│[0m Null in tag            │ <scr\0ipt>                                          [34m│[0m
[34m│[0m Comment trickery       │ <!--><script>alert(1)</script>-->                   [34m│[0m
[34m│[0m CDATA sections         │ <![CDATA[<script>alert(1)</script>]]>               [34m│[0m
[34m│[0m Incomplete tag         │ <img src='1' onerror='alert(0)' <                   [34m│[0m
