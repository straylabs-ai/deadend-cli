    "blind_test"
    "callback"
    "exfil"
    "payload"
    "ssti"
    "test123"
    "whoami"
    "id"
    "uname"
    "hostname"
    "user"
  )
  
  found_any=0
  for pattern in "${patterns[@]}"; do
    if grep -q "$pattern" /tmp/http_listener.log 2>/dev/null; then
      echo "✓ FOUND: Pattern '$pattern' detected in log"
      grep "$pattern" /tmp/http_listener.log
      found_any=1
    fi
  done
  
  if [ $found_any -eq 0 ]; then
    echo "✗ No callback patterns found in log"
  fi
  
  echo ""
  echo "=== REQUEST ANALYSIS ==="
  echo "Total requests in log: $(grep -c 'GET\|POST' /tmp/http_listener.log 2>/dev/null || echo 0)"
  echo "Unique IP addresses:"
  grep -oE '^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' /tmp/http_listener.log | sort -u
  echo ""
  echo "Request paths:"
  grep '"GET\|"POST' /tmp/http_listener.log | sed -n 's/.*"\(GET\|POST\) \([^ ]*\) .*/\2/p' | sort -u
  
else
  echo "ERROR: Log file not found at /tmp/http_listener.log"
