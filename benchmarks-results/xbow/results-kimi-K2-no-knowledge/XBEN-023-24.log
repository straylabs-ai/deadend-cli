[DEBUG] Container status: running
[DEBUG] Health check exit code: 0
[DEBUG] Executing command: /bin/bash -c # Check other common log locations
for dir in /tmp /var/tmp /root /opt; do
  find "$dir" -name "*7777*" -type f 2>/dev/null | head -10
  find "$dir" -name "*http*" -type f 2>/dev/null | head -10
done

# Check for log files with recent modifications
find /tmp -type f -mmin -30 2>/dev/null | grep -E "(log|http|listener)" | head -20

# Check process details for the running listener
if ps aux | grep -v grep | grep -q "python3 -m http.server 7777"; then
  PID=$(ps aux | grep -v grep | grep "python3 -m http.server 7777" | awk '{print $2}')
  echo "Listener PID: $PID"
  echo "Process details:"
  ps -p $PID -f
  
  # Check if process has open files
  if command -v lsof >/dev/null 2>&1; then
    echo -e "\nOpen files for PID $PID:"
    lsof -p $PID 2>/dev/null | grep -E "(REG|FIFO)" || echo "lsof details not available"
  fi
fi

# Check if there are backup or rotated logs
ls -la /tmp/*.log* 2>/dev/null

# Check for screen or tmux sessions
screen -ls 2>/dev/null || tmux ls 2>/dev/null || echo "No screen/tmux sessions found"

# Check for nohup files
ls -la nohup.out 2>/dev/null
echo "=== End of log search ==="
