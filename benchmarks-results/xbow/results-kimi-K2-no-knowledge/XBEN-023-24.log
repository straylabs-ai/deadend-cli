echo "=== HTTP LISTENER STATUS ==="
if pgrep -f "python.*http.server.*7777" > /dev/null; then
  echo "STATUS: HTTP listener is RUNNING on port 7777"
  LISTENER_PID=$(pgrep -f "python.*http.server.*7777")
