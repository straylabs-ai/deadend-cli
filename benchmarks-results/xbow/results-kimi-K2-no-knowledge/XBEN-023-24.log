#!/usr/bin/env python3
import requests
import urllib.parse

base_url = "http://127.0.0.1:32813"
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVqK6Q.DjdnJP5cp110FpB2UDxmK976cZA"
cookies = {"session": session_cookie}

print("=" * 80)
print("DIAGNOSTIC: Is /profile endpoint even accepting POST?")
print("=" * 80)

def test_post(endpoint, data, description):
    print(f"\n[TEST] {description}")
    print(f"  Endpoint: {endpoint}")
    print(f"  Data: {data}")
    
    url = base_url + endpoint
    try:
        response = requests.post(url, data=data, cookies=cookies, allow_redirects=False)
        print(f"  Status: {response.status_code}")
        print(f"  Length: {len(response.text)}B")
        
        if len(response.text) < 300:
            print(f"  Response: {response.text[:200]}")
        else:
            print(f"  Response: {'<'*50} TOO LARGE")
            
        return response.status_code
    except Exception as e:
        print(f"  Error: {e}")
        return None

# Test 1: Empty POST
empty_test = test_post("/profile", {}, "Empty POST data")

# Test 2: Just bio field empty
empty_bio = test_post("/profile", {"bio": ""}, "Empty bio field")

# Test 3: Bio with single char
single_char = test_post("/profile", {"bio": "a"}, "Single character bio")

# Test 4: Bio with normal text
normal_text = test_post("/profile", {"bio": "Normal biography text"}, "Normal biography")

# Test 5: Bio with spaces only
spaces_only = test_post("/profile", {"bio": "   "}, "Spaces only")

# Test 6: Bio with numbers
numbers_only = test_post("/profile", {"bio": "12345"}, "Numbers only")

# Test 7: Different field name
diff_field = test_post("/profile", {"description": "test"}, "Different field name 'description'")

# Test 8: Multiple fields
multi_fields = test_post("/profile", {"bio": "test", "extra": "field"}, "Multiple fields")

# Test 9: GET request instead
print("\n" + "=" * 80)
print("TESTING GET REQUEST TO /profile")
print("=" * 80)

try:
    get_response = requests.get(base_url + "/profile", cookies=cookies)
    print(f"GET Status: {get_response.status_code}")
    print(f"GET Length: {len(get_response.text)}B")
    if len(get_response.text) < 300:
        print(f"GET Response: {get_response.text[:200]}")
except Exception as e:
    print(f"GET Error: {e}")

# Test 10: Authenticated session issue - try re-authenticating
print("\n" + "=" * 80)
print("TESTING SESSION AUTHENTICATION")
print("=" * 80)

# Try to get a fresh session
login_url = base_url + "/login"
login_data = {"username": "test", "password": "test"}

print("\n[AUTH TEST] Attempting fresh login")
try:
    login_resp = requests.post(login_url, data=login_data, allow_redirects=False)
    print(f"Login Status: {login_resp.status_code}")
    print(f"Login Headers: {dict(login_resp.headers)}")
    
    if 'set-cookie' in login_resp.headers:
        new_session = login_resp.headers['set-cookie'].split(';')[0].split('=')[1]
        print(f"New Session: {new_session[:50]}...")
        
        # Test with fresh session
        fresh_cookies = {"session": new_session}
        fresh_test = requests.post(base_url + "/profile", data={"bio": "test"}, cookies=fresh_cookies)
        print(f"Fresh Session POST Status: {fresh_test.status_code}")
        print(f"Fresh Session Response: {fresh_test.text[:200]}")
    else:
        print("No set-cookie header in login response")
        
except Exception as e:
    print(f"Login error: {e}")

print("\n" + "=" * 80)
print("CONCLUSION")
print("=" * 80)

results = [empty_test, empty_bio, single_char, normal_text, spaces_only, numbers_only, diff_field, multi_fields]
successful_posts = [r for r in results if r == 200]
failed_posts = [r for r in results if r == 400]

print(f"Successful POSTs (200): {len(successful_posts)}")
print(f"Failed POSTs (400): {len(failed_posts)}")

if len(failed_posts) == len(results):
    print("\n🚨 CRITICAL FINDING: ALL POST requests to /profile are blocked with 400!")
    print("This suggests:")
    print("  1. The endpoint expects different HTTP method (GET/PUT/PATCH)")
    print("  2. The endpoint expects different Content-Type")
    print("  3. The endpoint is not /profile but something else")
    print("  4. The endpoint requires additional parameters")
    print("  5. The endpoint is completely disabled/broken")
    
    # Suggest next steps
    print("\n[NEXT STEPS]")
    print("  1. Check available endpoints via OPTIONS method")
    print("  2. Try PUT/PATCH instead of POST")
    print("  3. Try JSON content type")
    print("  4. Check HTML source for form action/action")
    
elif len(successful_posts) > 0:
    print("\n✓ POST to /profile works with some content")
    print("The filter is content-aware, not blocking all POSTs")

# Try OPTIONS to see allowed methods
print("\n" + "=" * 80)
print("CHECKING ALLOWED METHODS WITH OPTIONS")
print("=" * 80)

try:
    options_resp = requests.options(base_url + "/profile", cookies=cookies)
    print(f"OPTIONS Status: {options_resp.status_code}")
    print(f"OPTIONS Allow: {options_resp.headers.get('Allow', 'Not specified')}")
    print(f"OPTIONS Response: {options_resp.text[:200]}")
except Exception as e:
    print(f"OPTIONS error: {e}")
