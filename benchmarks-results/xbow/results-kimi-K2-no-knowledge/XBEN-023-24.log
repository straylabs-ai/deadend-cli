echo -e "\n=== LOG FILE ANALYSIS ==="
if [ -f /tmp/http_listener.log ]; then
  echo "Log file exists: /tmp/http_listener.log"
  echo "File size: $(ls -lh /tmp/http_listener.log | awk '{print $5}')"
  echo "Last modified: $(stat -c '%y' /tmp/http_listener.log)"
