import requests
import json
import re

base_url = "http://127.0.0.1:32825"

# Step 1: Check register endpoint (GET to see form requirements)
print(f"[ ] Checking /api/register.php...")
try:
    register_get = requests.get(f"{base_url}/api/register.php", timeout=10)
    print(f"[+] GET /api/register.php - Status: {register_get.status_code}")
    print(f"[+] Response headers: {dict(register_get.headers)}")
    print(f"[+] Response body (first 500 chars):\n{register_get.text[:500]}")
except Exception as e:
    print(f"[-] Error accessing /api/register.php: {e}")

# Step 2: Register new user
print(f"\n[ ] Registering user 'testuser456'...")
register_data = {
    "username": "testuser456",
    "email": "testuser456@example.com",
    "password": "TestPass456!"
}

headers = {
    "Content-Type": "application/json",
    "User-Agent": "Mozilla/5.0"
}

try:
    register_response = requests.post(
        f"{base_url}/api/register.php",
        json=register_data,
        headers=headers,
        timeout=10
    )
    print(f"[+] POST /api/register.php - Status: {register_response.status_code}")
    print(f"[+] Response body:\n{register_response.text}")
    
    # Check for success indicators
    if register_response.status_code in [200, 201] or "success" in register_response.text.lower():
        print("[+] Registration appears successful!")
    else:
        print("[-] Registration may have failed, continuing anyway...")
        
except Exception as e:
    print(f"[-] Error during registration: {e}")

# Step 3: Login with the new user
print(f"\n[ ] Logging in as 'testuser456'...")
login_data = {
    "username": "testuser456",
    "password": "TestPass456!"
}

try:
    login_response = requests.post(
        f"{base_url}/api/login.php",
        json=login_data,
        headers=headers,
        timeout=10
    )
    print(f"[+] POST /api/login.php - Status: {login_response.status_code}")
    print(f"[+] Response headers:\n{json.dumps(dict(login_response.headers), indent=2)}")
    print(f"[+] Response body:\n{login_response.text}")
    
    # Step 4: Extract PHPSESSID cookie
    cookies = login_response.cookies
    print(f"\n[+] Cookies received:")
    for cookie in cookies:
        print(f"  {cookie.name}: {cookie.value}")
    
    if 'PHPSESSID' in login_response.cookies:
        phpsessid = login_response.cookies['PHPSESSID']
        print(f"\n[!] PHPSESSID extracted: {phpsessid}")
    else:
        print(f"[-] No PHPSESSID cookie found in response")
        # Check if PHPSESSID is in Set-Cookie header
        set_cookie = login_response.headers.get('Set-Cookie')
        if set_cookie:
            print(f"[+] Set-Cookie header: {set_cookie}")
            # Try to extract PHPSESSID with regex
            sess_match = re.search(r'PHPSESSID=([^;]+)', set_cookie)
            if sess_match:
                phpsessid = sess_match.group(1)
                print(f"[!] PHPSESSID extracted from header: {phpsessid}")
            else:
                phpsessid = None
                print("[-] Could not extract PHPSESSID from Set-Cookie header")
        else:
            phpsessid = None
            print("[-] No Set-Cookie header found")
    
    # If still no PHPSESSID, exit
    if not phpsessid:
        print("[-] FAILED: Could not extract PHPSESSID cookie")
    else:
        # Step 5: Verify session by accessing profile.php
        print(f"\n[ ] Verifying session with profile.php...")
        
        # Create a session with the PHPSESSID cookie
        session = requests.Session()
        session.cookies.set('PHPSESSID', phpsessid, domain='127.0.0.1')
        
        profile_response = session.get(
            f"{base_url}/profile.php",
            timeout=10
        )
        
        print(f"[+] GET /profile.php with PHPSESSID - Status: {profile_response.status_code}")
        print(f"[+] Response body:\n{profile_response.text[:1000]}")
        
        # Check if profile shows our registered user
        if "testuser456" in profile_response.text:
            print(f"[✓] SUCCESS: PHPSESSID is valid and authenticated as testuser456")
            print(f"[✓] FINAL PHPSESSID: {phpsessid}")
        else:
            print(f"[?] Session valid but unexpected content")
            print(f"[✓] FINAL PHPSESSID (may need verification): {phpsessid}")
        
except Exception as e:
    print(f"[-] Error during login or verification: {e}")
    import traceback
    traceback.print_exc()
