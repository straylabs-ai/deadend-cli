import requests
import json

base_url = "http://127.0.0.1:32825"

# Try different registration data formats
print("[ ] Trying various registration formats...")

formats_to_try = [
    # JSON format
    {"username": "testuser456", "email": "testuser456@example.com", "password": "TestPass456!"},
    # JSON with different field order
    {"email": "testuser456@example.com", "username": "testuser456", "password": "TestPass456!"},
    # Add confirm_password field
    {"username": "testuser456", "email": "testuser456@example.com", "password": "TestPass456!", "confirm_password": "TestPass456!"}
]

headers_json = {"Content-Type": "application/json"}
headers_form = {"Content-Type": "application/x-www-form-urlencoded"}

for idx, data in enumerate(formats_to_try, 1):
    print(f"\n[ ] Attempt {idx}: JSON format")
    print(f"[ ] Data: {data}")
    
    try:
        response = requests.post(f"{base_url}/api/register.php", json=data, headers=headers_json, timeout=10)
        print(f"[+] Status: {response.status_code}")
        print(f"[+] Body: {response.text}")
        print(f"[+] Headers: {dict(response.headers)}")
        if response.status_code in [200, 201]:
            print("[✓] Registration successful!")
            break
    except Exception as e:
        print(f"[-] Error: {e}")

# Try form-encoded data
form_data = "username=testuser456&email=testuser456%40example.com&password=TestPass456!"
print(f"\n[ ] Attempt {len(formats_to_try)+1}: Form-encoded")
print(f"[ ] Data: {form_data}")

try:
    response = requests.post(f"{base_url}/api/register.php", data=form_data, headers=headers_form, timeout=10)
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Body: {response.text}")
    if response.status_code in [200, 201]:
        print("[✓] Registration successful!")
except Exception as e:
    print(f"[-] Error: {e}")

# Now try login
print("\n[ ] Attempting login...")
login_data = {"username": "testuser456", "password": "TestPass456!"}

try:
    login_response = requests.post(
        f"{base_url}/api/login.php",
        json=login_data,
        headers=headers_json,
        timeout=10
    )
    print(f"[+] Login status: {login_response.status_code}")
    print(f"[+] Login body: {login_response.text}")
    print(f"[+] Login headers: {dict(login_response.headers)}")
    
    # Extract PHPSESSID
    set_cookie = login_response.headers.get('Set-Cookie', '')
    import re
    match = re.search(r'PHPSESSID=([^;]+)', set_cookie)
    if match:
        phpsessid = match.group(1)
        print(f"[✓] PHPSESSID: {phpsessid}")
    else:
        phpsessid = None
        print("[-] No PHPSESSID in response")
    
except Exception as e:
    print(f"[-] Error: {e}")
    phpsessid = None

# Test profile if we have session
if phpsessid:
    print("\n[ ] Testing profile.php with PHPSESSID...")
    session = requests.Session()
    session.cookies.set('PHPSESSID', phpsessid)
    profile = session.get(f"{base_url}/profile.php", timeout=10)
    print(f"[+] Profile status: {profile.status_code}")
    print(f"[+] Profile body (first 500 chars):\n{profile.text[:500]}")
    
    if "testuser456" in profile.text:
        print(f"[✓] SUCCESS: Authenticated as testuser456")
        print(f"[✓] FINAL PHPSESSID: {phpsessid}")
    elif "Login" in profile.text or "login" in profile.text.lower():
        print("[-] Profile shows login page - registration may have failed")
        print(f"[?] PHPSESSID value: {phpsessid}")
    else:
        print("[?] Unexpected profile content")
        print(f"[?] PHPSESSID value: {phpsessid}")
