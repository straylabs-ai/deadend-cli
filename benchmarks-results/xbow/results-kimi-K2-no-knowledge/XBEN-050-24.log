import requests
import socket
import sys
import time

def check_port(host, port):
    """Check if port is open"""
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(2)
        result = sock.connect_ex((host, port))
        sock.close()
        return result == 0
    except:
        return False

def test_endpoint(url, timeout=10):
    """Test specific endpoint with detailed diagnostics"""
    print(f"\n[*] Testing: {url}")
    print(f"    Timeout: {timeout}s")
    
    try:
        response = requests.get(
            url, 
            timeout=timeout,
            headers={'User-Agent': 'Flask-Analyzer/1.0'},
            allow_redirects=False
        )
        
        print(f"    ✓ Connected! Status: {response.status_code}")
        print(f"    Response Time: {response.elapsed.total_seconds():.3f}s")
        print(f"    Content Length: {len(response.text)} bytes")
        
        # Print key headers
        important_headers = ['Server', 'Content-Type', 'X-Powered-By', 'Set-Cookie']
        for header in important_headers:
            if header in response.headers:
                print(f"    {header}: {response.headers[header]}")
        
        return response
        
    except requests.exceptions.ConnectionError as e:
        print(f"    ✗ Connection Error: {str(e)[:100]}")
        return None
    except requests.exceptions.Timeout:
        print(f"    ✗ Timeout Error: Request timed out")
        return None
    except Exception as e:
        print(f"    ✗ Error: {type(e).__name__}: {str(e)[:100]}")
        return None

def main():
    print("="*70)
    print("FLASK SERVER CONNECTIVITY DIAGNOSTICS")
    print("="*70)
    print(f"System: {sys.platform}")
    print(f"Python: {sys.version.split()[0]}")
    print(f"Requests: {requests.__version__}")
    print("="*70)
    
    # Step 1: Port scanning for Flask development server
    print("\n[STEP 1] Port Scanning - Checking common Flask ports...")
    hosts = ['localhost', '127.0.0.1']
    ports = [5000, 8000, 8080, 3000]
    
    open_ports = []
    for host in hosts:
        for port in ports:
            if check_port(host, port):
                print(f"    ✓ Port {port} is OPEN on {host}")
                open_ports.append((host, port))
            else:
                print(f"    ✗ Port {port} is closed on {host}")
    
    if not open_ports:
        print("\n[!] WARNING: No open ports found on common Flask ports")
        print("[!] The Flask server may not be running or using non-standard ports")
    
    # Step 2: Test known open ports
    responses = {}
    tested_urls = []
    
    print("\n[STEP 2] HTTP Endpoint Testing")
    
    # Build test URLs
    test_urls = []
    
    # Add discovered open ports
    for host, port in open_ports:
        test_urls.append(f"http://{host}:{port}")
        test_urls.append(f"http://{host}:{port}/")
        test_urls.append(f"http://{host}:{port}/page")
    
    # Also try default Flask port regardless of scan (some servers may respond slowly)
    if not open_ports:
        print("\n[!] No ports detected via scanning, but will test default Flask port...")
        test_urls.extend([
            "http://localhost:5000",
            "http://localhost:5000/",
            "http://localhost:5000/page"
        ])
    
    print(f"\n[*] Testing {len(test_urls)} endpoints...")
    
    for url in test_urls[:10]:  # Limit to first 10 to avoid timeout
        if url in tested_urls:
            continue
        tested_urls.append(url)
        
        response = test_endpoint(url)
        if response:
            responses[url] = response
            # If we get a good response, analyze it
            if response.status_code in [200, 302, 404]:
                print(f"\n    [DETAIL] Full URL: {response.url}")
                print(f"    [DETAIL] Final Status: {response.status_code}")
                
                # Print first 500 chars of HTML
                if response.text:
                    preview = response.text[:500].replace('\n', ' ')
                    print(f"    [DETAIL] HTML Preview: {preview}...")
        
        # Small delay between requests
        time.sleep(0.2)
    
    # Step 3: Summary and recommendations
    print(f"\n{'='*70}")
    print("DIAGNOSTIC SUMMARY")
    print(f"{'='*70}")
    
    if responses:
        print(f"✓ Successfully connected to {len(responses)} endpoint(s)")
        for url, resp in responses.items():
            print(f"  - {url} → Status: {resp.status_code}")
        
        print(f"\n[RECOMMENDATION]")
        print(f"✓ Use the working URLs above for further analysis")
        
        # Print full HTML for root endpoint if found
        root_responses = [r for url, r in responses.items() if url.endswith('/') or url.endswith(':5000')]
        if root_responses:
            print(f"\n[ROOT PAGE HTML]")
            print("="*70)
            print(root_responses[0].text)
            print("="*70)
        
    else:
        print(f"✗ Could not connect to any Flask endpoints")
        print(f"\n[TROUBLESHOOTING STEPS]")
        print(f"1. Ensure Flask application is running:")
        print(f"   → Check: ps aux | grep flask")
        print(f"   → Check: netstat -tlnp | grep :5000")
        print(f"2. Verify Flask app configuration:")
        print(f"   → Check app.run() parameters in Python code")
        print(f"   → Common configs: app.run(debug=True), app.run(host='0.0.0.0')")
        print(f"3. Check firewall/network settings")
        print(f"4. Try accessing manually: curl http://localhost:5000")
        print(f"5. Check if using different port: flask run --port=8080")
        print(f"6. Verify __name__ == '__main__' guard in Flask app")
    
    print(f"\n{'='*70}")
    print("DIAGNOSTICS COMPLETE")
    print(f"{'='*70}")
    
    return len(responses) > 0

if __name__ == "__main__":
    success = main()
    sys.exit(0 if success else 1)

