import requests
import re
import sys
import time
from urllib.parse import urljoin

def test_connectivity(base_url, timeout=10):
    """Test basic connectivity to the server with diagnostics"""
    print(f"\n[CONNECTIVITY TEST] Testing connection to {base_url}")
    
    # Try common Flask ports if default fails
    test_urls = [
        base_url,
        "http://localhost:5000",
        "http://127.0.0.1:5000"
    ]
    
    for url in test_urls:
        try:
            print(f"  Trying {url}...", end=" ")
            response = requests.get(url, timeout=5)
            print(f"SUCCESS (Status: {response.status_code})")
            return url, response
        except requests.exceptions.ConnectionError as e:
            print(f"FAILED - Connection refused")
        except requests.exceptions.Timeout:
            print(f"FAILED - Timeout")
        except Exception as e:
            print(f"FAILED - {type(e).__name__}")
    
    return None, None

def analyze_endpoint_detailed(url, endpoint_name):
    """Analyze endpoint with enhanced error handling"""
    print(f"\n{'='*70}")
    print(f"ANALYZING: {endpoint_name}")
    print(f"URL: {url}")
    print(f"{'='*70}")
    
    try:
        # Make request with extended timeout
        response = requests.get(
            url, 
            timeout=15,
            headers={
                'User-Agent': 'Mozilla/5.0 (Security Researcher)',
                'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8'
            }
        )
        
        print(f"\n[RESPONSE METRICS]")
        print(f"  Status Code: {response.status_code}")
        print(f"  Response Time: {response.elapsed.total_seconds():.3f} seconds")
        print(f"  Content Type: {response.headers.get('Content-Type', 'Not specified')}")
        print(f"  Content Length: {len(response.content)} bytes")
        
        # Headers analysis
        print(f"\n[HTTP HEADERS]")
        security_headers = []
        server_headers = []
        
        for header, value in sorted(response.headers.items()):
            header_lower = header.lower()
            print(f"  {header}: {value}")
            
            # Categorize headers
            if header_lower in ['server', 'x-powered-by', 'x-generator']:
                server_headers.append((header, value))
            elif header_lower in ['x-frame-options', 'x-xss-protection', 'content-security-policy']:
                security_headers.append((header, value))
        
        print(f"\n[SERVER STACK ANALYSIS]")
        if server_headers:
            for header, value in server_headers:
                print(f"  {header}: {value}")
                
                # Detect Flask/Werkzeug
                if 'werkzeug' in value.lower() or 'wsgi' in value.lower():
                    print(f"    → Flask Development Server (Werkzeug) detected!")
                if 'flask' in value.lower():
                    print(f"    → Flask framework confirmed!")
                if 'jinja' in value.lower():
                    print(f"    → Jinja2 template engine confirmed!")
        else:
            print(f"  No explicit server headers found")
        
        # Security headers
        if security_headers:
            print(f"\n[SECURITY HEADERS]")
            for header, value in security_headers:
                print(f"  {header}: {value}")
        
        # Full HTML content (critical for analysis)
        print(f"\n[RAW HTML CONTENT]")
        print("="*70)
        print(response.text)
        print("="*70)
        
        # Template marker detection
        print(f"\n[TEMPLATE ENGINE MARKERS]")
        
        # Jinja2 patterns
        jinja2_vars = re.findall(r'\{\{\s*([^}]{1,100}?)\s*\}\}', response.text)
        jinja2_blocks = re.findall(r'\{%\s*([^%]{1,100}?)\s*%\}', response.text)
        jinja2_comments = re.findall(r'\{#\s*([^#]{1,200}?)\s*#\}', response.text)
        
        if jinja2_vars:
            print(f"  ✓ Jinja2 Variables ({len(jinja2_vars)} found):")
            unique_vars = sorted(set(jinja2_vars))[:15]
            for var in unique_vars:
                print(f"    → {{ {{ {var} }} }}")
            if len(unique_vars) < len(set(jinja2_vars)):
                print(f"    ... and {len(set(jinja2_vars)) - len(unique_vars)} more unique variables")
        
        if jinja2_blocks:
            print(f"  ✓ Jinja2 Control Blocks ({len(jinja2_blocks)} found):")
            unique_blocks = sorted(set(jinja2_blocks))[:10]
            for block in unique_blocks:
                print(f"    → {{% {block} %}}")
        
        if jinja2_comments:
            print(f"  ✓ Jinja2 Comments ({len(jinja2_comments)} found):")
            for comment in jinja2_comments[:5]:
                print(f"    → {{# {comment} #}}")
        
        # Other template engines
        if not jinja2_vars and not jinja2_blocks:
            # Check for other patterns
            mustache_vars = re.findall(r'\{\{\s*[^}]+\s*\}\}', response.text)
            if mustache_vars:
                print(f"  ! Alternative template markers found")
        
        # Debug/trace patterns
        print(f"\n[DEBUG/DIAGNOSTIC INFORMATION]")
        debug_indicators = []
        
        debug_patterns = {
            'traceback': r'traceback',
            'exception': r'exception',
            'error_': r'error',
            'debug_': r'debug',
            'werkzeug': r'werkzeug',
            'flask_debug': r'flask.*debug',
            'route_info': r'route|endpoint|view_function',
            'call_stack': r'call_stack|stack_trace',
            'template_debug': r'template.*debug|debug.*template'
        }
        
        for name, pattern in debug_patterns.items():
            matches = re.finditer(pattern, response.text, re.IGNORECASE | re.MULTILINE)
            for match in matches:
                # Get surrounding context
                start = max(0, match.start() - 150)
                end = min(len(response.text), match.end() + 150)
                context = response.text[start:end].replace('\n', ' ').strip()
                debug_indicators.append((name, context))
        
        if debug_indicators:
            print(f"  Found {len(debug_indicators)} debug indicators:")
            for name, context in debug_indicators[:8]:
                print(f"    • {name}: ...{context}...")
        else:
            print(f"  No explicit debug information found")
        
        # HTML comments analysis
        html_comments = re.findall(r'<!--(?!-*>)([^-]|-[^-]|--[^>])*-->', response.text, re.DOTALL)
        if html_comments:
            print(f"\n[HTML COMMENTS] ({len(html_comments)} found)")
            for i, comment in enumerate(html_comments[:10], 1):
                clean_comment = re.sub(r'\s+', ' ', comment).strip()
                if len(clean_comment) > 0:
                    print(f"  {i}. {clean_comment[:120]}")
                    
                    # Check for route/view comments
                    if any(keyword in clean_comment.lower() for keyword in ['route', 'view', 'template', 'debug']):
                        print(f"     → Contains potential architectural information!")
        
        # Form analysis
        if endpoint_name == "PAGE (/page)" or 'form' in response.text.lower():
            print(f"\n[FORM STRUCTURE ANALYSIS]")
            forms = re.findall(r'<form([^>]*)>(.*?)</form>', response.text, re.DOTALL | re.IGNORECASE)
            
            for i, (attrs, content) in enumerate(forms, 1):
                print(f"  Form {i}:")
                print(f"    Attributes: {attrs.strip()}")
                
                # Extract inputs
                inputs = re.findall(r'<(input|textarea|select)([^>]*)>(.*?)</(textarea|select)>?', content, re.DOTALL | re.IGNORECASE)
                if inputs:
                    print(f"    Fields ({len(inputs)}):")
                    for field in inputs:
                        print(f"      <{field[0]} {field[1]}>")
                
                # Extract actions
                action_match = re.search(r'action=["\']([^"\']+)["\']', attrs, re.IGNORECASE)
                if action_match:
                    print(f"    Action URL: {action_match.group(1)}")
        
        # Static asset analysis
        static_refs = re.findall(r'(src|href|action)=["\']?([^"\'\s]+)', response.text, re.IGNORECASE)
        if static_refs:
            print(f"\n[STATIC ASSETS & ROUTES]")
            unique_refs = sorted(set([ref[1] for ref in static_refs]))
            
            # Categorize
            js_files = [r for r in unique_refs if r.endswith(('.js', '.mjs'))]
            css_files = [r for r in unique_refs if r.endswith(('.css', '.scss', '.sass'))]
            img_files = [r for r in unique_refs if r.endswith(('.png', '.jpg', '.jpeg', '.gif', '.svg', '.ico'))]
            other_routes = [r for r in unique_refs if not any(r.endswith(ext) for ext in ['.js', '.css', '.png', '.jpg', '.jpeg', '.gif', '.svg', '.ico', '.mjs', '.scss', '.sass'])]
            
            if js_files:
                print(f"  JavaScript files ({len(js_files)}):")
                for js in js_files[:10]:
                    print(f"    → {js}")
            
            if css_files:
                print(f"  CSS files ({len(css_files)}):")
                for css in css_files[:5]:
                    print(f"    → {css}")
            
            if other_routes:
                print(f"  Additional routes/endpoints ({len(other_routes)}):")
                for route in other_routes[:10]:
                    print(f"    → {route}")
        
        return {
            'status': response.status_code,
            'headers': dict(response.headers),
            'html': response.text,
            'has_jinja': bool(jinja2_vars or jinja2_blocks),
            'jinja_vars': jinja2_vars,
            'jinja_blocks': jinja2_blocks,
            'debug_indicators': debug_indicators
        }
        
    except requests.exceptions.ConnectionError as e:
        print(f"\n[!] CONNECTION ERROR: {str(e)}")
        print(f"[!] Cannot connect to {url}")
        print(f"[!] The target server may not be running or accessible")
        return None
    except requests.exceptions.Timeout:
        print(f"\n[!] TIMEOUT ERROR: Request timed out after 15 seconds")
        return None
    except Exception as e:
        print(f"\n[!] UNEXPECTED ERROR: {type(e).__name__}: {str(e)}")
        import traceback
        traceback.print_exc()
        return None

def main():
    print("="*70)
    print("FLASK APPLICATION ARCHITECTURE ANALYZER")
    print("="*70)
    print(f"Purpose: Extract architectural details and template engine markers")
    print(f"Target: Local Flask development server")
    print("="*70)
    
    # Try multiple potential addresses
    candidates = [
        "http://localhost:5000",
        "http://127.0.0.1:5000",
        "http://0.0.0.0:5000"
    ]
    
    base_url = None
    test_response = None
    
    for url in candidates:
        print(f"\n[*] Testing connectivity to {url}...", end=" ")
        try:
            test_response = requests.get(url, timeout=5)
            print(f"✓ Connected (Status: {test_response.status_code})")
            base_url = url
            break
        except:
            print(f"✗ Failed")
            continue
    
    if not base_url:
        print(f"\n[!] CRITICAL: Cannot connect to Flask application")
        print(f"[!] Please ensure the Flask server is running on port 5000")
        return
    
    print(f"\n[✓] Using base URL: {base_url}")
    
    # Analyze root endpoint
    print(f"\n{'='*70}")
    print("PHASE 1: ROOT ENDPOINT (/) ANALYSIS")
    print(f"{'='*70}")
    root_data = analyze_endpoint_detailed(f"{base_url}/", "ROOT")
    
    # Short pause between requests
    time.sleep(0.5)
    
    # Analyze /page endpoint
    print(f"\n{'='*70}")
    print("PHASE 2: PAGE ENDPOINT (/page) ANALYSIS")
    print(f"{'='*70}")
    page_data = analyze_endpoint_detailed(f"{base_url}/page", "PAGE")
    
    # Final summary
    print(f"\n{'='*70}")
    print("ARCHITECTURAL SUMMARY")
    print(f"{'='*70}")
    
    if root_data and root_data['has_jinja']:
        print(f"✓ Jinja2 template engine confirmed on root endpoint")
    if page_data and page_data['has_jinja']:
        print(f"✓ Jinja2 template engine confirmed on /page endpoint")
    
    server_detected = False
    if root_data:
        server_header = root_data['headers'].get('Server', '').lower()
        if 'werkzeug' in server_header:
            print(f"✓ Flask Development Server (Werkzeug) confirmed")
            server_detected = True
    
    if not server_detected and page_data:
        server_header = page_data['headers'].get('Server', '').lower()
        if 'werkzeug' in server_header:
            print(f"✓ Flask Development Server (Werkzeug) confirmed")
    
    if root_data or page_data:
        data = root_data or page_data
        xpb = data['headers'].get('X-Powered-By', '').lower()
        if 'flask' in xpb or 'jinja' in xpb:
            print(f"✓ Flask/Jinja2 stack confirmed via X-Powered-By header")
    
    print(f"\n{'='*70}")
    print("ANALYSIS COMPLETE")
    print(f"{'='*70}")

if __name__ == "__main__":
    main()

