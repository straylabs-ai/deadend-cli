import requests
import re
import sys

def analyze_endpoint(url, endpoint_name):
    """Analyze a single endpoint for Flask/Jinja2 artifacts"""
    print(f"\n{'='*60}")
    print(f"ANALYZING ENDPOINT: {endpoint_name}")
    print(f"URL: {url}")
    print(f"{'='*60}")
    
    try:
        response = requests.get(url, timeout=10)
        
        # Basic response info
        print(f"\n[+] Status Code: {response.status_code}")
        print(f"[+] Response Time: {response.elapsed.total_seconds()} seconds")
        print(f"[+] Content Length: {len(response.text)} bytes")
        
        # Headers analysis
        print(f"\n[+] HTTP HEADERS:")
        for header, value in response.headers.items():
            print(f"  {header}: {value}")
        
        # Check for Flask-specific headers
        server_header = response.headers.get('Server', '').lower()
        if 'werkzeug' in server_header or 'wsgi' in server_header:
            print(f"\n[✓] Flask Development Server Detected (Werkzeug)")
        if 'x-powered-by' in response.headers:
            xpb = response.headers['X-Powered-By'].lower()
            if 'flask' in xpb or 'jinja' in xpb:
                print(f"[✓] Flask/Jinja2 Stack Confirmed via X-Powered-By")
        
        # Full HTML response
        print(f"\n[+] FULL HTML RESPONSE:")
        print("-" * 60)
        print(response.text)
        print("-" * 60)
        
        # Template marker analysis
        print(f"\n[+] TEMPLATE ENGINE ANALYSIS:")
        
        # Jinja2 markers
        jinja_vars = re.findall(r'\{\{[^}]+\}\}', response.text)
        jinja_blocks = re.findall(r'\{%[^%]+%\}', response.text)
        jinja_comments = re.findall(r'\{#[^#]+#\}', response.text)
        
        if jinja_vars:
            print(f"  [✓] Found {len(jinja_vars)} Jinja2 variable expressions:")
            for var in jinja_vars[:10]:  # Show first 10
                print(f"    - {var}")
            if len(jinja_vars) > 10:
                print(f"    ... and {len(jinja_vars) - 10} more")
        
        if jinja_blocks:
            print(f"  [✓] Found {len(jinja_blocks)} Jinja2 control blocks:")
            for block in jinja_blocks[:10]:
                print(f"    - {block}")
            if len(jinja_blocks) > 10:
                print(f"    ... and {len(jinja_blocks) - 10} more")
        
        if jinja_comments:
            print(f"  [✓] Found {len(jinja_comments)} Jinja2 comments:")
            for comment in jinja_comments[:5]:
                print(f"    - {comment}")
        
        # Other template engines
        angular_vars = re.findall(r'\{\{[^}]+\}\}', response.text)
        if angular_vars and not jinja_vars:
            print(f"  [!] Possible Angular/Mustache templates detected")
        
        # Comment analysis
        html_comments = re.findall(r'<!--.*?-->', response.text, re.DOTALL)
        if html_comments:
            print(f"\n[+] HTML COMMENTS FOUND ({len(html_comments)}):")
            for i, comment in enumerate(html_comments[:10], 1):
                clean_comment = comment.replace('\n', ' ').strip()
                print(f"  {i}. {clean_comment[:100]}...")
                # Check for debug/route info in comments
                if len(clean_comment) < 200:
                    print(f"     Full: {clean_comment}")
                if any(word in clean_comment.lower() for word in ['route', 'view', 'function', 'debug', 'flask']):
                    print(f"     [✓] Contains architectural info!")
        
        # Static file references
        static_files = re.findall(r'(?:src|href)=["\'][^"\']*\.(?:js|css|png|jpg|jpeg|gif|ico|svg)["\']', response.text, re.I)
        if static_files:
            print(f"\n[+] STATIC FILE REFERENCES ({len(static_files)}):")
            for ref in static_files[:10]:
                print(f"  {ref}")
        
        # Form analysis (for /page specifically)
        if 'form' in response.text.lower():
            forms = re.findall(r'<form[^>]*>.*?</form>', response.text, re.DOTALL | re.I)
            print(f"\n[+] FORMS DETECTED ({len(forms)}):")
            for i, form in enumerate(forms, 1):
                print(f"\n  Form {i}:")
                # Extract form attributes
                form_attrs = re.findall(r'<form([^>]*)>', form, re.I)
                if form_attrs:
                    print(f"    Attributes: {form_attrs[0]}")
                
                # Extract input fields
                inputs = re.findall(r'<input[^>]*>', form, re.I)
                print(f"    Input fields ({len(inputs)}):")
                for inp in inputs:
                    print(f"      {inp}")
                
                # Extract textarea/select
                textareas = re.findall(r'<textarea[^>]*>.*?</textarea>', form, re.DOTALL | re.I)
                selects = re.findall(r'<select[^>]*>.*?</select>', form, re.DOTALL | re.I)
                if textareas:
                    print(f"    Textareas: {len(textareas)}")
                if selects:
                    print(f"    Selects: {len(selects)}")
        
        # JavaScript analysis
        scripts = re.findall(r'<script[^>]*>.*?</script>', response.text, re.DOTALL | re.I)
        inline_scripts = [s for s in scripts if not re.search(r'src=["\']', s, re.I)]
        if inline_scripts:
            print(f"\n[+] INLINE JAVASCRIPT ({len(inline_scripts)} blocks):")
            for i, script in enumerate(inline_scripts[:3], 1):
                # Extract script content
                content_match = re.search(r'<script[^>]*>(.*?)</script>', script, re.DOTALL | re.I)
                if content_match:
                    content = content_match.group(1).strip()
                    if len(content) < 200:
                        print(f"  Script {i}: {content[:100]}")
                    else:
                        print(f"  Script {i}: {content[:100]}... (truncated)")
        
        # Error/debug patterns
        debug_patterns = [
            r'traceback',
            r'exception',
            r'error',
            r'debug',
            r'werkzeug',
            r'jinja2',
            r'flask'
        ]
        
        found_debug = []
        for pattern in debug_patterns:
            if re.search(pattern, response.text, re.I):
                # Find context around the pattern
                matches = re.finditer(pattern, response.text, re.I)
                for match in matches:
                    start = max(0, match.start() - 100)
                    end = min(len(response.text), match.end() + 100)
                    context = response.text[start:end].replace('\n', ' ')
                    found_debug.append((pattern, context))
        
        if found_debug:
            print(f"\n[⚠️] DEBUG/ERROR PATTERNS FOUND ({len(found_debug)}):")
            for pattern, context in found_debug[:5]:
                print(f"  Pattern '{pattern}' found near: ...{context}...")
        
        # Template context hints (variables in templates)
        if jinja_vars:
            print(f"\n[+] TEMPLATE VARIABLES (potential data flow):")
            var_names = set()
            for var in jinja_vars:
                # Extract variable names from {{ variable }}
                name_match = re.search(r'\{\{\s*([^}|]+)', var)
                if name_match:
                    var_names.add(name_match.group(1).strip())
            
            for name in sorted(var_names)[:20]:
                print(f"  - {name}")
            if len(var_names) > 20:
                print(f"  ... and {len(var_names) - 20} more variables")
        
        return {
            'status': response.status_code,
            'headers': dict(response.headers),
            'content': response.text,
            'has_jinja': bool(jinja_vars or jinja_blocks),
            'jinja_vars': jinja_vars,
            'jinja_blocks': jinja_blocks,
            'forms_detected': 'form' in response.text.lower()
        }
        
    except Exception as e:
        print(f"\n[!] ERROR accessing {url}: {str(e)}")
        return None

def main():
    base_url = "http://localhost:5000"  # Default Flask development server
    
    # Test root endpoint
    print("Starting Flask Application Architecture Analysis")
    print("Target: Development server on localhost:5000")
    
    root_data = analyze_endpoint(f"{base_url}/", "ROOT (\)")
    
    # Test /page endpoint
    page_data = analyze_endpoint(f"{base_url}/page", "PAGE (/page)")
    
    # Summary
    print(f"\n{'='*60}")
    print("ARCHITECTURAL SUMMARY")
    print(f"{'='*60}")
    
    if root_data and root_data['has_jinja']:
        print("[✓] Jinja2 Template Engine confirmed on root endpoint")
    
    if page_data and page_data['has_jinja']:
        print("[✓] Jinja2 Template Engine confirmed on /page endpoint")
    
    if root_data and 'werkzeug' in root_data['headers'].get('Server', '').lower():
        print("[✓] Flask Development Server (Werkzeug) detected")
    
    if page_data and page_data['forms_detected']:
        print("[✓] HTML forms detected on /page endpoint (potential injection points)")
    
    print(f"\nAnalysis complete. Check detailed output above.")

if __name__ == "__main__":
    main()

