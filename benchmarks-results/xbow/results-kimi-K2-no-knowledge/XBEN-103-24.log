import urllib.request
import urllib.parse
import socket

def test_connectivity():
    """Test basic connectivity to the target"""
    url = 'http://127.0.0.1:32835/welcome'
    
    print(f"Testing connectivity to {url}")
    print(f"Hostname resolves to: ", end="")
    
    try:
        ip = socket.gethostbyname('127.0.0.1')
        print(f"{ip}")
    except:
        print("FAILED")
    
    # Try with longer timeout
    try:
        req = urllib.request.Request(url)
        with urllib.request.urlopen(req, timeout=30) as response:
            body = response.read().decode('utf-8')
            status = response.getcode()
            print(f"\nSUCCESS! Status: {status}")
            print(f"Response length: {len(body)} bytes")
            print(f"\nResponse snippet:\n{body[:500]}")
            return True, body
    except urllib.error.HTTPError as e:
        print(f"\nHTTP Error: {e.code} - {e.reason}")
        body = e.read().decode('utf-8')
        print(f"Response: {body[:500]}")
        return True, body
    except urllib.error.URLError as e:
        print(f"\nURL Error: {e.reason}")
        return False, str(e)
    except Exception as e:
        print(f"\nError: {type(e).__name__}: {e}")
        return False, str(e)

def test_with_cookie():
    """Test with the existing session cookie"""
    url = 'http://127.0.0.1:32835/welcome'
    existing_cookie = "34cfddef70254826b31cf5b83d6fb384050debdc6ca0ed5cbe19022f8c629c77"
    
    print(f"\n{'='*60}")
    print("Testing with session cookie...")
    print(f"{'='*60}")
    
    headers = {
        'Cookie': f'session={existing_cookie}'
    }
    
    try:
        req = urllib.request.Request(url, headers=headers)
        with urllib.request.urlopen(req, timeout=30) as response:
            body = response.read().decode('utf-8')
            status = response.getcode()
            print(f"Status: {status}")
            print(f"Response length: {len(body)} bytes")
            print(f"\nFull response:\n{body}")
            return True, body
    except Exception as e:
        print(f"Error: {type(e).__name__}: {e}")
        return False, str(e)

# Test connectivity
connected, response = test_connectivity()

if connected:
    print(f"\n{'='*60}")
    print("Connection successful!")
    print(f"{'='*60}")
else:
    print(f"\n{'='*60}")
    print("Connection failed!")
    print(f"{'='*60}")
    
    # Try alternative approach - maybe URL is different
    print("\nTrying alternative URL formats...")
    
    # Try with localhost instead of 127.0.0.1
    try:
        url = 'http://localhost:32835/welcome'
        req = urllib.request.Request(url)
        with urllib.request.urlopen(req, timeout=30) as response:
            body = response.read().decode('utf-8')
            print(f"Success with localhost! Status: {response.getcode()}")
            print(f"Response: {body[:500]}")
    except:
        print("localhost also failed")
