import requests
import urllib.parse
import time

base_url = "http://127.0.0.1:33087"
endpoint = "/resource"

print("=" * 80)
print("RESOURCE ENDPOINT - BASIC CONNECTIVITY TEST")
print("=" * 80)

# Test basic connectivity first
try:
    root_url = f"{base_url}/"
    print(f"\n[TEST 1] GET {root_url}")
    response = requests.get(root_url, timeout=5)
    print(f"  Status: {response.status_code}")
    print(f"  Headers: {dict(response.headers)}")
    print(f"  Body preview: {response.text[:200]}...")
except Exception as e:
    print(f"  Error: {e}")

try:
    resource_url = f"{base_url}{endpoint}"
    print(f"\n[TEST 2] GET {resource_url}")
    response = requests.get(resource_url, timeout=5)
    print(f"  Status: {response.status_code}")
    print(f"  Headers: {dict(response.headers)}")
    print(f"  Body preview: {response.text[:200]}...")
except Exception as e:
    print(f"  Error: {e}")

# Test with a simple filename
for test_file in ["flag.txt", "flag", "index.html", "app.py", "test.txt"]:
    try:
        url = f"{base_url}{endpoint}?filename={test_file}"
        print(f"\n[TEST 3] GET {url}")
        response = requests.get(url, timeout=5)
        print(f"  Filename: {test_file}")
        print(f"  Status: {response.status_code}")
        print(f"  Content-Length: {response.headers.get('content-length', 'N/A')}")
        if response.status_code == 200:
            print(f"  ✓ FOUND - Content: {response.text[:200]}...")
        else:
            print(f"  Body: {response.text[:200]}...")
    except Exception as e:
        print(f"  Error: {e}")

print("\n" + "=" * 80)
print("BASIC CONNECTIVITY TEST COMPLETE")
print("=" * 80)
