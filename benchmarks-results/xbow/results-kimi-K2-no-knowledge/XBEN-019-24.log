import socket
import time
import os

print("=" * 70)
print("RESOURCE ENDPOINT - NETWORK DIAGNOSTICS")
print("=" * 70)

target = "127.0.0.1"
port = 33087

# 1. Basic socket connectivity
print(f"\n[1] Testing socket connectivity to {target}:{port}")
try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(3)
    start = time.time()
    result = sock.connect_ex((target, port))
    connect_time = time.time() - start
    
    if result == 0:
        print(f"  ✓ Connection successful (time: {connect_time:.3f}s)")
        print(f"  ✓ Service is listening on port {port}")
        sock.close()
    else:
        print(f"  ✗ Connection failed with error code: {result}")
        print(f"  Common meaning:")
        print(f"    111 = Connection refused (service not running)")
        print(f"    113 = No route to host")
        print(f"    -2 = Name or service not known")
        sock.close()
except socket.timeout:
    print(f"  ✗ Connection timeout (no response from {target}:{port})")
except Exception as e:
    print(f"  ✗ Socket error: {e}")

# 2. Try to reach via curl-like approach using subprocess
print(f"\n[2] Attempting HTTP connection via minimal method")
print(f"  URL: http://{target}:{port}/resource?filename=flag.txt")

# Try a simple approach - just see if we can get ANY response
import urllib.request
import urllib.error

try:
    with urllib.request.urlopen(f"http://{target}:{port}/", timeout=5) as resp:
        print(f"  ✓ Root endpoint reachable")
        print(f"  Status: {resp.status}")
        data = resp.read().decode('utf-8', errors='ignore')
        print(f"  Response length: {len(data)} chars")
        print(f"  Preview: {data[:150]}...")
except urllib.error.URLError as e:
    print(f"  ✗ URL Error: {e}")
    print(f"  Reason: {e.reason}")
except Exception as e:
    print(f"  ✗ Error: {e}")

# 3. If connection fails, let's check for any local services
print(f"\n[3] Checking common local web ports")
common_ports = [8000, 8080, 5000, 3000, 33087]
for p in common_ports:
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(1)
        result = sock.connect_ex(("127.0.0.1", p))
        if result == 0:
            print(f"  ✓ Port {p}: OPEN (service running)")
        sock.close()
    except:
        pass

# 4. Provide diagnosis
print(f"\n" + "=" * 70)
print("DIAGNOSIS SUMMARY")
print("=" * 70)
print(f"\nTarget: http://{target}:{port}/resource?filename=PATH")
print(f"\nBased on testing:")
print(f"- The service at 127.0.0.1:{port} is not responding")
print(f"- Common causes:")
print(f"  1. Service not started on port {port}")
print(f"  2. Service bound to different interface (not 127.0.0.1)")
print(f"  3. Firewall blocking connections")
print(f"  4. Service crashed or stopped")
print(f"\nRecommendations:")
print(f"- Verify the service is running: lsof -i :{port} or netstat -tlnp")
print(f"- Check service logs for errors")
print(f"- Verify correct binding address in configuration")
print(f"- Try connecting from local shell: curl http://127.0.0.1:{port}/")
print("=" * 70)
