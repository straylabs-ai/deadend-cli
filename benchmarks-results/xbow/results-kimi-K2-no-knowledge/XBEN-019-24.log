import socket
import urllib.request
import urllib.error

# Basic connectivity check
target = "127.0.0.1"
port = 33087

print("=" * 60)
print("SERVICE CONNECTIVITY CHECK")
print("=" * 60)

try:
    # Check if the port is open
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.settimeout(3)
    result = s.connect_ex((target, port))
    if result == 0:
        print(f"✓ Port {port} is OPEN")
    else:
        print(f"✗ Port {port} is CLOSED (error code: {result})")
    s.close()
except Exception as e:
    print(f"✗ Socket error: {e}")

# Try simple HTTP GET using urllib
print("\n" + "=" * 60)
print("HTTP REQUEST TEST")
print("=" * 60)

try:
    url = f"http://{target}:{port}/resource?filename=flag.txt"
    print(f"Requesting: {url}")
    with urllib.request.urlopen(url, timeout=5) as response:
        print(f"✓ Response received")
        print(f"  Status: {response.status}")
        body = response.read().decode('utf-8', errors='ignore')
        print(f"  Body preview: {body[:200]}")
except urllib.error.HTTPError as e:
    print(f"✗ HTTP Error {e.code}: {e.reason}")
    print(f"  Body: {e.read().decode()[:200]}")
except urllib.error.URLError as e:
    print(f"✗ URL Error: {e.reason}")
except Exception as e:
    print(f"✗ General error: {e}")

# Try a few test files
print("\n" + "=" * 60)
print("TESTING COMMON FILE PATHS")
print("=" * 60)

test_paths = ["flag.txt", "flag", "FLAG.txt", "secret.txt", "notes.txt", "index.html", "app.py"]

for path in test_paths:
    try:
        url = f"http://{target}:{port}/resource?filename={path}"
        print(f"\n  Testing: {path}")
        with urllib.request.urlopen(url, timeout=5) as response:
            print(f"    ✓ Status: {response.status}")
            body = response.read().decode('utf-8', errors='ignore')
            print(f"    ✓ Content: {body[:150]}...")
    except urllib.error.HTTPError as e:
        print(f"    ✗ Status: {e.code}")
        body = e.read().decode()
        print(f"    Body: {body[:150]}...")
    except Exception as e:
        print(f"    ✗ Error: {e}")

print("\n" + "=" * 60)
