    ("fl%61g.txt", "Double enc: partial filename encoding"),
    ("%66%6c%61%67%2e%74%78%74", "Double enc: fully encoded filename"),
]

for path, desc in test_cases_6:
    results.append(test_path(path, desc))

# Test 7: Common application files
print("\n\n[TEST GROUP 7] Common Application Files")
print("-" * 70)
test_cases_7 = [
    ("app.py", "App file: app.py"),
    ("main.py", "App file: main.py"),
    ("config.py", "App file: config.py"),
