    ("docker-compose.yml", "App file: docker-compose.yml"),
    ("Procfile", "App file: Procfile"),
    (".env", "App file: .env"),
]

for path, desc in test_cases_7:
    results.append(test_path(path, desc))

# Test 8: System info files (to understand filtering)
print("\n\n[TEST GROUP 8] System Info Files (Filter Testing)")
print("-" * 70)
test_cases_8 = [
    ("/etc/passwd", "Sensitive: /etc/passwd"),
    ("/etc/hosts", "Sensitive: /etc/hosts"),
    ("etc/passwd", "Sensitive: etc/passwd (no leading slash)"),
    ("etc/hosts", "Sensitive: etc/hosts (no leading slash)"),
]

for path, desc in test_cases_8:
    results.append(test_path(path, desc))

# Summary analysis
print("\n\n" + "=" * 70)
print("ANALYSIS SUMMARY")
print("=" * 70)

successful_accesses = [r for r in results if r['status'] == 200]
blocked_by_filter = [r for r in results if r['status'] in [400, 403]]
not_found = [r for r in results if r['status'] == 404]

print(f"\n✓ Successfully accessed files: {len(successful_accesses)}")
for r in successful_accesses:
    print(f"  - {r['description']} (length: {len(r['content'])} chars)")

print(f"\n✗ Blocked by filter: {len(blocked_by_filter)}")
for r in blocked_by_filter:
    print(f"  - {r['description']}")

print(f"\n✗ Not found (404): {len(not_found)}")
print(f"  Total not found: {len(not_found)} items")

# Filter pattern analysis
print(f"\n" + "=" * 70)
print("FILTERING BEHAVIOR PATTERNS")
print("=" * 70)

# Check if absolute paths are filtered
abs_paths_tested = [r for r in results if r['description'].startswith('Absolute:')]
abs_paths_working = [r for r in abs_paths_tested if r['status'] == 200]
print(f"\nAbsolute paths test: {len(abs_paths_working)}/tested successful")

# Check if traversal is filtered
traversal_tested = [r for r in results if 'Traversal:' in r['description']]
traversal_working = [r for r in traversal_tested if r['status'] == 200]
print(f"Path traversal test: {len(traversal_working)}/tested successful")

# Check system file access attempts
system_tested = [r for r in results if 'Sensitive:' in r['description']]
system_working = [r for r in system_tested if r['status'] == 200]
print(f"System file access: {len(system_working)}/tested successful")

# List all successfully accessed content
if successful_accesses:
    print(f"\n" + "=" * 70)
    print("SUCCESSFULLY ACCESSED CONTENT")
    print("=" * 70)
    for r in successful_accesses:
        print(f"\n[{r['description']}]")
        print(f"Content:\n{r['content'][:500]}")
        if len(r['content']) > 500:
            print(f"[... truncated, full length: {len(r['content'])} chars ...]")

print(f"\n\n" + "=" * 70)
print("END OF TEST SUITE")
print("=" * 70)
