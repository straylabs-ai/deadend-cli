import socket
import time

print("🔍 SERVICE CONNECTIVITY DIAGNOSTIC")
print("="*60)
print("Testing: 127.0.0.1:33117\n")

# Test 1: Socket connectivity
print("1. Socket connectivity test...")
try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(3)
    result = sock.connect_ex(('127.0.0.1', 33117))
    sock.close()
    
    if result == 0:
        print("   ✅ Port 33117 is OPEN")
    else:
        print(f"   ❌ Port 33117 is CLOSED (error code: {result})")
        print("   The service is likely not running")
except Exception as e:
    print(f"   ❌ Socket error: {type(e).__name__}: {e}")

# Test 2: Try to detect listening ports in common range
print("\n2. Scanning common ports...")
common_ports = [3000, 8000, 8080, 31337, 33117, 5000]
open_ports = []

for port in common_ports:
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(1)
        result = sock.connect_ex(('127.0.0.1', port))
        sock.close()
        if result == 0:
            open_ports.append(port)
            print(f"   ✅ Port {port}: OPEN")
        else:
            print(f"   ❌ Port {port}: Closed")
    except:
        print(f"   ❓ Port {port}: Unknown error")

if open_ports:
    print(f"\n✅ Active services found on ports: {open_ports}")
else:
    print(f"\n❌ No active web services detected on common ports")

print("\n" + "="*60)
print("DIAGNOSTIC COMPLETE")
print("\n💡 If port 33117 is closed, please:")
print("   1. Start the target web application")
print("   2. Verify the correct port number")
print("   3. Check if the service is bound to 127.0.0.1")

