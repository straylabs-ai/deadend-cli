import socket
import sys

print("🔍 BASIC CONNECTIVITY TEST")
print("="*50)
print("Target: 127.0.0.1:33117\n")

# Simple socket test to see if port is listening
try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(3)
    result = sock.connect_ex(('127.0.0.1', 33117))
    sock.close()
    
    if result == 0:
        print("✅ PORT 33117 IS OPEN")
        print("   The service appears to be running")
        print("\nNext step: Attempt HTTP request...")
    else:
        print(f"❌ PORT 33117 IS CLOSED (Error: {result})")
        print("   The service is not running or not listening on this port")
        print("\n💡 Please ensure the target service is started")
        print("   Check with: lsof -i :33117 or netstat -tln | grep 33117")
        
except Exception as e:
    print(f"❌ Socket test failed: {type(e).__name__}")
    print(f"   Error: {e}")

print("\n" + "="*50)
