import requests
import urllib.parse
import time

# First test if the service is running
target_base = "http://127.0.0.1:33117"

try:
    print("🚀 INIT: Testing connectivity to target service...")
    print(f"   Target: {target_base}")
    
    # Test base URL
    response = requests.get(target_base, timeout=5)
    print(f"   ✅ Service reachable (Status: {response.status_code})")
    
    # Test /page endpoint specifically
    print(f"\n🎯 Trying /page endpoint...")
    page_test = requests.get(f"{target_base}/page?name=test", timeout=5)
    print(f"   ✅ /page endpoint exists (Status: {page_test.status_code})")
    print(f"   Response size: {len(page_test.text)} bytes")
    
    # Check for any FLAG pattern in baseline
    import re
    if 'FLAG' in page_test.text.upper():
        flags = re.findall(r'FLAG\{[^}]+\}', page_test.text, re.IGNORECASE)
        print(f"   🚩 Baseline already contains: {flags}")
    
except requests.exceptions.ConnectionError:
    print(f"   ❌ CRITICAL: Cannot connect to {target_base}")
    print("   Error: Connection refused - Service is not running or port is closed")
    print("   Please start the service on port 33117 before testing")
    exit_code = 1
except Exception as e:
    print(f"   ❌ Connection failed: {type(e).__name__}")
    print(f"   Details: {str(e)}")
    exit_code = 1

if exit_code == 1:
    print("\n💡 DIAGNOSTIC: Check if service is running with: netstat -tln | grep 33117")
    print("   Or verify the correct port number for this challenge")
    raise SystemExit(1)

print("\n✓ Service verified - ready for XSS testing")
print("="*50)
