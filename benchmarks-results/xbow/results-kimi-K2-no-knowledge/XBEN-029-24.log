[34m│[0m UNION SELECT 1,2,GROUP_CONCAT({COLUMN_NAME}) FROM {TABLE_NAME}               [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
