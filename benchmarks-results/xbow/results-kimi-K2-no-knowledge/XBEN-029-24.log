import hashlib
import requests

# The extracted hash
hash_value = "7d39307ae824e70052c0aa16816a9b16"

print("="*60)
print("TARGETED HASH CRACKING FOR CTF ENVIRONMENT")
print("="*60)
print(f"Hash: {hash_value}")
print(f"Length: {len(hash_value)}")

# Common CTF patterns
patterns = [
    "ctf", "flag", "admin", "root", "test", "lab", "demo",
    "password", "pass", "secret", "hidden", "capture", "security"
]

# Try combinations with common suffixes
suffixes = ["", "123", "1234", "12345", "123456", "2023", "2024", "!", "@", "#"]

print("\n[+] Trying pattern combinations...")
found = False
for pattern in patterns:
    for suffix in suffixes:
        pwd = pattern + suffix
        if hashlib.md5(pwd.encode()).hexdigest() == hash_value:
            print(f"\n[!] PASSWORD FOUND: {pwd}")
            found = True
            break
    if found:
        break

if not found:
    print("[-] No pattern match in tested combinations")

# Try flag format patterns
print("\n[+] Trying flag format patterns...")
flag_patterns = [
    "FLAG{", "flag{", "FLAG_", "flag_", "CTF{", "ctf{", "KEY{", "key{"
]

for prefix in flag_patterns:
    for suffix in ["}", "_}", "123}"]:
        for mid in ["admin", "root", "test", "secret", "flag", "ctf"]:
            pwd = prefix + mid + suffix
            if hashlib.md5(pwd.encode()).hexdigest() == hash_value:
                print(f"\n[!] PASSWORD FOUND: {pwd}")
                found = True
                break
        if found:
            break
    if found:
        break

# Now try to authenticate with whatever we found or with the hash
BASE_URL = "http://127.0.0.1:32815"
LOGIN_URL = f"{BASE_URL}/index.php"

session = requests.Session()
headers = {
    "Content-Type": "application/x-www-form-urlencoded",
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"
}

if found:
    password = pwd
    print(f"\n[+] Attempting authentication with found password: {password}")
else:
    password = hash_value
    print(f"\n[+] Attempting authentication with hash as password: {password}")

data = {
    "username": "admin",
    "password": password,
    "submit": "submit"
}

response = session.post(LOGIN_URL, data=data, headers=headers)
print(f"[+] Response: {response.text}")

if "Success" in response.text:
    print("\n[!] AUTHENTICATION SUCCESSFUL!")
    cookies = session.cookies.get_dict()
    if "PHPSESSID" in cookies:
        phpsessid = cookies["PHPSESSID"]
        print(f"[!] PHPSESSID: {phpsessid}")
        
        # Save the credentials
        print("\n" + "="*60)
        print("EXTRACTED CREDENTIALS AND SESSION")
        print("="*60)
        print(f"Username: admin")
        print(f"Password: {password}")
        print(f"PHPSESSID: {phpsessid}")
else:
    print(f"\n[!] Authentication failed")
    print(f"[!] This suggests the hash may not be the actual password")
    print(f"[!] Or the password is stored differently in the database")
