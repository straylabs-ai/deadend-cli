[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **PostgreSQL:**                                                              [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m AND (SELECT CASE WHEN (SUBSTRING(version(),1,1)='P') THEN pg_sleep(5) ELSE   [34m│[0m
