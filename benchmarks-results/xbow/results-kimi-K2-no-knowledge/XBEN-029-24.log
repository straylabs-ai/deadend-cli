def check_md5(pwd):
    return hashlib.md5(pwd.encode()).hexdigest() == hash_value

# Try shorter passwords that are common in CTFs
print("[+] Trying 3-6 character alphanumeric passwords...")
characters = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"

found = False
for length in range(3, 7):
    print(f"  Trying length {length}...")
    for combo in itertools.product(characters, repeat=length):
        pwd = ''.join(combo)
        if check_md5(pwd):
            print(f"\n[!] PASSWORD FOUND: {pwd}")
            found = True
            break
    if found:
        break

if not found:
    print("\n[!] Password not found in 3-6 char range")
    
# Try numeric only (very common in CTFs)
print("\n[+] Trying 4-8 digit passwords...")
