[34m│[0m ### Blind Injection                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Boolean-Based Blind:**                                                     [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **MySQL:**                                                                   [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m AND SUBSTRING(version(),1,1)='5'                                             [34m│[0m
