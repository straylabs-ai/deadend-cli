import base64
import requests
import urllib.parse
import time

# Configuration
base_url = "http://127.0.0.1:32834"
cookie_name = "captcha"
target_cookie = "2mArom13+gd4q/dQTQu4aFVpwOkejaqPtWuV0Kyn2ls="

# Decode the base64 cookie
cookie_bytes = base64.b64decode(target_cookie)
print(f"[+] Original cookie decoded: {cookie_bytes.hex()}")
print(f"[+] Cookie length: {len(cookie_bytes)} bytes")

# Split into blocks (AES block size is 16 bytes)
BLOCK_SIZE = 16
blocks = [cookie_bytes[i:i+BLOCK_SIZE] for i in range(0, len(cookie_bytes), BLOCK_SIZE)]
print(f"[+] Number of blocks: {len(blocks)}")
for i, block in enumerate(blocks):
    print(f"  Block {i}: {block.hex()}")

# First, let's test the registration endpoint to understand error responses
def test_registration(captcha_cookie_value):
    """Test registration with a modified cookie to see error responses"""
    session = requests.Session()
    
    # Get the registration page to extract CSRF token
    try:
        resp = session.get(base_url, timeout=10)
        print(f"\n[+] GET / status: {resp.status_code}")
        
        # Look for CSRF token in the response
        import re
        csrf_match = re.search(r'name="csrf_token" value="([^"]+)"', resp.text)
        if csrf_match:
            csrf_token = csrf_match.group(1)
            print(f"[+] CSRF token found: {csrf_token[:50]}...")
        else:
            print("[-] CSRF token not found in response")
            csrf_token = ""
            
        # Look for any error patterns in response
        print(f"[+] Sample of response:\n{resp.text[:500]}...")
        
        # Try to submit with original cookie
        # Create modified cookie and test
        modified_cookie = base64.b64encode(cookie_bytes).decode()
        session.cookies.set(cookie_name, modified_cookie)
        
        # Submit registration form
        data = {
            'csrf_token': csrf_token,
            'username': 'testuser',
            'captcha': 'test',
            'submit': 'Submit'
        }
        
        resp2 = session.post(base_url, data=data, timeout=10)
        print(f"\n[+] POST / status: {resp2.status_code}")
        print(f"[+] Response length: {len(resp2.text)} bytes")
        print(f"[+] Response sample:\n{resp2.text[:500]}...")
        
        return resp.text, resp2.text
        
    except Exception as e:
        print(f"[-] Error during test: {e}")
        return None, None

print("\n[+] Testing registration endpoint to understand response patterns...")
get_resp, post_resp = test_registration(target_cookie)

if get_resp and post_resp:
    print("\n[+] Test completed successfully")
    print(f"[+] Can analyze differences in error responses")
else:
    print("\n[-] Test failed")
