#!/usr/bin/env python3

hex_string = 'ca6f25af617cf00e70acf1554908ba69'

print(f"Input hex string: {hex_string}")
print(f"Length: {len(hex_string)} chars ({len(hex_string)//2} bytes)")
print()

# Convert hex to bytes
try:
    byte_data = bytes.fromhex(hex_string)
    print(f"[+] Converted to bytes: {byte_data}")
    print()
    
    # Try UTF-8 decoding
    print("Testing UTF-8 decoding:")
    try:
        utf8_text = byte_data.decode('utf-8')
        print(f"  Success: '{utf8_text}'")
    except UnicodeDecodeError as e:
        print(f"  Failed: {e}")
    print()
    
    # Try ASCII decoding
    print("Testing ASCII decoding:")
    try:
        ascii_text = byte_data.decode('ascii')
        print(f"  Success: '{ascii_text}'")
    except UnicodeDecodeError as e:
        print(f"  Failed: {e}")
    print()
    
    # Try Latin-1 (ISO-8859-1) - it never fails
    print("Testing Latin-1 decoding:")
    latin1_text = byte_data.decode('latin-1')
    print(f"  Success: '{latin1_text}'")
    print()
    
    # Show individual bytes and their ASCII/UTF-8 characters
    print("Byte-by-byte breakdown:")
    print("{:<6} {:<6} {:<8} {:<12} {:<12}".format("Index", "Hex", "Decimal", "ASCII/Char", "Is Readable"))
    print("-" * 50)
    
    readable_chars = []
    for i, byte in enumerate(byte_data):
        char = chr(byte)
        is_readable = 'Yes' if 32 <= byte <= 126 else 'No'
        if 32 <= byte <= 126:  # Printable ASCII range
            readable_chars.append(char)
        
        print("{:<6} {:<6} {:<8} {!r:<12} {:<12}".format(i, "{:02x}".format(byte), byte, char, is_readable))
    
    print()
    print(f"Readable characters extracted: '{''.join(readable_chars)}'")
    print(f"Count: {len(readable_chars)} readable chars out of {len(byte_data)} total bytes")
    print()
    
    # Try to reverse the bytes - sometimes data is stored in reverse
    print("Testing reversed bytes:")
    reversed_bytes = byte_data[::-1]
    print(f"  Reversed bytes: {reversed_bytes}")
    
    try:
        reversed_utf8 = reversed_bytes.decode('utf-8')
        print(f"  UTF-8: '{reversed_utf8}'")
    except:
        print("  UTF-8: Failed")
        
    try:
        reversed_ascii = reversed_bytes.decode('ascii')
        print(f"  ASCII: '{reversed_ascii}'")
    except:
        print("  ASCII: Failed")
        
    reversed_latin1 = reversed_bytes.decode('latin-1')
    print(f"  Latin-1: '{reversed_latin1}'")
    print()
    
    # Extract only alphanumeric characters
    import re
    alphanumeric = re.sub(r'[^a-zA-Z0-9]', '', ''.join(readable_chars))
    print(f"Alphanumeric only: '{alphanumeric}'")
    
    # Try Base64 encoding of the bytes to see if captcha might be base64-encoded
    import base64
    b64_encoded = base64.b64encode(byte_data).decode('ascii')
    print(f"Base64 encoded: '{b64_encoded}'")
    
    try:
        b64_decoded = base64.b64decode(byte_data, validate=True).decode('latin-1')
        print(f"Base64 decoded: '{b64_decoded}'")
    except:
        print("Base64 decode as-is: Not valid base64 input")

except Exception as e:
    print(f"Error: {e}")
