import base64
import os
import sys
import urllib.parse
from typing import Dict, List, Tuple

# Cookie value from context
cookie_value = "2mArom13+gd4q/dQTQu4aFVpwOkejaqPtWuV0Kyn2ls="

print("=" * 80)
print("CAPTCHA COOKIE STRUCTURE ANALYSIS")
print("=" * 80)
print(f"Cookie value: {cookie_value}")
print(f"Cookie length: {len(cookie_value)}")

# Check for URL-safe base64 characters
print(f"\n[1] Base64 Analysis")
print(f"Contains URL-safe characters (+, /): {'+' in cookie_value or '/' in cookie_value}")
print(f"Contains padding (=): {'=' in cookie_value}")

# URL-safe base64 decode
try:
    # Replace URL-safe characters with standard base64
    cookie_standard = cookie_value.replace('-', '+').replace('_', '/')
    decoded = base64.b64decode(cookie_standard)
    print(f"\n[2] URL-Safe Base64 Decode Successful")
    print(f"Decoded bytes length: {len(decoded)} bytes")
    print(f"Raw decoded bytes: {decoded.hex()}")
    print(f"Decoded bytes (repr): {decoded}")
except Exception as e:
    print(f"\n[ERROR] Base64 decode failed: {e}")
    sys.exit(1)

# Entropy analysis
def calculate_entropy(data: bytes) -> float:
    """Calculate Shannon entropy"""
    if not data:
        return 0.0
    
    entropy = 0.0
    for i in range(256):
        pi = float(data.count(i)) / len(data)
        if pi > 0:
            entropy += - pi * (pi.bit_length()) / (len(data).bit_length())
    
    # Normalize to 0-1 range
    max_entropy = len(data) * 8
    if max_entropy > 0:
        return entropy / max_entropy
    return 0.0

# Byte frequency analysis
def byte_frequency_analysis(data: bytes) -> Dict[int, int]:
    """Analyze byte frequencies"""
    freq = {}
    for b in data:
        freq[b] = freq.get(b, 0) + 1
    return freq

print(f"\n[3] Entropy and Structure Analysis")

# Calculate entropy
entropy = 0.0
if decoded:
    import math
    byte_freq = byte_frequency_analysis(decoded)
    data_len = len(decoded)
    for count in byte_freq.values():
        p_x = count / data_len
        entropy += - p_x * math.log2(p_x)

    print(f"Shannon entropy: {entropy:.4f} bits/byte")
    print(f"Entropy percentage: {(entropy / 8) * 100:.2f}% of maximum")
    
    # Entropy interpretation
    if entropy < 4.0:
        print("→ LOW entropy: Likely signed data (timestamp + plaintext)")
    elif entropy > 7.0:
        print("→ HIGH entropy: Likely encrypted data (random ciphertext)")
    else:
        print("→ MEDIUM entropy: Uncertain structure")

# Split potential components
print(f"\n[4] Component Analysis")
print(f"Total length: {len(decoded)} bytes")

# Try to split by common separators
if b'.' in decoded:
    parts = decoded.split(b'.')
    print(f"Found {len(parts)} components separated by '.'")
    for i, part in enumerate(parts):
        print(f"  Component {i}: {part.hex()} ({len(part)} bytes)")
        print(f"             ASCII: {part if len(part) < 50 else part[:50] + b'...'}")
        
        # Check if component is timestamp (4 bytes, unix timestamp)
        if len(part) == 4 and i == 0:
            import struct
            timestamp = struct.unpack('>I', part)[0]
            print(f"  → Possible timestamp: {timestamp}")
elif len(decoded) % 16 == 0:
    print(f"Length is multiple of block size (16): {len(decoded)} / 16 = {len(decoded) // 16} blocks")
    print("→ Likely encrypted with AES-CBC or similar block cipher")
else:
    print(f"Length is NOT multiple of 16: {len(decoded)} bytes")
    print("→ May be signed data or use different block size")

# Test if it looks like a timestamp + signature structure
if len(decoded) > 40:
    print(f"\n[5] Signature Analysis (if signed cookie)")
    potential_sig = decoded[-32:]  # Common signature size
    potential_data = decoded[:-32]
    
    print(f"Potential signature (last 32 bytes): {potential_sig.hex()}")
    print(f"Potential data portion: {len(potential_data)} bytes")
    print(f"Data hex: {potential_data.hex()}")
    
    # Check if data portion contains readable ASCII
    try:
        ascii_data = potential_data.decode('ascii', errors='ignore')
        printable = ''.join(c if 32 <= ord(c) <= 126 else '.' for c in ascii_data)
        print(f"Data as ASCII (printable only): {printable}")
    except:
        pass

# Padding analysis
print(f"\n[6] PKCS#7 Padding Analysis")
if len(decoded) > 0:
    last_byte = decoded[-1]
    padding_length = last_byte
    
    print(f"Last byte value: {last_byte} (0x{last_byte:02x})")
    print(f"If valid PKCS#7 padding, padding length = {padding_length}")
    
    if 1 <= padding_length <= 16:
        # Check if padding is consistent
        is_valid_padding = True
        for i in range(padding_length):
            if decoded[-1 - i] != padding_length:
                is_valid_padding = False
                break
        
        print(f"Padding validation: {'VALID' if is_valid_padding else 'INVALID'}")
        if is_valid_padding:
            print(f"→ This cookie IS encrypted! Padding oracle likely possible.")
            actual_data = decoded[:-padding_length]
            print(f"Data without padding: {actual_data.hex()} ({len(actual_data)} bytes)")
            try:
                print(f"ASCII: {actual_data.decode('utf-8', errors='ignore')}")
            except:
                pass
        else:
            print(f"→ Padding inconsistent, may be signed data or HMAC")
    else:
        print(f"→ Last byte out of valid padding range (1-16)")
        print(f"→ Likely signed data or timestamp-based")

# Test modified versions for padding oracle indicators
print(f"\n[7] Cookie Modification Test Strategy")
print("For padding oracle testing, we need to:")
print("1. Test original cookie (baseline)")
print("2. Modify last byte (change padding)")
print("3. Modify second-to-last byte")
print("4. Observe error differences (timing, status, messages)")
print("\nCookie byte array for modification reference:")
for i in range(0, min(len(decoded), 32), 16):
    chunk = decoded[i:i+16]
    print(f"{i:02x}: {chunk.hex()} | {' '.join(f'{b:02x}' for b in chunk)}")

# Generate modified cookies for testing
def modify_byte(data: bytes, position: int, value: int) -> bytes:
    """Modify byte at position to value"""
    data_list = list(data)
    data_list[position] = value
    return bytes(data_list)

