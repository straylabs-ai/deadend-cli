import base64
import requests
import re

# Configuration
base_url = "http://127.0.0.1:32834"
cookie_name = "captcha"
target_cookie = "2mArom13+gd4q/dQTQu4aFVpwOkejaqPtWuV0Kyn2ls="

# Decode cookie
cookie_bytes = base64.b64decode(target_cookie)
print(f"[+] Cookie: {target_cookie}")
print(f"[+] Decoded: {cookie_bytes.hex()}")
print(f"[+] Length: {len(cookie_bytes)} bytes")

# Get the registration page to see full form
session = requests.Session()
resp = session.get(base_url)
print(f"\n[+] GET / status: {resp.status_code}")
print(f"[+] Response snippet:\n{resp.text[:1000]}")

# Look for CSRF token and form fields
csrf_match = re.search(r'name="csrf_token" value="([^"]+)"', resp.text)
if csrf_match:
    csrf_token = csrf_match.group(1)
    print(f"\n[+] CSRF token found: {csrf_token}")
else:
    csrf_token = ""
    print(f"\n[-] No CSRF token found")

# Look for any hidden fields or javascript
hidden_fields = re.findall(r'<input[^>]*type="hidden"[^>]*>', resp.text)
print(f"[+] Hidden fields: {len(hidden_fields)}")
for field in hidden_fields:
    print(f"  {field}")

# Try to submit with the original cookie and see what happens
session.cookies.set(cookie_name, target_cookie)

form_data = {
    'username': 'testuser',
    'captcha': 'test',
    'submit': 'Submit'
}

if csrf_token:
    form_data['csrf_token'] = csrf_token

print(f"\n[+] Submitting form with data: {form_data}")
print(f"[+] Cookies: {dict(session.cookies)}")

resp2 = session.post(base_url, data=form_data)
print(f"\n[+] POST response status: {resp2.status_code}")
print(f"[+] POST response: '{resp2.text}'")
print(f"[+] Response headers: {dict(resp2.headers)}")
