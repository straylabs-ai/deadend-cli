#!/usr/bin/env python3
import re

hex_string = 'ca6f25af617cf00e70acf1554908ba69'

print(f"Analyzing hex: {hex_string}")
print(f"Length: {len(hex_string)} chars ({len(hex_string)//2} bytes)")
print()

# Convert to bytes
byte_data = bytes.fromhex(hex_string)
print(f"[*] Bytes: {byte_data}")
print()

# The captcha value from the cookie
# captcha_cookie = "0omFr9RIvOcZVjeD4XWqAnMPnywPudrqySWzAq5oM3w="
# print(f"[info] Captcha cookie: {captcha_cookie}")
# print()

# Try different byte slices
print("Testing different byte slices:")
for slice_range in [
    (0, 4), (0, 5), (0, 6), (0, 7), (0, 8),
    (4, 10), (6, 12), (8, 14),
    (1, 7), (2, 8), (3, 9)
]:
    if slice_range[1] <= len(byte_data):
        slice_bytes = byte_data[slice_range[0]:slice_range[1]]
        
        # Try decoding as UTF-8, ASCII, Latin-1
        readable = []
        for encoding in ['utf-8', 'ascii', 'latin-1']:
            try:
                decoded = slice_bytes.decode(encoding)
                # Check how many readable alphanum characters
                alphanum = sum(c.isalnum() for c in decoded)
                readable.append(f"{encoding}: {decoded!r} (alphanum: {alphanum})")
            except:
                continue
        
        if readable:
            print(f"  Bytes[{slice_range[0]}:{slice_range[1]}] = {slice_bytes!r}")
            for r in readable:
                print(f"    {r}")
            print()

# Try XOR with common patterns (0x00, 0xFF, etc.)
print("Testing XOR with common values:")
for xor_val in [0x00, 0x01, 0x02, 0x03, 0x0F, 0xFF, 0xCA, 0x6F, 0x25, 0xAF]:
    xor_bytes = bytes(b ^ xor_val for b in byte_data)
    try:
        xor_decoded = xor_bytes.decode('latin-1')
        alphanum_count = sum(c.isalnum() for c in xor_decoded)
        # Only show if reasonable number of alphanum (like a captcha)
        if 3 <= alphanum_count <= 8:
            print(f"  XOR 0x{xor_val:02x}: {xor_decoded!r} (alphanum: {alphanum_count})")
    except:
        pass
print()

# Alternative: maybe it's base64 of the actual captcha
# Try to base64 encode the bytes
import base64
b64_encoded = base64.b64encode(byte_data).decode('ascii')
print(f"[*] Base64-encoded: {b64_encoded}")
print()

# What about decoding as base64?
print("Testing if hex represents base64-encoded data:")
# The hex might be the result of base64 decoding something
try:
    # Try to base64 decode the hex string itself (as if it were ASCII)
    ascii_bytes = hex_string.encode('ascii')
    hex_as_base64_decoded = base64.b64decode(ascii_bytes, validate=False)
    print(f"  Base64 decode of hex (as ASCII): {hex_as_base64_decoded!r}")
    try:
        decoded_str = hex_as_base64_decoded.decode('latin-1')
        print(f"    as string: {decoded_str!r}")
    except:
        pass
except Exception as e:
    print(f"  Failed: {e}")
    print()

# Try to find printable ASCII words in different bit patterns
print("Testing for printable ASCII in various rotations:")
for rotate_bits in [1, 2, 3, 4, 5]:
    rotated = bytes(((b >> rotate_bits) | (b << (8 - rotate_bits))) & 0xFF for b in byte_data)
    try:
        rotated_str = rotated.decode('latin-1')
        alphanum = re.findall(r'[a-zA-Z0-9]+', rotated_str)
        if alphanum and max(len(word) for word in alphanum) >= 3:
            print(f"  Rotate {rotate_bits} bits: {rotated_str!r}")
            print(f"    alphanum tokens: {alphanum}")
    except:
        pass
print()

# Let's check the readable chars more carefully
readable_extracted = ''
for byte in byte_data:
    if 32 <= byte <= 126:
        readable_extracted += chr(byte)
print(f"[*] Only readable ASCII chars: '{readable_extracted}'")
print(f"[*] Filter alphanum only: '{''.join(c for c in readable_extracted if c.isalnum())}'")
print()

# One more approach: maybe captcha is in little-endian or big-endian order
print("Testing byte order swaps:")
# Swap each pair of bytes (0,1 -> 1,0, 2,3 -> 3,2, etc.)
if len(byte_data) % 2 == 0:
    swapped = bytes(sum([[byte_data[i+1], byte_data[i]] for i in range(0, len(byte_data), 2)], []))
    swapped_latin1 = swapped.decode('latin-1')
    swapped_alnum = sum(c.isalnum() for c in swapped_latin1)
    print(f"  Swap adjacent: {swapped_latin1!r} (alphanum: {swapped_alnum})")
    
    # Extract readable
    swapped_readable = ''.join(chr(b) for b in swapped if 32 <= b <= 126)
    print(f"    readable: '{swapped_readable}'")
    print()

# Try removing high bits (AND with 0x7F)
print("Testing with high bits masked (0x7F):")
masked = bytes(b & 0x7F for b in byte_data)
masked_latin1 = masked.decode('latin-1')
masked_alnum = sum(c.isalnum() for c in masked_latin1)
print(f"  Mask 0x7F: {masked_latin1!r} (alphanum: {masked_alnum})")

masked_readable = ''.join(chr(b) for b in masked if 32 <= b <= 126)
print(f"  Readable: '{masked_readable}'")
print()
    
# Final conclusion
print("=" * 60)
print("SUMMARY:")
print(f"Original hex: {hex_string}")
print(f"Readable chars: '{readable_extracted}'")
print(f"Alphanumeric from readable: '{''.join(c for c in readable_extracted if c.isalnum())}'")
