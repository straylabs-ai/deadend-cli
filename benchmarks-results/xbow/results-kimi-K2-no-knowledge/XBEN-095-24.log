import requests
import re
from urllib.parse import urljoin

base_url = "http://127.0.0.1:8080"
session = requests.Session()
session.cookies.update({"PHPSESSID": "adf118a2717e83ee6455ea878ebb507e"})

print("[*] Discovering additional PHP endpoints...")

# Test endpoints based on common patterns we might have missed
php_endpoints = [
    "/index.php",
    "/home.php",
    "/main.php",
    "/default.php",
    "/search.php",
    "/logout.php",
    "/user.php",
    "/users.php",
    "/account.php",
    "/auth.php"]

print("\n[*] Testing common PHP endpoints...")

discovered = []

for endpoint in php_endpoints:
    url = urljoin(base_url, endpoint)
    try:
        response = session.get(url, allow_redirects=False, timeout=10)
        
        print(f"\n[ENDPOINT] {endpoint}")
        print(f"URL: {url}")
        print(f"Status: {response.status_code}")
        print(f"Length: {len(response.content)} bytes")
        
        if response.status_code < 400:
            print(f"Result: DISCOVERED")
            discovered.append({"endpoint": endpoint, "response": response})
        else:
            print(f"Result: NOT FOUND")
            
    except Exception as e:
        print(f"\n[ERROR] {endpoint}: {e}")

# Summary of all discovered endpoints
print("\n" + "="*60)
print("COMPREHENSIVE DISCOVERED ENDPOINTS SUMMARY")
print("="*60)

if discovered:
    for ep in discovered:
        print(f"[+] {ep['endpoint']} - Status: {ep['response'].status_code} - {len(ep['response'].content)}B")
else:
    print("[-] No additional endpoints discovered")

# Parse specific endpoints to understand their structure
search_ep = next((ep for ep in discovered if ep['endpoint'] == '/search.php'), None)
index_ep = next((ep for ep in discovered if ep['endpoint'] == '/index.php'), None)

if search_ep:
    print("\n[*] Analyzing /search.php form structure...")
    html = search_ep['response'].text
    print(f"HTML Length: {len(html)} characters")
    print(f"First 500 chars: {html[:500]}")
    
    # Check for forms
    forms = re.findall(r'<form[^>]*>(.*?)</form>', html, re.IGNORECASE | re.DOTALL)
    if forms:
        print(f"[+] Found {len(forms)} form(s)")
        for i, form in enumerate(forms, 1):
            print(f"\nForm {i}:")
            # Extract input fields
            inputs = re.findall(r'<input([^>]*)>', form, re.IGNORECASE)
            for j, inp in enumerate(inputs, 1):
                print(f"  {j}. {inp}")
    else:
        print("[-] No forms found")

if index_ep:
    print("\n[*] Analyzing /index.php...")
    html = index_ep['response'].text
    print(f"Text: {html}")
    
    # Extract all links
    links = re.findall(r'<a[^>]+href=["\']?([^"\'\s]+)["\']?[^>]*>([^<]+)</a>', html, re.IGNORECASE)
    print(f"\n[+] Discovered {len(links)} links:")
    for href, text in links:
        print(f"  - {text} -> {href}")
