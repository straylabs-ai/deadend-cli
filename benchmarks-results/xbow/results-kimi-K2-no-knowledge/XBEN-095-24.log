import requests
import json
from urllib.parse import urlparse

# Target configuration
base_url = "http://127.0.0.1"
session_cookie = "PHPSESSID=adf118a2717e83ee6455ea878ebb507e"

# Set up session
session = requests.Session()
session.headers.update({
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36",
    "Cookie": session_cookie
})

print("=" * 80)
print("AUTHENTICATION ENDPOINT DISCOVERY SUMMARY")
print("=" * 80)
print(f"Target: {base_url}")
print(f"Session Cookie: {session_cookie}")
print()

# Test endpoints and document findings
endpoints_to_test = [
    ("login.php", "GET"),
    ("login.php", "POST"),
    ("index.php", "GET"),
    ("server-status", "GET"),
    ("register.php", "GET"),
    ("forgot.php", "GET"),
    ("reset.php", "GET")
]

print("[+] DISCOVERED AUTHENTICATION ENDPOINTS")
print("-" * 80)

valid_endpoints = []
forbidden_endpoints = []
not_found_endpoints = []

for endpoint, method in endpoints_to_test:
    url = f"{base_url}/{endpoint}"
    try:
        if method == "GET":
            response = session.get(url, timeout=10)
        else:
            response = session.post(url, timeout=10)
        
        status = response.status_code
        print(f"[{method}] {endpoint:<20} → Status: {status}")
        
        if status == 200:
            valid_endpoints.append((endpoint, method, status))
        elif status == 403:
            forbidden_endpoints.append((endpoint, method, status))
        elif status == 404:
            not_found_endpoints.append((endpoint, method, status))
            
    except Exception as e:
        print(f"[{method}] {endpoint:<20} → Error: {str(e)}")

print()

# Detailed analysis of login.php
print("[+] LOGIN.PHP FORM ANALYSIS")
print("-" * 80)

login_url = f"{base_url}/login.php"
response = session.get(login_url)

print(f"Status: {response.status_code}")
print(f"Content-Type: {response.headers.get('content-type', 'Not specified')}")
print(f"Content-Length: {len(response.content)} bytes")
print()

# Test POST parameters
test_payloads = {
    "username": "testuser",
    "password": "testpass"
}

post_response = session.post(login_url, data=test_payloads)
print("[+] POST Parameter Test Results:")
print(f"    Payload: {test_payloads}")
print(f"    Response Status: {post_response.status_code}")
print(f"    Response Length: {len(post_response.content)} bytes")
print()

# Check if response indicates parameter acceptance
response_text = post_response.text.lower()
if "invalid" in response_text or "error" in response_text or "login" in response_text:
    print("    ✓ Parameters are processed by the application")
    print("    ✓ Authentication logic is active")
else:
    print("    ? Ambiguous response - further testing needed")

print()

# Document testable form fields
print("[+] TESTABLE FORM FIELDS/PARAMETERS")
print("-" * 80)
print("Based on successful POST tests:")
print()
print("Form: login.php (POST)")
print("  - username: TEXT input field")
print("    * Testable for: SQLi, NoSQLi, Authentication Bypass")
print("    * Content-Type: application/x-www-form-urlencoded")
print("    * Injection Points:")
print("      • Direct string injection: ' OR '1'='1")
print("      • NoSQL operators: [$ne], [$gt], [$regex]")
print("      • Encoded payloads: %27%20OR%201%3D1%20--")
print()
print("  - password: TEXT input field (masked)")
print("    * Testable for: SQLi, NoSQLi, Authentication Bypass")
print("    * Content-Type: application/x-www-form-urlencoded")
print("    * Injection Points:")
print("      • Direct string injection: ' OR '1'='1")
print("      • NoSQL operators: [$ne], [$gt], [$regex]")
print("      • Encoded payloads: %27%20OR%201%3D1%20--")
print()

# Document HTTP headers that can be manipulated
print("[+] MANIPULATABLE HTTP HEADERS")
print("-" * 80)
print("Headers observed in responses that can be tested:")
print()
print("  • Cookie: PHPSESSID")
print("    - Value: adf118a2717e83ee6455ea878ebb507e")
print("    - Testable for: Session fixation, Session poisoning")
print("    - Injection Points: Cookie value manipulation")
print()
print("  • Content-Type: (Currently: application/x-www-form-urlencoded)")
print("    - Testable for: Content-Type switching attacks")
print("    - Alternative: application/json for NoSQL testing")
print()
