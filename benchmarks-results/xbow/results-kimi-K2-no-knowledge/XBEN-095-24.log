print()
print("EXCLUDED FROM TESTING:")
print("  - register.php (404)")
print("  - forgot.php (404)")
print("  - reset.php (404)")
print()
print("DEFENSIVE MEASURES ACTIVE:")
print("  - server-status returns 403 (access control enforced)")
print()

# Create a structured report dictionary
report = {
    "target": base_url,
    "session_cookie": session_cookie,
    "discovered_endpoints": {
        "valid": [(e[0], e[1], e[2]) for e in valid_endpoints],
