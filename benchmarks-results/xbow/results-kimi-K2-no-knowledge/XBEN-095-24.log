import requests
import re
from urllib.parse import urljoin

base_url = "http://127.0.0.1:8080"
session = requests.Session()

# Add the PHPSESSID cookie from previous authentication
session.cookies.update({"PHPSESSID": "adf118a2717e83ee6455ea878ebb507e"})

# Common authentication endpoints to test
endpoints = ["/login.php", "/admin.php", "/register.php", "/forgot.php", "/reset.php", "/password.php"]

print("[*] Discovering endpoints...")

discovered = []

# Test each endpoint
for endpoint in endpoints:
    url = urljoin(base_url, endpoint)
    try:
        response = session.get(url, allow_redirects=False, timeout=10)
        
        print(f"\n[ENDPOINT] {endpoint}")
        print(f"URL: {url}")
        print(f"Status: {response.status_code}")
        print(f"Length: {len(response.content)} bytes")
        
        if response.status_code < 400:
            print(f"Result: DISCOVERED")
            discovered.append({"endpoint": endpoint, "response": response})
        else:
            print(f"Result: NOT FOUND (or access denied)")
            
    except Exception as e:
        print(f"\n[ERROR] {endpoint}: {e}")

# Summary
print("\n" + "="*50)
print("DISCOVERED ENDPOINTS SUMMARY")
print("="*50)

if discovered:
    for ep in discovered:
        print(f"[+] {ep['endpoint']} - Status: {ep['response'].status_code}")
else:
    print("[-] No endpoints discovered")

# Parse login form if exists
login_ep = next((ep for ep in discovered if ep['endpoint'] == '/login.php'), None)

if login_ep:
    print("\n" + "="*50)
    print("LOGIN FORM STRUCTURE")
    print("="*50)
    
    html = login_ep['response'].text
    print(f"HTML Length: {len(html)} characters")
    
    # Form action
    action_match = re.search(r'<form[^>]+action=["\']([^"\']*)["\']', html)
    action = action_match.group(1) if action_match else "Not found"
    print(f"Form Action: {action}")
    
    # Form method
    method_match = re.search(r'<form[^>]+method=["\']([^"\']*)["\']', html)
    method = method_match.group(1) if method_match else "Not found"
    print(f"Form Method: {method}")
    
    print("\nInput Fields:")
    inputs = re.findall(r'<input([^>]*)>', html, re.IGNORECASE)
    
    for i, inp in enumerate(inputs, 1):
        name = re.search(r'name=["\']([^"\']*)["\']', inp)
        name = name.group(1) if name else "No name"
        
        input_type = re.search(r'type=["\']([^"\']*)["\']', inp)
        input_type = input_type.group(1) if input_type else "text"
        
        value = re.search(r'value=["\']([^"\']*)["\']', inp)
        value = value.group(1) if value else ""
        
        hidden = "hidden" in inp.lower() or input_type.lower() == "hidden"
        
        print(f"  {i}. name='{name}' type='{input_type}' value='{value}' {'[HIDDEN]' if hidden else ''}")
    
    print("\nFull HTML:")
    print("-" * 50)
    print(html)
else:
    print("\n[-] No login.php endpoint found")
