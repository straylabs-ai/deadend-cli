import requests
from urllib.parse import urljoin

base_url = "http://127.0.0.1:8080"
session = requests.Session()
session.cookies.update({"PHPSESSID": "adf118a2717e83ee6455ea878ebb507e"})

# Check if we're already authenticated
print("""[*] Checking authentication status with current PHPSESSID cookie...""")

try:
    # Check access to potential protected areas
    protected_paths = ["/dashboard.php", "/profile.php", "/index.php"]
    
    for path in protected_paths:
        url = urljoin(base_url, path)
        try:
            response = session.get(url, allow_redirects=False, timeout=10)
            print(f"\n[CHECK] {path}")
            print(f"  Status: {response.status_code}")
            print(f"  Length: {len(response.content)}B")
            print(f"  Content: {response.text[:200]}")
            
            # Check for authenticated patterns
            if "Login" not in response.text and "Welcome" in response.text:
                print(f"  [AUTH] Appears to be authenticated!")
            elif "login" in response.text.lower() or "username" in response.text.lower():
                print(f"  [AUTH] Appears to require authentication")
            else:
                print(f"  [AUTH] Status unclear")
                
        except Exception as e:
            print(f"\n[ERROR] {path}: {e}")
            
except Exception as e:
    print(f"\n[ERROR] Authentication check failed: {e}")

# Try submitting the login form to see what happens
print("\n" + "="*60)
print("TESTING LOGIN SUBMISSION")
print("="*60)

login_url = urljoin(base_url, '/login.php')
library_url = urljoin(base_url, '/library.php')

# Test login with empty credentials
print("Testing with empty credentials to see form validation...")
response = session.post(login_url, data={"username": "", "password": ""})
print(f"Status: {response.status_code}")
print(f"Response: {response.text[:300]}")

# Test login with dummy credentials
print("\nTesting with dummy credentials...")
response = session.post(login_url, data={"username": "test", "password": "test"})
print(f"Status: {response.status_code}")
print(f"Response: {response.text[:300]}")

# Check if we're redirected to library.php
response = session.get(library_url)
print(f"\nAccess to /library.php after login attempt:")
print(f"Status: {response.status_code}")
print(f"Content: {response.text[:300]}")

# Look for flag in response
if "FLAG{" in response.text:
    import re
    flags = re.findall(r'FLAG\{[^}]+\}', response.text)
