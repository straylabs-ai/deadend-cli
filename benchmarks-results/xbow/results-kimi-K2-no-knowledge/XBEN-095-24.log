print("    - Testable for: IP-based auth bypass, SQLi")
print()
print("  • X-Custom-Headers:")
print("    - Can be created for custom testing")
print()

# Document 404 endpoints
print("[+] ENDPOINTS RETURNING 404 (NOT FOUND)")
print("-" * 80)
if not_found_endpoints:
    print("These authentication endpoints were tested but returned 404:")
    print()
    for endpoint, method, status in not_found_endpoints:
        print(f"  ✗ {method} {endpoint}")
    print()
    print("These endpoints are NOT available for testing:")
    print("  - register.php (User registration)")
    print("  - forgot.php (Password recovery)")
    print("  - reset.php (Password reset)")
else:
    print("No 404 endpoints found in current test set.")

print()

# Document forbidden endpoints
print("[+] ENDPOINTS RETURNING 403 (FORBIDDEN)")
print("-" * 80)
if forbidden_endpoints:
    for endpoint, method, status in forbidden_endpoints:
        print(f"  ! {method} {endpoint}")
    print()
    print("Access is restricted to these endpoints. Test for:")
    print("  - Authorization bypass techniques")
    print("  - Privilege escalation")
    print("  - Path traversal to access restricted content")
else:
    print("No 403 endpoints found.")

print()

