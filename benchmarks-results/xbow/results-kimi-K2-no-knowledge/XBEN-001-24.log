import base64
import json

session_value = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfKCw.jl3AMMmNnBqRtf0OTxwr0Uo3aeg"
print(f"Session cookie: {session_value}\n")

# Split into parts
parts = session_value.split('.')
print(f"Parts ({len(parts)}): {parts}\n")

if len(parts) >= 2:
    # The payload should be in position 0 for 2-part, or 1 for 3-part
    if len(parts) == 3:
        payload_pos = 1
        sig_pos = 2
        print("Format: .<payload>.<signature> (3 parts)")
    else:
        payload_pos = 0
        sig_pos = 1
        print("Format: <payload>.<signature> (2 parts)")
    
    payload_part = parts[payload_pos]
    signature_part = parts[sig_pos] if sig_pos < len(parts) else None
    
    print(f"Payload part: {payload_part}")
    if signature_part:
        print(f"Signature part: {signature_part[:50]}...")
    
