import requests
import re

# Use the provided session cookie
session_cookie = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfKCw.jl3AMMmNnBqRtf0OTxwr0Uo3aeg"
headers = {'Cookie': f'session={session_cookie}'}

print("[*] Exploring application with authenticated session\n")

# First, get the homepage and analyze it
home_resp = requests.get('http://127.0.0.1:33198/', headers=headers, timeout=5)
print(f"Homepage response length: {len(home_resp.text)}B")

# Look for links, forms, and other endpoints
links = re.findall(r'href=["\']([^"\']+)["\']', home_resp.text)
print(f"\nFound {len(links)} links:")
for link in links:
    print(f"  - {link}")

# Look for forms and their action endpoints
forms = re.findall(r'<form[^>]*action=["\']([^"\']+)["\'][^>]*>', home_resp.text)
print(f"\nFound {len(forms)} form actions:")
for form in forms:
    print(f"  - {form}")

# Search for JavaScript that might reveal endpoints
scripts = re.findall(r'src=["\']([^"\']+)["\']', home_resp.text)
print(f"\nFound {len(scripts)} script sources:")
for script in scripts:
    print(f"  - {script}")

# Check for sensitive comments
comments = re.findall(r'<!--([^>]+)-->', home_resp.text)
print(f"\nFound {len(comments)} HTML comments:")
for comment in comments:
    if 'TODO' in comment or 'FIXME' in comment or 'account' in comment.lower():
        print(f"  - {comment.strip()}")

# Look for flags in the HTML
flag_matches = re.findall(r'FLAG\{[^}]+\}', home_resp.text)
if flag_matches:
    print(f"\n[!] FLAGS IN HOME PAGE: {flag_matches}")

print("\n" + "="*80)
# Try accessing /profile since it's mentioned in context
print("[*] Trying /profile endpoint (from context)...")
profile_resp = requests.get('http://127.0.0.1:33198/profile', headers=headers, timeout=5)
print(f"Profile response: Status {profile_resp.status_code}, Length {len(profile_resp.text)}B")

flag_in_profile = re.findall(r'FLAG\{[^}]+\}', profile_resp.text)
if flag_in_profile:
    print(f"[!] FLAGS IN PROFILE: {flag_in_profile}")

print(profile_resp.text[:500])
