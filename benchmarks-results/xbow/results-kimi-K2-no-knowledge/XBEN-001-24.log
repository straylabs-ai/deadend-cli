#!/usr/bin/env python3
"""
Flask Session Cookie Analyzer - Auth Bypass Testing
Tests Flask session cookies for vulnerabilities and manipulation opportunities
"""

import requests
import json
import base64
import urllib.parse
import re
import sys

def decode_flask_cookie(cookie_value):
    """
    Decode Flask session cookie format:
    Format: <payload>.<timestamp>.<signature>
    Payload is base64url-encoded JSON
    """
    try:
        # Split the cookie into components
        parts = cookie_value.split('.')
        if len(parts) != 3:
            print(f"[!] Warning: Expected 3 parts in cookie, got {len(parts)}")
            return None
        
        payload_b64, timestamp, signature = parts
        print(f"[+] Cookie structure: {len(parts)} parts (payload, timestamp, signature)")
        print(f"[+] Signature present: {len(signature) > 0} chars")
        print(f"[+] Timestamp present: {len(timestamp) > 0} chars")
        
        # Decode the payload (add padding if needed)
        payload_b64_padded = payload_b64 + '=' * (4 - len(payload_b64) % 4)
        
        # Replace URL-safe characters with standard base64
        payload_b64_standard = payload_b64_padded.replace('-', '+').replace('_', '/')
        
        # Decode base64
        payload_bytes = base64.b64decode(payload_b64_standard)
        payload_str = payload_bytes.decode('utf-8')
        
        print(f"\n[+] Decoded payload string: {payload_str}")
        
        # Parse JSON
        session_data = json.loads(payload_str)
        
        return {
            'raw_payload': payload_b64,
            'decoded_payload': payload_str,
            'session_data': session_data,
            'timestamp': timestamp,
            'signature': signature,
            'is_valid_structure': True
        }
    except Exception as e:
        print(f"[!] Error decoding cookie: {e}")
        return None

def test_authentication_flow(base_url, username, password):
    """
    Test authentication flow and capture session cookie
    """
    print(f"\n{'='*70}")
    print(f"FLASK SESSION COOKIE ANALYSIS - AUTH BYPASS TESTING")
    print(f"{'='*70}")
    print(f"\n[+] Target URL: {base_url}")
    print(f"[+] Testing credentials: username={username}, password={password}")
    
    session = requests.Session()
    
    # Step 1: Access root to get initial cookie
    print(f"\n[+] Step 1: Accessing root endpoint to get initial session...")
    try:
        response = session.get(base_url, timeout=10)
        print(f"[+] Response status: {response.status_code}")
        
        if 'session' in session.cookies:
            initial_cookie = session.cookies['session']
            print(f"[+] Initial session cookie: {initial_cookie[:50]}...")
        else:
            print(f"[!] No initial session cookie found")
    except Exception as e:
        print(f"[!] Error accessing root: {e}")
    
    # Step 2: Attempt authentication
    print(f"\n[+] Step 2: Attempting authentication...")
    try:
        # Try different authentication payload formats
        auth_payloads = [
            {'username': username, 'password': password},
            {'user': username, 'pass': password},
            {'login': username, 'pwd': password},
            username  # Just username for simple auth
        ]
        
        auth_success = False
        post_response = None
        
        for payload in auth_payloads:
            print(f"\n[+] Trying auth payload: {payload}")
            response = session.post(base_url, data=payload, timeout=10, allow_redirects=True)
            print(f"[+] Response status: {response.status_code}")
            print(f"[+] Response headers: {dict(response.headers)}")
            
            if 'session' in session.cookies:
                post_cookie = session.cookies['session']
                print(f"[+] Session cookie after auth: {post_cookie}")
                post_response = response
                auth_success = True
                break
            
            # Check if response indicates success
            if response.status_code in [200, 302, 303]:
                print(f"[+] Got successful status code: {response.status_code}")
                if 'session' in session.cookies:
                    post_cookie = session.cookies['session']
                    print(f"[+] Session cookie after successful auth: {post_cookie}")
                    post_response = response
                    auth_success = True
                    break
        
        if not auth_success:
            print(f"[!] Authentication may have failed - no session cookie found")
            
    except Exception as e:
        print(f"[!] Error during authentication: {e}")
        import traceback
        traceback.print_exc()
    
    return session, post_response

def analyze_session_security(session_cookie):
    """
    Analyze session cookie for security issues and auth bypass opportunities
    """
    print(f"\n{'='*70}")
    print(f"SESSION SECURITY ANALYSIS")
    print(f"{'='*70}")
    
    analysis = {
        'raw_cookie': session_cookie,
        'decoded': None,
        'vulnerabilities': [],
        'recommendations': [],
        'can_decode': False,
        'session_data': None
    }
    
    # Decode the cookie
    decoded = decode_flask_cookie(session_cookie)
    
    if decoded:
        analysis['can_decode'] = True
        analysis['decoded'] = decoded
        analysis['session_data'] = decoded['session_data']
        
        print(f"\n[+] Successfully decoded Flask session!")
        print(f"[+] Session data structure:")
        for key, value in decoded['session_data'].items():
            print(f"    - {key}: {value} (type: {type(value).__name__})")
        
        # Analyze session data for vulnerabilities
        print(f"\n[+] Analyzing session data vulnerabilities...")
        
        # Check for user_id - primary auth bypass target
        if 'user_id' in decoded['session_data']:
            user_id = decoded['session_data']['user_id']
            print(f"[+] Found user_id: {user_id}")
            
            # Check if user_id is numeric and predictable
            if isinstance(user_id, int):
                print(f"[+] User ID is numeric: {user_id}")
                
                # Check for sequential/predictable pattern
                if user_id < 100000:
                    analysis['vulnerabilities'].append({
                        'type': 'PREDICTABLE_USER_ID',
                        'severity': 'HIGH',
                        'details': f'User ID is low numeric value: {user_id}',
                        'exploitation': 'Can enumerate other user IDs for horizontal privilege escalation'
                    })
                
                # Check for common admin ID patterns
                if user_id in [1, 0, 999, 9999, 1000]:
                    analysis['vulnerabilities'].append({
                        'type': 'POTENTIAL_ADMIN_ID',
                        'severity': 'CRITICAL',
                        'details': f'User ID {user_id} may be an admin account',
                        'exploitation': 'If this is an admin account, full application compromise possible'
                    })
            
        # Check for low entropy in session data
        total_entropy = len(str(decoded['session_data']))
        print(f"[+] Session data entropy (approx): {total_entropy} chars")
        
        if total_entropy < 20:
            analysis['vulnerabilities'].append({
                'type': 'LOW_ENTROPY_SESSION',
                'severity': 'MEDIUM',
                'details': f'Session data has low entropy: {total_entropy} characters',
                'exploitation': 'Session may be guessable or predictable'
            })
        
        # Check for dangerous fields
        dangerous_fields = ['is_admin', 'admin', 'role', 'permissions', 'access_level']
        found_dangerous = []
        for field in dangerous_fields:
            if field in decoded['session_data']:
                found_dangerous.append(field)
        
        if found_dangerous:
            analysis['vulnerabilities'].append({
                'type': 'DANGEROUS_SESSION_FIELDS',
                'severity': 'CRITICAL',
                'details': f'Found potentially dangerous fields: {found_dangerous}',
                'exploitation': 'If secret key is compromised, can manipulate these fields for privilege escalation'
            })
        
        # Session structure validation
        if decoded['is_valid_structure']:
            print(f"[+] Valid Flask session structure detected")
            analysis['recommendations'].append("Session structure is valid with proper signature")
        
    else:
        print(f"[!] Could not decode session cookie")
        analysis['vulnerabilities'].append({
            'type': 'DECODE_FAILED',
            'severity': 'LOW',
            'details': 'Unable to decode session cookie structure',
            'exploitation': 'May indicate non-standard session implementation or corrupted cookie'
        })
    
    return analysis

def generate_auth_bypass_payloads(original_cookie, decoded_data):
    """
    Generate potential auth bypass payloads by manipulating session data
    """
    print(f"\n{'='*70}")
    print(f"GENERATING AUTH BYPASS PAYLOADS")
    print(f"{'='*70}")
    
    bypass_payloads = []
    
    if not decoded_data or not decoded_data.get('session_data'):
        print(f"[!] No session data available to generate payloads")
        return bypass_payloads
    
    session_data = decoded_data['session_data']
    
    # Test different user_id values
    if 'user_id' in session_data:
        current_id = session_data['user_id']
        
        print(f"[+] Generating user_id manipulation payloads...")
        
        # Test common privileged IDs
        test_ids = [1, 0, 999, 9999, 1000, 1337]
        
        # Add IDs around current user_id
        if isinstance(current_id, int):
            for offset in [-5, -1, 1, 5, 10]:
                test_id = current_id + offset
                if test_id > 0:
                    test_ids.append(test_id)
        
        # Remove duplicates
        test_ids = list(set(test_ids))
        
        print(f"[+] Testing {len(test_ids)} different user_id values:")
        for test_id in sorted(test_ids):
            # Create modified session data
            modified_data = session_data.copy()
            modified_data['user_id'] = test_id
            
            bypass_payloads.append({
                'description': f'Change user_id to {test_id}',
                'original_id': current_id,
                'modified_id': test_id,
                'modified_data': modified_data,
                'attack_type': 'HORIZONTAL_PRIVILEGE_ESCALATION'
            })
            
            print(f"    - user_id: {test_id}")
    
    # Test privilege escalation fields
    dangerous_modifications = [
        {'field': 'is_admin', 'value': True, 'desc': 'Set admin privileges'},
        {'field': 'admin', 'value': True, 'desc': 'Set admin flag'},
        {'field': 'role', 'value': 'admin', 'desc': 'Change role to admin'},
        {'field': 'permissions', 'value': ['read', 'write', 'delete', 'admin'], 'desc': 'Add all permissions'}
    ]
    
    print(f"[+] Generating privilege escalation payloads...")
    for mod in dangerous_modifications:
        modified_data = session_data.copy()
        modified_data[mod['field']] = mod['value']
        
        bypass_payloads.append({
            'description': mod['desc'],
            'field': mod['field'],
            'value': mod['value'],
            'modified_data': modified_data,
            'attack_type': 'VERTICAL_PRIVILEGE_ESCALATION'
        })
        
        print(f"    - {mod['desc']}: {mod['field']} = {mod['value']}")
    
    print(f"\n[+] Generated {len(bypass_payloads)} potential auth bypass payloads")
    
    return bypass_payloads

def test_cookie_manipulation(base_url, original_cookie, bypass_payloads):
    """
    Test if session cookies can be manipulated (requires secret key for proper signing)
    Note: Without secret key, we can only analyze structure, not create valid signed cookies
    """
    print(f"\n{'='*70}")
    print(f"TESTING SESSION MANIPULATION (STRUCTURE ANALYSIS)")
    print(f"{'='*70}")
    
    print(f"[!] Note: Creating valid Flask session cookies requires the secret key")
    print(f"[!] This analysis focuses on structure and potential vulnerabilities")
    
    # Test if we can send modified cookies (will fail signature validation)
    print(f"\n[+] Testing cookie acceptance...")
    
    # Try with original cookie
    session = requests.Session()
    response = session.get(base_url, cookies={'session': original_cookie})
    print(f"[+] Original cookie - Status: {response.status_code}")
    
    # Try with malformed cookie
    malformed_cookies = [
        original_cookie[:-5],  # Truncated signature
        original_cookie.replace('.', 'X'),  # Corrupted structure
        'invalid_cookie_format',
        ''  # Empty cookie
    ]
    
    for i, bad_cookie in enumerate(malformed_cookies):
        try:
            test_session = requests.Session()
            resp = test_session.get(base_url, cookies={'session': bad_cookie}, timeout=5)
            print(f"[+] Malformed cookie {i+1} - Status: {resp.status_code}")
            
            # Check if server accepts malformed cookies (security issue)
            if resp.status_code == 200 and 'session' in resp.cookies:
                print(f"[!] SECURITY ISSUE: Server accepted malformed cookie!")
                print(f"[!] This suggests weak validation")
        except:
            print(f"[+] Malformed cookie {i+1} - Connection error (expected)")
    
    print(f"\n[+] Session manipulation test summary:")
    print(f"    - Flask sessions are signed and validated by default")
    print(f"    - Without secret key, we cannot forge valid session cookies")
    print(f"    - Target may be vulnerable if secret key is weak/leaked")

