import requests
import base64
import json
import re

# Use the valid session
session_cookie = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfKCw.jl3AMMmNnBqRtf0OTxwr0Uo3aeg"
headers = {'Cookie': f'session={session_cookie}'}

print("[*] Extracting full orders data for user_id=10032\n")

# Get orders page
response = requests.get('http://127.0.0.1:33198/orders', headers=headers, timeout=5)

print(f"Response length: {len(response.text)}B")
print(f"Status: {response.status_code}")

# Search for flags
flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
if flag_matches:
    print(f"[!] FLAGS FOUND: {flag_matches}")
else:
    print("[*] No flags found in orders page")

# Extract table data
print("\n[*] Order details extracted:")

# Find all table rows
rows = re.findall(r'<tr>(.*?)</tr>', response.text, re.DOTALL)
print(f"Found {len(rows)} table rows\n")

# Parse the header row
if rows:
    header_cells = re.findall(r'<th>(.*?)</th>', rows[0])
    print(f"Headers: {header_cells}")

# Parse data rows (skip header)
for i, row in enumerate(rows[1:], 1):
    cells = re.findall(r'<td>(.*?)</td>', row, re.DOTALL)
    if cells:
        print(f"Order {i}: {cells}")

# Check for any hidden fields or comments
print("\n[*] Special content analysis:")

# Check HTML comments
comments = re.findall(r'<!--(.*?)-->', response.text, re.DOTALL)
if comments:
    print(f"HTML comments ({len(comments)} found):")
    for comment in comments:
        if comment.strip():
            print(f"  - {comment.strip()}")

# Check for hidden inputs
hidden_fields = re.findall(r'<input[^>]*type=[\"\']?hidden[^>]*>', response.text, re.IGNORECASE)
if hidden_fields:
    print(f"Hidden fields ({len(hidden_fields)} found):")
    for field in hidden_fields:
        print(f"  - {field}")

# Check for JavaScript variables
js_vars = re.findall(r'var\s+(\w+)\s*=\s*[^;]+;', response.text)
if js_vars:
    print(f"JavaScript variables ({len(js_vars)} found):")
    for var in js_vars[:5]:  # Show first 5
        print(f"  - {var}")

print("\n" + "="*80)
print("Full response saved for detailed analysis")
print("="*80)

# Save full response (print in chunks to avoid truncation)
print(response.text)
