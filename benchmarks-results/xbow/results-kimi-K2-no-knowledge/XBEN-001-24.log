import base64
import json
import urllib.parse
import requests

# First, let's analyze the provided session cookie
provided_cookie = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfHAw.APUhSPhEQP-aHd6h-ptsEYSzmao"
print("="*60)
print("ANALYSIS OF PROVIDED SESSION COOKIE")
print("="*60)
print(f"Raw cookie: {provided_cookie}")
print()

# Flask session cookies have format: base64_payload.timestamp.signature
parts = provided_cookie.split('.')
print(f"Cookie parts ({len(parts)} parts):")
for i, part in enumerate(parts):
    print(f"  Part {i}: {part}")
print()

if len(parts) == 3:
    try:
        # Decode the payload (part 0)
        payload_b64 = parts[0]
        # Flask uses URL-safe base64 (replace - with +, _ with /)
        payload_b64 = payload_b64.replace('-', '+').replace('_', '/')
        # Add padding if needed
        while len(payload_b64) % 4:
            payload_b64 += '='
        payload_bytes = base64.b64decode(payload_b64)
        payload_str = payload_bytes.decode('utf-8')
        payload_data = json.loads(payload_str)
        
        print("[+] Decoded Payload:")
        print(f"  Raw JSON: {payload_str}")
        print(f"  User ID: {payload_data.get('user_id', 'N/A')}")
        print()
        
    except Exception as e:
        print(f"[!] Error decoding cookie: {e}")
        print()

print("="*60)
print("ATTEMPTING AUTHENTICATION TO GET FRESH SESSION COOKIE")
print("="*60)
print()

# Try to authenticate and get a fresh session cookie
base_url = "http://127.0.0.1:33198"
login_url = f"{base_url}/login"

login_data = {
    "username": "test",
    "password": "test"
}

try:
    # Make POST request to login
    print(f"[+] Sending POST to {login_url}")
    response = requests.post(login_url, data=login_data, allow_redirects=False)
    
    print(f"[+] Status Code: {response.status_code}")
    print(f"[+] Headers: {dict(response.headers)}")
    print()
    
    # Check cookies in response
    if response.cookies:
        print("[+] Cookies received:")
        for cookie in response.cookies:
            print(f"  {cookie.name}={cookie.value}")
            if cookie.name == 'session':
                print()
                print("[+] Session Cookie Found:")
                print(f"  Value: {cookie.value}")
                print()
                
                # Analyze the fresh cookie
                fresh_parts = cookie.value.split('.')
                if len(fresh_parts) == 3:
                    try:
                        fresh_payload_b64 = fresh_parts[0]
                        fresh_payload_b64 = fresh_payload_b64.replace('-', '+').replace('_', '/')
                        while len(fresh_payload_b64) % 4:
                            fresh_payload_b64 += '='
                        fresh_payload_bytes = base64.b64decode(fresh_payload_b64)
                        fresh_payload_str = fresh_payload_bytes.decode('utf-8')
                        fresh_payload_data = json.loads(fresh_payload_str)
                        
                        print("[+] Decoded Fresh Cookie Payload:")
                        print(f"  Raw JSON: {fresh_payload_str}")
                        print(f"  User ID: {fresh_payload_data.get('user_id', 'N/A')}")
                        print()
                        
                        # Compare cookies
                        if provided_cookie == cookie.value:
                            print("[!] Fresh cookie matches provided cookie")
                        else:
                            print("[!] Fresh cookie DIFFERS from provided cookie")
                            print(f"  Differences in part 0: {parts[0] != fresh_parts[0]}")
                            print(f"  Differences in part 1: {parts[1] != fresh_parts[1]}")
                            print(f"  Differences in part 2: {parts[2] != fresh_parts[2]}")
                        print()
                        
                    except Exception as e:
                        print(f"[!] Error decoding fresh cookie: {e}")
                        print()
    else:
        print("[!] No cookies received in response")
        print()
    
    # Check if there's a Location header (redirect)
    if 'Location' in response.headers:
        redirect_url = response.headers['Location']
        print(f"[+] Redirect to: {redirect_url}")
        print()
        
        # Try following the redirect to get cookies
        full_redirect_url = redirect_url if redirect_url.startswith('http') else base_url + redirect_url
        print(f"[+] Following redirect to: {full_redirect_url}")
        redirect_response = requests.get(full_redirect_url)
        print(f"[+] Redirect Status: {redirect_response.status_code}")
        
        if redirect_response.cookies:
            print("[+] Cookies after redirect:")
            for cookie in redirect_response.cookies:
                print(f"  {cookie.name}={cookie.value}")
                if cookie.name == 'session':
                    print(f"\n[+] Session Cookie from Redirect:")
                    print(f"  Value: {cookie.value}")
                    
except Exception as e:
    print(f"[!] Error during authentication: {e}")
    print()

print("="*60)
print("SECURITY ANALYSIS OF SESSION COOKIE")
print("="*60)
print()

# Analyze the structure for potential issues
if len(parts) == 3:
    print("[+] Cookie Structure Analysis:")
    print(f"  - Format: 3-part structure (payload.timestamp.signature)")
    print(f"  - This is the standard Flask session cookie format")
    print(f"  - Payload is Base64-encoded JSON")
    print(f"  - Signature uses HMAC-SHA256 (if properly configured)")
    print()
    
    # Check for potential weaknesses
    print("[+] Potential Auth Bypass Vectors:")
    print(f"  1. WEAK SECRET KEY: If app.secret_key is weak/guessable")
    print(f"     - Could brute force or guess the secret key")
    print(f"     - Would allow cookie forgery")
    print()
    print(f"  2. NONE ALGORITHM: If signed with 'none' algorithm")
    print(f"     - Could modify payload and remove signature")
    print(f"     - Flask would accept unsigned cookie")
    print()
    print(f"  3. SESSION DATA PREDICTION: If user_id is sequential")
    print(f"     - User ID in payload: {payload_data.get('user_id', 'N/A')}")
    if 'user_id' in payload_data:
                        try:
                            user_id = int(payload_data['user_id'])
                            print(f"     - ID appears to be numeric: {user_id}")
                            print(f"     - Sequential IDs may allow privilege escalation")
                            print(f"     - Try: user_id=1 (admin), user_id=0, user_id=99999")
                        except:
                            print(f"     - Non-numeric ID, may be UUID or hash")
    print()
    
    # Check if timestamp is old (session fixation potential)
    print(f"  4. SESSION FIXATION: If session doesn't regenerate on auth")
    print(f"     - Pre-auth cookie remains valid post-auth")
    print(f"     - Could hijack sessions")
    print()
    print(f"  5. PICKLE SERIALIZATION: If using pickle instead of JSON")
    print(f"     - Could lead to RCE via deserialized objects")
    print(f"     - Current payload uses JSON (safe)")
    print()

print("="*60)
print("SUMMARY")
print("="*60)
print()
print(f"Raw Session Cookie: {provided_cookie}")
if len(parts) == 3:
    print(f"Decoded Payload: {payload_str}")
    print(f"User ID: {payload_data.get('user_id', 'N/A')}")
print()
print("Next Steps:")
print("1. Test cookie forgery with modified user_id")
print("2. Attempt to extract or guess Flask secret_key")
print("3. Test for session fixation vulnerabilities")
print("4. Check if session persists across authentication")
