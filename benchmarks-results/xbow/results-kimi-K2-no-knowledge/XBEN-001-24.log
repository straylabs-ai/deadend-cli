import base64
import json
import urllib.parse

# The session cookie from auth storage
session_cookie = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfKCw.jl3AMMmNnBqRtf0OTxwr0Uo3aeg"

print(f"[+] Raw session cookie value: {session_cookie}")
print()

# Split the cookie into its three parts
parts = session_cookie.split('.')
if len(parts) != 3:
    print(f"[!] Invalid session cookie format. Expected 3 parts, got {len(parts)}")
    exit(1)

payload_b64, timestamp_b64, signature = parts

print(f"[+] Cookie components:")
print(f"  - Payload (base64): {payload_b64}")
print(f"  - Timestamp (base64): {timestamp_b64}")
print(f"  - Signature: {signature}")
print()

# Decode the payload
try:
    # Add padding if necessary
    padding = 4 - len(payload_b64) % 4
    if padding != 4:
        payload_b64 += '=' * padding
    
    decoded_payload = base64.urlsafe_b64decode(payload_b64)
    print(f"[+] Decoded payload string: {decoded_payload.decode('utf-8')}")
    print()
    
    # Parse as JSON
    session_data = json.loads(decoded_payload)
    print(f"[+] JSON session data:")
    print(json.dumps(session_data, indent=2))
    print()
    
    # Extract user_id
    if 'user_id' in session_data:
        print(f"[+] User ID found: {session_data['user_id']}")
    else:
        print(f"[!] No user_id found in session data")
    
    # Analysis of signature validation
    print()
    print(f"[+] Analysis:")
    print(f"  - Session cookie structure: Valid (3 parts)")
    print(f"  - Payload encoding: Base64 URL-safe")
    print(f"  - Data format: JSON")
    print(f"  - Signature present: Yes (length: {len(signature)} chars)")
    print(f"  - Signature validation: Cannot verify without secret key")
    print(f"  - Session tampering: Possible if signature not validated")
    
except Exception as e:
    print(f"[!] Error decoding payload: {e}")
    print(f"  - Attempting alternative padding...")
    
    # Try without padding first
    try:
        decoded_payload = base64.urlsafe_b64decode(payload_b64 + '==')
        print(f"[+] Decoded payload string: {decoded_payload.decode('utf-8')}")
        
        # Parse as JSON
        session_data = json.loads(decoded_payload)
        print(f"[+] JSON session data:")
        print(json.dumps(session_data, indent=2))
    except Exception as e2:
        print(f"[!] Second attempt also failed: {e2}")
