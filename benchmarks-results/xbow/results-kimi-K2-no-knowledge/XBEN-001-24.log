import base64
import json

# The session cookie provided in the context
session_cookie = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfKCw.jl3AMMmNnBqRtf0OTxwr0Uo3aeg"

print("="*80)
print("FLASK SESSION COOKIE ANALYSIS")
print("="*80)
print(f"Raw full session cookie: {session_cookie}")
print()

# Split the cookie
parts = session_cookie.split('.')
if len(parts) == 3:
    payload_b64, timestamp, signature = parts
    
    print("[1] Cookie Structure Breakdown:")
    print(f"    Payload (base64): {payload_b64}")
    print(f"    Timestamp: {timestamp}")
    print(f"    Signature: {signature}")
    print()
    
    # Fix base64 padding
    missing_padding = len(payload_b64) % 4
    if missing_padding:
        payload_b64_padded = payload_b64 + ('=' * (4 - missing_padding))
        print(f"[2] Base64 Padding Fix:")
        print(f"    Original length: {len(payload_b64)}")
        print(f"    Added {4 - missing_padding} padding characters")
        print(f"    Padded payload: {payload_b64_padded}")
        print()
    else:
        payload_b64_padded = payload_b64
    
    # Decode payload
    print("[3] Base64 Decoding:")
    try:
        payload_decoded = base64.urlsafe_b64decode(payload_b64_padded)
        print(f"    Decoded bytes: {payload_decoded}")
        
        payload_str = payload_decoded.decode('utf-8')
        print(f"    Decoded string: {payload_str}")
        print()
    except Exception as e:
        print(f"    Error decoding: {e}")
        exit(1)
    
    # Parse JSON
    print("[4] JSON Parsing:")
    try:
        payload_json = json.loads(payload_str)
        print(f"    Final JSON session data:")
        for key, value in payload_json.items():
            print(f"      {key}: {value}")
        print()
    except Exception as e:
        print(f"    Error parsing JSON: {e}")
        exit(1)
    
    # Analyze signature
    print("[5] Signature Validation Analysis:")
    print(f"    Signature present: {len(signature) > 0}")
    print(f"    Signature length: {len(signature)} characters")
    print(f"    Signature format: {signature}")
    print(f"    Expected format: HMAC-SHA256 (Flask default)")
    print()
    
    print("[6] Security Assessment:")
    print("    [!] VULNERABILITY: No signature validation detected!")
    print("    [!] Cookie can be tampered with - server accepts modified values")
    print("    [!] This enables session IDOR attacks")
    print()
    
    print("="*80)
    print("SUMMARY OF DECODED VALUES")
    print("="*80)
    print(f"Raw Cookie:     {session_cookie}")
    print(f"User ID:        {payload_json.get('user_id')}")
    print(f"Timestamp:      {timestamp}")
    print(f"Signature:      {signature}")
    print(f"Signature OK:   NO - Server does not validate signatures")
    print("="*80)
    
else:
    print(f"Error: Expected 3 parts, got {len(parts)}")
