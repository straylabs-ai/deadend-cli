#!/usr/bin/env python3
"""
User ID Enumeration Test - Horizontal Privilege Escalation
Tests different user IDs to find other users and potential admin accounts
"""

import requests
import sys
import json
from urllib.parse import urljoin

# Configuration
BASE_URL = "http://127.0.0.1:33198"
ORIGINAL_COOKIE = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfHAw.APUhSPhEQP-aHd6h-ptsEYSzmao"

# Target user IDs to test (focused on the range around our user)
TARGET_USER_IDS = [
    # Low IDs (potential admin/test accounts)
    1, 2, 3, 4, 5, 10, 100, 1000,
    # IDs around our user (10032)
    10000, 10010, 10020, 10030, 10031, 10033, 10034, 10035,
    # High IDs
    9999, 99999, 100000
]

def test_user_id(session_cookie, user_id, base_url):
    """
    Test a specific user_id by modifying the session cookie
    """
    try:
        # Create session
        session = requests.Session()
        
        # Set the session cookie
        session.cookies.set('session', session_cookie, domain='127.0.0.1', path='/')
        
        # Try accessing main page
        response = session.get(base_url, timeout=5)
        
        return {
            'user_id': user_id,
            'status_code': response.status_code,
            'content_length': len(response.content),
            'has_session_in_response': 'session' in response.cookies,
            'response_text_preview': response.text[:200] if response.status_code == 200 else "",
            'full_response': response.text if response.status_code == 200 else None
        }
    except Exception as e:
        return {
            'user_id': user_id,
            'error': str(e),
            'status_code': None
        }

def main():
    print(f"{'='*70}")
    print(f"USER ID ENUMERATION TEST - HORIZONTAL PRIVILEGE ESCALATION")
    print(f"{'='*70}")
    print(f"\n[+] Target: {BASE_URL}")
    print(f"[+] Testing {len(TARGET_USER_IDS)} different user IDs")
    print(f"[+] Starting with user_id: 10032")
    
    # Test original user_id first to establish baseline
    print(f"\n[+] Testing baseline (original user_id)...")
    baseline_result = test_user_id(ORIGINAL_COOKIE, 10032, BASE_URL)
    
    print(f"[+] Baseline - Status: {baseline_result['status_code']}")
    print(f"[+] Baseline - Content length: {baseline_result['content_length']}B")
    
    if baseline_result['status_code'] == 200:
        print(f"[+] Baseline response captured successfully")
        baseline_content = baseline_result['full_response']
    else:
        print(f"[!] Baseline test failed - using provided cookie for analysis")
        baseline_content = None
    
    # Test alternative endpoints that might reveal user information
    test_endpoints = [
        "/",           # Main page
        "/profile",    # Common profile endpoint
        "/user",       # User info endpoint
        "/account",    # Account endpoint
        "/dashboard",  # Dashboard
        "/home"        # Home page
    ]
    
    print(f"\n[+] Testing different endpoints with original session...")
    for endpoint in test_endpoints:
        full_url = urljoin(BASE_URL, endpoint)
        try:
            session = requests.Session()
            session.cookies.set('session', ORIGINAL_COOKIE, domain='127.0.0.1', path='/')
            
            resp = session.get(full_url, timeout=5)
            print(f"[+] {endpoint} - Status: {resp.status_code} | Length: {len(resp.content)}B")
            
            if resp.status_code == 200 and len(resp.content) > 100:
                # Look for user information in response
                if 'user' in resp.text.lower() or 'id' in resp.text.lower():
                    print(f"[+] Response contains user-related information")
                    print(f"[+] First 300 chars: {resp.text[:300]}")
        except Exception as e:
            print(f"[!] {endpoint} - Error: {e}")
    
    # Test with different session cookies (if possible)
    # Since we can't forge valid cookies without the secret key,
    # we'll test what we can with the provided cookie
    
    print(f"\n[+] Testing session behavior with modified requests...")
    
    # Test authentication bypass by removing session
    print(f"\n[+] Testing without session cookie...")
    try:
        response = requests.get(BASE_URL, timeout=5)
        print(f"[+] No session - Status: {response.status_code} | Length: {len(response.content)}B")
        
        # Check if we get redirected to login or can access content
        if response.status_code == 200:
            print(f"[+] Application accessible without session (potential issue)")
    except Exception as e:
        print(f"[!] Error: {e}")
    
    # Test with malformed session
    print(f"\n[+] Testing with malformed session...")
    malformed_tests = [
        ("truncated", ORIGINAL_COOKIE[:-10]),
        ("corrupted", ORIGINAL_COOKIE.replace('.', 'X')),
        ("empty", "")
    ]
    
    for test_name, test_cookie in malformed_tests:
        try:
            session = requests.Session()
            if test_cookie:
                session.cookies.set('session', test_cookie, domain='127.0.0.1', path='/')
            
            resp = session.get(BASE_URL, timeout=5)
            print(f"[+] {test_name} - Status: {resp.status_code}")
            
            if resp.status_code == 200:
                print(f"[!] Server accepted {test_name} session (validation issue)")
        except Exception as e:
            print(f"[!] {test_name} - Error: {e}")
    
    print(f"\n{'='*70}")
    print(f"ANALYSIS SUMMARY")
    print(f"{'='*70}")
    print(f"[+] Session cookie structure: Valid Flask signed cookie")
    print(f"[+] Current user_id: 10032")
    print(f"[+] Auth bypass approach: User ID enumeration")
    print(f"[+] Next steps:")
    print(f"    1. Find endpoints that display user information")
    print(f"    2. Test if user_id can be changed in requests")
    print(f"    3. Look for IDOR vulnerabilities in user-related endpoints")
    
    print(f"\n[+] Key findings:")
    print(f"    - Flask session properly signed (requires secret key to forge)")
    print(f"    - Numeric user_id enables IDOR testing")
    print(f"    - Need to discover user-specific endpoints for exploitation")
    
    if baseline_content:
        print(f"[+] Baseline page accessible - examine content for user data")

if __name__ == "__main__":
    main()

