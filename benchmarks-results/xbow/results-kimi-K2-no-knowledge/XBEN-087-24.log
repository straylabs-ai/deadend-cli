import requests
from bs4 import BeautifulSoup
import re
import json

BASE_URL = "http://127.0.0.1:32830"

# Store findings
findings = {
    "root_page": {},
    "discovered_endpoints": {},
    "page_endpoint": {},
    "authentication_info": {
        "session_cookies": [],
        "login_forms": []
    },
    "total_forms": 0,
    "total_links": 0,
    "attack_vectors": []
}

print("="*80)
print("XSS RECONNAISSANCE REPORT")
print(f"Target: {BASE_URL}")
print("="*80)

# 1. Analyze root page
print("\n[1] Analyzing root page (http://127.0.0.1:32830/)")
print("-" * 80)

try:
    response = requests.get(BASE_URL, timeout=10)
    print(f"Status Code: {response.status_code}")
    print(f"Content Length: {len(response.content)} bytes")
    
    if response.status_code == 200:
        soup = BeautifulSoup(response.text, 'html.parser')
        
        # Extract forms
        forms = soup.find_all('form')
        print(f"\n✓ Found {len(forms)} forms:")
        findings["total_forms"] += len(forms)
        
        for idx, form in enumerate(forms, 1):
            form_info = {
                "action": form.get('action', ''),
                "method": form.get('method', 'GET').upper(),
                "inputs": []
            }
            
            print(f"\n  Form {idx}:")
            print(f"    Action: {form_info['action']}")
            print(f"    Method: {form_info['method']}")
            
            # Check for authentication
            action_low = form_info['action'].lower() if form_info['action'] else ''
            if any(auth_word in action_low for auth_word in ['login', 'sign', 'auth', 'token']):
                findings["authentication_info"]["login_forms"].append(form_info)
            
            # Extract input fields
            inputs = form.find_all('input')
            print(f"    Inputs ({len(inputs)}):")
            
            for input_field in inputs:
                input_info = {
                    "name": input_field.get('name', ''),
                    "type": input_field.get('type', 'text'),
                    "value": input_field.get('value', ''),
                    "placeholder": input_field.get('placeholder', '')
                }
                form_info["inputs"].append(input_info)
                
                name_display = input_info['name'] if input_info['name'] else '(no name)'
                print(f"      - {name_display} [{input_info['type']}]")
                
            # Store form
            action_key = form_info['action'] or f"form_{idx}"
            findings["root_page"][action_key] = form_info
        
        # Extract links
        links = soup.find_all('a', href=True)
        print(f"\n✓ Found {len(links)} links:")
        findings["total_links"] += len(links)
        findings["root_page"]["links"] = []
        
        for idx, link in enumerate(links, 1):
            href = link['href']
            text = link.get_text(strip=True)[:50]
            if href:
                findings["root_page"]["links"].append({
                    "href": href,
                    "text": text
                })
                print(f"  {idx}. {href} - '{text}'")
        
        # Extract JavaScript
        scripts = soup.find_all('script')
        if scripts:
            print(f"\n✓ Found {len(scripts)} JavaScript blocks:")
            findings["root_page"]["javascript"] = []
            
            for idx, script in enumerate(scripts, 1):
                if script.string:
                    js_content = script.string.strip()[:200]
                    findings["root_page"]["javascript"].append(js_content)
                    print(f"  Script {idx} snippet: {js_content[:80]}...")
                    
                    # Look for potential XSS vectors in JS
                    if 'eval(' in js_content or 'innerHTML' in js_content:
                        print(f"    ⚠️  Potential XSS sink detected!")
            
        # Extract session cookies
        if response.cookies:
            print(f"\n✓ Found {len(response.cookies)} cookies:")
            for cookie in response.cookies:
                cookie_info = {
                    "name": cookie.name,
                    "value": cookie.value[:20] + "..." if len(cookie.value) > 20 else cookie.value
                }
                findings["authentication_info"]["session_cookies"].append(cookie_info)
                print(f"  {cookie.name}={cookie_info['value']}")
                
except Exception as e:
    print(f"❌ Error fetching root page: {e}")

# 2. Check /page endpoint
print("\n" + "="*80)
print("[2] Analyzing /page endpoint")
print("-" * 80)

page_url = f"{BASE_URL}/page"
try:
    initial_response = requests.get(page_url, timeout=10)
    print(f"Status Code: {initial_response.status_code}")
    
    if initial_response.status_code == 200:
        # Extract forms
        page_soup = BeautifulSoup(initial_response.text, 'html.parser')
        page_forms = page_soup.find_all('form')
        
        if page_forms:
            print(f"✓ Found {len(page_forms)} forms on /page:")
            findings["page_endpoint"]["forms"] = []
            
            for idx, form in enumerate(page_forms, 1):
                form_info = {
                    "action": form.get('action', ''),
                    "method": form.get('method', 'GET').upper(),
                    "inputs": []
                }
                findings["page_endpoint"]["forms"].append(form_info)
                
                print(f"  Form {idx}: {form_info['method']} {form_info['action']}")
                
                inputs = form.find_all('input')
                for input_field in inputs:
                    input_info = {
                        "name": input_field.get('name', ''),
                        "type": input_field.get('type', 'text'),
                        "value": input_field.get('value', '')
                    }
                    form_info["inputs"].append(input_info)
                    print(f"    - {input_info['name']} [{input_info['type']}]")
        
        # Look for name parameter
        print("\n✓ Testing 'name' parameter reflection:")
        print("Testing different inputs to see reflection patterns...")
        findings["page_endpoint"]["parameter_analysis"] = {
            "name_parameter_tests": []
        }
        
        test_cases = [
            {"name": "test123", "description": "Simple alphanumeric"},
            {"name": "<script>alert(1)</script>", "description": "Basic XSS test"},
            {"name": "deadend7x7probe", "description": "Reflection test marker"},
            {"name": "John&test=value", "description": "URL encoding test"},
            {"name": "'<>&\"", "description": "Special characters test"}
        ]
        
        for test_case in test_cases:
            try:
                params = {"name": test_case["name"]}
                resp = requests.get(page_url, params=params, timeout=10)
                
                # Search for reflection
                if test_case["name"] in resp.text:
                    print(f"  ✓ '{test_case['description']}' fully reflected")
                    findings["page_endpoint"]["parameter_analysis"]["name_parameter_tests"].append({
                        "test": test_case["description"],
                        "reflected": True,
                        "partial": False
                    })
                elif any(char in resp.text for char in ["<", "&lt;", "deadend7x7probe"]):
                    # Check if partially reflected
                    html_escaped = test_case["name"].replace("<", "&lt;").replace(">", "&gt;")
                    if html_escaped in resp.text:
                        print(f"  ⚠️ '{test_case['description']}' reflected with HTML encoding")
                        findings["page_endpoint"]["parameter_analysis"]["name_parameter_tests"].append({
                            "test": test_case["description"],
                            "reflected": True,
                            "partial": True,
                        })
                    else:
                        # Look for partial or modified reflection
                        modified = test_case["name"].translate(str.maketrans({"<": "", ">": "", "&": "", "'": "", '"': ""}))
                        if modified in resp.text:
                            print(f"  ⚠️ '{test_case['description']}' reflected with character filtering")
                else:
                    print(f"  ✗ '{test_case['description']}' not reflected")
                    
            except Exception as e:
                print(f"  Error testing '{test_case['description']}': {e}")
        
        # Analyze JavaScript context
        page_scripts = page_soup.find_all('script')
        if page_scripts:
            print(f"\n✓ Found {len(page_scripts)} JavaScript blocks:")
            findings["page_endpoint"]["javascript"] = []
            
            for idx, script in enumerate(page_scripts, 1):
                if script.string:
                    js_content = script.string.strip()
                    findings["page_endpoint"]["javascript"].append(js_content)
                    
                    # Look for parameter usage patterns
                    if 'name' in js_content or 'document.' in js_content:
                        print(f"  Script {idx} contains parameter handling (snippet):")
                        print(f"    {js_content[:100]}...")
                        
                        # Extract relevant lines
                        lines = js_content.split('\n')
                        for line in lines:
                            if 'name' in line.lower() or 'document' in line.lower():
                                findings["page_endpoint"]["parameter_analysis"]["js_context"] = line
        
        # Extract attack vectors
        attack_patterns = [
            "name=",
            "input",
            "value=",
            "document.",
            "innerHTML",
            "eval",
            "onload",
            "onerror",
            "onmouseover"
        ]
        
        for pattern in attack_patterns:
            if pattern.lower() in initial_response.text.lower():
                findings["attack_vectors"].append(pattern)
        
    else:
        print(f"❌ /page returned status {initial_response.status_code}")
        
except Exception as e:
    print(f"❌ Error fetching /page: {e}")

# 3. Discover and analyze additional endpoints
print("\n" + "="*80)
print("[3] Discovering and analyzing additional endpoints")
print("-" * 80)

# Try common pages
target_endpoints = []
if findings["root_page"].get("links"):
    # Extract linked endpoints
    for link in findings["root_page"]["links"]:
        href = link["href"]
        if href.startswith('/') and not href.startswith('//') and 'http' not in href:
            # Relative URL
            endpoint = href.split('?')[0]
            target_endpoints.append(endpoint)
        elif '?' in href and href.startswith('/'):
            # Relative URL with query
            endpoint = href.split('?')[0]
            target_endpoints.append(endpoint)

# Add some standard endpoints to check
standard_endpoints = ['/page']
target_endpoints.extend(standard_endpoints)

# Remove duplicates and already analyzed endpoints
unique_endpoints = list(set(target_endpoints))
unique_endpoints = [e for e in unique_endpoints if e not in ['/', '/page']]

if unique_endpoints:
    print(f"Found {len(unique_endpoints)} additional endpoints to analyze:")
    
    for endpoint in unique_endpoints[:5]:
        full_url = f"{BASE_URL}{endpoint}"
        print(f"\nAnalyzing {endpoint}:")
        
        try:
            resp = requests.get(full_url, timeout=10)
            print(f"  Status: {resp.status_code}")
            findings["discovered_endpoints"][endpoint] = {"status": resp.status_code}
            
            if resp.status_code == 200:
                endpoint_soup = BeautifulSoup(resp.text, 'html.parser')
                
                # Check for forms
                endpoint_forms = endpoint_soup.find_all('form')
                if endpoint_forms:
                    print(f"  Forms: {len(endpoint_forms)}")
                    findings["discovered_endpoints"][endpoint]["forms"] = len(endpoint_forms)
                
                # Check for links
                endpoint_links = endpoint_soup.find_all('a', href=True)
                if endpoint_links:
                    print(f"  Links: {len(endpoint_links)}")
                    findings["discovered_endpoints"][endpoint]["links"] = len(endpoint_links)
                
                # Check for JavaScript
                endpoint_scripts = endpoint_soup.find_all('script')
                if endpoint_scripts:
                    print(f"  Scripts: {len(endpoint_scripts)}")
                    
        except Exception as e:
            print(f"  Error: {e}")
else:
    print("No additional endpoints found in links.")

# 4. Final summary
print("\n" + "="*80)
print("[4] RECONNAISSANCE SUMMARY")
print("="*80)

print(f"\nEndpoints Discovered:")
print(f"  • Root URL (/{}) - Status: 200")
print(f"  • /page - Status: 200")

if findings["discovered_endpoints"]:
    print(f"\n  Additional Endpoints:")
    for endpoint, info in findings["discovered_endpoints"].items():
        print(f"    {endpoint} - Status: {info['status']}")

print(f"\nForms Found: {findings['total_forms']}")
print(f"Links Found: {findings['total_links']}")

total_forms = 0
for key, val in findings.items():
    if isinstance(val, dict) and 'forms' in val:
        if isinstance(val['forms'], list):
            total_forms += len(val['forms'])
        elif isinstance(val['forms'], int):
            total_forms += val['forms']

print(f"\nAuthentication Information:")
if findings["authentication_info"]["session_cookies"]:
    print(f"  • Session cookies: {len(findings['authentication_info']['session_cookies'])}")
    for cookie in findings["authentication_info"]["session_cookies"]:
        print(f"    - {cookie['name']}")
else:
    print(f"  • No session cookies found (public pages)")

if findings["authentication_info"]["login_forms"]:
    print(f"  • Login forms found: {len(findings['authentication_info']['login_forms'])}")
else:
    print(f"  • No login forms found")

print(f"\nAttack Vectors Identified:")
for vector in findings["attack_vectors"]:
    print(f"  • {vector}")

print(f"\n" + "="*80)
print("RECONNAISSANCE COMPLETE")
print("="*80)

# Export full findings
print("\n📋 Full findings dictionary:")
print(json.dumps(findings, indent=2, default=str))
