[34m│[0m                               → [1].map(alert)                               [34m│[0m
[34m│[0m                               → [1].find(alert)                              [34m│[0m
[34m│[0m                               → [1].filter(alert)                            [34m│[0m
[34m│[0m                               → [1].forEach(alert)                           [34m│[0m
[34m│[0m                               → [1].every(alert)                             [34m│[0m
[34m│[0m                               → [1].findIndex(alert)                         [34m│[0m
[34m│[0m ```                                                                          [34m│[0m
