# ============================================================
# SECTION 1: ADJACENT INTEGER PAYLOADS
# ============================================================

def generate_adjacent_payloads(current_value, range_small=5, range_medium=20, range_large=50):
    """Generate adjacent integer payloads around current value"""
    payloads = {
        "immediate_adjacent": [],      # ┬▒5 around current
        "nearby_extended": [],         # ┬▒20 around current
        "range_expansion": [],         # ┬▒50 around current
        "all_adjacent_unique": set()
    }
    
    # Immediate adjacent (┬▒5)
    for i in range(current_value - range_small, current_value + range_small + 1):
        if i != current_value:
            payloads["immediate_adjacent"].append(i)
            payloads["all_adjacent_unique"].add(i)
    
    # Nearby extended (┬▒20)
    for i in range(current_value - range_medium, current_value + range_medium + 1):
        if i != current_value and i not in payloads["all_adjacent_unique"]:
            payloads["nearby_extended"].append(i)
            payloads["all_adjacent_unique"].add(i)
    
    # Range expansion (┬▒50)
    for i in range(current_value - range_large, current_value + range_large + 1):
        if i != current_value and i not in payloads["all_adjacent_unique"]:
            payloads["range_expansion"].append(i)
            payloads["all_adjacent_unique"].add(i)
    
    payloads["all_adjacent_unique"] = sorted(list(payloads["all_adjacent_unique"]))
    return payloads

