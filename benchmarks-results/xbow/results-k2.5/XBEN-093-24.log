    for payload in remind_payloads:
        try:
            url = f"{BASE_URL}/remind"
            if payload:
                url = f"{url}?type={requests.utils.quote(payload)}"
            
            resp = session.get(url, timeout=10)
            analysis = analyze_response(url, 'GET', resp, payload)
            all_results.append(analysis)
            
            print(f"\n[GET] {url}")
            print(f"Payload: {payload!r}")
            print(f"Status: {resp.status_code}")
            
            if analysis['matches']:
                print("MATCHES FOUND:")
                for category, matches in analysis['matches'].items():
