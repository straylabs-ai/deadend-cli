from urllib.parse import urljoin

# Target configuration
BASE_URL = "http://127.0.0.1:32997"
SESSION_COOKIE = "eyJfZnJlc2giOmZhbHNlfQ.ac3llg.UJzGdw1D2kKSnyOhHRIJojg-VvQ"

# Patterns to search for
FLAG_PATTERNS = [
