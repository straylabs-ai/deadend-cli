        if "/var/www" in response_lower or "/app" in response_lower or "/home" in response_lower:
            indicators.append("FOUND path indicators")
        
        # Environment variable indicators
        if "path=" in response_lower or "home=" in response_lower or "user=" in response_lower:
            indicators.append("FOUND environment variables")
        
        # Time-based detection
        if elapsed > 4.0:  # If delay was significant (sleep 5)
