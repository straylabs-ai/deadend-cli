        except Exception as e:
            print(f"Error testing {payload}: {e}")
    
    return all_results

def analyze_findings(results):
    """Summarize all findings"""
    print("\n" + "=" * 80)
    print("SUMMARY OF INFORMATION DISCLOSURE ANALYSIS")
    print("=" * 80)
    
    total_requests = len(results)
    requests_with_findings = 0
    all_matches = {}
    
    for result in results:
        if result['matches']:
            requests_with_findings += 1
            for category, matches in result['matches'].items():
                if category not in all_matches:
                    all_matches[category] = []
                all_matches[category].extend(matches)
    
    print(f"\nTotal requests made: {total_requests}")
    print(f"Requests with information disclosure indicators: {requests_with_findings}")
    
    if all_matches:
        print("\nFINDINGS BY CATEGORY:")
        for category, matches in all_matches.items():
            print(f"\n{category}:")
            # Remove duplicates while preserving order
            unique_matches = list(dict.fromkeys(matches))
            for match in unique_matches[:10]:  # Limit to first 10 per category
                print(f"  - {match}")
            if len(unique_matches) > 10:
                print(f"  ... and {len(unique_matches) - 10} more")
    else:
        print("\nNo information disclosure indicators detected in any response.")
    
    # Check for specific patterns
    print("\n" + "=" * 80)
    print("DETAILED SECURITY INDICATORS CHECK")
    print("=" * 80)
    
    indicators = {
        'FLAG Patterns': 'FLAG' in all_matches,
        'SQL Error Messages': 'SQL_ERROR' in all_matches,
        'Stack Traces': 'STACK_TRACE' in all_matches,
        'Debug Mode Indicators': 'DEBUG' in all_matches,
        'File Path Disclosures': 'PATH_DISCLOSURE' in all_matches,
        'Server Version Headers': 'HEADERS' in all_matches or 'SERVER_VERSION' in all_matches,
        'Verbose Auth Failures': 'AUTH_FAILURE' in all_matches,
        'Database Structure Hints': 'DB_STRUCTURE' in all_matches
    }
    
    for indicator, present in indicators.items():
        status = "✗ FOUND" if present else "✓ NOT FOUND"
        print(f"{indicator}: {status}")
    
    return all_matches

# Run analysis
