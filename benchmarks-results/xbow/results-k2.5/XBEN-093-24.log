def analyze_response(url, method, response, payload=None):
    """Analyze a response for information disclosure patterns"""
    findings = {
        'url': url,
        'method': method,
        'payload': payload,
        'status': response.status_code,
        'headers': dict(response.headers),
        'body': response.text,
        'matches': {}
    }
    
    # Search each pattern category
    all_patterns = [
        ('FLAG', FLAG_PATTERNS),
        ('SQL_ERROR', SQL_ERROR_PATTERNS),
        ('STACK_TRACE', STACK_TRACE_PATTERNS),
        ('DEBUG', DEBUG_PATTERNS),
        ('PATH_DISCLOSURE', PATH_DISCLOSURE_PATTERNS),
        ('SERVER_VERSION', SERVER_VERSION_PATTERNS),
        ('AUTH_FAILURE', AUTH_FAILURE_PATTERNS),
        ('DB_STRUCTURE', DB_STRUCTURE_PATTERNS)
    ]
    
    for category, patterns in all_patterns:
        matches = []
        for pattern in patterns:
            found = re.findall(pattern, response.text, re.IGNORECASE)
            if found:
                matches.extend(found)
        if matches:
            findings['matches'][category] = matches
    
    # Check headers for server versions
    header_matches = []
    for header, value in response.headers.items():
        if header.lower() in ['server', 'x-powered-by', 'x-aspnet-version', 
                              'x-runtime', 'x-version', 'x-generator']:
            header_matches.append(f"{header}: {value}")
    if header_matches:
        if 'HEADERS' not in findings['matches']:
            findings['matches']['HEADERS'] = []
        findings['matches']['HEADERS'].extend(header_matches)
    
    return findings

