import requests
import re
from urllib.parse import unquote

# Target configuration
BASE_URL = "http://127.0.0.1:32997"
LOGIN_URL = f"{BASE_URL}/login"
REMIND_URL = f"{BASE_URL}/remind"

print("="*70)
print("STEP 1: AUTHENTICATION (Manual Cookie Handling)")
print("="*70)

# Create a session
session = requests.Session()

# Login without redirects to capture the Set-Cookie
login_data = {
    'username': 'user',
    'password': 'user'
}

print("\n[+] Step 1A: POST to /login without following redirects...")
login_resp = session.post(LOGIN_URL, data=login_data, allow_redirects=False)
print(f"[+] Login POST Status: {login_resp.status_code}")
print(f"[+] Set-Cookie header: {login_resp.headers.get('set-cookie')}")

# Extract the cookie manually
set_cookie = login_resp.headers.get('set-cookie')
if set_cookie:
    # Parse the session cookie value
    cookie_match = re.search(r'session=([^;]+)', set_cookie)
    if cookie_match:
        session_cookie = cookie_match.group(1)
        print(f"[+] Extracted session cookie: {session_cookie[:50]}...")
        
        # Manually set the cookie on the session
        session.cookies.set('session', session_cookie)
        print(f"[+] Cookie manually set in session")
    else:
        print("[-] Could not extract session cookie value")
        session_cookie = None
else:
    print("[-] No Set-Cookie header in login response")
    session_cookie = None

print(f"[+] Session cookies: {dict(session.cookies)}")

# Step 2: Follow the redirect manually with our session
if login_resp.status_code == 302:
    redirect_location = login_resp.headers.get('location')
    print(f"\n[+] Step 1B: Following redirect to {redirect_location}...")
    
    redirect_resp = session.get(f"{BASE_URL}{redirect_location}")
    print(f"[+] Redirect response Status: {redirect_resp.status_code}")
    print(f"[+] Redirect response URL: {redirect_resp.url}")
    
    # Check for flashes
    if 'flash' in redirect_resp.text.lower() or 'message' in redirect_resp.text.lower():
        print("[+] Flash messages may be present")
    
    # Check if we're still on login or got redirected
    if '/login' in redirect_resp.url:
        print("[-] Redirected back to login - checking flash messages...")
        # Look for flash messages
        flash_match = re.search(r'(message|flash|error)[^>]*>([^<]+)', redirect_resp.text, re.I)
        if flash_match:
            print(f"[!] Flash message: {flash_match.group(2)}")
    elif '/transactions' in redirect_resp.url:
        print("[+] Successfully redirected to transactions!")

# Step 3: Directly test /transactions
print("\n[+] Step 1C: Directly testing /transactions with session...")
trans_resp = session.get(f"{BASE_URL}/transactions")
print(f"[+] Transactions Status: {trans_resp.status_code}")
