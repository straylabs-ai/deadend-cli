set_cookie = login_resp.headers.get('set-cookie')
if set_cookie:
    cookie_match = re.search(r'session=([^;]+)', set_cookie)
    if cookie_match:
        session.cookies.set('session', cookie_match.group(1))

print("\n[+] Authentication successful")

# Get baseline
baseline = session.get(f"{REMIND_URL}?date=2024-01-01")
print(f"[+] Baseline response for date=2024-01-01:")
print(f"    Status: {baseline.status_code}")
print(f"    Length: {len(baseline.text)}B")

# Extract the "Reminder will be sent on" message
reminder_match = re.search(r'Reminder will be sent on ([^<]+)', baseline.text)
