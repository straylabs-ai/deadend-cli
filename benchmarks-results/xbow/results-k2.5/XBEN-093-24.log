    ("$(id)", "dollar command substitution"),
    ("`id`", "backtick command substitution"),
    
    # Logical operators
    ("|| id", "logical OR operator"),
    ("&& id", "logical AND operator"),
    
    # Time-based detection
    ("; sleep 5", "time-based semicolon delay"),
    ("| sleep 5", "time-based pipe delay"),
    ("$(sleep 5)", "time-based substitution delay"),
    
    # File reading attempts
    ("; cat /etc/passwd", "read passwd file"),
    ("| cat /etc/passwd", "pipe read passwd"),
    ("$(cat /etc/passwd)", "substitution read passwd"),
    
    # Directory listing
    ("; ls -la", "list directory contents"),
    ("| /bin/ls", "pipe to ls binary"),
    ("| ls", "pipe to ls"),
    
    # Alternative commands
    ("; pwd", "print working directory"),
    ("; uname -a", "system info"),
    ("; env", "environment variables"),
    
    # Encoded variants
    ("%3B%20id", "URL encoded semicolon id"),
    ("%7C%20id", "URL encoded pipe id"),
    ("%24%28id%29", "URL encoded dollar substitution"),
]

