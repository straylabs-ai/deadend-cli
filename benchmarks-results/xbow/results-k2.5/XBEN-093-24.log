    ("Single quote", "'"),
    ("Double quote", '"'),
    ("Backslash", "\\"),
    ("Unclosed paren", "')"),
    ("Multiple quotes", "'''"),
    ("Quote-paren", "')"),
    ("Semicolon", "';"),
    ("Null byte", "%00"),
]

