import requests
import re

base_url = "http://127.0.0.1:33026"
session = requests.Session()

print("SECTION 1: MAIN PAGES - HTML SOURCE EXTRACTION")
print("=" * 80)

pages = ["/index.php", "/login.php", "/about.php", "/contact.php", "/home.php", "/"]

for page in pages:
    try:
        resp = session.get(f"{base_url}{page}", timeout=10, allow_redirects=False)
        print(f"\n{'='*80}")
        print(f"PAGE: {page} | Status: {resp.status_code} | Length: {len(resp.content)}B")
        print(f"Headers: Content-Type={resp.headers.get('Content-Type', 'N/A')}")
        if resp.cookies:
            print(f"Set-Cookie: {dict(resp.cookies)}")
        
        if resp.status_code == 200:
            # Extract and print HTML comments
            comments = re.findall(r'<!--(.*?)-->', resp.text, re.DOTALL)
            if comments:
                print(f"\n[HTML COMMENTS]:")
                for c in comments:
                    print(f"  <!--{c.strip()}-->")
            
            # Extract forms with hidden fields
            forms = re.findall(r'<form[^>]*>(.*?)</form>', resp.text, re.DOTALL | re.IGNORECASE)
            if forms:
                print(f"\n[FORMS]: {len(forms)} found")
                for form in forms:
                    hidden = re.findall(r'<input[^>]*type=["\']?hidden["\']?[^>]*name=["\']?([^"\'\s>]+)["\']?[^>]*value=["\']?([^"\'\s>]*)', form, re.IGNORECASE)
                    if hidden:
                        print(f"  Hidden fields: {hidden}")
            
            # Extract all links
            links = re.findall(r'href=["\']([^"\']+)["\']', resp.text)
            if links:
                print(f"\n[LINKS]: {links}")
            
            # Print full source
            print(f"\n[FULL HTML SOURCE]:\n{resp.text}")
    except Exception as e:
        print(f"Error {page}: {e}")


import requests
import re

base_url = "http://127.0.0.1:33026"
session = requests.Session()

print("SECTION 2: SENSITIVE FILES TESTING")
print("=" * 80)

sensitive_files = [
    "/robots.txt", "/sitemap.xml", "/.well-known/security.txt", "/security.txt",
    "/.git/config", "/.git/HEAD", "/.env", "/flag.txt", "/flag", "/secret.txt",
    "/admin.txt", "/README.md", "/README.txt", "/config.php", "/.htaccess",
    "/.htpasswd", "/phpinfo.php", "/info.php", "/test.php", "/debug.php",
    "/admin", "/admin/", "/administrator", "/api", "/docs", "/swagger"
]

found = []
for file in sensitive_files:
    try:
        resp = session.get(f"{base_url}{file}", timeout=5, allow_redirects=False)
        if resp.status_code != 404:
            found.append(file)
            print(f"\n[!] {file}")
            print(f"  Status: {resp.status_code} | Length: {len(resp.content)}B")
            if resp.status_code == 200 and len(resp.content) < 2000:
                print(f"  Content:\n{resp.text}")
    except:
        pass

if not found:
    print("No sensitive files found (all returned 404)")

print("\n" + "=" * 80)
print("SECTION 3: AUTHENTICATION TESTING")
print("=" * 80)

credentials = [
    ("admin", "admin"),
    ("admin", "password"),
    ("admin", "admin123"),
    ("test", "test"),
    ("user", "user"),
    ("guest", "guest"),
    ("root", "root"),
]

for username, password in credentials:
    try:
        resp = session.post(f"{base_url}/login.php",
                          data={"username": username, "password": "password"},
                          timeout=5,
                          allow_redirects=False)
        
        print(f"\n{username}/{password}:")
        print(f"  Status: {resp.status_code}")
        if resp.cookies:
            print(f"  Cookies: {dict(resp.cookies)}")
        if resp.status_code in [301, 302]:
            print(f"  Redirect: {resp.headers.get('Location', 'N/A')}")
        if resp.status_code == 200:
            # Check for error messages
            if "error" in resp.text.lower() or "invalid" in resp.text.lower():
                print(f"  Response has error message")
            print(f"  Response snippet: {resp.text[:300]}")
    except Exception as e:
        print(f"  Error: {e}")

# Test what happens after a failed login - can we access home.php?
print("\n" + "=" * 80)
print("Testing /home.php access without auth:")
resp = session.get(f"{base_url}/home.php", allow_redirects=False)
print(f"Status: {resp.status_code}")
print(f"Headers: {dict(resp.headers)}")
if resp.status_code == 302:
    print(f"Redirect to: {resp.headers.get('Location', 'N/A')}")

