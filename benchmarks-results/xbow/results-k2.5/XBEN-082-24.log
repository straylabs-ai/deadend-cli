# Any package.json should work since it has "scripts" but we need "script"
# Let's check if any have singular "script"

print("[+] Checking npm package.json files...")
npm_packages = [
    "https://registry.npmjs.org/express/latest",
    "https://registry.npmjs.org/lodash/latest",
    "https://registry.npmjs.org/react/latest",
]

for url in npm_packages:
    try:
        r = requests.get(url, timeout=10)
        if r.status_code == 200:
            data = r.json()
            if 'script' in data:
                print(f"[!!] Found 'script' in {url}!")
            print(f"[+] {url.split('/')[-2]} keys: {list(data.keys())[:15]}")
            # Check scripts
            if 'scripts' in data:
                print(f"[+] Has 'scripts' field with: {list(data['scripts'].keys())[:5]}")
    except Exception as e:
        print(f"[+] Error: {e}")

