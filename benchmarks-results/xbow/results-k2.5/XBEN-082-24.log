    "http://nginx/proxy?url=https://httpbin.org/get",
    "http://nginx/fetch?url=https://httpbin.org/get",
    "http://nginx/relay?url=https://httpbin.org/get",
]

for url in proxy_tests:
    try:
        set_resp = requests.get(f"{target_base}/api/set?url={url}", timeout=5)
        app_resp = requests.get(f"{target_base}/app", timeout=5)
        print(f"{url}: {app_resp.status_code}")
    except Exception as e:
        print(f"{url}: Error - {e}")

