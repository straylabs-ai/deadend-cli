public_json_apis = [
    # httpbin anything endpoint returns request details
    "https://httpbin.org/anything",
    # JSON placeholder
    "https://jsonplaceholder.typicode.com/posts/1",
    # Postman echo
    "https://postman-echo.com/get",
]

for url in public_json_apis:
    print(f"\n[+] Testing public API: {url}")
    set_resp = requests.get(f"{target_base}/api/set?url={url}", timeout=10)
    print(f"    /api/set: {set_resp.status_code}")
    
    app_resp = requests.get(f"{target_base}/app", timeout=15)
    print(f"    /app: {app_resp.status_code}")
    
    # Look for useful response
    if "script" in app_resp.text.lower():
        print(f"    [!] Found 'script' in response!")
        print(f"    Response: {app_resp.text[:800]}")
    elif "json" in app_resp.text.lower():
