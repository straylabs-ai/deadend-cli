    # Integer 1
    ('int_1', 'a:3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:7:"isAdmin";i:1;}'),
    
    # String "1"
    ('str_1', 'a:3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:7:"isAdmin";s:1:"1";}'),
    
    # String "true"
    ('str_true', 'a:3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:7:"isAdmin";s:4:"true";}'),
    
