field_tests = [
    ('isAdmin', 'b:1'),
    ('is_admin', 'b:1'),
    ('admin', 'b:1'),
    ('role', 's:5:"admin"'),
    ('level', 'i:100'),
    ('access', 's:5:"admin"'),
    ('type', 's:5:"admin"'),
    ('user_type', 's:5:"admin"'),
    ('is_admin_user', 'b:1'),
    ('superuser', 'b:1'),
    ('is_superuser', 'b:1'),
