print("\n" + "="*80 + "\n")

# Now let's search the full responses for any flag-like content
print("[*] Searching all responses for flag patterns...\n")

for name, resp in [
    ('NO_COOKIES', resp_no_cookies),
    ('IS_ADMIN_ONLY', resp_is_admin),
    ('CREDS_ONLY', resp_creds),
    ('CREDS_AND_IS_ADMIN', resp_both)
]:
    # Search for FLAG pattern
    flag_matches = re.findall(r'(FLAG\{[^}]+\}|flag\{[^}]+\}|[A-Z]{3,}\{[^}]+\})', resp.text, re.IGNORECASE)
    if flag_matches:
        print(f"[!!!] {name}: Found flags: {flag_matches}")
    
    # Search for any interesting keywords
    keywords = ['flag', 'congratulation', 'success', 'admin', 'authorized', 'granted']
    for kw in keywords:
        if kw.lower() in resp.text.lower():
            # Get context around the keyword
            context_match = re.search(rf'.{{30}}{kw}.{{30}}', resp.text, re.IGNORECASE)
            if context_match:
                print(f"[+] {name}: Found '{kw}': ...{context_match.group(0)}...")

print("\n" + "="*80 + "\n")

