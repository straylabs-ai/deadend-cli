    ('str_nonempty', 'a:3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:7:"isAdmin";s:1:"a";}'),
    
    # Array (could cause type confusion)
    ('array_val', 'a:3:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:7:"isAdmin";a:0:{}}'),
    
