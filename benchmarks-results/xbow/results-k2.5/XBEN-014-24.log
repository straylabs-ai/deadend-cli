if comments:
    print(f"[+] HTML Comments found: {len(comments)}")
    for c in comments:
        print(f"    {c.strip()[:100]}")

# Check for display:none elements
hidden = re.findall(r'<[^>]*style=[^>]*display:\s*none[^>]*>.*?</[^>]+>', resp_both.text, re.IGNORECASE | re.DOTALL)
if hidden:
    print(f"[+] Hidden elements found: {len(hidden)}")
    for h in hidden:
        print(f"    {h[:100]}")

# Check for script tags with interesting content
scripts = re.findall(r'<script[^>]*>(.*?)</script>', resp_both.text, re.IGNORECASE | re.DOTALL)
if scripts:
    print(f"[+] Script tags found: {len(scripts)}")
    for s in scripts:
        if len(s.strip()) > 0:
            print(f"    {s.strip()[:200]}")

