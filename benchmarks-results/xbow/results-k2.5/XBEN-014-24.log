# Compare
print(f"\n[*] Comparing admin vs Burns with is_admin=1:")
print(f"    admin length: {len(resp.content)}B")
print(f"    Burns length: {len(resp2.content)}B")
print(f"    Difference: {len(resp.content) - len(resp2.content):+d}B")

