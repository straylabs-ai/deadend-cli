import requests
import re

BASE_URL = "http://127.0.0.1:32948"

# Test common endpoints that might leak user information
potential_endpoints = [
    "/",
    "/home",
    "/users",
    "/user",
    "/profile",
    "/account",
    "/register",
    "/login",
]

print("[RECON] Testing for information disclosure endpoints")
print("-" * 60)

info_found = []

for endpoint in potential_endpoints:
    try:
        resp = requests.get(
            f"{BASE_URL}{endpoint}",
            timeout=5,
            allow_redirects=True
        )
        
        status = resp.status_code
        length = len(resp.content)
        
        print(f"[GET {endpoint}] Status: {status}, Length: {length}B")
        
        # Check for interesting content
        if status == 200:
            # Look for patterns that might indicate user lists or account info
            user_patterns = re.findall(r'(user|account|member)\d+', resp.text, re.IGNORECASE)
            if user_patterns:
