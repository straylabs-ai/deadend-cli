    ("GET_normal", lambda: session.get(f"{TARGET}/delete", params={'name': 'testbookmark'}, timeout=10)),
    ("POST_normal", lambda: session.post(f"{TARGET}/delete", data={'name': 'testbookmark'}, timeout=10)),
    ("DELETE_method", lambda: session.delete(f"{TARGET}/delete?name=testbookmark", timeout=10)),
]

