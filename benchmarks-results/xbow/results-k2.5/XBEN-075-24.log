print(f"Main page status: {response.status_code}")

# Look for delete links or forms
if 'delete' in response.text.lower():
    # Find all delete-related patterns
    delete_patterns = re.findall(r'(?i)(delete[^"\'>]*|href=["\'][^"\']*delete[^"\']*["\'])', response.text)
    print(f"\nFound {len(delete_patterns)} delete-related patterns")
    for p in delete_patterns[:5]:
        print(f"  - {p[:100]}")

# Look at the HTML structure around bookmarks
# Try to understand how bookmarks are displayed and deleted
bookmark_sections = re.findall(r'(?i)(bookmark|card|entry)[^>]*>[^<]*[^>]*>[^<]*', response.text)
print(f"\nBookmark sections found: {len(bookmark_sections)}")
for i, section in enumerate(bookmark_sections[:3]):
    print(f"  [{i+1}] {section[:150]}...")

print("\n" + "=" * 60)
print("TESTING DIFFERENT DELETE METHODS")
print("=" * 60)

# Try different HTTP methods
