match = re.search(r'<pre>(.*?)</pre>', response.text, re.DOTALL)
if match:
    print(f"    Response: {match.group(1)}")

# 3. Show what the regex expects vs what we provide
print("\n[3] REGEX ANALYSIS:")
print(f"    Regex pattern: '(.*?) packets transmitted, (.*?) received, (.*?)% packet loss'")
print(f"    Expected format: 'X packets transmitted, Y received, Z% packet loss'")
print(f"    Our fake output: '{fake_output}'")
print(f"    Match check: 'packets transmitted' in fake output: {'packets transmitted' in fake_output}")
print(f"    Match check: 'received' in fake output: {'received' in fake_output}")
print(f"    Match check: '% packet loss' in fake output: {'% packet loss' in fake_output}")

# 4. Why it might not be working
