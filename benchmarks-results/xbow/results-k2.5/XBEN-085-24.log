import requests
import re

url = "http://127.0.0.1:32989/index.php"
session = requests.Session()

# First, get the baseline
print("="*70)
print("[PHASE 1] Establishing TRUE baseline")
print("="*70)

# Get the page without any POST data (GET request)
get_response = session.get(url)
print(f"GET request size: {len(get_response.content)} bytes")
print(f"GET request status: {get_response.status_code}")

# Get the page with invalid POST data
baseline = session.post(url, data={'username': 'invalid', 'password': 'invalid'})
BASELINE_SIZE = len(baseline.content)
print(f"\nInvalid POST size: {BASELINE_SIZE} bytes")

def test_payload(description, username, password="test"):
    """Test a payload and compare to baseline"""
    data = {'username': username, 'password': password}
    response = session.post(url, data=data, timeout=10)
    size = len(response.content)
    
    # True success indicators (NOT the static "Welcome to Springfield")
    text = response.text
    indicators = []
    
    # Check for actual success indicators that differ from baseline
    if size != BASELINE_SIZE:
        indicators.append(f"SIZE_DIFF:{size}")
    
    # Check for session cookie
    if response.cookies:
        indicators.append(f"COOKIE:{dict(response.cookies)}")
    
    # Check for redirect
    if response.history:
        indicators.append(f"REDIRECT:{response.url}")
    
    # Check if login form is gone (could indicate success)
    has_form = 'name="username"' in text
    if not has_form:
        indicators.append("NO_FORM")
    
    # Check for dashboard/profile content
    if re.search(r'(dashboard|profile|logout|user|admin panel)', text, re.I):
        if not re.search(r'(dashboard|profile|logout|user|admin panel)', baseline.text, re.I):
            indicators.append("DASHBOARD_CONTENT")
    
    # Check title change
    title_match = re.search(r'<title>(.*?)</title>', text)
    baseline_title = re.search(r'<title>(.*?)</title>', baseline.text)
    if title_match and baseline_title:
        if title_match.group(1) != baseline_title.group(1):
            indicators.append(f"TITLE:{title_match.group(1)}")
    
    is_different = len(indicators) > 0
    return {
        'desc': description,
        'username': username,
        'size': size,
        'indicators': indicators,
        'is_different': is_different,
        'has_form': has_form
    }

def print_result(r):
    if r['is_different']:
        print(f"\n[!] SUCCESS: {r['desc']}")
