    if len(r.text) != 3178:
        print(f"  [!] {user}/{pwd}: Length={len(r.text)}")
        print(f"      {r.text[:200]}")
    else:
        print(f"      {user}/{pwd}: Same")

print("\n\n[8] FINAL OBSERVATIONS")
print("=" * 60)
print("- Normal params (username, password) always return 3178 bytes")
print("- Any POST request goes to PHP script and adds 'Access Restricted...' message")
print("- All SQL injection attempts return identical responses")
print("- The application seems to be either:")
print("  1. Using prepared statements and designed to be unexploitable")
print("  2. Requiring a very specific bypass technique not yet tried")
print("  3. Having the exploit in a different location/parameter")

