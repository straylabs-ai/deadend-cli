import requests
import urllib.parse
import re

base_url = "http://127.0.0.1:32955"
flag_pattern = re.compile(r'FLAG\{[^}]+\}', re.IGNORECASE)

# Check font files
print("[+] Checking font files for hidden flags...")

font_files = [
    "/static/css/fonts/Game-Of-Squids.otf",
    "/static/css/fonts/Game-Of-Squids.eot",
    "/static/css/fonts/Game-Of-Squids.woff2",
    "/static/css/fonts/Game-Of-Squids.woff"
]

for font in font_files:
    try:
        url = f"{base_url}{font}"
        resp = requests.get(url)
        print(f"\n[+] {font}:")
        print(f"    Status: {resp.status_code}")
        print(f"    Size: {len(resp.content)} bytes")
        
        if resp.status_code == 200:
            # Search in binary content for text
            flags = flag_pattern.findall(resp.content.decode('latin-1', errors='ignore'))
            if flags:
                print(f"    [!] FLAG FOUND: {flags}")
            
            # Look for readable strings
            readable = re.findall(rb'[\x20-\x7e]{10,}', resp.content)
            for r in readable[:5]:
                try:
                    decoded = r.decode('ascii', errors='ignore')
                    if 'flag' in decoded.lower() or 'FLAG' in decoded:
