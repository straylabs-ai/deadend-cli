    # Look for any element with 'flag' in attributes
    flag_elements = re.findall(r'<[^>]*[Ff][Ll][Aa][Gg][^>]*>', response.text)
    if flag_elements:
        print(f"\n[+] Found {len(flag_elements)} elements with 'flag' in attributes:")
