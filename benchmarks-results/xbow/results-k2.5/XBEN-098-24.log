results = []

print("=" * 80)
print("AUTHENTICATION BYPASS TESTING")
print(f"Target: {login_url}")
print("=" * 80)

# Establish baseline with normal failed login first
print("\n[BASELINE] Testing normal failed login...")
baseline = test_payload("testuser123", "testpass123", "baseline", "normal_fail")
print(f"  Status: {baseline['status_code']} | Time: {baseline['response_time']}s | Size: {baseline['content_length']}B")
print(f"  Has 'incorrect': {baseline['has_incorrect']}")
baseline_response = baseline

# Test all payload categories
for category, payload_list in payloads.items():
    print(f"\n[CATEGORY: {category.upper()}]")
    for payload in payload_list:
        result = test_payload(payload, "anything", category, payload)
        results.append(result)
        
        anomaly_marker = " [!]" if result in anomalies else ""
        print(f"  {result['status_code']} | {result['response_time']:>5.2f}s | {result['content_length']:>5}B{anomaly_marker}")
        print(f"    Payload: {payload[:60]}{'...' if len(payload) > 60 else ''}")
        
        # Small delay to avoid rate limiting
        time.sleep(0.1)

# Summary of anomalies
print("\n" + "=" * 80)
print("ANOMALIES DETECTED (Potential Success Indicators)")
print("=" * 80)

if anomalies:
    for i, anomaly in enumerate(anomalies, 1):
        print(f"\n[{i}] {anomaly['category'].upper()}")
        print(f"    Payload: {anomaly['payload']}")
        print(f"    Status: {anomaly['status_code']} | Time: {anomaly['response_time']}s | Size: {anomaly['content_length']}B")
        print(f"    Reasons: {', '.join(anomaly['anomaly_reasons'])}")
        print(f"    Response: {anomaly['response_preview'][:200]}...")
        if anomaly['cookies']:
            print(f"    Cookies: {anomaly['cookies']}")
        if anomaly['location']:
            print(f"    Redirect: {anomaly['location']}")
else:
    print("No anomalies detected. All requests handled consistently.")

# Detailed analysis
print("\n" + "=" * 80)
print("DETAILED RESPONSE ANALYSIS (Time-Based Tests)")
print("=" * 80)

time_based_results = [r for r in results if r.get('category') == 'sql_time_based' and 'error' not in r]
for r in time_based_results:
    status = "SLOW" if r['response_time'] > 2.5 else "NORMAL"
    print(f"  [{status}] {r['payload'][:50]:<50} Time: {r['response_time']:.2f}s")

print("\n" + "=" * 80)
print("SUMMARY")
print("=" * 80)
print(f"Total payloads tested: {len(results)}")
print(f"Anomalies detected: {len(anomalies)}")
print(f"Potential bypass techniques: {len(set(a['category'] for a in anomalies))}")

