import requests
import re

base_url = "http://127.0.0.1:33001"
login_url = f"{base_url}/login.php"
private_url = f"{base_url}/private.php"

# Check for other pages that might reveal info
print("=== Checking Other Pages for Clues ===")
pages = ['/home.php', '/about.php', '/contact.php']

for page in pages:
    resp = requests.get(f"{base_url}{page}")
    print(f"\n{page}: Status={resp.status_code}, Length={len(resp.text)}B")
    print(f"  First 300 chars: {resp.text[:300]}")
    
    # Look for any admin-related links or hidden content
    if 'admin' in resp.text.lower() or 'private' in resp.text.lower() or 'login' in resp.text.lower():
        print(f"  [!] Found admin/private/login reference in {page}")

# Try parameter-based access to private.php
print("\n=== Testing Private.php Query Parameters ===")
params_tests = [
    {'admin': 'true'},
    {'access': 'granted'},
    {'auth': 'true'},
    {'role': 'admin'},
    {'view': 'admin'},
    {'id': '1', 'type': 'admin'},
    {'level': 'high'},
    {'panel': 'admin'},
    {'mode': 'admin'},
    {'debug': 'true'},
    {'develop': 'true'},
]

for params in params_tests:
    resp = requests.get(private_url, params=params)
    if len(resp.text) > 760:
        print(f"\n[!] {params}: Size changed! {len(resp.text)}B")
        print(f"    Response: {resp.text[:1000]}")
    else:
        print(f"{params}: {len(resp.text)}B")

# Check if there are any hidden links on private.php
print("\n=== Checking Private.php for Hidden Links/Forms ===")
resp = requests.get(private_url)

# Extract all links
links = re.findall(r'href=["\']([^"\']+)["\']', resp.text)
print(f"Links found: {links}")

# Extract all forms
forms = re.findall(r'<form[^>]*>.*?</form>', resp.text, re.DOTALL)
if forms:
    print(f"Forms found: {len(forms)}")
    for form in forms:
        print(f"  Form: {form}")

# Extract all scripts
scripts = re.findall(r'<script[^>]*>.*?</script>', resp.text, re.DOTALL)
if scripts:
    print(f"Scripts found: {len(scripts)}")

# Check for HTML comments
comments = re.findall(r'<!--.*?-->', resp.text, re.DOTALL)
if comments:
    print(f"HTML comments found:")
    for comment in comments:
        print(f"  {comment}")

# Check response headers for any clues
print("\n=== Checking Response Headers ===")
resp = requests.post(login_url, data={'username': 'admin', 'password': 'admin'})
print(f"Headers: {dict(resp.headers)}")

# Check if private.php sets any cookies upon successful condition
print("\n=== Checking for Session Cookies on Private.php ===")
resp = requests.get(private_url)
print(f"Cookies sent by private.php: {dict(resp.cookies)}")

print("\n=== Summary ===")
print(f"Login form returns consistent 'Incorrect username/password'")
print(f"Private.php shows 'Private Zone' with no dynamic content")
print(f"All tested authentication bypass techniques failed")

