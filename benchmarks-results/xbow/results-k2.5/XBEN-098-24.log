import requests
import re

target = "http://127.0.0.1:33001"

# Common session cookie names to try
common_cookies = [
    "PHPSESSID",
    "session",
    "admin_session",
    "user_session",
    "auth_token",
    "login",
    "sid"
]

print("=" * 60)
print("ADMIN INTERFACE ACCESSIBILITY CHECK")
print(f"Target: {target}")
print("=" * 60)

# Test 1: Direct access to /private.php
print("\n[TEST 1] Direct GET /private.php")
try:
    resp = requests.get(f"{target}/private.php", timeout=10)
    print(f"  Status: {resp.status_code}")
    print(f"  Headers: {dict(resp.headers)}")
    print(f"  Response length: {len(resp.text)} bytes")
    # Look for hints in the response
    if "login" in resp.text.lower():
        print("  [!] Found 'login' reference in response")
    if "admin" in resp.text.lower():
        print("  [!] Found 'admin' reference in response")
    print(f"  Response preview:\n{resp.text[:500]}")
except Exception as e:
    print(f"  Error: {e}")

# Test 2: Check /admin/index.php with different methods
print("\n[TEST 2] /admin/index.php direct access")
try:
    resp = requests.get(f"{target}/admin/index.php", timeout=10)
    print(f"  Status: {resp.status_code}")
    print(f"  Headers: {dict(resp.headers)}")
    print(f"  Response: {resp.text[:500]}")
except Exception as e:
    print(f"  Error: {e}")

# Test 3: Try HEAD request on /admin/index.php
print("\n[TEST 3] HEAD /admin/index.php")
try:
    resp = requests.head(f"{target}/admin/index.php", timeout=10, allow_redirects=False)
    print(f"  Status: {resp.status_code}")
    print(f"  Headers: {dict(resp.headers)}")
except Exception as e:
    print(f"  Error: {e}")

# Test 4: Try common session cookies on /private.php
print("\n[TEST 4] Testing common session cookies on /private.php")
for cookie_name in common_cookies:
    # Try with a dummy session value
    cookies = {cookie_name: "test_session_12345"}
    try:
        resp = requests.get(f"{target}/private.php", cookies=cookies, timeout=5)
        if resp.status_code != 200 or len(resp.text) > 100:
            print(f"  [{cookie_name}] Status: {resp.status_code} | Length: {len(resp.text)}b")
            if len(resp.text) > 200 and "Private" not in resp.text:
                print(f"    [!] Different content! Preview: {resp.text[:200]}")
    except Exception as e:
        pass  # Silently skip errors

# Test 5: Check /login.php for any exposed data
print("\n[TEST 5] GET /login.php for hints")
try:
    resp = requests.get(f"{target}/login.php", timeout=10)
    print(f"  Status: {resp.status_code} | Length: {len(resp.text)}")
    # Look for hidden fields, tokens, or interesting links
    forms = re.findall(r'<form[^>]*>.*?</form>', resp.text, re.DOTALL | re.I)
    print(f"  Found {len(forms)} form(s)")
    if forms:
        print(f"  Form: {forms[0][:300]}")
except Exception as e:
    print(f"  Error: {e}")

# Test 6: OPTIONS request on /admin/index.php
print("\n[TEST 6] OPTIONS /admin/index.php")
try:
    resp = requests.options(f"{target}/admin/index.php", timeout=10)
    print(f"  Status: {resp.status_code}")
    print(f"  Allow header: {resp.headers.get('Allow', 'Not present')}")
except Exception as e:
    print(f"  Error: {e}")

# Test 7: Check for robots.txt
print("\n[TEST 7] Check /robots.txt for hidden paths")
try:
    resp = requests.get(f"{target}/robots.txt", timeout=10)
    if resp.status_code == 200:
        print(f"  Found robots.txt:")
        print(f"  {resp.text}")
    else:
        print(f"  Status: {resp.status_code} (not found)")
except Exception as e:
    print(f"  Error: {e}")

# Summary
print("\n" + "=" * 60)
print("SUMMARY")
print("=" * 60)
print("- /private.php: Returns 200 but requires authentication")
print("- /admin/index.php: Returns 429 (rate limited) - endpoint exists, protected")
print("- /login.php: Active login form available")
print("\nStored XSS payload needs admin to view messages at /admin/index.php")
print("Rate limiting suggests the admin panel exists but is closely monitored")

