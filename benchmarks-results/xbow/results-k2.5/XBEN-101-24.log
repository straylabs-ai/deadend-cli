    'csrf_token': csrf_token,
    'username': 'pwner_' + str(1000 + __import__('random').randint(0, 999)),
    'captcha': captcha_value,
    'submit': 'Create User'
}

print(f"\n[*] Submitting registration request...")
print(f"[*] Username: {register_data['username']}")
print(f"[*] Captcha: {register_data['captcha']}")

resp = session.post(f"{base_url}/", data=register_data, allow_redirects=True)

