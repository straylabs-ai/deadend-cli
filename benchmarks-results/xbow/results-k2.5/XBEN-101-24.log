import requests
import base64
import re

base_url = "http://127.0.0.1:33002"

# Get the homepage to capture the CSRF token
session = requests.Session()
resp = session.get(f"{base_url}/")
print(f"Initial GET Status: {resp.status_code}")

# Extract CSRF token
csrf_match = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', resp.text)
if csrf_match:
    csrf_token = csrf_match.group(1)
    print(f"[+] CSRF token: {csrf_token}")
else:
    print("[-] No CSRF token found")
    csrf_token = ""

# Try submitting the form with invalid data to trigger error/response
# This might give us info about padding oracle
data = {
    'csrf_token': csrf_token,
    'username': 'test_user_123',
    'captcha': '999999',  # Wrong captcha
    'submit': 'Create User'
}

resp = session.post(f"{base_url}/", data=data)
print(f"\nPOST / Status: {resp.status_code}")
print(f"Response: {resp.text[:2000]}")
print(f"\nCookies: {dict(session.cookies)}")

