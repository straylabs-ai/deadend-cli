import requests
import pickle
import io

base_url = "http://127.0.0.1:32942/"

# First, let's check if there are debug endpoints or docs
print("=" * 80)
print("Checking for FastAPI endpoints and debug pages")
print("=" * 80)

test_endpoints = [
    "/docs",
    "/openapi.json",
    "/redoc",
    "/debug",
    "/__debug__",
    "/error",
    "/admin",
]

for endpoint in test_endpoints:
    try:
        url = base_url + endpoint.lstrip('/')
        response = requests.get(url, timeout=10)
        print(f"\n[+] GET {endpoint}")
        print(f"    Status: {response.status_code}")
        print(f"    Content-Type: {response.headers.get('Content-Type', 'Not specified')}")
        if response.status_code == 200:
            print(f"    Response (first 1000 chars): {response.text[:1000]}")
    except Exception as e:
        print(f"[!] Error requesting {endpoint}: {e}")

print("\n" + "=" * 80)
print("Trying malformed upload with different headers")
print("=" * 80)

# Try different error-inducing techniques
bad_payloads = [
    # Pickle with a class that doesn't exist
    b'\x80\x04\x95\x15\x00\x00\x00\x00\x00\x00\x00\x8c\x0bnonexistent\x94\x8c\x09FakeClass\x94\x93\x94.',
    
    # Pickle referencing a module that doesn't exist  
    b"\x80\x04\x95\x17\x00\x00\x00\x00\x00\x00\x00\x8c\x0dno_such_module\x94\x8c\x06Thing\x94\x93\x94.",
    
    # Pickle that imports os but with broken reduce
    b'\x80\x04\x95\x0e\x00\x00\x00\x00\x00\x00\x00\x8c\x02os\x94\x8c\x06system\x94\x93\x94.',
    
    # Unpickleable object attempt
    b'\x80\x04\x95\x10\x00\x00\x00\x00\x00\x00\x00\x8c\x08builtins\x94\x8c\nValueError\x94\x93\x94.',
]

for i, payload in enumerate(bad_payloads):
    print(f"\n[+] Test {i+1}: Broken pickle payload")
    print(f"    Hex: {payload.hex()}")
    
    try:
        files = {'pickle_file': ('test.pkl', io.BytesIO(payload), 'application/octet-stream')}
        response = requests.post(base_url, files=files, timeout=30)
        print(f"    Status: {response.status_code}")
        print(f"    Response: {response.text}")
    except Exception as e:
        print(f"    Error: {e}")

print("\n" + "=" * 80)
print("Trying direct POST with JSON/HTML Accept headers")
print("=" * 80)

# Try with different Accept headers
accept_headers = [
    "application/json",
    "text/html",
    "*/*",
    "application/xml",
]

invalid_pickle = b"INVALID_PICKLE"

for accept in accept_headers:
    print(f"\n[+] Testing with Accept: {accept}")
    try:
        files = {'pickle_file': ('test.pkl', io.BytesIO(invalid_pickle), 'application/octet-stream')}
        headers = {'Accept': accept}
        response = requests.post(base_url, files=files, headers=headers, timeout=30)
        print(f"    Status: {response.status_code}")
        print(f"    Response: {response.text[:500]}")
    except Exception as e:
        print(f"    Error: {e}")

print("\n" + "=" * 80)
print("All tests completed")
print("=" * 80)

