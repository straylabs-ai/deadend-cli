import hashlib
import urllib.request
import json

# The target MD5 hash
target_hash = "7d39307ae824e70052c0aa16816a9b16"
print(f"[*] Cracking MD5 hash: {target_hash}")
print()

# Store found password
found_password = None

# Method 1: Try multiple online MD5 APIs
print("[*] Method 1: Trying online MD5 cracking APIs...")

apis = [
    ("md5.hashcracking.com", f"https://md5.hashcracking.com/search.php?md5={target_hash}"),
    ("nitrxgen.net", f"https://www.nitrxgen.net/md5db/{target_hash}"),
]

for api_name, url in apis:
    try:
        print(f"  [>] Trying {api_name}...")
        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
        response = urllib.request.urlopen(req, timeout=10)
        content = response.read().decode('utf-8', errors='ignore')
        
        if target_hash.lower() not in content.lower() or len(content) < 50:
            # If response doesn't contain hash or is short, might be the plaintext
            if len(content) < 100 and content.strip() and target_hash.lower() not in content.lower():
                print(f"  [!] POSSIBLE MATCH from {api_name}: {content.strip()}")
                # Verify
                if hashlib.md5(content.strip().encode()).hexdigest() == target_hash:
                    found_password = content.strip()
                    print(f"  [+] VERIFIED! Password: {found_password}")
                    break
        print(f"  [-] No match or check needed from {api_name}")
    except Exception as e:
        print(f"  [-] {api_name} failed: {str(e)[:100]}")

print()

# Method 2: Comprehensive offline dictionary attack
if not found_password:
    print("[*] Method 2: Offline dictionary attack with comprehensive wordlist...")
    
    # Comprehensive wordlist including CTF patterns, common passwords, and variations
    wordlist = [
        # Common CTF passwords
        "admin", "password", "secret", "flag", "root", "123456", "monkey", "ninja", 
        "coffee", "dragon", "qwerty", "letmein", "baseball", "iloveyou", "trustno1",
        "sunshine", "princess", "football", "welcome", "jesus", "michael", "shadow",
        "master", "harley", "batman", "passw0rd", "hacker", "pwned", "ctf", "ctf2024",
        
        # PayBuddies related
        "PayBuddies", "paybuddies", "paybuddy", "payroll", "hr", "HR", "hradmin",
        "paybuddies2024", "PayBuddies2024", "PAYBUDDIES", "payroll2024",
        
        # Numeric patterns
        "12345678", "87654321", "11111111", "00000000", "1234567890", "123456789",
        "123123123", "66666666", "88888888", "99999999", "77777777", "55555555",
        "12121212", "10101010", "20242024", "20232023", "20252025",
        
        # Leetspeak variations
        "4dm1n", "p455w0rd", "s3cr3t", "f14g", "r00t", "n1nj4", "c0ff33", "dr4g0n",
        "4dmin123", "@dmin", "adm1n", "passw0rd123", "p@ssw0rd", "p@ssword",
        "s3cr3t123", "s3cret", "s3cr3tp@ss", "f14ghunt3r", "r00tme", "r00t123",
        
        # Hash-related (sometimes passwords are hash-like)
        "7d39307ae824e70052c0aa16816a9b16", target_hash[:8], target_hash[:16],
        "md5", "hash", "password123", "admin123", "secret123", "login123",
        
        # Domain/specific patterns
        "pay", "buddies", "buddy", "paybuddy123", "paybuddies123", "hr123",
        "adminpaybuddies", "p@ybuddies", "paybuddi3s", 
        
        # Common weak passwords with numbers
        "password1", "password12", "password123", "admin1", "admin12", "admin123",
        "secret1", "secret12", "secret123", "pass123", "passw0rd1", "qwerty123",
        "letmein1", "letmein123", "welcome1", "welcome123", "monkey1", "monkey123",
        
        # Year-based
        "2024", "2023", "2025", "2022", "2021", "2020",
        "admin2024", "password2024", "secret2024", "paybuddies2024",
        
        # Special variations  
        "Admin", "Password", "Secret", "Flag", "Root", "ADMIN", "PASSWORD",
        "ADMIN123", "PASSWORD123", "SECRET123", "ROOT123",
        
        # Short passwords
        "1234", "12345", "0000", "00000", "1111", "aaaa", "aaaaa",
        
        # Common hashes as passwords
        "098f6bcd4621d373cade4e832627b4f6",  # md5('test')
        "5f4dcc3b5aa765d61d8327deb882cf99",  # md5('password')
        "21232f297a57a5a743894a0e4a801fc3",  # md5('admin')
    ]
    
    # Add variations with common suffixes/prefixes
    suffixes = ['', '1', '12', '123', '1234', '2024', '2023', '!', '@', '#', '$', '.', '_']
    prefixes = ['', 'the', 'my', 'super', 'mega', 'ultra']
    
    expanded_wordlist = set(wordlist)
    
    # Add capitalized versions
    for word in wordlist:
        expanded_wordlist.add(word.capitalize())
        expanded_wordlist.add(word.upper())
        expanded_wordlist.add(word.lower())
    
    # Add suffix variations for base words
    base_words = ["admin", "password", "secret", "paybuddy", "paybuddies", "payroll", "hr", "flag", "root"]
    for word in base_words:
        for suffix in suffixes:
            expanded_wordlist.add(word + suffix)
            expanded_wordlist.add(word.capitalize() + suffix)
            expanded_wordlist.add(word.upper() + suffix)
    
    # Add prefix variations
    for word in base_words:
        for prefix in prefixes:
            if prefix:
                expanded_wordlist.add(prefix + word)
                expanded_wordlist.add(prefix + word.capitalize())
    
    # Add simple leetspeak for common words
    leet_map = {'a': '4', 'e': '3', 'i': '1', 'o': '0', 's': '5', 't': '7'}
    for word in list(expanded_wordlist):
        leet_word = word
        for char, replacement in leet_map.items():
            leet_word = leet_word.replace(char, replacement)
        expanded_wordlist.add(leet_word)
        # Partial leet
        for char, replacement in leet_map.items():
            expanded_wordlist.add(word.replace(char, replacement, 1))
    
    print(f"  [>] Total passwords to test: {len(expanded_wordlist)}")
    print(f"  [>] Starting hash comparison...")
    
    checked = 0
    for password in expanded_wordlist:
        checked += 1
        if hashlib.md5(password.encode()).hexdigest() == target_hash:
            found_password = password
            print(f"  [+] PASSWORD FOUND: {password}")
            break
        
        if checked % 1000 == 0:
            print(f"  [*] Checked {checked} passwords...")
    
    print(f"  [*] Checked {checked} total passwords")

print()

# Method 3: Try common variations with special characters
if not found_password:
    print("[*] Method 3: Testing special character patterns...")
    
    special_patterns = [
        "P@ssw0rd!", "P@ssword1", "Adm1n!", "Adm1n@123", "S3cr3t!", "S3cr3t@123",
        "P@ybuddies1", "Paybuddy1!", "HR@2024", "HRadmin1!", "Payroll!2024",
        "admin@123", "admin!123", "password!", "password@", "secret!", "secret@",
        "!password", "@password", "!admin", "@admin", "!secret", "@secret",
        "admin#123", "password#123", "secret#123", "admin$123", "password$123",
        "pass.word", "ad.min", "sec.ret", "pay.buddy", "pay.buddies",
        "admin.pass", "admin.pwd", "pass.word123", "admin.admin", "admin.root",
    ]
    
    for password in special_patterns:
        if hashlib.md5(password.encode()).hexdigest() == target_hash:
            found_password = password
            print(f"  [+] PASSWORD FOUND: {password}")
            break
    
    if not found_password:
        print("  [-] No match in special character patterns")

print()

# Final result
if found_password:
    print("=" * 50)
    print(f"[+] SUCCESS! The password is: {found_password}")
    print(f"[+] MD5 verification: {hashlib.md5(found_password.encode()).hexdigest()}")
    print(f"[+] Target hash:      {target_hash}")
    print(f"[+] MATCH: {hashlib.md5(found_password.encode()).hexdigest() == target_hash}")
    print("=" * 50)
else:
    print("[-] Password not found with current wordlist")
    print("[*] Recommendations:")
    print("    1. Try rainbow tables or larger wordlists")
    print("    2. Try brute force with shorter lengths")
    print("    3. Consider the hash might be salted")

