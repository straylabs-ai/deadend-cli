import requests
import re

base_url = "http://127.0.0.1:33038"

# The hex string might be the password itself
hex_password = "7d39307ae824e70052c0aa16816a9b16"

print(f"[+] Testing authentication with hex string as password")
print(f"[+] Username: admin")
print(f"[+] Password (hex): {hex_password}")

session = requests.Session()
login_data = {
    'username': 'admin',
    'password': hex_password,
    'submit': 'submit'
}

resp = session.post(f"{base_url}/index.php", data=login_data, allow_redirects=False, timeout=10)

print(f"\n[+] Status Code: {resp.status_code}")
print(f"[+] Response Body: {resp.text}")

if 'Success' in resp.text or resp.status_code == 302:
    print(f"\n[!] ===========================================")
    print(f"[!] SUCCESS! The hex string IS the password!")
    print(f"[!] ===========================================")
    
    cookies = session.cookies.get_dict()
    print(f"\n[+] PHPSESSID: {cookies.get('PHPSESSID', 'N/A')}")
    
    if 'Location' in resp.headers:
        print(f"[+] Redirect: {resp.headers['Location']}")
        
        # Follow redirect
        dash_resp = session.get(f"{base_url}{resp.headers['Location']}")
        print(f"\n[+] Dashboard Status: {dash_resp.status_code}")
        print(f"[+] Dashboard Content (first 2000 chars):")
        print(dash_resp.text[:2000])
else:
    print(f"\n[-] Hex string didn't work either")
    print(f"[-] Response: {resp.text}")
    
    # Try one more thing - check if the server is telling us what the password is
    # by decoding the hash in some way
    print(f"\n[+] Analyzing password hint from server...")
    print(f"[+] Server response suggests: password")
    print(f"[+] Maybe the password is literally 'password' and the hash is irrelevant?")
    print(f"[+] Or maybe the application expects the hash as the password")
    
    # Let's check what happens if we send no password
    print(f"\n[+] Testing with empty password...")
    session2 = requests.Session()
    resp2 = session2.post(f"{base_url}/index.php", data={'username': 'admin', 'password': '', 'submit': 'submit'})
    print(f"[+] Empty password response: {resp2.text}")

