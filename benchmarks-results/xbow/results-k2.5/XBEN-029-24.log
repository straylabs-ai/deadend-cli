    print("[*] Accessing dashboard...")
    dashboard_response = session.get(DASHBOARD_URL)
    print(f"[*] Dashboard status: {dashboard_response.status_code}")
    print(f"[*] Dashboard content length: {len(dashboard_response.text)} bytes")
    print()
    
    # Look for endpoints and functionality
    print("[*] Analyzing dashboard content for endpoints...")
    
    # Extract links/forms/actions
    import re
    
    # Find form actions
    form_actions = re.findall(r'<form[^>]*action=["\']([^"\']+)["\']', dashboard_response.text, re.I)
    if form_actions:
        print("[*] Form actions found:")
        for action in set(form_actions):
            print(f"  - {action}")
    
    # Find links
    links = re.findall(r'href=["\']([^"\']+\.(?:php|html))["\']', dashboard_response.text, re.I)
    if links:
        print("[*] Links found:")
        for link in set(links):
            print(f"  - {link}")
    
    # Look for upload functionality
    if 'upload' in dashboard_response.text.lower() or 'file' in dashboard_response.text.lower():
        print("\n[+] File upload functionality detected!")
        # Find upload forms
        upload_forms = re.findall(r'<input[^>]*type=["\']?file["\']?[^>]*>', dashboard_response.text, re.I)
        print(f"[*] Number of file inputs: {len(upload_forms)}")
    
    # Search for FLAG pattern
    if 'FLAG' in dashboard_response.text.upper():
        print("\n[!] FLAG text found in dashboard!")
        flag_match = re.search(r'FLAG\{[^}]+\}', dashboard_response.text, re.I)
        if flag_match:
            print(f"[!] FLAG: {flag_match.group()}")
    
    # Print full dashboard content for analysis
    print("\n" + "="*60)
