]

test_passwords = set(bases)  # Start with base words

# Generate all combinations
for base in bases:
    for year in ["", "2023", "2024", "2025", "22", "23", "24"]:
        for suffix in ["", "!", "@", "1", "01", "123", "12", "007"]:
            test_passwords.add(f"{base}{year}{suffix}")
            test_passwords.add(f"{year}{base}{suffix}")
            test_passwords.add(f"{base}{suffix}{year}")

# Add leet speak variations
leet_map = {'a': '4', 'e': '3', 'i': '1', 'o': '0', 's': '5', 't': '7'}
for word in list(test_passwords):
    leet = word
    for char, replacement in leet_map.items():
        leet = leet.replace(char, replacement)
    test_passwords.add(leet)

# Add variations with symbols at start/middle/end
symbols = ["!", "@", "#", "$", "_", "-"]
for word in list(test_passwords):
    for sym in symbols:
        test_passwords.add(f"{sym}{word}")
        test_passwords.add(f"{word}{sym}")

# Add common numeric patterns
for word in list(test_passwords):
    for i in range(100):
        test_passwords.add(f"{word}{i:02d}")

