if file_inputs:
    print(f"[+] File upload inputs found: {len(file_inputs)}")
    for inp in file_inputs:
        print(f"  - {inp}")
else:
    print("[!] No direct file upload inputs found")

# Look for links to other pages
print("\n[*] Links found on dashboard:")
links = re.findall(r'href=["\']([^"\']+\.(?:php))["\']', dashboard_response.text, re.I)
unique_links = set(links)
for link in unique_links:
    if not link.startswith('http'):
        print(f"  - {link}")

# Look for upload-related elements
print("\n[*] Looking for upload-related content:")
if "upload" in dashboard_response.text.lower():
    print("[+] 'upload' keyword found in page")
    # Find the context
    upload_contexts = re.findall(r'[^<]*upload[^<]*', dashboard_response.text, re.I)
    for ctx in upload_contexts[:3]:  # Show first 3 matches
        print(f"  Context: {ctx.strip()}")

if "file" in dashboard_response.text.lower():
