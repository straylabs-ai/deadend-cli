import hashlib
import urllib.request
import urllib.parse
import json

# The target MD5 hash
target_hash = "7d39307ae824e70052c0aa16816a9b16"
print(f"[*] Cracking MD5 hash: {target_hash}")
print()

found_password = None

# Try hashcrack.com API via POST request
print("[*] Trying hashcrack.com API...")
try:
    url = "http://www.md5crack.com/api/api.cracker.php"
    data = urllib.parse.urlencode({'term': target_hash, 'option': 1, 'crackbtn': 'Crack+that+hash+baby%21'})
    data = data.encode('ascii')
    req = urllib.request.Request(url, data=data, headers={'User-Agent': 'Mozilla/5.0', 'Content-Type': 'application/x-www-form-urlencoded'})
    response = urllib.request.urlopen(req, timeout=15)
    content = response.read().decode('utf-8', errors='ignore')
    print(f"  [>] Response: {content[:500]}")
    
    # Check if result is in response
    if target_hash.lower() in content.lower():
        # Try to extract password from result
        import re
        matches = re.findall(r'>([^<]+)</', content)
        for match in matches:
            match_clean = match.strip()
            if match_clean and match_clean != target_hash:
                print(f"  [!] Possible password: {match_clean}")
                if hashlib.md5(match_clean.encode()).hexdigest() == target_hash:
                    found_password = match_clean
                    print(f"  [+] VERIFIED! Password: {found_password}")
except Exception as e:
    print(f"  [-] hashcrack.com failed: {str(e)[:100]}")

print()

# Try md5.gromweb.com (JSON API version)
if not found_password:
    print("[*] Trying md5.gromweb.com JSON API...")
    try:
        url = f"http://md5.gromweb.com/query/{target_hash}"
        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
        response = urllib.request.urlopen(req, timeout=15)
        content = response.read().decode('utf-8', errors='ignore').strip()
        print(f"  [>] Response: {content}")
        
        if content and target_hash.lower() not in content.lower():
            print(f"  [!] Possible password: {content}")
            if hashlib.md5(content.encode()).hexdigest() == target_hash:
                found_password = content
                print(f"  [+] VERIFIED! Password: {found_password}")
    except Exception as e:
        print(f"  [-] gromweb.com failed: {str(e)[:100]}")

print()

# Try c0llision.net API
if not found_password:
    print("[*] Trying c0llision.net API...")
    try:
        url = f"http://c0llision.net/webcrack/{target_hash}"
        req = urllib.request.Request(url, headers={'User-Agent': 'Mozilla/5.0'})
        response = urllib.request.urlopen(req, timeout=15)
        content = response.read().decode('utf-8', errors='ignore')
        print(f"  [>] Response: {content[:500]}")
        content_clean = content.strip()
        if content_clean and target_hash.lower() not in content_clean.lower():
            print(f"  [!] Possible password: {content_clean}")
            if hashlib.md5(content_clean.encode()).hexdigest() == target_hash:
                found_password = content_clean
                print(f"  [+] VERIFIED! Password: {found_password}")
    except Exception as e:
        print(f"  [-] c0llision.net failed: {str(e)[:100]}")

print()

# Try additional patterns based on common CTF password patterns
if not found_password:
    print("[*] Testing more CTF-specific patterns...")
    
    ctf_specific = [
        # Hash as password
        "7d39307ae824e70052c0aa16816a9b16",
        # Partials of the hash
        "7d39307a", "e824e700", "52c0aa16", "816a9b16",
        "7d39", "e824", "52c0", "816a",
        # Numeric patterns
        str(int(target_hash, 16))[:10] if target_hash else "",
        # Character sequences from hash bytes
        "}90", "}90z", "90z$", "z$R", "$Rj", "Rjj\x16",
    ]
    
    # Try each byte as ASCII
    hash_bytes = bytes.fromhex(target_hash)
    readable_chars = ''.join(chr(b) if 32 <= b < 127 else '' for b in hash_bytes)
    print(f"  [>] Hash as readable ASCII: '{readable_chars}'")
    ctf_specific.append(readable_chars)
    
    # Try variations
    for pattern in ctf_specific:
        if pattern and hashlib.md5(pattern.encode()).hexdigest() == target_hash:
            found_password = pattern
            print(f"  [+] PASSWORD FOUND: {pattern}")
            break
    
    if not found_password:
        print("  [-] No match in CTF-specific patterns")

print()

# Try extending wordlist with compound passwords
if not found_password:
    print("[*] Testing compound password patterns...")
    
    compounds = []
    bases = ["admin", "paybuddies", "paybuddy", "payroll", "hr", "password", "secret", "flag", "root"]
    connectors = ["", "_", "-", ".", "@", "#", "!"]
    suffixes = ["", "123", "2024", "1", "!"]
    
    for base in bases:
        for connector in connectors:
            for suffix in suffixes:
                compounds.append(f"{base}{connector}{suffix}")
                compounds.append(f"{base.capitalize()}{connector}{suffix}")
                compounds.append(f"{base.upper()}{connector}{suffix}")
    
    # Add mixed compounds
    for b1 in bases[:5]:
        for b2 in bases[5:]:
            for conn in connectors[:4]:
                compounds.append(f"{b1}{conn}{b2}")
                compounds.append(f"{b1.capitalize()}{conn}{b2}")
    
    compounds = list(set(compounds))
    print(f"  [>] Total compound patterns: {len(compounds)}")
    
    checked = 0
    for pattern in compounds:
        checked += 1
        if hashlib.md5(pattern.encode()).hexdigest() == target_hash:
            found_password = pattern
            print(f"  [+] PASSWORD FOUND: {pattern}")
            break
        if checked % 10000 == 0:
            print(f"  [*] Checked {checked} compounds...")
    
    print(f"  [*] Checked {checked} compound patterns")

print()

# Final result
if found_password:
    print("=" * 50)
    print(f"[+] SUCCESS! The password is: {found_password}")
    print(f"[+] MD5 verification: {hashlib.md5(found_password.encode()).hexdigest()}")
    print(f"[+] Target hash:      {target_hash}")
    print(f"[+] MATCH: {hashlib.md5(found_password.encode()).hexdigest() == target_hash}")
    print("=" * 50)
