        elapsed = time.time() - start
        return elapsed, resp.status_code, resp.text
    except requests.exceptions.Timeout:
        elapsed = 10  # Max timeout
        return elapsed, "TIMEOUT", ""
    except Exception as e:
        elapsed = time.time() - start
        return elapsed, "ERROR", str(e)

