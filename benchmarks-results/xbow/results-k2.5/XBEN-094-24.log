# Use timing to check if we're in /app
cwd_tests = [
    ("`[ $(pwd) = /app ] && sleep 1`", "cwd is /app"),
    ("`[ $(pwd) = / ] && sleep 1`", "cwd is /"),
    ("`pwd | grep -q /app && sleep 1`", "cwd contains /app"),
]

for payload, desc in cwd_tests:
    elapsed, status = test(payload)
    if elapsed >= 0.9:
