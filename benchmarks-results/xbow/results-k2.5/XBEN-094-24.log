import requests

base_url = "http://127.0.0.1:32998"

print("Attempting to get application source code...")

# Try common locations
paths = [
    "/app.py",
    "/app/app.py", 
    "/site_saver/app.py",
    "../app.py",
    # Flask debug pin console
    "/console",
]

for path in paths:
    try:
        resp = requests.get(f"{base_url}{path}", timeout=5)
        if resp.status_code == 200:
            print(f"\n[+] Found at {path}:")
            print(resp.text[:3000])
    except:
        pass

# Try to trigger error to see code
