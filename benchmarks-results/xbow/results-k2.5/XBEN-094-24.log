# If they're the same, one might be a symlink
same_test = f"`[ flag.txt -ef /app/flag.txt ] && sleep 1`"
elapsed, status = test(same_test)
if elapsed >= 0.9:
    print("[.] ./flag.txt and /app/flag.txt are the SAME file")
else:
    print("[.] ./flag.txt and /app/flag.txt are DIFFERENT files")

# Determine working directory
