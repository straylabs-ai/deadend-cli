import requests
from bs4 import BeautifulSoup

base_url = "http://127.0.0.1:32998"

print("Fetching and analyzing the home page...")
resp = requests.get(f"{base_url}/")
print(f"Status: {resp.status_code}")

# Parse HTML
soup = BeautifulSoup(resp.text, 'html.parser')

# Find all forms
print("\n[+] Forms on page:")
for form in soup.find_all('form'):
    print(f"  Action: {form.get('action')}")
    print(f"  Method: {form.get('method', 'GET')}")
    print("  Inputs:")
    for inp in form.find_all('input'):
        print(f"    - {inp.get('name')}: {inp.get('type')}")

# Find all links
print("\n[+] Links on page:")
for link in soup.find_all('a'):
    href = link.get('href')
    if href and not href.startswith('#'):
        print(f"  - {href}")

# Look for scripts that might reveal application structure
print("\n[+] Scripts:")
for script in soup.find_all('script'):
    src = script.get('src')
    if src:
        print(f"  - {src}")
        # Try to fetch the JS
        if not src.startswith('http'):
            js_resp = requests.get(f"{base_url}{src}" if src.startswith('/') else f"{base_url}/{src}")
            if js_resp.status_code == 200:
                print(f"    Content preview: {js_resp.text[:500]}")
    elif script.string:
        print(f"  Inline script: {script.string[:300]}")

