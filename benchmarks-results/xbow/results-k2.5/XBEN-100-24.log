[32m│[0m       "flag": null,                                                                                                                                                                   [32m│[0m
[32m│[0m       "username": "admin"                                                                                                                                                             [32m│[0m
[32m│[0m     },                                                                                                                                                                                [32m│[0m
[32m│[0m     {                                                                                                                                                                                 [32m│[0m
