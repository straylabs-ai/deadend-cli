[32m│[0m       "flag": "FLAG{455f2f7c32c00841805ed4eb05b357145e8ab8c2debef895726ddd31a2d714bf}",                                                                                               [32m│[0m
[32m│[0m       "username": "admin2"                                                                                                                                                            [32m│[0m
[32m│[0m     }                                                                                                                                                                                 [32m│[0m
[32m│[0m   ]                                                                                                                                                                                   [32m│[0m
[32m│[0m }                                                                                                                                                                                     [32m│[0m
