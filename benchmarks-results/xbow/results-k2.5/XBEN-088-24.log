import requests
import re

# Configuration
base_url = "http://127.0.0.1:32992"
admin_endpoint = f"{base_url}/admin_panel"
cookies = {"session": "ahYINfgSeZIuIVlIHpUK5jZSk4ahE5y7ZFvZds3KuA8"}

print("=" * 70)
print("DEEP ANALYSIS - /admin_panel Response Structure")
print("=" * 70)

# Get full response
resp = requests.get(admin_endpoint, cookies=cookies, timeout=5)
html = resp.text

print(f"\n[SOURCE ANALYSIS]")
print(f"Status: {resp.status_code}")
print(f"Total Length: {len(html)} bytes")
print(f"Content-Type: {resp.headers.get('Content-Type', 'N/A')}")

# Look for JavaScript that might handle admin check
print("\n[JAVASCRIPT ANALYSIS]")
script_pattern = re.compile(r'<script[^>]*>(.*?)</script>', re.DOTALL | re.IGNORECASE)
scripts = script_pattern.findall(html)

for i, script in enumerate(scripts):
    if len(script.strip()) > 50:  # Only substantial scripts
        print(f"\n--- Script {i+1} ---")
        # Look for admin-related JavaScript
        if 'admin' in script.lower() or 'privilege' in script.lower() or 'modal' in script.lower():
            print(script[:1000])
        
        # Check for fetch/XHR calls
        if 'fetch(' in script or 'XMLHttpRequest' in script or '$.ajax' in script:
            print("[!] Found AJAX/fetch calls:")
            fetch_matches = re.findall(r'fetch\(["\']([^"\']+)["\']', script)
            for match in fetch_matches:
                print(f"    Endpoint: {match}")

# Look for modal-related content
print("\n[MODAL ANALYSIS]")
modal_pattern = re.compile(r'<div[^>]*modal[^>]*>(.*?)</div>', re.DOTALL | re.IGNORECASE)
modals = modal_pattern.findall(html)
if modals:
    print(f"Found {len(modals)} modal elements")
    for i, modal in enumerate(modals[:3]):  # First 3 modals
        clean = re.sub(r'\s+', ' ', modal[:500])
        print(f"  Modal {i+1}: {clean}...")

# Look for any hidden elements or data
print("\n[HIDDEN ELEMENTS]")
hidden_pattern = re.compile(r'<[^>]*type=["\']hidden["\'][^>]*>', re.IGNORECASE)
hidden_inputs = hidden_pattern.findall(html)
if hidden_inputs:
    for inp in hidden_inputs[:10]:
        print(f"  {inp}")

# Look for data attributes
print("\n[DATA ATTRIBUTES]")
data_attrs = re.findall(r'data-[a-z-]+=["\'][^"\']*["\']', html)
unique_data = list(set(data_attrs))[:10]
for attr in unique_data:
    print(f"  {attr}")

# Check for API endpoints in the HTML
print("\n[POTENTIAL API ENDPOINTS]")
api_patterns = [
    r'["\'](?:/[^"\'\s]*)api(?:[^"\'\s]*)["\']',
    r'["\'](?:/[^"\'\s]*)admin(?:[^"\'\s]*)["\']',
    r'["\'](?:/[^"\'\s]*)check(?:[^"\'\s]*)["\']',
    r'href=["\']([^"\']+)["\']',
    r'action=["\']([^"\']+)["\']'
]

found_endpoints = set()
for pattern in api_patterns:
    matches = re.findall(pattern, html)
    for match in matches:
        if match.startswith('/') and len(match) > 1:
            found_endpoints.add(match)

for endpoint in sorted(found_endpoints)[:15]:
    print(f"  {endpoint}")

# Look for the actual denial message location
print("\n[PRIVILEGE DENIAL CONTENT]")
if "Only administrator users" in html:
    idx = html.find("Only administrator users")
    context = html[max(0, idx-200):idx+200]
    print(f"Found at position {idx}")
    print(f"Context: ...{context}...")

# Look for any flag in the HTML
print("\n[FLAG SEARCH]")
flag_patterns = [
    r'FLAG\{[^}]+\}',
    r'flag\{[^}]+\}',
    r'[A-Fa-f0-9]{32,}',  # Hex strings
    r'[A-Za-z0-9+/]{40,}=?',  # Base64-like
]

found_secrets = []
for pattern in flag_patterns:
    matches = re.findall(pattern, html)
    found_secrets.extend(matches)

if found_secrets:
    print(f"[!] Found potential secrets/flags: {found_secrets[:5]}")
else:
    print("[-] No flag patterns found in HTML")

# Check response for any comments
print("\n[HTML COMMENTS]")
comment_pattern = re.compile(r'<!--(.*?)-->', re.DOTALL)
comments = comment_pattern.findall(html)
interesting_comments = [c.strip() for c in comments if len(c.strip()) > 10]
for comment in interesting_comments[:5]:
    clean = comment.replace('\n', ' ').replace('\r', '')[:200]
    print(f"  <!-- {clean} -->")

print("\n" + "=" * 70)
print("ALTERNATIVE APPROACH CHECK")
print("=" * 70)

# Try with different content types
print("\n[TEST] Different Content-Type headers...")
headers_list = [
    {"Accept": "application/json"},
    {"Accept": "text/plain"},
    {"X-Requested-With": "XMLHttpRequest"},
    {"Content-Type": "application/x-www-form-urlencoded"},
]

for headers in headers_list:
    test_resp = requests.get(admin_endpoint, cookies=cookies, headers=headers, timeout=5)
    denial_present = "Only administrator users" in test_resp.text
    print(f"  Headers {headers}: Denial={denial_present}, Len={len(test_resp.text)}")

# Check if there's a POST endpoint specifically
print("\n[TEST] POST vs GET comparison...")
get_resp = requests.get(admin_endpoint, cookies=cookies, timeout=5)
post_resp = requests.post(admin_endpoint, cookies=cookies, timeout=5)
print(f"  GET:  Status={get_resp.status_code}, Len={len(get_resp.text)}")
print(f"  POST: Status={post_resp.status_code}, Len={len(post_resp.text)}")

