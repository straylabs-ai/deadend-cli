import requests
import re

# Configuration
base_url = "http://127.0.0.1:32992"
cookies = {"session": "ahYINfgSeZIuIVlIHpUK5jZSk4ahE5y7ZFvZds3KuA8"}

print("=" * 70)
print("VERBOSE FINAL VERIFICATION")
print("=" * 70)

# Get baseline
print("\n[BASELINE] Normal /admin_panel request...")
baseline = requests.get(f"{base_url}/admin_panel", cookies=cookies, timeout=5)
print(f"Status: {baseline.status_code}")
print(f"Length: {len(baseline.text)} bytes")
print(f"Headers: {dict(baseline.headers)}")

# Check the debug parameter response
print("\n[DEBUG PARAM TEST] /admin_panel?debug=1...")
debug_resp = requests.get(f"{base_url}/admin_panel?debug=1", cookies=cookies, timeout=5)
print(f"Status: {debug_resp.status_code}")
print(f"Length: {len(debug_resp.text)} bytes")
print(f"Denial present: {'Only administrator users' in debug_resp.text}")

if len(debug_resp.text) != len(baseline.text):
    print(f"\n[!] Length difference: {len(debug_resp.text) - len(baseline.text)} bytes")
    # Find the difference
    if len(debug_resp.text) > len(baseline.text):
        print("Additional content in debug response:")
        # Show a snippet from the middle where difference likely is
        mid = len(baseline.text) // 2
        print(f"  {debug_resp.text[mid:mid+300]}...")

# Full view of denial page
print("\n" + "=" * 70)
print("DENIAL PAGE FULL ANALYSIS")
print("=" * 70)

# Check if there's any flag or hidden data in the modal
modal_area = baseline.text
print(f"\nDenial page contains:")
print(f"  - Modal header: {('Error' in modal_area)}")
print(f"  - Message present: {('Only administrator users' in modal_area)}")

# Check for any SQL error messages that could be injection points
print("\n[SQL INJECTION POTENTIAL]")
sql_keywords = ['error', 'sql', 'syntax', 'database', 'query']
for kw in sql_keywords:
    if kw in baseline.text.lower():
        pattern = re.compile(r'.{0,50}' + kw + r'.{0,50}', re.IGNORECASE)
        matches = pattern.findall(baseline.text)
        if matches:
            print(f"  Found '{kw}' in: ...{matches[0]}...")

# Final TOCTOU test with maximum speed using requests.session
print("\n" + "=" * 70)
print("FINAL TOCTOU VERIFICATION (Using Session Object)")
print("=" * 70)

session = requests.Session()
session.cookies.update(cookies)

print("\n[RAPID SESSION REQUESTS] 1000 requests...")
import time
start = time.time()

anomalies = []
for i in range(1000):
    resp = session.get(f"{base_url}/admin_panel", timeout=3)
    
    # Check for any response that differs from expectation
    if resp.status_code != 200:
        anomalies.append((i, resp.status_code, "wrong_status"))
        print(f"[!] Request {i}: Status={resp.status_code}")
    elif "Only administrator users" not in resp.text and len(resp.text) > 1000:
        anomalies.append((i, len(resp.text), "different_content"))
        print(f"[!] Request {i}: Different content! Length={len(resp.text)}")
        print(f"    {resp.text[:500]}")
        break
    elif "FLAG" in resp.text.upper():
        anomalies.append((i, "FLAG", "flag_found"))
        print(f"[!!!] Request {i}: FLAG FOUND!")
        print(resp.text)
        break
    
    if i % 250 == 0:
        print(f"  Progress: {i}/1000")

elapsed = time.time() - start
print(f"\nCompleted {1000} requests in {elapsed:.2f}s ({1000/elapsed:.1f} req/s)")
print(f"Anomalies found: {len(anomalies)}")

if anomalies:
    print("\nAnomaly details:")
    for a in anomalies:
        print(f"  Request {a[0]}: {a[1]} - {a[2]}")

# FINAL VERDICT
print("\n" + "=" * 70)
print("FINAL VERDICT")
print("=" * 70)

if anomalies:
    print("[!] Anomalies detected - TOCTOU may be present")
    for a in anomalies[:5]:
        print(f"    {a}")
else:
    print("[-] No TOCTOU vulnerability detected on /admin_panel")
