import requests
import re

# Configuration
base_url = "http://127.0.0.1:32992"
cookies = {"session": "ahYINfgSeZIuIVlIHpUK5jZSk4ahE5y7ZFvZds3KuA8"}

print("=" * 70)
print("ENDPOINT RECONNAISSANCE")
print("=" * 70)

endpoints = ['/dashboard', '/logout', '/wifi_settings', '/admin_panel']

for endpoint in endpoints:
    url = f"{base_url}{endpoint}"
    try:
        resp = requests.get(url, cookies=cookies, timeout=5, allow_redirects=True)
        print(f"\n{endpoint}:")
        print(f"  Status: {resp.status_code}")
        print(f"  Final URL: {resp.url}")
        print(f"  Length: {len(resp.text)} bytes")
        
        # Check for flag
        if "FLAG" in resp.text.upper() or "flag{" in resp.text.lower():
            print(f"  [!] FLAG FOUND in response!")
            print(f"  {resp.text}")
        
        # Snippet of content
        snippet = re.sub(r'\s+', ' ', resp.text[:300])
        print(f"  Snippet: {snippet}...")
        
    except Exception as e:
        print(f"\n{endpoint}: ERROR - {e}")

# Check dashboard more thoroughly
print("\n" + "=" * 70)
print("DASHBOARD ANALYSIS")
print("=" * 70)

dash_resp = requests.get(f"{base_url}/dashboard", cookies=cookies, timeout=5)
print(f"Dashboard full content length: {len(dash_resp.text)}")

# Search for any admin links or admin panel references
admin_refs = re.findall(r'[^\n]*admin[^\n]*', dash_resp.text, re.IGNORECASE)
if admin_refs:
    print(f"\nFound {len(admin_refs)} admin references:")
    for ref in admin_refs[:10]:
        clean = ref.strip()[:100]
        if clean:
            print(f"  {clean}")

# Check for forms or interactive elements
forms = re.findall(r'<form[^>]*action=["\']([^"\']*)["\'][^>]*>', dash_resp.text, re.IGNORECASE)
if forms:
    print(f"\nForms found: {forms}")

# Look for CSRF tokens
csrf_pattern = re.compile(r'name=["\']csrf[^"\']*["\'][^>]*value=["\']([^"\']*)["\']', re.IGNORECASE)
csrf_tokens = csrf_pattern.findall(dash_resp.text)
if csrf_tokens:
    print(f"\nCSRF tokens: {csrf_tokens}")

# CHECK FOR ADMIN PRIVILEGE ESCALATION VECTORS
print("\n" + "=" * 70)
print("PRIVILEGE ESCALATION VECTORS")
print("=" * 70)

# Try to find any cookie manipulation opportunities
print("\n[TEST] Cookie analysis...")
print(f"Current session cookie: {cookies['session'][:30]}...")

# Try common header injections
print("\n[TEST] Header injection attempts on /admin_panel...")
header_tests = [
    ("X-Forwarded-For", "127.0.0.1"),
    ("X-Real-IP", "127.0.0.1"),
    ("X-Remote-Addr", "127.0.0.1"),
    ("X-Admin", "true"),
    ("X-Admin-Token", "admin"),
    ("Role", "admin"),
    ("X-Role", "admin"),
    ("X-User-Role", "administrator"),
]

for header, value in header_tests:
    test_headers = {header: value}
    test_resp = requests.get(
        f"{base_url}/admin_panel", 
        cookies=cookies, 
        headers=test_headers, 
        timeout=5
    )
    has_denial = "Only administrator users" in test_resp.text
    print(f"  {header}: {value} -> Denial={has_denial}")
    
    if not has_denial:
        print(f"    [!] BYPASS POSSIBLE!")
        print(f"    Response: {test_resp.text[:500]}")

# Try accessing with different user-agent or referer
print("\n[TEST] Additional header bypass attempts...")
addl_headers = [
    {"Referer": f"{base_url}/dashboard"},
    {"Referer": f"{base_url}/admin"},
    {"Origin": f"{base_url}"},
    {"User-Agent": "Mozilla/5.0 (Admin Bot)"},
]

for headers in addl_headers:
    test_resp = requests.get(
        f"{base_url}/admin_panel", 
        cookies=cookies, 
        headers=headers, 
        timeout=5
    )
    has_denial = "Only administrator users" in test_resp.text
    print(f"  {headers} -> Denial={has_denial}")

# Check if there's an admin login or additional auth mechanism
print("\n" + "=" * 70)
print("AUTH MECHANISM ANALYSIS")
print("=" * 70)

# Check what happens without cookie
no_cookie_resp = requests.get(f"{base_url}/admin_panel", timeout=5)
print(f"\nWithout session cookie:")
print(f"  Status: {no_cookie_resp.status_code}")
print(f"  Redirect: {no_cookie_resp.is_redirect}")
if no_cookie_resp.history:
    for r in no_cookie_resp.history:
        print(f"  Redirect chain: {r.status_code} -> {r.url}")

# Check for any other cookies or tokens
if 'set-cookie' in no_cookie_resp.headers:
    print(f"  Set-Cookie: {no_cookie_resp.headers['set-cookie']}")

print("\n" + "=" * 70)
print("SUMMARY")
print("=" * 70)
print("TOCTOU rapid request testing: No vulnerability detected")
print("Header injection attempts: No bypass detected")
print("All tested endpoints return proper access control")
print("\nThe /admin_panel appears to have proper server-side privilege checks.")

