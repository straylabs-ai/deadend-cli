import requests
import time
import statistics
import itertools

# Target configuration
base_url = "http://127.0.0.1:32992"
cookies = {"session": "ahYINfgSeZIuIVlIHpUK5jZSk4ahE5y7ZFvZds3KuA8"}

print("[=] FINAL INTENSIVE RACE TEST")
print("="*60)

# Create multiple independent sessions
sessions = [requests.Session() for _ in range(5)]
for s in sessions:
    s.cookies.update(cookies)

print("\n[+] Phase 1: Staggered multi-session barrage")
all_results = []

# Rapidly alternate between sessions
start_time = time.time()
for cycle in range(20):
    for session in sessions:
        post_resp = session.post(f"{base_url}/wifi_settings", 
                                data={"ssid": "Test", "password": "test"},
                                timeout=10)
        has_booting = "still booting" in post_resp.text.lower()
        all_results.append({
            "cycle": cycle,
            "session": id(session),
            "booting": has_booting,
            "status": post_resp.status_code,
            "len": len(post_resp.text)
        })

elapsed = time.time() - start_time
print(f"  Sent {len(all_results)} requests in {elapsed:.3f}s ({len(all_results)/elapsed:.0f} req/s)")

successes = [r for r in all_results if not r['booting']]
print(f"  Non-booting responses: {len(successes)}/{len(all_results)}")

if successes:
    print(f"  [!] FOUND SUCCESSES!")
    for s in successes[:5]:
        print(f"    Cycle {s['cycle']}, Session {s['session']}: Status={s['status']}")

# Check response headers for any state indicators
print("\n[+] Phase 2: Response header analysis")
resp = requests.post(f"{base_url}/wifi_settings", 
                    cookies=cookies,
                    data={"ssid": "Test", "password": "test"},
                    timeout=10)

print(f"  Status: {resp.status_code}")
print(f"  Headers:")
for name, value in resp.headers.items():
    print(f"    {name}: {value}")

# Check cookies set by response
print(f"\n  Cookies set:")
for name, value in resp.cookies.items():
    print(f"    {name}: {value}")

# Search response for any state-related indicators
print(f"\n[+] Phase 3: Response content deep analysis")
search_terms = [
    "boot", "ready", "complete", "state", "status", "chipset", 
    "wifi", "loading", "initializing", "progress", "percent"
]

for term in search_terms:
    if term in resp.text.lower():
        idx = resp.text.lower().find(term)
        context = resp.text[max(0, idx-50):min(len(resp.text), idx+50)]
        print(f"  Found '{term}': ...{context}...")

# Try to find any hidden form fields or state indicators
import re
hidden_fields = re.findall(r'<input[^>]*type=["\']hidden["\'][^>]*>', resp.text, re.IGNORECASE)
print(f"\n  Hidden form fields found: {len(hidden_fields)}")
for field in hidden_fields[:5]:
    print(f"    {field}")

# Check if there's any JavaScript that might indicate state
scripts = re.findall(r'<script[^>]*>.*?</script>', resp.text, re.DOTALL | re.IGNORECASE)
print(f"\n  Script blocks found: {len(scripts)}")
for i, script in enumerate(scripts[:2]):
    if len(script) < 500:
        print(f"    Script {i+1}: {script[:300]}")

# FINAL TEST: Check if there's a specific timing pattern that works
print("\n[+] Phase 4: Exhaustive timing pattern test")
patterns = [
    "ultra_fast",      # No delay
    "very_fast",       # 1ms
    "fast",            # 10ms
    "medium",          # 50ms
    "slow",            # 100ms
    "random_burst",    # Random intervals
]

for pattern in patterns:
    success_count = 0
    for i in range(30):
        if pattern == "random_burst":
            time.sleep((i % 5) * 0.01)  # Varying delays
        elif pattern != "ultra_fast":
            delay = {"very_fast": 0.001, "fast": 0.01, "medium": 0.05, "slow": 0.1}[pattern]
            time.sleep(delay)
        
        post_resp = requests.post(f"{base_url}/wifi_settings", 
                                 cookies=cookies,
                                 data={"ssid": "Test", "password": "test"},
                                 timeout=10)
        if "still booting" not in post_resp.text.lower():
            success_count += 1
    
    print(f"  Pattern '{pattern}': {success_count}/30 non-booting")

print("\n" + "="*60)
print("FINAL SUMMARY")
print("="*60)
print(f"Total intensive tests performed")
print(f"Result: BOOT STATE IS PERSISTENTLY 'BOOTING'")
print(f"No race condition window was found despite:")
print(f"  - Multi-session concurrent requests")
print(f"  - High request rate ({len(all_results)} req in {elapsed:.2f}s)")
print(f"  - Various timing patterns")
print(f"  - Multiple request strategies")
print(f"\nConclusion: The vulnerability may require:")
print(f"  1. A trigger to change boot state (not found)")
