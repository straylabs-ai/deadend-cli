baseline_data = BASELINE_VALUES.copy()
baseline_data['submit'] = 'Send Message'
baseline = send_request(baseline_data)

print(f"URL: {TARGET_URL}")
print(f"Status: {baseline['status']}")
print(f"Length: {baseline['length']}B")
print(f"Time: {baseline['time']:.3f}s")
print(f"Redirects: {baseline['redirects']}")
print(f"\nResponse preview (first 500 chars):")
print(baseline['text'][:500])

# Store baseline characteristics
baseline_length = baseline['length']
baseline_status = baseline['status']

print("\n" + "=" * 70)
print("[2] PARAMETER-BY-PARAMETER SQL INJECTION TESTING")
print("=" * 70)

vulnerable_params = []

for param in PARAMETERS:
    print(f"\n{'='*50}")
    print(f"Testing parameter: {param}")
    print("="*50)
    
    param_vulnerable = False
    interesting_behaviors = []
    
    for payload_name, payload in SQL_PAYLOADS:
        # Create test data with payload in target parameter
        test_data = BASELINE_VALUES.copy()
        test_data[param] = payload
        test_data['submit'] = 'Send Message'
        
        response = send_request(test_data)
        
        # Analyze for anomalies
        differences = analyze_response(baseline, response, payload_name)
        
        # Check for SQL errors in response
        sql_errors = detect_sqli_errors(response['text'])
        
        # Determine anomaly level
        status = "NORMAL"
        if sql_errors:
            status = "SQL_ERROR"
            param_vulnerable = True
        elif response['time'] > 3.0 and 'SLEEP' in payload_name:
            status = "TIME_DELAY"
            param_vulnerable = True
        elif baseline_status != response['status'] and response['status'] != -1:
            status = "STATUS_CHANGE"
            param_vulnerable = True
        elif abs(response['length'] - baseline_length) > 50:
            status = "LENGTH_DIFF"
        
        # Print interesting results
        if status != "NORMAL" or differences:
            print(f"\n  Payload: {payload_name}")
            print(f"  Value: {payload[:50]}{'...' if len(payload) > 50 else ''}")
            print(f"  Status: {status} | Response: {response['status']} | Time: {response['time']:.2f}s")
            if differences:
                print(f"  Differences: {' | '.join(differences)}")
            
            if sql_errors:
                # Print the error context
                match = re.search(r'.{0,100}(?:' + '|'.join(SQL_ERROR_PATTERNS) + r').{0,200}', 
                                  response['text'].lower())
                if match:
                    print(f"  Error context: ...{match.group(0)}...")
            
            if status != "NORMAL":
                interesting_behaviors.append({
                    'payload': payload_name,
                    'payload_val': payload,
                    'status': status,
                    'response_status': response['status'],
                    'time': response['time'],
                    'length': response['length'],
                    'text_sample': response['text'][:300]
                })
    
    if param_vulnerable:
        vulnerable_params.append({
            'param': param,
            'behaviors': interesting_behaviors
        })
        print(f"\n  [!] Parameter '{param}' shows SQL injection indicators!")

