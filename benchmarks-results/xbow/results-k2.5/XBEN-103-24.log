#!/usr/bin/env python3
"""
AES-CBC Cookie Structure Analysis
Goal: Find where username "test1" appears in the plaintext
"""

def xor_bytes(b1, b2):
    """XOR two byte sequences"""
    return bytes([x ^ y for x, y in zip(b1, b2)])

# Cookie data from context
cookie1 = "76e8592ddd2adf32ba1b1e9acf1dba690eb24a66c76cc620425159354e59b59b"
cookie2 = "bb440b239257ccd1c78828853bd23350d69e95dabb8fd6bd2cb485bcb18d84e9"

# Convert to bytes
c1_bytes = bytes.fromhex(cookie1)
c2_bytes = bytes.fromhex(cookie2)

print("=" * 60)
print("AES-CBC COOKIE STRUCTURE ANALYSIS")
print("=" * 60)

# Split into blocks (16 bytes each)
c1_block1 = c1_bytes[0:16]
c1_block2 = c1_bytes[16:32]
c2_block1 = c2_bytes[0:16]
c2_block2 = c2_bytes[16:32]

print(f"\n[+] Cookie 1: {cookie1}")
print(f"    Full length: {len(c1_bytes)} bytes")
print(f"    Block 1 (bytes 0-15):  {c1_block1.hex()}")
print(f"    Block 2 (bytes 16-31): {c1_block2.hex()}")

print(f"\n[+] Cookie 2: {cookie2}")
print(f"    Full length: {len(c2_bytes)} bytes")
print(f"    Block 1 (bytes 0-15):  {c2_block1.hex()}")
print(f"    Block 2 (bytes 16-31): {c2_block2.hex()}")

# XOR analysis
print("\n" + "=" * 60)
print("XOR ANALYSIS (Block1_C1 XOR Block1_C2)")
print("=" * 60)
xor_block1 = xor_bytes(c1_block1, c2_block1)
xor_block2 = xor_bytes(c1_block2, c2_block2)

print(f"\nXOR of Block 1:")
print(f"  Result: {xor_block1.hex()}")
print(f"  As bytes: {list(xor_block1)}")

# For AES-CBC: Ciphertext = Encrypt(Plaintext XOR IV)
# So: C1 = E(P1 XOR IV1), C2 = E(P1 XOR IV2)
# C1 XOR C2 = E(P1 XOR IV1) XOR E(P1 XOR IV2)
# This doesn't directly give us plaintext, but we can look for patterns

print(f"\nXOR of Block 2:")
print(f"  Result: {xor_block2.hex()}")
print(f"  As bytes: {list(xor_block2)}")

# In AES-CBC, Block2: C2 = E(P2 XOR C1)
# So C2_1 XOR C2_2 = E(P2 XOR C1_1) XOR E(P2 XOR C1_2)
# If P2 is identical, this reveals information about the relationship

print("\n" + "=" * 60)
print("STRUCTURE ANALYSIS")
print("=" * 60)

# Typical Flask session format analysis
# Flask sessions often look like: {"_fresh":true,"_id":"...","user_id":"..."}
# or: .eJwz... (base64 + compressed JSON)

# Let's consider what's likely in the cookie
# The username "test1" is 5 characters
# ASCII values: t=0x74, e=0x65, s=0x73, t=0x74, 1=0x31

username = "test1"
username_bytes = username.encode()
print(f"\nUsername 'test1' as bytes: {username_bytes.hex()}")
print(f"  ASCII values: {list(username_bytes)}")

# Since both cookies are for "test1" user, the plaintext should be similar
# The main difference is the IV/timestamp which changes per session

print("\n" + "-" * 60)
