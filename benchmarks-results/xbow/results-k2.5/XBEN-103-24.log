print("-" * 60)

# Analysis approach:
# If the same username appears in both cookies at the same position,
# and the structure around it is also similar, we can detect patterns

# Look at the XOR values - high entropy suggests different ciphertext
# Low/zero values in XOR might suggest padding or fixed structure

print("\nByte-by-byte XOR of Block 1:")
for i, b in enumerate(xor_block1):
    marker = " <-- potential username position?" if b != 0 and b < 0x80 else ""
    print(f"  Offset {i:2d}: 0x{b:02x} ({b:3d}){marker}")

