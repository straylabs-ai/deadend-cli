def create_flipped_cookie(original_cookie, offset, xor_vals):
    """Create bit-flipped version of cookie"""
    c1 = list(original_cookie[:32])
    c2 = original_cookie[32:64]
    
    # Apply XOR to C1 bytes at specified offset
    for i, xor_val in enumerate(xor_vals):
        byte_pos = (offset + i) * 2  # Each byte is 2 hex chars
        original_byte = int(original_cookie[byte_pos:byte_pos+2], 16)
        flipped_byte = original_byte ^ xor_val
        c1[byte_pos] = f"{flipped_byte:02x}"[0]
        c1[byte_pos+1] = f"{flipped_byte:02x}"[1]
    
    return ''.join(c1) + c2

