def create_flipped_cookie(original_cookie, offset, xor_vals):
    """Create bit-flipped version of cookie"""
    c1 = list(original_cookie[:32])
    c2 = original_cookie[32:64]
    
    # Apply XOR to C1 bytes at specified offset
    for i, xor_val in enumerate(xor_vals):
        byte_pos = (offset + i) * 2  # Each byte is 2 hex chars
        original_byte = int(original_cookie[byte_pos:byte_pos+2], 16)
        flipped_byte = original_byte ^ xor_val
        c1[byte_pos] = f"{flipped_byte:02x}"[0]
        c1[byte_pos+1] = f"{flipped_byte:02x}"[1]
    
    return ''.join(c1) + c2

# Test offsets 9 and 14
test_offsets = [9, 14]
xor_vals = [0x15, 0x01, 0x1e, 0x1d, 0x4f]

for offset in test_offsets:
    label = "user" if offset == 9 else "username"
    print(f"\nOffset {offset} ({label} format):")
    for name in ['A', 'B', 'C']:
        original = cookies[name]
        flipped = create_flipped_cookie(original, offset, xor_vals)
        print(f"  Cookie {name}:")
        print(f"    Original: {original}")
        print(f"    Flipped:  {flipped}")
        print(f"    Diff at:  C1 bytes {offset}-{offset+4}")

print("\n" + "=" * 70)
print("RECOMMENDATION: Test offset 14 first (most common Flask format)")
print("If that fails, try offset 9")
print("=" * 70)


