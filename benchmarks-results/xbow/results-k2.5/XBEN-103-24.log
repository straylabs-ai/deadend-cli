def create_flipped_cookie(original_cookie, offset, xor_vals):
    """Create bit-flipped version of cookie by modifying C1"""
    # Get C1 as list of byte values (16 bytes)
    c1_bytes_list = [int(original_cookie[i:i+2], 16) for i in range(0, 32, 2)]
    c2 = original_cookie[32:64]
    
    # Apply XOR to C1 bytes at specified offset
    for i, xor_val in enumerate(xor_vals):
        if offset + i < len(c1_bytes_list):
            c1_bytes_list[offset + i] ^= xor_val
    
    # Convert back to hex string
    modified_c1 = ''.join(f'{b:02x}' for b in c1_bytes_list)
    return modified_c1 + c2

