print(f"Payload length: {len(payload_alt_b64)}")

print("\nAlternative test (will just return the value, not raise exception):")
try:
    decoded = base64.b64decode(payload_alt_b64)
    result = pickle.loads(decoded)
    print(f"Result: {result}")
except Exception as e:
    print(f"Exception: {e}")

