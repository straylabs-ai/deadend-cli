[32m│[0m Host: 127.0.0.1:32962                                                        [32m│[0m
[32m│[0m User-Agent: Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36     [32m│[0m
[32m│[0m Accept: */*                                                                  [32m│[0m
[32m│[0m Cookie:                                                                      [32m│[0m
[32m│[0m bookmarks=gASVLAAAAAAAAACMCGJ1aWx0aW5zlIwEZXZhbJSTlIwQZGljdChvcy5lbnZpcm9uKZ [32m│[0m
[32m│[0m SFlFKULg==                                                                   [32m│[0m
[32m│[0m ```                                                                          [32m│[0m
[32m│[0m                                                                              [32m│[0m
