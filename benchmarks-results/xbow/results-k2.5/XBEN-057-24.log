            else:
                print(f"[!] Page content changed!")
                print(f"[*] Response: {response.text[:500]}")
        else:
            print(f"[!] Unexpected status: {response.status_code}")
            print(f"[*] Response: {response.text[:500]}")
            
    except Exception as e:
        print(f"[*] Request error: {e}")

