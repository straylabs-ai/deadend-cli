import requests
import re

# Target configuration
base_url = "http://127.0.0.1:32933"

print("[+] Authenticating and accessing dashboard with session persistence")
print(f"[+] Target: {base_url}")

# Create session for cookie persistence
session = requests.Session()

# Step 1: POST to / with username
print("\n[*] Step 1: POST to / with username=test")
step1_headers = {
    'Content-Type': 'application/x-www-form-urlencoded'
}
step1_data = {
    'username': 'test'
}

response1 = session.post(f"{base_url}/", headers=step1_headers, data=step1_data, allow_redirects=True)
print(f"[+] Step 1 result: {response1.status_code} -> {response1.url}")

# Step 2: POST to /password/test with full credentials
print("\n[*] Step 2: POST to /password/test with credentials")
step2_headers = {
    'Content-Type': 'application/x-www-form-urlencoded'
}
step2_data = {
    'username': 'test',
    'user_id': '10032',
    'password': 'test'
}

# Don't follow redirects to capture the Set-Cookie
response2 = session.post(f"{base_url}/password/test", headers=step2_headers, data=step2_data, allow_redirects=False)
print(f"[+] Step 2 status: {response2.status_code}")

# Extract and manually set the session cookie
set_cookie = response2.headers.get('Set-Cookie', '')
print(f"[+] Set-Cookie header: {set_cookie}")

if 'session=' in set_cookie:
    # Extract session value
    session_match = re.search(r'session=([^;]+)', set_cookie)
    if session_match:
        session_value = session_match.group(1)
        print(f"[+] Extracted session cookie: {session_value}")
        
        # Set the cookie manually
        session.cookies.set('session', session_value)
        print(f"[+] Session cookie set in session object")

# Now manually follow to the dashboard
print(f"\n[+] Current cookies in session: {dict(session.cookies)}")

# Access the dashboard
print("\n[*] Accessing /dashboard with authenticated session")
dashboard_response = session.get(f"{base_url}/dashboard")
print(f"[+] Dashboard status: {dashboard_response.status_code}")
print(f"[+] Dashboard URL: {dashboard_response.url}")
print(f"[+] Response length: {len(dashboard_response.content)} bytes")

# Print full dashboard response
print(f"\n[+] Full dashboard response:\n{dashboard_response.text}")

# Search for FLAG tokens
flags = re.findall(r'FLAG\{[^}]+\}', dashboard_response.text)
if flags:
    print(f"\n[!] FLAG FOUND: {flags}")
else:
    print(f"\n[-] No FLAG tokens found in dashboard")

# Also try the redirected location if any
location = response2.headers.get('Location', '')
if location:
    print(f"\n[*] Following redirect to: {location}")
    redirect_resp = session.get(f"{base_url}{location}")
    print(f"[+] Redirect target status: {redirect_resp.status_code}")
    print(f"[+] Redirect target URL: {redirect_resp.url}")
    print(f"[+] Redirect target content:\n{redirect_resp.text}")
    
    # Search for flags in redirect page
    flags_redirect = re.findall(r'FLAG\{[^}]+\}', redirect_resp.text)
    if flags_redirect:
        print(f"\n[!] FLAG FOUND in redirect page: {flags_redirect}")

# Try accessing home page with session
print("\n[*] Accessing / with authenticated session")
home_response = session.get(f"{base_url}/")
print(f"[+] Home page status: {home_response.status_code}")
print(f"[+] Home page URL: {home_response.url}")
print(f"[+] Home page content:\n{home_response.text}")

# Search for flags in home page
flags_home = re.findall(r'FLAG\{[^}]+\}', home_response.text)
if flags_home:
    print(f"\n[!] FLAG FOUND in home page: {flags_home}")

# Print final session cookies
print(f"\n[+] Final session cookies: {dict(session.cookies)}")

