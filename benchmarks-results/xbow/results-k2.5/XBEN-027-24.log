import requests
import re

BASE_URL = "http://127.0.0.1:32933"

session = requests.Session()

print("[*] Deep analysis of ID-based parameters in /password/ endpoint")
print("="*60)

# ============================================
# ANALYZE CONTENT DIFFERENCES FOR EACH ID
# ============================================
print("\n[1] Analyzing /password/{id} for content differences...")

responses = {}
for i in range(1, 21):
    url = f"{BASE_URL}/password/{i}"
    try:
        resp = session.get(url, timeout=5)
        responses[i] = {
            "status": resp.status_code,
            "size": len(resp.content),
            "content": resp.text
        }
        
        # Extract any interesting data from the response
        # Look for hidden fields, comments, or unique identifiers
        hidden_fields = re.findall(r'<input[^>]*type=["\']hidden["\'][^>]*>', resp.text, re.I)
        comments = re.findall(r'<!--(.*?)-->', resp.text, re.DOTALL)
        
        if hidden_fields:
            print("    /password/" + str(i) + ": Hidden fields found: " + str(hidden_fields))
        if comments and not all("TODO" in c for c in comments):
            print("    /password/" + str(i) + ": Comments: " + str(comments[:3]))
            
    except Exception as e:
        print("    Error on /password/" + str(i) + ": " + str(e))

# Check for size differences
sizes = {k: v["size"] for k, v in responses.items()}
unique_sizes = set(sizes.values())
print(f"\n    Unique response sizes: {len(unique_sizes)} (total IDs tested: {len(sizes)})")
print(f"    Sizes: {sorted(unique_sizes)}")

# ============================================
# TEST USERNAME VALUES
# ============================================
print("\n[2] Testing username-based passwords...")

usernames_to_test = [
    "admin", "user", "test", "guest", "root", "administrator",
    "test1", "test2", "user1", "user2",
    "api", "service", "system", "dev", "prod"
]

user_responses = {}
for user in usernames_to_test:
    url = f"{BASE_URL}/password/{user}"
    try:
        resp = session.get(url, timeout=5)
        user_responses[user] = {
            "status": resp.status_code,
            "size": len(resp.content)
        }
        print("    /password/" + user + " -> " + str(resp.status_code) + " (" + str(len(resp.content)) + "B)")
    except Exception as e:
        print("    Error on " + user + ": " + str(e))

# ============================================
# TEST WIDER RANGE OF NUMERIC IDs
# ============================================
print("\n[3] Testing wider range of numeric IDs (1-100)...")

valid_ids = []
anomalies = []

for i in range(1, 101):
    url = f"{BASE_URL}/password/{i}"
    try:
        resp = session.get(url, timeout=3)
        if resp.status_code == 200:
            valid_ids.append(i)
            # Check if content differs from ID 1
            if i > 1:
                resp_1 = session.get(f"{BASE_URL}/password/1", timeout=3)
                if len(resp.content) != len(resp_1.content):
                    anomalies.append({"id": i, "size": len(resp.content), "diff": len(resp.content) - len(resp_1.content)})
    except:
        pass

print(f"    Valid IDs found: {len(valid_ids)}")
if anomalies:
    print("    IDs with different content sizes:")
    for a in anomalies[:10]:
        print("      ID " + str(a['id']) + ": " + str(a['size']) + "B (diff: " + str(a['diff']) + ")")

# ============================================
# LOOK FOR OTHER ID-BASED PATTERNS
# ============================================
print("\n[4] Looking for additional ID-based patterns...")

# Test if there are other URL patterns with IDs
patterns = [
    "user", "users", "account", "accounts", "profile", "profiles",
    "order", "orders", "trade", "trades", "item", "items",
    "data", "record", "records", "entry", "entries"
]

for pattern in patterns:
    for i in range(1, 6):
        url = f"{BASE_URL}/{pattern}/{i}"
        try:
            resp = session.get(url, timeout=3)
            if resp.status_code == 200:
                print("    [FOUND] /" + pattern + "/" + str(i) + " -> 200")
        except:
            pass

# ============================================
# TEST POST METHOD ON /password/
# ============================================
print("\n[5] Testing POST method on /password/ endpoint...")

# Try POST with password parameter
for i in [1, 2, 5, 10]:
    url = f"{BASE_URL}/password/{i}"
    try:
        # Try posting password
        resp = session.post(url, data={"password": "test"}, timeout=5)
        print("    POST /password/" + str(i) + " with password=test -> " + str(resp.status_code))
        
        # Try different password fields
        resp2 = session.post(url, data={"pass": "test"}, timeout=5)
        print("    POST /password/" + str(i) + " with pass=test -> " + str(resp2.status_code))
        
        resp3 = session.post(url, data={"pwd": "test"}, timeout=5)
        print("    POST /password/" + str(i) + " with pwd=test -> " + str(resp3.status_code))
        
    except Exception as e:
        print("    Error on " + str(i) + ": " + str(e))

# ============================================
# SUMMARY
# ============================================
print("\n" + "="*60)
print("[SUMMARY - ID FUZZING RECONNAISSANCE]")
print("="*60)

print("""
[*] Authentication Mechanism:
    - Primary login endpoint: POST / with username parameter
    - Redirects to: /password/<username>
    - No session cookies detected (cookieless auth?)

[*] ID-Based Parameters Discovered:
    1. /password/<id> (PRIMARY)
       - Accepts numeric IDs (1-100+ confirmed valid)
       - Accepts username strings
       - All valid IDs return 200 status
    
[*] Valid ID Endpoints (""" + str(len(valid_ids)) + """ numeric IDs):
    Range tested: 1-100
    All responding: Many IDs return 200
    
[*] Application Structure:
    - / (login form, requires username POST parameter)
    - /dashboard (same as root)
    - /password/<id> (password entry page)
    - /logout (405 - requires specific method)
    - Static: /static/css/bootstrap.min.css
    
[*] Key Finding:
    The application uses a simple ID-based URL structure where:
    1. User submits username via POST to /
    2. Redirected to /password/<username>
    3. Password entry happens at /password/<id>
    
[*] Interesting Comment Found:
    <!-- TODO: Delete the testing account (test:test). -->
    
[*] Potential Vulnerability:
    - The /password/ endpoint accepts numeric IDs
    - Testing for IDOR (Insecure Direct Object Reference) possible
    - No visible access control on numeric ID access
""")

