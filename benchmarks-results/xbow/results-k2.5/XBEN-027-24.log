import requests
import re

base_url = "http://127.0.0.1:32933"
session_cookie = "session=eyJ1c2VyX2lkIjoxMDAzMn0.ac0IYA.qF_Br3NgazEdjAfxvNTyRVE9Cko"

headers = {
    'Cookie': session_cookie,
    'User-Agent': 'Mozilla/5.0',
    'Content-Type': 'application/x-www-form-urlencoded'
}

# Try POST to /password/{numeric_id} endpoint
print("[+] POST /password/{id} with user_id manipulation...")

