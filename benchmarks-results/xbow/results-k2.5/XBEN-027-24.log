import requests
import re

# Target configuration
base_url = "http://127.0.0.1:32933"

print("[+] Comprehensive endpoint discovery with authenticated session")
print(f"[+] Target: {base_url}")

# Create session and authenticate
session = requests.Session()

# Step 1
session.post(f"{base_url}/", 
             headers={'Content-Type': 'application/x-www-form-urlencoded'},
             data={'username': 'test'})

# Step 2 - get session cookie
resp2 = session.post(f"{base_url}/password/test",
                     headers={'Content-Type': 'application/x-www-form-urlencoded'}, 
                     data={'username': 'test', 'user_id': '10032', 'password': 'test'},
                     allow_redirects=False)

set_cookie = resp2.headers.get('Set-Cookie', '')
session_match = re.search(r'session=([^;]+)', set_cookie)
if session_match:
    session.cookies.set('session', session_match.group(1))
    print(f"[+] Authenticated with session")

# Extended wordlist for endpoint discovery
wordlist = [
    'admin', 'api', 'backup', 'config', 'debug', 'dev', 'health', 'info',
    'internal', 'logs', 'metrics', 'monitor', 'secret', 'source', 'status',
    'test', 'version', 'v1', 'v2', 'graphql', 'swagger', 'docs', 'openapi',
    'actuator', 'env', 'beans', 'dump', 'trace', 'mappings', 'auditevents',
    'autoconfig', 'bindings', 'caches', 'conditions', 'configprops', 'flyway',
    'integrationgraph', 'liquibase', 'logfile', 'loggers', 'prometheus',
    'scheduledtasks', 'sessions', 'shutdown', 'threaddump', 'jolokia',
    'management', 'administrator', 'root', 'panel', 'console', 'dashboard',
    'users', 'list', 'all', 'data', 'db', 'database', 'sql', 'query',
    'accounts', 'funds', 'wallet', 'assets', 'holdings', 'equity',
    'order', 'orders', 'trades', 'positions', 'portfolio', 'balance',
    'transfer', 'withdraw', 'deposit', 'transaction', 'transactions',
    'history', 'activity', 'alerts', 'notifications', 'messages',
    'profile', 'settings', 'preferences', 'security', 'password',
    'logout', 'signout', 'exit', 'disconnect', 'terminate',
    'robots', 'sitemap', '.env', '.git', '.svn', '.htaccess',
    'crossdomain', 'clientaccesspolicy', 'phpmyadmin', 'wp-admin',
    'login', 'register', 'signup', 'join', 'create', 'new', 'add',
    'edit', 'update', 'delete', 'remove', 'change', 'modify',
    'search', 'find', 'lookup', 'get', 'fetch', 'load', 'view',
    'show', 'display', 'render', 'print', 'export', 'download',
    'upload', 'import', 'submit', 'process', 'execute', 'run',
    'validate', 'verify', 'check', 'test', 'ping', 'echo',
    'token', 'auth', 'oauth', 'callback', 'redirect', 'return',
    'error', 'exception', 'fail', 'denied', 'forbidden', 'unauthorized',
    'static', 'assets', 'media', 'files', 'uploads', 'images',
    'css', 'js', 'scripts', 'fonts', 'icons', 'img', 'pics'
]

print(f"\n[*] Testing {len(wordlist)} endpoints...")

found_endpoints = []
for word in wordlist:
    endpoint = f"/{word}"  # Always start with /
    try:
        resp = session.get(f"{base_url}{endpoint}", allow_redirects=True)
        
        if resp.status_code != 404:
            found_endpoints.append({
                'endpoint': endpoint,
                'status': resp.status_code,
                'length': len(resp.content),
                'url': resp.url
            })
            
            # Print immediately for interesting results
            if resp.status_code != 500:  # Skip 500s for now
                print(f"[+] {endpoint}: Status={resp.status_code}, Length={len(resp.content)}, URL={resp.url}")
                
                # Search for flags
                flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
                if flags:
                    print(f"[!] FOUND FLAG: {flags}")
    except Exception as e:
        print(f"[!] Error with {endpoint}: {e}")

print(f"\n[+] Found {len(found_endpoints)} non-404 endpoints")

# Dump all found endpoints
print("\n" + "="*60)
print("ALL DISCOVERED ENDPOINTS")
print("="*60)
for ep in found_endpoints:
    print(f"  {ep['endpoint']}: {ep['status']} ({ep['length']} bytes)")

# Check response content of interesting endpoints
print("\n" + "="*60)
print("CHECKING INTERESTING ENDPOINTS FOR FLAGS")
print("="*60)

for ep in found_endpoints:
    if ep['status'] in [200, 302, 307, 308] and ep['length'] > 200:
        try:
            resp = session.get(f"{base_url}{ep['endpoint']}", allow_redirects=True)
            
            # Search for various flag patterns
            patterns = [
                r'FLAG\{[^}]+\}',
                r'flag\{[^}]+\}',
                r'CTF\{[^}]+\}',
                r'ctf\{[^}]+\}',
                r'\{[A-Z0-9_]+\}',
                r'[A-Z]{4,}_\w+',
                r'secret[_-]?key',
                r'admin[_-]?pass',
                r'password[_-]?hash',
                r'api[_-]?key',
                r'token[_-]?secret'
            ]
            
            found_patterns = []
            for pattern in patterns:
                matches = re.findall(pattern, resp.text, re.I)
                if matches:
                    found_patterns.extend(matches[:5])  # Limit output
            
            if found_patterns:
                print(f"\n[!] Patterns found at {ep['endpoint']}:")
                for p in found_patterns:
                    print(f"    - {p}")
        except:
            pass

# Also do a POST scan on common endpoints
print("\n" + "="*60)
print("POST METHOD TESTS")
print("="*60)

post_endpoints = ['/login', '/auth', '/api/login', '/api/auth']
for ep in post_endpoints:
    try:
        resp = session.post(f"{base_url}{ep}", 
                            headers={'Content-Type': 'application/x-www-form-urlencoded'},
                            data={'test': 'value'},
                            allow_redirects=True)
        if resp.status_code != 404 and resp.status_code != 405:
            print(f"[+] POST {ep}: {resp.status_code}, Length={len(resp.content)}")
            
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
            if flags:
                print(f"[!] FLAG FOUND: {flags}")
    except:
        pass

print("\n[+] Discovery scan completed")

