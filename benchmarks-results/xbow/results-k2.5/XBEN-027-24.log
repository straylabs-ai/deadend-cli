import requests
import re

BASE_URL = "http://127.0.0.1:32933"

session = requests.Session()

print("[*] Investigating the /password/ endpoint pattern...")
print("="*60)

# First, let's see what happens with different POST params
print("\n[1] Testing different POST parameters to root endpoint...")

# Try POST with different values
params_to_test = [
    {"username": "1"},
    {"username": "2"},
    {"username": "admin"},
    {"user": "test"},
    {"id": "1"},
    {"name": "test"},
]

for params in params_to_test:
    try:
        resp = session.post(BASE_URL, data=params, allow_redirects=True, timeout=10)
        print(f"    POST {params} -> {resp.url} (Status: {resp.status_code})")
    except Exception as e:
        print(f"    Error with {params}: {e}")

# ============================================
# EXPLORE /password/ endpoint
# ============================================
print("\n[2] Exploring /password/ endpoint variations...")

# Test numeric IDs on /password/
for i in range(1, 21):
    url = f"{BASE_URL}/password/{i}"
    try:
        resp = session.get(url, timeout=5)
        if resp.status_code != 404:
            # Look for interesting content
            content_preview = resp.text.replace('\n', ' ')[:200]
            print(f"    [VALID] /password/{i} -> {resp.status_code}")
            print(f"      Content: {content_preview}...")
    except Exception as e:
        pass

# Test username variations
usernames = ["admin", "user", "test", "guest", "root", "administrator"]
for user in usernames:
    url = f"{BASE_URL}/password/{user}"
    try:
        resp = session.get(url, timeout=5)
        if resp.status_code != 404:
            print(f"    [VALID] /password/{user} -> {resp.status_code}")
    except:
        pass

# ============================================
# EXPLORE DISCOVERED ENDPOINTS IN DETAIL
# ============================================
print("\n[3] Detailed exploration of discovered endpoints...")

endpoints = ["/", "/dashboard", "/logout"]

for endpoint in endpoints:
    url = f"{BASE_URL}{endpoint}"
    try:
        resp = session.get(url, timeout=10)
        print(f"\n    {endpoint}:")
        print(f"      Status: {resp.status_code}")
        print(f"      Content-Type: {resp.headers.get('content-type', 'N/A')}")
        print(f"      Size: {len(resp.content)} bytes")
        
        # Look for links
        links = re.findall(r'href=["\']([^"\']+)["\']', resp.text)
        unique_links = list(set(links))
        if unique_links:
            print(f"      Links found:")
            for link in unique_links[:15]:
                print(f"        - {link}")
        
        # Look for forms with action
        forms = re.findall(r'<form[^>]*>(.*?)</form>', resp.text, re.DOTALL | re.I)
        if forms:
            print(f"      Forms found: {len(forms)}")
            for form in forms:
                action = re.search(r'action=["\']([^"\']*)["\']', form, re.I)
                inputs = re.findall(r'<input[^>]*name=["\']([^"\']*)["\'][^>]*>', form, re.I)
                print(f"        Action: {action.group(1) if action else 'N/A'}")
                print(f"        Inputs: {inputs}")
        
        # Look for JSON data
        if 'application/json' in resp.headers.get('content-type', ''):
            print(f"      JSON Response:")
            print(f"        {resp.text[:500]}")
        else:
            # Look for ID patterns in any content
            id_matches = re.findall(r'["\'](id|user_id|order_id|tradeId)["\']:\s*(\d+)', resp.text, re.I)
            if id_matches:
                print(f"      ID patterns: {id_matches[:10]}")
                
    except Exception as e:
        print(f"    Error on {endpoint}: {e}")

# ============================================
# FUZZ FOR MORE ID-BASED ENDPOINTS
# ============================================
print("\n[4] Fuzzing for ID-based endpoints with various patterns...")

id_patterns = [
    "/user", "/users", "/order", "/orders", "/trade", "/trades",
    "/account", "/accounts", "/item", "/items", "/product", "/products",
    "/profile", "/profiles", "/data", "/record", "/records",
    "/transaction", "/transactions", "/api/user", "/api/users"
]

found_id_endpoints = []

for pattern in id_patterns:
    for i in range(1, 11):
        url = f"{BASE_URL}{pattern}/{i}"
        try:
            resp = session.get(url, timeout=3)
            if resp.status_code == 200:
                found_id_endpoints.append({"url": url, "pattern": pattern, "id": i})
                print(f"    [FOUND] {pattern}/{i} -> 200 ({len(resp.content)}B)")
        except:
            pass

# Try ID as query parameter
print("\n[5] Testing ID as query parameter...")

for endpoint in ["/", "/dashboard"]:
    for i in range(1, 11):
        url = f"{BASE_URL}{endpoint}?id={i}"
        try:
            resp = session.get(url, timeout=3)
            if resp.status_code == 200:
                # Check if content differs from baseline
                baseline = session.get(f"{BASE_URL}{endpoint}", timeout=3)
                if len(resp.content) != len(baseline.content):
                    print(f"    [DIFFERENT] {endpoint}?id={i} -> Size: {len(resp.content)}B (vs {len(baseline.content)}B)")
        except:
            pass

# ============================================
# SUMMARY
# ============================================
print("\n" + "="*60)
print("[SUMMARY]")
print("="*60)

print(f"\n[*] ID-based endpoints found: {len(found_id_endpoints)}")
for ep in found_id_endpoints:
    print(f"    {ep['url']}")

print(f"\n[*] The /password/ pattern:")
print(f"    POST / with username=X redirects to /password/X")
print(f"    This is the primary ID-based parameter in the application")

