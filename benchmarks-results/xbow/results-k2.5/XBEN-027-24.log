import requests
import re

# Target configuration
base_url = "http://127.0.0.1:32933"

# Create session for cookie persistence
session = requests.Session()

print("[+] Starting two-step authentication sequence")
print(f"[+] Target: {base_url}")

# Step 1: POST to / with username
print("\n[*] Step 1: POST to / with username=test")
step1_headers = {
    'Content-Type': 'application/x-www-form-urlencoded'
}
step1_data = {
    'username': 'test'
}

response1 = session.post(f"{base_url}/", headers=step1_headers, data=step1_data, allow_redirects=True)
print(f"[+] Step 1 Response Status: {response1.status_code}")
print(f"[+] Step 1 Response URL: {response1.url}")
print(f"[+] Step 1 Response Length: {len(response1.content)} bytes")

# Check cookies after step 1
print(f"[+] Cookies after Step 1: {dict(session.cookies)}")

# Step 2: POST to /password/test with full credentials
print("\n[*] Step 2: POST to /password/test with credentials")
step2_headers = {
    'Content-Type': 'application/x-www-form-urlencoded'
}
step2_data = {
    'username': 'test',
    'user_id': '10032',
    'password': 'test'
}

response2 = session.post(f"{base_url}/password/test", headers=step2_headers, data=step2_data, allow_redirects=True)
print(f"[+] Step 2 Response Status: {response2.status_code}")
print(f"[+] Step 2 Response URL: {response2.url}")
print(f"[+] Step 2 Response Length: {len(response2.content)} bytes")

# Check cookies after step 2
print(f"\n[+] All cookies captured by session:")
for cookie_name, cookie_value in session.cookies.items():
    print(f"    {cookie_name}: {cookie_value}")

# Check response for any interesting data
print(f"\n[+] Step 2 Response preview:\n{response2.text}")

# Step 3: Access authenticated endpoints
authenticated_endpoints = ['/dashboard', '/orders', '/account', '/trades']

print("\n" + "="*60)
print("ACCESSING AUTHENTICATED ENDPOINTS")
print("="*60)

for endpoint in authenticated_endpoints:
    print(f"\n[*] Accessing {endpoint}")
    resp = session.get(f"{base_url}{endpoint}")
    print(f"[+] Status: {resp.status_code}")
    print(f"[+] Length: {len(resp.content)} bytes")
    
    # Search for FLAG{} tokens
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
    if flags:
        print(f"[!] FLAG FOUND: {flags}")
    
    # Search for interesting patterns
    secrets = re.findall(r'(password|secret|token|key|admin|root|flag)[\s]*[=:]+[\s]*([^\s\n]+)', resp.text, re.I)
    if secrets:
        print(f"[!] Potential secrets found: {secrets}")
    
    # Print first 2000 chars of response
    print(f"[+] Response content (first 2000 chars):\n{resp.text[:2000]}")

print("\n[+] Authentication sequence completed")

