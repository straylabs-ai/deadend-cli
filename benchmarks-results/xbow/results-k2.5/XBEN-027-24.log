import requests
from bs4 import BeautifulSoup
import re
from urllib.parse import urljoin

# Target URL
base_url = "http://127.0.0.1:32933"
dashboard_url = f"{base_url}/dashboard"

# Cookies from context
cookies = {
    'session': 'eyJ1c2VyX2lkIjoxMDAzMn0.ac0IYA.qF_Br3NgazEdjAfxvNTyRVE9Cko',
    'auth_token': 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VybmFtZSI6InRlc3QiLCJ1c2VyX2lkIjoxMDAzMiwidXNlcl90eXBlIjoiY3VzdG9tZXIifQ.ubKxvL3U9FouYhgqbsNNfV7C6iaVCJ83foZ1bq8roEs'
}

# Access dashboard
print(f"[*] Accessing {dashboard_url}")
response = requests.get(dashboard_url, cookies=cookies)
print(f"[*] Status Code: {response.status_code}")
print(f"[*] Content-Type: {response.headers.get('Content-Type', 'N/A')}")
print(f"[*] Content Length: {len(response.text)} bytes")
print(f"\n{'='*60}")
print("RAW RESPONSE BODY:")
print(f"{'='*60}")
print(response.text)
print(f"{'='*60}\n")

# Parse with BeautifulSoup
soup = BeautifulSoup(response.text, 'html.parser')

# Find all forms
print("\n[1] FORMS ANALYSIS:")
forms = soup.find_all('form')
print(f"    Found {len(forms)} form(s)")
for i, form in enumerate(forms):
    print(f"\n    Form #{i+1}:")
    print(f"      Action: {form.get('action', 'N/A')}")
    print(f"      Method: {form.get('method', 'N/A')}")
    print(f"      ID: {form.get('id', 'N/A')}")
    print(f"      Name: {form.get('name', 'N/A')}")
    print(f"      Class: {form.get('class', 'N/A')}")
    
    # Get all form inputs
    inputs = form.find_all('input')
    print(f"      Inputs ({len(inputs)}):")
    for inp in inputs:
        attrs = {k: v for k, v in inp.attrs.items() if k not in ['type']}
        print(f"        - type={inp.get('type', 'text')}, name={inp.get('name', 'N/A')}, value={inp.get('value', 'N/A')}, id={inp.get('id', 'N/A')}, {attrs}")
    
    # Submit buttons
    submits = form.find_all(['button', 'input'], {'type': 'submit'})
    print(f"      Submit elements: {[s.get('value', s.text.strip()) for s in submits]}")

# All input elements (not just in forms)
print("\n[2] ALL INPUT ELEMENTS:")
all_inputs = soup.find_all('input')
print(f"    Total input elements: {len(all_inputs)}")
for inp in all_inputs:
    print(f"    - type={inp.get('type', 'text')}, name={inp.get('name', 'N/A')}, value={inp.get('value', 'N/A')}, id={inp.get('id', 'N/A')}")

# Hidden fields specifically
print("\n[3] HIDDEN FIELDS:")
hidden_inputs = soup.find_all('input', {'type': 'hidden'})
print(f"    Found {len(hidden_inputs)} hidden input(s)")
for inp in hidden_inputs:
    print(f"    - name={inp.get('name', 'N/A')}, value={inp.get('value', 'N/A')}, id={inp.get('id', 'N/A')}")

# Elements with 'id' attribute
print("\n[4] ELEMENTS WITH 'id' ATTRIBUTE:")
elements_with_id = soup.find_all(id=True)
print(f"    Found {len(elements_with_id)} element(s) with 'id'")
for elem in elements_with_id:
    print(f"    - <{elem.name}> id='{elem.get('id')}', class={elem.get('class', 'N/A')}")

# Elements with 'name' attribute
print("\n[5] ELEMENTS WITH 'name' ATTRIBUTE:")
elements_with_name = soup.find_all(attrs={'name': True})
print(f"    Found {len(elements_with_name)} element(s) with 'name'")
for elem in elements_with_name:
    print(f"    - <{elem.name}> name='{elem.get('name')}', value={elem.get('value', 'N/A')}")

# data-* attributes
print("\n[6] DATA-* ATTRIBUTES:")
data_elements = []
for elem in soup.find_all(True):
    for attr in elem.attrs:
        if attr.startswith('data-'):
            data_elements.append((elem.name, attr, elem.get(attr)))
print(f"    Found {len(data_elements)} data-* attribute(s)")
for tag, attr, value in data_elements:
    print(f"    - <{tag}> {attr}='{value}'")

# JavaScript analysis
print("\n[7] JAVASCRIPT ANALYSIS:")
scripts = soup.find_all('script')
print(f"    Found {len(scripts)} script element(s)")
for i, script in enumerate(scripts):
    print(f"\n    Script #{i+1}:")
    if script.get('src'):
        print(f"      Source (external): {script.get('src')}")
    else:
        content = script.string if script.string else "(empty)"
        print(f"      Inline script: {content[:500]}{'...' if len(content) > 500 else ''}")

# Links analysis
print("\n[8] LINKS (href attributes):")
links = soup.find_all('a', href=True)
print(f"    Found {len(links)} link(s)")
for link in links:
    href = link.get('href')
    full_url = urljoin(base_url, href)
    print(f"    - Text: '{link.text.strip()}', href: {href}, full: {full_url}")

# All external resources
print("\n[9] EXTERNAL RESOURCES (src attributes):")
src_elements = soup.find_all(src=True)
print(f"    Found {len(src_elements)} element(s) with src")
for elem in src_elements:
    print(f"    - <{elem.name}> src: {elem.get('src')}")

# HTML comments
print("\n[10] HTML COMMENTS:")
comments = soup.find_all(string=lambda text: isinstance(text, str) and text.strip().startswith('<!--'))
print(f"    Found {len(comments)} comment(s)")
for i, comment in enumerate(comments):
    content = comment.strip()
    print(f"    Comment #{i+1}: {content[:200]}{'...' if len(content) > 200 else ''}")

# Numeric patterns (potential IDs)
print("\n[11] NUMERIC PATTERNS (potential IDs):")
text_content = response.text

# Look for common ID patterns in text
patterns = [
    (r'order[_-]?id[:=\s]*["\']?(\d+)', 'order_id'),
    (r'trade[_-]?id[:=\s]*["\']?(\d+)', 'trade_id'),
    (r'account[_-]?id[:=\s]*["\']?(\d+)', 'account_id'),
    (r'user[_-]?id[:=\s]*["\']?(\d+)', 'user_id'),
    (r'item[_-]?id[:=\s]*["\']?(\d+)', 'item_id'),
    (r'product[_-]?id[:=\s]*["\']?(\d+)', 'product_id'),
    (r'transaction[_-]?id[:=\s]*["\']?(\d+)', 'transaction_id'),
    (r'portfolio[_-]?id[:=\s]*["\']?(\d+)', 'portfolio_id'),
]

found_ids = {}
for pattern, name in patterns:
    matches = re.findall(pattern, text_content, re.IGNORECASE)
    if matches:
        found_ids[name] = matches

if found_ids:
    for name, values in found_ids.items():
        print(f"    {name}: {values}")
else:
    print("    No common ID patterns found")

# Search for any standalone 4-10 digit numbers that might be IDs
standalone_numbers = re.findall(r'[^\d](\d{4,10})[^\d]', text_content)
if standalone_numbers:
    print(f"\n    Standalone 4-10 digit numbers found: {standalone_numbers}")

# Meta tags
print("\n[12] META TAGS:")
meta_tags = soup.find_all('meta')
print(f"    Found {len(meta_tags)} meta tag(s)")
for meta in meta_tags:
    attrs = {k: v for k, v in meta.attrs.items()}
    print(f"    - {attrs}")

# Check for JSON data in page (common for SPAs)
print("\n[13] JSON DATA PATTERNS:")
json_pattern = re.search(r'<script[^>]*>\s*window\.__INITIAL_STATE__\s*=\s*({.*?})\s*</script>', text_content, re.DOTALL)
if json_pattern:
    print("    Found __INITIAL_STATE__ JSON data")
else:
    json_pattern2 = re.search(r'window\.__DATA__\s*=\s*({.*?});', text_content, re.DOTALL)
    if json_pattern2:
        print("    Found __DATA__ JSON data")
    else:
        print("    No typical JSON data patterns found")

# Summary
print(f"\n{'='*60}")
print("SUMMARY:")
print(f"{'='*60}")
print(f"Total forms: {len(forms)}")
print(f"Total inputs: {len(all_inputs)}")
print(f"Hidden inputs: {len(hidden_inputs)}")
print(f"Elements with ID: {len(elements_with_id)}")
print(f"Elements with name: {len(elements_with_name)}")
print(f"Data-* attributes: {len(data_elements)}")
print(f"Scripts: {len(scripts)}")
print(f"Links: {len(links)}")
print(f"External resources: {len(src_elements)}")
print(f"Comments: {len(comments)}")

# Check for specific trading-related keywords
print(f"\nTRADING-RELATED KEYWORDS SEARCH:")
trading_keywords = ['order', 'trade', 'portfolio', 'account', 'balance', 'stock', 'asset', 'position', 'transaction']
for keyword in trading_keywords:
    if keyword in text_content.lower():
        print(f"    Found '{keyword}' in page content")

