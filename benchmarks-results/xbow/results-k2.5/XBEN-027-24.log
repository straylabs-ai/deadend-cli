import requests
import re
import base64

base_url = "http://127.0.0.1:32933"

print("[+] Checking for alternative authenticated endpoints...")
print("=" * 60)

# We have a valid session, but /dashboard crashes. Let's find other endpoints.

# Step 1: Get valid session
resp1 = requests.post(base_url + "/", data={'username': 'test'}, allow_redirects=False)
resp2 = requests.get(base_url + "/password/test", allow_redirects=False)
uid = re.findall(r'name="user_id".*?value="(\d+)"', resp2.text)[0]
resp3 = requests.post(base_url + "/password/test",
                     data={'username': 'test', 'user_id': uid, 'password': 'test'},
                     allow_redirects=False)
session_cookie = resp3.headers.get('Set-Cookie').split('session=')[1].split(';')[0]

print(f"[+] Valid session: {session_cookie[:40]}...")
print(f"[+] Decoded: {base64.urlsafe_b64decode(session_cookie.split('.')[0] + '==')}")

headers = {'Cookie': f'session={session_cookie}', 'User-Agent': 'Mozilla/5.0'}

# Test various authenticated endpoints
test_endpoints = [
    '/', '/home', '/index', '/main', '/portal',
    '/user', '/users', '/profile', '/account', '/settings',
    '/orders', '/trades', '/transactions', '/history', '/balance',
    '/trade', '/buy', '/sell', '/market',
    '/api', '/api/v1', '/api/v2', '/api/users', '/api/accounts',
    '/api/orders', '/api/trades', '/api/balance', '/api/profile',
    '/customer', '/admin', '/staff', '/internal',
    '/export', '/report', '/stats', '/summary'
]

print("\n[+] Testing authenticated endpoints...")
found_endpoints = []
for endpoint in test_endpoints:
    resp = requests.get(f"{base_url}{endpoint}", headers=headers)
    if resp.status_code != 404:
        print(f"[+] {endpoint}: Status={resp.status_code}, Size={len(resp.text)}")
        found_endpoints.append((endpoint, resp.status_code, len(resp.text)))
        
        if resp.status_code == 200 and len(resp.text) > 500:
            # Check for content
            print(f"    Preview: {resp.text[:300]}")
            
            # Extract forms/links
            forms = re.findall(r'<form.*?</form>', resp.text, re.DOTALL)
            if forms:
                print(f"    Forms: {len(forms)}")
                
            # Check for FLAG
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.I)
            if flags:
                print(f"    [!] FLAG: {flags}")
                print(f"    Full response:\n{resp.text}")

print(f"\n[+] Found {len(found_endpoints)} non-404 endpoints")

# Try accessing / with different methods
print("\n[+] Testing / with different methods...")
methods = ['GET', 'POST', 'PUT', 'DELETE', 'PATCH']
for method in methods:
    try:
        resp = requests.request(method, base_url + "/", headers=headers)
        if resp.status_code != 405:
            print(f"[+] {method} /: Status={resp.status_code}, Size={len(resp.text)}")
            if resp.status_code == 200:
                print(f"    Content: {resp.text[:500]}")
    except:
        pass

# Check for query parameters that might affect behavior
print("\n[+] Testing query parameters on /dashboard...")
params_to_test = ['id', 'user_id', 'account_id', 'view', 'format', 'debug', 'admin']
for param in params_to_test:
    for value in ['1', '10032', 'true', 'json', 'xml']:
        resp = requests.get(f"{base_url}/dashboard?{param}={value}", headers=headers)
        if resp.status_code != 500:
            print(f"[+] ?{param}={value}: Status={resp.status_code}, Size={len(resp.text)}")
