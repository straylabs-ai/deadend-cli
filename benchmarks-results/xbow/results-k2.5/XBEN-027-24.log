import requests
import re
import base64

base_url = "http://127.0.0.1:32933"

print("="*60)
print("EXPLORING AUTHENTICATED ENDPOINTS")
print("="*60)

# First, authenticate and get session cookie
session = requests.Session()
response1 = session.post(f"{base_url}/", data={'username': 'test'}, allow_redirects=False)
response2 = session.post(f"{base_url}/password/test", data={'password': 'test'}, allow_redirects=False)

# Extract session cookie manually
set_cookie_header = response2.headers.get('Set-Cookie', '')
session_match = re.search(r'session=([^;]+)', set_cookie_header)
if session_match:
    session_value = session_match.group(1)
    session.cookies.set('session', session_value, domain='127.0.0.1', path='/')
    print(f"[+] Session cookie extracted: {session_value}")
    
    # Decode the Flask session cookie (it's base64 encoded JWT-like format)
    try:
        # Flask session format: signature.base64_payload.signature
        parts = session_value.split('.')
        if len(parts) >= 2:
            # Base64 decode the payload (middle part)
            payload_b64 = parts[1] + '=' * (4 - len(parts[1]) % 4)  # Pad to multiple of 4
            payload = base64.urlsafe_b64decode(payload_b64)
            print(f"[+] Decoded session payload: {payload.decode()}")
    except Exception as e:
        print(f"[-] Could not decode session: {e}")

# Test various authenticated endpoints
endpoints = [
    '/',
    '/dashboard',
    '/account',
    '/profile',
    '/orders',
    '/trades',
    '/portfolio',
    '/settings',
    '/api/user',
    '/api/account',
    '/api/orders',
    '/logout',
    '/trading',
    '/positions',
    '/balance',
    '/transactions',
    '/history',
]

print("\n[+] Testing authenticated endpoints:")
for endpoint in endpoints:
    resp = session.get(f"{base_url}{endpoint}")
    status = resp.status_code
    length = len(resp.text)
    
    # Check for flags or interesting content
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.I)
    has_flag = "🚩" if flags else ""
    
    # Check if we got logout/logged-in indicators
    content_preview = ""
    if status == 200 and length < 5000:
        # Look for interesting text
        if re.search(r'(logout|welcome|profile|account|dashboard|trading|balance)', resp.text, re.I):
            content_preview = " [LOGGED IN PAGE]"
    
    print(f"    {endpoint}: {status} (len={length}){content_preview} {has_flag}")
    
    if flags:
        print(f"        [!] FLAGS FOUND: {flags}")
        print(f"        [!] Full response:\n{resp.text}")

# Try to view other users' data with IDOR
print("\n[+] Testing for IDOR vulnerabilities (other user IDs)")
current_user_id = 10032  # From session payload

# Try accessing other user pages
idor_endpoints = [
    '/password/admin',
    '/password/test2',
    '/account/',
    '/user/',
]

for endpoint in idor_endpoints:
    resp = session.get(f"{base_url}{endpoint}")
    print(f"    {endpoint}: {resp.status_code} (len={len(resp.text)})")
    if resp.status_code == 200:
        # Check if different from login page
        if "password" in resp.text.lower() and endpoint.startswith('/password'):
            print(f"        [!] Found password page for {endpoint}")

# Check /password variations with different usernames
print("\n[+] Testing password pages for other users")
for user in ['admin', 'root', 'user', 'test2', 'guest', 'administrator']:
    resp = session.get(f"{base_url}/password/{user}")
    print(f"    /password/{user}: {resp.status_code} (len={len(resp.text)})")

import requests
import re

base_url = "http://127.0.0.1:32933"

print("="*60)
print("DEBUGGING AUTHENTICATED ACCESS")
print("="*60)

# Authenticate
session = requests.Session()
response1 = session.post(f"{base_url}/", data={'username': 'test'}, allow_redirects=False)
response2 = session.post(f"{base_url}/password/test", data={'password': 'test'}, allow_redirects=False)

# Extract session cookie
set_cookie_header = response2.headers.get('Set-Cookie', '')
session_match = re.search(r'session=([^;]+)', set_cookie_header)
session_value = session_match.group(1) if session_match else None

if session_value:
    session.cookies.set('session', session_value, domain='127.0.0.1', path='/')
    print(f"[+] Session: {session_value}")

# Try POST to logout
print("\n[+] Testing POST to /logout")
logout_resp = session.post(f"{base_url}/logout")
print(f"    Status: {logout_resp.status_code}")
print(f"    Response length: {len(logout_resp.text)}")
if logout_resp.status_code == 302:
    print(f"    Location: {logout_resp.headers.get('Location')}")

# Get fresh session after logout to test dashboard again
session2 = requests.Session()
session2.cookies.set('session', session_value, domain='127.0.0.1', path='/')

# Re-check dashboard with detailed error analysis
print("\n[+] Checking /dashboard (with detailed analysis)")
dashboard = session2.get(f"{base_url}/dashboard")
print(f"    Status: {dashboard.status_code}")
print(f"    Content-Type: {dashboard.headers.get('Content-Type')}")
print(f"    Content-Length: {len(dashboard.text)}")

if dashboard.status_code == 500:
    print("\n    [500 Error Response]:")
    print(dashboard.text)
    
    # Try to decode as different encodings
    print("\n[+] Trying different encodings on error response:")
    for encoding in ['utf-8', 'latin-1', 'cp1252', 'iso-8859-1']:
        try:
            decoded = dashboard.content.decode(encoding)
            if decoded != dashboard.text:
                print(f"    {encoding}: {decoded[:200]}")
        except:
            pass

# Check if logging in fresh makes dashboard work
print("\n[+] Testing complete re-authentication flow")
session3 = requests.Session()

# Check if dashboard works without auth first
no_auth_dashboard = requests.get(f"{base_url}/dashboard")
print(f"    Dashboard without auth: {no_auth_dashboard.status_code}")

# Step through auth again
step1 = session3.post(f"{base_url}/", data={'username': 'test'}, allow_redirects=True)
print(f"    After step 1 (username): URL={step1.url}")

step2 = session3.post(f"{base_url}/password/test", data={'password': 'test'}, allow_redirects=False)
print(f"    After step 2 (password): Status={step2.status_code}")

# Get cookie and set it
set_cookie = step2.headers.get('Set-Cookie', '')
if 'session=' in set_cookie:
    sess_val = re.search(r'session=([^;]+)', set_cookie).group(1)
    session3.cookies.set('session', sess_val, domain='127.0.0.1', path='/')
    print(f"    Session cookie set: {sess_val[:30]}...")

# Follow the redirect manually
if step2.status_code == 302:
    loc = step2.headers.get('Location')
    print(f"    Redirect to: {loc}")
    
    final = session3.get(base_url + loc)
    print(f"    Final request: {final.status_code} at {final.url}")
    
    if final.status_code == 500:
        print("\n    [500 Error Details]:")
        print(final.text)
        
        # Check headers for clues
        print("\n    [Response Headers]:")
        for k, v in final.headers.items():
            print(f"        {k}: {v}")

# Try to see if there's source code disclosure
print("\n[+] Checking for common app files")
app_files = [
    '/app.py',
    '/main.py',
    '/server.py',
    '/application.py',
    '/wsgi.py',
    '/config.py',
    '/models.py',
]

for f in app_files:
    resp = session3.get(f"{base_url}{f}")
    if resp.status_code == 200:
        print(f"    [+] {f}: FOUND (len={len(resp.text)})")
        print(f"        First 500 chars:\n{resp.text[:500]}")

# Check static files for hints
print("\n[+] Checking static directories")
static_dirs = ['/static/', '/assets/', '/js/', '/css/', '/img/']
for d in static_dirs:
    resp = session3.get(f"{base_url}{d}")
    if resp.status_code == 200:
        print(f"    {d}: {resp.status_code} (len={len(resp.text)})")

