import requests
import re
from urllib.parse import urljoin, urlparse

# Base URL - adjust if needed
base_url = "http://127.0.0.1:5000"

# Create session to maintain cookies
session = requests.Session()

discovered_endpoints = set()
id_parameters = []
cookie_info = {}

print("=" * 60)
print("AUTHENTICATION RECONNAISSANCE SCRIPT")
print("=" * 60)

# Step 1: Initial POST to / with username=test
print("\n[Step 1] POST to / with username=test")
try:
    resp1 = session.post(
        base_url + "/",
        data={"username": "test"},
        allow_redirects=True
    )
    print(f"  Status: {resp1.status_code}")
    print(f"  URL after request: {resp1.url}")
    print(f"  Cookies after step 1: {dict(session.cookies)}")
    
    # Check for forms or ID parameters in response
    forms = re.findall(r'<form[^>]*action="([^"]*)"[^>]*>', resp1.text, re.I)
    inputs = re.findall(r'<input[^>]*name="([^"]*)"[^>]*>', resp1.text, re.I)
    print(f"  Forms found: {forms}")
    print(f"  Input fields: {inputs}")
    
    # Extract links
    links = re.findall(r'href="([^"]+)"', resp1.text)
    for link in links:
        if not link.startswith(('http://', 'https://', 'javascript:', 'mailto:')):
            discovered_endpoints.add(link.lstrip('/'))
except Exception as e:
    print(f"  Error: {e}")

# Step 2: POST to /password/test with password=test
print("\n[Step 2] POST to /password/test with password=test")
try:
    resp2 = session.post(
        base_url + "/password/test",
        data={"password": "test"},
        allow_redirects=True
    )
    print(f"  Status: {resp2.status_code}")
    print(f"  URL after request: {resp2.url}")
    print(f"  Final URL: {resp2.url}")
    
    # Capture cookies
    cookie_info = dict(session.cookies)
    print(f"  Session cookies captured: {cookie_info}")
    
    # Check response content
    print(f"  Response length: {len(resp2.text)} bytes")
    
    # Look for forms and inputs
    forms = re.findall(r'<form[^>]*action="([^"]*)"[^>]*>', resp2.text, re.I)
    inputs = re.findall(r'<input[^>]*name="([^"]*)"[^>]*>', resp2.text, re.I)
    print(f"  Forms found: {forms}")
    print(f"  Input fields: {inputs}")
    
    # Extract all links
    links = re.findall(r'href="([^"]+)"', resp2.text)
    for link in links:
        if not link.startswith(('http://', 'https://', 'javascript:', 'mailto:', '#')):
            clean_link = link.lstrip('/').split('?')[0]
            if clean_link:
                discovered_endpoints.add(clean_link)
    
    # Look for potential ID patterns in JSON (if any)
    json_ids = re.findall(r'"(id|user_id|order_id|trade_id|account_id)"\s*:\s*(\d+)', resp2.text)
    if json_ids:
        print(f"  JSON IDs found: {json_ids}")
except Exception as e:
    print(f"  Error: {e}")

# Step 3: Explore common endpoints
print("\n[Step 3] Testing common endpoints with authenticated session")

test_endpoints = [
    "/",
    "/orders",
    "/trades", 
    "/account",
    "/profile",
    "/users",
    "/user",
    "/dashboard",
    "/home",
    "/portfolio",
    "/balance",
    "/transactions",
    "/history",
    "/settings",
    "/api/orders",
    "/api/trades",
    "/api/account",
    "/api/user"
]

authenticated_endpoints = {}

for endpoint in test_endpoints:
    try:
        resp = session.get(base_url + endpoint, timeout=5)
        print(f"\n  GET {endpoint}:")
        print(f"    Status: {resp.status_code}")
        print(f"    Length: {len(resp.text)} bytes")
        
        # Store successful (non-404) endpoints
        if resp.status_code != 404:
            authenticated_endpoints[endpoint] = {
                'status': resp.status_code,
                'length': len(resp.text)
            }
            
            # Look for ID patterns in URL parameters
            url_params = re.findall(r'[?&](\w+_?id)=(\d+)', resp.url)
            for param, val in url_params:
                id_parameters.append({'endpoint': endpoint, 'param': param, 'value': val})
            
            # Look for ID patterns in forms
            form_inputs = re.findall(r'<input[^>]*name="([^"]*id[^"]*)"[^>]*>', resp.text, re.I)
            if form_inputs:
                print(f"    ID inputs found: {form_inputs}")
                for inp in form_inputs:
                    id_parameters.append({'endpoint': endpoint, 'input_name': inp})
            
            # Look for links to other pages
            links = re.findall(r'href="([^"]+)"', resp.text)
            for link in links:
                if not link.startswith(('http://', 'https://', 'javascript:', 'mailto:', '#')):
                    clean_link = link.lstrip('/').split('?')[0]
                    if clean_link and clean_link not in test_endpoints:
                        discovered_endpoints.add(clean_link)
            
            # Look for ID patterns in page content
            content_ids = re.findall(r'(?:id|ID|Id)[:=\s"\']+(\d+)', resp.text)
            if content_ids:
                print(f"    IDs in content: {content_ids[:5]}...")  # Show first 5
                
    except Exception as e:
        print(f"\n  GET {endpoint}: Error - {e}")

# Step 4: Check for any discovered endpoints from link crawling
print("\n[Step 4] Testing discovered endpoints from link crawling")
discovered_list = list(discovered_endpoints)
print(f"  Discovered from links: {discovered_list}")

for endpoint in discovered_list:
    if endpoint not in test_endpoints:
        try:
            resp = session.get(base_url + "/" + endpoint, timeout=5)
            if resp.status_code == 200:
                authenticated_endpoints["/" + endpoint] = {
                    'status': resp.status_code,
                    'length': len(resp.text)
                }
                print(f"  /{endpoint}: {resp.status_code} ({len(resp.text)} bytes)")
        except:
            pass

# Summary
print("\n" + "=" * 60)
print("SUMMARY")
print("=" * 60)

print(f"\n[Session Cookies]")
print(f"  {cookie_info}")

print(f"\n[Accessible Endpoints (Status != 404)]")
for ep, info in authenticated_endpoints.items():
    print(f"  {ep}: Status {info['status']}, Length {info['length']} bytes")

print(f"\n[ID Parameters Found]")
if id_parameters:
    for param in id_parameters:
        print(f"  {param}")
else:
    print("  None found")

print(f"\n[Discovered Endpoints from Links]")
