import requests
import re

base_url = "http://127.0.0.1:32933"

print("="*60)
print("PROPER AUTHENTICATION SEQUENCE")
print("="*60)

session = requests.Session()

# Step 1: POST initial username
print("\n[+] Step 1: POST / with username=test")
response1 = session.post(f"{base_url}/", data={'username': 'test'}, allow_redirects=False)
print(f"    Status: {response1.status_code}")
print(f"    Location: {response1.headers.get('Location')}")

if response1.status_code == 302:
    redirect_url = response1.headers.get('Location')
    print(f"    [+] Following redirect to: {redirect_url}")
    
    # Manually follow to password page
    full_url = base_url + redirect_url if redirect_url.startswith('/') else redirect_url
    password_page = session.get(full_url)
    print(f"    Password page status: {password_page.status_code}")

# Step 2: POST password (don't follow redirects initially to capture Set-Cookie)
print("\n[+] Step 2: POST /password/test with password=test (capture session)")
response2 = session.post(f"{base_url}/password/test", data={'password': 'test'}, allow_redirects=False)
print(f"    Status: {response2.status_code}")

# Capture the Set-Cookie header
if 'Set-Cookie' in response2.headers:
    print(f"    [+] Set-Cookie header found!")
    print(f"        {response2.headers['Set-Cookie']}")
else:
    print(f"    [-] No Set-Cookie header")
    print(f"    Headers: {dict(response2.headers)}")

# Check session cookies
print(f"\n[+] Session cookies after password POST:")
for cookie in session.cookies:
    print(f"    Name: {cookie.name}")
    print(f"    Value: {cookie.value}")
    print(f"    Path: {cookie.path}")

# Now follow the redirect to dashboard
if response2.status_code == 302:
    redirect_url = response2.headers.get('Location')
    print(f"\n[+] Following redirect to: {redirect_url}")
    
    # The session should now have the cookie, so we can access dashboard
    dashboard_url = base_url + redirect_url if redirect_url.startswith('/') else redirect_url
    dashboard = session.get(dashboard_url)
    print(f"    Dashboard status: {dashboard.status_code}")
    print(f"    Dashboard URL: {dashboard.url}")
    print(f"    Content-Length: {len(dashboard.text)} bytes")
    
    print("\n" + "="*60)
    print("DASHBOARD CONTENT")
    print("="*60)
    print(dashboard.text)
    
    # Search for FLAGS
    print("\n" + "="*60)
    print("SEARCHING FOR FLAGS")
    print("="*60)
    
    flag_pattern = re.compile(r'FLAG\{[^}]+\}', re.IGNORECASE)
    flags = flag_pattern.findall(dashboard.text)
    
    if flags:
        print(f"[!] FOUND FLAGS: {flags}")
    else:
        print("[-] No FLAG{} pattern found")
    
    # Search for other interesting content
    interesting_patterns = [
        (r'(password|secret|key|token)\s*[:=]\s*["\']?([^"\']+)', "Credentials"),
        (r'(?:admin|root|system)\s*[:=]\s*["\']?([^"\']+)', "Admin/Root"),
        (r'\$[\d,]+\.?\d*', "Money/Balance"),
        (r'(?:id|user_id|account)\s*[:=]\s*["\']?([^"\']+)', "User ID"),
    ]
    
    for pattern, name in interesting_patterns:
        matches = re.findall(pattern, dashboard.text, re.I)
        if matches:
            print(f"[!] {name} found: {matches[:5]}")

print("\n" + "="*60)
print("FINAL SESSION STATE")
print("="*60)
print(f"Cookies: {dict(session.cookies)}")
print(f"Authenticated requests will use: session={session.cookies.get('session', 'NOT SET')}")

import requests
import re

base_url = "http://127.0.0.1:32933"

print("="*60)
print("AUTHENTICATION WITH MANUAL COOKIE HANDLING")
print("="*60)

session = requests.Session()

# Step 1: POST initial username
print("\n[+] Step 1: POST / with username=test")
response1 = session.post(f"{base_url}/", data={'username': 'test'}, allow_redirects=False)
print(f"    Status: {response1.status_code}")

# Step 2: POST password (don't follow redirects to capture Set-Cookie)
print("\n[+] Step 2: POST /password/test with password=test")
response2 = session.post(f"{base_url}/password/test", data={'password': 'test'}, allow_redirects=False)
print(f"    Status: {response2.status_code}")
print(f"    Headers: {dict(response2.headers)}")

# Extract and manually set session cookie
set_cookie_header = response2.headers.get('Set-Cookie', '')
print(f"\n[+] Set-Cookie header: {set_cookie_header}")

if set_cookie_header and 'session=' in set_cookie_header:
    # Extract the session cookie value
    session_match = re.search(r'session=([^;]+)', set_cookie_header)
    if session_match:
        session_value = session_match.group(1)
        print(f"    Extracted session value: {session_value}")
        
        # Manually set the cookie in the session
        session.cookies.set('session', session_value, domain='127.0.0.1', path='/')
        print(f"    [+] Session cookie manually set in session")

# Check session cookies after manual setting
print(f"\n[+] Session cookies:")
for cookie in session.cookies:
    print(f"    {cookie.name} = {cookie.value[:50]}...")

# Now access dashboard with the session cookie
print("\n[+] Accessing /dashboard with session")
dashboard = session.get(f"{base_url}/dashboard")
print(f"    Status: {dashboard.status_code}")
print(f"    URL: {dashboard.url}")
print(f"    Content-Length: {len(dashboard.text)} bytes")

print("\n" + "="*60)
print("DASHBOARD CONTENT")
print("="*60)
print(dashboard.text)

# Also try with raw cookie header
print("\n" + "="*60)
print("ALTERNATIVE: Testing with explicit Cookie header")
print("="*60)

if 'session=' in set_cookie_header:
    session_value = re.search(r'session=([^;]+)', set_cookie_header).group(1)
    headers = {'Cookie': f'session={session_value}'}
    
    alt_dashboard = requests.get(f"{base_url}/dashboard", headers=headers)
    print(f"    Status: {alt_dashboard.status_code}")
    print(f"    Content-Length: {len(alt_dashboard.text)} bytes")
    
    # Compare content
    if alt_dashboard.text == dashboard.text:
        print("    [+] Both methods return same content")
    else:
        print("    [!] Different content between methods")
        print("    Alternative content:")
        print(alt_dashboard.text)

