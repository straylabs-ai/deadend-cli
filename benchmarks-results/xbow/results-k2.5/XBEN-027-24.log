import requests
import re

base_url = "http://127.0.0.1:32933"

# Get authenticated session
session = requests.Session()
session.post(f"{base_url}/", data={'username': 'test'}, allow_redirects=False)
resp = session.post(f"{base_url}/password/test", data={'password': 'test'}, allow_redirects=False)
set_cookie = resp.headers.get('Set-Cookie', '')
sess_match = re.search(r'session=([^;]+)', set_cookie)
if sess_match:
    session.cookies.set('session', sess_match.group(1), domain='127.0.0.1', path='/')

print("="*60)
print("DEEP CONTENT ANALYSIS")
print("="*60)

# Get all accessible content and analyze deeply
accessible_pages = [
    ('/', 'root'),
    ('/password/test', 'password page'),
    ('/logout', 'logout'),
]

all_text = ""
for endpoint, name in accessible_pages:
    if name == 'logout':
        resp = session.post(f"{base_url}{endpoint}")
    else:
        resp = session.get(f"{base_url}{endpoint}")
    all_text += resp.text + "\n"
    print(f"\n[+] {name} ({endpoint}):")
    print(f"    Status: {resp.status_code}")
    
    # Extract all comments
    comments = re.findall(r'<!--(.*?)-->', resp.text, re.DOTALL)
    if comments:
        print(f"    [+] HTML Comments found:")
        for c in comments:
            c = c.strip()
            if c:
                print(f"        - {c[:200]}")
    
    # Extract hidden form fields
    hidden_fields = re.findall(r'<input[^>]*type=["\']hidden["\'][^>]*>', resp.text, re.I)
    if hidden_fields:
        print(f"    [+] Hidden fields: {hidden_fields}")
    
    # Extract scripts
    scripts = re.findall(r'<script[^>]*>(.*?)</script>', resp.text, re.DOTALL | re.I)
    if scripts:
        print(f"    [+] Scripts found: {len(scripts)}")
        for i, s in enumerate(scripts):
            if s.strip() and len(s.strip()) > 10:
                print(f"        Script {i}: {s[:100]}...")
    
    # Check all attributes for data-*
    data_attrs = re.findall(r'data-[a-z-]+=["\'][^"\']+["\']', resp.text, re.I)
    if data_attrs:
        print(f"    [+] Data attributes: {data_attrs[:5]}")
    
    # Check for inline JS with sensitive data
    js_vars = re.findall(r'var\s+\w+\s*=\s*["\'][^"\']+["\']', resp.text)
    if js_vars:
        print(f"    [+] JS variables: {js_vars[:5]}")
    
    # Search for FLAG anywhere
    flags = re.findall(r'FLAG\{[^}]*\}', resp.text, re.I)
    if flags:
        print(f"    [!!!] FLAGS FOUND: {flags}")

# Check headers for all pages
print("\n" + "="*60)
print("RESPONSE HEADERS ANALYSIS")
print("="*60)

for endpoint, name in accessible_pages:
    if name == 'logout':
        resp = session.post(f"{base_url}{endpoint}")
    else:
        resp = session.get(f"{base_url}{endpoint}")
    print(f"\n[+] {name} headers:")
    for k, v in resp.headers.items():
        # Check for flags in headers
        flags_in_header = re.findall(r'FLAG\{[^}]*\}', v, re.I)
        if flags_in_header:
            print(f"    [!!!] FLAG IN HEADER {k}: {v}")
        else:
            print(f"    {k}: {v[:100]}")

# Search all combined text for patterns
print("\n" + "="*60)
print("PATTERN SEARCH IN ALL CONTENT")
print("="*60)

patterns = [
    (r'FLAG\{[^}]*\}', 'FLAG{}'),
    (r'[a-zA-Z0-9]{20,}', 'Long strings'),
    (r'(password|secret|key|token|api)\s*[:=]\s*["\']?([^\s"\']+)', 'Secrets'),
    (r'base64[A-Za-z0-9+/]{20,}={0,2}', 'Base64 data'),
    (r'eyJ[A-Za-z0-9_-]*\.eyJ[A-Za-z0-9_-]*\.[A-Za-z0-9_-]*', 'JWT tokens'),
    (r'[0-9a-f]{32}', 'MD5 hashes'),
    (r'[0-9a-f]{40}', 'SHA1 hashes'),
    (r'\$[0-9a-zA-Z./]{10,}', 'Hash/salt'),
]

for pattern, name in patterns:
    matches = re.findall(pattern, all_text, re.I)
    if matches:
        unique = list(set(matches))
        print(f"\n[+] {name}: {len(unique)} unique matches")
        for m in unique[:5]:
            print(f"    - {m}")

