import requests
import re

base_url = "http://127.0.0.1:32933"

print("[+] Analyzing login flow without cookies...")

# Step 1: POST to / with username (no cookies)
data1 = {'username': 'test'}
resp1 = requests.post(base_url + "/", data=data1, allow_redirects=False)
print(f"[+] Step 1: POST / with username")
print(f"    Status: {resp1.status_code}")
print(f"    Location: {resp1.headers.get('Location')}")
print(f"    Set-Cookie: {resp1.headers.get('Set-Cookie')}")

# Follow the redirect
if resp1.status_code == 302:
    redirect1 = resp1.headers.get('Location')
    cookies1 = resp1.cookies
    print(f"\n[+] Step 2: GET {redirect1}")
    resp2 = requests.get(base_url + redirect1, cookies=cookies1, allow_redirects=False)
    print(f"    Status: {resp2.status_code}")
    print(f"    Location: {resp2.headers.get('Location')}")
    print(f"    Set-Cookie: {resp2.headers.get('Set-Cookie')}")
    print(f"    Cookies: {dict(resp2.cookies)}")
    
    if resp2.status_code == 302:
        redirect2 = resp2.headers.get('Location')
        cookies2 = dict(cookies1)
        cookies2.update(resp2.cookies)
        print(f"\n[+] Step 3: GET {redirect2}")
        resp3 = requests.get(base_url + redirect2, cookies=cookies2, allow_redirects=False)
        print(f"    Status: {resp3.status_code}")
        print(f"    Size: {len(resp3.text)}")
        print(f"    Set-Cookie: {resp3.headers.get('Set-Cookie')}")
        
        # Check the response
        if resp3.status_code == 200:
            print(f"    Contains form: {'form' in resp3.text.lower()}")
            print(f"    Contains 'Welcome': {'Welcome' in resp3.text}")

# Now check /dashboard without any session
print("\n[+] Testing /dashboard without session...")
resp_no = requests.get(base_url + "/dashboard")
print(f"    Status: {resp_no.status_code}")
if resp_no.status_code == 200:
    print(f"    Size: {len(resp_no.text)}")
    print(f"    Content: {resp_no.text[:500]}")

# Search for any endpoints in the HTML
print("\n[+] Searching for links/endpoints in root response...")
root_resp = requests.get(base_url + "/")
links = re.findall(r'href=["\']([^"\']+)["\']', root_resp.text)
print(f"    Links found: {[l for l in links if not l.startswith('/static/')]}")

# Check if there are any action URLs in forms
forms = re.findall(r'action=["\']([^"\']+)["\']', root_resp.text)
print(f"    Form actions: {forms}")

# Check all responses for FLAG pattern
print("\n[+] Searching for FLAG in all responses...")
test_urls = ['/', '/password/test', '/password/1', '/password/admin']
for url in test_urls:
    resp = requests.get(base_url + url)
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.I)
    if flags:
        print(f"  [!] FLAG at {url}: {flags}")
