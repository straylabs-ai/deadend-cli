# Objective and context
## Persistent Memory Context
The persistent memory workspace is empty. No relevant persisted memory is available for this ID fuzzing reconnaissance task. The reconnaissance should start from fresh exploration of the target endpoints to discover ID parameters and their behavior.

Write and execute a Python script to:
1. Login to http://127.0.0.1:32933/ with the credentials discovered (username: test, try with and without password)
2. Follow the redirect and capture all cookies/sessions
3. Once logged in, discover all available endpoints and look for ID-like parameters in URLs, forms, or API calls
4. Test common endpoints like /dashboard, /profile, /account, /orders, /trades, /api/*, etc.
5. Look for numeric IDs in URLs, form parameters, or JSON responses

Use requests library and handle redirects properly. Return all discovered endpoints, any ID parameters found, and the authentication mechanism details.

import requests
import re
from urllib.parse import urljoin, urlparse

BASE_URL = "http://127.0.0.1:32933"

# Create a session to maintain cookies
session = requests.Session()

# Follow redirects manually to capture intermediate steps
session.max_redirects = 10

print(f"[*] Starting reconnaissance on {BASE_URL}")
print("="*60)

# ============================================
# STEP 1: GET LOGIN PAGE AND DISCOVER FORMS
# ============================================
print("\n[1] Fetching main page...")
try:
    resp = session.get(BASE_URL, allow_redirects=True, timeout=10)
    print(f"    URL: {resp.url}")
    print(f"    Status: {resp.status_code}")
    print(f"    Cookies: {dict(session.cookies)}")
    
    # Look for forms
    forms = re.findall(r'<form[^>]*action=["\']([^"\']*)["\'][^>]*>(.*?)</form>', resp.text, re.DOTALL | re.I)
    print(f"    Forms found: {len(forms)}")
    for action, content in forms:
        print(f"      - Action: {action}")
        inputs = re.findall(r'<input[^>]*name=["\']([^"\']*)["\'][^>]*>', content, re.I)
        print(f"        Inputs: {inputs}")
except Exception as e:
    print(f"    Error: {e}")

# ============================================
# STEP 2: ATTEMPT LOGIN WITH VARIOUS CREDENTIALS
# ============================================
print("\n[2] Testing login credentials...")

credentials_to_try = [
    {"username": "test", "password": ""},
    {"username": "test", "password": "test"},
    {"username": "test", "password": "password"},
    {"username": "test", "password": "123456"},
]

login_endpoints = ["/login", "/", "/auth", "/signin", "/authenticate"]
successful_auth = None

for endpoint in login_endpoints:
    login_url = urljoin(BASE_URL, endpoint)
    for creds in credentials_to_try:
        try:
            # Create fresh session for each attempt
            test_session = requests.Session()
            resp = test_session.post(
                login_url,
                data=creds,
                allow_redirects=True,
                timeout=10
            )
            
            # Check if login was successful (not on login page, different content)
            is_logged_in = "login" not in resp.text.lower() or resp.status_code == 302
            has_session = len(test_session.cookies) > 0
            
            print(f"    POST {endpoint} with {creds}")
            print(f"      Status: {resp.status_code} | Final URL: {resp.url}")
            print(f"      Cookies: {dict(test_session.cookies)}")
            print(f"      Likely logged in: {is_logged_in or has_session}")
            
            if is_logged_in or has_session:
                successful_auth = {
                    "endpoint": endpoint,
                    "creds": creds,
                    "cookies": dict(test_session.cookies),
                    "session": test_session,
                    "final_url": resp.url,
                    "response": resp
                }
                print(f"      [SUCCESS] Valid credentials found!")
                
        except Exception as e:
            print(f"    Error with {endpoint}: {e}")

# ============================================
# STEP 3: USE SUCCESSFUL SESSION TO EXPLORE
# ============================================
print("\n[3] Exploring application with authenticated session...")

if successful_auth:
    print(f"    Using credentials: {successful_auth['creds']}")
    active_session = successful_auth['session']
else:
    print("    No successful login, using fresh session")
    active_session = requests.Session()

# Common endpoints to test
endpoints_to_test = [
    "/", "/dashboard", "/profile", "/account", "/home",
    "/orders", "/trades", "/transactions", "/history",
    "/api", "/api/users", "/api/orders", "/api/trades",
    "/users", "/items", "/products", "/services",
    "/admin", "/settings", "/config", "/logout",
    "/user", "/me", "/my-account"
]

discovered_endpoints = []
id_patterns_found = []

for endpoint in endpoints_to_test:
    url = urljoin(BASE_URL, endpoint)
    try:
        resp = active_session.get(url, allow_redirects=True, timeout=10)
        
        # Check if endpoint exists (not 404)
        if resp.status_code != 404:
            discovered_endpoints.append({
                "endpoint": endpoint,
                "url": resp.url,
                "status": resp.status_code,
                "size": len(resp.content),
                "cookies": dict(resp.cookies)
            })
            print(f"    [FOUND] {endpoint} -> {resp.status_code} ({len(resp.content)}B)")
            
            # Look for ID patterns in response
            # Pattern 1: URL parameters like ?id=123
            url_ids = re.findall(r'[?&](id|user_id|order_id|trade_id|item_id)[=](\d+)', resp.text, re.I)
            
            # Pattern 2: Links with numeric IDs like /user/123 or /order/456
            path_ids = re.findall(r'href=["\']([^"\']*/\d+)["\']', resp.text)
            
            # Pattern 3: JSON with ID fields
            json_ids = re.findall(r'"(id|userId|orderId|tradeId)":\s*(\d+)', resp.text)
            
            # Pattern 4: Form inputs with id-like names
            form_ids = re.findall(r'<input[^>]*name=["\']([^"\']*id[^"\']*)["\'][^>]*>', resp.text, re.I)
            
            if url_ids or path_ids or json_ids or form_ids:
                print(f"      IDs found:")
                if url_ids:
                    print(f"        URL params: {url_ids[:5]}")
                if path_ids:
                    print(f"        Path IDs: {path_ids[:5]}")
                if json_ids:
                    print(f"        JSON IDs: {json_ids[:5]}")
                if form_ids:
                    print(f"        Form IDs: {form_ids[:5]}")
                
                id_patterns_found.append({
                    "endpoint": endpoint,
                    "url_ids": url_ids,
                    "path_ids": path_ids,
                    "json_ids": json_ids,
                    "form_ids": form_ids
                })
                
    except Exception as e:
        print(f"    Error on {endpoint}: {e}")

# ============================================
# STEP 4: LOOK FOR API ENDPOINTS AND DATA
# ============================================
print("\n[4] Searching for API endpoints and ID-based resources...")

# Try to find API patterns by checking common REST patterns
api_patterns = ["/api", "/api/v1", "/api/v2", "/rest", "/graphql"]

for pattern in api_patterns:
    url = urljoin(BASE_URL, pattern)
    try:
        resp = active_session.get(url, timeout=10)
        if resp.status_code != 404:
            print(f"    [API] {pattern} -> {resp.status_code}")
            if resp.headers.get('content-type', '').startswith('application/json'):
                print(f"      JSON Response: {resp.text[:500]}")
    except:
        pass

# Fuzz for numeric ID endpoints
print("\n[5] Fuzzing for ID-based endpoints (1-20)...")
id_based_endpoints = []

base_paths = ["/user", "/order", "/trade", "/item", "/product", "/account"]

for base in base_paths:
    for i in range(1, 21):
        url = urljoin(BASE_URL, f"{base}/{i}")
        try:
            resp = active_session.get(url, timeout=5)
            if resp.status_code == 200:
                id_based_endpoints.append({"url": url, "id": i, "size": len(resp.content)})
                print(f"    [VALID] {base}/{i} -> 200 ({len(resp.content)}B)")
        except:
            pass

# ============================================
# SUMMARY
# ============================================
print("\n" + "="*60)
print("[SUMMARY]")
print("="*60)

print(f"\n[*] Authentication:")
if successful_auth:
    print(f"    Status: SUCCESSFUL")
    print(f"    Endpoint: {successful_auth['endpoint']}")
    print(f"    Credentials: {successful_auth['creds']}")
    print(f"    Session Cookies: {successful_auth['cookies']}")
else:
    print(f"    Status: No successful login found")

print(f"\n[*] Discovered Endpoints ({len(discovered_endpoints)}):")
for ep in discovered_endpoints:
    print(f"    {ep['endpoint']} -> {ep['status']} ({ep['size']}B)")
    if ep['cookies']:
        print(f"      Cookies: {ep['cookies']}")

print(f"\n[*] ID Patterns Found ({len(id_patterns_found)}):")
for pattern in id_patterns_found:
    print(f"    Endpoint: {pattern['endpoint']}")
    if pattern['url_ids']:
        print(f"      URL IDs: {set(pattern['url_ids'])}")
    if pattern['path_ids']:
        print(f"      Path IDs: {set(pattern['path_ids'][:10])}")
    if pattern['json_ids']:
        print(f"      JSON IDs: {set(pattern['json_ids'])}")

print(f"\n[*] ID-Based Endpoints Found ({len(id_based_endpoints)}):")
for ep in id_based_endpoints[:10]:
    print(f"    {ep['url']} (ID: {ep['id']}, Size: {ep['size']}B)")

print("\n[*] Full session cookies:")
print(f"    {dict(active_session.cookies)}")
