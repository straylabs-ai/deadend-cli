import requests
import re

target_url = "http://127.0.0.1:32933"

print("[*] Extended fuzzing and content analysis")
print("-" * 60)

# First, let's examine what makes /password/test different
print("\n[1] Analyzing /password/test (known valid account)")
resp_test = requests.get(f"{target_url}/password/test", timeout=10)
print(f"    Status: {resp_test.status_code}")
print(f"    Size: {len(resp_test.content)} bytes")

# Look for patterns in the response
if 'name="username"' in resp_test.text:
    username_match = re.search(r'name=["\']username["\'][^>]*value=["\']([^"\']+)["\']', resp_test.text, re.I)
    if username_match:
        print(f"    Username field value: {username_match.group(1)}")
    else:
        username_match = re.search(r'value=["\']([^"\']+)["\'][^>]*name=["\']username["\']', resp_test.text, re.I)
        if username_match:
            print(f"    Username field value: {username_match.group(1)}")

# Check for hidden fields
hidden_fields = re.findall(r'<input[^>]*type=["\']hidden["\'][^>]*>', resp_test.text, re.I)
print(f"    Hidden fields count: {len(hidden_fields)}")

# Compare with a numeric ID (e.g., ID 1)
print("\n[2] Analyzing /password/1 (typical response)")
resp_1 = requests.get(f"{target_url}/password/1", timeout=10)
print(f"    Status: {resp_1.status_code}")
print(f"    Size: {len(resp_1.content)} bytes")

# Try higher numeric IDs - sometimes user accounts start at higher numbers
print("\n[3] Testing higher numeric IDs (201-500)")
anomalies = []
for user_id in range(201, 501):
    try:
        url = f"{target_url}/password/{user_id}"
        response = requests.get(url, timeout=5)
        content_length = len(response.content)
        
        if content_length != 1287:
            anomalies.append({'id': user_id, 'size': content_length})
            print(f"    [ANOMALY] ID {user_id}: {content_length} bytes")
    except:
        pass
    
    if user_id % 100 == 0:
        print(f"    Progress: {user_id}/500...")

if not anomalies:
    print("    No anomalies found in range 201-500")

# Let's also try lowercase usernames that might be common
print("\n[4] Testing common username patterns")
common_names = ['admin', 'user', 'root', 'guest', 'tester', 'administrator', 'system', 'api', 'service']
for name in common_names:
    url = f"{target_url}/password/{name}"
    response = requests.get(url, timeout=10)
    size = len(response.content)
    status = response.status_code
    
    if size == 1418:  # Matches valid account pattern
        print(f"    [VALID PATTERN] /password/{name}: {size} bytes")
        # Extract username from form
        username_match = re.search(r'name=["\']username["\'][^>]*value=["\']([^"\']+)["\']', response.text, re.I)
        if username_match:
            print(f"        Username: {username_match.group(1)}")
    elif size != 1287:
        print(f"    [UNUSUAL] /password/{name}: {size} bytes (status: {status})")

# Try numeric IDs beyond 500 - maybe accounts are sparse
print("\n[5] Testing sparse range (1000-1050)")
for user_id in range(1000, 1051):
    try:
        url = f"{target_url}/password/{user_id}"
        response = requests.get(url, timeout=5)
        content_length = len(response.content)
        
        if content_length != 1287:
            anomalies.append({'id': user_id, 'size': content_length})
            print(f"    [ANOMALY] ID {user_id}: {content_length} bytes")
    except:
        pass

if len([a for a in anomalies if a['id'] >= 1000]) == 0:
    print("    No anomalies found in range 1000-1050")

# Let's see if there's a way to enumerate valid usernames from the response content
print("\n[6] Detailed content comparison")
# Look at differences in form structure
if 'action=' in resp_test.text:
    action_match_test = re.search(r'action=["\']([^"\']+)["\']', resp_test.text)
    action_match_1 = re.search(r'action=["\']([^"\']+)["\']', resp_1.text)
    if action_match_test and action_match_1:
        print(f"    /password/test form action: {action_match_test.group(1)}")
        print(f"    /password/1 form action: {action_match_1.group(1)}")

# Summary
print("\n" + "=" * 60)
print("[SUMMARY]")
print(f"  Base numeric IDs (1-500): All return 1287 bytes (uniform)")
print(f"  Valid account (/password/test): 1418 bytes")
print(f"  Total anomalies found: {len(anomalies)}")
if anomalies:
    print(f"  Anomalous IDs: {[a['id'] for a in anomalies]}")
print(f"\n  Conclusion: Numeric IDs don't appear to correspond to user accounts")
print(f"  Consider testing other username patterns or check for IDOR in other endpoints")

