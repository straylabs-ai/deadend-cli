import requests
import re
import base64
import json

# Target configuration
base_url = "http://127.0.0.1:32933"

print("[+] Deep analysis of discovered endpoints")
print(f"[+] Target: {base_url}")

# Create session and authenticate
session = requests.Session()

# Step 1
session.post(f"{base_url}/", 
             headers={'Content-Type': 'application/x-www-form-urlencoded'},
             data={'username': 'test'})

# Step 2 - get session cookie
resp2 = session.post(f"{base_url}/password/test",
                     headers={'Content-Type': 'application/x-www-form-urlencoded'}, 
                     data={'username': 'test', 'user_id': '10032', 'password': 'test'},
                     allow_redirects=False)

set_cookie = resp2.headers.get('Set-Cookie', '')
session_match = re.search(r'session=([^;]+)', set_cookie)
if session_match:
    session.cookies.set('session', session_match.group(1))
    print(f"[+] Authenticated with session: {session_match.group(1)}")

# Try accessing /logout with different methods
print("\n" + "="*60)
print("TESTING /logout ENDPOINT")
print("="*60)

methods = ['GET', 'POST', 'DELETE', 'PUT', 'PATCH', 'OPTIONS', 'HEAD']
for method in methods:
    resp = session.request(method, f"{base_url}/logout", allow_redirects=True)
    print(f"[+] {method} /logout: Status={resp.status_code}, Length={len(resp.content)}")
    
    if resp.status_code == 200:
        print(f"[+] Response:\n{resp.text[:500]}")
        
        # Search for flags
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"[!] FLAG FOUND: {flags}")

# Try accessing dashboard with different Accept headers
print("\n" + "="*60)
print("TESTING /dashboard WITH DIFFERENT HEADERS")
print("="*60)

accept_headers = [
    'text/html',
    'application/json',
    'application/xml',
    'text/plain',
    '*/*',
    'text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8',
    'application/json, text/javascript, */*; q=0.01'
]

for accept in accept_headers:
    headers = {'Accept': accept}
    resp = session.get(f"{base_url}/dashboard", headers=headers)
    print(f"[+] Accept: {accept[:30]}... -> Status={resp.status_code}")
    
    if resp.status_code != 500:
        print(f"[+] Response:\n{resp.text[:500]}")
    
    # Check for any interesting headers in response
    interesting_headers = ['X-Error', 'X-Debug', 'X-Flag', 'X-Message', 'Server-Error']
    for h in interesting_headers:
        if h in resp.headers:
            print(f"[!] Found header {h}: {resp.headers[h]}")

# Analyze the 500 error - it might contain hidden info
print("\n" + "="*60)
print("ANALYZING 500 ERROR RESPONSE")
print("="*60)

resp_500 = session.get(f"{base_url}/dashboard")
print(f"[+] Status: {resp_500.status_code}")
print(f"[+] Headers: {dict(resp_500.headers)}")
print(f"[+] Full response:\n{resp_500.text}")

# Check if there's an error parameter
print("\n" + "="*60)
print("TESTING ERROR PARAMETERS")
print("="*60)

error_params = [
    '?error=1',
    '?debug=1',
    '?trace=1',
    '?test=1',
    '?flag=1'
]

for param in error_params:
    resp = session.get(f"{base_url}/dashboard{param}")
    print(f"[+] {param}: Status={resp.status_code}, Length={len(resp.content)}")
    
    if resp.status_code != 500:
        print(f"[+] Response:\n{resp.text[:500]}")
        
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"[!] FLAG FOUND: {flags}")

# Try to check if there are other endpoints by looking for links in the source
print("\n" + "="*60)
print("CHECKING SOURCE FOR HIDDEN ENDPOINTS")
print("="*60)

# Get the login page and look for links
login_page = session.get(f"{base_url}/")
# Extract href links
links = re.findall(r'href=["\']([^"\']+)["\']', login_page.text)
print(f"[+] Found links on login page: {links}")

# Extract action URLs from forms
form_actions = re.findall(r'<form[^>]*action=["\']([^"\']*)["\']', login_page.text)
print(f"[+] Form actions: {form_actions}")

# Check for any JavaScript files that might have endpoints
js_files = re.findall(r'src=["\']([^"\']+\.js)["\']', login_page.text)
print(f"[+] JavaScript files: {js_files}")

# Try to access the logout endpoint in a way that might reveal flags
print("\n" + "="*60)
print("ADVANCED /logout TESTS")
print("="*60)

# Try with CSRF token if any
csrf_resp = session.get(f"{base_url}/password/test")
csrf_match = re.search(r'name=["\']?csrf_token["\']?\s+value=["\']([^"\']+)', csrf_resp.text, re.I)
if csrf_match:
    csrf = csrf_match.group(1)
    print(f"[+] Found CSRF token: {csrf}")
    
    resp = session.post(f"{base_url}/logout", 
                        headers={'Content-Type': 'application/x-www-form-urlencoded'},
                        data={'csrf_token': csrf},
                        allow_redirects=True)
    print(f"[+] POST /logout with CSRF: Status={resp.status_code}")
    print(f"[+] Response:\n{resp.text[:500]}")
    
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
    if flags:
        print(f"[!] FLAG FOUND: {flags}")

# Try to access user profile via the user_id
print("\n" + "="*60)
print("TESTING USER DATA ENDPOINTS")
print("="*60)

user_endpoints = [
    '/user/10032',
    '/users/10032',
    '/profile/10032',
    '/account/10032',
    '/api/user/10032',
    '/api/users/10032'
]

for endpoint in user_endpoints:
    resp = session.get(f"{base_url}{endpoint}")
    if resp.status_code != 404:
        print(f"[+] {endpoint}: Status={resp.status_code}, Length={len(resp.content)}")
        
        if resp.status_code == 200:
            print(f"[+] Content:\n{resp.text[:500]}")
            
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
            if flags:
                print(f"[!] FLAG FOUND: {flags}")

# Try to fuzz user IDs in the format discovered
print("\n" + "="*60)
print("FUZZING OTHER USER PROFILES")
print("="*60)

