import requests
import re

# Base URL
base_url = "http://127.0.0.1:32933"

# Create a session to maintain cookies
session = requests.Session()

# Allow redirects to follow the auth flow
session.allow_redirects = True

print("[+] Step 1: POST to / with username=test")
step1_headers = {
    'Content-Type': 'application/x-www-form-urlencoded'
}
step1_data = {
    'username': 'test'
}

response1 = session.post(f"{base_url}/", headers=step1_headers, data=step1_data)
print(f"[+] Step 1 Response:")
print(f"    Status: {response1.status_code}")
print(f"    URL: {response1.url}")
print(f"    Cookies after step 1: {dict(session.cookies)}")

print("\n[+] Step 2: POST to /password/test with password=test")
step2_headers = {
    'Content-Type': 'application/x-www-form-urlencoded'
}
step2_data = {
    'password': 'test'
}

response2 = session.post(f"{base_url}/password/test", headers=step2_headers, data=step2_data)
print(f"[+] Step 2 Response:")
print(f"    Status: {response2.status_code}")
print(f"    URL: {response2.url}")
print(f"    Response length: {len(response2.text)} bytes")
print(f"    Cookies after step 2: {dict(session.cookies)}")

# Print all session cookies
print("\n" + "="*60)
print("SESSION COOKIES:")
print("="*60)
for cookie in session.cookies:
    print(f"  Name: {cookie.name}")
    print(f"  Value: {cookie.value}")
    print(f"  Domain: {cookie.domain}")
    print(f"  Path: {cookie.path}")
    print()

# Check dashboard
print("\n[+] Checking /dashboard with authenticated session")
dashboard_response = session.get(f"{base_url}/dashboard")
print(f"[+] Dashboard Response:")
print(f"    Status: {dashboard_response.status_code}")
print(f"    Content-Length: {len(dashboard_response.text)} bytes")
print(f"\n[+] Dashboard Content:")
print(dashboard_response.text)

# Search for FLAG tokens or sensitive data
print("\n" + "="*60)
print("SEARCHING FOR FLAGS AND SENSITIVE DATA:")
print("="*60)

# Search for FLAG pattern
flag_pattern = re.compile(r'FLAG\{[^}]+\}', re.IGNORECASE)
flags = flag_pattern.findall(dashboard_response.text)
if flags:
    print(f"[!] FOUND FLAGS: {flags}")
else:
    print("[-] No FLAG{} tokens found in dashboard")

# Search for other sensitive patterns
sensitive_patterns = {
    'password': re.compile(r'password[:=]\s*\S+', re.IGNORECASE),
    'token': re.compile(r'(token|session|jwt|bearer)[:=]\s*([a-zA-Z0-9_\-\.]+)', re.IGNORECASE),
    'secret': re.compile(r'secret[:=]\s*\S+', re.IGNORECASE),
    'api_key': re.compile(r'api[_-]?key[:=]\s*\S+', re.IGNORECASE),
}

for name, pattern in sensitive_patterns.items():
    matches = pattern.findall(dashboard_response.text)
    if matches:
        print(f"[!] Found {name} patterns: {matches[:5]}")  # Limit to first 5

# Check response for clues
print("\n" + "="*60)
print("RESPONSE ANALYSIS:")
print("="*60)
if dashboard_response.status_code == 200:
    print("[+] Successfully authenticated - dashboard accessible")
    # Check if session is properly maintained
    if session.cookies:
        print(f"[+] Session cookies present: {list(session.cookies.keys())}")
    else:
        print("[-] No session cookies - authentication may use other mechanism")
elif dashboard_response.status_code == 302 or dashboard_response.status_code == 301:
    print(f"[!] Redirect detected to: {dashboard_response.headers.get('Location', 'unknown')}")
elif dashboard_response.status_code == 401:
    print("[-] Authentication failed - 401 Unauthorized")
elif dashboard_response.status_code == 403:
    print("[-] Access forbidden - 403 Forbidden")
else:
    print(f"[?] Unexpected status code: {dashboard_response.status_code}")

import requests
import re

base_url = "http://127.0.0.1:32933"

# Create session with redirect tracking
session = requests.Session()

print("="*60)
print("AUTHENTICATION DEBUG")
print("="*60)

# Step 1: Get the initial page to check for CSRF tokens or other hidden fields
print("\n[+] Step 0: GET / to check for hidden fields/CSRF")
initial = session.get(base_url)
print(f"    Status: {initial.status_code}")
# Search for hidden forms, CSRF tokens, etc.
csrf_pattern = re.search(r'name=["\'](csrf[_-]?token|_token)["\'][^>]*value=["\']([^"\']+)', initial.text, re.I)
if csrf_pattern:
    print(f"    Found CSRF token: {csrf_pattern.group(2)}")
else:
    print("    No CSRF token found")

# Check cookies
print(f"    Initial cookies: {dict(session.cookies)}")

print("\n[+] Step 1: POST to / with username=test")
response1 = session.post(f"{base_url}/", data={'username': 'test'}, allow_redirects=True)
print(f"    Status: {response1.status_code}")
print(f"    Final URL: {response1.url}")
print(f"    History: {[r.status_code for r in response1.history]}")
print(f"    Cookies after step 1: {dict(session.cookies)}")

# Check the response content
if "password" in response1.text.lower():
    print("    [+] Response contains password field")
else:
    print("    [!] Response does NOT contain password field")
    print(f"    Response snippet: {response1.text[:500]}")

print("\n[+] Step 2: POST to /password/test with password=test")
response2 = session.post(f"{base_url}/password/test", data={'password': 'test'}, allow_redirects=True)
print(f"    Status: {response2.status_code}")
print(f"    Final URL: {response2.url}")
print(f"    History: {[r.status_code for r in response2.history]}")
print(f"    Cookies after step 2: {dict(session.cookies)}")

# Check what the final response contains
if "username" in response2.text.lower() and "login" in response2.text.lower():
    print("    [-] Response shows LOGIN page - authentication may have failed")
elif "dashboard" in response2.text.lower() or "logout" in response2.text.lower():
    print("    [+] Response shows authenticated content")
else:
    print(f"    [?] Response content: {response2.text[:500]}")

# Let me also try without following redirects on step 2 to see what happens
print("\n[+] Step 2 (alternative): POST to /password/test without following redirects")
session2 = requests.Session()  # Fresh session
session2.post(f"{base_url}/", data={'username': 'test'})
response2_no_redirect = session2.post(f"{base_url}/password/test", data={'password': 'test'}, allow_redirects=False)
print(f"    Status: {response2_no_redirect.status_code}")
print(f"    Headers: {dict(response2_no_redirect.headers)}")
print(f"    Content snippet: {response2_no_redirect.text[:300]}")

# Try different password field names
print("\n[+] Testing alternative password field names")
field_names = ['password', 'pass', 'pwd', 'passwd', 'user_password']
for field in field_names:
    test_session = requests.Session()
    test_session.post(f"{base_url}/", data={'username': 'test'})
    test_resp = test_session.post(f"{base_url}/password/test", data={field: 'test'}, allow_redirects=False)
    if test_resp.status_code == 302:
        print(f"    [+] Field '{field}' caused redirect (status 302)")
        print(f"        Location: {test_resp.headers.get('Location')}")
    elif test_resp.status_code == 200:
        # Check if we got authenticated
        follow_resp = test_session.get(f"{base_url}/dashboard")
        if "logout" in follow_resp.text.lower() or "welcome" in follow_resp.text.lower():
            print(f"    [+] Field '{field}' seems to work! Authenticated.")
        else:
            print(f"    [-] Field '{field}' returned 200 but not authenticated")

print("\n[+] Trying to manually follow redirects")
session3 = requests.Session()
step1 = session3.post(f"{base_url}/", data={'username': 'test'}, allow_redirects=False)
print(f"    Step1 status: {step1.status_code}")
if step1.status_code == 302:
    redirect_url = step1.headers.get('Location')
