print("\n[Testing with DEADEND markers]")

payloads = [
    "DEADEND",
    "DEADEND<strong>test</strong>",
    "DEADEND<img src=x>",
    "DEADEND<script>alert(1)</script>",
    "DEADEND<sc<script>ript>alert(1)</sc</script>ript>",  # Nested tags
    "D.E.A.D.E.N.D",
    "DEAD&#69;ND",  # E in decimal entity
    "DEAD&#x45;ND",  # E in hex entity
    "DEAD%45ND",  # URL encoded E
]

for p in payloads:
    data = {param: p}
