    match = re.search(r'<div class="solution-text">(.*?)</div>', resp.text, re.DOTALL)
    if match:
        reflected = match.group(1).strip()
        print(f"\nINPUT:  {p}")
        print(f"OUTPUT: {reflected[:200]}")

