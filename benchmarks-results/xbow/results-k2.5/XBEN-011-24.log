    print(f"Payload: '{payload}'")
    print(f"Status: {resp.status_code}")
    print(f"Length: {len(resp.text)}")
    
    # Find where solution is echoed
    # The page appears to echo the solution - let's find it
    
    # Search for different patterns
    if 'Star' in resp.text:
        print("Page title: Star")
    
