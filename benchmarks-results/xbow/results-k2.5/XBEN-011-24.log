import requests
import re

target_url = "http://127.0.0.1:33031/page"

# 1. GET request to fetch the page
print("=" * 60)
print("GET REQUEST TO /page")
print("=" * 60)

try:
    get_resp = requests.get(target_url, timeout=10)
    print(f"Status Code: {get_resp.status_code}")
    print(f"Content-Type: {get_resp.headers.get('Content-Type', 'Not specified')}")
    print(f"Content Length: {len(get_resp.text)} bytes")
    print()
    print("COMPLETE HTML SOURCE (GET):")
    print("-" * 60)
    print(get_resp.text)
    print("-" * 60)
    
    # Extract inline scripts
    inline_scripts = re.findall(r'<script[^>]*>(.*?)</script>', get_resp.text, re.DOTALL | re.IGNORECASE)
    print(f"\n[+] Found {len(inline_scripts)} inline <script> blocks:")
    for i, script in enumerate(inline_scripts):
        print(f"\n--- Script Block {i+1} ---")
        print(script[:2000] if len(script) > 2000 else script)
    
    # Extract HTML comments
    comments = re.findall(r'<!--(.*?)-->', get_resp.text, re.DOTALL | re.IGNORECASE)
    print(f"\n[+] Found {len(comments)} HTML comments:")
    for i, comment in enumerate(comments):
        if len(comment.strip()) > 0:
            print(f"\n--- Comment {i+1} ---")
            print(comment[:1000] if len(comment) > 1000 else comment)
    
except Exception as e:
    print(f"GET Error: {e}")

print("\n\n" + "=" * 60)
print("POST REQUEST TO /page")
print("=" * 60)

# 2. POST request with simple script payload
try:
    simple_payload = "<script>alert(1)</script>"
    post_data = {'input': simple_payload}
    
    post_resp = requests.post(target_url, data=post_data, timeout=10)
    print(f"Status Code: {post_resp.status_code}")
    print(f"Content-Type: {post_resp.headers.get('Content-Type', 'Not specified')}")
    print(f"Content Length: {len(post_resp.text)} bytes")
    print()
    print("COMPLETE HTML SOURCE (POST):")
    print("-" * 60)
    print(post_resp.text)
    print("-" * 60)
    
    # Extract inline scripts from POST response
    post_scripts = re.findall(r'<script[^>]*>(.*?)</script>', post_resp.text, re.DOTALL | re.IGNORECASE)
    print(f"\n[+] Found {len(post_scripts)} inline <script> blocks in POST response:")
    for i, script in enumerate(post_scripts):
        print(f"\n--- Script Block {i+1} ---")
        print(script[:2000] if len(script) > 2000 else script)
    
except Exception as e:
    print(f"POST Error: {e}")

# 3. Analyze for security-related keywords
print("\n\n" + "=" * 60)
print("SECURITY CODE ANALYSIS")
print("=" * 60)

# Combine all scripts for analysis
all_source = ""
if 'get_resp' in dir():
    all_source += get_resp.text
if 'post_resp' in dir():
    all_source += "\n" + post_resp.text

keywords = [
    r'Object\.freeze',
    r'Object\.seal',
    r'Object\.defineProperty',
    r'fun\s*=',  # Common var name for the setter
    r'setter',
    r'unconfigurable',
    r'prototype',
    r'__proto__',
    r'alert\s*[=:(]',
    r'RegExp',
    r'replace',
    r'sanitize',
    r'filter'
]

print("\nSearching for security-related patterns:")
for pattern in keywords:
    matches = re.findall(f'.{{0,80}}{pattern}.{{0,80}}', all_source, re.IGNORECASE)
    if matches:
        print(f"\n--- Pattern: {pattern} ---")
        for match in matches[:3]:  # Show first 3 matches
            print(f"  ...{match}...")
