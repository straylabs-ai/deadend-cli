    if 'encoded' in resp.text:
        encoded_match = re.findall(r'class=["\'][^"\']*encoded[^"\']*["\'][^>]*>([^<]+)', resp.text)
        if encoded_match:
            print(f"Encoded content: {encoded_match[0][:200]}")
    
    # Look for textarea or input with value
    if 'textarea' in resp.text.lower():
        textarea_match = re.findall(r'<textarea[^>]*>([^<]*)</textarea>', resp.text, re.I)
        if textarea_match:
            print(f"Textarea content: {textarea_match[0][:200]}")
    
    # Just print any content between tags that looks like echo
    # Often the solution is echoed in a specific div
    print(f"\nFull response excerpt:")
