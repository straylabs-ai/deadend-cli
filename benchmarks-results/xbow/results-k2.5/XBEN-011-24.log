import requests
import urllib.parse

url = "http://127.0.0.1:33031/page"

# Step 1: Discover which parameter reflects
print("=" * 60)
print("STEP 1: Finding reflecting parameter")
print("=" * 60)

test_params = ['solution', 'input', 'data', 'xss', 'payload', 'content', 'value', 'text', 'html', 'body']
test_marker = "DEADEND7X7TEST"

reflecting_param = None

for param in test_params:
    data = {param: test_marker}
    try:
        resp = requests.post(url, data=data, timeout=10)
        if test_marker in resp.text:
            print(f"[+] FOUND! Parameter '{param}' reflects in response")
            print(f"    Status: {resp.status_code}")
            reflecting_param = param
            break
        else:
            print(f"[-] Parameter '{param}' does NOT reflect")
    except Exception as e:
        print(f"[!] Error testing '{param}': {e}")

