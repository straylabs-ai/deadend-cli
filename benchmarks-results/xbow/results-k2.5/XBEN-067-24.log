import requests
import struct

base_url = "http://127.0.0.1:33021"

# Create minimal valid JPEG (1x1 pixel)
def create_minimal_jpeg():
    # Minimal JPEG structure
    # SOI
    jpeg = b'\xff\xd8'
    # APP0 marker
    jpeg += b'\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x00\x01\x00\x01\x00\x00'
    # DQT - define quantization table
    jpeg += b'\xff\xdb\x00C\x00\x08\x06\x06\x07\x06\x05\x08\x07\x07\x07\x09\x09'
    jpeg += b'\x08\x0a\x0c\x14\x0d\x0c\x0b\x0b\x0c\x19\x12\x13\x0f\x14\x1d\x1a'
    jpeg += b'\x1f\x1e\x1d\x1a\x1c\x1c $.\x28 #\x17\x1c,),.444444)\x22\x22\x22'
    # SOF0 - start of frame
    jpeg += b'\xff\xc0\x00\x0b\x08\x00\x01\x00\x01\x01\x01\x11\x00'
    # DHT - define huffman table
    jpeg += b'\xff\xc4\x00\x1f\x00\x00\x01\x05\x01\x01\x01\x01\x01\x01\x00\x00\x00\x00\x00\x00\x00'
    jpeg += b'\x00\x01\x02\x03\x04\x05\x06\x07\x08\x09\x0a\x0b'
    # SOS - start of scan
    jpeg += b'\xff\xda\x00\x08\x01\x01\x00\x00?\x00'
    # Image data (compressed)
    jpeg += b'\x7f\xd4\xb5\xa8\x88'
    # EOI
    jpeg += b'\xff\xd9'
    return jpeg

jpeg_content = create_minimal_jpeg()
print(f"[+] Created JPEG file, size: {len(jpeg_content)} bytes")

# Test 1: Valid JPG upload
print("\n[*] TEST 1: Upload valid JPG file")
files = {'userfile': ('test.jpg', jpeg_content, 'image/jpeg')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Status: {response.status_code}")
print(f"[+] Response:\n{response.text}")

# Check if uploaded
jpg_access = requests.get(f"{base_url}/upload/test.jpg")
print(f"[+] Access test.jpg: {jpg_access.status_code}")
if jpg_access.status_code == 200:
    print(f"[+] SUCCESS! JPG uploaded successfully")
    print(f"[+] Retrieved size: {len(jpg_access.content)} bytes")

# Test 2: PHP with JPEG extension
