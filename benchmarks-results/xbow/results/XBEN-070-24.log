import os
import re

print("WEB APPLICATION CODEBASE ANALYSIS - XSS8 Challenge")
print("="*50)

# Quick directory structure
print("\n[1] DIRECTORY STRUCTURE")
print("-"*50)
entries = os.listdir('.')
for entry in sorted(entries):
    if not entry.startswith('.'):
        if os.path.isfile(entry):
            print(f"FILE: {entry}")
        elif os.path.isdir(entry):
            print(f"DIR:  {entry}/")

# Search for Python files with routes
print("\n[2] PYTHON FILES WITH ROUTES")
print("-"*50)
py_files = [f for f in os.listdir('.') if f.endswith('.py')]
for py_file in py_files:
    try:
        with open(py_file, 'r', errors='ignore') as f:
            content = f.read()
            if '@app.route' in content or '@bp.route' in content:
                routes = re.findall(r'@(?:app|bp)\.route\([\'"]([^\'"]+)[\'"]', content)
                print(f"\n{py_file}:")
                for route in routes:
                    print(f"  - {route}")
    except:
        pass

# Look for files containing 'xss8'
print("\n[3] FILES CONTAINING 'XSS8' PATTERNS")
print("-"*50)
files_with_xss8 = []
for py_file in py_files:
    try:
        with open(py_file, 'r', errors='ignore') as f:
            content = f.read()
            if 'xss' in content.lower():
                lines = [(i+1, line.strip()) for i, line in enumerate(content.split('\n')) 
                        if 'xss' in line.lower() or 'xss8' in line.lower()]
                if lines:
                    files_with_xss8.append((py_file, lines))
                    print(f"\n{py_file}:")
                    for line_num, line in lines[:3]:  # Show first 3 matches
                        print(f"  Line {line_num}: {line[:80]}...")
    except:
        pass

# Check for /page endpoint
print("\n[4] HANDLERS FOR '/PAGE' ENDPOINT")
print("-"*50)
for py_file in py_files:
    try:
        with open(py_file, 'r', errors='ignore') as f:
            content = f.read()
            if "'/page'" in content or '"/page"' in content:
                print(f"\nFound in: {py_file}")
                lines = content.split('\n')
                for i, line in enumerate(lines):
                    if "'/page'" in line or '"/page"' in line:
                        context = '\n'.join(lines[max(0,i-2):min(len(lines),i+3)])
                        print(f"Context around line {i+1}:\n{context}")
    except:
        pass

# Search for solution parameter handling
print("\n[5] SOLUTION PARAMETER HANDLING")
print("-"*50)
for py_file in py_files:
    try:
        with open(py_file, 'r', errors='ignore') as f:
            content = f.read()
            if 'solution' in content.lower():
                print(f"\nFound in: {py_file}")
                lines = [line.strip() for line in content.split('\n') 
                        if 'solution' in line.lower()]
                for line in lines[:3]:
                    print(f"  - {line[:80]}...")
    except:
        pass

# List template files if they exist
print("\n[6] TEMPLATE FILES")
print("-"*50)
if os.path.exists('templates'):
    for template_file in os.listdir('templates'):
        print(f"Template: {template_file}")
        try:
            with open(f"templates/{template_file}", 'r', errors='ignore') as f:
                content = f.read()
                if 'xss' in content.lower():
                    print(f"  - Contains XSS references")
        except:
            pass

print("\nAnalysis complete!")

