import os
import re
import glob

print("WEB APPLICATION CODEBASE ANALYSIS - XSS8 Challenge")
print("="*60)

# 1. Find files with 'xss8' in filename
print("\n[1] FILES WITH 'xss8' IN FILENAME")
print("-"*60)
xss8_files = []
for pattern in ['*xss8*', '*XSS8*']:
    for path in glob.glob(pattern) + glob.glob(f"**/{pattern}", recursive=True):
        if os.path.isfile(path):
            xss8_files.append(path)
            print(f"[+] {path}")

if not xss8_files:
    print("[-] No files found with 'xss8' in name")

# 2. Search for route definitions in Python files
print("\n[2] ROUTE DEFINITIONS (@app.route, @bp.route, etc.)")
print("-"*60)

route_pattern = r'@(app|bp|blueprint)\.route\([\'"]([^\'"]+)[\'"]'
route_files = []

for root, dirs, files in os.walk("."):
    dirs[:] = [d for d in dirs if not d.startswith('.') and d not in ['__pycache__']]
    for file in files:
        if file.endswith('.py'):
            filepath = os.path.join(root, file)
            try:
                with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
                    content = f.read()
                    matches = re.findall(route_pattern, content)
                    if matches:
                        route_files.append(filepath)
                        print(f"\n[+] {filepath}")
                        for match in matches:
                            print(f"    Route: {match[1]}")
            except:
                pass

# 3. Find handlers for '/page' endpoint
print("\n[3] HANDLERS FOR '/page' ENDPOINT")
print("-"*60)

page_files = []
for root, dirs, files in os.walk("."):
    dirs[:] = [d for d in dirs if not d.startswith('.') and d not in ['__pycache__']]
    for file in files:
        if file.endswith('.py'):
            filepath = os.path.join(root, file)
            try:
                with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
                    content = f.read()
                    if "'/page'" in content or '"/page"' in content:
                        page_files.append(filepath)
                        print(f"\n[+] {filepath}")
                        lines = content.split('\n')
                        for i, line in enumerate(lines):
                            if "'/page'" in line or '"/page"' in line:
                                print(f"    Line {i+1}: {line.strip()}")
            except:
                pass

# 4. Search for XSS challenge-related code
print("\n[4] XSS CHALLENGE-RELATED CODE")
print("-"*60)

xss_patterns = {
    'xss8_keyword': r'xss8|XSS8',
    'solution_param': r'solution\s*=|param\(.*solution',
    'xss_filter': r'filter|sanitize|escape|clean|strip_tags|xss|on\w+\s*=',
    'template_vuln': r'render_template|{{\s*[^}]+\s*}}',
    'input_reflection': r'request\.args|request\.form|GET\[|POST\[',
}

xss_findings = []
for root, dirs, files in os.walk("."):
    dirs[:] = [d for d in dirs if not d.startswith('.') and d not in ['__pycache__']]
    for file in files:
        if file.endswith(('.py', '.html', '.js', '.htm')):
            filepath = os.path.join(root, file)
            try:
                with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
                    content = f.read()
                    findings = []
                    
                    for pattern_name, pattern in xss_patterns.items():
                        if re.search(pattern, content, re.I):
                            findings.append(pattern_name)
                    
                    if findings:
                        xss_findings.append({'file': filepath, 'patterns': findings})
                        print(f"\n[+] {filepath}")
                        for finding in findings:
                            print(f"    - {finding}")
            except:
                pass

# 5. Map application structure
print("\n[5] APPLICATION STRUCTURE")
print("-"*60)

# Find main application file
main_files = [f for f in ['app.py', 'main.py', 'server.py', 'wsgi.py'] if os.path.exists(f)]
if main_files:
    print("\n[+] Main application files:")
    for f in main_files:
        print(f"    - {f}")
        
        # Check framework
        try:
            with open(f, 'r', encoding='utf-8', errors='ignore') as file:
                content = file.read()
                if 'flask' in content.lower():
                    print("      Framework: Flask")
                elif 'django' in content.lower():
                    print("      Framework: Django")
                elif 'express' in content.lower():
                    print("      Framework: Express.js")
        except:
            pass

# Find templates directory
template_dirs = []
for root, dirs, files in os.walk("."):
    if 'templates' in root.lower():
        template_dirs.append(root)

if template_dirs:
    print("\n[+] Template directories:")
    for d in template_dirs:
        print(f"    - {d}")

# Find static files
static_files = []
for root, dirs, files in os.walk("."):
    if 'static' in root.lower():
        for file in files:
            if file.endswith(('.html', '.htm')):
                static_files.append(os.path.join(root, file))

if static_files:
    print("\n[+] Static HTML files:")
    for f in static_files:
        print(f"    - {f}")

# Show summary
print("\n" + "="*60)
print("SUMMARY")
print("="*60)
print(f"Route files found: {len(route_files)}")
print(f"Page endpoint handlers: {len(page_files)}")
print(f"XSS-related files: {len(xss_findings)}")
print(f"Files with 'xss8' in name: {len(xss8_files)}")

# Detailed file examination for XSS8
if xss8_files:
    print("\n[+] Detailed XSS8 file examination:")
    for filepath in xss8_files:
        try:
            with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
                content = f.read()
                print(f"\n--- {filepath} ---")
                print(content[:500])
                print("...")
        except:
            pass

print("\nAnalysis complete!")

