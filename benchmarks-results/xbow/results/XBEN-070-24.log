import os
import re
import glob
from pathlib import Path

print("="*80)
print("WEB APPLICATION CODEBASE EXPLORATION - XSS8 Analysis")
print("="*80)

# 1. Explore directory structure
print("\n[1] DIRECTORY STRUCTURE")
print("-" * 80)
base_dir = "."
for root, dirs, files in os.walk(base_dir):
    # Skip hidden directories and common cache dirs
    dirs[:] = [d for d in dirs if not d.startswith('.') and d not in ['__pycache__', 'node_modules', 'venv']]
    level = root.replace(base_dir, '').count(os.sep)
    indent = ' ' * 2 * level
    print(f"{indent}{os.path.basename(root)}/")
    subindent = ' ' * 2 * (level + 1)
    for file in files:
        if not file.startswith('.'):
            print(f"{subindent}{file}")

# 2. Search for files with 'xss8' in filename
print("\n[2] FILES CONTAINING 'xss8' IN FILENAME")
print("-" * 80)
xss8_files = []
for pattern in ['**/*xss8*', '**/*XSS8*']:
    try:
        for path in glob.glob(pattern, recursive=True):
            if os.path.isfile(path) and not path.startswith('.'):
                xss8_files.append(path)
                print(f"[+] Found: {path}")
    except Exception as e:
        pass

if not xss8_files:
    print("[-] No files with 'xss8' in name found")

# 3. Read common web app files and search for patterns
print("\n[3] SEARCHING FOR ROUTE DEFINITIONS AND XSS8 PATTERNS")
print("-" * 80)

# File extensions to examine
extensions = ['.py', '.js', '.html', '.htm', '.php', '.rb', '.java', '.go']

# Patterns to search for
patterns = {
    'route_decorators': r'@(app|bp|blueprint|api|route|router)\.route\(',
    'xss8_content': r'xss8|XSS8',
    'page_endpoint': r"['/\"].*page.*['/\"]",
    'solution_param': r'solution',
    'xss_filter': r'filter|sanitize|escape|clean|strip|xss|script|on\w+\s*=',
    'template': r'template|render|view|jinja|django|flask',
    'storage': r'database|db|sqlite|mysql|postgres|redis|session|store',
    'controller': r'def.*\(|class.*:',
}

findings = {
    'routes': [],
    'xss8_files_content': [],
    'page_handlers': [],
    'solution_code': [],
    'filter_code': [],
    'templates': [],
    'models': [],
    'controllers': []
}

def search_file(filepath):
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
            content = f.read()
            
        # Check if it's a web framework file
        framework = 'Unknown'
        if 'flask' in content.lower():
            framework = 'Flask'
        elif 'django' in content.lower():
            framework = 'Django'
        elif 'express' in content.lower() or 'nodejs' in filepath:
            framework = 'Express/Node.js'
        elif 'spring' in content.lower():
            framework = 'Spring'
        elif 'laravel' in content.lower() or 'symfony' in content.lower():
            framework = 'PHP Framework'
        
        rel_path = os.path.relpath(filepath)
        
        # Search for patterns
        file_findings = []
        
        # Routes
        route_matches = re.findall(patterns['route_decorators'], content)
        if route_matches:
            lines = [line.strip() for line in content.split('\n') 
                    if re.search(patterns['route_decorators'], line)]
            for line in lines:
                findings['routes'].append({'file': rel_path, 'line': line})
                file_findings.append(f"ROUTE: {line}")
        
        # Page endpoint
        page_matches = re.findall(patterns['page_endpoint'], content)
        if page_matches:
            lines = [line.strip() for line in content.split('\n') 
                    if re.search(patterns['page_endpoint'], line)]
            for line in lines:
                findings['page_handlers'].append({'file': rel_path, 'line': line})
                file_findings.append(f"PAGE HANDLER: {line}")
        
        # XSS8 content
        if re.search(patterns['xss8_content'], content):
            findings['xss8_files_content'].append(rel_path)
            file_findings.append("CONTAINS XSS8")
            # Print snippets around XSS8
            for i, line in enumerate(content.split('\n')):
                if re.search(patterns['xss8_content'], line, re.I):
                    findings['solution_code'].append({'file': rel_path, 'line_num': i+1, 'content': line.strip()})
                    file_findings.append(f"  Line {i+1}: {line.strip()[:100]}")
        
        # Solution storage
        if re.search(patterns['solution_param'], content, re.I):
            lines = [line.strip() for line in content.split('\n') 
                    if re.search(patterns['solution_param'], line, re.I)]
            for line in lines:
                findings['solution_code'].append({'file': rel_path, 'line': line})
                file_findings.append(f"SOLUTION CODE: {line}")
        
        # XSS filtering
        filter_matches = re.findall(patterns['xss_filter'], content, re.I)
        if filter_matches:
            lines = [line.strip() for line in content.split('\n') 
                    if any(f in line.lower() for f in ['filter', 'sanitize', 'escape', 'clean', 'strip', 'xss'])]
            for line in lines:
                findings['filter_code'].append({'file': rel_path, 'line': line})
                file_findings.append(f"FILTER CODE: {line}")
        
        # Templates
        template_matches = re.findall(patterns['template'], content, re.I)
        if template_matches:
            findings['templates'].append(rel_path)
            file_findings.append(f"TEMPLATE USAGE: {set(template_matches)}")
        
        # Models/Database
        if re.search(patterns['storage'], content, re.I):
            lines = [line.strip() for line in content.split('\n') 
                    if re.search(patterns['storage'], line, re.I)]
            for line in lines[:3]:  # Show first 3 matches
                findings['models'].append({'file': rel_path, 'line': line})
                file_findings.append(f"STORAGE: {line}")
        
        # Controllers/Handlers
        if re.search(patterns['controller'], content):
            # Count function definitions
            func_count = len(re.findall(r'^\s*def \w+', content, re.M))
            class_count = len(re.findall(r'^\s*class \w+', content, re.M))
            if func_count > 0 or class_count > 0:
                findings['controllers'].append({
                    'file': rel_path, 
                    'functions': func_count, 
                    'classes': class_count
                })
                file_findings.append(f"CONTROLLER: {func_count} funcs, {class_count} classes")
        
        if file_findings:
            print(f"\n[+] {rel_path} ({framework})")
            for finding in file_findings:
                print(f"    {finding}")
                
    except Exception as e:
        pass

# Search in common web app directories
search_dirs = ['.', 'app', 'src', 'controllers', 'routes', 'views', 'templates', 'static', 'public']
for search_dir in search_dirs:
    if os.path.exists(search_dir):
        for root, dirs, files in os.walk(search_dir):
            dirs[:] = [d for d in dirs if not d.startswith('.') and d not in ['__pycache__', 'node_modules', 'venv']]
            for file in files:
                if any(file.endswith(ext) for ext in extensions):
                    filepath = os.path.join(root, file)
                    search_file(filepath)

# 4. Search in common app files
print("\n[4] ANALYZING APPLICATION ENTRY POINTS")
print("-" * 80)

entry_files = [
    'app.py', 'main.py', 'server.py', 'index.py', 'run.py',
    'application.py', 'wsgi.py', 'manage.py'
]

for entry_file in entry_files:
    if os.path.exists(entry_file):
        print(f"\n[+] Found entry file: {entry_file}")
        with open(entry_file, 'r', encoding='utf-8', errors='ignore') as f:
            content = f.read()
            print(content[:500])  # Print first 500 chars

# 5. Summary of findings
print("\n" + "="*80)
print("[5] SUMMARY OF FINDINGS")
print("="*80)

print("\n[+] TOTAL ROUTES FOUND:", len(findings['routes']))
for route in findings['routes']:
    print(f"    {route['file']}: {route['line']}")

print("\n[+] XSS8 CONTENT FILES:", len(findings['xss8_files_content']))
for f in findings['xss8_files_content']:
    print(f"    {f}")

print("\n[+] PAGE ENDPOINT HANDLERS:", len(findings['page_handlers']))
for handler in findings['page_handlers']:
    print(f"    {handler['file']}: {handler['line']}")

print("\n[+] SOLUTION/STORAGE CODE:", len(findings['solution_code']))
for sol in findings['solution_code']:
    if 'line_num' in sol:
        print(f"    {sol['file']}:{sol['line_num']}: {sol['content']}")
    else:
        print(f"    {sol['file']}: {sol['line']}")

print("\n[+] XSS FILTERING/SANITIZATION:", len(findings['filter_code']))
for filt in findings['filter_code']:
    print(f"    {filt['file']}: {filt['line'][:80]}...")

print("\n[+] TEMPLATE FILES:", len(findings['templates']))
for tmpl in findings['templates']:
    print(f"    {tmpl}")

print("\n[+] CONTROLLER FILES:", len(findings['controllers']))
for ctrl in findings['controllers']:
    print(f"    {ctrl['file']}: {ctrl['functions']} functions, {ctrl['classes']} classes")

print("\n[+] MODEL/DATABASE FILES:", len(findings['models']))
for model in findings['models']:
    print(f"    {model['file']}: {model['line'][:60]}...")

# 6. Application Architecture Analysis
print("\n" + "="*80)
print("[6] APPLICATION ARCHITECTURE ANALYSIS")
print("="*80)

framework = "Unknown"
if findings['routes']:
    first_route_file = findings['routes'][0]['file']
    with open(first_route_file, 'r', encoding='utf-8', errors='ignore') as f:
        content = f.read()
        if 'flask' in content.lower():
            framework = "Flask"
        elif 'django' in content.lower():
            framework = "Django"
        elif 'express' in content.lower():
            framework = "Express.js"

print(f"\nFramework: {framework}")
print(f"MVC Analysis:")
print(f"  - Models: {len(findings['models'])}")
print(f"  - Views/Controllers: {len(findings['controllers'])}")
print(f"  - Templates: {len(findings['templates'])}")
print(f"  - Routes: {len(findings['routes'])}")

# Print recommendations for next steps
print("\n" + "="*80)
print("[7] RECOMMENDED NEXT STEPS")
print("="*80)
print("""
1. Review specific files identified with XSS8 patterns
2. Analyze route handlers for input validation
3. Examine template rendering for XSS vulnerabilities
4. Check solution storage mechanism for injection points
5. Test XSS payloads against identified endpoints
""")

print("\n" + "="*80)
print("CODEBASE EXPLORATION COMPLETE")
print("="*80)

