import requests
import re
import json
import time

base_url = "http://127.0.0.1:33160"
results = {"server_reachable": False, "routes": [], "debug_info": {}, "error_pages": {}}

print("Flask Introspection - Starting scan on " + base_url)
print("="*60)

# Test basic connectivity
print("\n[1] Testing connectivity...")
try:
    # Create session without connection pooling
    session = requests.Session()
    session.headers.update({"Connection": "close"})
    
    resp = session.get(base_url, timeout=15)
    results["server_reachable"] = True
    print(f"[+] Server reachable - Status: {resp.status_code}")
    print(f"[+] Response headers: {dict(resp.headers)}")
    
    # Check for session cookie
    if 'set-cookie' in resp.headers:
        cookie = resp.headers['set-cookie']
        if 'session' in cookie.lower():
            print(f"[+] Flask session detected: {cookie.split(';')[0]}")
except Exception as e:
    print(f"[-] Connection failed: {str(e)}")
    results["error"] = str(e)
    exit()

# Test debug endpoints
endpoints = ["/console", "/__debug__", "/debugger", "/debug", "/__debug__/console"]
print("\n[2] Testing debug endpoints...")
for endpoint in endpoints:
    try:
        url = base_url + endpoint
        resp = session.get(url, timeout=10, allow_redirects=False)
        print(f"[*] {endpoint:30s} Status: {resp.status_code:3d} | Size: {len(resp.text):5d}B")
        
        results["debug_info"][endpoint] = {
            "status": resp.status_code,
            "size": len(resp.text),
            "has_debugger": "Werkzeug" in resp.text or "__debugger__" in resp.text
        }
        
        if "PIN" in resp.text and "debugger" in resp.text.lower():
            pin_match = re.search(r'PIN[:\s]*([0-9-]+)', resp.text)
            if pin_match:
                print(f"  [!!!] DEBUG PIN: {pin_match.group(1)}")
                results["debug_pin"] = pin_match.group(1)
        
        if resp.status_code == 200:
            print(f"  [+] 200 OK on {endpoint}")
            
    except Exception as e:
        print(f"[-] {endpoint:30s} Error: {str(e)[:40]}")

# Test error triggers to extract routes
print("\n[3] Testing error triggers for route leaks...")
error_tests = ["/nonexistent", "/{{7*7}}", "/{{config}}", "/<script>"]
for test in error_tests:
    try:
        url = base_url + test
        resp = session.get(url, timeout=10)
        
        # Look for route info in errors
        routes = re.findall(r'Rule\(\"([^\"]+)\"', resp.text)
        if routes:
            print(f"[+] Routes leaked from {test}: {routes}")
            results["routes"].extend(routes)
        
        # Check for debugger
        if "__debugger__" in resp.text:
            print(f"[!] Debugger triggered at: {test}")
            results["error_pages"][test] = "debugger_visible"
        else:
            results["error_pages"][test] = resp.status_code
            
    except Exception as e:
        print(f"[-] Error test {test} failed: {str(e)[:40]}")

# Test debugger resources
print("\n[4] Testing debugger resource access...")
debugger_resources = [
    "/?__debugger__=yes&cmd=resource&f=console.html",
    "/?__debugger__=yes&cmd=resource&f=debugger.js"
]
for resource in debugger_resources:
    try:
        url = base_url + resource
        resp = session.get(url, timeout=10)
        print(f"[*] {resource} - Status: {resp.status_code}")
        
        if resp.status_code == 200 and ("Werkzeug" in resp.text or "debugger" in resp.text.lower()):
            print(f"[!!!] Debugger resource accessible without auth!")
        
    except Exception as e:
        print(f"[-] Resource test failed: {str(e)[:40]}")

# Summary
print("\n" + "="*60)
print("SCAN SUMMARY")
print("="*60)
print(f"Server reachable: {results['server_reachable']}")
if "debug_pin" in results:
    print(f"[!] DEBUG PIN FOUND: {results['debug_pin']}")
if results["routes"]:
    print(f"Routes discovered: {list(set(results['routes']))}")
print(json.dumps(results, indent=2))
