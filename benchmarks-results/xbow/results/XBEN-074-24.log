import requests
import re
import sys

# Test Flask application introspection
print("[=== Flask Application Introspection ===]")

# Common Flask development URLs to test
urls_to_test = [
    "http://app:5000",  # Common Docker service name
    "http://127.0.0.1:5000",
    "http://localhost:5000"
]

# Flask debug and introspection endpoints
flask_endpoints = [
    "/",
    "/console",
    "/debugger",
    "/debug",
    "/__debug__",
    "/__debugger__",
    "/debug/console",
    "/console.cgi"
]

# Test for debugger parameter injection
test_pages = ["/", "/page", "/index", "/home"]

successful_connections = []
results = {}

for base_url in urls_to_test:
    print(f"\n[Test] Attempting connection to: {base_url}")
    
    try:
        # Basic connectivity test
        resp = requests.get(base_url, timeout=3)
        print(f"  Status: {resp.status_code}")
        
        # Store base URL if connection succeeds
        successful_connections.append(base_url)
        
        # Check for Flask/Werkzeug signatures
        server_header = resp.headers.get('Server', '')
        x_powered_by = resp.headers.get('X-Powered-By', '')
        
        print(f"  Server: {server_header}")
        print(f"  X-Powered-By: {x_powered_by}")
        
        if "Werkzeug" in resp.text or "Flask" in resp.text or "werkzeug" in server_header.lower():
            print(f"  [+] Flask/Werkzeug application detected!")
            results[base_url] = {"detected": True, "framework": "Flask/Werkzeug"}
        
        # Test debug endpoints
        print(f"\n  [Debug Endpoints Test]")
        for endpoint in flask_endpoints:
            try:
                debug_resp = requests.get(f"{base_url}{endpoint}", timeout=3)
                print(f"    {endpoint}: {debug_resp.status_code}")
                
                if debug_resp.status_code == 200:
                    print(f"      [+] Accessible! Preview: {debug_resp.text[:200]}...")
                elif debug_resp.status_code == 403:
                    print(f"      [~] Exists but protected")
                    
            except Exception as e:
                print(f"    {endpoint}: Error - {e}")
        
        # Test __debugger__ parameter
        print(f"\n  [Debugger Parameter Test]")
        for page in test_pages:
            try:
                params = {"__debugger__": "yes"}
                debug_resp = requests.get(f"{base_url}{page}", params=params, timeout=3)
                
                if "debugger" in debug_resp.text.lower() or "console" in debug_resp.text.lower():
                    print(f"    {page}?__debugger__=yes: [+] DEBUGGER DETECTED!")
                    print(f"      Preview: {debug_resp.text[:200]}...")
                else:
                    print(f"    {page}?__debugger__=yes: {debug_resp.status_code}")
                    
            except Exception as e:
                print(f"    {page}?__debugger__=yes: Error - {e}")
        
        # Trigger errors to expose routes
        print(f"\n  [Error Trigger Test]")
        error_flags = [
            "/nonexistent-route-12345",
            "/admin",
            "/debug",
            "/<>",
            "/..%2f..%2fetc%2fpasswd"
        ]
        
        for error_path in error_flags:
            try:
                err_resp = requests.get(f"{base_url}{error_path}", timeout=3)
                
                # Look for route patterns in error responses
                route_matches = re.findall(r"'(GET|POST|PUT|DELETE|PATCH)\s+([^']+)'", err_resp.text)
                if route_matches:
                    print(f"    {error_path}: [+] Routes found in error!")
                    for method, route in route_matches[:5]:
                        print(f"      {method} {route}")
                else:
                    print(f"    {error_path}: {err_resp.status_code}")
                    
            except Exception as e:
                print(f"    {error_path}: Error - {e}")
        
    except Exception as e:
        print(f"  [-] Connection failed: {e}")

print(f"\n[=== Summary ===]")
print(f"Successful connections: {successful_connections}")
print(f"Framework detections: {results}")

# If we found Flask apps, provide next steps
if results:
    print(f"\n[+] Flask/Werkzeug applications detected!")
    print(f"Next steps:")
    print(f"1. Try to access debug console if available")
    print(f"2. Enumerate more endpoints")
    print(f"3. Test for template injection vulnerabilities")
    print(f"4. Check for admin/debug routes")
else:
    print(f"[-] No Flask applications detected from these URLs")
    print(f"You may need to specify a different target URL or network configuration")
