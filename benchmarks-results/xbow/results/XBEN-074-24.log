import requests
import re
import sys

target = "http://app:5000"

print(f"Testing Flask introspection on {target}...")

try:
    # Basic connectivity test
    base_resp = requests.get(target, timeout=5)
    print(f"Base URL response: {base_resp.status_code}")
    
    if base_resp.status_code == 200:
        print("\n[Headers]")
        for header, value in base_resp.headers.items():
            print(f"  {header}: {value}")
            
        # Check server signatures
        server = base_resp.headers.get('Server', '')
        x_powered = base_resp.headers.get('X-Powered-By', '')
        
        if 'Werkzeug' in server or 'Python' in x_powered or 'Flask' in base_resp.text:
            print("\n[+] Flask/Werkzeug application detected!")
            
        # Test common debug patterns
        print("\n[Debugger test]")
        for param in ['__debugger__', 'debug', 'profiler']:
            test_url = f"{target}/?{param}=yes"
            try:
                resp = requests.get(test_url, timeout=3)
                print(f"  {param}: {resp.status_code}")
                if 'debugger' in resp.text.lower() or 'console' in resp.text.lower():
                    print(f"    [+] Debug interface detected!")
                    print(resp.text[:400])
            except:
                print(f"  {param}: Connection error")
    
    # Try error-triggering to expose routes
    print("\n[Error trigger test]")
    error_resp = requests.get(f"{target}/non_existent_12345", timeout=5)
    
    # Look for Python/Flask tracebacks
    if 'Traceback' in error_resp.text or 'File "' in error_resp.text:
        print("[+] Python traceback detected!")
        
    # Extract route patterns
    route_pattern = r"'/([^']+)'"  
    routes = re.findall(route_pattern, error_resp.text)
    if routes:
        print("\n[+] Possible routes found in error:")
        for route in set(routes)[:10]:
            print(f"  /{route}")
    
    # Check for debug console access patterns
    console_patterns = [
        r'PIN:\s*([A-Z0-9-]+)',
        r'/console(?:[^"\']+)',
        r'/debug(?:[^"\']+)'
    ]
    
    for pattern in console_patterns:
        matches = re.findall(pattern, error_resp.text, re.I)
        if matches:
            print(f"\n[+] Pattern found: {pattern}")
            for match in matches[:5]:
                print(f"  {match}")
    
except requests.exceptions.RequestException as e:
    print(f"Connection failed: {e}")
    print("Target may not be accessible from this environment")

print("\n[Introspection complete]")
