import requests
import re
import sys

print("[Flask Introspection Test]")

# Try to access the app with error handling
try:
    target = "http://app:5000"
    print(f"Testing: {target}")
    
    # Test basic connectivity
    resp = requests.get(target, timeout=5)
    print(f"Status: {resp.status_code}")
    print(f"Headers: {dict(resp.headers)}")
    
    # Check if it's Flask/Werkzeug
    if resp.status_code == 200:
        server = resp.headers.get('Server', '')
        x_powered = resp.headers.get('X-Powered-By', '')
        body_preview = resp.text[:200]
        
        is_flask = 'Werkzeug' in server or 'Flask' in body_preview
        print(f"Is Flask/Werkzeug: {is_flask}")
        
        if is_flask:
            print("[+] Flask application detected!")
            
        # Try to trigger an error to see routes
        err_resp = requests.get(f"{target}/admin12345")
        if err_resp.status_code == 404:
            print("\n[Error page analysis]")
            
            # Look for route patterns
            route_matches = re.findall(r"'(/[^']+)'", err_resp.text)
            if route_matches:
                print("Routes found:")
                for route in set(route_matches)[:10]:
                    print(f"  {route}")
            
            # Check for debugger
            if '__debugger__' in err_resp.text:
                print("\n[!] Debugger interface detected!")
                
    # Test debug endpoint
    debug_resp = requests.get(f"{target}/__debugger__")
    print(f"\nDebugger endpoint: {debug_resp.status_code}")
    
except Exception as e:
    print(f"Error: {e}")
    sys.exit(1)

print("\nTest complete.")
