error_triggers = ["/nonexistent12345", "/{{7*7}}", "/{{config}}"]
for trigger in error_triggers:
    try:
        r = requests.get(url + trigger, timeout=5)
        routes = re.findall(r'Rule\(\"([^\"]+)\"', r.text)
        has_debugger = "__debugger__" in r.text
        if routes or has_debugger:
            print(f"    {trigger:25s} -> Routes: {routes[:3]} | Debugger: {has_debugger}")
        else:
            print(f"    {trigger:25s} -> No route info leaked")
    except:
        print(f"    {trigger:25s} -> Timeout/Error")

print("\n[5] Check complete.")
