import requests
import re
import json
from urllib.parse import urljoin

base_url = "http://127.0.0.1:33160"
results = {
    "debug_endpoints": {},
    "flask_indicators": [],
    "routes_found": [],
    "debug_pin": None,
    "version_info": {},
    "errors_triggered": {}
}

# Common Flask/Werkzeug debug endpoints to test
debug_endpoints = [
    "/console",
    "/__debug__/console",
    "/__debug__",
    "/debugger",
    "/debug",
    "/admin",
    "/flask",
    "/routes",
    "/env",
    "/config",
    "/.env",
    "/.git/config",
    "/?__debugger__=yes",
    "/?__debugger__=yes&cmd=resource&f=console.html"
]

print("="*60)
print("Flask Application Introspection Scan")
print(f"Target: {base_url}")
print("="*60)

# Test debug endpoints
print("\n[1] Testing Flask/Werkzeug Debug Endpoints:")
print("-" * 60)
for endpoint in debug_endpoints:
    url = urljoin(base_url, endpoint)
    try:
        response = requests.get(url, timeout=5)
        results["debug_endpoints"][endpoint] = {
            "status": response.status_code,
            "length": len(response.content),
            "has_debugger": "Werkzeug Debugger" in response.text or "__debugger__" in response.text,
            "has_console": "console" in response.text.lower() and ("pin" in response.text.lower() or "debugger" in response.text.lower())
        }
        
        print(f"[*] {endpoint:40s} Status: {response.status_code:3d} | Size: {len(response.content):5d}B")
        
        if response.status_code == 200:
            print(f"  [+] 200 OK - Potential exposure!")
        elif response.status_code == 500:
            print(f"  [!] 500 Error - Debugger might be triggered")
        
        # Check for debug pin
        pin_match = re.search(r'PIN:\s*([0-9-]+)', response.text)
        if pin_match:
            results["debug_pin"] = pin_match.group(1)
            print(f"  [!!!] DEBUG PIN FOUND: {pin_match.group(1)}")
        
    except Exception as e:
        print(f"[-] {endpoint:40s} Error: {str(e)}")

# Analyze headers for Flask/Werkzeug signatures
print("\n[2] Analyzing Response Headers:")
print("-" * 60)
try:
    response = requests.get(base_url, timeout=5)
    headers = dict(response.headers)
    
    # Look for Flask/Werkzeug signatures
    flask_indicators = []
    for header_name, header_value in headers.items():
        header_lower = header_value.lower()
        if 'werkzeug' in header_lower or 'flask' in header_lower:
            flask_indicators.append(f"{header_name}: {header_value}")
        if 'python' in header_lower:
            flask_indicators.append(f"{header_name}: {header_value}")
    
    if flask_indicators:
        print("[+] Flask/Werkzeug indicators found in headers:")
        for indicator in flask_indicators:
            print(f"  - {indicator}")
        results["flask_indicators"] = flask_indicators
    else:
        print("[-] No obvious Flask/Werkzeug indicators in headers")
    
    # Check Server header
    server_header = headers.get('Server', '')
    if server_header:
        results["version_info"]['server'] = server_header
        print(f"[+] Server: {server_header}")
    
    # Check X-Powered-By
    powered_by = headers.get('X-Powered-By', '')
    if powered_by:
        results["version_info"]['x_powered_by'] = powered_by
        print(f"[+] X-Powered-By: {powered_by}")
    
    # Set-Cookie might reveal Flask session
    set_cookie = headers.get('Set-Cookie', '')
    if 'session' in set_cookie.lower():
        print(f"[+] Flask session cookie detected: {set_cookie[:80]}...")
        results["flask_indicators"].append(f"Session cookie: {set_cookie.split(';')[0]}")
        
except Exception as e:
    print(f"[-] Error analyzing headers: {str(e)}")

# Try to trigger errors to leak routes
print("\n[3] Triggering Errors to Extract Routes:")
print("-" * 60)
error_tests = [
    "/nonexistent_page_12345",
    "/%00",
    "/?arg=<script>",
    "/admin'",
    "/../../etc/passwd",
    "/{{ 7*7 }}",
    "/{{ config }}",
    "/?__debugger__=yes&cmd=resource&f=console.html",
    "/?__debugger__=yes&cmd=resource&f=debugger.js",
    "/console?test=1"
]

for test_path in error_tests:
    url = urljoin(base_url, test_path)
    try:
        response = requests.get(url, timeout=5)
        
        # Look for route listings in error pages
        route_patterns = [
            r'Rule\(.*\)',
            r'<Rule \'(.*)\'',
            r"Route\(.*\)",
            r'@app\.route\(.*\)',
            r'methods=\[(.*)\]',
            r'endpoint:\s*\'(.*)\''
        ]
        
        routes_found = []
        for pattern in route_patterns:
            matches = re.findall(pattern, response.text)
            if matches:
                routes_found.extend(matches)
        
        if routes_found:
            print(f"[+] Routes leaked from {test_path}:")
            for route in routes_found[:10]:  # Show first 10
                print(f"  - {route}")
            results["errors_triggered"][test_path] = routes_found
            results["routes_found"].extend(routes_found)
        
        # Check for debugger page
        if "Werkzeug Debugger" in response.text or "__debugger__" in response.text:
            print(f"[!] Debugger page triggered at: {test_path}")
            
            # Extract available commands
            cmd_matches = re.findall(r'cmd=([^&\'\"\s]+)', response.text)
            if cmd_matches:
                print(f"  [+] Available debugger commands: {set(cmd_matches)}")
            
            # Look for PIN in debugger page
            pin_match = re.search(r'PIN=\\'([0-9-]+)\\'', response.text)
            if pin_match:
                results["debug_pin"] = pin_match.group(1)
                print(f"  [!!!] DEBUG PIN FOUND: {pin_match.group(1)}")
        
    except Exception as e:
        print(f"[-] Error testing {test_path}: {str(e)}")

# Test for specific Flask config exposure
print("\n[4] Testing for Config/Environment Exposure:")
print("-" * 60)
config_tests = [
    {"url": "/config", "desc": "Config endpoint"},
    {"url": "/?config=1", "desc": "Config parameter"},
    {"url": "/?__debugger__=yes&cmd=resource&f=console.html", "desc": "Debugger console"},
    {"url": "/?debug=1", "desc": "Debug parameter"},
    {"url": "/?traceback=1", "desc": "Traceback parameter"}
]

for test in config_tests:
    url = urljoin(base_url, test["url"])
    try:
        response = requests.get(url, timeout=5)
        
        # Look for config variables
        config_patterns = [
            r'CONFIG\s*=',
            r'config\[.*\]',
            r'FLASK_ENV\s*=\s*[\'"](\w+)[\'"]',
            r'DEBUG\s*=\s*(True|False)',
            r'SECRET_KEY\s*=\s*[\'"](.+)[\'"]',
            r'DATABASE_URL\s*=',
            r'APP_SETTINGS\s*='
        ]
        
        for pattern in config_patterns:
            matches = re.findall(pattern, response.text, re.IGNORECASE)
            if matches:
                print(f"[+] Config exposure in {test['desc']}: {matches[:3]}")
        
    except Exception as e:
        print(f"[-] Error with {test['desc']}: {str(e)}")

# Summary
print("\n" + "="*60)
print("INTROSPECTION SUMMARY")
print("="*60)
print(f"[+] Target: {base_url}")
print(f"[+] Debug endpoints tested: {len(debug_endpoints)}")
print(f"[+] Error triggers tested: {len(error_tests)}")

if results["debug_pin"]:
    print(f"[!!!] CRITICAL: Debug PIN discovered: {results['debug_pin']}")
else:
    print("[-] No debug PIN found")

if results["flask_indicators"]:
    print(f"[+] Flask indicators found: {len(results['flask_indicators'])}")
else:
    print("[-] No Flask indicators in headers")

if results["routes_found"]:
    unique_routes = list(set(results["routes_found"]))
    print(f"[+] Routes discovered: {len(unique_routes)}")
    for route in unique_routes[:10]:
        print(f"  - {route}")
else:
    print("[-] No routes discovered from error pages")

# Print full JSON results for detailed analysis
print("\n[DEBUG] Full Results JSON:")
print(json.dumps(results, indent=2))
