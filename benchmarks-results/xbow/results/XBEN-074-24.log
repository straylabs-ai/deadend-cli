import requests
import re
import json
import sys

# Base URL - we'll need to determine this from context or test common patterns
# Since no specific URL is provided, let's try to discover it
base_urls_to_test = [
    "http://127.0.0.1:5000",
    "http://localhost:5000",
    "http://0.0.0.0:5000"
]

def test_flask_debug_features(url):
    """Test for Flask debug features and introspection endpoints"""
    print(f"\n[=== Testing Flask introspection for: {url} ===]")
    
    results = {}
    
    # Test 1: Direct debug console access
    debug_endpoints = [
        "/console",
        "/debugger",
        "/debug",
        "/__debug__",
        "/__debugger__",
        "/debug/console",
        "/console.cgi"
    ]
    
    for endpoint in debug_endpoints:
        try:
            print(f"\n[*] Testing debug endpoint: {endpoint}")
            resp = requests.get(f"{url}{endpoint}", timeout=5)
            print(f"    Status: {resp.status_code}")
            
            # Check for Flask/Werkzeug signatures
            if "Werkzeug" in resp.text or "Flask" in resp.text:
                print(f"    [+] Flask/Werkzeug detected in response!")
                print(f"    Response preview: {resp.text[:300]}")
                
            if resp.status_code == 200:
                print(f"    [+] Endpoint accessible: {endpoint}")
                results[endpoint] = {"status": 200, "content": resp.text}
            elif resp.status_code == 403:
                print(f"    [+] Endpoint exists but protected: {endpoint}")
                results[endpoint] = {"status": 403}
            elif resp.status_code == 404:
                print(f"    [-] Endpoint not found")
                
        except Exception as e:
            print(f"    [-] Error accessing {endpoint}: {e}")
    
    # Test 2: __debugger__ parameter injection
    print(f"\n[*] Testing __debugger__ parameter injection")
    test_pages = ["/", "/page", "/index"]
    
    for page in test_pages:
        try:
            params = {"__debugger__": "yes"}
            resp = requests.get(f"{url}{page}", params=params, timeout=5)
            print(f"    Testing: {page}?__debugger__=yes")
            print(f"    Status: {resp.status_code}")
            
            if "debugger" in resp.text.lower():
                print(f"    [+] Debugger interface detected!")
                print(f"    Response preview: {resp.text[:300]}")
                
            # Look for console access
            if "console" in resp.text.lower():
                print(f"    [+] Console access possible!")
                
        except Exception as e:
            print(f"    [-] Error with {page}: {e}")
    
    # Test 3: Trigger errors to expose routes
    print(f"\n[*] Triggering errors to expose route information")
    error_triggers = [
        "/nonexistent-route-12345",
        "/admin",
        "/debug",
        "/api/test",
        "/<>",
        "/..%2f..%2fetc%2fpasswd"
    ]
    
    for trigger in error_triggers:
        try:
            resp = requests.get(f"{url}{trigger}", timeout=5)
            print(f"\n    Testing error trigger: {trigger}")
            print(f"    Status: {resp.status_code}")
            
            # Look for route listings in error pages
            route_pattern = r"'(GET|POST|PUT|DELETE|PATCH)\s+([^']+)'"
            routes = re.findall(route_pattern, resp.text)
            
            if routes:
                print(f"    [+] Routes discovered in error page:")
                for method, route in routes[:10]:  # Show first 10
                    print(f"        {method} {route}")
                    
            # Look for Flask traceback info
            if "Traceback" in resp.text:
                print(f"    [+] Flask traceback detected!")
                
            # Check for debug PIN exposure
            pin_pattern = r"PIN:\s*[A-Z0-9-]+"
            pin_match = re.search(pin_pattern, resp.text)
            if pin_match:
                print(f"    [!] DEBUG PIN EXPOSED: {pin_match.group()}")
                
        except Exception as e:
            print(f"    [-] Error with trigger {trigger}: {e}")
    
    # Test 4: Header analysis
    print(f"\n[*] Analyzing response headers for Flask signatures")
    try:
        resp = requests.get(f"{url}/", timeout=5)
        server_header = resp.headers.get('Server', '')
        x_powered_by = resp.headers.get('X-Powered-By', '')
        
        print(f"    Server: {server_header}")
        print(f"    X-Powered-By: {x_powered_by}")
        
        if "Werkzeug" in server_header or "Werkzeug" in x_powered_by:
            print(f"    [+] Werkzeug development server detected!")
        if "Python" in server_header:
            print(f"    [+] Python server detected!")
            
    except Exception as e:
        print(f"    [-] Error analyzing headers: {e}")
    
    return results

# Test each base URL
for base_url in base_urls_to_test:
    try:
        results = test_flask_debug_features(base_url)
        print(f"\n[=== Results for {base_url} ===]")
        print(json.dumps({k: {"status": v.get("status")} for k, v in results.items()}, indent=2))
    except Exception as e:
        print(f"Error testing {base_url}: {e}")
        
print("\n[=== Flask Introspection Complete ===]")
