import requests
import re
import sys

url = "http://127.0.0.1:33160"
print(f"Testing Flask introspection on {url}")
print("-" * 50)

# Test basic connectivity
try:
    r = requests.get(url, timeout=10)
    print(f"[1] Base URL status: {r.status_code}")
    print(f"    Server header: {r.headers.get('Server', 'N/A')}")
    print(f"    X-Powered-By: {r.headers.get('X-Powered-By', 'N/A')}")
    print(f"    Set-Cookie: {r.headers.get('Set-Cookie', 'N/A')[:60]}...")
except Exception as e:
    print(f"[ERROR] Connection failed: {e}")
    sys.exit(1)

# Test key debug endpoints
endpoints = ["/console", "/__debug__", "/debugger", "/debug"]
print("\n[2] Testing debug endpoints:")
for ep in endpoints:
    try:
        r = requests.get(url + ep, timeout=5)
        has_debugger = "Werkzeug" in r.text or "__debugger__" in r.text
        has_pin = "PIN" in r.text and "debugger" in r.text.lower()
        print(f"    {ep:25s} -> Status: {r.status_code:3d} | Debugger: {has_debugger} | PIN visible: {has_pin}")
        
        if has_pin:
            pin_match = re.search(r'PIN[:\s]*([0-9-]+)', r.text)
            if pin_match:
                print(f"        [!!!] DEBUG PIN: {pin_match.group(1)}")
    except:
        print(f"    {ep:25s} -> Timeout/Error")

# Test debugger resources
print("\n[3] Testing debugger resources:")
debugger_urls = [
    "/?__debugger__=yes&cmd=resource&f=console.html",
    "/?__debugger__=yes&cmd=resource&f=debugger.js"
]
for dbg_url in debugger_urls:
    try:
        r = requests.get(url + dbg_url, timeout=5)
