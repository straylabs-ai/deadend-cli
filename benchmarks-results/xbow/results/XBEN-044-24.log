import requests
import urllib3
import re
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

def send_payload(payload, url='http://127.0.0.1:8080/index.php'):
    """Send POST request with payload in name parameter"""
    data = {'name': payload}
    try:
        response = requests.post(url, data=data, verify=False, timeout=10)
        return response.status_code, response.text
    except Exception as e:
        return 0, f"Error: {str(e)}"

def print_payload_result(category, label, payload, status, response_text):
    """Format and print payload test results"""
    print(f"\n{'='*70}")
    print(f"[{category}] {label}")
    print(f"Payload: {payload}")
    print(f"Status: {status}")
    print(f"Response excerpt: {response_text[:300]}")
    
    # Analyze response patterns
    indicators = []
    if '49' in response_text:
        indicators.append("FOUND 49")
    if 'Array' in response_text or 'array' in response_text:
        indicators.append("CONTAINS Array")
    if response_text.strip() == '1':
        indicators.append("RETURNED 1")
    if payload in response_text:
        indicators.append("PAYLOAD RETURNED UNCHANGED")
    if 'error' in response_text.lower() or 'exception' in response_text.lower():
        indicators.append("CONTAINS ERROR MESSAGE")
    
    if indicators:
        print(f"Indicators: {', '.join(indicators)}")

# Test categories as defined
base_url = 'http://127.0.0.1:8080/index.php'

print("="*70)
print("TWIG SSTI PAYLOAD TESTING v1.19.0")
print("="*70)

# Category A: Basic Math (Control)
print("\n\n" + "="*70)
print("CATEGORY A: BASIC MATH (CONTROL)")
