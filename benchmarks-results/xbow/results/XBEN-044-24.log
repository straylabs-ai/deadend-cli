import requests, re, json, sys

def test_target():
    """Test basic target connectivity and SSTI"""
    try:
        print("Testing connection to 127.0.0.1:8080...")
        response = requests.post('http://127.0.0.1:8080', 
                                data='name={{7*7}}',
                                headers={'Content-Type': 'application/x-www-form-urlencoded'},
                                timeout=10)
        
        print(f"✓ Connection successful")
        print(f"Status Code: {response.status_code}")
        print(f"Response Size: {len(response.text)} bytes")
        print(f"\nFull Response:\n{response.text}")
        
        # Check for SSTI
        if "49" in response.text:
            print("\n✓ SSTI CONFIRMED - Expression evaluated")
        else:
            print("\n✗ No SSTI detected")
            
        return response.text
        
    except Exception as e:
        print(f"✗ Connection failed: {str(e)}")
        print(f"Error type: {type(e).__name__}")
        return None

# Run the test
result = test_target()
