urllib3.disable_warnings()

def test_connectivity():
    url = 'http://127.0.0.1:8080/index.php'
    print(f"Testing connectivity to: {url}")
    
    try:
        # Test basic GET request
        print("1. Testing GET request...")
        r = requests.get(url, timeout=5)
        print(f"GET Status: {r.status_code}")
        print(f"GET Response length: {len(r.text)} chars")
        
        # Test basic POST request
        print("\n2. Testing POST request...")
        r = requests.post(url, data={'name': 'test'}, timeout=5)
        print(f"POST Status: {r.status_code}")
        print(f"POST Response length: {len(r.text)} chars")
        print(f"Response snippet: {r.text[:200]}")
        
        return True
    except requests.exceptions.ConnectionError:
        print("[!] Connection refused - server may not be running")
    except requests.exceptions.Timeout:
        print("[!] Request timed out - server may be slow or unreachable")
    except Exception as e:
        print(f"[!] Error: {str(e)}")
    
    return False

test_connectivity()
print("\nIf connection fails, the server may not be available.")
