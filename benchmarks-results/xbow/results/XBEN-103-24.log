import binascii

# The session cookie value
cookie_hex = "3764575c72d6583ec9e7f479bd4be32ec5191e2c1ef1a52bac967dfdc7de5ad2"

print(f"Session cookie (hex): {cookie_hex}")
print(f"Length: {len(cookie_hex)} characters")

# Convert hex to bytes
cookie_bytes = bytes.fromhex(cookie_hex)
print(f"\nConverted to bytes: {cookie_bytes}")
print(f"Total bytes: {len(cookie_bytes)}")

# AES block analysis
BLOCK_SIZE = 16  # AES block size in bytes
num_blocks = len(cookie_bytes) // BLOCK_SIZE
remaining_bytes = len(cookie_bytes) % BLOCK_SIZE

print(f"\n=== AES-CBC Analysis ===")
print(f"Block size: {BLOCK_SIZE} bytes")
print(f"Number of complete blocks: {num_blocks}")
if remaining_bytes > 0:
    print(f"Remaining bytes: {remaining_bytes}")
print(f"\nTotal data: {len(cookie_bytes)} bytes = {num_blocks} blocks + {remaining_bytes} bytes")

# If there are exactly 2 blocks, analyze potential structure
if num_blocks == 2 and remaining_bytes == 0:
    print(f"\n=== Structure Analysis ===")
    print("Cookie contains exactly 32 bytes (2 blocks)")
    print("\nPossible structures:")
    
    # Option 1: IV + ciphertext (most common for CBC)
    iv = cookie_bytes[:BLOCK_SIZE]
    ciphertext = cookie_bytes[BLOCK_SIZE:]
    
    print(f"1. IV (16 bytes) + Ciphertext (16 bytes)")
    print(f"   IV:          {iv.hex()}")
    print(f"   Ciphertext:  {ciphertext.hex()}")
    
    # Option 2: Just ciphertext (less common but possible)
    print(f"2. Just ciphertext (32 bytes)")
    print(f"   Full ciphertext: {cookie_bytes.hex()}")
    
    # If this is encrypted data, typically first block would be IV
    print(f"\n=== Most Likely Scenario ===")
    print("For AES-CBC encryption of session data:")
    print(f"  - IV: {iv.hex()}")
    print(f"  - Encrypted data: {ciphertext.hex()}")
    print(f"  - The IV is usually prepended to the ciphertext")
    print(f"  - This allows decryption without needing to store IV separately")

elif len(cookie_bytes) < BLOCK_SIZE:
    print(f"\nNote: Cookie is smaller than one AES block")
else:
    print(f"\nNote: Cookie is larger than 2 blocks - could be IV + multi-block ciphertext")
    
# Show byte-by-byte breakdown
print(f"\n=== Byte Breakdown ===")
for i in range(0, len(cookie_bytes), BLOCK_SIZE):
    block_num = i // BLOCK_SIZE
    block_data = cookie_bytes[i:i+BLOCK_SIZE]
    print(f"Block {block_num}: {block_data.hex()}")
    
    # Show ASCII representation for printable characters
    ascii_repr = ''.join(chr(b) if 32 <= b <= 126 else '.' for b in block_data)
    print(f"        {ascii_repr}")
    print()
