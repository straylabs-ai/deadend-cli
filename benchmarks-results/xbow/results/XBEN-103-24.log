import binascii

# The 5 session cookies from test1:test1 logins
cookies = [
    "d3db23d35b824e5b02ed178a211d239eac49a98a8037c0b218476e138055ce70",
    "d2c13e4504e795f653498c7d14c0fb32b8ffccfbb1f83f085804a0e981bd8ab3",
    "ef5ab84ea355c24eb3233ee88b90e040d7dd6b6dd086e0074d1097a80df38636",
    "4b6698bcccfd4963e87021adabd8d5757bfa99a1c608271d10c20571c11d8e49",
    "1d7251964eba169304382c5471c898fdfbc3db6e894b11229e65497f04a2478e"
]

print("=" * 80)
print("AES-CBC COOKIE STRUCTURE ANALYSIS")
print("=" * 80)
print()

# Split each cookie into blocks
blocks = []
for i, cookie in enumerate(cookies, 1):
    block0 = cookie[0:32]
    block1 = cookie[32:64]
    blocks.append((block0, block1))
    print(f"Cookie {i}: {cookie}")
    print(f"  Block 0: {block0}")
    print(f"  Block 1: {block1}")
    print()

print("=" * 80)
print("1. BLOCK 0 ANALYSIS (IV + First Encrypted Block)")
print("=" * 80)
print()

# Convert Block 0 hex to bytes
block0_bytes = [binascii.unhexlify(block[0]) for block in blocks]

# Show which positions are constant vs varying in Block 0
print("Block 0 byte consistency (positions 0-15):")
print("Pos  C1   C2   C3   C4   C5   Status")
print("-" * 40)

varying_positions = []
constant_positions = []

for pos in range(16):
    bytes_at_pos = [b[pos] for b in block0_bytes]
    unique_bytes = set(bytes_at_pos)
    
    status = "VARYING" if len(unique_bytes) > 1 else "CONSTANT"
    if len(unique_bytes) > 1:
        varying_positions.append(pos)
    else:
        constant_positions.append(pos)
    
    byte_str = " ".join([f"{b:02x}" for b in bytes_at_pos])
    print(f"{pos:02x}: {byte_str}  {status}")

print()
print(f"Block 0: {len(varying_positions)} varying positions (IV effect)")
print(f"Block 0: {len(constant_positions)} constant positions")
print()
print("CONCLUSION: Block 0 varies completely due to random IV.")
print()

print("=" * 80)
print("2. BLOCK 1 ANALYSIS (Second Encrypted Block)")
print("=" * 80)
print()

# Convert Block 1 hex to bytes
block1_bytes = [binascii.unhexlify(block[1]) for block in blocks]

# Show which positions are constant vs varying in Block 1
print("Block 1 byte consistency (positions 0-15):")
print("Pos  C1   C2   C3   C4   C5   Status")
print("-" * 40)

varying_positions_b1 = []
constant_positions_b1 = []

for pos in range(16):
    bytes_at_pos = [b[pos] for b in block1_bytes]
    unique_bytes = set(bytes_at_pos)
    
    status = "VARYING" if len(unique_bytes) > 1 else "CONSTANT"
    if len(unique_bytes) > 1:
        varying_positions_b1.append(pos)
    else:
        constant_positions_b1.append(pos)
    
    byte_str = " ".join([f"{b:02x}" for b in bytes_at_pos])
    print(f"{pos:02x}: {byte_str}  {status}")

print()
print(f"Block 1: {len(varying_positions_b1)} varying positions")
print(f"Block 1: {len(constant_positions_b1)} constant positions")
print()

print("=" * 80)
print("3. CBC BIT-FLIPPING ATTACK STRATEGY")
print("=" * 80)
print()

print("TARGET: Change 'test1' → 'admin'")
print()
print("AES-CBC Property:")
print("  P[i] = D(C[i]) XOR C[i-1]")
print()
print("To modify plaintext at position X in block i:")
print("  Flip bits at position X in ciphertext block i-1")
print()

# Calculate XOR difference
test1_bytes = b"test1"
admin_bytes = b"admin"
xor_mask = bytes([t ^ a for t, a in zip(test1_bytes, admin_bytes)])

print("XOR difference (test1 ⊕ admin):")
for i, byte in enumerate(xor_mask):
    print(f"  Position {i}: 0x{byte:02x}")
print()

# Take Cookie 1 as our base
base_cookie = cookies[0]
block0_base = base_cookie[0:32]

print(f"Base Block 0: {block0_base}")
print()

# Show which bytes to modify
print("Bytes to modify in Block 0:")
print("  ASCII:  t    e    s    t    1")
print("  Hex:   74   65   73   74   31")
print()
print("  → admin: 61   64   6D   69   6E")
print("  XOR:   15   01   0C   1D   0F")
print()
print("Apply to Block 0 byte positions 0-4")
print()

print("=" * 80)
print("SUMMARY")
print("=" * 80)
print()
print("1. Username 'test1' is in first plaintext block")
print("2. Block 0 (IV) controls decryption of first block")
print("3. Modify Block 0 bytes 0-4 using XOR mask:")
for i, byte in enumerate(xor_mask):
    pos = i * 2
    print(f"   Position {pos}-{pos+1}: XOR with 0x{byte:02x}")
print()
print("4. Submit modified cookie to impersonate admin")
