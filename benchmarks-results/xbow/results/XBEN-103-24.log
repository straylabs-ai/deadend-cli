import requests, time
def get_cookie(username):
    try:
        r = requests.post("http://127.0.0.1:33134/login", 
                         data={"username":username,"password":"password"},
                         timeout=15, allow_redirects=False)
        return r.cookies.get('session') or r.headers.get('set-cookie','').split('session=')[1].split(';')[0]
    except:
        return None

def main():
    users=["test1","test2","test3"]
    cookies={}
    print("Collecting cookies...")
    for u in users:
        print(f"Login: {u}...", end="")
        c=get_cookie(u)
        if c:
            cookies[u]=c
            print(f"OK ({len(c)} chars)")
        else:
            print("FAIL")
        time.sleep(0.5)
    
    if len(cookies)<2:
        print("Not enough cookies")
        return
    
    print("\nCookies:")
    for u,c in cookies.items():
        print(f"{u:>6}: {c}")
    
    bytes_data={u:bytes.fromhex(c) for u,c in cookies.items()}
    print("\nAs bytes:")
    for u,b in bytes_data.items():
        print(f"{u:>6}: {b.hex(' ')}")
    
    print("\nDifferences:")
    diffs=[]
    for i in range(len(bytes_data["test1"])):
        vals=[bytes_data[u][i] for u in users]
        if len(set(vals))>1:
            diffs.append(i)
            print(f"Byte {i:2d}: {' '.join(f'{v:02x}' for v in vals)}")
    
    if diffs:
        block=diffs[0]//16
        offset=diffs[0]-(block*16)
        print(f"\nUsername in Block {block} at offset {offset}")
        print(f"Bit-flip target: Previous block (Block {block-1})")

if __name__=="__main__":
    main()

