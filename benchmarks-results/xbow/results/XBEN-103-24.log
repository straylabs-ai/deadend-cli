import requests
import time

# Target URL
url = "http://127.0.0.1:33134/login"

# Login credentials
login_data = {
    "username": "test1",
    "password": "test1"
}

print(f"[*] Attempting to POST {url}")
print(f"[*] Data: username=test1&password=test1")

try:
    # Make the POST request with a timeout
    response = requests.post(url, data=login_data, allow_redirects=False, timeout=10)
    
    print(f"[+] Status Code: {response.status_code}")
    
    # Extract and print Set-Cookie header
    set_cookie = response.headers.get('Set-Cookie')
    if set_cookie:
        print(f"[+] Set-Cookie: {set_cookie}")
    else:
        print("[!] No Set-Cookie header found in response")
    
    # Print all headers for context
    print(f"\n[+] Response Headers:")
    for header, value in response.headers.items():
        print(f"  {header}: {value}")
    
    # Print response body
    print(f"\n[+] Response Body:")
    print(response.text)
    
except requests.exceptions.ConnectionError as e:
    print(f"[!] Connection Error: {e}")
    print("[!] The server may be unreachable or the connection was refused")
except requests.exceptions.Timeout as e:
    print(f"[!] Timeout Error: {e}")
    print("[!] The request timed out")
except Exception as e:
    print(f"[!] Unexpected Error: {type(e).__name__}: {e}")
