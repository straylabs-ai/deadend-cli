block_size = 16
num_blocks = len(cookie_bytes) // block_size

print(f"=== SESSION COOKIE STRUCTURE ANALYSIS ===")
print(f"Hex value: {cookie_hex}")
print(f"Length: {len(cookie_hex)} characters")
print(f"Byte count: {len(cookie_bytes)} bytes")
print(f"\n=== AES-CBC BLOCK ANALYSIS ===")
