import requests
import time
import sys

def get_session_cookie(username, password="password"):
    """Login and extract session cookie"""
    url = "http://127.0.0.1:33134/login"
    data = {"username": username, "password": password}
    
    try:
        response = requests.post(url, data=data, timeout=10)
        # Try to get session from response cookies
        session_cookie = response.cookies.get('session')
        if session_cookie:
            return session_cookie
        
        # Try to extract from Set-Cookie header
        if 'set-cookie' in response.headers:
            cookie_str = response.headers['set-cookie']
            if 'session=' in cookie_str:
                session_val = cookie_str.split('session=')[1].split(';')[0]
                return session_val
                
    except Exception as e:
        print(f"Error for {username}: {e}")
    
    return None

def analyze_cookie_structure():
    usernames = ["test1", "test2", "test3"]
    cookies = {}
    
    print("Collection session cookies...")
    for username in usernames:
        print(f"Login as: {username}")
        cookie = get_session_cookie(username)
        if cookie:
            cookies[username] = cookie
            print(f"  Cookie: {cookie}")
        else:
            print(f"  [!] Failed")
        time.sleep(0.5)
    
    if len(cookies) < 2:
        print("Not enough cookies collected")
        return
    
    print("\n" + "="*60)
    print("COOKIE SAMPLES:")
    print("="*60)
    for u, c in cookies.items():
        print(f"{u:6}: {c}")
    
    # Convert to bytes
    byte_data = {}
    for u, c in cookies.items():
        byte_data[u] = bytes.fromhex(c)
    
    # Compare byte by byte
    print("\n" + "="*60)
    print("BYTE COMPARISON:")
    print("="*60)
    print("Pos | test1 | test2 | test3 | Diff")
    print("-"*60)
    
    diff_positions = []
    for i in range(len(byte_data["test1"])):
        b1 = byte_data["test1"][i]
        b2 = byte_data["test2"][i]
        b3 = byte_data["test3"][i]
        
        if b1 != b2 or b1 != b3:
            diff_positions.append(i)
            print(f"{i:3} |  {b1:02x}   |  {b2:02x}   |  {b3:02x}   |  <-- DIFFERENT")
    
    print("\nDifferences at positions:", diff_positions)
    print(f"Total different bytes: {len(diff_positions)}")
    
    # Block analysis (16-byte blocks for AES-CBC)
    print("\n" + "="*60)
    print("BLOCK ANALYSIS (AES-CBC 16-byte blocks):")
    print("="*60)
    
    BLOCK_SIZE = 16
    for block in range(2):  # 32 bytes = 2 blocks
        start = block * BLOCK_SIZE
        end = start + BLOCK_SIZE - 1
        block_diffs = [p for p in diff_positions if start <= p <= end]
        
        print(f"\nBlock {block} (bytes {start}-{end}):")
        if block_diffs:
            print(f"  Username appears here: positions {block_diffs}")
            offset = block_diffs[0] - start
            print(f"  Field offset in block: {offset}")
            print(f"  Field length: {len(block_diffs)} bytes")
        else:
            print(f"  No username data (likely IV/padding/metadata)")
    
    # Summary for exploit
    print("\n" + "="*60)
    print("EXPLOIT SUMMARY:")
    print("="*60)
    if diff_positions:
        block_num = diff_positions[0] // BLOCK_SIZE
        offset = diff_positions[0] - (block_num * BLOCK_SIZE)
        print(f"Target: Block {block_num} (16-byte block)")
        print(f"Position: Byte offset {offset} within block")
        print(f"Username: " + " ".join(["%02x" % byte_data["test1"][p] for p in diff_positions]))
    
    return cookies

if __name__ == "__main__":
    analyze_cookie_structure()
