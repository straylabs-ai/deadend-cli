    print(f"Block 1 (Ciphertext): {ciphertext.hex()}")
    print(f"\nMost likely structure: IV (16 bytes) + Ciphertext (16 bytes)")
    print("This is standard for AES-CBC where IV is prepended to ciphertext.")
