import socket,requests,time,sys

def test_connectivity():
    host,port="127.0.0.1",33134
    print(f"Testing {host}:{port}...")
    sock=socket.socket()
    sock.settimeout(3)
    try:
        r=sock.connect_ex((host,port))
        sock.close()
        return r==0
    except:return False

def get_cookie(username):
    try:
        r=requests.post(f"http://127.0.0.1:{33134}/login",
                       data={'username':username,'password':'password'},
                       timeout=5,allow_redirects=False)
        return r.cookies.get('session')
    except Exception as e:
        print(f"Error: {e}")
        return None

def main():
    print("="*60)
    print("COOKIE STRUCTURE ANALYSIS")
    print("="*60)
    
    if not test_connectivity():
        print("\n[!] Cannot connect to 127.0.0.1:33134")
        sys.exit(1)
    
    users=['test1','test2','test3']
    cookies={}
    
    print("\nCollecting cookies...")
    for u in users:
        c=get_cookie(u)
        if c:
            cookies[u]=c
            print(f"{u}: {c[:32]}...({len(c)} chars)")
        time.sleep(0.3)
    
    if len(cookies)<2:
        print("\n[!] Insufficient cookies")
        return
    
    print("\n"+"="*60)
    print("ANALYSIS")
    print("="*60)
    
    bytes_data={u:bytes.fromhex(c) for u,c in cookies.items()}
    
    print("\nBytes (hex):")
    for u,b in bytes_data.items():
        print(f"{u}: {' '.join(f'{x:02x}' for x in b[:16])}")
        print(f"   {' '.join(f'{x:02x}' for x in b[16:])}")
    
    print("\nDifferences:")
    diffs=[]
    for i in range(len(list(bytes_data.values())[0])):
        vals=[bytes_data[u][i] for u in users if u in bytes_data]
        if len(set(vals))>1:
            diffs.append(i)
            print(f"Byte {i:2d}: {' '.join(f'{v:02x}' for v in vals)}")
    
    if diffs:
        block=diffs[0]//16
        offset=diffs[0]-(block*16)
        print(f"\n{'='*60}")
        print("RESULTS:")
        print(f"{'='*60}")
        print(f"Username in Block {block} (bytes {block*16}-{block*16+15})")
        print(f"Offset within block: {offset}")
        print(f"Bit-flip target: Previous block (Block {block-1})")
        print(f"Different bytes: {diffs}")

if __name__=="__main__":
    try:
        main()
    except Exception as e:
        print(f"Fatal error: {e}")
        sys.exit(1)
