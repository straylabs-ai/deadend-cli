import requests
import time

def get_session_cookie(username, password="password"):
    """Login and extract session cookie"""
    url = "http://127.0.0.1:33134/login"
    data = {
        "username": username,
        "password": password
    }
    
    try:
        response = requests.post(url, data=data, allow_redirects=False)
        if 'set-cookie' in response.headers or 'session' in str(response.headers):
            cookies = response.headers.get('set-cookie', '')
            # Extract session cookie value
            for cookie_str in cookies.split(','):
                if 'session=' in cookie_str:
                    session_val = cookie_str.split('session=')[1].split(';')[0]
                    return session_val
        
        # Also check if cookie is accessible via cookies jar
        if response.cookies:
            session_cookie = response.cookies.get('session')
            if session_cookie:
                return session_cookie
                
        return None
    except Exception as e:
        print(f"[!] Error getting cookie for {username}: {e}")
        return None

# Collect cookies for different usernames
usernames = ["test1", "test2", "test3"]
cookies = {}

print("[*] Collecting session cookies for different usernames...\n")

for username in usernames:
    print(f"[+] Logging in as: {username}")
    cookie = get_session_cookie(username)
    if cookie:
        cookies[username] = cookie
        print(f"    Cookie: {cookie}")
        print(f"    Length: {len(cookie)} chars")
        # Show as bytes for analysis
        cookie_bytes = bytes.fromhex(cookie)
        print(f"    As bytes: {cookie_bytes.hex()} ({len(cookie_bytes)} bytes)")
        print()
    else:
        print(f"    [!] Failed to get cookie")
        print()
    time.sleep(0.5)  # Be polite

print("=" * 80)
print("COOKIE ANALYSIS")
print("=" * 80)
print()

# Verify we have cookies
if len(cookies) < 2:
    print(f"[!] Only collected {len(cookies)} cookies, need at least 2 for comparison")
    exit()

# Show cookie samples
for username, cookie in cookies.items():
    print(f"Cookie for {username:>6s}: {cookie}")

print()

# Convert to byte arrays for comparison
byte_arrays = {}
for username, cookie in cookies.items():
    byte_arrays[username] = bytes.fromhex(cookie)

# Byte-by-byte comparison
print("BYTE-BY-BYTE COMPARISON")
print("-" * 80)
print("Byte | test1  | test2  | test3  | Differences")
print("-" * 80)

diff_positions = []
for i in range(len(byte_arrays["test1"])):
    bytes_at_position = []
    for username in usernames:
        if i < len(byte_arrays[username]):
            bytes_at_position.append(byte_arrays[username][i])
    
    all_same = all(b == bytes_at_position[0] for b in bytes_at_position)
    
    byte_str = str(i).rjust(3)
    hex_values = [f"{b:02x}" for b in bytes_at_position]
    diff_marker = " <-- DIFFERENT" if not all_same else ""
    
    if not all_same:
        diff_positions.append(i)
        print(f"{byte_str} |   {hex_values[0]}    |   {hex_values[1]}    |   {hex_values[2]}    |  {diff_marker}")
    else:
        print(f"{byte_str} |   {hex_values[0]}    |   {hex_values[1]}    |   {hex_values[2]}    |")

print("-" * 80)
print()

# Block analysis (AES-CBC uses 16-byte blocks)
BLOCK_SIZE = 16
num_blocks = len(byte_arrays["test1"]) // BLOCK_SIZE

print("BLOCK MAPPING ANALYSIS")
print(f"Block size: {BLOCK_SIZE} bytes")
print(f"Total blocks: {num_blocks}")
print(f"Total cookie bytes: {len(byte_arrays['test1'])}")
print()

for block_num in range(num_blocks):
    start_byte = block_num * BLOCK_SIZE
    end_byte = start_byte + BLOCK_SIZE - 1
    block_diffs = [pos for pos in diff_positions if start_byte <= pos <= end_byte]
    
    print(f"Block {block_num}: bytes {start_byte:2d}-{end_byte:2d}")
    if block_diffs:
        print(f"  -> Contains username: bytes {block_diffs} differ between users")
    else:
        print(f"  -> No differences (likely metadata/integrity)")
    print()

# Analyze specific differences
print("DETAILED DIFFERENCE ANALYSIS")
print("-" * 80)
print(f"Total different bytes: {len(diff_positions)}")
print(f"Positions: {diff_positions}")
print()

# Show what we can infer about username encoding
print("INFERENCES ABOUT USERNAME ENCODING")
print("-" * 80)
print("Username changes detected at bytes:", " , ".join(map(str, diff_positions)))

# Check if positions are contiguous (indicates username in one place)
is_contiguous = len(diff_positions) >= 1 and \
                all(diff_positions[i] - diff_positions[i-1] == 1 
                   for i in range(1, len(diff_positions)))

if is_contiguous:
    print("Username appears in CONTIGUOUS bytes (good for exploitation)")
    username_block = diff_positions[0] // BLOCK_SIZE
    print(f"Username in Block {username_block} (bytes {diff_positions[0]}-{diff_positions[-1]})")
else:
    print("Username appears in DISPERSED bytes (may be encoded/complex)")

# Estimate username field position in block
if diff_positions:
    first_diff = diff_positions[0]
    field_offset = first_diff - (first_diff // BLOCK_SIZE * BLOCK_SIZE)
    print(f"Username field starts at offset {field_offset} within its block")
    print(f"Username length: approximately {len(diff_positions)} bytes")

print("-" * 80)
print()
print("[!] Cookie structure analysis complete!")
print("[!] Ready for CBC bit flipping exploit targeting identified block.")
