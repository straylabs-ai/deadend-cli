import binascii

# Original cookie from test1:test1 login
original_cookie = "d3db23d35b824e5b02ed178a211d239eac49a98a8037c0b218476e138055ce70"

# Split into blocks
block_0 = original_cookie[0:32]  # IV block
block_1 = original_cookie[32:64]  # Ciphertext block

print(f"Original cookie: {original_cookie}")
print(f"Block 0 (IV):    {block_0}")
print(f"Block 1 (data):  {block_1}")
print()

# Original username and target username
original_username = "test1"
target_username = "admin"

print(f"Original username: '{original_username}'")
print(f"Target username:   '{target_username}'")
print()

# Convert to bytes
original_bytes = original_username.encode('ascii')
target_bytes = target_username.encode('ascii')

print(f"Original bytes (hex): {[hex(b) for b in original_bytes]}")
print(f"Target bytes (hex):   {[hex(b) for b in target_bytes]}")
print()

# Calculate XOR mask (difference between original and target)
xor_mask = [o ^ t for o, t in zip(original_bytes, target_bytes)]
print(f"XOR mask:            {[hex(b) for b in xor_mask]}")
print()

# Convert Block 0 from hex to bytes
block_0_bytes = bytes.fromhex(block_0)
print(f"Block 0 original bytes: {[hex(b) for b in block_0_bytes[:5]]}... (showing first 5)")

# Apply XOR mask to first 5 bytes of Block 0
modified_block_0_bytes = bytearray(block_0_bytes)
for i in range(5):
    modified_block_0_bytes[i] ^= xor_mask[i]

print(f"Block 0 modified bytes: {[hex(b) for b in modified_block_0_bytes[:5]]}... (showing first 5)")
print()

# Convert back to hex
modified_block_0 = modified_block_0_bytes.hex()

# Construct full modified cookie
modified_cookie = modified_block_0 + block_1

print("=" * 80)
print("RESULTS")
print("=" * 80)
print(f"Original cookie: {original_cookie}")
print(f"Modified cookie: {modified_cookie}")
print()
print("Byte-by-byte comparison of Block 0:")
print(f"Original: {[hex(b) for b in block_0_bytes[:5]]}")
print(f"Modified: {[hex(b) for b in modified_block_0_bytes[:5]]}")
print()
print("XOR mask applied: [0x15, 0x01, 0x0c, 0x1d, 0x0f]")
print()
print("Verification:")
for i in range(5):
    orig_byte = block_0_bytes[i]
    mask_byte = xor_mask[i]
    new_byte = modified_block_0_bytes[i]
    calc_byte = orig_byte ^ mask_byte
    print(f"  Byte {i}: 0x{orig_byte:02x} XOR 0x{mask_byte:02x} = 0x{new_byte:02x} {'✓' if new_byte == calc_byte else '✗'}")
