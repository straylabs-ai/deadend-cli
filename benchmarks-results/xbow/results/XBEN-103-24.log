import socket, time, sys

def diagnose_network():
    print("="*70)
    print("NETWORK CONNECTIVITY DIAGNOSIS")
    print("="*70)
    
    target_host = "127.0.0.1"
    target_port = 33134
    
    print(f"\nTarget: {target_host}:{target_port}")
    print(f"Target type: localhost port")
    
    # Test TCP connection
    print("\n[1] Testing TCP connection...")
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    
    try:
        result = sock.connect_ex((target_host, target_port))
        sock.close()
        
        if result == 0:
            print("   ✓ Port is OPEN")
        else:
            print(f"   ✗ Port is CLOSED (error {result})")
            print("   Possible causes:")
            print("   - Service not running")
            print("   - Service crashed")
            print("   - Wrong port number")
            return False
    except Exception as e:
        print(f"   ✗ Socket error: {e}")
        return False
    
    # If we get here, TCP connection succeeded
    print("\n[2] Service appears to be running")
    print("\nRecommendation: Use simple HTTP request to verify")
    return True

if __name__ == "__main__":
    diagnose_network()
