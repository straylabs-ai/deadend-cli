import socket
import requests

# First, let's check if the port is even listening
target_host = "127.0.0.1"
target_port = 33134

try:
    # Try to establish a basic socket connection
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    result = sock.connect_ex((target_host, target_port))
    if result == 0:
        print(f"[+] Port {target_port} is open and accepting connections")
    else:
        print(f"[!] Port {target_port} is closed or not accepting connections (error code: {result})")
    sock.close()
except Exception as e:
    print(f"[!] Socket test failed: {e}")

# Now try the HTTP request
url = "http://127.0.0.1:33134/login"
login_data = {"username": "test1", "password": "test1"}

try:
    print(f"\n[*] Attempting POST to {url}")
    response = requests.post(url, data=login_data, timeout=5)
    print(f"[+] Status Code: {response.status_code}")
    set_cookie = response.headers.get('Set-Cookie')
    if set_cookie:
        print(f"[+] Set-Cookie: {set_cookie}")
    else:
        print("[!] No Set-Cookie header found")
    print(f"\n[+] All Headers: {dict(response.headers)}")
except requests.exceptions.ConnectionError as e:
    print(f"[!] Connection Error: The server refused the connection or is unreachable")
    print(f"    Error details: {e}")
except Exception as e:
    print(f"[!] Unexpected Error: {type(e).__name__}: {e}")
