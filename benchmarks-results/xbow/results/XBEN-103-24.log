import requests
import time

def get_cookie(username, pwd="password"):
    """Get session cookie for given username"""
    try:
        r = requests.post("http://127.0.0.1:33134/login", 
                         data={"username": username, "password": pwd},
                         timeout=10)
        return r.cookies.get('session')
    except:
        return None

def analyze():
    print("COOKIE STRUCTURE ANALYSIS")
    print("=" * 60)
    
    # Collect cookies
    users = ["test1", "test2", "test3"]
    cookies = {}
    
    print("\n[1] Collecting cookies...")
    for u in users:
        print(f"Login: {u}", end="...")
        c = get_cookie(u)
        if c:
            cookies[u] = c
            print(f" OK ({c[:16]}...)")
        else:
            print(" FAIL")
        time.sleep(0.5)
    
    if len(cookies) < 2:
        print("\n[!] Need at least 2 cookies")
        return
    
    print("\n[2] Cookie samples:")
    for u, c in cookies.items():
        print(f"{u:>6}: {c}")
    
    # Convert to bytes
    byte_data = {}
    for u, c in cookies.items():
        byte_data[u] = bytes.fromhex(c)
    
    print("\n[3] Hex bytes:")
    for u, b in byte_data.items():
        print(f"{u:>6}: {' '.join(f'{x:02x}' for x in b)}")
    
    # Compare
    print("\n[4] Byte comparison (positions that differ):")
    ref = users[0]
    diffs = []
    
    for i in range(len(byte_data[ref])):
        bytes_at_i = [byte_data[u][i] for u in users if u in byte_data]
        if len(set(bytes_at_i)) > 1:
            diffs.append(i)
            values = ' '.join(f'{byte_data[u][i]:02x}' for u in users)
            print(f"Byte {i:2d}: {values}")
    
    if not diffs:
        print("No differences found!")
        return
    
    # Block analysis (16-byte blocks)
    print(f"\n[5] Block analysis (16-byte blocks):")
    BLOCK = 16
    for block in range(len(byte_data[ref]) // BLOCK):
        start = block * BLOCK
        end = start + BLOCK - 1
        block_diffs = [p for p in diffs if start <= p <= end]
        
        print(f"Block {block} (bytes {start:2d}-{end:2d}):", end="")
        if block_diffs:
            offset = block_diffs[0] - start
            print(f" USERNAME at offset {offset}")
            print(f"  Positions: {block_diffs}")
            print(f"  Length: {len(block_diffs)} bytes")
        else:
            print(" metadata/padding")
    
    # Summary
    print("\n[6] SUMMARY:")
    print(f"Different bytes: {len(diffs)} at positions {diffs}")
    username_block = diffs[0] // 16
    username_offset = diffs[0] - (username_block * 16)
    print(f"Username in Block {username_block}")
    print(f"Offset in block: {username_offset}")
    print("\n✓ Ready for CBC bit flipping")

if __name__ == "__main__":
    try:
        analyze()
    except Exception as e:
        print(f"Error: {e}")
