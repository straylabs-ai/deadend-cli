import binascii

# The session cookie value
cookie_hex = "3764575c72d6583ec9e7f479bd4be32ec5191e2c1ef1a52bac967dfdc7de5ad2"

print(f"Session cookie (hex): {cookie_hex}")
print(f"Length: {len(cookie_hex)} characters")

# Convert hex to bytes
cookie_bytes = bytes.fromhex(cookie_hex)
print(f"\nTotal bytes: {len(cookie_bytes)}")

# AES block analysis
BLOCK_SIZE = 16  # AES-CBC uses 16-byte blocks
num_blocks = len(cookie_bytes) // BLOCK_SIZE
remaining_bytes = len(cookie_bytes) % BLOCK_SIZE

print(f"\nAES-CBC Analysis:")
print(f"Block size: {BLOCK_SIZE} bytes")
print(f"Number of blocks: {num_blocks}")
print(f"Remaining bytes: {remaining_bytes}")
print(f"Total: {len(cookie_bytes)} bytes")

if num_blocks == 2 and remaining_bytes == 0:
    print(f"\nThis cookie contains exactly 2 blocks (32 bytes)")
    
    # Most likely structure: IV + ciphertext
    iv = cookie_bytes[:BLOCK_SIZE]
    ciphertext = cookie_bytes[BLOCK_SIZE:]
    
    print(f"\nMost likely structure for AES-CBC:")
    print(f"Block 0 (IV):         {iv.hex()}")
    print(f"Block 1 (Ciphertext): {ciphertext.hex()}")
    
    print(f"\nThis is a common pattern where:")
    print(f"1. A random 16-byte IV is generated")
    print(f"2. The session data is encrypted with CBC mode")
    print(f"3. The IV is prepended to the ciphertext")
    print(f"4. The combined value is hex-encoded for the cookie")
    
    # Show the structure visually
    print(f"\nStructure: [IV (16 bytes)][Ciphertext (16 bytes)]")
    print(f"           [{iv.hex()}][{ciphertext.hex()}]")

# Show each block separately
print(f"\nBlock breakdown:")
for i in range(0, len(cookie_bytes), BLOCK_SIZE):
    block_num = i // BLOCK_SIZE
    block = cookie_bytes[i:i+BLOCK_SIZE]
    print(f"Block {block_num}: {block.hex()}")
