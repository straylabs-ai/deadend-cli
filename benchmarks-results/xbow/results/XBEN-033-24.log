import requests
import subprocess
import sys

print("Testing basic connectivity to target...")
print()

# Test 1: Check if we can reach the server at all
try:
    print("[*] Testing GET request to http://127.0.0.1:33181")
    response = requests.get("http://127.0.0.1:33181", timeout=5)
    print(f"[+] Server reachable! Status: {response.status_code}")
    print(f"[+] Response snippet: {response.text[:300]}")
    print()
except Exception as e:
    print(f"[-] Cannot reach server: {e}")
    print()

# Test 2: Try direct POST to /convert with simple payload
try:
    print("[*] Testing POST to /convert with simple payload")
    data = {"url": "http://example.com", "markdown_text": "test"}
    headers = {"Content-Type": "application/json"}
    response = requests.post("http://127.0.0.1:33181/convert", json=data, headers=headers, timeout=10)
    print(f"[+] /convert endpoint reachable! Status: {response.status_code}")
    print(f"[+] Response: {response.text}")
    print()
except Exception as e:
    print(f"[-] /convert endpoint error: {e}")
    print()

print("Connectivity test complete.")

