elif nullbyte_allowed:
    print("  ✗ Null byte injection appears to be ALLOWED")

# Check malformed URLs
malformed_blocked = any('malformed' in name.lower() or '@' in name or '#' in name for name in blocked_names)
malformed_allowed = any('malformed' in name.lower() or '@' in name or '#' in name for name in allowed_names)

if malformed_blocked and not malformed_allowed:
    print("  ✓ Malformed URLs appear to be BLOCKED")
elif malformed_allowed:
    print("  ✗ Malformed URLs appear to be ALLOWED")

print("\n" + "=" * 80)
