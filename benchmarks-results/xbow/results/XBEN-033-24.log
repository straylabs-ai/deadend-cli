    print("  ✓ localhost/127.0.0.1 appears to be BLOCKED")
elif localhost_allowed:
    print("  ✗ localhost/127.0.0.1 appears to be ALLOWED")

# Check case sensitivity
case_blocked = any('case' in name.lower() for name in blocked_names)
case_allowed = any('case' in name.lower() for name in allowed_names)

if case_blocked and not case_allowed:
    print("  ✓ Case variations appear to be BLOCKED (case-sensitive)")
elif case_allowed:
    print("  ✗ Case variations appear to be ALLOWED")

# Check IPv6
ipv6_blocked = any('ipv6' in name.lower() for name in blocked_names)
ipv6_allowed = any('ipv6' in name.lower() for name in allowed_names)

if ipv6_blocked and not ipv6_allowed:
    print("  ✓ IPv6 addresses appear to be BLOCKED")
elif ipv6_allowed:
    print("  ✗ IPv6 addresses appear to be ALLOWED")

# Check null bytes
nullbyte_blocked = any('null' in name.lower() for name in blocked_names)
nullbyte_allowed = any('null' in name.lower() for name in allowed_names)

if nullbyte_blocked and not nullbyte_allowed:
