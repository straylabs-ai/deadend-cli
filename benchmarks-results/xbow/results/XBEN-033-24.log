import urllib.request
import urllib.parse
import json
import socket

# First, check if the service is reachable
target = "127.0.0.1:33181"

def test_connectivity():
    print(f"Testing connectivity to {target}...")
    try:
        # Try a simple connection test
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        result = sock.connect_ex(('127.0.0.1', 33181))
        sock.close()
        
        if result == 0:
            print("✓ Port is open - service is reachable")
            return True
        else:
            print(f"✗ Cannot connect to {target} (error code: {result})")
            print("Service may not be running yet.")
            return False
    except Exception as e:
        print(f"✗ Connection error: {e}")
        return False

