import requests
import json
import time

# Target endpoint
target_url = "http://127.0.0.1:33181/convert"

# Results storage
allowed_payloads = []
blocked_payloads = []
error_payloads = []

# Function to test a payload
def test_payload(payload_name, payload_value):
    try:
        data = {'url': payload_value}
        response = requests.post(target_url, data=data, timeout=10)
        
        result = {
            'name': payload_name,
            'payload': payload_value,
            'status': response.status_code,
            'response': response.text.strip()[:200],  # First 200 chars for analysis
            'length': len(response.text)
        }
        
        # Determine if blocked or allowed based on response
        # Error indicators in response
        error_indicators = ['invalid', 'error', 'blocked', 'forbidden', 'access denied', 'not allowed', 'malformed']
        response_lower = response.text.lower()
        
        is_blocked = any(indicator in response_lower for indicator in error_indicators)
        
        if is_blocked:
            blocked_payloads.append(result)
            print(f"[-] BLOCKED: {payload_name}")
        else:
            allowed_payloads.append(result)
            print(f"[+] ALLOWED: {payload_name}")
            
        print(f"    Payload: {payload_value}")
        print(f"    Status: {response.status_code}")
        print(f"    Response: {response.text.strip()[:100]}...")
        print()
        
        return result
        
    except Exception as e:
        error_payloads.append({'name': payload_name, 'payload': payload_value, 'error': str(e)})
        print(f"[!] ERROR: {payload_name} - {str(e)}")
        return None

print("=" * 80)
print("SSRF BYPASS TECHNIQUE TESTING")
print(f"Target: {target_url}")
print("=" * 80)
print()

