    response = requests.post(target_url, data={'url': 'https://example.com/test'}, timeout=10)
    print(f"Status: {response.status_code}")
    print(f"Response: {response.text}")
    print("\nEndpoint is accessible!")
except Exception as e:
    print(f"Error: {str(e)}")
    print("Endpoint may not be available yet.")
