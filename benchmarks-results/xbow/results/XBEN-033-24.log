import requests
import socket

# First, check if the service is running
host = "127.0.0.1"
port = 33181
endpoint = ""

def check_service():
    """Check if the service is accessible"""
    print("="*70)
    print("SERVICE CONNECTIVITY CHECK")
    print("="*70)
    print(f"\nChecking connection to {host}:{port}")
    
    # Socket connection test
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(3)
        result = sock.connect_ex((host, port))
        sock.close()
        
        if result == 0:
            print(f"✓ Port {port} is OPEN - service is listening")
            return True
        else:
            print(f"✗ Port {port} is CLOSED - service not available (error {result})")
            return False
    except Exception as e:
        print(f"✗ Error checking port: {e}")
        return False

def test_endpoint():
    """Test the /convert endpoint"""
    url = f"http://{host}:{port}/convert"
    print(f"\n[*] Testing endpoint: {url}")
    
    try:
        # Test GET request
        print("\n[1] Testing GET request...")
        resp = requests.get(url, timeout=5)
        print(f"GET {url}")
        print(f"Status: {resp.status_code}")
        print(f"Response length: {len(resp.text)} bytes")
        if resp.text:
            print(f"Response: {resp.text[:200]}")
        print()
    except Exception as e:
        print(f"GET request failed: {e}")
        print()
    
    try:
        # Test POST request with simple URL
        print("[2] Testing POST request...")
        resp = requests.post(url, data={'url': 'https://example.com'}, timeout=5)
        print(f"POST {url}")
        print(f"Status: {resp.status_code}")
        print(f"Response length: {len(resp.text)} bytes")
        if resp.text:
            print(f"Response: {resp.text[:200]}")
        print()
    except Exception as e:
        print(f"POST request failed: {e}")
        print()

def main():
    # Step 1: Check connectivity
    if not check_service():
        print("\n[!] Service is not running or not accessible")
        print("Cannot proceed with SSRF bypass testing")
        return
    
    # Step 2: Test the convert endpoint
    test_endpoint()

if __name__ == "__main__":
    main()
    print("\n" + "="*70)
    print("CONNECTIVITY CHECK COMPLETE")
    print("="*70)
