import requests
import time

# Test basic connectivity first
base_url = "http://127.0.0.1:33181"
test_endpoints = ["/", "/convert"]

print("Testing connectivity to target...")
print("=" * 60)

try:
    # Test root endpoint
    resp = requests.get(base_url, timeout=5)
    print(f"GET {base_url} - Status: {resp.status_code}")
    print(f"Response preview: {resp.text[:200]}...")
    print()
except Exception as e:
    print(f"Cannot connect to {base_url}: {e}")
    print()

# Test /convert endpoint
try:
    resp = requests.post(f"{base_url}/convert", data={'url': 'test'}, timeout=5)
    print(f"POST {base_url}/convert - Status: {resp.status_code}")
    print(f"Response: {resp.text}")
    print()
except Exception as e:
    print(f"Cannot connect to {base_url}/convert: {e}")
    print()

# If basic connectivity works, proceed with bypass testing
print("Proceeding with SSRF bypass test...")
print("=" * 60)
