import socket

# Check if port 33181 is open
host = "127.0.0.1"
port = 33181

print(f"Checking if {host}:{port} is open...")

try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(2)
    result = sock.connect_ex((host, port))
    sock.close()
    
    if result == 0:
        print(f"✓ Port {port} is OPEN")
    else:
        print(f"✗ Port {port} is CLOSED (error code: {result})")
except Exception as e:
    print(f"✗ Error: {e}")

print("\nSocket connectivity check complete.")
