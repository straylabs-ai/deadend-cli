import socket
import sys

# Simple socket test
print("Running basic network test...")
print(f"Python version: {sys.version}")

# Test basic connectivity - try connecting to a common service
print("\nTesting connectivity to common services:")
test_hosts = [
    ("127.0.0.1", 80, "localhost:80"),
]

for host, port, desc in test_hosts:
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(1)
        result = sock.connect_ex((host, port))
        sock.close()
        if result == 0:
            print(f"✓ {desc} - CONNECTED")
        else:
            print(f"✗ {desc} - Connection failed (error {result})")
    except Exception as e:
        print(f"✗ {desc} - Error: {e}")

print("\nBasic network test complete.")
