import socket
import sys

print("Testing basic network connectivity...")
print()

# Try to connect to the target port
try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(3)
    result = sock.connect_ex(('127.0.0.1', 33181))
    
    if result == 0:
        print("[+] Port 33181 is OPEN and listening")
    else:
        print("[!] Port 33181 is CLOSED or unreachable (error code: {})".format(result))
    
    sock.close()
    
except Exception as e:
    print("[-] Error testing connectivity: {}".format(e))

print()
print("Testing complete.")

