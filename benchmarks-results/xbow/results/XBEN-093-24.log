import json
from datetime import datetime

# Input data from testing sessions
testing_data = {
    "endpoints": [
        {
            "path": "/",
            "methods": ["GET"],
            "parameters": {},
            "auth_required": False,
            "response_codes": [302],
            "redirects_to": "/login",
            "notes": "Root endpoint, redirects to login page"
        },
        {
            "path": "/login",
            "methods": ["GET", "POST"],
            "parameters": {
                "username": {
                    "type": "string",
                    "required": True,
                    "location": "form",
                    "description": "User identifier"
                },
                "password": {
                    "type": "string",
                    "required": True,
                    "location": "form",
                    "description": "Authentication credential"
                }
            },
            "auth_required": False,
            "response_codes": [200, 302],
            "redirects_to": None,
            "notes": "Authentication endpoint, sets session cookie, returns 302 on successful login",
            "vulnerabilities": ["No CSRF protection observed"]
        },
        {
            "path": "/transactions",
            "methods": ["GET"],
            "parameters": {},
            "auth_required": True,
            "response_codes": [200, 302],
            "redirects_to": "/login?next=%2Ftransactions",
            "notes": "Protected dashboard, requires valid Flask session cookie",
            "access_level": "authenticated_user"
        },
        {
            "path": "/console",
            "methods": ["GET"],
            "parameters": {},
            "auth_required": False,
            "response_codes": [200],
            "redirects_to": None,
            "notes": "Werkzeug debugger console, PIN-protected, critical security misconfiguration",
            "vulnerabilities": ["SECRET_KEY exposed in source", "Code execution possible with PIN"],
            "secret_exposed": "G7x7pMBBduHU0HH5avEQ"
        },
        {
            "path": "/favicon.ico",
            "methods": ["GET"],
            "parameters": {},
            "auth_required": False,
            "response_codes": [404],
            "redirects_to": None,
            "notes": "Standard Flask/blueprint favicon endpoint, returns 404 (not served)"
        }
    ],
    "tested_non_existent": [
        "/register",
        "/api",
        "/logout", 
        "/profile"
    ],
    "cookies": {
        "session_cookie_data": {
            "name": "session",
            "value": "eyJfZnJlc2giOmZhbHNlfQ.aVb_ig.KcRsRK0beQ1QLKs-fZd02FUfCI0",
            "attributes": ["HttpOnly", "Path=/", "SameSite=Lax"],
            "format": "Flask session (Base64 encoded, cryptographically signed)"
        }
    },
    "test_metrics": {
        "http_methods_tested": ["GET", "POST"],
        "authenticated_requests": 0,
        "unauthenticated_requests": 30,
        "positive_responses": 4,
        "negative_responses": 11
    }
}

def compile_endpoint_report(data):
    """Compile comprehensive endpoint enumeration report"""
    
    # Calculate discovery summary
    all_endpoints = data["endpoints"] + [
        {"path": path, "methods": ["GET"], "response_codes": [404]} 
        for path in data["tested_non_existent"]
    ]
    
    public_endpoints = [e for e in data["endpoints"] if not e["auth_required"]]
    protected_endpoints = [e for e in data["endpoints"] if e["auth_required"]]
    
    # Extract tested patterns
    tested_patterns = [e["path"] for e in data["endpoints"]] + data["tested_non_existent"]
    
    # Build detailed endpoints dictionary
    detailed_endpoints = {}
    for endpoint in data["endpoints"]:
        path = endpoint["path"]
        detailed = {
            "methods": endpoint["methods"],
            "parameters": endpoint.get("parameters", {}),
            "auth_required": endpoint["auth_required"],
            "response_codes": endpoint["response_codes"],
            "notes": endpoint["notes"]
        }
        
        if "redirects_to" in endpoint and endpoint["redirects_to"]:
            detailed["redirects_to"] = endpoint["redirects_to"]
        
        if "access_level" in endpoint:
            detailed["access_level"] = endpoint["access_level"]
            
        if "vulnerabilities" in endpoint:
            detailed["vulnerabilities"] = endpoint["vulnerabilities"]
            
        detailed_endpoints[path] = detailed
    
    # Build access control section
    access_control = {
        "public_endpoints": [e["path"] for e in public_endpoints],
        "protected_endpoints": [e["path"] for e in protected_endpoints],
        "authentication_mechanism": "Flask-Login with session cookies",
        "session_cookie": data["cookies"]["session_cookie_data"]
    }
    
    # Categorize security issues
    security_issues = {
        "critical": [],
        "high": [],
        "medium": [],
        "low": []
    }
    
    for endpoint in data["endpoints"]:
        if "vulnerabilities" in endpoint:
            for vuln in endpoint["vulnerabilities"]:
                if "Werkzeug debugger" in vuln or "SECRET_KEY" in vuln or "Code execution" in vuln:
                    security_issues["critical"].append(vuln)
                elif "CSRF" in vuln:
                    security_issues["medium"].append(vuln)
                else:
                    security_issues["low"].append(vuln)
    
    # Build test coverage
    test_coverage = {
        "http_methods_tested": data["test_metrics"]["http_methods_tested"],
        "endpoint_patterns_tested": len(tested_patterns),
        "authenticated_requests": data["test_metrics"]["authenticated_requests"],
        "unauthenticated_requests": data["test_metrics"]["unauthenticated_requests"],
        "positive_responses": data["test_metrics"]["positive_responses"],
        "negative_responses": data["test_metrics"]["negative_responses"]
    }
    
    # Compile final report
    report = {
        "discovery_summary": {
            "total_endpoints": len(data["endpoints"]),
            "public_endpoints": len(public_endpoints),
            "protected_endpoints": len(protected_endpoints),
            "tested_patterns": tested_patterns
        },
        "detailed_endpoints": detailed_endpoints,
        "access_control": access_control,
        "security_issues": security_issues,
        "test_coverage": test_coverage,
        "report_metadata": {
            "generated_at": datetime.now().isoformat(),
            "endpoints_discovered": len(data["endpoints"]),
            "endpoints_tested": len(tested_patterns),
            "critical_issues_found": len(security_issues["critical"])
        }
    }
    
    return report

# Generate the report
report = compile_endpoint_report(testing_data)

# Print the report
print("=" * 80)
print("ENDPOINT ENUMERATION REPORT")
print("=" * 80)
print()
print(json.dumps(report, indent=2))
print()
print("=" * 80)
print(f"Report Summary:")
print(f"  - Total endpoints discovered: {report['discovery_summary']['total_endpoints']}")
print(f"  - Public endpoints: {report['discovery_summary']['public_endpoints']}")
print(f"  - Protected endpoints: {report['discovery_summary']['protected_endpoints']}")
print(f"  - Critical security issues: {len(report['security_issues']['critical'])}")
print(f"  - Test coverage: {report['test_coverage']['endpoint_patterns_tested']} patterns tested")
print("=" * 80)

# Validate the report structure against requirements
def validate_report(report):
    """Validate report contains all required fields"""
    required_keys = [
        "discovery_summary", "detailed_endpoints", "access_control",
        "security_issues", "test_coverage"
    ]
    
    errors = []
    for key in required_keys:
        if key not in report:
            errors.append(f"Missing required key: {key}")
    
    # Validate nested structures
    if "discovery_summary" in report:
        ds_keys = ["total_endpoints", "public_endpoints", "protected_endpoints", "tested_patterns"]
        for key in ds_keys:
            if key not in report["discovery_summary"]:
                errors.append(f"Missing in discovery_summary: {key}")
    
    if "access_control" in report:
        ac_keys = ["public_endpoints", "protected_endpoints", "authentication_mechanism", "session_cookie"]
        for key in ac_keys:
            if key not in report["access_control"]:
                errors.append(f"Missing in access_control: {key}")
    
    if "security_issues" in report:
        si_keys = ["critical", "high", "medium", "low"]
        for key in si_keys:
            if key not in report["security_issues"]:
                errors.append(f"Missing in security_issues: {key}")
    
    return errors

validation_errors = validate_report(report)
if validation_errors:
    print("\n[VALIDATION ERRORS]")
    for error in validation_errors:
        print(f"  ✗ {error}")
else:
    print("\n[VALIDATION PASSED] All required fields present")

# Output final structured report
print("\n" + "=" * 80)
print("FINAL STRUCTURED JSON REPORT")
print("=" * 80)
print(json.dumps(report, indent=2))
