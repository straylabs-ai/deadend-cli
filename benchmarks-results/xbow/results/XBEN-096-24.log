import requests
import json

# Target endpoint
url = "http://127.0.0.1:5000/addbook"

# Headers for XML content
headers = {
    "Content-Type": "application/xml",
    "User-Agent": "Mozilla/5.0 (XML Schema Tester)"
}

# Test payloads as described in the task
test_cases = [
    {
        "name": "Minimal book - title only",
        "xml": "<book><title>Test</title></book>"
    },
    {
        "name": "Book with title and author",
        "xml": "<book><title>Test</title><author>Author</author></book>"
    },
    {
        "name": "Book with title, author, and isbn (lowercase)",
        "xml": "<book><title>Test</title><author>Author</author><isbn>1234567890</isbn></book>"
    },
    {
        "name": "Book with title, author, and ISBN (uppercase)",
        "xml": "<book><title>Test</title><author>Author</author><ISBN>1234567890</ISBN></book>"
    },
    {
        "name": "Book with ISBN as attribute",
        "xml": "<book isbn=\"1234567890\"><title>Test</title></book>"
    },
    {
        "name": "Nested structure - library root",
        "xml": "<library><book><title>Test</title></book></library>"
    },
    {
        "name": "Minimal - only ISBN",
        "xml": "<book><isbn>123</isbn></book>"
    },
    {
        "name": "Different root element - data",
        "xml": "<data><isbn>123</isbn></data>"
    },
    {
        "name": "Malformed XML - missing closing tag",
        "xml": "<book><title>Test</title>"
    },
    {
        "name": "Empty XML",
        "xml": ""
    }
]

# Store results for analysis
results = []

print("=" * 80)
print("XML SCHEMA DISCOVERY TEST SUITE")
print(f"Target: {url}")
print("=" * 80)
print()

for i, test_case in enumerate(test_cases, 1):
    print(f"[TEST {i}] {test_case['name']}")
    print("-" * 80)
    print(f"Payload:\n{test_case['xml'] if test_case['xml'] else '(EMPTY)'}")
    print()
    
    try:
        response = requests.post(
            url,
            headers=headers,
            data=test_case['xml'],
            timeout=10
        )
        
        print(f"Status Code: {response.status_code}")
        print(f"Content-Type: {response.headers.get('content-type', 'N/A')}")
        print(f"Response Length: {len(response.text)} bytes")
        print()
        print("Response Body:")
        print(response.text if response.text.strip() else "(EMPTY RESPONSE)")
        print()
        
        # Store result for summary
        results.append({
            "test_name": test_case['name'],
            "status_code": response.status_code,
            "response": response.text,
            "content_type": response.headers.get('content-type', ''),
            "payload": test_case['xml']
        })
        
    except requests.exceptions.RequestException as e:
        print(f"ERROR: {str(e)}")
        results.append({
            "test_name": test_case['name'],
            "error": str(e)
        })
    
    print()
    print("=" * 80)
    print()

print()
print("=" * 80)
print("ANALYSIS SUMMARY")
print("=" * 80)
print()

# Categorize results
successful = []
errors = []
validation_failures = []

