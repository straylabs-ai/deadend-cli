    print(f"Payload:\n{test_case['payload']}")
    print()
    
    try:
        response = requests.post(
            base_url,
            headers=headers,
            data=test_case['payload'],
            timeout=10
        )
        
        print(f"Status Code: {response.status_code}")
        print(f"Response Length: {len(response.text)} bytes")
        print(f"Response Body:\n{response.text}")
        
        # Check for specific patterns in response
        response_lower = response.text.lower()
        
        if response.status_code == 200:
            results["success_count"] += 1
            print(f"[+] SUCCESS: Request accepted")
            
            # Check if ISBN was ignored/stripped
            if "isbn" not in response_lower:
                results["isbn_ignored"].append({
                    "test_name": test_case['name'],
                    "response": response.text[:200]
                })
                print(f"[!] NOTE: ISBN field not present in response (ignored)")
            else:
                results["interesting_responses"].append({
                    "test_name": test_case['name'],
                    "response": response.text
                })
                print(f"[!] INTERESTING: ISBN present in response!")
        else:
            results["failure_count"] += 1
            print(f"[-] FAILED: Request rejected")
            
            # Extract error messages
            if "error" in response_lower or "invalid" in response_lower:
                results["error_messages"].append({
                    "test_name": test_case['name'],
                    "status": response.status_code,
                    "response": response.text
                })
                print(f"[!] ERROR DETECTED: {response.text[:150]}")
        
        print("-" * 80)
        
    except requests.exceptions.RequestException as e:
        print(f"[-] REQUEST ERROR: {str(e)}")
        results["failure_count"] += 1
        print("-" * 80)

# Test XXE payloads
print("\n\nTESTING XXE PAYLOADS")
print("=" * 80)

xxe_results = {
    "success_count": 0,
    "failure_count": 0,
    "vulnerable": [],
    "blocked": []
}

for idx, test_case in enumerate(xxe_test_cases, 1):
    print(f"\n[XXE TEST {idx}] {test_case['name']}")
    print(f"Payload preview:\n{test_case['payload'][:150]}...")
    print()
    
    try:
        response = requests.post(
            base_url,
            headers=headers,
            data=test_case['payload'],
            timeout=15  # Longer timeout for potential DoS
        )
        
        print(f"Status Code: {response.status_code}")
        print(f"Response Length: {len(response.text)} bytes")
        print(f"Response Body:\n{response.text}")
        
        # Check for XXE indicators
        response_lower = response.text.lower()
        xxe_indicators = ["root:", "bin:", "daemon:", "nologin", "etc/passwd"]
        file_indicators = ["cmdline", "proc/"]
        
        vulnerable = False
        for indicator in xxe_indicators + file_indicators:
            if indicator in response_lower:
                vulnerable = True
                break
        
        if vulnerable:
            xxe_results["vulnerable"].append({
                "test_name": test_case['name'],
                "response": response.text
            })
            print(f"[!] VULNERABLE: Potential XXE exploitation detected!")
        elif response.status_code == 200:
            xxe_results["success_count"] += 1
            print(f"[+] ACCEPTED: No XXE detected (may be patched)")
        else:
            xxe_results["blocked"].append({
                "test_name": test_case['name'],
                "status": response.status_code,
                "response": response.text
            })
            print(f"[-] BLOCKED: XXE payload rejected")
        
        print("-" * 80)
        
    except requests.exceptions.RequestException as e:
        print(f"[-] REQUEST ERROR: {str(e)}")
        xxe_results["failure_count"] += 1
        print("-" * 80)

