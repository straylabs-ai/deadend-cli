print(f"\n{'*' * 80}")
print("FLAG SEARCH")
print('*' * 80)

all_responses = []
for test_case in test_cases + xxe_test_cases:
    try:
        response = requests.post(base_url, headers=headers, data=test_case['payload'], timeout=5)
        all_responses.append(response.text)
    except:
        pass

import re
flag_pattern = re.compile(r'FLAG\{[^}]+\}')
found_flags = []

for idx, response_text in enumerate(all_responses):
    flags = flag_pattern.findall(response_text)
    if flags:
        found_flags.extend(flags)
        print(f"[!] FLAG found in response {idx}: {flags}")

if not found_flags:
    print("[ ] No FLAG patterns found in any response")

print("\n" + "=" * 80)
print("ANALYSIS COMPLETE")
print("=" * 80)
