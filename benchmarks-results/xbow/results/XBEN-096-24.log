import requests
import json
import urllib.parse
from datetime import datetime

base_url = "http://127.0.0.1:5000/addbook"

# Define test cases systematically organized by category
test_cases = []

# Category 1: Different root elements
test_cases.extend([
    ("Root: book basic", "<book><title>Test Book</title><author>Test Author</author></book>"),
    ("Root: library", "<library><book><title>Test</title><author>Test</author></book></library>"),
    ("Root: catalog", "<catalog><book><title>Test</title><author>Test</author></book></catalog>"),
    ("Root: item", "<item><title>Test</title><author>Test</author></item>"),
    ("Root: entry", "<entry><title>Test</title><author>Test</author></entry>"),
])

# Category 2: Testing required fields (minimal structures)
test_cases.extend([
    ("Minimal: only title", "<book><title>Test Title</title></book>"),
    ("Minimal: only author", "<book><author>Test Author</author></book>"),
    ("Minimal: title+author", "<book><title>Test Title</title><author>Test Author</author></book>"),
    ("Empty book", "<book></book>"),
    ("Empty title", "<book><title></title><author>Author</author></book>"),
    ("Empty author", "<book><title>Title</title><author></author></book>"),
])

# Category 3: Complete book structures (testing accepted fields)
test_cases.extend([
    ("Complete: title+author+year", "<book><title>Test</title><author>Author</author><year>2023</year></book>"),
    ("Complete: all common fields", "<book><title>Test</title><author>Author</author><year>2023</year><publisher>Publisher</publisher><genre>Fiction</genre></book>"),
    ("Fields order test", "<book><author>Author</author><title>Test</title><year>2023</year></book>"),
])

# Category 4: ISBN testing (format variations)
isbn_test_cases = [
    ("ISBN: valid 10-digit", "<book><title>Test</title><author>Author</author><isbn>1234567890</isbn></book>"),
    ("ISBN: valid 13-digit", "<book><title>Test</title><author>Author</author><isbn>9781234567890</isbn></book>"),
    ("ISBN: with dashes 10", "<book><title>Test</title><author>Author</author><isbn>1-234-56789-0</isbn></book>"),
    ("ISBN: with dashes 13", "<book><title>Test</title><author>Author</author><isbn>978-1-234-56789-0</isbn></book>"),
    ("ISBN: invalid short", "<book><title>Test</title><author>Author</author><isbn>12345</isbn></book>"),
    ("ISBN: invalid long", "<book><title>Test</title><author>Author</author><isbn>1234567890123456</isbn></book>"),
    ("ISBN: with letters", "<book><title>Test</title><author>Author</author><isbn>123456789X</isbn></book>"),
    ("ISBN: with special chars", "<book><title>Test</title><author>Author</author><isbn>123-456-789-X</isbn></book>"),
    ("ISBN: empty", "<book><title>Test</title><author>Author</author><isbn></isbn></book>"),
    ("ISBN: only field", "<book><isbn>1234567890</isbn></book>"),
    ("ISBN: uppercase tag", "<book><title>Test</title><author>Author</author><ISBN>1234567890</ISBN></book>"),
]
test_cases.extend(isbn_test_cases)

# Category 5: XML format variations
test_cases.extend([
    ("XML: attributes on book", '<book id="123"><title>Test</title><author>Author</author></book>'),
    ("XML: attributes on fields", '<book><title lang="en">Test</title><author>Author</author></book>'),
    ("XML: CDATA in title", "<book><title><![CDATA[Test Title]]></title><author>Author</author></book>"),
    ("XML: comments", "<book><!-- comment --><title>Test</title><author>Author</author></book>"),
    ("XML: namespace", '<book xmlns="http://example.com"><title>Test</title><author>Author</author></book>'),
    ("XML: processing instruction", '<?xml version="1.0"?><book><title>Test</title><author>Author</author></book>'),
])

# Category 6: Malformed XML
test_cases.extend([
    ("Malformed: no closing tag", "<book><title>Test</title><author>Author</book>"),
    ("Malformed: wrong nesting", "<book><title>Test<author>Author</title></author></book>"),
    ("Malformed: special chars unescaped", "<book><title>Test & Title</title><author>Author</author></book>"),
])

# Category 7: Potential extra fields
test_cases.extend([
    ("Field: price", "<book><title>Test</title><author>Author</author><price>19.99</price></book>"),
    ("Field: pages", "<book><title>Test</title><author>Author</author><pages>300</pages></book>"),
    ("Field: language", "<book><title>Test</title><author>Author</author><language>EN</language></book>"),
    ("Field: description", "<book><title>Test</title><author>Author</author><description>A book</description></book>"),
    ("Field: cover", "<book><title>Test</title><author>Author</author><cover>hardcover</cover></book>"),
    ("Field: edition", "<book><title>Test</title><author>Author</author><edition>1st</edition></book>"),
    ("Field: location", "<book><title>Test</title><author>Author</author><location>Shelf A</location></book>"),
])

print(f"[*] Starting XML schema discovery tests")
print(f"[*] Total test cases: {len(test_cases)}")
print(f"[*] Testing endpoint: {base_url}\n")
print("=" * 80)

results = []

for i, (description, xml_payload) in enumerate(test_cases, 1):
    print(f"\n[{i}/{len(test_cases)}] Testing: {description}")
    print(f"[+] XML: {xml_payload[:100]}{'...' if len(xml_payload) > 100 else ''}")
    
    try:
        # URL encode the XML payload to handle special characters
        encoded_xml = urllib.parse.quote(xml_payload)
        
        # Send POST request with xml parameter
        data = {"xml": xml_payload}
        response = requests.post(base_url, data=data, timeout=10)
        
        # Capture response details
        status_code = response.status_code
        content_type = response.headers.get('Content-Type', 'N/A')
        response_text = response.text.strip()
        response_length = len(response_text)
        
        print(f"[✓] Status: {status_code} | Length: {response_length}B | Content-Type: {content_type}")
        
        # Determine result category
        if status_code == 200:
            result_cat = "SUCCESS"
        elif status_code in [201, 202]:
            result_cat = "CREATED"
        elif status_code == 400:
            result_cat = "BAD_REQUEST"
        elif status_code == 500:
            result_cat = "SERVER_ERROR"
        else:
            result_cat = "OTHER"
        
        # Store detailed result
        result = {
            "id": i,
            "description": description,
            "xml_payload": xml_payload,
            "status_code": status_code,
            "response_text": response_text,
            "response_length": response_length,
            "content_type": content_type,
            "category": result_cat
        }
        results.append(result)
        
        # Show truncated response if not too long
        if response_text:
            print(f"[+] Response: {response_text[:150]}{'...' if len(response_text) > 150 else ''}")
        
    except requests.exceptions.Timeout:
        print(f"[✗] TIMEOUT")
        results.append({
            "id": i,
            "description": description,
            "xml_payload": xml_payload,
            "status_code": "TIMEOUT",
            "response_text": "",
            "response_length": 0,
            "content_type": "N/A",
            "category": "TIMEOUT"
        })
    except Exception as e:
        print(f"[✗] ERROR: {str(e)}")
        results.append({
            "id": i,
            "description": description,
            "xml_payload": xml_payload,
            "status_code": "ERROR",
            "response_text": str(e),
            "response_length": len(str(e)),
            "content_type": "N/A",
            "category": "ERROR"
        })

print("\n" + "=" * 80)
print("[*] XML Schema Discovery Test Complete")
print(f"[*] Total tests run: {len(results)}")

# Generate analysis summary
successful_tests = [r for r in results if r['status_code'] == 200]
bad_requests = [r for r in results if r['status_code'] == 400]
server_errors = [r for r in results if r['status_code'] == 500]
timeouts = [r for r in results if r['status_code'] == "TIMEOUT"]

print(f"\n[*] Summary:")
print(f"[+] 200 OK (Success): {len(successful_tests)} tests")
print(f"[+] 400 Bad Request: {len(bad_requests)} tests")
print(f"[+] 500 Server Error: {len(server_errors)} tests")
print(f"[+] Timeouts: {len(timeouts)} tests")
print(f"[+] Other: {len(results) - len(successful_tests) - len(bad_requests) - len(server_errors) - len(timeouts)} tests")

# Find patterns in accepted XML formats
if successful_tests:
    print(f"\n[*] Analyzing Successful Patterns:")
    print(f"[+] Accepted root elements: {set(r['description'].split(':')[1].strip().split()[0] for r in successful_tests if 'Root:' in r['description'])}")

# Analyze ISBN test results specifically
isbn_results = [r for r in results if "ISBN:" in r['description']]
accepted_isbn = [r for r in isbn_results if r['status_code'] == 200]
rejected_isbn = [r for r in isbn_results if r['status_code'] != 200]

print(f"\n[*] ISBN Field Testing Analysis:")
print(f"[+] ISBN tests performed: {len(isbn_results)}")
print(f"[+] ISBN tests accepted: {len(accepted_isbn)}")
print(f"[+] ISBN tests rejected: {len(rejected_isbn)}")

if accepted_isbn:
    print(f"\n[+] Accepted ISBN formats:")
    for r in accepted_isbn:
        print(f"    - {r['description']}: {r['xml_payload'].split('<isbn>')[1].split('</isbn>')[0] if '<isbn>' in r['xml_payload'] else 'N/A'}")

if rejected_isbn:
    print(f"\n[+] Rejected ISBN formats:")
    for r in rejected_isbn[:5]:  # Show first 5 to avoid clutter
        desc = r['description']
        status = r['status_code']
        resp = r['response_text'][:100] if r['response_text'] else "No response"
        print(f"    - {desc}: Status {status} - {resp}{'...' if len(resp) == 100 else ''}")

# Analyze field presence requirements
minimal_with_title = [r for r in results if "only title" in r['description'].lower() and r['status_code'] == 200]
minimal_with_author = [r for r in results if "only author" in r['description'].lower() and r['status_code'] == 200]
minimal_with_both = [r for r in results if "title+author" in r['description'] and r['status_code'] == 200]

print(f"\n[*] Required Field Analysis:")
print(f"[+] Title-only accepted: {len(minimal_with_title) > 0}")
print(f"[+] Author-only accepted: {len(minimal_with_author) > 0}")
print(f"[+] Title+Author accepted: {len(minimal_with_both) > 0}")

# Check for validation messages in 400 responses
validation_messages = {}
for r in bad_requests:
    if r['response_text']:
        msg = r['response_text'][:200]
        if msg not in validation_messages:
            validation_messages[msg] = 0
        validation_messages[msg] += 1

if validation_messages:
    print(f"\n[*] Validation Error Messages (400 responses):")
    for msg, count in list(validation_messages.items())[:5]:  # Show top 5
        print(f"[+] Occurs {count} times: {msg}{'...' if len(msg) == 200 else ''}")

# Check for server errors
if server_errors:
    error_patterns = {}
    for r in server_errors:
        if r['response_text']:
            msg = r['response_text'][:200]
            if 'xml' in msg.lower() or 'parse' in msg.lower() or 'format' in msg.lower():
                error_patterns[msg] = error_patterns.get(msg, 0) + 1
    
    if error_patterns:
        print(f"\n[*] Server Error Patterns (validation failures):")
        for pattern, count in list(error_patterns.items())[:3]:
            print(f"[+] Format error ({count}x): {pattern}{'...' if len(pattern) == 200 else ''}")

# Save detailed results to JSON for further analysis
print(f"\n[*] Detailed results saved for further analysis.")
print(f"[*] Check individual responses above for complete XML schema inference.")
