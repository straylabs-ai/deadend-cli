import requests
import time
import socket

# Configuration
target_host = "127.0.0.1"
target_port = 5000
endpoint = "/addbook"

print("XML SCHEMA DISCOVERY TEST SUITE")
print(f"Target: http://{target_host}:{target_port}{endpoint}")
print("=" * 70)
print()

# Test connectivity with socket (low-level)
print("[CONNECTIVITY CHECK] Testing low-level TCP connection...")
try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(3)
    result = sock.connect_ex((target_host, target_port))
    sock.close()
    
    if result == 0:
        print(f"✓ Port {target_port} is OPEN on {target_host}")
    else:
        print(f"✗ Port {target_port} is CLOSED or not responding (error code: {result})")
        print()
        print("[!] CRITICAL: Cannot establish TCP connection")
        print("    The target service is likely not running or not accessible.")
        print("    Please start the service and try again.")
        exit(1)
except Exception as e:
    print(f"✗ Socket test failed: {str(e)}")
    exit(1)

print()
print("[INITIAL PROTOCOL TEST] Testing HTTP request...")

# Create session with retry strategy
session = requests.Session()
adapter = requests.adapters.HTTPAdapter(
    max_retries=requests.adapters.Retry(
        total=3,
        backoff_factor=0.3,
        status_forcelist=[500, 502, 503, 504]
    )
)
session.mount('http://', adapter)
session.mount('https://', adapter)

try:
    # Test root endpoint first
    response = session.get(
        f"http://{target_host}:{target_port}",
        headers={'User-Agent': 'Schema-Tester/1.0'},
        timeout=5
    )
    print(f"✓ HTTP GET to / returned: {response.status_code}")
    print(f"  Server: {response.headers.get('server', 'Unknown')}")
    print(f"  Content-Type: {response.headers.get('content-type', 'Unknown')}")
except requests.exceptions.RequestException as e:
    print(f"✗ HTTP GET failed: {str(e)}")

print()
print("=" * 70)
print("BEGINNING XML SCHEMA TESTS")
print("=" * 70)
print()

# Create fresh session for tests
test_session = requests.Session()
test_session.headers.update({
    "Content-Type": "application/xml",
    "User-Agent": "Schema-Tester/1.0"
})

# Test cases
test_cases = [
    {"id": 1, "name": "Minimal book - title only", "xml": "<book><title>Test</title></book>"},
    {"id": 2, "name": "Book with title and author", "xml": "<book><title>Test</title><author>Author</author></book>"},
    {"id": 3, "name": "Book with title, author, and isbn (lowercase)", "xml": "<book><title>Test</title><author>Author</author><isbn>1234567890</isbn></book>"},
    {"id": 4, "name": "Book with title, author, and ISBN (uppercase)", "xml": "<book><title>Test</title><author>Author</author><ISBN>1234567890</ISBN></book>"},
    {"id": 5, "name": "Book with ISBN as attribute", "xml": "<book isbn=\"1234567890\"><title>Test</title></book>"},
    {"id": 6, "name": "Nested structure - library root", "xml": "<library><book><title>Test</title></book></library>"},
    {"id": 7, "name": "Minimal - only ISBN", "xml": "<book><isbn>123</isbn></book>"},
    {"id": 8, "name": "Different root element - data", "xml": "<data><isbn>123</isbn></data>"},
    {"id": 9, "name": "Malformed XML - missing closing tag", "xml": "<book><title>Test</title>"},
    {"id": 10, "name": "Empty XML", "xml": ""}
]

results = []
success_count = 0
failure_count = 0
error_count = 0

for i, test in enumerate(test_cases, 1):
    print(f"[TEST {i}/{len(test_cases)}] ID:{test['id']} - {test['name']}")
    print("-" * 70)
    
    if test['xml']:
        print(f"Payload: {test['xml']}")
    else:
        print("Payload: (EMPTY)")
    print()
    
    try:
        response = test_session.post(
            f"http://{target_host}:{target_port}{endpoint}",
            data=test['xml'] if test['xml'] else '',
            timeout=8,
            allow_redirects=False
        )
        
        status = response.status_code
        length = len(response.text)
        
        print(f"Status: {status}")
        print(f"Length: {length} bytes")
        print(f"Type: {response.headers.get('content-type', 'N/A')}")
        print()
        
        if response.text.strip():
            print("Response:")
            print(response.text)
            print()
        
        result_summary = {
            "test_id": test['id'],
            "test_name": test['name'],
            "status_code": status,
            "response": response.text,
            "length": length
        }
        
        results.append(result_summary)
        
        if status == 200:
            success_count += 1
        else:
            failure_count += 1
            
    except requests.exceptions.Timeout:
        print("✗ ERROR: Request timed out after 8 seconds")
        print()
        error_count += 1
    except requests.exceptions.ConnectionError as e:
        print(f"✗ ERROR: Connection lost - {str(e).split(':')[-1].strip()}")
        print()
        error_count += 1
    except Exception as e:
        print(f"✗ ERROR: {str(e)[:60]}")
        print()
        error_count += 1
    
    time.sleep(0.3)

print("=" * 70)
print()
