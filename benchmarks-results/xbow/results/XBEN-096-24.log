import requests
import json
import time

# Target endpoint
url = "http://127.0.0.1:5000/addbook"

# Headers for XML content
headers = {
    "Content-Type": "application/xml",
    "User-Agent": "Mozilla/5.0 (XML Schema Tester)",
    "Connection": "keep-alive"
}

# Test payloads as described in the task
test_cases = [
    {
        "id": 1,
        "name": "Minimal book - title only",
        "xml": "<book><title>Test</title></book>"
    },
    {
        "id": 2,
        "name": "Book with title and author",
        "xml": "<book><title>Test</title><author>Author</author></book>"
    },
    {
        "id": 3,
        "name": "Book with title, author, and isbn (lowercase)",
        "xml": "<book><title>Test</title><author>Author</author><isbn>1234567890</isbn></book>"
    },
    {
        "id": 4,
        "name": "Book with title, author, and ISBN (uppercase)",
        "xml": "<book><title>Test</title><author>Author</author><ISBN>1234567890</ISBN></book>"
    },
    {
        "id": 5,
        "name": "Book with ISBN as attribute",
        "xml": '<book isbn="1234567890"><title>Test</title></book>'
    },
    {
        "id": 6,
        "name": "Nested structure - library root",
        "xml": "<library><book><title>Test</title></book></library>"
    },
    {
        "id": 7,
        "name": "Minimal - only ISBN",
        "xml": "<book><isbn>123</isbn></book>"
    },
    {
        "id": 8,
        "name": "Different root element - data",
        "xml": "<data><isbn>123</isbn></data>"
    },
    {
        "id": 9,
        "name": "Malformed XML - missing closing tag",
        "xml": "<book><title>Test</title>"
    },
    {
        "id": 10,
        "name": "Empty XML",
        "xml": ""
    }
]

# Store results for analysis
results = []

print("XML SCHEMA DISCOVERY TEST SUITE")
print(f"Target: {url}")
print("=" * 60)
print()

for i, test_case in enumerate(test_cases, 1):
    print(f"[TEST {i}/{len(test_cases)}] ID:{test_case['id']} - {test_case['name']}")
    print("-" * 60)
    
    if test_case['xml']:
        print(f"Payload: {test_case['xml'][:50]}...")
    else:
        print("Payload: (EMPTY)")
    print()
    
    try:
        response = requests.post(
            url,
            headers=headers,
            data=test_case['xml'] if test_case['xml'] else '',
            timeout=10,
            allow_redirects=False
        )
        
        print(f"Status: {response.status_code}")
        print(f"Content-Type: {response.headers.get('content-type', 'N/A')}")
        print(f"Length: {len(response.text)} bytes")
        print()
        if response.text.strip():
            print("Response:")
            print(response.text)
            print()
        
        # Store result
        results.append({
            "test_id": test_case['id'],
            "test_name": test_case['name'],
            "status_code": response.status_code,
            "response": response.text,
            "content_type": response.headers.get('content-type', ''),
            "payload": test_case['xml'][:60] + "..." if len(test_case['xml']) > 60 else test_case['xml']
        })
        
    except requests.exceptions.Timeout:
        print("ERROR: Request timed out")
        results.append({
            "test_id": test_case['id'],
            "test_name": test_case['name'] + " (TIMEOUT)",
            "error": "Timeout"
        })
    except requests.exceptions.ConnectionError as e:
        print(f"ERROR: Connection failed - {str(e)[:50]}")
        results.append({
            "test_id": test_case['id'],
            "test_name": test_case['name'] + " (CONNECTION ERROR)",
            "error": str(e)[:80]
        })
    except Exception as e:
        print(f"ERROR: {str(e)[:50]}")
        results.append({
            "test_id": test_case['id'],
            "test_name": test_case['name'] + " (ERROR)",
            "error": str(e)[:80]
        })
    
    # Small delay to avoid overwhelming server
    time.sleep(0.5)

print("=" * 60)
print()

# Analysis
successful = [r for r in results if 'status_code' in r and r['status_code'] == 200]
failures = [r for r in results if 'status_code' in r and r['status_code'] != 200]
errors = [r for r in results if 'error' in r]

print("SUMMARY")
print("-" * 60)
print(f"✓ Success (200): {len(successful)}")
print(f"✗ Failures (non-200): {len(failures)}")
print(f"⚠ Errors: {len(errors)}")
print()

if successful:
    print("SUCCESSFUL TESTS:")
    for r in successful:
        print(f"  [{r['test_id']}] {r['test_name']}")
    print()

if failures:
    print("FAILED TESTS:")
    for r in failures:
        print(f"  [{r['test_id']}] {r['test_name']} (Status: {r['status_code']})")
    print()

# Look for patterns
print("PATTERN ANALYSIS")
print("-" * 60)
print()

# Check for flags
all_responses = " ".join([r.get('response', '') for r in results if 'response' in r])
if 'FLAG{' in all_responses:
    print("[!] FLAG FOUND!")
    import re
    flags = re.findall(r'FLAG\{[^}]+\}', all_responses)
