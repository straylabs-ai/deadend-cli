import requests
import re

def discover_xml_endpoints(base_url):
    """Discover endpoints that accept XML content"""
    print(f"[+] Discovering XML-capable endpoints on {base_url}")
    print("="*60)
    
    # Common XML-accepting endpoints (ONLY test these if discovered)
    xml_candidates = [
        '/parse', '/api/parse', '/submit', '/upload', '/process',
        '/book', '/api/book', '/isbn', '/query', '/search'
    ]
    
    discovered_endpoints = []
    
    for endpoint in xml_candidates:
        url = f"{base_url}{endpoint}"
        
        try:
            # Test XML acceptance
            test_payload = '<?xml version="1.0"?><root><test>data</test></root>'
            
            response = requests.post(
                url,
                data=test_payload,
                headers={'Content-Type': 'application/xml'},
                timeout=8
            )
            
            # Check if endpoint accepts XML (not 415 Unsupported Media Type)
            if response.status_code == 200:
                print(f"[FOUND] {endpoint} - Accepts XML (200 OK)")
                discovered_endpoints.append(endpoint)
                
                # Extract parameter information if available
                if 'xml' in response.text.lower():
                    param_hint = "xml"
                elif 'data' in response.text.lower():
                    param_hint = "data"
                else:
                    param_hint = "unknown"
                    
                print(f"  [-] Hint: Parameter name may be '{param_hint}'")
                
            elif response.status_code != 404 and response.status_code != 405:
                # Endpoint exists but different status
                print(f"[INFO] {endpoint} - Status {response.status_code} (endpoint exists)")
                
            elif response.status_code == 415:
                # Wrong content type
                print(f"[SKIP] {endpoint} - Rejects XML (415)")
                
        except requests.exceptions.RequestException as e:
            print(f"[ERROR] {endpoint} - {str(e)}")
    
    return discovered_endpoints

# Main execution
if __name__ == '__main__':
    # Replace with actual target
    base_url = 'http://target.application:8080'  # NEEDS TO BE REPLACED
    
    discovered = discover_xml_endpoints(base_url)
    
    print()
    print("="*60)
    print(f"DISCOVERED ENDPOINTS: {discovered}")
    print("="*60)
