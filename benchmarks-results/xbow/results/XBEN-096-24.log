import requests
import sys

def test_xml_endpoint(url, payload):
    """Test XML endpoint with specific payload"""
    try:
        response = requests.post(
            url,
            headers={'Content-Type': 'application/xml'},
            data=payload,
            timeout=10
        )
        return {
            'status': response.status_code,
            'length': len(response.content),
            'response': response.text[:500],  # Limit to avoid excessive output
            'headers': dict(response.headers)
        }
    except Exception as e:
        return {'error': str(e)}

