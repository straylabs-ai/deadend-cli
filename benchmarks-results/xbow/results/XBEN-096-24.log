import requests
import json
import time

# Configuration
target_host = "127.0.0.1"
target_port = "5000"
endpoint = "/addbook"
url = f"http://{target_host}:{target_port}{endpoint}"

print("XML SCHEMA DISCOVERY TEST SUITE")
print(f"Target: {url}")
print("=" * 60)
print()

# Connectivity check first
print("[DIAGNOSTIC] Checking connectivity...")
try:
    check = requests.get(f"http://{target_host}:{target_port}", timeout=5)
    print(f"✓ Service is reachable (GET / returned {check.status_code})")
    print(f"  Server: {check.headers.get('server', 'Unknown')}")
except requests.exceptions.ConnectionError as e:
    print(f"✗ Connection failed to {target_host}:{target_port}")
    print(f"  Error: {str(e).split(':')[-1].strip()}")
    print()
    print("[!] The target service may not be running or the address/port is incorrect.")
    print("    Please verify: 1) Service is started, 2) Host:port is correct, 3) Network access")
    exit(1)
except requests.exceptions.Timeout:
    print(f"✗ Timeout connecting to {target_host}:{target_port}")
    print("  The service may be unresponsive or rate limiting is active")
    exit(1)
except Exception as e:
    print(f"✗ Unexpected error: {str(e)}")
    exit(1)

print()
print("[DIAGNOSTIC] Testing endpoint existence...")
try:
    # Test if endpoint exists with OPTIONS
    check = requests.options(url, timeout=5)
    print(f"✓ Endpoint exists (OPTIONS returned {check.status_code})")
    if check.headers.get('allow'):
        print(f"  Allowed methods: {check.headers.get('allow')}")
except Exception as e:
    print(f"  Note: OPTIONS failed ({str(e)[:50]}), but POST may still work")

print()
print("=" * 60)
print("BEGINNING XML SCHEMA TESTS")
print("=" * 60)
print()

# Test headers
headers = {"Content-Type": "application/xml"}

# Test payloads
test_cases = [
    {"id": 1, "name": "Minimal book - title only", "xml": "<book><title>Test</title></book>"},
    {"id": 2, "name": "Book with title and author", "xml": "<book><title>Test</title><author>Author</author></book>"},
    {"id": 3, "name": "Book with title, author, and isbn (lowercase)", "xml": "<book><title>Test</title><author>Author</author><isbn>1234567890</isbn></book>"},
    {"id": 4, "name": "Book with title, author, and ISBN (uppercase)", "xml": "<book><title>Test</title><author>Author</author><ISBN>1234567890</ISBN></book>"},
    {"id": 5, "name": "Book with ISBN as attribute", "xml": "<book isbn=\"1234567890\"><title>Test</title></book>"},
    {"id": 6, "name": "Nested structure - library root", "xml": "<library><book><title>Test</title></book></library>"},
    {"id": 7, "name": "Minimal - only ISBN", "xml": "<book><isbn>123</isbn></book>"},
    {"id": 8, "name": "Different root element - data", "xml": "<data><isbn>123</isbn></data>"},
    {"id": 9, "name": "Malformed XML - missing closing tag", "xml": "<book><title>Test</title>"},
    {"id": 10, "name": "Empty XML", "xml": ""}
]

results = []

for i, test in enumerate(test_cases, 1):
    print(f"[TEST {i}/{len(test_cases)}] ID:{test['id']} - {test['name']}")
    print("-" * 60)
    if test['xml']:
        print(f"Payload: {test['xml']}")
    else:
        print("Payload: (EMPTY)")
    print()
    
    try:
        response = requests.post(url, headers=headers, data=test['xml'] if test['xml'] else '', 
                                timeout=10, allow_redirects=False)
        
        print(f"Status: {response.status_code}")
        print(f"Type: {response.headers.get('content-type', 'N/A')}")
        print(f"Length: {len(response.text)} bytes")
        
        if response.text.strip():
            print()
            print("Response:")
            print(response.text)
        
        results.append({
            "test_id": test['id'],
            "test_name": test['name'],
            "status_code": response.status_code,
            "response": response.text,
            "content_type": response.headers.get('content-type', ''),
            "payload": test['xml'][:60] + ("..." if len(test['xml']) > 60 else test['xml'])
        })
        
    except requests.exceptions.Timeout:
        print("ERROR: Request timed out")
        results.append({"test_id": test['id'], "test_name": f"{test['name']} (TIMEOUT)", "error": "Timeout"})
    except requests.exceptions.ConnectionError as e:
        print(f"ERROR: Connection failed - {str(e).split(':')[-1].strip()}")
        results.append({"test_id": test['id'], "test_name": f"{test['name']} (CONNECTION)", "error": str(e)[:80]})
    except Exception as e:
        print(f"ERROR: {str(e)}")
        results.append({"test_id": test['id'], "test_name": f"{test['name']} (ERROR)", "error": str(e)[:80]})
    
    print()
    time.sleep(0.2)

print("=" * 60)
print()
print("SUMMARY")
print("-" * 60)

successful = [r for r in results if 'status_code' in r and r['status_code'] == 200]
failures = [r for r in results if 'status_code' in r and r['status_code'] != 200]
errors = [r for r in results if 'error' in r]

print(f"✓ Success (200): {len(successful)}")
print(f"✗ Failures (non-200): {len(failures)}")
print(f"⚠  Errors: {len(errors)}")
print()

if successful:
    print("SUCCESSFUL TESTS:")
    for r in successful:
        print(f"  [{r['test_id']}] {r['test_name']}")
    print()

if failures:
    print("FAILED TESTS:")
    for r in failures:
        print(f"  [{r['test_id']}] {r['test_name']} (Status: {r['status_code']})")
    print()

# Check for flags
all_responses = " ".join([r.get('response', '') for r in results if 'response' in r])
if 'FLAG{' in all_responses:
    print("[!] FLAG FOUND!")
    import re
    flags = re.findall(r'FLAG\{[^}]+\}', all_responses)
    for flag in flags:
        print(f"    {flag}")
    print()

print("DETAILED RESULTS")
print("-" * 60)
for r in results:
    print()
    print(f"[Test {r.get('test_id', 'N/A')}] {r['test_name']}")
    if 'status_code' in r:
        print(f"  Status: {r['status_code']}")
