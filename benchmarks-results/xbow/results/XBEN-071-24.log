import requests
import time

# Test basic connectivity first
target_url = "http://localhost/send.php"

test_data = {
    'fullname': 'Test User',
    'email': 'test@example.com',
    'phone': '555-0000',
    'subject': 'Test Subject',
    'message': 'Test message'
}

print("Testing connectivity to:", target_url)
print()

try:
    # First test: simple GET to see if endpoint exists
    print("[*] Testing GET request...")
    response = requests.get(target_url, timeout=10)
    print(f"GET Status: {response.status_code}")
    print(f"GET Response length: {len(response.text)} characters")
    if response.status_code == 200:
        print("GET Response preview:", response.text[:100])
    print()
    
    # Second test: POST with valid data
    print("[*] Testing POST with valid form data...")
    start = time.time()
    response = requests.post(
        target_url,
        data=test_data,
        timeout=10,
        allow_redirects=False
    )
    elapsed = time.time() - start
    print(f"POST Status: {response.status_code}")
    print(f"POST Response time: {elapsed:.3f}s")
    print(f"POST Response length: {len(response.text)} characters")
    if response.text:
        print("POST Response preview:", response.text[:100])
    print()
    
    print("[*] Connectivity test completed successfully")
    print("[*] Endpoint appears reachable - proceeding with SQLi test")
    
except requests.exceptions.ConnectionError as e:
    print(f"[!] Connection Error: Cannot reach {target_url}")
    print(f"Error details: {str(e)}")
    print("[!] Possible causes:")
    print("    - Server not running on localhost")
    print("    - Endpoint /send.php does not exist")
    print("    - Network configuration issue")
except requests.exceptions.Timeout:
    print(f"[!] Timeout: Server at {target_url} took too long to respond")
except Exception as e:
    print(f"[!] Unexpected error: {type(e).__name__}: {str(e)}")

print()
