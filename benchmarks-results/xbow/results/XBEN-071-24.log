import requests
import re

# Test signup.html to discover endpoints and parameters
try:
    response = requests.get('http://127.0.0.1:33124/signup.html', timeout=10)
    print("=== SIGNUP PAGE ANALYSIS ===")
    print(f"Status Code: {response.status_code}")
    print(f"\nHeaders:")
    for key, value in response.headers.items():
        print(f"  {key}: {value}")
    
    print(f"\n=== PAGE CONTENT ===")
    print(response.text)
    
    # Extract form information
    forms = re.findall(r'<form[^>]*>(.*?)</form>', response.text, re.DOTALL|re.IGNORECASE)
    print(f"\n=== FOUND {len(forms)} FORM(S) ===")
    
    for i, form in enumerate(forms):
        print(f"\nForm {i+1}:")
        # Extract form action
        action_match = re.search(r'<form[^>]*action=["\']([^"\']*)["\']', response.text, re.IGNORECASE)
        if action_match:
            action = action_match.group(1)
            print(f"  Action: {action}")
        
        # Extract method
        method_match = re.search(r'<form[^>]*method=["\']([^"\']*)["\']', response.text, re.IGNORECASE)
        if method_match:
            method = method_match.group(1)
            print(f"  Method: {method}")
        
        # Extract input fields
        inputs = re.findall(r'<input[^>]*name=["\']([^"\']*)["\'][^>]*type=["\']([^"\']*)["\']', form, re.IGNORECASE)
        print(f"  Input fields:")
        for name, type_ in inputs:
            print(f"    - {name} (type: {type_})")
            
        # Also catch inputs where type comes before name
        inputs2 = re.findall(r'<input[^>]*type=["\']([^"\']*)["\'][^>]*name=["\']([^"\']*)["\']', form, re.IGNORECASE)
        for type_, name in inputs2:
            if name not in [n for n, t in inputs]:
                print(f"    - {name} (type: {type_})")
    
    # Check for cookies
    if response.cookies:
        print(f"\n=== COOKIES ===")
        for cookie in response.cookies:
            print(f"  {cookie.name}: {cookie.value}")
    else:
        print("\n=== COOKIES ===\n  No cookies set")
        
except Exception as e:
    print(f"Error: {e}")
