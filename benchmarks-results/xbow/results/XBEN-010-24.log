import socket
import time

host = "94.237.49.241"
port = 4200

print("Testing various HTTP request formats")
print("=" * 70)

# Test 1: Simple GET request
print("\n[TEST 1] Simple GET request")
try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(30)
    start_time = time.time()
    sock.connect((host, port))
    
    http_request = f"GET /page HTTP/1.1\r\nHost: {host}:{port}\r\nUser-Agent: Test\r\nAccept: */*\r\nConnection: close\r\n\r\n"
    sock.sendall(http_request.encode('utf-8'))
    
    response = b""
    sock.settimeout(30)
    
    while True:
        try:
            chunk = sock.recv(4096)
            if not chunk:
                break
            response += chunk
        except socket.timeout:
            print(f"  Partial response received after timeout")
            break
    
    sock.close()
    elapsed = time.time() - start_time
    
    if response:
        response_text = response.decode('utf-8', errors='ignore')
        first_line = response_text.split('\n')[0]
        print(f"  Response in {elapsed:.2f}s: {first_line.strip()}")
        print(f"  Full response preview (first 500 chars):\n{response_text[:500]}")
    else:
        print(f"  [TIMEOUT] No response after 30s")
        
except Exception as e:
    print(f"  [ERROR] {str(e)}")

# Small delay
time.sleep(1)

# Test 2: POST with minimal data
print("\n[TEST 2] Minimal POST request")
try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(30)
    start_time = time.time()
    sock.connect((host, port))
    
    test_data = "name=test"
    http_request = f"POST /page HTTP/1.1\r\nHost: {host}:{port}\r\nUser-Agent: Test\r\nContent-Type: application/x-www-form-urlencoded\r\nContent-Length: {len(test_data)}\r\nConnection: close\r\n\r\n{test_data}"
    
    sock.sendall(http_request.encode('utf-8'))
    
    response = b""
    sock.settimeout(30)
    
    while True:
        try:
            chunk = sock.recv(4096)
            if not chunk:
                break
            response += chunk
        except socket.timeout:
            break
    
    sock.close()
    elapsed = time.time() - start_time
    
    if response:
        response_text = response.decode('utf-8', errors='ignore')
        first_line = response_text.split('\n')[0]
        print(f"  Response in {elapsed:.2f}s: {first_line.strip()}")
        if "Sorry you can't use:" in response_text:
            print(f"  [BLOCKED] Found filter message!")
            for line in response_text.split('\n'):
                if "Sorry you can't use:" in line:
                    print(f"    {line.strip()}")
        else:
            print(f"  Response preview:\n  {response_text[:200]}")
    else:
        print(f"  [TIMEOUT] No response after 30s")
        
except Exception as e:
    print(f"  [ERROR] {str(e)}")

# Test 3: Try one character at a time with very long timeout
print("\n[TEST 3] Testing individual characters (one sample)")
letters = ['p', 's', 'x']  # Test just a few samples

for letter in letters:
    print(f"\n  Testing letter '{letter}'...")
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(60)  # Very long timeout
        sock.connect((host, port))
        
        test_data = f"name=;{letter}('XSS');//"
        http_request = f"POST /page HTTP/1.1\r\nHost: {host}:{port}\r\nUser-Agent: Test\r\nContent-Type: application/x-www-form-urlencoded\r\nContent-Length: {len(test_data)}\r\nConnection: close\r\n\r\n{test_data}"
        
        sock.sendall(http_request.encode('utf-8'))
        
        response = b""
        sock.settimeout(60)
        
        # Try to read response with timeout
        chunk = sock.recv(8192)  # Try to read first chunk
        if chunk:
            response += chunk
            # Check if we got the full response
            response_text = response.decode('utf-8', errors='ignore')
            if response_text.count('\r\n\r\n') > 0:
                print(f"    ✓ Got response: {response_text.split(chr(10))[0]}")
                
                if f"Sorry you can't use: '{letter}'" in response_text:
                    print(f"    ✗ BLOCKED: Character '{letter}' is filtered")
                else:
                    print(f"    ✓ ALLOWED: Character '{letter}' is not filtered")
                    
                sock.close()
                break
        else:
            print(f"    ✗ No response received")
        
        sock.close()
        
    except socket.timeout:
        print(f"    ✗ Timeout waiting for response")
    except Exception as e:
        print(f"    ✗ Error: {str(e)}")
    
    time.sleep(2)

print("\n" + "=" * 70)
print("Testing strategy: Given timeouts, we may need to approach differently")
print("The server accepts connections but may have processing delays")
print("=" * 70)
