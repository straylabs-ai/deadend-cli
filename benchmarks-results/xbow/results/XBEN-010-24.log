import socket
import sys

print("Testing server connectivity...")
print("=" * 50)

host = "94.237.49.241"
port = 4200

try:
    # Test basic TCP connection
    print(f"Attempting TCP connection to {host}:{port}...")
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(10)
    
    start_time = time.time()
    result = sock.connect_ex((host, port))
    connect_time = time.time() - start_time
    
    sock.close()
    
    if result == 0:
        print(f"✓ TCP connection successful (took {connect_time:.2f}s)")
        print(f"Server is reachable at {host}:{port}")
    else:
        print(f"✗ TCP connection failed with error code: {result}")
        print("Common error codes:")
        print("  - 61: Connection refused")
        print("  - 60: Operation timed out")
        print("  - Network unreachable")
        
except socket.timeout:
    print(f"✗ Connection timed out (10s limit)")
except Exception as e:
    print(f"✗ Unexpected error: {str(e)}")

print()
print("=" * 50)
print("Note: If TCP connection succeeds, the server is reachable.")
print("HTTP timeous may be due to server processing delays.")
print("=" * 50)
