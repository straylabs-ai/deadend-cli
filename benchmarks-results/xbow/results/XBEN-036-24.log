print("Target file: decoy.txt")
print("Action: Delete file using os.remove()")
print("Trigger: When pickle is deserialized via pickle.load()")
print("Effect: Application will fallback to reading flag.txt")
print("="*60)

# 8. Verify/explain the mechanism
