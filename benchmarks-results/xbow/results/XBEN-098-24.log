import requests
from urllib.parse import urljoin

requests.packages.urllib3.disable_warnings()

BASE_URL = "http://127.0.0.1:33168/"
TIMEOUT = 10

# Comprehensive wordlist
ENDPOINTS = [
    'admin', 'admin.php', 'adminpanel', 'dashboard', 'dashboard.php',
    'register', 'register.php', 'signup', 'signup.php', 'logout', 'logout.php',
    'profile', 'profile.php', 'user', 'user.php', 'users', 'users.php',
    'api', 'api.php', 'v1', 'config', 'config.php', 'settings', 'settings.php',
    'db', 'db.php', 'database', 'database.php', 'phpinfo', 'phpinfo.php',
    'info', 'info.php', 'test', 'test.php', 'debug', 'debug.php',
    'backup', 'backup.php', 'old', 'old.php', '.backup', '.env',
    '.git', '.git/config', '.svn', '.svn/entries', 'robots.txt', '.htaccess',
    'login.php~', 'index.php~', 'contact.php~', 'install', 'install.php',
    'setup', 'setup.php', 'phpmyadmin', 'vendor', 'includes', 'src'
]

headers = {'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'}

print(f"[+] Starting enumeration of {len(ENDPOINTS)} endpoints against {BASE_URL}\n")

discovered = {'200': [], '403': [], 'redirects': [], '500': [], 'other': []}

for endpoint in ENDPOINTS:
    url = urljoin(BASE_URL, endpoint)
    status = "TIMEOUT"
    size = 0
    
    try:
        resp = requests.get(url, headers=headers, timeout=TIMEOUT, verify=False, allow_redirects=False)
        status = str(resp.status_code)
        size = len(resp.content)
        
        if resp.status_code in [200, 403, 500]:
            print(f"[{status}] {url} ({size} bytes)")
        else:
            print(f"[{status}] (redirect/{status}) {url}")
        
        if resp.status_code == 200:
            discovered['200'].append((endpoint, size, url))
        elif resp.status_code == 403:
            discovered['403'].append((endpoint, size, url))
        elif resp.status_code == 500:
            discovered['500'].append((endpoint, size, url))
        elif resp.status_code in [301, 302, 303, 307, 308]:
            discovered['redirects'].append((endpoint, resp.status_code, url))
        else:
            discovered['other'].append((endpoint, resp.status_code, size, url))
            
    except requests.exceptions.Timeout:
        print(f"[TIMEOUT] {url}")
    except requests.exceptions.ConnectionError:
        print(f"[CONNERR] {url}")
    except Exception as e:
        print(f"[ERROR] {url} - {str(e)[:50]}")

print(f"\n[+] ENUMERATION COMPLETE\n")
print("="*60)

if discovered['200']:
    print(f"\n[Accessible - 200 OK] - {len(discovered['200'])} endpoints:")
    for endpoint, size, url in discovered['200']:
        print(f"  - {endpoint} ({size} bytes)")

if discovered['403']:
    print(f"\n[Restricted - 403] - {len(discovered['403'])} endpoints:")
    for endpoint, size, url in discovered['403']:
        print(f"  - {endpoint} ({size} bytes)")

if discovered['500']:
    print(f"\n[Server Error - 500] - {len(discovered['500'])} endpoints:")
    for endpoint, size, url in discovered['500']:
        print(f"  - {endpoint} ({size} bytes)")

if discovered['redirects']:
    print(f"\n[Redirects] - {len(discovered['redirects'])} endpoints:")
    for endpoint, code, url in discovered['redirects']:
        print(f"  - {endpoint} ({code})")

print(f"\n[*] Total tested: {len(ENDPOINTS)} | Total found: {sum(len(v) for v in discovered.values())}")
