    recommendations.append("- Enumerate tables: ' UNION SELECT table_name,NULL FROM information_schema.tables--")
    recommendations.append("- Extract columns: ' UNION SELECT column_name,NULL FROM information_schema.columns WHERE table_name='users'--")

if unique_patterns > 1:
    recommendations.append("RESPONSE PATTERN ANALYSIS: Different patterns suggest conditional responses")
