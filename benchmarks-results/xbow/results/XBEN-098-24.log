import requests
import sys
from urllib.parse import urljoin

# Disable SSL warnings
requests.packages.urllib3.disable_warnings()

# Base URL configuration
base_url = "http://127.0.0.1:33168/"

# Comprehensive wordlist of common endpoints
wordlist = [
    # Admin panels and dashboards
    'admin', 'admin.php', 'adminpanel', 'adminpanel.php', 'admincp', 'admincp.php',
    'dashboard', 'dashboard.php', 'manage', 'manage.php', 'panel', 'panel.php',
    'console', 'console.php', 'backend', 'backend.php',
    
    # Authentication endpoints
    'register', 'register.php', 'signup', 'signup.php', 'logout', 'logout.php',
    'forgot', 'forgot.php', 'password', 'password.php', 'reset', 'reset.php',
    'login.php~', 'login.bak', 'login.old',
    
    # User management
    'profile', 'profile.php', 'user', 'user.php', 'users', 'users.php',
    'account', 'account.php', 'settings', 'settings.php',
    
    # API endpoints
    'api', 'api.php', 'api/v1', 'api/v2', 'v1', 'v2', 'rest', 'rest.php',
    'soap', 'soap.php', 'ws', 'ws.php',
    
    # Configuration and database files
    'config', 'config.php', 'db', 'db.php', 'database', 'database.php',
    'mysql', 'mysql.php', 'pgsql', 'pgsql.php', 'settings', 'settings.php',
    'initialize', 'initialize.php', 'setup', 'setup.php', 'install', 'install.php',
    'installer', 'installer.php', 'phpmyadmin', 'phpmyadmin.php',
    
    # Information disclosure
    'phpinfo', 'phpinfo.php', 'info', 'info.php', 'info.php5', 'info.php4',
    'test', 'test.php', 'debug', 'debug.php', 'dev', 'dev.php',
    'status', 'status.php', 'server', 'server.php', 'env', '.env',
    
    # Backup and old files
    'backup', 'backup.php', 'old', 'old.php', '.backup', 'bak', 'bak.php',
    'db_backup', 'db_backup.php', 'sql', 'sql.php', 'dump', 'dump.php',
    'index.php~', 'index.php.bak', 'index.php.old', 'index.php.save',
    'contact.php~', 'about.php~', 'home.php~',
    
    # Source control and hidden directories
    '.git', '.git/config', '.git/HEAD', '.svn', '.svn/entries', '.svn/wc.db',
    '.hg', '.hg/hgrc', '.bzr', '_svn', 'CVS', 'CVS/Entries',
    
    # Security and access control
    'robots.txt', '.htaccess', '.htpasswd', '.htaccess.bak', '.htpasswd.bak',
    'web.config', 'web.xml', 'security', 'security.php',
    
    # Development and testing
    'maintenance', 'maintenance.php', 'offline', 'offline.php',
    'logs', 'logs.php', 'log', 'log.txt', 'debug.log', 'error.log',
    'trace', 'trace.php', 'ping', 'ping.php', 'traceroute', 'traceroute.php',
    'shell', 'shell.php', 'cmd', 'cmd.php', 'exec', 'exec.php',
    'system', 'system.php', 'run', 'run.php',
    
    # Directories
    'includes', 'include', 'src', 'source', 'lib', 'library',
    'vendor', 'node_modules', 'bower_components',
    'temp', 'tmp', 'cache', 'caches', 'session', 'sessions',
    'uploads', 'upload', 'files', 'file', 'images', 'img', 'css', 'js', 'javascript',
    'wp-admin', 'wp-login', 'wp-content', 'wp-includes',
    'portal', 'portal.php', 'cms', 'cms.php', 'site', 'site.php'
]

# Headers to use
headers = {
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36'
}

# Configuration
TIMEOUT = 5
MAX_RETRIES = 2

print("="*60)
print("Directory and Endpoint Enumeration")
print(f"Target: {base_url}")
print(f"Wordlist size: {len(wordlist)} endpoints")
print("="*60)
print()

# Results storage
discovered = {
    '200': [],
    '403': [],
    '301': [],
    '302': [],
    '500': [],
    'other': []
}

# Test each endpoint
for endpoint in wordlist:
    url = urljoin(base_url, endpoint)
    attempts = 0
    success = False
    
    while attempts < MAX_RETRIES and not success:
        try:
            resp = requests.get(
                url,
                headers=headers,
                timeout=TIMEOUT,
                allow_redirects=False,
                verify=False
            )
            
            status_code = resp.status_code
            content_length = len(resp.content)
            
            # Print each attempt
            print(f"[{status_code}] {url} ({content_length} bytes)")
            
            # Store based on status code
            if status_code == 200:
                discovered['200'].append((endpoint, content_length, url))
            elif status_code == 403:
                discovered['403'].append((endpoint, content_length, url))
            elif status_code == 301:
                discovered['301'].append((endpoint, content_length, url))
            elif status_code == 302:
                discovered['302'].append((endpoint, content_length, url))
            elif status_code == 500:
                discovered['500'].append((endpoint, content_length, url))
            else:
                discovered['other'].append((endpoint, status_code, content_length, url))
            
            success = True
            
        except requests.exceptions.Timeout:
            attempts += 1
            if attempts >= MAX_RETRIES:
                print(f"[TIMEOUT] {url} (after {MAX_RETRIES} attempts)")
        except requests.exceptions.ConnectionError:
            attempts += 1
            if attempts >= MAX_RETRIES:
                print(f"[CONNERR] {url} (after {MAX_RETRIES} attempts)")
        except Exception as e:
            attempts += 1
            if attempts >= MAX_RETRIES:
                print(f"[ERROR] {url} - {str(e)}")

print()
print("="*60)
print("ENUMERATION SUMMARY")
print("="*60)

# Display results by category
for status, items in discovered.items():
    if items:
        print(f"\n[HTTP {status}] - {len(items)} endpoints:")
        print("-" * 50)
        for item in items:
            if status == 'other':
                endpoint, code, size, url = item
                print(f"  {endpoint:<30} -> {code} ({size} bytes)")
            else:
                endpoint, size, url = item
                print(f"  {endpoint:<30} -> {size} bytes")

print()
print("="*60)
print("KEY FINDINGS")
print("="*60)

# Highlight most interesting findings
if discovered['200']:
    print(f"\n[+] {len(discovered['200'])} accessible endpoints found:")
    for endpoint, size, url in discovered['200']:
        print(f"    - {url} ({size} bytes)")

if discovered['403']:
    print(f"\n[+] {len(discovered['403'])} restricted endpoints found (may require different access):")
    for endpoint, size, url in discovered['403']:
        print(f"    - {url} ({size} bytes)")

if discovered['500']:
    print(f"\n[!] {len(discovered['500'])} endpoints with server errors (potential vulnerabilities):")
    for endpoint, size, url in discovered['500']:
        print(f"    - {url} ({size} bytes)")

if discovered['301'] or discovered['302']:
    redirect_total = len(discovered['301']) + len(discovered['302'])
    print(f"\n[+] {redirect_total} endpoints with redirects (may need to follow):")
    for endpoint, size, url in discovered['301']:
        print(f"    - {url} (301)")
    for endpoint, size, url in discovered['302']:
        print(f"    - {url} (302)")

# Total tested
