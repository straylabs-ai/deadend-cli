import socket
import time
import urllib.parse

# Direct HTTP POST testing to avoid broken pipe issues
TARGET_HOST = "127.0.0.1"
TARGET_PORT = 33168
TIMEOUT = 15
BASELINE_SAMPLES = 3

def send_raw_http_request(method, path, data_dict):
    """Send raw HTTP request using sockets"""
    try:
        # Create socket
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(TIMEOUT)
        sock.connect((TARGET_HOST, TARGET_PORT))
        
        # Prepare POST data
        post_data = urllib.parse.urlencode(data_dict)
        
        # Build HTTP request
        request_lines = [
            f"{method} {path} HTTP/1.1",
            f"Host: {TARGET_HOST}:{TARGET_PORT}",
            "User-Agent: SQLi-Test/1.0",
            "Content-Type: application/x-www-form-urlencoded",
            f"Content-Length: {len(post_data)}",
            "Connection: close",
            "",
            post_data
        ]
        
        request = "\r\n".join(request_lines)
        
        # Send request
        start_time = time.time()
        sock.sendall(request.encode())
        
        # Receive response
        response = b""
        while True:
            try:
                chunk = sock.recv(4096)
                if not chunk:
                    break
                response += chunk
            except socket.timeout:
                break
        
        end_time = time.time()
        response_time = end_time - start_time
        
        sock.close()
        
        # Parse response
        response_str = response.decode('utf-8', errors='ignore')
        
        # Extract status code
        status_code = 0
        if "\r\n" in response_str:
            first_line = response_str.split("\r\n")[0]
            if " " in first_line:
                status_code = int(first_line.split()[1])
        
        # Extract body
        body = ""
        if "\r\n\r\n" in response_str:
            body = response_str.split("\r\n\r\n", 1)[1]
        
        return {
            "status_code": status_code,
            "body": body,
            "response_time": response_time,
            "full_response": response_str[:1000]
        }
        
    except Exception as e:
        return {"error": str(e), "response_time": 0}

# Get baseline response time
print("[+] Getting baseline response time...")
baseline_times = []
for i in range(BASELINE_SAMPLES):
    result = send_raw_http_request("POST", "/login.php", {"username": "test", "password": "test"})
    if "response_time" in result and "error" not in result:
        baseline_times.append(result["response_time"])
        print(f"  Baseline {i+1}: {result['response_time']:.3f}s")
    time.sleep(0.5)

baseline_avg = sum(baseline_times) / len(baseline_times) if baseline_times else 1.0
print(f"[+] Average baseline: {baseline_avg:.3f}s\n")

