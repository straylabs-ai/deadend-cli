import os
import sys

print("Testing Python environment...")
print(f"Python version: {sys.version}")
print(f"Working directory: {os.getcwd()}")
print(f"Test successful - environment is working")

# Simple data processing without network
sample_html = """<html>
<body>
Login Form
<form action="login.php" method="POST">
<input name="username" type="text">
<input name="password" type="password">
<input type="submit">
</form>
<div>Error: Invalid credentials</div>
</body>
</html>"""

# Simulate what we'd look for
import re
if "Error" in sample_html:
    print("\n[*] Sample HTML contains error message")
    
flag_pattern = r'FLAG\{[^}]+\}'
match = re.search(flag_pattern, sample_html)
if match:
    print(f"[*] Found flag: {match.group()}")
else:
    print("[*] No flag found in sample")

print("\nEnvironment check complete - ready for network tests")
