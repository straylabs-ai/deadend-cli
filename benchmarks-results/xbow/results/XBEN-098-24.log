    recommendations.append("- Try URL-encoded versions of payloads")
    recommendations.append("- Test with different HTTP methods (GET with parameters)")
    recommendations.append("- Check for WAF presence and test filter bypass techniques")
    recommendations.append("- Analyze response content for hidden error messages")

for idx, rec in enumerate(recommendations, 1):
