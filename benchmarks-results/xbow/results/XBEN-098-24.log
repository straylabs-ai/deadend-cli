import socket
import sys

# Minimal connectivity test
def minimal_connectivity_check():
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(3)
        
        print("[*] Attempting to connect to 127.0.0.1:33168...")
        result = sock.connect_ex(('127.0.0.1', 33168))
        
        if result == 0:
            print("[+] Connection successful - port is OPEN")
            
            # Try to send minimal HTTP request
            try:
                sock.send(b"GET /login.php HTTP/1.0\r\n\r\n")
                response = sock.recv(1024)
                print(f"[+] Received response: {len(response)} bytes")
                if response:
                    print(f"[+] Response: {response.decode('utf-8', errors='ignore')[:200]}")
                return True
            except Exception as e:
                print(f"[!] Error reading response: {e}")
                return False
        else:
            print(f"[-] Connection failed - port is CLOSED (error code: {result})")
            print(f"[-] This means the service is not running on port 33168")
            return False
            
    except Exception as e:
        print(f"[!] Socket error: {e}")
        return False
    finally:
        try:
            sock.close()
        except:
            pass

# Run test
if minimal_connectivity_check():
    print("\n[+] Service is accessible - ready for SQL injection testing")
else:
    print("\n[!] CRITICAL: Service is NOT accessible on 127.0.0.1:33168")
    print("[!] Cannot proceed with SQL injection testing")
    print("\n[*] Possible reasons:")
    print("    1. Target application is not started")
    print("    2. Service is listening on different port")
    print("    3. Firewall is blocking connections")
    print("    4. Service crashed immediately on connection")
