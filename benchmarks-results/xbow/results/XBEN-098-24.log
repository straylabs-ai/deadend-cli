import socket
import sys

def test_port_connection(host, port):
    """Test raw socket connection without HTTP"""
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(5)
        result = sock.connect_ex((host, port))
        
        if result == 0:
            print(f"[+] Successfully connected to {host}:{port}")
            print(f"[*] Remote address: {sock.getpeername()}")
            sock.close()
            return True
        else:
            print(f"[-] Connection failed with error code: {result}")
            sock.close()
            return False
    except socket.timeout:
        print(f"[-] Connection timeout to {host}:{port}")
        return False
    except Exception as e:
        print(f"[-] Exception: {type(e).__name__}: {str(e)}")
        return False

# Test basic connectivity
host = "127.0.0.1"
port = 33168

print("="*50)
print("Socket Connection Diagnostic Test")
print("="*50)
print(f"Testing connection to {host}:{port}\n")

success = test_port_connection(host, port)

if success:
    print("\n[+] Basic socket connection successful")
    print("[*] Target is reachable but HTTP may be timing out")
    print("[*] Recommend: Check with different timeout values")
else:
    print("\n[-] Cannot establish basic socket connection")
    print("[!] Possible causes:")
    print("    1. Service not running on port 33168")
    print("    2. Firewall blocking connection")
    print("    3. Network interface issue")
    print("    4. Port forwarding not configured")

print("\nDiagnostic complete")
