import socket
import os

# Test if port is accessible
def test_port_connection():
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(5)
        result = sock.connect_ex(('127.0.0.1', 33168))
        
        if result == 0:
            print("[+] Port 33168 is OPEN and accepting connections")
            # Try to get any banner
            try:
                sock.send(b"GET /login.php HTTP/1.0\r\n\r\n")
                banner = sock.recv(1024).decode('utf-8', errors='ignore')
                print(f"[+] Initial response: {banner[:200]}")
            except:
                pass
        else:
            print(f"[-] Port 33168 is CLOSED or not accepting connections (error code: {result})")
            
        sock.close()
        return result == 0
    except Exception as e:
        print(f"[!] Error testing port: {e}")
        return False

if test_port_connection():
    print("\n[+] Port is accessible, proceeding with testing...")
else:
    print("\n[!] Cannot connect to port 33168 - the service may not be running")
    print("[!] Check if the target application is started")
