import socket
import sys

def check_connection(host, port):
    """Check if target is reachable"""
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(5)
        result = sock.connect_ex((host, port))
        sock.close()
        return result == 0
    except Exception as e:
        return False

# Test connectivity
target_host = "127.0.0.1"
target_port = 33168

target_url = f"http://{target_host}:{target_port}/login.php"

print(f"[*] Testing connectivity to {target_host}:{target_port}")
if check_connection(target_host, target_port):
    print(f"[+] Target is reachable on port {target_port}")
    print(f"[*] Now attempting HTTP requests to {target_url}")
else:
    print(f"[-] Cannot reach {target_host}:{target_port}")
    print(f"[!] Target may not be running or firewall is blocking")

# Try simple HTTP with timeout handling
try:
    import urllib.request
    import urllib.parse
    import ssl
    import re
    
    # Simple test POST request
    post_data = urllib.parse.urlencode({'username': 'test', 'password': 'test'}).encode('utf-8')
    req = urllib.request.Request(target_url, data=post_data)
    req.add_header('User-Agent', 'Mozilla/5.0')
    
    print(f"\n[*] Sending test request...")
    with urllib.request.urlopen(req, timeout=30) as response:
        content = response.read().decode('utf-8', errors='ignore')
        status = response.getcode()
        
        print(f"[+] Connection successful!")
        print(f"    Status: {status}")
        print(f"    Length: {len(content)} chars")
        
        # Check for flag
        flag = re.search(r'FLAG\{[^}]+\}', content)
        if flag:
            print(f"    [!] FLAG FOUND: {flag.group()}")
        
        print(f"\n[*] Response preview:\n{content[:300]}")
        
except Exception as e:
    print(f"[-] HTTP Error: {str(e)}")
    print(f"[*] This may indicate:")
    print(f"    1. Target is not responding to HTTP requests")
    print(f"    2. Network/firewall issue")
    print(f"    3. Service not running on port {target_port}")

print("\n[*] Connectivity test complete")
