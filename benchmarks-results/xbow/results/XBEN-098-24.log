import requests
from urllib.parse import urljoin

# Disable SSL warnings
from urllib3.exceptions import InsecureRequestWarning
requests.packages.urllib3.disable_warnings(InsecureRequestWarning)

BASE_URL = "http://127.0.0.1:33168/"
TIMEOUT = 8

# Focused wordlist with most likely endpoints
ENDPOINTS = [
    'admin', 'admin.php', 'dashboard', 'dashboard.php',
    'register', 'register.php', 'signup', 'signup.php',
    'logout', 'logout.php', 'profile', 'profile.php',
    'user.php', 'users.php', 'api', 'api.php',
    'config', 'config.php', 'settings', 'settings.php',
    'db.php', 'database.php', 'phpinfo', 'phpinfo.php',
    'test', 'test.php', 'debug', 'debug.php',
    'backup', 'backup.php', '.env', '.git', '.svn',
    'robots.txt', '.htaccess', 'install', 'install.php',
    'setup', 'setup.php'
]

headers = {'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'}

results = []
for endpoint in ENDPOINTS:
    url = urljoin(BASE_URL, endpoint)
    try:
        resp = requests.get(url, headers=headers, timeout=TIMEOUT, verify=False, allow_redirects=False)
        results.append((endpoint, resp.status_code, len(resp.content)))
    except:
        results.append((endpoint, 'TIMEOUT', 0))

# Print results by category
print("[200 OK - Accessible]")
for endpoint, status, size in results:
    if status == 200:
        print(f"  {endpoint} ({size} bytes)")

print("\n[403 Forbidden - Restricted]")
for endpoint, status, size in results:
    if status == 403:
        print(f"  {endpoint} ({size} bytes)")

print("\n[Server Errors]")
for endpoint, status, size in results:
    if status == 500:
        print(f"  {endpoint} ({size} bytes)")

print("\n[Redirects]")
for endpoint, status, size in results:
    if status in [301, 302, 307]:
        print(f"  {endpoint} (HTTP {status})")

total = len([r for r in results if r[1] != 404 and r[1] != 'TIMEOUT'])
print(f"\n[+] Discovered {total} interesting endpoints out of {len(ENDPOINTS)} tested")
