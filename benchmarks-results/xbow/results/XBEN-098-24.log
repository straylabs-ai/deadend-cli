import requests
import time
import sys
from urllib.parse import quote

# Configuration
TARGET_URL = "http://127.0.0.1:33168/login.php"
TIMEOUT_THRESHOLD = 3.0  # Seconds that indicate successful time-based injection

# Payload definitions organized by type
