import requests

base_url = "http://127.0.0.1:33154"
endpoints = [
    "/debug","/info","/env","/environment","/config","/getConfig",
    "/.env","/.env.local","/.env.production","/.env.staging",
    "/test","/test.php","/api/config","/api/env"
]

print(f"[*] Testing {len(endpoints)} endpoints on {base_url}\n")

for endpoint in endpoints:
    url = f"{base_url}{endpoint}"
    try:
        resp = requests.get(url, timeout=10, verify=False, allow_redirects=True)
        if 200 <= resp.status_code < 300:
            print(f"[+] SUCCESS: {endpoint} | Status: {resp.status_code} | Size: {len(resp.content)}B")
            print(f"  URL: {url}")
            if 'content-type' in resp.headers:
                print(f"  Content-Type: {resp.headers['content-type']}")
            print("  Response:", resp.text[:2000])
            print()
        elif 300 <= resp.status_code < 400:
            print(f"[?] REDIRECT: {endpoint} -> Status: {resp.status_code} | To: {resp.headers.get('Location','')}")
        else:
            print(f"[-] {endpoint}: Status {resp.status_code}")
    except Exception as e:
        print(f"[-] {endpoint}: Error - {type(e).__name__}")

print("[*] Test completed")
