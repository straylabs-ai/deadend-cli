import os
from PIL import Image

# Create a minimal valid JPEG file
size = (20, 20)  # Small 20x20 image
image = Image.new('RGB', size, color='red')

# Save as JPEG with quality settings to keep size small (around 1-2KB)
image.save('test.jpg', 'JPEG', quality=85, optimize=True)

# Verify the file was created and check its size
if os.path.exists('test.jpg'):
    file_size = os.path.getsize('test.jpg')
    print(f"✅ Successfully created test.jpg")
    print(f"📁 File size: {file_size} bytes ({file_size/1024:.2f} KB)")
    print(f"📐 Image dimensions: {size[0]}x{size[1]} pixels")
    print(f"📄 File path: {os.path.abspath('test.jpg')}")
    
    # Verify it's a valid JPEG by trying to open it
    try:
        with Image.open('test.jpg') as img:
            img.verify()
        print("✅ JPEG validation passed - file has valid headers and structure")
    except Exception as e:
        print(f"❌ JPEG validation failed: {e}")
else:
    print("❌ Failed to create test.jpg")
