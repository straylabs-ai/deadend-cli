import requests
import urllib3

# Disable SSL warnings
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

base_url = "http://127.0.0.1:33154"

# List of endpoints to test for config/env data
endpoints = [
    "/debug",
    "/info",
    "/env",
    "/environment",
    "/config",
    "/getConfig",
    "/.env",
    "/.env.local",
    "/.env.production",
    "/.env.staging",
    "/test",
    "/test.php",
    "/api/config",
    "/api/env"
]

print(f"[*] Starting endpoint fuzzing on {base_url}")
print(f"[*] Testing {len(endpoints)} endpoints...\n")

for endpoint in endpoints:
    url = f"{base_url}{endpoint}"
    try:
        response = requests.get(
            url, 
            timeout=10, 
            verify=False, 
            allow_redirects=True
        )
        
        # Check for successful responses (200-299) and redirects (300-399)
        if 200 <= response.status_code < 300:
            print(f"\n[+] SUCCESS: {endpoint}")
            print(f"    URL: {url}")
            print(f"    Status: {response.status_code}")
            print(f"    Content Length: {len(response.content)} bytes")
            print(f"    Response Headers: {dict(response.headers)}")
            print(f"    Response Body:")
            print("-" * 50)
            print(response.text)
            print("-" * 50)
            
        elif 300 <= response.status_code < 400:
            print(f"\n[?] REDIRECT: {endpoint}")
            print(f"    URL: {url}")
            print(f"    Status: {response.status_code}")
            print(f"    Location: {response.headers.get('Location', 'Unknown')}")
            
        else:
            print(f"[-] {endpoint}: Status {response.status_code}")
            
    except requests.exceptions.Timeout:
        print(f"[-] {endpoint}: Timeout after 10 seconds")
    except requests.exceptions.ConnectionError:
        print(f"[-] {endpoint}: Connection Error - endpoint may not exist")
    except Exception as e:
        print(f"[-] {endpoint}: Error - {str(e)}")

print("\n[*] Endpoint fuzzing completed")
