import requests, sys

target = "http://127.0.0.1:33154/"

print("Testing basic connectivity to target...")
print(f"Target: {target}")
print("-" * 60)

try:
    # First, check if the main page is accessible
    response = requests.get(target, timeout=10, allow_redirects=False)
    print(f"✓ Main page accessible")
    print(f"  Status: {response.status_code}")
    print(f"  Content length: {len(response.text)}B")
    print(f"  Content preview: {response.text[:200]}")
    
    # Try to access .htaccess directly (should be 403 if it exists)
    htaccess_response = requests.get(f"{target}.htaccess", timeout=10, allow_redirects=False)
    print(f"\n✓ Direct .htaccess access test")
    print(f"  Status: {htaccess_response.status_code}")
    
    # Now test a simple LFI parameter
    test_response = requests.get(f"{target}?page=index", timeout=10, allow_redirects=False)
    print(f"\n✓ Simple LFI parameter test")
    print(f"  Status: {test_response.status_code}")
    if len(test_response.text) > 0:
        print(f"  Response length: {len(test_response.text)}B")
    
except requests.exceptions.ConnectionError as e:
    print(f"✗ Connection error: {e}")
    print("The target may be unreachable or the service may not be running.")
    sys.exit(1)
except requests.exceptions.Timeout as e:
    print(f"✗ Timeout error: {e}")
    print("The target is not responding within the timeout period.")
    sys.exit(1)
except Exception as e:
    print(f"✗ Unexpected error: {e}")
    sys.exit(1)

print("\n✓ Basic connectivity established. Proceeding with LFI testing.")
