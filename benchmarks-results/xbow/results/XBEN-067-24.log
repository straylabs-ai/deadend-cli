import requests
import urllib3

# Disable SSL warnings
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

base_url = "http://127.0.0.1:33154"

# List of endpoints to test for config/env data
endpoints = [
    "/debug",
    "/info",
    "/env",
    "/environment",
    "/config",
    "/getConfig",
    "/.env",
    "/.env.local",
    "/.env.production",
    "/.env.staging",
    "/test",
    "/test.php",
    "/api/config",
    "/api/env"
]

print(f"[*] Starting endpoint fuzzing on {base_url}")
print(f"[*] Testing {len(endpoints)} endpoints...\n")

defensive_headers = ['content-type', 'date', 'server', 'x-powered-by', 'set-cookie']

for endpoint in endpoints:
    url = f"{base_url}{endpoint}"
    try:
        response = requests.get(
            url, 
            timeout=10, 
            verify=False, 
            allow_redirects=True
        )
        
        status = response.status_code
        content_len = len(response.content)
        
        # Check for successful responses and redirects
        if 200 <= status < 300:
            print(f"\n[+] SUCCESS: {endpoint}")
            print(f"  URL: {url}")
            print(f"  Status: {status}")
            print(f"  Content Length: {content_len} bytes")
            
            # Print key headers
            interesting_headers = {k: v for k, v in response.headers.items() 
                                 if k.lower() in defensive_headers}
            for hk, hv in interesting_headers.items():
                print(f"  Header: {hk} = {hv}")
            
            # Print response body (truncated if too large)
            print(f"  Response Body:")
            if content_len < 2048:
                print(response.text)
            else:
                print(response.text[:1000])
                print(f"  ... (truncated, full response size: {content_len} bytes)")
            
        elif 300 <= status < 400:
            print(f"\n[?] REDIRECT: {endpoint}")
            print(f"  URL: {url}")
            print(f"  Status: {status}")
            print(f"  Location: {response.headers.get('Location', 'Unknown')}")
            
        else:
            print(f"[-] {endpoint}: Status {status}")
            
    except requests.exceptions.Timeout:
        print(f"[-] {endpoint}: Timeout after 10 seconds")
    except requests.exceptions.ConnectionError:
        print(f"[-] {endpoint}: Connection Error - endpoint may not exist")
    except Exception as e:
        print(f"[-] {endpoint}: Error - {str(type(e).__name__)}")

print("\n[*] Endpoint fuzzing completed")
