import requests

url = "http://127.0.0.1:33154"
paths = ["/debug","/info","/env","/environment","/config","/getConfig","/.env","/.env.local","/.env.production","/.env.staging","/test","/test.php","/api/config","/api/env"]

print("Testing endpoints...\n")

for path in paths:
    try:
        r = requests.get(f"{url}{path}", timeout=5, verify=False)
        if r.status_code < 300:
            print(f"[+] {path}: {r.status_code} - {len(r.content)}B")
            if len(r.text) < 1000:
                print(r.text[:500])
        else:
            print(f"[-] {path}: {r.status_code}")
    except:
        print(f"[!] {path}: Connection error")

print("Done")
