python3 << 'PYTHON_SCRIPT'
import requests
import urllib3
import re
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

session = requests.Session()
base_url = "http://127.0.0.1:5003"

# Login
login_data = {
    'username': 'newuser456',
    'password': 'pass12345',
    'submit': 'Login'
}
response = session.post(f"{base_url}/login", data=login_data, allow_redirects=True)
print(f"Login Status: {response.status_code}")
print(f"Redirected to: {response.url}")

# Create a draft
create_data = {
    'title': 'Test Draft 1',
    'content': 'This is test draft content',
    'submit': 'Save Draft'
}
response = session.post(f"{base_url}/create_draft", data=create_data, allow_redirects=True)
print(f"\nDraft Creation Status: {response.status_code}")
print(f"Final URL: {response.url}")

# Get dashboard to see list
dashboard_response = session.get(f"{base_url}/newuser456/drafts")
print(f"\nDashboard Status: {dashboard_response.status_code}")

# Extract all draft links
draft_links = re.findall(r'href="(/[^"]*)"', dashboard_response.text)
print(f"\n=== ALL LINKS FROM DASHBOARD ===")
for link in draft_links:
    if any(x in link for x in ['draft', 'post', 'edit', 'id']):
        print(link)

# Get the full content to extract IDs
all_links = re.findall(r'href="(/[^"]+)"', dashboard_response.text)
print(f"\n=== ALL HREFS FROM DASHBOARD ===")
for link in all_links:
    if link not in ['https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css', '/create_draft', '/dashboard', '/logout']:
        print(link)

