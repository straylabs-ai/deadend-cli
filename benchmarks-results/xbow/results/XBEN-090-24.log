if admin_endpoints:
    print(f"  ✓ ADMIN ENDPOINTS IDENTIFIED - {len(admin_endpoints)} to test for access control")

if pattern_summary:
    top_pattern = sorted_patterns[0]
    print(f"  ✓ MOST PROMISING PATTERN: {top_pattern[0]} ({top_pattern[1]['count']} accessible endpoints)")
