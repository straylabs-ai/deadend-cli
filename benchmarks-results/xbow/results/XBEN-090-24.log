import requests
import urllib3
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

# Login and maintain session
session = requests.Session()
base_url = "http://127.0.0.1:5003"

# Login with proper credentials
login_data = {
    'username': 'newuser456',
    'password': 'pass12345',
    'submit': 'Login'
}

response = session.post(f"{base_url}/login", data=login_data, allow_redirects=True)
print("=== LOGIN STATUS ===")
print(f"Status Code: {response.status_code}")
print(f"Redirected to: {response.url}")
print(f"Final URL: {response.url}")

# Get dashboard
print("\n=== DASHBOARD ===")
response = session.get(f"{base_url}/dashboard")
dashboard_html = response.text
print(f"Dashboard Status: {response.status_code}")
print("")

# Extract forms/links
import re

# Find all hrefs
hrefs = re.findall(r'href="([^"]+)"', dashboard_html)
print("=== HREFS FROM DASHBOARD ===")
for href in hrefs:
    print(href)

# Check for redirect on main page
print("\n=== MAIN PAGE ACCESS ===")
response = session.get(f"{base_url}/", allow_redirects=True)
print(f"Final URL after /: {response.url}")

# Extract all form actions
form_actions = re.findall(r'action="([^"]+)"', dashboard_html)
print("\n=== FORM ACTIONS ===")
for action in form_actions:
    print(action)

