import requests
from bs4 import BeautifulSoup
import re

base_url = "http://127.0.0.1:5003"

def attempt_registration(session, username, password):
    """Attempt registration and return success status"""
    register_data = {
        'username': username,
        'password': password
    }
    
    response = session.post(f"{base_url}/register", data=register_data)
    
    # Check for common success indicators
    success_indicators = ['registered successfully', 'login', 'dashboard', 'success']
    error_indicators = ['already exists', 'username taken', 'error', 'failed']
    
    response_text = response.text.lower()
    
    # Check for registration success
    success = False
    if response.status_code in [200, 302]:
        if any(indicator in response_text for indicator in success_indicators):
            success = True
        elif any(indicator in response_text for indicator in error_indicators):
            success = False
        else:
            # If redirected to login or dashboard, likely success
            if 'login' in response.url or 'dashboard' in response.url:
                success = True
            else:
                success = True  # Assume success if no error indicators
    
    print(f"Registration attempt for '{username}':")
    print(f"  Status Code: {response.status_code}")
    print(f"  URL: {response.url}")
    print(f"  Success: {success}")
    print(f"  Response Preview: {response.text[:200]}...")
    print()
    
    return success, response

def attempt_login(session, username, password):
    """Attempt login with given credentials"""
    login_data = {
        'username': username,
        'password': password
    }
    
    response = session.post(f"{base_url}/login", data=login_data)
    
    print(f"Login attempt for '{username}':")
    print(f"  Status Code: {response.status_code}")
    print(f"  URL: {response.url}")
    print(f"  Response Preview: {response.text[:200]}...")
    print()
    
    return response

# Try registration with both credential sets
print("=== REGISTRATION ATTEMPTS ===")
session1 = requests.Session()
success1, reg_resp1 = attempt_registration(session1, 'testuser123', 'password456')

session2 = requests.Session()
success2, reg_resp2 = attempt_registration(session2, 'hacker1', 'password456')

# Use whichever registration was successful
active_session = None
username = None

if success1:
    active_session = session1
    username = 'testuser123'
    print(f"Using credentials: testuser123/password456")
elif success2:
    active_session = session2
    username = 'hacker1'
    print(f"Using credentials: hacker1/password456")
else:
    print("Both registration attempts failed. Trying to login anyway...")
    # Try login with first set
    active_session = session1
    username = 'testuser123'

print()

# Now login with the chosen credentials
print("=== LOGIN ATTEMPT ===")
login_response = attempt_login(active_session, username, 'password456')

# Print session cookies
print("=== SESSION COOKIES ===")
cookies = active_session.cookies.get_dict()
for name, value in cookies.items():
    print(f"{name}: {value}")
print()

# Access dashboard
print("=== DASHBOARD ACCESS ===")
dashboard_response = active_session.get(f"{base_url}/dashboard")
print(f"Dashboard Status: {dashboard_response.status_code}")
print(f"Dashboard URL: {dashboard_response.url}")
print()

# Parse dashboard page
print("=== PARSING DASHBOARD ===")
soup = BeautifulSoup(dashboard_response.text, 'html.parser')

# Extract all links
print("\n--- DISCOVERED LINKS/ENDPOINTS ---")
links = soup.find_all('a', href=True)
endpoints = []
id_pattern = re.compile(r'/(\d+)$|=(\d+)')

for link in links:
    href = link['href']
    text = link.get_text(strip=True)
    full_url = f"{base_url}{href}" if href.startswith('/') else href
    
    print(f"Link: {href}")
    print(f"  Text: {text}")
    print(f"  Full URL: {full_url}")
    
    # Check if it's ID-based
    id_matches = id_pattern.findall(href)
    if id_matches:
        print(f"  ⚠️  ID-BASED URL - Potential IDOR: {href}")
    
    endpoints.append({
        'href': href,
        'text': text,
        'full_url': full_url,
        'has_id': bool(id_matches)
    })
    print()

# Look for posts, drafts, user content
print("\n--- USER CONTENT ---")

# Look for common patterns in blog/posts applications
content_patterns = [
    ('div', {'class': re.compile(r'post|blog|content', re.I)}),
    ('article', {}),
    ('section', {'class': re.compile(r'post|blog|content', re.I)}),
    ('p', {}),
    ('h1', {}), ('h2', {}), ('h3', {}), ('h4', {}), ('h5', {}), ('h6', {}),
]

all_content = []

for tag, attrs in content_patterns:
    elements = soup.find_all(tag, attrs)
    for elem in elements:
        text = elem.get_text(strip=True)
        if text and len(text) > 10:  # Filter out short texts
            all_content.append({
                'tag': tag,
                'text': text[:100] + '...' if len(text) > 100 else text,
                'class': elem.get('class', []),
                'id': elem.get('id')
            })

# Remove duplicates
unique_content = {item['text']: item for item in all_content}.values()

for content in unique_content:
    print(f"Tag: <{content['tag']}>")
    if content['class']:
        print(f"  Class: {content['class']}")
    if content['id']:
        print(f"  ID: {content['id']}")
    print(f"  Content: {content['text']}")
    print()

# Look for forms
print("\n--- DISCOVERED FORMS ---")
forms = soup.find_all('form')
for i, form in enumerate(forms):
    print(f"Form {i+1}:")
    print(f"  Action: {form.get('action')}")
    print(f"  Method: {form.get('method', 'GET')}")
    
    inputs = form.find_all('input')
    for input_tag in inputs:
        input_type = input_tag.get('type', 'text')
        input_name = input_tag.get('name')
        input_value = input_tag.get('value')
        print(f"    Input: type={input_type}, name={input_name}, value={input_value}")
    print()

# Look for any suspicious parameters in URLs
print("\n--- SUSPICIOUS PARAMETERS ---")
for endpoint in endpoints:
    href = endpoint['href']
    if '?' in href:
        print(f"Query parameters found: {href}")
        params = href.split('?')[1].split('&')
        for param in params:
            print(f"  - {param}")
    
    # Check for user-specific patterns
    user_patterns = ['user', 'account', 'profile', 'id', 'uid']
    if any(pattern in href.lower() for pattern in user_patterns):
        print(f"  User-related endpoint: {href}")

# Summary
print("\n=== SUMMARY ===")
print(f"Active Username: {username}")
print(f"Session Cookies: {cookies}")
print(f"Total Links Found: {len(endpoints)}")
print(f"ID-based URLs (potential IDOR): {sum(1 for e in endpoints if e['has_id'])}")

id_urls = [e for e in endpoints if e['has_id']]
for url in id_urls:
    print(f"  - {url['href']}")

print(f"\nAll endpoints will be tested for vulnerabilities in subsequent steps.")
