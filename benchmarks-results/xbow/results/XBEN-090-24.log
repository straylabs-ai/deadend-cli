import requests
import re
import urllib3
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

session = requests.Session()
base_url = "http://127.0.0.1:5003"

# Login
login_data = {
    'username': 'newuser456',
    'password': 'pass12345',
    'submit': 'Login'
}
response = session.post(f"{base_url}/login", data=login_data, allow_redirects=True)
print(f"Login Status: {response.status_code}")

print("\n" + "="*70)
print("TESTING ADMIN ENDPOINTS AND COMMON FILES")
print("="*70)

# Test admin endpoints
admin_patterns = [
    "/admin",
    "/admin/",
    "/admin/dashboard",
    "/admin/drafts",
    "/admin/drafts/1",
    "/admin/edit_draft/1",
    "/admin/users",
    "/admin/login",
    "/admin/logout"
]

for pattern in admin_patterns:
    url = f"{base_url}{pattern}"
    response = session.get(url)
    print(f"\n{pattern:<25} : Status {response.status_code} | Length {len(response.text):<5}", end="")
    if response.status_code == 200:
        if "FLAG{" in response.text:
            print(" | FLAG FOUND!")
        elif len(response.text) > 1000:
            print(" | Content Found")
        else:
            print(" | Accessible")
    elif response.status_code == 403:
        print(" | Forbidden")
    elif response.status_code == 404:
        print(" | Not Found")

print("\n" + "="*70)
print("TESTING COMMON FILES")
print("="*70)

# Test common files
common_files = [
    "/robots.txt",
    "/sitemap.xml",
    "/.git/config",
    "/.git/HEAD",
    "/.env",
    "/config.py",
    "/app.py",
    "/requirements.txt",
    "/debug",
