import requests
from bs4 import BeautifulSoup
import re
import time

base_url = "http://127.0.0.1:5003"
timeout_seconds = 10

def safe_request(method, url, session=None, data=None, max_retries=2):
    """Make a request with error handling and retry logic"""
    if session is None:
        session = requests.Session()
    
    for attempt in range(max_retries):
        try:
            if method.upper() == 'POST':
                response = session.post(url, data=data, timeout=timeout_seconds)
            else:
                response = session.get(url, timeout=timeout_seconds)
            return response, None
        except Exception as e:
            error_msg = str(e)
            if attempt < max_retries - 1:
                time.sleep(1)
                continue
            return None, error_msg

def attempt_registration(session, username, password):
    """Attempt registration and return success status"""
    register_url = f"{base_url}/register"
    register_data = {'username': username, 'password': password}
    
    response, error = safe_request('POST', register_url, session, register_data)
    
    if error:
        print(f"Registration error for '{username}': {error}")
        return False, None
    
    print(f"Registration attempt for '{username}':")
    print(f"  Status Code: {response.status_code}")
    print(f"  URL: {response.url}")
    print(f"  Response Length: {len(response.text)} bytes")
    print(f"  Preview: {response.text[:150]}...")
    print()
    
    # Registration likely successful if status is 200-302 and no clear error
    success = response.status_code in [200, 302, 301]
    return success, response

def attempt_login(session, username, password):
    """Attempt login with given credentials"""
    login_url = f"{base_url}/login"
    login_data = {'username': username, 'password': password}
    
    response, error = safe_request('POST', login_url, session, login_data)
    
    if error:
        print(f"Login error for '{username}': {error}")
        return None
    
    print(f"Login attempt for '{username}':")
    print(f"  Status Code: {response.status_code}")
    print(f"  URL: {response.url}")
    print(f"  Response Length: {len(response.text)} bytes")
    print()
    
    return response

# Try registration with both credential sets
print("=== REGISTRATION ATTEMPTS ===")
session1 = requests.Session()
success1, reg_resp1 = attempt_registration(session1, 'testuser123', 'password456')

session2 = requests.Session()
success2, reg_resp2 = attempt_registration(session2, 'hacker1', 'password456')

# Select the session with successful registration (or first if both failed)
active_session = session1 if success1 else session2 if success2 else session1
username = 'testuser123' if (success1 or not success2) else 'hacker1'

print(f"Selected username: {username}")
print()

# Login with chosen credentials
print("=== LOGIN ATTEMPT ===")
login_response = attempt_login(active_session, username, 'password456')

if login_response is None:
    print("Login failed - no response received")
else:
    # Print session cookies
    print("=== SESSION COOKIES ===")
    cookies = active_session.cookies.get_dict()
    for name, value in cookies.items():
        print(f"{name}: {value}")
    print()
    
    # Access dashboard
    print("=== DASHBOARD ACCESS ===")
    dashboard_response, error = safe_request('GET', f"{base_url}/dashboard", active_session)
    
    if error:
        print(f"Dashboard error: {error}")
    else:
        print(f"Dashboard Status: {dashboard_response.status_code}")
        print(f"Dashboard URL: {dashboard_response.url}")
        print(f"Response Length: {len(dashboard_response.text)} bytes")
        print()
        
        # Parse dashboard page
        print("=== PARSING DASHBOARD ===")
        soup = BeautifulSoup(dashboard_response.text, 'html.parser')
        
        # Extract all links
        print("\n--- DISCOVERED LINKS/ENDPOINTS ---")
        links = soup.find_all('a', href=True)
        endpoints = []
        id_pattern = re.compile(r'(\d+)')
        
        for link in links:
            href = link['href']
            text = link.get_text(strip=True)
            full_url = f"{base_url}{href}" if href.startswith('/') else href
            
            # Extract ID numbers
            id_matches = id_pattern.findall(href)
            has_id = len(id_matches) > 0
            
            print(f"Link: {href}")
            print(f"  Text: '{text}'")
            print(f"  Full URL: {full_url}")
            
            if has_id:
                print(f"  ⚠️  ID-FOUND: {id_matches}")
            
            endpoints.append({'href': href, 'text': text, 'full_url': full_url, 'has_id': has_id, 'ids': id_matches})
            print()
        
        # Look for posts, drafts, user content
        print("\n--- USER CONTENT ---")
        
        # Find all text elements
        text_elements = soup.find_all(['p', 'h1', 'h2', 'h3', 'h4', 'h5', 'h6', 'div', 'article', 'section'])
        content_count = 0
        
        for elem in text_elements:
            text = elem.get_text(strip=True)
            if text and len(text) > 20 and content_count < 20:  # Show first 20 meaningful texts
                print(f"<{elem.name}>: {text[:100]}..." if len(text) > 100 else text)
                content_count += 1
        
        if content_count == 0:
            print("No significant content found")
        
        # Look for forms
        print(f"\n--- DISCOVERED FORMS ({len(soup.find_all('form'))} found) ---")
        forms = soup.find_all('form')
        for i, form in enumerate(forms[:5]):  # Show max 5 forms
            print(f"Form {i+1}:")
            print(f"  Action: {form.get('action')}")
            print(f"  Method: {form.get('method', 'GET')}")
            
            inputs = form.find_all('input')
            for input_tag in inputs:
                input_type = input_tag.get('type', 'text')
                input_name = input_tag.get('name')
                if input_name:  # Only show named inputs
                    print(f"    Input: name={input_name}, type={input_type}")
            print()
        
        # Look for suspicious patterns
        print("\n--- SUSPICIOUS PATTERNS ---")
        id_endpoints = [e for e in endpoints if e['has_id']]
        
        if id_endpoints:
            print(f"Found {len(id_endpoints)} ID-based endpoints (potential IDOR):")
            for ep in id_endpoints:
                print(f"  - {ep['href']} (IDs: {ep['ids']})")
        else:
            print("No ID-based endpoints found")
        
        # User-related endpoints
        user_keywords = ['user', 'profile', 'account', 'admin', 'settings']
        user_endpoints = [e for e in endpoints if any(kw in e['href'].lower() for kw in user_keywords)]
        
        if user_endpoints:
            print(f"\nFound {len(user_endpoints)} user-related endpoints:")
            for ep in user_endpoints:
                print(f"  - {ep['href']} ('{ep['text']}')")
        
        # Summary
        print("\n=== SUMMARY ===")
        print(f"Active Username: {username}")
        print(f"Session Cookies: {cookies}")
        print(f"Total Links Found: {len(endpoints)}")
        print(f"ID-based URLs: {len(id_endpoints)}")
        print(f"User-related URLs: {len(user_endpoints)}")
        print(f"Forms Found: {len(forms)}")
