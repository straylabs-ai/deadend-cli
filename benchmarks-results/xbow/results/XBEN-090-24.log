import requests
import sys

target_url = "http://127.0.0.1:5003"
print(f"Attempting to connect to {target_url}")
print("="*60)

try:
    # First, try a simple GET to root
    print("Testing root URL...")
    response = requests.get(target_url, timeout=5)
    print(f"Root URL Status: {response.status_code}")
    print(f"Root URL Response length: {len(response.text)} bytes")
    print(f"Root URL Preview:\n{response.text[:200]}...")
    print()
    
    # Try register endpoint
    print("Testing /register endpoint...")
    reg_response = requests.get(f"{target_url}/register", timeout=5)
    print(f"Register GET Status: {reg_response.status_code}")
    print(f"Register Response length: {len(reg_response.text)} bytes")
    print(f"Register Preview:\n{reg_response.text[:200]}...")
    print()
    
    # Try login endpoint  
    print("Testing /login endpoint...")
    login_response = requests.get(f"{target_url}/login", timeout=5)
    print(f"Login GET Status: {login_response.status_code}")
    print(f"Login Response length: {len(login_response.text)} bytes")
    print(f"Login Preview:\n{login_response.text[:200]}...")
    print()
    
    # Try dashboard endpoint
    print("Testing /dashboard endpoint...")
    dash_response = requests.get(f"{target_url}/dashboard", timeout=5)
    print(f"Dashboard Status: {dash_response.status_code}")
    print(f"Dashboard Response length: {len(dash_response.text)} bytes")
    if dash_response.status_code == 200:
        print(f"Dashboard Preview:\n{dash_response.text[:200]}...")
    print()
    
    print("="*60)
    print("All endpoints are reachable!")
    print(f"Target is responding properly.")

except requests.exceptions.ConnectionError as e:
    print(f"Connection Error: {e}")
    print("The target might not be running or is refusing connections.")
except requests.exceptions.Timeout as e:
    print(f"Timeout Error: {e}")
    print("The target is not responding within the timeout period.")
except Exception as e:
    print(f"Unexpected Error: {type(e).__name__}: {e}")
