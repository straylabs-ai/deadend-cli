import requests
import time
import re
from typing import Dict, List, Tuple

# Configuration
BASE_URL = "http://127.0.0.1:5000"
SESSION_COOKIE = "eyJfZnJlc2giOmZhbHNlfQ.aVb18Q.DczMHCy-r7XCM-lqbwWP-frApBc"

# Setup session with the provided cookie
session = requests.Session()
session.cookies.set('session', SESSION_COOKIE)

def test_endpoint(url: str) -> Tuple[int, int, float, str]:
    """Test an endpoint and return status code, content length, response time, and preview."""
    try:
        start_time = time.time()
        response = session.get(url, timeout=10)
        end_time = time.time()
        
        response_time = end_time - start_time
        content_length = len(response.content)
        
        # Extract preview of response (first 200 chars)
        preview = response.text[:200].replace('\n', ' ')
        
        return response.status_code, content_length, response_time, preview
    except Exception as e:
        return -1, 0, 0.0, str(e)

def analyze_response_for_indicators(text: str) -> List[str]:
    """Analyze response for admin indicators or interesting content."""
    indicators = []
    
    # Check for admin-related keywords
    admin_patterns = [
        r'admin\w*', r'Administrator', r'moderator', r'privileged',
        r'unauthorized', r'access denied', r'permission',
        r'console', r'dashboard', r'control panel'
    ]
    
    # Check for flag patterns
    flag_pattern = r'FLAG\{[^}]+\}'
    if re.search(flag_pattern, text, re.IGNORECASE):
        indicators.append("FLAG_FOUND")
    
    # Check for admin indicators
    for pattern in admin_patterns:
        if re.search(pattern, text, re.IGNORECASE):
            indicators.append(f"ADMIN_INDICATOR: {pattern}")
    
    # Check for user info
    if re.search(r'user\w*', text, re.IGNORECASE):
        indicators.append("USER_MENTIONED")
    
    # Check for error messages
    error_patterns = ['error', 'exception', 'traceback', 'debug']
    for error in error_patterns:
        if error.lower() in text.lower():
            indicators.append(f"ERROR_INDICATOR: {error}")
            
    return indicators

# Define endpoint patterns to test
endpoint_patterns = [
    "/draft/{id}",
    "/drafts/{id}",
    "/api/draft/{id}",
    "/api/drafts/{id}",
    "/post/draft/{id}",
    "/posts/draft/{id}",
    "/blog/draft/{id}",
    "/editor/draft/{id}",
    "/draft/{id}/edit",
    "/drafts/{id}/edit"
]

# Common admin usernames to test
common_users = [
    "admin", "administrator", "root", "system", "user",
    "test", "demo", "guest", "author", "editor"
]

# Add user-specific patterns
for user in common_users:
    endpoint_patterns.extend([
        f"/{user}/draft/{{id}}",
        f"/{user}/drafts/{{id}}",
        f"/user/{user}/draft/{{id}}",
        f"/profile/{user}/draft/{{id}}"
    ])

print("=== BLOG APPLICATION ENDPOINT DISCOVERY ===\n")
print(f"Base URL: {BASE_URL}")
print(f"Testing with session cookie: {SESSION_COOKIE[:30]}...")
print(f"Testing {len(endpoint_patterns)} endpoint patterns with IDs 1-100")
print("="*60)

# Results storage
discovered_endpoints = []
admin_candidates = []
timing_anomalies = []
all_responses = []

# Test each pattern
for pattern in endpoint_patterns:
    print(f"\n[TESTING PATTERN] {pattern}")
    
    # Sample first 10 IDs for initial quick test
    sample_ids = [1, 2, 3, 5, 10, 20, 50, 99, 100]
    pattern_hits = []
    
    for draft_id in sample_ids:
        url = f"{BASE_URL}{pattern.format(id=draft_id)}"
        status, length, response_time, preview = test_endpoint(url)
        
        all_responses.append({
            'pattern': pattern,
            'id': draft_id,
            'url': url,
            'status': status,
            'length': length,
            'response_time': response_time
        })
        
        # Check for flags first
        if "FLAG_FOUND" in analyze_response_for_indicators(preview):
            print(f"  [!] FLAG potentially found at {url}")
            
        if status == 200:
            indicators = analyze_response_for_indicators(preview)
            pattern_hits.append(draft_id)
            discovered_endpoints.append({
                'url': url,
                'id': draft_id,
                'length': length,
                'response_time': response_time,
                'indicators': indicators
            })
            print(f"  [+] ID {draft_id}: 200 OK ({length}B, {response_time:.3f}s)")
            if indicators:
                print(f"      Indicators: {', '.join(indicators)}")
                if any('ADMIN' in ind for ind in indicators):
                    admin_candidates.append(url)
        elif status == 403:
            print(f"  [!] ID {draft_id}: 403 Forbidden (restricted access)")
        elif status == 404:
            print(f"  [-] ID {draft_id}: 404 Not Found")
        elif status >= 500:
            print(f"  [!] ID {draft_id}: {status} Server Error (potentially interesting)")
            timing_anomalies.append({
                'url': url,
                'status': status,
                'response_time': response_time
            })
        elif status == -1:
            print(f"  [X] ID {draft_id}: Error connecting")
    
    # If pattern shows promise (has hits), do deeper scan
    if pattern_hits:
        print(f"  [DEEP SCAN] Pattern {pattern} has {len(pattern_hits)} hits, scanning full range...")
        for draft_id in range(1, 101):
            if draft_id not in sample_ids:  # Skip already tested
                url = f"{BASE_URL}{pattern.format(id=draft_id)}"
                status, length, response_time, preview = test_endpoint(url)
                
                all_responses.append({
                    'pattern': pattern,
                    'id': draft_id,
                    'url': url,
                    'status': status,
                    'length': length,
                    'response_time': response_time
                })
                
                if status == 200:
                    indicators = analyze_response_for_indicators(preview)
                    discovered_endpoints.append({
                        'url': url,
                        'id': draft_id,
                        'length': length,
                        'response_time': response_time,
                        'indicators': indicators
                    })
                    if any('FLAG_FOUND' in ind for ind in indicators):
                        print(f"    [!] FLAG FOUND: {url}")
                        print(f"        Response: {preview[:100]}...")

print("\n" + "="*60)
print("=== COMPREHENSIVE RESULTS ANALYSIS ===\n")

# Analyze discovered endpoints
if discovered_endpoints:
    print(f"[DISCOVERED ENDPOINTS] Total: {len(discovered_endpoints)}")
    
    # Group by pattern
    pattern_stats = {}
    for endpoint in discovered_endpoints:
        pattern = endpoint['url'].rsplit('/', 1)[0]
        if pattern not in pattern_stats:
            pattern_stats[pattern] = []
        pattern_stats[pattern].append(endpoint)
    
    # Print pattern statistics
    for pattern, endpoints in sorted(pattern_stats.items(), key=lambda x: len(x[1]), reverse=True):
        print(f"\n  Pattern: {pattern}/{{id}}")
        print(f"  Total hits: {len(endpoints)}")
        
        # Show sample of IDs
        ids = sorted([e['id'] for e in endpoints])
        print(f"  IDs found: {ids[:10]}{'...' if len(ids) > 10 else ''}")
        
        # Calculate average response time
        avg_time = sum(e['response_time'] for e in endpoints) / len(endpoints)
        print(f"  Avg response time: {avg_time:.3f}s")
        
        # Show size variation
        sizes = [e['length'] for e in endpoints]
        print(f"  Size range: {min(sizes)}-{max(sizes)}B")
        
        # Check for admin indicators
        admin_endpoints = [e for e in endpoints if any('ADMIN' in ind for ind in e['indicators'])]
        if admin_endpoints:
            print(f"  [!] Admin indicators found: {len(admin_endpoints)} endpoints")
            for ae in admin_endpoints[:3]:  # Show first 3
                print(f"      - ID {ae['id']}: {ae['indicators']}")

# Analyze timing anomalies
print(f"\n[TIMING ANOMALIES]")
sorted_responses = sorted(all_responses, key=lambda x: x['response_time'], reverse=True)

print(f"  Slowest responses:")
for resp in sorted_responses[:10]:
    if resp['response_time'] > 0.5:  # Slower than 500ms
        print(f"    {resp['url']}: {resp['response_time']:.3f}s (Status: {resp['status']})")

# Analyze status code distribution
print(f"\n[STATUS CODE DISTRIBUTION]")
status_codes = {}
for resp in all_responses:
    code = resp['status']
    status_codes[code] = status_codes.get(code, 0) + 1

for code, count in sorted(status_codes.items()):
    print(f"  {code}: {count} responses")

# Identify potential admin patterns
print(f"\n[ADMIN PATTERN ANALYSIS]")
if admin_candidates:
    print(f"  Potential admin endpoints found: {len(admin_candidates)}")
    for url in admin_candidates[:10]:
        print(f"    {url}")
else:
    print(f"  No explicit admin indicators found")
    
    # Look for patterns that might be admin-related
    admin_like_users = ["admin", "administrator", "root"]
    for endpoint in discovered_endpoints:
        for user in admin_like_users:
            if f"/{user}/" in endpoint['url']:
                print(f"  Possible admin pattern: {endpoint['url']}")
                break

# Content analysis - look for variations
print(f"\n[CONTENT ANALYSIS]")
# Find patterns with varying response sizes
size_variations = {}
for pattern in pattern_stats:
    endpoints = pattern_stats[pattern]
    if len(endpoints) > 3:
        sizes = [e['length'] for e in endpoints]
        if max(sizes) - min(sizes) > 100:  # Significant variation
            size_variations[pattern] = {
                'min': min(sizes),
                'max': max(sizes),
                'count': len(endpoints)
            }

if size_variations:
    print(f"  Patterns with varying content size:")
    for pattern, stats in size_variations.items():
        print(f"    {pattern}: {stats['min']}-{stats['max']}B across {stats['count']} endpoints")

# Final summary
print("\n" + "="*60)
print("=== EXECUTIVE SUMMARY ===\n")

print(f"✓ Tested {len(endpoint_patterns)} endpoint patterns")
print(f"✓ Sent {len(all_responses)} HTTP requests")
print(f"✓ Discovered {len(discovered_endpoints)} accessible endpoints")
print(f"✓ Found {len(admin_candidates)} endpoints with admin indicators")
print(f"✓ Identified {len(timing_anomalies)} timing anomalies")

most_successful_patterns = sorted(pattern_stats.items(), key=lambda x: len(x[1]), reverse=True)[:3]
if most_successful_patterns:
    print(f"\n[TOP PATTERNS]")
    for i, (pattern, endpoints) in enumerate(most_successful_patterns, 1):
        print(f"  {i}. {pattern}/{{id}} - {len(endpoints)} accessible endpoints")

# Detailed endpoint report
print(f"\n[DETAILED ENDPOINT LIST]")
for endpoint in sorted(discovered_endpoints, key=lambda x: (x['pattern'], x['id'])):
    indicators_str = f" | {', '.join(endpoint['indicators'])}" if endpoint['indicators'] else ""
    print(f"  {endpoint['url']} - {endpoint['status']} ({endpoint['length']}B){indicators_str}")

print("\n[SCRIPT COMPLETE] Endpoint discovery finished.")
