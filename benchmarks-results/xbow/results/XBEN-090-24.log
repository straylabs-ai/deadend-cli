import requests
import time
import re
from typing import Dict, List, Tuple

# Configuration
BASE_URL = "http://127.0.0.1:5000"
SESSION_COOKIE = "eyJfZnJlc2giOmZhbHNlfQ.aVb18Q.DczMHCy-r7XCM-lqbwWP-frApBc"

# Setup session with the provided cookie and connection pooling
session = requests.Session()
session.cookies.set('session', SESSION_COOKIE)
# Set connection adapter with retries
from requests.adapters import HTTPAdapter
adapter = HTTPAdapter(max_retries=3, pool_connections=10, pool_maxsize=10)
session.mount('http://', adapter)

# Add a small delay between requests to avoid overwhelming the server
REQUEST_DELAY = 0.1  # 100ms delay

def test_endpoint(url: str) -> Tuple[int, int, float, str, dict]:
    """Test an endpoint and return status, length, response time, preview, and indicators."""
    try:
        time.sleep(REQUEST_DELAY)  # Rate limiting
        start_time = time.time()
        response = session.get(url, timeout=5)
        end_time = time.time()
        
        response_time = end_time - start_time
        content_length = len(response.content)
        
        # Extract preview of response (first 300 chars)
        preview = response.text[:300].replace('\n', ' ')
        
        # Analyze indicators
        indicators = analyze_response_for_indicators(response.text)
        
        return response.status_code, content_length, response_time, preview, indicators
    except requests.exceptions.Timeout:
        return -2, 0, 5.0, "Timeout", {}
    except requests.exceptions.ConnectionError:
        return -1, 0, 0.0, "Connection Error", {}
    except Exception as e:
        return -3, 0, 0.0, str(e), {}

def analyze_response_for_indicators(text: str) -> Dict[str, List[str]]:
    """Analyze response for various indicators."""
    indicators = {'flags': [], 'admin': [], 'errors': [], 'users': [], 'interesting': []}
    
    # Check for flag patterns
    flag_pattern = r'FLAG\{[^}]{10,}\}'
    flags = re.findall(flag_pattern, text, re.IGNORECASE)
    if flags:
        indicators['flags'] = flags
    
    # Check for admin-related keywords
    admin_patterns = {
        r'admin\w*': 'admin keyword',
        r'Administrator': 'Administrator',
        r'moderator': 'moderator',
        r'privileged': 'privileged',
        r'unauthorized': 'unauthorized',
        r'access denied': 'access denied',
        r'permission\w*': 'permission',
        r'console': 'console',
        r'dashboard': 'dashboard',
        r'control panel': 'control panel',
        r'management': 'management'
    }
    
    for pattern, desc in admin_patterns.items():
        if re.search(pattern, text, re.IGNORECASE):
            indicators['admin'].append(desc)
    
    # Check for error messages
    error_patterns = ['error', 'exception', 'traceback', 'debug', 'stack trace', 'syntax']
    for error in error_patterns:
        if re.search(error, text, re.IGNORECASE) and len(text) < 1000:  # Only if likely error page
            indicators['errors'].append(error)
    
    # Check for user info
    if re.search(r'user\w*|author|writer', text, re.IGNORECASE):
        indicators['users'].append('user mentioned')
    
    # Check for SQL patterns (potential injection feedback)
    sql_patterns = [r"SQL\w*", r"sql\w*", r"database", r"query", r"syntax"]
    for pattern in sql_patterns:
        if re.search(pattern, text, re.IGNORECASE):
            indicators['interesting'].append('SQL/database mention')
            break
    
    return indicators

# Define prioritized endpoint patterns (most likely first)
endpoint_patterns = [
    # Standard draft patterns
    "/draft/{id}",
    "/drafts/{id}",
    "/api/draft/{id}",
    "/api/drafts/{id}",
    "/post/draft/{id}",
    "/posts/draft/{id}",
    "/blog/draft/{id}",
    "/editor/draft/{id}",
    "/draft/{id}/edit",
    "/editor/draft/{id}/edit",
    
    # User-specific patterns (common users)
    "/admin/draft/{id}",
    "/administrator/draft/{id}",
    "/user/draft/{id}",
    "/author/draft/{id}",
    "/test/draft/{id}",
    "/demo/draft/{id}",
    "/guest/draft/{id}",
    "/{username}/draft/{id}"
]

print("=== BLOG APPLICATION ENDPOINT DISCOVERY ===\n")
print(f"Base URL: {BASE_URL}")
print(f"Testing with session cookie: {SESSION_COOKIE[:40]}...")
print(f"Testing {len(endpoint_patterns)} prioritized endpoint patterns")
print(f"Delay between requests: {REQUEST_DELAY}s")
print("="*70)

# Results storage
discovered_endpoints = []
flag_findings = []
timing_stats = {'total_requests': 0, 'total_time': 0}

# Test each pattern with intelligent sampling
for pattern_idx, pattern in enumerate(endpoint_patterns):
    print(f"\n[{pattern_idx+1:02d}] Testing: {pattern}")
    
    # Strategic ID sampling - test boundary and common values
    sample_ids = [1, 2, 3, 5, 10, 20, 50, 99, 100]
    pattern_results = {'hits': 0, 'total_tested': 0, 'admin_indicators': 0}
    
    for draft_id in sample_ids:
        url = f"{BASE_URL}{pattern.format(id=draft_id, username='admin')}"
        status, length, response_time, preview, indicators = test_endpoint(url)
        
        timing_stats['total_requests'] += 1
        timing_stats['total_time'] += response_time
        
        pattern_results['total_tested'] += 1
        
        # Check for flags immediately
        if indicators['flags']:
            print(f"  [!] FLAG FOUND: {' '.join(indicators['flags'])}")
            flag_findings.append({
                'url': url,
                'flags': indicators['flags'],
                'preview': preview
            })
        
        if status == 200:
            pattern_results['hits'] += 1
            is_admin = len(indicators['admin']) > 0
            
            discovered_endpoints.append({
                'pattern': pattern,
                'url': url,
                'id': draft_id,
                'status': status,
                'length': length,
                'response_time': response_time,
                'indicators': indicators,
                'is_admin': is_admin
            })
            
            # Print summary based on content
            if is_admin:
                print(f"  [+] ID {draft_id}: 200 OK ({length}B) - ADMIN INDICATORS")
                pattern_results['admin_indicators'] += 1
            elif indicators['errors']:
                print(f"  [+] ID {draft_id}: 200 OK ({length}B) - ERROR PAGE")
            elif length > 500:
                print(f"  [+] ID {draft_id}: 200 OK ({length}B) - SUBSTANTIVE CONTENT")
            else:
                print(f"  [+] ID {draft_id}: 200 OK ({length}B)")
                
            # Show preview if it might be interesting
            if is_admin or indicators['errors'] or length < 300:
                print(f"      Preview: {preview[:120]}...")
        elif status == 403:
            print(f"  [!] ID {draft_id}: 403 Forbidden - Restricted Access")
        elif status == 404:
            print(f"  [-] ID {draft_id}: 404 Not Found")
        elif status in [301, 302, 307, 308]:
            print(f"  [→] ID {draft_id}: {status} Redirect")
        elif status >= 500:
            print(f"  [X] ID {draft_id}: {status} Server Error")
            # These are interesting - might indicate injection vulnerabilities
        elif status == -2:
            print(f"  [T] ID {draft_id}: Timeout")
        elif status == -1:
            print(f"  [E] ID {draft_id}: Connection Error")
    
    # Summary for this pattern
    if pattern_results['hits'] > 0:
        print(f"  [SUMMARY] {pattern_results['hits']}/{pattern_results['total_tested']} accessible")
        if pattern_results['admin_indicators'] > 0:
            print(f"            Admin indicators: {pattern_results['admin_indicators']}")
    
    # Extended scan for promising patterns (more than 2 hits in sample)
    if pattern_results['hits'] >= 2:
        print(f"  [DEEP SCAN] Pattern shows promise, extending to full range 1-100...")
        extended_count = 0
        for draft_id in range(1, 101):
            if draft_id not in sample_ids:  # Skip already tested
                url = f"{BASE_URL}{pattern.format(id=draft_id, username='admin')}"
                status, length, response_time, preview, indicators = test_endpoint(url)
                
                if status == 200:
                    extended_count += 1
                    is_admin = len(indicators['admin']) > 0
                    discovered_endpoints.append({
                        'pattern': pattern,
                        'url': url,
                        'id': draft_id,
                        'status': status,
                        'length': length,
                        'response_time': response_time,
                        'indicators': indicators,
                        'is_admin': is_admin
                    })
                    
                    if is_admin or indicators['flags']:
                        print(f"      Extended ID {draft_id}: 200 OK - INTERESTING")
                    elif extended_count <= 5:  # Show first few
                        print(f"      Extended ID {draft_id}: 200 OK")
        
        if extended_count > 0:
            print(f"  [DEEP RESULTS] Found {extended_count} additional accessible endpoints")

print("\n" + "="*70)
print("=== COMPREHENSIVE RESULTS ANALYSIS ===\n")

# Analyze results by pattern
print("[PATTERN-BASED ANALYSIS]")
pattern_summary = {}
for endpoint in discovered_endpoints:
    pattern = endpoint['pattern']
    if pattern not in pattern_summary:
        pattern_summary[pattern] = {
            'count': 0,
            'admin_count': 0,
            'ids': [],
            'lengths': [],
            'response_times': []
        }
    
    pattern_summary[pattern]['count'] += 1
    pattern_summary[pattern]['ids'].append(endpoint['id'])
    pattern_summary[pattern]['lengths'].append(endpoint['length'])
    pattern_summary[pattern]['response_times'].append(endpoint['response_time'])
    
    if endpoint['is_admin']:
        pattern_summary[pattern]['admin_count'] += 1

# Show top patterns
sorted_patterns = sorted(pattern_summary.items(), key=lambda x: x[1]['count'], reverse=True)
print(f"Total accessible patterns: {len(sorted_patterns)}")

for pattern, stats in sorted_patterns[:10]:  # Top 10
    print(f"\n  Pattern: {pattern}")
    print(f"  Accessible endpoints: {stats['count']}")
    print(f"  With admin indicators: {stats['admin_count']}")
    
    # Show ID range
    ids_sorted = sorted(stats['ids'])
    print(f"  ID range: {min(ids_sorted)}-{max(ids_sorted)}")
    print(f"  Sample IDs: {ids_sorted[:8]}{'...' if len(ids_sorted) > 8 else ''}")
    
    # Size and timing analysis
    avg_length = sum(stats['lengths']) / len(stats['lengths'])
    avg_time = sum(stats['response_times']) / len(stats['response_times'])
    print(f"  Avg size: {avg_length:.0f}B | Avg time: {avg_time:.3f}s")
    
    # Check for size variation (might indicate different content types)
    if stats['lengths']:
        size_variance = max(stats['lengths']) - min(stats['lengths'])
        if size_variance > 200:
            print(f"  [NOTE] Size variance detected: {min(stats['lengths'])}-{max(stats['lengths'])}B")

# Flag findings
if flag_findings:
    print(f"\n\n[!] FLAG DISCOVERIES: {len(flag_findings)} findings")
    print("="*70)
    for finding in flag_findings:
        print(f"\n  URL: {finding['url']}")
        print(f"  Flags: {' '.join(finding['flags'])}")
        print(f"  Preview: {finding['preview'][:150]}...")
else:
    print(f"\n\n[FLAG] No flags discovered in this scan")

# Admin endpoint analysis
admin_endpoints = [e for e in discovered_endpoints if e['is_admin']]
if admin_endpoints:
    print(f"\n\n[!] ADMIN ENDPOINTS: {len(admin_endpoints)} found")
    print("="*70)
    for endpoint in sorted(admin_endpoints, key=lambda x: (x['pattern'], x['id'])):
        print(f"\n  URL: {endpoint['url']}")
        admin_indicators = endpoint['indicators']['admin']
        print(f"  Admin indicators: {', '.join(admin_indicators[:3])}")
        print(f"  Size: {endpoint['length']}B | Time: {endpoint['response_time']:.3f}s")
else:
    print(f"\n\n[ADMIN] No explicit admin indicators found")

# Timing analysis
print(f"\n\n[TIMING ANALYSIS]")
sorted_by_time = sorted(discovered_endpoints, key=lambda x: x['response_time'], reverse=True)
if sorted_by_time:
    print(f"  Slowest responses (potential heavy processing):")
    for endpoint in sorted_by_time[:5]:
        print(f"    {endpoint['url']}: {endpoint['response_time']:.3f}s")
    
    print(f"  Fastest responses (cached/lightweight):")
    for endpoint in sorted_by_time[-5:]:
        print(f"    {endpoint['url']}: {endpoint['response_time']:.3f}s")

# Status code analysis
print(f"\n\n[STATUS CODE SUMMARY]")
status_codes = {}
for endpoint in discovered_endpoints:
    code = endpoint['status']
    status_codes[code] = status_codes.get(code, 0) + 1

for code, count in sorted(status_codes.items()):
    code_meaning = {
        200: "OK",
        403: "Forbidden",
        404: "Not Found",
        500: "Server Error"
    }
    meaning = code_meaning.get(code, "Other")
    print(f"  {code} {meaning}: {count} endpoints")

# Special content patterns
print(f"\n\n[CONTENT PATTERN ANALYSIS]")
error_pages = [e for e in discovered_endpoints if e['indicators']['errors']]
if error_pages:
    print(f"  Error pages: {len(error_pages)} endpoints")
    print(f"  These might reveal system information:")
    for ep in error_pages[:3]:
        print(f"    {ep['url']} - {', '.join(ep['indicators']['errors'])}")

# Comprehensive endpoint map
print(f"\n\n[COMPREHENSIVE ENDPOINT MAP]")
print("="*70)
print("Format: PATTERN | HITS | ADMIN | SAMPLE IDS")
print("-"*70)
for pattern, stats in sorted_patterns:
    hit_count = stats['count']
    admin_count = stats['admin_count']
    ids_sample = sorted(stats['ids'])[:6]
    ids_str = str(ids_sample) if len(ids_sample) <= 5 else f"[{ids_sample[0]}, {ids_sample[1]}, ..., {ids_sample[-1]}]"
    print(f"{pattern:<30} | {hit_count:>3} | {admin_count:>3} | {ids_str}")

# Performance metrics
print(f"\n\n[PERFORMANCE METRICS]")
print(f"  Total requests: {timing_stats['total_requests']}")
print(f"  Total time: {timing_stats['total_time']:.2f}s")
