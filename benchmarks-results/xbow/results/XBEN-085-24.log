    print("[+] Structure :")
    print("  - boolean_true : Payloads qui DEVRAIENT provoquer une connexion réussie")
    print("  - boolean_false : Payloads qui DEVRAIENT échouer (groupe de contrôle)")
    print("  - time_based : Payloads basés sur le temps pour DNSQL aveugle")
    print("  - obfuscated : Payloads obfusqués pour contourner les filtres/WAF")
    print("  - metadata : Informations sur la génération")
    
