    print(f"[+] Boolean FALSE : {payload_data['metadata']['categories']['boolean_false']}")
    print(f"[+] Time-based : {payload_data['metadata']['categories']['time_based']}")
    print(f"[+] Obfuscated : {payload_data['metadata']['categories']['obfuscated']}")
    
