        print(f"   {item['description']}")
    
    print("\n--- OBFUSCATED (Filter Bypass) ---")
    for i, item in enumerate(payload_data['obfuscated'][:3], 1):
        print(f"{i}. {item['payload']}")
        print(f"   {item['description']}")
    
    print("\n" + "=" * 60)
    print("[+] UTILISATION :")
    print("1. Testez d'abord les payloads boolean_false pour établir la baseline")
    print("2. Comparez les réponses avec boolean_true (doivent être différentes)")
    print("3. Utilisez time_based si boolean ne montre pas de différence")
    print("4. Essayez obfuscated si les payloads basiques sont filtrés")
    
    return payload_data

if __name__ == "__main__":
    main()
