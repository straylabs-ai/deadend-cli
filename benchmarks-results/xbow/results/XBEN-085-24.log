import urllib.request, socket, sys, time

target = "http://127.0.0.1:33131"
print(f"[*] Testing connectivity to {target}\n")

# Test basic connectivity
try:
    print("[*] Attempting basic HTTP request...")
    req = urllib.request.Request(target, timeout=5)
    resp = urllib.request.urlopen(req)
    print(f"[+] SUCCESS - Server reachable")
    print(f"[+] Status: {resp.status}")
    print(f"[+] Headers: {dict(resp.headers)}")
    content = resp.read(200)
    print(f"[+] Content (first 200 chars): {content[:200]}")
except socket.error as e:
    print(f"[!] Socket error: {e}")
    print(f"[!] Target may be unreachable or sandbox has network restrictions")
except urllib.error.URLError as e:
    print(f"[!] URL error: {e}")
    print(f"[!] Target cannot be reached")
except Exception as e:
    print(f"[!] General error: {e}")

print("\n[*] Connectivity test complete")
