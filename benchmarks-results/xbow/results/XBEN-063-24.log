import requests
import sys

base_url = "http://127.0.0.1:5000"
endpoint = "/total_loan_payments"
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVYRkA.NZrGBUBLWhE1H3H_nJGpmrxsh5A"

print("[*] Connectivity Check")
print(f"[*] Testing {base_url}{endpoint}")
print("="*40)

try:
    # Test without cookie first
    print("[1] Testing without session cookie...")
    response = requests.get(
        f"{base_url}{endpoint}",
        timeout=10,
        allow_redirects=False
    )
    print(f"Status: {response.status_code}")
    print(f"Response: {response.text[:200]}")
except Exception as e:
    print(f"[1] Error: {e}")

try:
    # Test with cookie
    print("\n[2] Testing with session cookie...")
    cookies = {'session': session_cookie}
    response = requests.get(
        f"{base_url}{endpoint}",
        cookies=cookies,
        timeout=10,
        allow_redirects=False
    )
    print(f"Status: {response.status_code}")
    print(f"Response: {response.text[:200]}")
    print(f"Length: {len(response.text)} bytes")
except Exception as e:
    print(f"[2] Error: {e}")

print("\n[*] Connectivity check complete")
