import requests
import sys

base_url = "http://127.0.0.1:5000"
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVYTgQ.zxJDgrrGBVoUrTrnwwifgdf1QW0"
cookies = {"session": session_cookie}

def test_endpoint(endpoint, params=None, description=""):
    """Test an endpoint and return response info"""
    try:
        print(f"\n[+] Testing {endpoint} - {description}")
        if params:
            print(f"    Params: {params}")
        
        resp = requests.get(f"{base_url}{endpoint}", 
                           params=params, 
                           cookies=cookies, 
                           timeout=5)
        print(f"    Status: {resp.status_code}")
        print(f"    Content-Type: {resp.headers.get('Content-Type', 'N/A')}")
        print(f"    Response length: {len(resp.text)} chars")
        print(f"    Response preview: {resp.text[:150]}")
        return resp
    except Exception as e:
        print(f"    ERROR: {str(e)}")
        return None

print("=" * 80)
print("CONNECTION AND FILTER TEST")
print("=" * 80)

# Quick connectivity test
print("\n[CONNECTIVITY TEST]")
esp = test_endpoint("/", description="Root endpoint")
if esp:
    print("✓ Connection successful")
else:
    print("✗ Connection failed")
    sys.exit(1)

# Test 1: Baseline working request
resp1 = test_endpoint("/total_loan_payments", 
                     {"principal": "10000", "payment": "500", "term": "24"},
                     "Baseline - normal parameters")

# Test 2: Template injection (should be blocked)
resp2 = test_endpoint("/total_loan_payments",
                     {"principal": "{{7*7}}", "payment": "500", "term": "24"},
                     "Template injection - should be blocked")

# Test 3: Different chars to see what's blocked
for char in ["{", "}", "%", "<", ">"]:
    test_endpoint("/total_loan_payments",
                 {"principal": f"test{char}value", "payment": "500", "term": "24"},
                 f"Character test - '{char}'")

# Test 4: Try /home for comparison
resp_home = test_endpoint("/home", {"data": "{{7*7}}"}, "Template on /home - should work")

print("\n" + "=" * 80)
print("TEST COMPLETE")
print("=" * 80)
