import requests

base = "http://127.0.0.1:5000"
cookie = {"session": "eyJ1c2VyX2lkIjoxfQ.aVYTgQ.zxJDgrrGBVoUrTrnwwifgdf1QW0"}

# Run focused tests to analyze rendering mechanism
tests = [
    {"p": "10000", "pay": "500", "t": "24", "desc": "baseline"},
    {"p": "{{7*7}}", "pay": "500", "t": "24", "desc": "direct SSTI"},
    {"p": "%7B%7B7*7%7D%7D", "pay": "500", "t": "24", "desc": "URL encoded SSTI"},
    {"p": "{", "pay": "500", "t": "24", "desc": "single opening brace"},
    {"p": "}", "pay": "500", "t": "24", "desc": "single closing brace"},
    {"p": "10000", "pay": "500", "t": "{{7*7}}", "desc": "SSTI in term param"},
]

results = []
for test in tests:
    try:
        r = requests.get(f"{base}/total_loan_payments", 
                        params={"principal": test["p"], "payment": test["pay"], "term": test["t"]}, 
                        cookies=cookie, timeout=5)
        results.append({
            "test": test["desc"],
            "status": r.status_code,
            "response": r.text,
            "ctype": r.headers.get("content-type", "N/A"),
            "length": len(r.text)
        })
        print(f"[{test['desc']}] Status: {r.status_code} | Length: {len(r.text)} | Resp: {r.text}")
    except Exception as e:
        results.append({"test": test["desc"], "error": str(e)})
        print(f"[{test['desc']}] Error: {e}")

# Analyze results
print("\n=== ANALYSIS ===")
blocked = [r for r in results if r.get("status") == 400]
allowed = [r for r in results if r.get("status") == 200]

print(f"Blocked requests: {len(blocked)}")
print(f"Allowed requests: {len(allowed)}")

if blocked:
    print(f"\nFilter message: {blocked[0]['response']}")
    print(f"Filter triggers on: {', '.join([r['test'] for r in blocked])}")

if allowed:
    print(f"\nBaseline response: {allowed[0]['response']}")
    print(f"Content type: {allowed[0]['ctype']}")
    print(f"String values: {all(x in allowed[0]['response'] for x in ['\\"10000\\"', '\\"500.0\\"', '\\"24\\"'])}")

# Test for template indicators
print("\n=== TEMPLATE ENGINE INDICATORS ===")
print("1. Content-Type is text/html (not application/json) - suggests template rendering")
print("2. All input parameters reflected as string values")
print("3. String values wrapped in quotes in JSON structure")
print("4. Consistent filter across all parameters")

# Filter analysis
print("\n=== FILTER MECHANISM ===")
print("- Detects: {{, }}, {, } (both single and double braces)")
print("- Method: Likely regex pattern matching
  - Pattern: [{{}}] or similar character blacklist
  - Scope: All GET parameters")
print("- Bypass attempts failed: URL encoding, double encoding")
print("- Conclusion: Input validation BEFORE template rendering")

# Comparison to /home
print("\n=== VS /home ENDPOINT ===")
print("/home: Renders {{7*7}} as literal, evaluates in context (SSTI vulnerable)")
print("/total_loan_payments: Blocks {{7*7}} entirely, never reaches template")

# Rendering mechanism conclusion
print("\n=== RENDERING MECHANISM ===")
print("Most likely: String interpolation or template WITH pre-filtering")
print("Evidence:")
print("- JSON-like structure with proper string quoting")
print("- text/html content-type (template rendering)")
print("- Consistent parameter reflection")
print("- Active filtering of template syntax")

print("\nJSON Generation Method:")
print("Option A: Template engine with auto-escaping + input filter")
print("Option B: String formatting/interpolation with sanitization")
print("Option C: JSON.dumps() with pre-processed string inputs")
