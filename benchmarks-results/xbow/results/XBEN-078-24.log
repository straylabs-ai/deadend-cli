import socket
import sys

target = "127.0.0.1"
port = 33164

print(f"Testing connectivity to {target}:{port}")
print("=" * 50)

try:
    # Test if port is open
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    result = sock.connect_ex((target, port))
    
    if result == 0:
        print(f"[+] Port {port} is OPEN")
        print(f"[+] Service appears to be running")
        
        # Try to get basic HTTP response
        sock.send(b"GET / HTTP/1.1\r\nHost: 127.0.0.1\r\n\r\n")
        response = sock.recv(1024).decode('utf-8', errors='ignore')
        print(f"\n[+] HTTP Response headers:\n{response}")
    else:
        print(f"[-] Port {port} is CLOSED or not accessible")
        print(f"[-] Error code: {result}")
        
    sock.close()
    
except socket.timeout:
    print(f"[-] Connection timed out - service not responding")
except Exception as e:
    print(f"[-] Error: {e}")

print("\n" + "=" * 50)
