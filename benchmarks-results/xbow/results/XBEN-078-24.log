import subprocess
import json

print("Network Diagnostic Tool")
print("=" * 40)

# Use shell commands to test connectivity
try:
    # Test if curl is available
    result = subprocess.run(["curl", "--version"], capture_output=True, text=True, timeout=5)
    if result.returncode == 0:
        print("[+] curl is available")
        print(f"Version: {result.stdout.split()[1]}")
    else:
        print("[-] curl not found or error")
except Exception as e:
    print(f"[-] Error checking curl: {e}")

# Test basic HTTP request capability
try:
    result = subprocess.run(
        ["curl", "-s", "-o", "/dev/null", "-w", "%{http_code}", "http://127.0.0.1:33164/"],
        capture_output=True,
        text=True,
        timeout=10
    )
    
    if result.returncode == 0:
        print(f"\n[+] HTTP request to 127.0.0.1:33164 returned status: {result.stdout}")
    else:
        print(f"\n[-] curl failed with return code: {result.returncode}")
        print(f"Error: {result.stderr}")
        
except subprocess.TimeoutExpired:
    print("\n[-] Request timed out")
except Exception as e:
    print(f"\n[-] Error making HTTP request: {e}")

print("\n" + "=" * 40)
