        if len(resp.text) > baseline_max:
            print(f"      [!] RESPONSE DIFFERS FROM BASELINE")
            print(f"      [+] Snippet: {resp.text[:200]}")
            
    except Exception as e:
        print(f"  [-] Error: {e}")

print("\n" + "=" * 80)
print("TESTING COMPLETE")
print("=" * 80)

