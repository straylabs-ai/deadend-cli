import requests, socket, sys

# Simple connectivity test
try:
    # Test 1: Can we resolve/connect?
    print("Testing basic connectivity...")
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.settimeout(5)
    result = s.connect_ex(("127.0.0.1", 33164))
    s.close()
    
    if result == 0:
        print("[+] Port 33164 is open")
    else:
        print(f"[-] Port closed (code: {result})")
        
except Exception as e:
    print(f"[-] Socket error: {e}")

# Test 2: Try a single HTTP GET
try:
    print("\nTrying HTTP request...")
    r = requests.get("http://127.0.0.1:33164/", timeout=10)
    print(f"[+] Status: {r.status_code}")
    print(f"[+] Length: {len(r.text)} bytes")
    print(f"[+] First 200 chars: {r.text[:200]}")
except Exception as e:
    print(f"[-] HTTP error: {e}")
