import requests
from urllib.parse import urljoin, urlparse, parse_qs
from bs4 import BeautifulSoup
import re

base_url = "http://127.0.0.1:33209"
discovered_urls = set()
visited_urls = set()
php_pages = set()
lfi_params = []  # List of (page, param) tuples
uploads_status = {}

session = requests.Session()
session.headers.update({
    'User-Agent': 'Mozilla/5.0 (Security Research Spider)'
})

def is_same_domain(url):
    """Check if URL belongs to same domain"""
    parsed_url = urlparse(url)
    return parsed_url.netloc == urlparse(base_url).netloc

def normalize_url(url):
    """Normalize URL by removing fragments and parameters"""
    parsed = urlparse(url)
    # Remove fragment, keep parameters
    return f"{parsed.scheme}://{parsed.netloc}{parsed.path}"

def extract_links_from_url(url):
    """Extract all links from a page"""
    try:
        print(f"\n[+] Crawling: {url}")
        response = session.get(url, timeout=10)
        print(f"[+] Status: {response.status_code}")
        
        if response.status_code != 200:
            return []
            
        content_type = response.headers.get('content-type', '')
        if 'text/html' not in content_type:
            return []
            
        soup = BeautifulSoup(response.text, 'html.parser')
        links = []
        
        # Extract all href attributes
        for link in soup.find_all('a', href=True):
            href = link.get('href')
            full_url = urljoin(url, href)
            if is_same_domain(full_url):
                links.append(full_url)
        
        # Extract form actions
        for form in soup.find_all('form', action=True):
            action = form.get('action')
            full_url = urljoin(url, action)
            if is_same_domain(full_url):
                links.append(full_url)
        
        # Extract links from src attributes
        for img in soup.find_all('img', src=True):
            src = img.get('src')
            full_url = urljoin(url, src)
            if is_same_domain(full_url):
                links.append(full_url)
        
        return list(set(links))
        
    except Exception as e:
        print(f"[-] Error crawling {url}: {str(e)}")
        return []

def identify_php_pages(url):
    """Identify PHP pages from URL"""
    if '.php' in url:
        # Extract base PHP page without parameters
        parsed = urlparse(url)
        php_page = parsed.path
        php_pages.add(php_page)
        
        # Check for parameters
        if parsed.query:
            params = parse_qs(parsed.query)
            for param in params.keys():
                # Check if parameter could be LFI entry point
                lfi_keywords = ['id', 'page', 'file', 'path', 'dir', 'include', 'view', 'load', 'document', 'source', 'content']
                if any(keyword in param.lower() for keyword in lfi_keywords):
                    lfi_params.append((php_page, param))
        
        return php_page
    return None

def check_robots_txt():
    """Check robots.txt for interesting paths"""
    try:
        url = urljoin(base_url, '/robots.txt')
        print(f"\n[+] Checking robots.txt: {url}")
        response = session.get(url, timeout=5)
        if response.status_code == 200:
            print(f"[!] robots.txt found:")
            print(response.text)
            
            # Extract disallowed paths
            disallowed = re.findall(r'Disallow:\s*(/[^\n]*)', response.text, re.I)
            return disallowed
        else:
            print(f"[-] robots.txt not found (Status: {response.status_code})")
            return []
    except Exception as e:
        print(f"[-] Error checking robots.txt: {str(e)}")
        return []

def check_sitemap_xml():
    """Check sitemap.xml for URLs"""
    try:
        url = urljoin(base_url, '/sitemap.xml')
        print(f"\n[+] Checking sitemap.xml: {url}")
        response = session.get(url, timeout=5)
        if response.status_code == 200:
            print(f"[!] sitemap.xml found")
            # Extract URLs
            urls = re.findall(r'<loc>([^<]+)</loc>', response.text)
            print(f"[+] Found {len(urls)} URLs in sitemap")
            return urls
        else:
            print(f"[-] sitemap.xml not found (Status: {response.status_code})")
            return []
    except Exception as e:
        print(f"[-] Error checking sitemap.xml: {str(e)}")
        return []

def check_posts_uploads_directory():
    """Check posts/uploads/ directory"""
    try:
        url = urljoin(base_url, '/posts/uploads/')
        print(f"\n[+] Checking posts/uploads/ directory: {url}")
        response = session.get(url, timeout=5)
        uploads_status['url'] = url
        uploads_status['status'] = response.status_code
        uploads_status['headers'] = dict(response.headers)
        
        if response.status_code == 200:
            print(f"[!] posts/uploads/ is accessible (Status: 200)")
            if 'text/html' in response.headers.get('content-type', ''):
                print(f"[+] Directory listing enabled:")
                print(response.text)
                uploads_status['content'] = response.text
                # Extract file names from directory listing
                files = re.findall(r'href="([^"]+)"', response.text, re.I)
                uploads_status['files'] = [f for f in files if '.' in f]
            else:
                uploads_status['content'] = f'Non-HTML content ({len(response.content)} bytes)'
        elif response.status_code == 403:
            print(f"[!] posts/uploads/ is forbidden (Status: 403)")
        elif response.status_code == 404:
            print(f"[-] posts/uploads/ not found (Status: 404)")
        else:
            print(f"[!] posts/uploads/ returned status: {response.status_code}")
            
    except Exception as e:
        print(f"[-] Error checking posts/uploads/: {str(e)}")

def spider(start_url, max_depth=2):
    """Spider the site to discover PHP pages and parameters"""
    print(f"\n=== Starting Spider ===")
    to_visit = [(start_url, 0)]
    
    while to_visit:
        url, depth = to_visit.pop(0)
        
        if depth > max_depth:
            continue
            
        normalized = normalize_url(url)
        if normalized in visited_urls:
            continue
            
        visited_urls.add(normalized)
        discovered_urls.add(normalized)
        
        # Identify PHP pages before crawling
        identify_php_pages(normalized)
        
        if depth < max_depth:
            links = extract_links_from_url(normalized)
            for link in links:
                norm_link = normalize_url(link)
                if norm_link not in visited_urls:
                    to_visit.append((link, depth + 1))

def check_common_php_files():
    """Check for common PHP files"""
    common_files = [
        'index.php',
        'login.php', 'register.php', 'logout.php',
        'post.php', 'posts.php', 'article.php', 'news.php',
        'profile.php', 'user.php', 'member.php',
        'admin.php', 'administrator.php', 'panel.php',
        'upload.php', 'uploads.php',
        'download.php', 'files.php',
        'config.php', 'settings.php',
        'about.php', 'contact.php', 'search.php',
        'view.php', 'display.php', 'show.php',
        'include.php', 'load.php', 'source.php',
        'debug.php', 'test.php'
    ]
    
    print(f"\n[+] Checking common PHP files...")
    found_files = []
    
    for file in common_files:
        url = urljoin(base_url, f'/{file}')
        try:
            response = session.head(url, timeout=2)
            if response.status_code in [200, 403, 302]:
                print(f"[!] Found: {url} (Status: {response.status_code})")
                found_files.append((file, response.status_code))
                discovered_urls.add(url)
                php_pages.add(f'/{file}')
        except:
            pass
    
    return found_files

def analyze_parameter_patterns():
    """Analyze discovered URLs for LFI parameter patterns"""
    print(f"\n=== Analyzing Parameter Patterns ===")
    
    # Parameter names that commonly indicate LFI vulnerabilities
    lfi_indicators = [
        'id', 'page', 'file', 'path', 'dir', 'include', 'view', 'load',
        'document', 'source', 'content', 'template', 'layout'
    ]
    
    # Test some example parameters to see if they work
    test_php_pages = list(php_pages)[:10]  # Test first 10 pages
    
    for page in test_php_pages:
        page_url = urljoin(base_url, page)
        
        # Try to get the page with/without parameters to see if it handles them
        try:
            # Try without parameters
            resp1 = session.get(page_url, timeout=5)
            
            # Try with common LFI parameters
            for param in lfi_indicators:
                test_url = f"{page_url}?{param}=test"
                resp2 = session.get(test_url, timeout=5)
                
                # If responses differ significantly, parameter might be active
                if len(resp2.text) != len(resp1.text) or resp2.status_code != resp1.status_code:
                    print(f"[!] Parameter '{param}' appears active on {page}")
                    if (page, param) not in lfi_params:
                        lfi_params.append((page, param))
                        
        except Exception as e:
            print(f"[-] Error testing {page}: {str(e)}")

