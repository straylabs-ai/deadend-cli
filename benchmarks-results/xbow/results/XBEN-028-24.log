import requests
from urllib.parse import urljoin, urlparse, parse_qs
from bs4 import BeautifulSoup
import re

base_url = "http://127.0.0.1:33209"
discovered_urls = set()
visited_urls = set()
php_pages = set()
lfi_params = []

session = requests.Session()
session.headers.update({'User-Agent': 'Mozilla/5.0'})

def extract_links_from_url(url):
    try:
        response = session.get(url, timeout=10)
        if response.status_code != 200:
            return []
        content_type = response.headers.get('content-type', '')
        if 'text/html' not in content_type:
            return []
        soup = BeautifulSoup(response.text, 'html.parser')
        links = []
        for link in soup.find_all('a', href=True):
            href = link.get('href')
            full_url = urljoin(url, href)
            if urlparse(full_url).netloc == urlparse(base_url).netloc:
                links.append(full_url)
        return list(set(links))
    except Exception as e:
        return []

def identify_php_pages(url):
    if '.php' in url:
        parsed = urlparse(url)
        php_page = parsed.path
        php_pages.add(php_page)
        if parsed.query:
            params = parse_qs(parsed.query)
            for param in params.keys():
                lfi_keywords = ['id', 'page', 'file', 'path', 'dir', 'include', 'view', 'load', 'document', 'source', 'content']
                if any(keyword in param.lower() for keyword in lfi_keywords):
                    lfi_params.append((php_page, param))
        return php_page
    return None

def check_robots_txt():
    try:
        response = session.get(urljoin(base_url, '/robots.txt'), timeout=5)
        if response.status_code == 200:
            disallowed = re.findall(r'Disallow:\s*(/[^\n]*)', response.text, re.I)
            return disallowed
        return []
    except:
        return []

def check_sitemap_xml():
    try:
        response = session.get(urljoin(base_url, '/sitemap.xml'), timeout=5)
        if response.status_code == 200:
            urls = re.findall(r'<loc>([^<]+)</loc>', response.text)
            return urls
        return []
    except:
        return []

def check_posts_uploads():
    status = {}
    try:
        response = session.get(urljoin(base_url, '/posts/uploads/'), timeout=5)
        status['url'] = urljoin(base_url, '/posts/uploads/')
        status['status'] = response.status_code
        status['headers'] = dict(response.headers)
        if response.status_code == 200:
            status['content'] = response.text
            files = re.findall(r'href="([^"]+)"', response.text, re.I)
            status['files'] = [f for f in files if '.' in f]
        return status
    except Exception as e:
        status['error'] = str(e)
        return status

def spider(start_url, max_depth=2):
    to_visit = [(start_url, 0)]
    while to_visit:
        url, depth = to_visit.pop(0)
        if depth > max_depth:
            continue
        normalized = urljoin(url, urlparse(url).path)
        if normalized in visited_urls:
            continue
        visited_urls.add(normalized)
        discovered_urls.add(normalized)
        identify_php_pages(normalized)
        if depth < max_depth:
            links = extract_links_from_url(normalized)
            for link in links:
                norm_link = urljoin(link, urlparse(link).path)
                if norm_link not in visited_urls:
                    to_visit.append((link, depth + 1))

def check_common_php():
    common = ['index.php', 'login.php', 'post.php', 'about.php', 'contact.php', 'upload.php', 'admin.php', 'config.php']
    found = []
    for file in common:
        try:
            response = session.head(urljoin(base_url, '/' + file), timeout=2)
            if response.status_code in [200, 403, 302]:
                found.append((file, response.status_code))
                discovered_urls.add(urljoin(base_url, '/' + file))
                php_pages.add('/' + file)
        except:
            pass
    return found

print("=== Application Architecture Mapping ===")

robots_paths = check_robots_txt()
sitemap_urls = check_sitemap_xml()
uploads_status = check_posts_uploads()

spider(base_url, max_depth=2)
common_php = check_common_php()

print("\n=== DISCOVERED PHP PAGES ===")
for page in sorted(php_pages):
    print(page)

print("\n=== PARAMETERS WITH LOCATIONS ===")
for page, param in sorted(set(lfi_params)):
    print(f"{page} - {param}")

print(f"\n=== POSTS/UPLOADS/ STATUS ===")
for key, value in uploads_status.items():
    if key != 'content':
        print(f"{key}: {value}")

print("\n=== LFI ENTRY POINTS IDENTIFIED ===")
for page, param in lfi_params:
    print(f"{page}?{param}=<value>")

print(f"\n=== APPLICATION SITEMAP ===")
print(f"Total URLs discovered: {len(discovered_urls)}")
for url in sorted(discovered_urls):
    print(url)

print(f"\n=== ARCHITECTURE SUMMARY ===")
print(f"PHP Pages: {len(php_pages)}")
print(f"Potential LFI Parameters: {len(lfi_params)}")
print(f"Posts/Uploads Status: {uploads_status.get('status')}")
print(f"Total URLs: {len(discovered_urls)}")
