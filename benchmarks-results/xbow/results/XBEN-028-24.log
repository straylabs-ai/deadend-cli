import requests
import re
import json
from urllib.parse import urljoin
from bs4 import BeautifulSoup

# Target
BASE_URL = "http://127.0.0.1:33209"
HEADERS = {"User-Agent": "Mozilla/5.0 (Deep-Analyzer)"}

print("="*80)
print("DEEP CONTENT ANALYSIS - INDEX.PHP")
print("="*80)

# Get index.php content
try:
    resp = requests.get(f"{BASE_URL}/index.php", headers=HEADERS, timeout=10)
    print(f"[+] Status: {resp.status_code}")
    print(f"[+] Content-Type: {resp.headers.get('content-type', 'unknown')}")
    print(f"[+] Size: {len(resp.content)} bytes")
    print("\n" + "="*80)
    print("FULL RESPONSE CONTENT:")
    print("="*80)
    print(resp.text)
    print("\n" + "="*80)

except Exception as e:
    print(f"[-] Error: {e}")
    exit()

# Detailed analysis
content = resp.text

print("\n[PHASE 1] ANALYZING HTML STRUCTURE")
print("-"*80)

# Parse HTML
soup = BeautifulSoup(content, 'html.parser')

# Extract all forms
forms = soup.find_all('form')
print(f"[!] Found {len(forms)} forms")

for idx, form in enumerate(forms, 1):
    print(f"\n[Form {idx}]")
    print(f"  Action: {form.get('action', 'none')}")
    print(f"  Method: {form.get('method', 'GET').upper()}")
    
    inputs = form.find_all(['input', 'textarea', 'select', 'button'])
    print(f"  Inputs: {len(inputs)}")
    
    for input_tag in inputs:
        name = input_tag.get('name', 'no-name')
        type_attr = input_tag.get('type', 'text')
        value = input_tag.get('value', '')
        placeholder = input_tag.get('placeholder', '')
        
        print(f"    - {name} (type: {type_attr})")
        if value:
            print(f"      Value: {value}")
        if placeholder:
            print(f"      Placeholder: {placeholder}")

# Extract all links
print("\n[PHASE 2] EXTRACTING ALL LINKS")
print("-"*80)

all_links = []

# Standard links
for tag in soup.find_all(['a', 'link', 'script', 'img']):
    for attr in ['href', 'src', 'action']:
        if tag.get(attr):
            link = tag[attr]
            full_url = urljoin(BASE_URL, link)
            all_links.append(full_url)

# Remove duplicates
all_links = list(set(all_links))

print(f"[!] Found {len(all_links)} unique links")

for link in sorted(all_links):
    if '127.0.0.1:33209' in link:
        print(f"  {link}")

# JavaScript analysis
print("\n[PHASE 3] JAVASCRIPT ANALYSIS")
print("-"*80)

scripts = soup.find_all('script')
print(f"[!] Found {len(scripts)} script blocks")

# Extract inline JavaScript
inline_js = []
for idx, script in enumerate(scripts, 1):
    if script.string:  # Inline script
        script_content = script.string
        inline_js.append(script_content)
        print(f"\n[Script {idx}] {len(script_content)} chars")
        
        # Look for interesting patterns
        patterns = {
            'fetch/xhr': r'fetch\(|xmlhttprequest|\.ajax\(|axios\.',
            'endpoints': r'["\'](/?[\w/-]+\.[\w]+)["\']',
            'parameters': r'\?([\w]+)=',
            'functions': r'function\s+([\w$]+)',
            'event_handlers': r'onclick|onsubmit|onload',
        }
        
        for pattern_name, pattern in patterns.items():
            matches = re.findall(pattern, script_content, re.I)
            if matches:
                # Remove duplicates
                unique_matches = list(set(matches))
                print(f"  {pattern_name}: {unique_matches[:5]}")  # Show first 5

# Extract JavaScript from external files
print("\n[PHASE 4] EXTERNAL JAVASCRIPT FILES")
print("-"*80)

external_scripts = soup.find_all('script', src=True)
print(f"[!] Found {len(external_scripts)} external scripts")

for idx, script in enumerate(external_scripts, 1):
    src = script['src']
    full_url = urljoin(BASE_URL, src)
    print(f"\n[External Script {idx}] {full_url}")
    
    try:
        js_resp = requests.get(full_url, headers=HEADERS, timeout=5)
        print(f"  Status: {js_resp.status_code}, Size: {len(js_resp.content)}B")
        
        if js_resp.status_code == 200:
            js_content = js_resp.text
            
            # Look for API endpoints in JS
            api_patterns = [
                r'["\'](/?api/[\w/-]+)["\']',
                r'["\'](/?[\w-]+\?[^"\']+)["\']',
                r'fetch\(["\']([^"\']+)["\']',
                r'\.ajax\(\{[^}]*url\s*:\s*["\']([^"\']+)["\']',
            ]
            
            endpoints_found = []
            for pattern in api_patterns:
                matches = re.findall(pattern, js_content, re.I)
                if matches:
                    endpoints_found.extend(matches)
            
            if endpoints_found:
                print(f"  Endpoints found: {list(set(endpoints_found))}")
                
    except Exception as e:
        print(f"  Error loading: {e}")

# URL parameter patterns
print("\n[PHASE 5] URL PARAMETER PATTERNS")
print("-"*80)

# Look for URL patterns in the content
url_patterns = [
    r'href=["\'][^"\']*\?([^&"\']+)=[^"\']*["\']',
    r'action=["\'][^"\']*\?([^&"\']+)=[^"\']*["\']',
    r'url\s*[:=]\s*["\'][^"\']*\?([^&"\']+)=[^"\']*["\']',
]

all_params = []
for pattern in url_patterns:
    matches = re.findall(pattern, content)
    all_params.extend(matches)

# Remove duplicates
unique_params = list(set(all_params))
print(f"[!] Found {len(unique_params)} unique URL parameters in the page")

for param in sorted(unique_params):
    print(f"  - {param}")

# Comments in HTML
print("\n[PHASE 6] HTML COMMENTS")
print("-"*80)

comments = re.findall(r'<!--(.*?)-->', content, re.S)
print(f"[!] Found {len(comments)} HTML comments")

for idx, comment in enumerate(comments[:5], 1):  # Show first 5
    comment_text = comment.strip()
    if len(comment_text) < 100:  # Don't show very long comments
        print(f"\n[Comment {idx}] {comment_text}")

# Meta tags
print("\n[PHASE 7] META TAGS")
print("-"*80)

meta_tags = soup.find_all('meta')
print(f"[!] Found {len(meta_tags)} meta tags")

for meta in meta_tags:
    name = meta.get('name', meta.get('property', 'unnamed'))
    content = meta.get('content', '')
    print(f"  {name}: {content[:50]}...")

# Hidden inputs
print("\n[PHASE 8] HIDDEN INPUT FIELDS")
print("-"*80)

hidden_inputs = soup.find_all('input', type='hidden')
print(f"[!] Found {len(hidden_inputs)} hidden inputs")

for hidden in hidden_inputs:
    name = hidden.get('name', 'unnamed')
    value = hidden.get('value', '')
    print(f"  {name} = {value[:50]}...")

# Look for upload-related forms or functions
print("\n[PHASE 9] UPLOAD FUNCTIONALITY")
print("-"*80)

# Search for upload keywords
upload_keywords = ['upload', 'file', 'post', 'article', 'content', 'import', 'import_file']
matches = []

for keyword in upload_keywords:
    if keyword.lower() in content.lower():
        # Find context
        start = content.lower().find(keyword.lower())
        context = content[max(0, start-50):start+50]
        matches.append((keyword, context))

if matches:
    print(f"[!] Found {len(matches)} upload-related terms:")
    for keyword, context in matches:
        print(f"  '{keyword}' in: ...{context}...")
else:
    print("[-] No obvious upload keywords found in visible content")

print("\n" + "="*80)
print("ANALYSIS COMPLETE")
print("="*80)

# Save results
results = {
    'url': BASE_URL,
    'page_title': soup.title.string if soup.title else 'No title',
    'form_count': len(forms),
    'link_count': len(all_links),
    'script_count': len(scripts),
    'parameters': unique_params,
    'hidden_fields': len(hidden_inputs),
    'comments': len(comments)
}

with open('/tmp/index_page_analysis.json', 'w') as f:
    json.dump(results, f, indent=2, default=str)

print(f"\n[*] Analysis saved to /tmp/index_page_analysis.json")
