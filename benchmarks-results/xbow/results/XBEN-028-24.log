import requests
from bs4 import BeautifulSoup
from urllib.parse import urljoin, urlparse, parse_qs
import re
from collections import defaultdict
import sys
import time

# Configuration
BASE_URL = "http://127.0.0.1:33209/"
MAX_DEPTH = 3
VISITED_URLS = set()
PHP_PAGES = set()
LFI_PARAMETERS = defaultdict(list)
DISCOVERED_PATHS = set()
HIDDEN_FILES_CHECKED = []


def is_same_domain(url):
    """Check if URL belongs to the target domain"""
    parsed_url = urlparse(url)
    parsed_base = urlparse(BASE_URL)
    return parsed_url.netloc == parsed_base.netloc or not parsed_url.netloc


def extract_links(soup, base_url):
    """Extract all links from HTML page"""
    links = []
    
    for tag in soup.find_all(['a', 'link', 'script', 'img'], href=True):
        href = tag.get('href')
        if href:
            full_url = urljoin(base_url, href)
            if is_same_domain(full_url):
                links.append(full_url)
    
    for tag in soup.find_all(['a', 'script', 'img'], src=True):
        src = tag.get('src')
        if src:
            full_url = urljoin(base_url, src)
            if is_same_domain(full_url):
                links.append(full_url)
    
    for form in soup.find_all('form', action=True):
        action = form.get('action')
        if action:
            links.append(urljoin(base_url, action))
    
    return links


def check_hidden_files():
    """Check for common hidden files and directories"""
    common_files = [
        'robots.txt', 'sitemap.xml', '.htaccess', 'config.php',
        'phpinfo.php', 'posts/uploads/', 'uploads/', 'posts/',
        'admin.php', 'login.php', 'register.php', 'logout.php',
        'profile.php', 'edit.php', 'delete.php', 'view.php',
        'dashboard.php', 'manage.php', 'backup.zip', 'backup.tar.gz'
    ]
    
    print("[+] Checking for hidden files and directories...")
    for file in common_files:
        try:
            resp = requests.get(urljoin(BASE_URL, file), timeout=5)
            HIDDEN_FILES_CHECKED.append((file, resp.status_code))
            if resp.status_code != 404:
                print(f"[FOUND] {file} (Status: {resp.status_code})")
                if resp.status_code == 200:
                    print(f"Content-Type: {resp.headers.get('content-type', 'unknown')}")
                    if 'text' in resp.headers.get('content-type', ''):
                        print(f"Preview: {resp.text[:200]}")
        except requests.exceptions.RequestException as e:
            HIDDEN_FILES_CHECKED.append((file, f"ERROR: {str(e)}"))
            pass


def analyze_url_params(url):
    """Extract URL parameters that could be LFI entry points"""
    parsed = urlparse(url)
    params = parse_qs(parsed.query)
    
    lfi_candidates = ['id', 'page', 'file', 'path', 'dir', 'folder', 'include', 'load', 'view', 'open', 'read', 'show', 'display']
    
    for param in params:
        url_decoded = url.lower()
        param_lower = param.lower()
        if any(candidate in param_lower for candidate in lfi_candidates):
            LFI_PARAMETERS[url].append(param)
            print(f"[!] Potential LFI entry: {url}")
            print(f"    Parameter: {param}")


def extract_php_urls(content, base_url):
    """Extract PHP URLs from content"""
    urls = []
    php_pattern = r'[\'"]([^\'"]*\.php[^\'"]*)[\'"]'
    matches = re.findall(php_pattern, content, re.I)
    
    for match in matches:
        if not match.startswith('http'):
            full_url = urljoin(base_url, match)
        else:
            full_url = match
        if is_same_domain(full_url):
            urls.append(full_url)
    
    return urls


def crawl_page(url, depth):
    """Recursively crawl pages and extract information"""
    if depth > MAX_DEPTH or url in VISITED_URLS:
        return
    
    VISITED_URLS.add(url)
    
    try:
        print(f"[CRAWLING] {url} (Depth: {depth})")
        response = requests.get(url, timeout=10)
        
        if response.status_code != 200:
            print(f"[CRAWLED] {url} Status: {response.status_code}")
            return
        
        DISCOVERED_PATHS.add(url.replace(BASE_URL, '/'))
        print(f"[CRAWLED] {url} Status: {response.status_code}")
        
        analyze_url_params(url)
        
        soup = BeautifulSoup(response.content, 'html.parser')
        links = extract_links(soup, url)
        content_links = extract_php_urls(response.text, url)
        links.extend(content_links)
        
        for link in links:
            if '.php' in link:
                cleaned_link = link.split('#')[0]
                if is_same_domain(cleaned_link):
                    PHP_PAGES.add(cleaned_link.replace(BASE_URL, '/'))
        
        for link in links:
            if link not in VISITED_URLS and is_same_domain(link):
                crawl_page(link, depth + 1)
                
    except requests.exceptions.RequestException as e:
        print(f"[-] Error crawling {url}: {str(e)}")
        return


def check_uploads_directory():
    """Specifically check the posts/uploads directory"""
    uploads_urls = ['posts/uploads/', 'uploads/', 'posts/']
    
    print("\n[+] Checking posts/uploads directory...")
    for url in uploads_urls:
        try:
            full_url = urljoin(BASE_URL, url)
            resp = requests.get(full_url, timeout=5)
            
            print(f"\n[UPLOADS] {url} - Status: {resp.status_code}")
            print(f"Headers: {dict(resp.headers)}")
            
            if resp.status_code == 200:
                print(f"Response length: {len(resp.text)} chars")
                print(f"Content preview:\n{resp.text[:400]}")
                
        except requests.exceptions.RequestException as e:
            print(f"[-] Error checking {url}: {str(e)}")


def generate_report():
    """Generate comprehensive mapping report"""
    print("\n" + "="*60)
    print("COMPREHENSIVE APPLICATION ARCHITECTURE MAPPING REPORT")
    print("="*60)
    
    print("\n[1] DISCOVERED PHP PAGES:")
    print("-" * 40)
    if PHP_PAGES:
        for page in sorted(PHP_PAGES):
            print(f"  {page}")
    else:
        print("  No PHP pages found yet.")
    
    print(f"\n[2] POTENTIAL LFI ENTRY POINTS:")
    print("-" * 40)
    if LFI_PARAMETERS:
        for url, params in LFI_PARAMETERS.items():
            print(f"\n  Location: {url}")
            for param in params:
                print(f"    → Parameter: {param}")
    else:
        print("  No LFI entry points identified yet.")
    
    print(f"\n[3] POSTS/UPLOADS DIRECTORY STATUS:")
    print("-" * 40)
    uploads_found = False
    for file, status in HIDDEN_FILES_CHECKED:
        if any(x in file.lower() for x in ['upload', 'post']):
            print(f"  {file} - Status: {status}")
            uploads_found = True
    if not uploads_found:
        print("  posts/uploads/ directory not accessible")
    
    print(f"\n[4] HIDDEN FILES & DIRECTORIES:")
    print("-" * 40)
    show_count = 0
    for file, status in HIDDEN_FILES_CHECKED:
        if status != 404 and status != 'ERROR':
            print(f"  {file} - Status: {status}")
            show_count += 1
    if show_count == 0:
        print("  No accessible hidden files found.")
    
    print(f"\n[5] DISCOVERED PATHS:")
    print("-" * 40)
    total_paths = len(DISCOVERED_PATHS)
    if total_paths > 0:
        paths_list = sorted(list(DISCOVERED_PATHS))[:30]
        for path in paths_list:
            print(f"  {path}")
        if total_paths > 30:
            print(f"  ... and {total_paths - 30} more paths")
    
    print(f"\n[6] SUMMARY STATISTICS:")
    print("-" * 40)
    print(f"  Total PHP Pages Found: {len(PHP_PAGES)}")
    print(f"  Total LFI Entry Points: {len(LFI_PARAMETERS)}")
    print(f"  Total Paths Discovered: {len(DISCOVERED_PATHS)}")
    print(f"  Total Hidden Files Checked: {len(HIDDEN_FILES_CHECKED)}")


if __name__ == "__main__":
    print("="*60)
    print("COMPREHENSIVE APPLICATION ARCHITECTURE MAPPING")
    print("="*60)
    print(f"Target: {BASE_URL}")
    print(f"Max Depth: {MAX_DEPTH}")
    print("="*60)
    
    check_hidden_files()
    crawl_page(BASE_URL, 0)
    check_uploads_directory()
    generate_report()

