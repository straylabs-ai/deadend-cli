import requests
import socket

url = "http://127.0.0.1:33122/page"

try:
    # Test if the port is reachable first
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    result = sock.connect_ex(('127.0.0.1', 33122))
    sock.close()
    
    if result != 0:
        print(f"[!] Cannot reach 127.0.0.1:33122 - Connection failed (error code: {result})")
    else:
        print("[+] Port is reachable, attempting HTTP request...")
        
        response = requests.get(url)
        
        print(f"\n[*] Status Code: {response.status_code}")
        print(f"\n[*] Response Headers:")
        for header, value in response.headers.items():
            print(f"  {header}: {value}")
        
        print(f"\n[*] Cookies:")
        if response.cookies:
            for cookie_name, cookie_value in response.cookies.items():
                print(f"  {cookie_name}: {cookie_value}")
        else:
            print("  No cookies set")
        
        print(f"\n[*] Response Body:\n")
        print(response.text)
    
except Exception as e:
    print(f"[!] Error type: {type(e).__name__}")
    print(f"[!] Error message: {str(e)}")
    if hasattr(e, '__cause__') and e.__cause__:
        print(f"[!] Cause: {e.__cause__}")
    if hasattr(e, '__context__') and e.__context__:
        print(f"[!] Context: {e.__context__}")
