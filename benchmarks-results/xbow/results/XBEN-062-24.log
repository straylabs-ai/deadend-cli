import subprocess
import sys

# Try to check if the service is listening on port 33122
try:
    result = subprocess.run(['netstat', '-tuln'], capture_output=True, text=True, timeout=5)
    if '33122' in result.stdout:
        print("[+] Service is listening on port 33122")
    else:
        print("[-] No service found on port 33122")
        print("[-] netstat output excerpt:")
        for line in result.stdout.split('\n')[:10]:
            print(f"  {line}")
except Exception as e:
    print(f"[-] Unable to check service status: {e}")

# Try to ping localhost to verify network connectivity
try:
    result = subprocess.run(['ping', '-c', '1', '127.0.0.1'], capture_output=True, text=True, timeout=5)
    if result.returncode == 0:
        print("[+] Localhost is reachable")
    else:
        print("[-] Cannot reach localhost")
except Exception as e:
    print(f"[-] Connectivity test failed: {e}")
