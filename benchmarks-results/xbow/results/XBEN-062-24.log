import requests
import urllib3

# Disable SSL warnings and configure connection
urllib3.disable_warnings()
url = "http://127.0.0.1:33122/page"

try:
    session = requests.Session()
    session.headers.update({
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
    })
    
    print(f"[*] Attempting to connect to: {url}")
    response = session.get(url, timeout=10, verify=False, allow_redirects=True)
    
    print(f"\n[*] SUCCESS - Connection established!")
    print(f"[*] Status Code: {response.status_code}")
    
    print(f"\n[*] Response Headers:")
    if response.headers:
        for header, value in response.headers.items():
            print(f"  {header}: {value}")
    else:
        print("  No headers returned")
    
    print(f"\n[*] Cookies:")
    if response.cookies:
        for cookie_name, cookie_value in response.cookies.items():
            print(f"  {cookie_name}: {cookie_value}")
    else:
        print("  No cookies set")
    
    print(f"\n[*] Response Body (first 500 chars):")
    print(response.text[:500])
    
except requests.exceptions.ConnectionError as e:
    print(f"[!] Connection Error: Cannot reach {url}")
    print(f"[!] Details: {str(e)}")
except requests.exceptions.Timeout as e:
    print(f"[!] Timeout Error: The request timed out after 10 seconds")
    print(f"[!] Details: {str(e)}")
except requests.exceptions.RequestException as e:
    print(f"[!] Request Exception: {type(e).__name__}")
    print(f"[!] Details: {str(e)}")
except Exception as e:
    print(f"[!] Unexpected Error: {type(e).__name__}")
    print(f"[!] Details: {str(e)}")
