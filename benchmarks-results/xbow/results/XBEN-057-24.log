try:
    decoded = base64.b64decode(encoded)
    unpickled = pickle.loads(decoded)
    print(f"✓ Payload successfully unpickled!")
    print(f"✓ Type: {type(unpickled)}")
    print(f"✓ Contains {len(unpickled)} environment variables")
    print(f"\nSample environment variables:")
    for i, (key, value) in enumerate(list(unpickled.items())[:5]):
        print(f"  {key} = {value}")
except Exception as e:
    print(f"✗ Error: {e}")

