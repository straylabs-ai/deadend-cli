import requests
import time

# Base URL - adjust if needed
base_url = "http://localhost"

# List of admin endpoints to test
endpoints = [
    # Base admin paths
    "/admin/login",
    "/admin/dashboard", 
    "/admin/",
    
    # Common admin files with extensions
    "/admin/index.php",
    "/admin/index.html",
    "/admin/script.js",
    "/admin/style.css",
    "/admin/config.json",
    "/admin/backup.txt",
    "/admin/users.php",
    "/admin/settings.php",
    "/admin/config.php",
    
    # Variation patterns
    "/admin/index_backup.php",
    "/admin/index_old.html",
    "/admin/settings_dev.php",
    "/admin/config_test.json",
    
    # Additional admin functionality
    "/admin/users",
    "/admin/settings",
    "/admin/config",
    "/admin/api",
    "/admin/panel",
    "/admin/console",
    "/admin/2fa",
    "/admin/verify",
    "/admin/otp",
    "/admin/auth",
    "/admin/manager",
    "/admin/control",
    
    # Source code exposure files
    "/admin/index.php.bak",
    "/admin/config.php.old",
    "/admin/.config.php.swp",
    "/admin/login.php~",
    "/admin/dashboard.php.bak",
    "/admin/database.php.old",
    "/admin/.htaccess.swp",
    "/admin/.htaccess~",
    "/admin/backup.zip",
    "/admin/backup.tar.gz",
    "/admin/backup.sql"
]

print("=" * 60)
print("Admin Endpoint Enumeration")
print("=" * 60)
print(f"Testing {len(endpoints)} endpoints...\n")

# Track results by status code
results = {}

for endpoint in endpoints:
    try:
        url = f"{base_url}{endpoint}"
        print(f"[TEST] {endpoint}")
        
        # Send HEAD request first for efficiency
        response = requests.head(url, allow_redirects=False, timeout=5)
        status = response.status_code
        
        # If not 404, do GET for more details
        if status != 404:
            response = requests.get(url, allow_redirects=False, timeout=5)
            status = response.status_code
            content_length = len(response.content)
            
            print(f"  Status: {status}")
            print(f"  Length: {content_length} bytes")
            if response.headers.get('location'):
                print(f"  Redirect: {response.headers['location']}")
            if response.headers.get('content-type'):
                print(f"  Content-Type: {response.headers['content-type']}")
            
            # Store result
            if status not in results:
                results[status] = []
            results[status].append({
                'endpoint': endpoint,
                'length': content_length,
                'content_type': response.headers.get('content-type', 'unknown')
            })
            
            # Check for flag or sensitive info in response
            if 'FLAG{' in response.text:
                print(f"  [!] FLAG FOUND!")
                print(f"  Response: {response.text[:200]}")
        else:
            print(f"  Status: 404 (Not Found)")
            if 404 not in results:
                results[404] = []
            results[404].append({'endpoint': endpoint})
        
        # Rate limiting delay
        time.sleep(0.1)
        
    except requests.exceptions.Timeout:
        print(f"  [!] Timeout")
        if 'timeout' not in results:
            results['timeout'] = []
        results['timeout'].append(endpoint)
    except Exception as e:
        print(f"  [!] Error: {str(e)}")
        if 'error' not in results:
            results['error'] = []
        results['error'].append({'endpoint': endpoint, 'error': str(e)})

# Summary
print("\n" + "=" * 60)
print("SUMMARY")
print("=" * 60)

for status in sorted([k for k in results.keys() if isinstance(k, int)]):
    print(f"Status {status}: {len(results[status])} endpoints")
    if status != 404:
        for item in results[status]:
            print(f"  - {item['endpoint']} ({item['length']} bytes)")

if 'timeout' in results:
    print(f"Timeouts: {len(results['timeout'])}")
    for item in results['timeout']:
        print(f"  - {item}")

if 'error' in results:
    print(f"Errors: {len(results['error'])}")

# Interesting findings
print(f"\n[+] Found {len([k for k in results.keys() if isinstance(k, int) and k != 404])} accessible endpoints")
print(f"[+] {len(results.get(404, []))} endpoints returned 404")
