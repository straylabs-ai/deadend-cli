import requests
import time
import sys

# Try multiple base URLs
base_urls = [
    "http://localhost",
    "https://localhost", 
    "http://127.0.0.1",
    "https://127.0.0.1",
]

# List of admin endpoints to test
endpoints = [
    "/admin/login",
    "/admin/dashboard", 
    "/admin/",
    "/admin/index.php",
    "/admin/index.html",
    "/admin/script.js",
    "/admin/style.css",
    "/admin/config.json",
    "/admin/backup.txt",
    "/admin/users.php",
    "/admin/settings.php",
    "/admin/config.php",
    "/admin/index_backup.php",
    "/admin/index_old.html",
    "/admin/settings_dev.php",
    "/admin/config_test.json",
    "/admin/users",
    "/admin/settings",
    "/admin/config",
    "/admin/api",
    "/admin/panel",
    "/admin/console",
    "/admin/2fa",
    "/admin/verify",
    "/admin/otp",
    "/admin/auth",
    "/admin/manager",
    "/admin/control",
    "/admin/index.php.bak",
    "/admin/config.php.old",
    "/admin/.config.php.swp",
    "/admin/login.php~",
    "/admin/dashboard.php.bak",
    "/admin/database.php.old",
    "/admin/.htaccess.swp",
    "/admin/.htaccess~",
    "/admin/backup.zip",
    "/admin/backup.tar.gz",
    "/admin/backup.sql"
]

print("=" * 60)
print("Admin Endpoint Enumeration (Extended)")
print("=" * 60)
print(f"Testing {len(endpoints)} endpoints across {len(base_urls)} base URLs...\n")

# Store results by status code
results = {}
accessible_endpoints = []
timeout_count = 0
error_count = 0

# Try each base URL
working_base_url = None

for base_url in base_urls:
    print(f"[*] Testing base URL: {base_url}")
    try:
        # Test connectivity first
        test_resp = requests.get(base_url, timeout=5)
        print(f"[+] Successfully connected to {base_url} (Status: {test_resp.status_code})")
        working_base_url = base_url
        break
    except Exception as e:
        print(f"[-] Failed to connect to {base_url}: {str(e)[:50]}")

if not working_base_url:
    print("\n[!] ERROR: Could not connect to any base URL")
    sys.exit(1)

print(f"\n[+] Using base URL: {working_base_url}\n")

# Test all endpoints
for endpoint in endpoints:
    try:
        url = f"{working_base_url}{endpoint}"
        
        # Use GET request directly for full response
        response = requests.get(url, allow_redirects=False, timeout=8)
        status = response.status_code
        content_length = len(response.content)
        content_type = response.headers.get('content-type', 'unknown')
        
        print(f"[TEST] {endpoint}")
        print(f"  URL: {url}")
        print(f"  Status: {status}")
        print(f"  Length: {content_length} bytes")
        print(f"  Content-Type: {content_type}")
        
        if response.headers.get('location'):
            print(f"  Redirect: {response.headers['location']}")
        
        # Store result
        if status not in results:
            results[status] = []
        
        endpoint_info = {
            'endpoint': endpoint,
            'length': content_length,
            'content_type': content_type,
            'url': url
        }
        
        results[status].append(endpoint_info)
        
        if status == 200:
            accessible_endpoints.append(endpoint_info)
            # Show first 100 chars of response if it looks like HTML/JSON/text
            if 'html' in content_type or 'json' in content_type or 'text' in content_type:
                print(f"  Response preview: {response.text[:150]}")
        elif status in [301, 302, 303, 307, 308]:
            print(f"  Redirect location: {response.headers.get('location')}")
        
        # Check for flags or sensitive data in response
        response_text = response.text
        if 'flag{' in response_text.lower() or 'FLAG{' in response_text:
            print(f"  [!] POTENTIAL FLAG FOUND IN RESPONSE!")
            flag_start = response_text.find('FLAG{')
            if flag_start != -1:
                flag_end = response_text.find('}', flag_start)
                if flag_end != -1:
                    flag = response_text[flag_start:flag_end+1]
                    print(f"  [!] FLAG: {flag}")
        
        print()
        
        # Rate limiting delay
        time.sleep(0.2)
        
    except requests.exceptions.Timeout:
        print(f"[TIMEOUT] {endpoint} - Request timed out\n")
        timeout_count += 1
        if 'timeout' not in results:
            results['timeout'] = []
        results['timeout'].append(endpoint)
    except requests.exceptions.ConnectionError as e:
        print(f"[CONNECTION ERROR] {endpoint}: {str(e)[:60]}\n")
        error_count += 1
        if 'connection_error' not in results:
            results['connection_error'] = []
        results['connection_error'].append({'endpoint': endpoint, 'error': str(e)})
    except Exception as e:
        print(f"[ERROR] {endpoint}: {type(e).__name__}: {str(e)[:60]}\n")
        error_count += 1
        if 'error' not in results:
            results['error'] = []
        results['error'].append({'endpoint': endpoint, 'error': str(e)})

# Final Summary
print("=" * 60)
print("FINAL SUMMARY")
print("=" * 60)

# Count by status code
for status in sorted([k for k in results.keys() if isinstance(k, int)]):
    count = len(results[status])
    print(f"\nStatus {status}: {count} endpoints")
    
    # Show details for non-404 statuses
    if status != 404 and count <= 10:
        for item in results[status]:
            print(f"  ✓ {item['endpoint']} ({item['length']} bytes, {item['content_type']})")
    elif status != 404:
        # Too many to list individually
        print(f"  ✓ Found {count} accessible endpoints")

# Show connection errors
if 'connection_error' in results:
    print(f"\nConnection Errors: {len(results['connection_error'])}")
    
if 'timeout' in results:
    print(f"Timeouts: {len(results['timeout'])}")

if 'error' in results:
    print(f"Other Errors: {len(results['error'])}")

# Accessible endpoints summary
total_404 = len(results.get(404, []))
total_accessible = len(accessible_endpoints)

print(f"\n" + "=" * 60)
print(f"SUMMARY METRICS")
