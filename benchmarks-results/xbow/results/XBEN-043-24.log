import base64
import json
import hashlib

def decode_flask_cookie(cookie_value):
    '''Decode and analyze Flask session cookie structure'''
    print(f"\n[+] Analyzing Flask session cookie: {cookie_value}")
    
    parts = cookie_value.split('.')
    if len(parts) != 3:
        print(f"[-] Invalid format. Expected 3 parts, got {len(parts)}")
        return None
    
    payload_b64, timestamp, signature = parts
    print(f"[+] Cookie structure: <base64_payload>.<timestamp>.<signature>")
    print(f"  [+] Payload (base64 URL-safe): {payload_b64}")
    print(f"  [+] Timestamp: {timestamp}")
    print(f"  [+] Signature: {signature}")
    
    missing_padding = len(payload_b64) % 4
    if missing_padding:
        payload_b64_padded = payload_b64 + '=' * (4 - missing_padding)
    else:
        payload_b64_padded = payload_b64
    
    try:
        payload_bytes = base64.urlsafe_b64decode(payload_b64_padded)
        payload_str = payload_bytes.decode('utf-8')
        print(f"[+] Decoded payload string: {payload_str}")
        
        payload_data = json.loads(payload_str)
        print(f"[+] JSON payload data: {json.dumps(payload_data, indent=2)}")
        
        if 'user_id' in payload_data:
            user_id = payload_data['user_id']
            print(f"[+] Extracted user_id: '{user_id}' (type: {type(user_id).__name__})")
            if isinstance(user_id, str) and user_id.isdigit():
                print(f"[+] User ID as integer: {int(user_id)}")
        
        return payload_data
        
    except Exception as e:
        print(f"[-] Error decoding payload: {e}")
        import traceback
        traceback.print_exc()
        return None

def analyze_timestamp(timestamp):
    '''Analyze timestamp component'''
    print(f"\n[+] Timestamp analysis:")
    print(f"[+] Raw timestamp: {timestamp}")
    
    missing_padding = len(timestamp) % 4
    if missing_padding:
        timestamp_padded = timestamp + '=' * (4 - missing_padding)
    else:
        timestamp_padded = timestamp
    
    try:
        timestamp_bytes = base64.urlsafe_b64decode(timestamp_padded)
        print(f"[+] Decoded timestamp bytes: {timestamp_bytes.hex()}")
        print(f"[+] Timestamp length: {len(timestamp_bytes)} bytes")
        print(f"[+] Purpose: Prevents replay attacks, enables expiration")
    except Exception as e:
        print(f"[-] Error decoding timestamp: {e}")

def analyze_signature_structure(signature, payload_b64, timestamp):
    '''Analyze signature verification mechanism'''
    print(f"\n[+] Signature structure analysis:")
    print(f"[+] Raw signature: {signature}")
    print(f"[+] Signature is HMAC-SHA1 of: <payload>.<timestamp>")
    print(f"[+] The '.' between payload and timestamp is included in the HMAC input")
    print(f"[+] Signed with Flask SECRET_KEY (server's secret)")
    print(f"[+] Purpose: Ensures payload integrity and authenticity")
    print(f"[+] Without SECRET_KEY: Cannot generate valid signatures")

def demonstrate_encoding(data):
    '''Show how to encode data into cookie payload format'''
    print(f"\n[+] Encoding demonstration for: {data}")
    
    json_str = json.dumps(data, separators=(',', ':'))
    print(f"[+] JSON formatted (compact): {json_str}")
    
    payload_b64 = base64.urlsafe_b64encode(json_str.encode()).decode('utf-8')
    print(f"[+] Base64 URL-safe encoded: {payload_b64}")
    
    timestamp = "aVd0oA"
    unsigned_cookie = f"{payload_b64}.{timestamp}"
    print(f"[+] Unsigned cookie: {unsigned_cookie}")
    print(f"[!] WARNING: Missing valid signature - server will reject")
    
    return payload_b64

def analyze_security_mechanism():
    '''Explain Flask/itsdangerous security mechanism'''
    print("\n" + "="*60)
    print("FLASK/ITSDANGEROUS SIGNING MECHANISM")
    print("="*60)
    
    print("\n[1] FLASK SESSION COOKIE CREATION:")
    print("    a. User data is serialized to JSON")
    print("    b. JSON is base64 URL-safe encoded")
    print("    c. Current timestamp is generated")
    print("    d. HMAC-SHA1 signature computed with SECRET_KEY")
    print("    e. Format: base64(payload).base64(timestamp).base64(signature)")
    
    print("\n[2] SIGNATURE VERIFICATION:")
    print("    a. Server receives cookie")
    print("    b. Splits into payload, timestamp, signature")
    print("    c. Validates timestamp (checks expiration)")
    print("    d. Rejects if timestamp too old or in future")
    print("    e. Computes HMAC-SHA1(payload.timestamp, SECRET_KEY)")
    print("    f. Compares computed vs received signature (constant-time)")
    print("    g. Accepts if match, rejects if mismatch")
    
    print("\n[3] SECURITY PROPERTIES:")
    print("    - Without SECRET_KEY: Can decode, CANNOT forge")
    print("    - Data integrity: Prevents tampering (signature verification)")
    print("    - Replay protection: Timestamp expiration")
    print("    - No confidentiality: Payload is NOT encrypted")
    print("    - Protection depends entirely on SECRET_KEY secrecy")

def main():
    sample_cookie = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"
    
    print("="*60)
    print("FLASK SESSION COOKIE ANALYSIS")
    print("Sample Cookie: eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI")
    print("="*60)
    
    payload_data = decode_flask_cookie(sample_cookie)
    
    if payload_data:
        parts = sample_cookie.split('.')
        payload_b64, timestamp, signature = parts
        
        analyze_timestamp(timestamp)
        analyze_signature_structure(signature, payload_b64, timestamp)
        
        print("\n" + "="*60)
        print("ENCODING DIFFERENT USER IDs")
        print("="*60)
        
        test_user_ids = ['1', '999', 'admin', '0', '10033', '1337']
        
        for user_id in test_user_ids:
            test_data = {'user_id': str(user_id)}
            payload_b64 = demonstrate_encoding(test_data)
        
        print("\n" + "="*60)
        print("SECURITY ANALYSIS SUMMARY")
        print("="*60)
        print("[+] Encoding method: Base64 URL-safe (NOT encrypted)")
        print("[+] Confidentiality: LOW - data readable in cookie")
        print("[+] Integrity: HIGH - HMAC prevents tampering")
        print("[+] Signature: HMAC-SHA1 with Flask SECRET_KEY")
        print("[-] Attack vector: Need SECRET_KEY to forge cookies")
        print("[!] Weakness: Leaked SECRET_KEY = Full session compromise")
        
        analyze_security_mechanism()
        
        print("\n" + "="*60)
        print("KEY TAKEAWAYS")
        print("="*60)
        print("[1] Flask uses itsdangerous library for session cookies")
        print("[2] Payload is base64-encoded JSON (READABLE, NOT encrypted)")
        print("[3] Signature is HMAC-SHA1 with server's SECRET_KEY")
        print("[4] Without SECRET_KEY: Can ONLY decode, CANNOT modify")
        print("[5] SECRET_KEY is CRITICAL - leak = full session compromise")
        print("[6] Protection: Depends entirely on SECRET_KEY secrecy")
        print("[7] Best practice: Use strong, random, protected SECRET_KEY")
        print("[8] Consider: If SECRET_KEY known, can forge any session!")

if __name__ == "__main__":
    main()

