import base64
import json
import itsdangerous
import hashlib

def decode_flask_cookie(cookie_value):
    """Decode and analyze Flask session cookie structure"""
    print("[+] FLASK SESSION COOKIE DECODER")
    print(f"[+] Cookie: {cookie_value}")
    
    parts = cookie_value.split('.')
    if len(parts) != 3:
        print(f"[-] Invalid format. Expected 3 parts, got {len(parts)}")
        return None
    
    payload_b64, timestamp, signature = parts
    print(f"[+] Structure: payload.timestamp.signature")
    print(f"[+] Payload (base64): {payload_b64}")
    print(f"[+] Timestamp: {timestamp}")
    print(f"[+] Signature: {signature}")
    
    missing_padding = len(payload_b64) % 4
    if missing_padding:
        payload_b64_padded = payload_b64 + '=' * (4 - missing_padding)
    else:
        payload_b64_padded = payload_b64
    
    try:
        payload_bytes = base64.urlsafe_b64decode(payload_b64_padded)
        payload_str = payload_bytes.decode('utf-8')
        print(f"[+] Decoded payload: {payload_str}")
        
        payload_data = json.loads(payload_str)
        print(f"[+] JSON data: {payload_data}")
        
        if 'user_id' in payload_data:
            user_id = payload_data['user_id']
            print(f"[+] User ID extracted: {user_id} (raw string)")
            if user_id.isdigit():
                print(f"[+] User ID numeric: {int(user_id)}")
        
        return payload_data
        
    except Exception as e:
        print(f"[-] Error decoding payload: {e}")
        return None

def analyze_timestamp(timestamp):
    """Analyze timestamp component"""
    print(f"[+] Timestamp analysis:")
    print(f"[+] Raw timestamp: {timestamp}")
    
    missing_padding = len(timestamp) % 4
    if missing_padding:
        timestamp_padded = timestamp + '=' * (4 - missing_padding)
    else:
        timestamp_padded = timestamp
    
    try:
        timestamp_bytes = base64.urlsafe_b64decode(timestamp_padded)
        print(f"[+] Decoded timestamp bytes: {timestamp_bytes.hex()}")
        print(f"[+] Timestamp length: {len(timestamp_bytes)} bytes")
        print(f"[+] Timestamp purpose: Prevents replay attacks, expiration")
    except Exception as e:
        print(f"[-] Error decoding timestamp: {e}")

def analyze_signature(signature, payload_b64, timestamp):
    """Analyze signature verification mechanism"""
    print(f"[+] Signature analysis:")
    print(f"[+] Raw signature: {signature}")
    print(f"[+] Signature is HMAC-SHA1 of: {payload_b64}.{timestamp}")
    print(f"[+] Signed with Flask SECRET_KEY (unknown to us)")
    print(f"[+] Purpose: Ensures payload integrity and authenticity")
    print(f"[+] Without SECRET_KEY: Cannot generate valid signatures")

def demonstrate_encoding(data):
    """Show how to encode data into cookie payload format"""
    print(f"[+] Encoding demonstration for: {data}")
    
    json_str = json.dumps(data, separators=(',', ':'))
    print(f"[+] JSON string: {json_str}")
    
    payload_b64 = base64.urlsafe_b64encode(json_str.encode()).decode('utf-8')
    print(f"[+] Base64-encoded payload: {payload_b64}")
    
    timestamp = "aVd0oA"
    unsigned_cookie = f"{payload_b64}.{timestamp}"
    print(f"[+] Unsigned cookie: {unsigned_cookie}")
    print(f"[+] WARNING: Missing valid signature - server will reject")
    
    return payload_b64

def analyze_security_mechanism():
    """Explain Flask/itsdangerous security mechanism"""
    print("[+] FLASK/ITSDANGEROUS SIGNING MECHANISM:")
    print("[+] 1. Serialize data to JSON")
    print("[+] 2. Base64 encode JSON")
    print("[+] 3. Generate current timestamp")
    print("[+] 4. Compute HMAC-SHA1(payload + '.' + timestamp, SECRET_KEY)")
    print("[+] 5. Base64 encode signature")
    print("[+] 6. Format: base64(payload).base64(timestamp).base64(signature)")
    
    print("[+] VERIFICATION PROCESS:")
    print("[+] 1. Split cookie into three parts")
    print("[+] 2. Check timestamp (not expired)")
    print("[+] 3. Recompute HMAC-SHA1(payload.timestamp, SECRET_KEY)")
    print("[+] 4. Compare with provided signature (constant-time)")
    print("[+] 5. If valid: Accept and decode payload")
    print("[+] 6. If invalid: Reject with BadSignature exception")

def main():
    sample_cookie = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"
    
    print("FLASK SESSION COOKIE ANALYZER")
    print("="*60)
    
    payload_data = decode_flask_cookie(sample_cookie)
    
    if payload_data:
        parts = sample_cookie.split('.')
        payload_b64, timestamp, signature = parts
        
        analyze_timestamp(timestamp)
        analyze_signature(signature, payload_b64, timestamp)
        
        print("[+] DEMONSTRATING ENCODING WITH DIFFERENT USER IDs:")
        test_ids = ['1', '999', '0', '10033', 'admin']
        
        for user_id in test_ids:
            test_data = {'user_id': str(user_id)}
            demonstrate_encoding(test_data)
        
        print("[+] SECURITY ANALYSIS:")
        print("[+] Encoding: Base64 only (NOT encrypted)")
        print("[+] Confidentiality: Low - data is visible in cookie")
        print("[+] Integrity: High - HMAC-SHA1 prevents tampering")
        print("[+] Attack vector: Need SECRET_KEY to forge cookies")
        print("[+] Without SECRET_KEY: Can decode but cannot modify")
        
        analyze_security_mechanism()
        
        print("[+] KEY TAKEAWAYS:")
        print("[+] 1. Flask uses itsdangerous for session cookies")
        print("[+] 2. Payload is base64-encoded JSON (readable)")
        print("[+] 3. Signature is HMAC-SHA1 with SECRET_KEY")
        print("[+] 4. Cannot forge without SECRET_KEY")
        print("[+] 5. Leaked SECRET_KEY = full session compromise")

if __name__ == "__main__":
    main()

