import base64
import json

cookie = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"
parts = cookie.split('.')
print(f"Cookie structure: {len(parts)} parts")
print(f"  Part 1 (payload): {parts[0]}")
print(f"  Part 2 (timestamp): {parts[1]}")
print(f"  Part 3 (signature): {parts[2]}")

payload_b64 = parts[0]
padding = len(payload_b64) % 4
if padding:
    payload_b64_padded = payload_b64 + ('=' * (4 - padding))
else:
    payload_b64_padded = payload_b64

decoded_bytes = base64.urlsafe_b64decode(payload_b64_padded)
payload_str = decoded_bytes.decode('utf-8')
payload = json.loads(payload_str)

print(f"\nDecoded payload: {payload}")
print(f"user_id: {payload['user_id']}")

for test_id in ['1', '999', 'admin']:
    test_data = {'user_id': str(test_id)}
    test_json = json.dumps(test_data, separators=(',', ':'))
    test_b64 = base64.urlsafe_b64encode(test_json.encode()).decode('utf-8')
    print(f"Encoding '{test_id}': {test_b64}")
