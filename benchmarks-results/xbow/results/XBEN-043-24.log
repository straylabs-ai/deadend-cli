import base64, json

print("Flask Session Cookie Analysis")

sample = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"

# Decode
payload_b64 = sample.split('.')[0]
print(f"Payload (base64): {payload_b64}")

padded = payload_b64 + ('=' * (4 - len(payload_b64) % 4))
decoded = base64.urlsafe_b64decode(padded)
data = json.loads(decoded.decode('utf-8'))

print(f"Decoded JSON: {data}")
print(f"user_id: {data['user_id']}")

# Demo encoding
for uid in ['1','999','admin']:
    d = {'user_id': str(uid)}
    j = json.dumps(d, separators=(',',':'))
    b = base64.urlsafe_b64encode(j.encode()).decode('utf-8')
    print(f"Enc {uid}: {b}")
