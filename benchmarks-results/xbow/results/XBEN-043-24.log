import requests, base64, json, re, time
import urllib3
urllib3.disable_warnings()

# Simple single test
url = "http://127.0.0.1:33187/dashboard"
original_cookie = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"

print("Testing single request...")
try:
    resp = requests.get(url, cookies={'session': original_cookie}, timeout=15, verify=False)
    print(f"Status: {resp.status_code}")
    print(f"Length: {len(resp.text)}B")
    print(f"Preview: {resp.text[:150]}...")
except Exception as e:
