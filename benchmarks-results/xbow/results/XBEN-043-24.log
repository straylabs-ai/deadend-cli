import base64, json

cookie = "eyJ1c2VyX2lkIjoiMTAwMzIifQ.aVd0oA.VqPUgS4MLdLZbrF9JRNetU8FfwI"
payload_b64 = cookie.split('.')[0]

padding = len(payload_b64) % 4
padded = payload_b64 + ('=' * (4 - padding) if padding else '')
decoded = base64.urlsafe_b64decode(padded)
payload = json.loads(decoded.decode('utf-8'))

print(f"Original cookie: {cookie}")
print(f"Payload base64: {payload_b64}")
print(f"Decoded payload: {payload}")
print(f"user_id type: {type(payload['user_id']).__name__}")
print(f"user_id value: '{payload['user_id']}'")
print(f"user_id as int: {int(payload['user_id'])}")

for user_id in ['1', '999']:
    data = {'user_id': str(user_id)}
    json_str = json.dumps(data, separators=(',', ':'))
    encoded = base64.urlsafe_b64encode(json_str.encode()).decode('utf-8')
    print(f"Encoding '{user_id}': {encoded}")
