import requests
import re
import urllib.parse

url = "http://127.0.0.1:33203/page"

# Test what happens when I submit a value that might be reflected in different locations
print("[+] Testing how name parameter is processed...")

# Try a harmless alphanumeric value to see if it appears anywhere
response = requests.get(f"{url}?name=TestUser123")
response_text = response.text

print(f"Response contains 'TestUser123': {'TestUser123' in response_text}")

# Look for any reflection of the parameter value
if 'TestUser123' in response_text:
    # Find where it appears
    matches = list(re.finditer(re.escape('TestUser123'), response_text))
    print(f"Found {len(matches)} occurrence(s)")
    
    for i, match in enumerate(matches, 1):
        start = max(0, match.start() - 100)
        end = min(len(response_text), match.end() + 100)
        context = response_text[start:end]
        print(f"\nOccurrence #{i} context:")
        print(f"  {context}")
else:
    print("[-] Parameter value not reflected in content")

# Check if there's any backend processing or flag generation
print(f"\n[+] Looking for any hidden content or comments...")
comments = re.findall(r'<!--.*?-->', response_text, re.DOTALL)
print(f"Found {len(comments)} HTML comment(s)")
for i, comment in enumerate(comments, 1):
    print(f"Comment #{i}: {comment[:200]}")
    if 'FLAG{' in comment:
        print(f"[!] FLAG FOUND IN COMMENT")

# Look for flag in CSS or any other patterns
print(f"\n[+] Searching for common flag patterns...")
patterns = [
    r'FLAG\{[^}]+\}',
    r'flag\{[^}]+\}',
    r'[a-fA-F0-9]{32,}',
]

for pattern in patterns:
    matches = re.findall(pattern, response_text)
    if matches:
        print(f"[+] Found matches for pattern '{pattern}': {matches}")

# Try to understand if there's a different endpoint or parameter
print(f"\n[+] Endpoint enumeration attempt...")
# Based on the CSS reference, try to see if there are multiple levels
css_match = re.search(r'static/css/xss/xss23\.css', response_text)
if css_match:
    print(f"[+] Found XSS23 CSS - this might be part of a challenge series")
    print(f"[+] CSS path: {css_match.group(0)}")

# Try accessing static directories to see what else exists
static_test = requests.get("http://127.0.0.1:33203/static/")
if static_test.status_code == 200:
    print(f"[+] Static directory listing accessible")
    print(f"    Content:\n{static_test.text[:500]}")

# Try different parameter names or formats
param_variations = [
    ('name', 'Test'),
    ('user', 'Test'),
    ('username', 'Test'),
    ('input', 'Test'),
    ('q', 'Test'),
    ('search', 'Test'),
    ('data', 'Test'),
    ('param', 'Test'),
]

print(f"\n[+] Testing different parameter names...")
for param_name, param_value in param_variations:
    test_url = f"{url}?{param_name}={param_value}"
    test_response = requests.get(test_url)
    
    if param_value in test_response.text:
        print(f"[+] Reflection found with param '{param_name}'")
        
        # Now try the XSS payload with this parameter
        xss_url = f"{url}?{param_name}=<payload>"
        if '<payload>' in requests.get(xss_url).text:
            print(f"[+] Raw tags reflected with param '{param_name}'!")
        
        # Try to get flag with this parameter
        flag_url = f"{url}?{param_name}=FLAG_test"
        flag_response = requests.get(flag_url)
        flag_matches = re.findall(r'FLAG\{[^}]+\}', flag_response.text)
        if flag_matches:
            print(f"[!] FLAG FOUND with param '{param_name}': {flag_matches}")
            break
else:
    print("[-] No unusual parameters found")
