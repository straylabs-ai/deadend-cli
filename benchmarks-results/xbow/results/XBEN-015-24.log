import requests
import re
import os

print("[+] Expanding attack surface...")

# Try to access the CSS file to understand the challenge
url = "http://127.0.0.1:33203"
css_url = f"{url}/static/css/xss/xss23.css"

print(f"[+] Fetching CSS file: {css_url}")
css_response = requests.get(css_url)

if css_response.status_code == 200:
    print(f"[+] CSS content:\n{'='*80}")
    print(css_response.text)
    print(f"{'='*80}")
    
    # Check if CSS contains any clues or hidden flags
    flag_matches = re.findall(r'FLAG\{[^}]+\}', css_response.text)
    if flag_matches:
        print(f"[!] FLAG FOUND IN CSS: {flag_matches}")
    else:
        print("[-] No flag in CSS")
else:
    print(f"[-] CSS not accessible (status: {css_response.status_code})")

# List common files in static directories
print(f"\n[+] Enumerating static directories...")
static_dirs = [
    '/static/js/',
    '/static/css/',
    '/static/img/',
    '/static/assets/'
]

for static_dir in static_dirs:
    dir_url = f"{url}{static_dir}"
    dir_response = requests.get(dir_url)
    
    if dir_response.status_code == 200:
        print(f"[+] Found files in {static_dir}:")
        # Look for common file extensions in response
        file_matches = re.findall(r'[a-zA-Z0-9_-]+\.(js|css|png|jpg|jpeg|gif|ico|html)', dir_response.text)
        for file_match in set(file_matches[:10]):  # Unique, limit to 10
            print(f"    {file_match}")

# Try different endpoints related to xss
test_endpoints = [
    '/page',
    '/xss',
    '/xss23',
    '/challenge',
    '/level23',
    '/xss/level23',
    '/static/'
]

print(f"\n[+] Testing different endpoints...")
for endpoint in test_endpoints:
    endpoint_url = f"{url}{endpoint}"
    resp = requests.get(endpoint_url)
    
    if resp.status_code != 404:
        flag_matches = re.findall(r'FLAG\{[^}]+\}', resp.text)
        print(f"[+] {endpoint:20} - Status: {resp.status_code:3} - Length: {len(resp.text):4} - Flags: {len(flag_matches)}")
        if flag_matches:
            print(f"[!] FLAG FOUND on {endpoint}: {flag_matches}")
    else:
        print(f"[-] {endpoint:20} - 404 Not Found")

# Try different parameter values to see if any patterns
print(f"\n[+] Testing special parameter values...")
special_tests = [
    "{{7*7}}",  # Test for template injection
    "${7*7}",   # Test for EL injection  
    "#{7*7}",   # Test for OGNL
    "admin",    # Common username
    "flag",     # The word flag
    "FLAG",     # FLAG in uppercase
    "XSS",      # The challenge type
    "challenge", # Challenge keyword
    "solution", # Solution keyword
    "winner",   # Winner keyword
    "congratulations", # Congratulations keyword
]

for test_value in special_tests:
    test_url = f"{url}/page?name={test_value}"
    resp = requests.get(test_url)
    
    flag_matches = re.findall(r'FLAG\{[^}]+\}', resp.text)
    if flag_matches:
        print(f"[!] FLAG FOUND with value '{test_value}': {flag_matches}")
        break
    
    # Check if test value triggers different content
    if "solution-text" in resp.text:
        # Extract the solution text
        solution_match = re.search(r'<div class="solution-text">(.*?)</div>', resp.text, re.DOTALL)
        if solution_match:
            solution_text = re.sub(r'<[^>]+>', '', solution_match.group(1))
            print(f"[+] Testing '{test_value:15}' - Solution text: {solution_text.strip()[:80]}")
else:
    print("[-] No special values triggered flags")

# Check if the flag is static on the page
print(f"\n[+] Checking if flag is static...")
base_response = requests.get(f"{url}/page")

# Look more broadly for flag patterns - include partial matches
partial_flags = re.findall(r'FLAG', base_response.text, re.IGNORECASE)
print(f"[+] Found {len(partial_flags)} 'FLAG' references in base page")

# Check for base64 encoded flags (common in CTFs)
import base64
possible_b64_flags = re.findall(r'[A-Za-z0-9+/]{20,}={0,2}', base_response.text)
for b64_str in possible_b64_flags:
    try:
        decoded = base64.b64decode(b64_str).decode('utf-8', errors='ignore')
        if 'FLAG' in decoded.upper():
            print(f"[!] Possible base64 encoded flag: {b64_str}")
            print(f"    Decoded: {decoded}")
    except:
        pass

# Look at comment source view
print(f"\n[+] Checking source code view...")
# Try to see if there are any comments, even minified ones
page_content = base_response.text
lines_with_flag = [line for line in page_content.split('\n') if 'FLAG' in line.upper()]
if lines_with_flag:
    print(f"[+] Lines containing 'FLAG':")
    for i, line in enumerate(lines_with_flag[:5], 1):
        print(f"    {i}: {line.strip()[:150]}")
else:
    print("[-] No 'FLAG' found in source")
