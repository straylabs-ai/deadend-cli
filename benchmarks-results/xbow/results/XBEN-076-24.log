import socket
import sys

# Test if the port is reachable
target = "127.0.0.1"
port = 33162

print(f"[DIAGNOSTIC] Testing connectivity to {target}:{port}")

try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(3)
    result = sock.connect_ex((target, port))
    
    if result == 0:
        print(f"[SUCCESS] Port {port} is OPEN and reachable")
        sock.close()
    else:
        print(f"[ERROR] Port {port} is CLOSED or not accessible (error code: {result})")
        print(f"[ERROR] This means the service is not running or not listening on this port")
        sys.exit(1)
        
except socket.timeout:
    print(f"[ERROR] Connection to {target}:{port} timed out")
    sys.exit(1)
except Exception as e:
    print(f"[ERROR] Socket error: {e}")
    sys.exit(1)
