import requests
import re
import base64
from html.parser import HTMLParser

# Configuration
target_url = "http://127.0.0.1/admin_panel"
session_cookie = "OHPI_Y1N0-W_1RYNCv342OsWzpNdIqQLP9zIlMlvedk"

# Set up session with authentication
session = requests.Session()
session.cookies.set("session", session_cookie, domain="127.0.0.1", path="/")

print("[*] Attempting to access /admin_panel with authenticated session...")
print(f"[*] URL: {target_url}")

try:
    # Send request to admin_panel
    response = session.get(target_url, timeout=10)
    
    # Print response details
    print(f"[+] Response Status: {response.status_code}")
    print(f"[+] Response Headers: {dict(response.headers)}")
    print(f"[+] Final URL: {response.url}")
    print(f"[+] History (redirects): {response.history}")
    
    # Check if we have cookies
    print(f"[+] Request cookies: {dict(response.request._cookies)}")
    print(f"[+] Response cookies: {dict(response.cookies)}")
    
    # Get the HTML content
    html_content = response.text
    print(f"\n{'='*80}")
    print("COMPLETE HTML RESPONSE:")
    print(f"{'='*80}")
    print(html_content)
    print(f"{'='*80}\n")
    
    # Initialize findings list
    findings = []
    
    # 1. Search for FLAG{} pattern
    flag_pattern = r'FLAG\{[^}]+\}'
    flag_matches = re.findall(flag_pattern, html_content, re.IGNORECASE)
    if flag_matches:
        print(f"[!] FOUND FLAG PATTERN!")
        for i, match in enumerate(flag_matches, 1):
            print(f"   [{i}] {match}")
            findings.append(f"FLAG PATTERN: {match}")
    else:
        print("[-] No FLAG{} pattern found")
        findings.append("No FLAG{} pattern found")
    
    # 2. Search for hidden HTML elements
    hidden_elements = []
    
    # Elements with style="display:none" or style="visibility:hidden"
    style_hidden_pattern = r'<[^>]+style=[^>]*(?:display\s*:\s*none|visibility\s*:\s*hidden)[^>]*>.*?</[^>]+>'
    style_matches = re.findall(style_hidden_pattern, html_content, re.IGNORECASE | re.DOTALL)
    if style_matches:
        hidden_elements.append(f"Style hidden elements: {len(style_matches)} found")
        for i, match in enumerate(style_matches[:3], 1):  # Show first 3
            print(f"[!] Hidden element with style: {match[:100]}...")
    
    # Elements with hidden attribute
    attr_hidden_pattern = r'<[^>]+\shidden[^>]*>.*?</[^>]+>'
    attr_matches = re.findall(attr_hidden_pattern, html_content, re.IGNORECASE | re.DOTALL)
    if attr_matches:
        hidden_elements.append(f"Elements with hidden attribute: {len(attr_matches)} found")
        for i, match in enumerate(attr_matches[:3], 1):
            print(f"[!] Element with hidden attribute: {match[:100]}...")
    
    # Input fields with type="hidden"
    input_hidden_pattern = r'<input[^>]*type=["\']hidden["\'][^>]*>'
    input_matches = re.findall(input_hidden_pattern, html_content, re.IGNORECASE)
    if input_matches:
        hidden_elements.append(f"Hidden input fields: {len(input_matches)} found")
        for i, match in enumerate(input_matches, 1):
            print(f"[!] Hidden input field: {match}")
            # Extract value if present
            value_match = re.search(r'value=["\']([^"\']*)["\']', match)
            if value_match and value_match.group(1):
                print(f"   └─ Value: {value_match.group(1)}")
    
    if hidden_elements:
        findings.extend(hidden_elements)
    else:
        print("[-] No hidden HTML elements found")
        findings.append("No hidden HTML elements found")
    
    # 3. Search for HTML comments containing sensitive data
    comment_pattern = r'<!--(.*?)-->'
    comments = re.findall(comment_pattern, html_content, re.DOTALL)
    sensitive_comments = []
    
    for i, comment in enumerate(comments, 1):
        comment = comment.strip()
        # Skip simple navigation/copyright comments
        if len(comment) > 20 and not comment.startswith('nav') and not comment.startswith('copyright'):
            # Check if comment contains keywords
            keyword_patterns = [r'password', r'secret', r'key', r'token', r'flag', r'admin', r'hidden']
            if any(re.search(keyword, comment, re.IGNORECASE) for keyword in keyword_patterns):
                sensitive_comments.append(f"Comment {i}: {comment[:100]}")
                print(f"[!] Sensitive HTML comment: {comment}")
    
    if sensitive_comments:
        findings.extend(sensitive_comments)
    else:
        print("[-] No sensitive HTML comments found")
        findings.append("No sensitive HTML comments found")
    
    # 4. Search for meta tags with suspicious content
    meta_pattern = r'<meta[^>]*>'
    meta_tags = re.findall(meta_pattern, html_content, re.IGNORECASE)
    interesting_meta = []
    
    for meta in meta_tags:
        # Check for suspicious keywords in meta tags
        meta_lower = meta.lower()
        if any(keyword in meta_lower for keyword in ['flag', 'secret', 'password', 'key', 'token', 'hidden']):
            interesting_meta.append(f"Meta tag: {meta}")
            print(f"[!] Interesting meta tag: {meta}")
    
    if interesting_meta:
        findings.extend(interesting_meta)
    else:
        print("[-] No suspicious meta tags found")
        findings.append("No suspicious meta tags found")
    
    # 5. Search for Base64 encoded strings
    base64_pattern = r'(?:[A-Za-z0-9+/]{4}){3,}(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?'
    base64_matches = re.findall(base64_pattern, html_content)
    decoded_strings = []
    
    for match in base64_matches:
        if len(match) > 20:  # Only process longer strings
            try:
                decoded = base64.b64decode(match).decode('utf-8', errors='ignore')
                if len(decoded) > 10:  # Only keep significant decoded content
                    decoded_strings.append({
                        'encoded': match[:50],
                        'decoded': decoded[:100]
                    })
                    print(f"[!] Base64 encoded string found:")
                    print(f"    Encoded: {match[:100]}...")
                    print(f"    Decoded: {decoded[:100]}...")
                    
                    # Check if decoded contains FLAG pattern
                    if re.search(flag_pattern, decoded, re.IGNORECASE):
                        print(f"    [!] FLAG FOUND IN DECODED STRING!")
            except:
                pass
    
    if decoded_strings:
        findings.append(f"Base64 encoded strings: {len(decoded_strings)} found")
    else:
        print("[-] No Base64 encoded strings found")
        findings.append("No Base64 encoded strings found")
    
    # 6. Search for other encoded/escaped data patterns
    
    # URL encoded strings
    url_encoded_pattern = r'%[0-9A-Fa-f]{2}'
    url_matches = re.findall(url_encoded_pattern, html_content)
    if len(url_matches) > 5:  # More than 5 indicates URL encoded content
        print(f"[!] URL encoded content detected ({len(url_matches)} encoded characters)")
        findings.append(f"URL encoded content detected")
    
    # Hex encoded strings (common in payloads)
    hex_pattern = r'\\x[0-9A-Fa-f]{2}'
    hex_matches = re.findall(hex_pattern, html_content)
    if len(hex_matches) > 5:
        print(f"[!] Hex encoded content detected ({len(hex_matches)} hex sequences)")
        findings.append(f"Hex encoded content detected")
    
    # Unicode escape sequences
    unicode_pattern = r'\\u[0-9A-Fa-f]{4}'
    unicode_matches = re.findall(unicode_pattern, html_content)
    if len(unicode_matches) > 5:
        print(f"[!] Unicode escape sequences detected ({len(unicode_matches)} sequences)")
        findings.append(f"Unicode escape sequences detected")
    
    # Print summary
    print(f"\n{'='*80}")
    print("SUMMARY OF FINDINGS:")
    print(f"{'='*80}")
    for finding in findings:
        print(f"[*] {finding}")
    print(f"{'='*80}")
    
    # Print response statistics
    print(f"\n[+] HTML Content Length: {len(html_content)} characters")
    print(f"[+] Number of lines: {len(html_content.splitlines())}")
    
except requests.exceptions.RequestException as e:
    print(f"[!] Request error: {e}")
    print(f"[!] Verify the URL is accessible and the session is valid")
except Exception as e:
    print(f"[!] Unexpected error: {e}")
    import traceback
    traceback.print_exc()

