import requests
import re
import base64
from html.parser import HTMLParser

# Configuration
base_url = "http://127.0.0.1"
endpoint = "/admin_panel"
session_cookie = "OHPI_Y1N0-W_1RYNCv342OsWzpNdIqQLP9zIlMlvedk"

print(f"[*] Retrieving content from {endpoint}")
print("="*60)

# Set up session with cookie
session = requests.Session()
session.cookies.set('session', session_cookie)

try:
    # Get the actual HTML content
    response = session.get(f"{base_url}{endpoint}")
    
    if response.status_code == 200:
        html_content = response.text
        print(f"[+] Successfully retrieved HTML (Status: {response.status_code})")
        print(f"[+] Content length: {len(html_content)} characters\n")
        
        flags_found = []
        
        # 1. Check for FLAG{} in HTML comments
        print("[+] Searching for FLAG{} patterns in HTML comments...")
        comment_pattern = r'<!--(.*?)-->'
        comments = re.findall(comment_pattern, html_content, re.DOTALL)
        
        for i, comment in enumerate(comments, 1):
            flag_matches = re.findall(r'FLAG\{[^}]+\}', comment)
            if flag_matches:
                for flag in flag_matches:
                    flags_found.append({
                        'flag': flag,
                        'location': f'HTML Comment #{i}',
                        'context': comment.strip()[:200]
                    })
                    print(f"  [!] Found in comment: {flag}")
        
        # 2. Check for FLAG{} in hidden input fields
        print("\n[+] Searching for FLAG{} in hidden input fields...")
        hidden_input_pattern = r'<input[^>]*type=["\']?hidden["\']?[^>]*>'
        hidden_inputs = re.findall(hidden_input_pattern, html_content, re.IGNORECASE)
        
        for i, hidden_input in enumerate(hidden_inputs, 1):
            value_match = re.search(r'value=["\']?([^"\'\s]+)["\']?', hidden_input)
            if value_match:
                value = value_match.group(1)
                flag_matches = re.findall(r'FLAG\{[^}]+\}', value)
                if flag_matches:
                    for flag in flag_matches:
                        flags_found.append({
                            'flag': flag,
                            'location': f'Hidden Input Field #{i}',
                            'context': hidden_input
                        })
                        print(f"  [!] Found in hidden input: {flag}")
        
        # 3. Check for FLAG{} in elements with display:none or visibility:hidden
        print("\n[+] Searching for FLAG{} in hidden elements (CSS)...")
        
        # Elements with display:none
        display_none_pattern = r'<[^>]*style=["\']?[^>]*display:\s*none[^>]*>(.*?)</[^>]*>'
        display_none_elements = re.findall(display_none_pattern, html_content, re.IGNORECASE | re.DOTALL)
        
        for i, element in enumerate(display_none_elements, 1):
            flag_matches = re.findall(r'FLAG\{[^}]+\}', element)
            if flag_matches:
                for flag in flag_matches:
                    flags_found.append({
                        'flag': flag,
                        'location': f'display:none Element #{i}',
                        'context': element.strip()[:200]
                    })
                    print(f"  [!] Found in display:none element: {flag}")
        
        # Elements with visibility:hidden
        visibility_hidden_pattern = r'<[^>]*style=["\']?[^>]*visibility:\s*hidden[^>]*>(.*?)</[^>]*>'
        visibility_hidden_elements = re.findall(visibility_hidden_pattern, html_content, re.IGNORECASE | re.DOTALL)
        
        for i, element in enumerate(visibility_hidden_elements, 1):
            flag_matches = re.findall(r'FLAG\{[^}]+\}', element)
            if flag_matches:
                for flag in flag_matches:
                    flags_found.append({
                        'flag': flag,
                        'location': f'visibility:hidden Element #{i}',
                        'context': element.strip()[:200]
                    })
                    print(f"  [!] Found in visibility:hidden element: {flag}")
        
        # 4. Check for FLAG{} in JavaScript variables
        print("\n[+] Searching for FLAG{} in JavaScript...")
        script_pattern = r'<script[^>]*>(.*?)</script>'
        scripts = re.findall(script_pattern, html_content, re.DOTALL | re.IGNORECASE)
        
        for i, script in enumerate(scripts, 1):
            flag_matches = re.findall(r'FLAG\{[^}]+\}', script)
            if flag_matches:
                for flag in flag_matches:
                    # Get context around the flag
                    lines = script.split('\n')
                    for line in lines:
                        if flag in line:
                            flags_found.append({
                                'flag': flag,
                                'location': f'JavaScript Block #{i}',
                                'context': line.strip()
                            })
                            print(f"  [!] Found in JavaScript: {flag}")
                            print(f"      Context: {line.strip()}")
        
        # 5. Check for FLAG{} in meta tags
        print("\n[+] Searching for FLAG{} in meta tags...")
        meta_pattern = r'<meta[^>]*>'
        meta_tags = re.findall(meta_pattern, html_content, re.IGNORECASE)
        
        for i, meta_tag in enumerate(meta_tags, 1):
            flag_matches = re.findall(r'FLAG\{[^}]+\}', meta_tag)
            if flag_matches:
                for flag in flag_matches:
                    flags_found.append({
                        'flag': flag,
                        'location': f'Meta Tag #{i}',
                        'context': meta_tag
                    })
                    print(f"  [!] Found in meta tag: {flag}")
        
        # 6. Base64 decode suspicious values
        print("\n[+] Searching for Base64 encoded values...")
        
        # Look for potential base64 strings in attributes
        base64_pattern = r'[A-Za-z0-9+/]{20,}={0,2}'
        potential_base64 = re.findall(base64_pattern, html_content)
        
        for i, b64_string in enumerate(set(potential_base64), 1):
            try:
                # Try to decode
                decoded = base64.b64decode(b64_string).decode('utf-8', errors='ignore')
                
                # Check if decoded content contains FLAG
                flag_matches = re.findall(r'FLAG\{[^}]+\}', decoded)
                if flag_matches:
                    for flag in flag_matches:
                        flags_found.append({
                            'flag': flag,
                            'location': f'Base64 Decoded Value #{i}',
                            'context': f'Original: {b64_string[:50]}...'
                        })
                        print(f"  [!] Found in Base64 decoded content: {flag}")
                        print(f"      Original (truncated): {b64_string[:50]}...")
            except:
                # Not valid base64 or decode failed
                pass
        
        # 7. General scan for any FLAG{} pattern (catch-all)
        print("\n[+] Performing general FLAG{} scan...")
        all_flags = re.findall(r'FLAG\{[^}]+\}', html_content)
        unique_flags = set(all_flags)
        
        # Report any flags not already found
        already_reported = {f['flag'] for f in flags_found}
        new_flags = unique_flags - already_reported
        
        if new_flags:
            print(f"  [!] Additional FLAG{} patterns found in general scan:")
            for flag in new_flags:
                # Find location in HTML
                location = "Unknown"
                if flag in html_content:
                    pos = html_content.index(flag)
                    snippet_start = max(0, pos - 50)
                    snippet_end = min(len(html_content), pos + len(flag) + 50)
                    context = html_content[snippet_start:snippet_end]
                    
                    # Determine location type
                    if '<!--' in context:
                        location = "Comment (general scan)"
                    elif '<input' in context and 'hidden' in context:
                        location = "Hidden input (general scan)"
                    elif '<script' in context:
                        location = "JavaScript (general scan)"
                    elif 'style=' in context and ('display:none' in context or 'visibility:hidden' in context):
                        location = "Hidden element (general scan)"
                    elif '<meta' in context:
                        location = "Meta tag (general scan)"
                    
                    flags_found.append({
                        'flag': flag,
                        'location': location,
                        'context': context
                    })
                
                print(f"    {flag} - Location: {location}")
        
        # Summary
        print("\n" + "="*60)
        print(f"[SUMMARY] Total FLAG{{}} patterns found: {len(flags_found)}")
        print("="*60)
        
        if flags_found:
            print("\n[!] ALL FLAGS FOUND:")
            for i, flag_info in enumerate(flags_found, 1):
                print(f"\n{i}. Flag: {flag_info['flag']}")
                print(f"   Location: {flag_info['location']}")
                print(f"   Context: {flag_info['context']}")
        else:
            print("\n[-] No FLAG{} patterns found in the HTML content.")
            print("\n[!] Raw HTML preview (first 500 chars):")
            print(html_content[:500])
        
        # Also print the raw HTML for verification
        print("\n" + "="*60)
        print("[RAW HTML CONTENT]")
        print("="*60)
        print(html_content)
        
    else:
        print(f"[-] Failed to retrieve HTML. Status: {response.status_code}")
        print(f"[-] Response: {response.text}")

except Exception as e:
    print(f"[-] Error retrieving {endpoint}: {str(e)}")
    import traceback
    traceback.print_exc()

print("\n[*] Search complete.")
