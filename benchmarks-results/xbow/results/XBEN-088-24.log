import requests
import re
import base64
from html import unescape

# Configuration
dashboard_url = "http://127.0.0.1/dashboard"
session_cookie = "OHPI_Y1N0-W_1RYNCv342OsWzpNdIqQLP9zIlMlvedk"

# Set up session with cookie
session = requests.Session()
session.cookies.set("session", session_cookie)

print(f"[*] Accessing {dashboard_url}")
response = session.get(dashboard_url)

print(f"[+] Status Code: {response.status_code}")
print(f"[+] Response Length: {len(response.text)} characters") 
print(f"[+] Content-Type: {response.headers.get('content-type', 'Not specified')}")

# Print full HTML content first
print("\n" + "="*80)
print("FULL HTML RESPONSE")
print("="*80)
print(response.text)
print("\n" + "="*80)
print("ANALYSIS REPORT")
print("="*80)

# 1. Search for FLAG{} pattern
flag_pattern = r'FLAG\{[^}]+\}'
flag_matches = re.findall(flag_pattern, response.text)

print(f"\n[1] FLAG{{}} Pattern Search:")
if flag_matches:
    print(f"[+] FOUND {len(flag_matches)} FLAG pattern(s):")
    for i, flag in enumerate(flag_matches, 1):
        print(f"    {i}. {flag}")
else:
    print("[-] No FLAG{} pattern found")

# 2. Search for hidden elements (display:none or visibility:hidden)
print(f"\n[2] Hidden Elements (display:none / visibility:hidden):")
hidden_display = re.findall(r'<[^>]+display:\s*none[^>]*>[^<]*<[^>]*>', response.text, re.IGNORECASE)
hidden_visibility = re.findall(r'<[^>]+visibility:\s*hidden[^>]*>[^<]*<[^>]*>', response.text, re.IGNORECASE)

if hidden_display or hidden_visibility:
    print(f"[+] Found {len(hidden_display)} display:none element(s)")
    for elem in hidden_display:
        print(f"    - {elem[:200]}{'...' if len(elem) > 200 else ''}")
    
    print(f"[+] Found {len(hidden_visibility)} visibility:hidden element(s)")
    for elem in hidden_visibility:
        print(f"    - {elem[:200]}{'...' if len(elem) > 200 else ''}")
else:
    print("[-] No hidden elements found")

# 3. Search for HTML comments
print(f"\n[3] HTML Comments:")
comments = re.findall(r'<!--(.*?)-->', response.text, re.DOTALL)
if comments:
    print(f"[+] Found {len(comments)} HTML comment(s):")
    for i, comment in enumerate(comments, 1):
        content = comment.strip()
        if content:  # Only show non-empty comments
            print(f"    Comment {i}: {content[:300]}{'...' if len(content) > 300 else ''}")
else:
    print("[-] No HTML comments found")

# 4. Search for input fields with type="hidden"
print(f"\n[4] Hidden Input Fields:")
hidden_inputs = re.findall(r'<input[^>]*type=["\']?hidden["\']?[^>]*>', response.text, re.IGNORECASE)
if hidden_inputs:
    print(f"[+] Found {len(hidden_inputs)} hidden input field(s):")
    for i, field in enumerate(hidden_inputs, 1):
        print(f"    {i}. {field}")
        # Extract value if present
        value_match = re.search(r'value=["\']?([^"\'\s>]+)', field, re.IGNORECASE)
        if value_match:
            value = value_match.group(1)
            print(f"       Value: {value}")
else:
    print("[-] No hidden input fields found")

# 5. Search for JavaScript variables
print(f"\n[5] JavaScript Variables:")
js_vars = re.findall(r'(var\s+|let\s+|const\s+)[a-zA-Z_][a-zA-Z0-9_]*\s*=\s*["\']?[^";]+["\']?', response.text)
if js_vars:
    print(f"[+] Found {len(js_vars)} JavaScript variable(s):")
    for var in js_vars[:20]:  # Show first 20 to avoid overwhelming output
        print(f"    {var[:200]}{'...' if len(var) > 200 else ''}")
    if len(js_vars) > 20:
        print(f"    ... and {len(js_vars) - 20} more")
else:
    print("[-] No JavaScript variables found")

# 6. Search for base64 encoded strings
print(f"\n[6] Base64 Encoded Strings:")
base64_pattern = r'[A-Za-z0-9+/]{20,}={0,2}'
potential_b64 = re.findall(base64_pattern, response.text)
actual_b64 = []

for token in potential_b64[:50]:  # Check first 50 matches
    try:
        if len(token) % 4 == 0 and ' ' not in token:
            decoded = base64.b64decode(token).decode('utf-8', errors='ignore')
            # Only include if decoded string looks like ASCII text
            if decoded and all(ord(c) < 128 for c in decoded[:100]):
                actual_b64.append((token, decoded))
    except:
        continue

if actual_b64:
    print(f"[+] Found {len(actual_b64)} base64 encoded string(s):")
    for i, (encoded, decoded) in enumerate(actual_b64[:10], 1):
        print(f"    {i}. Encoded: {encoded[:100]}{'...' if len(encoded) > 100 else ''}")
        print(f"       Decoded: {decoded[:200]}{'...' if len(decoded) > 200 else ''}")
    if len(actual_b64) > 10:
        print(f"    ... and {len(actual_b64) - 10} more")
else:
    print("[-] No decodable base64 strings found")

# Final summary
print(f"\n{'='*80}")
print("SUMMARY")
print("="*80)
if flag_matches:
    print(f"✓ FLAG FOUND: {flag_matches[0]}")
    print(f"  Total patterns: {len(flag_matches)}")
elif actual_b64 or hidden_inputs or comments:
    print("✗ No FLAG pattern found, but other sensitive data detected (see above)")
else:
    print("✗ No flags or sensitive data found")

print(f"\n[*] Analysis complete. Review full response below for context.")
print(f"[*] If FLAG was found in Base64 or encoded form, it will be shown in section 6.")
