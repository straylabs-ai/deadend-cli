for script in re.findall(r'<script[^>]*>(.*?)</script>', html, re.I|re.DOTALL):
    flags.extend([{'flag': f, 'loc': 'javascript'} for f in re.findall(r'FLAG\{[^}]+\}', script)])

# 5. Meta tags
for meta in re.findall(r'<meta[^>]*>', html, re.I):
    flags.extend([{'flag': f, 'loc': 'meta'} for f in re.findall(r'FLAG\{[^}]+\}', meta)])

# 6. Base64
for b64 in set(re.findall(r'[A-Za-z0-9+/]{20,}={0,2}', html)):
