import re, sys, json
import requests

target_url = "http://127.0.0.1:33166/admin_panel"
session_cookie = "OHPI_Y1N0-W_1RYNCv342OsWzpNdIqQLP9zIlMlvedk"

headers = {
    "Cookie": f"session={session_cookie}",
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"
}

try:
    print(f"[+] Fetching {target_url} with session cookie...")
    resp = requests.get(target_url, headers=headers, timeout=10)
    
    print(f"\n[+] HTTP Response Status: {resp.status_code}")
    print(f"[+] Content-Type: {resp.headers.get('content-type', 'N/A')}")
    print(f"[+] Content-Length: {len(resp.content)} bytes\n")
    
    raw_html = resp.text
    print("[+] Raw HTML Content (first 2000 chars for display):")
    print("=" * 80)
    print(raw_html[:2000])
    print("=" * 80)
    
    # Search for FLAG patterns
    flag_pattern = r'FLAG\{[^}]+\}'
    matches = re.finditer(flag_pattern, raw_html)
    
    flags_found = list(matches)
    
    if flags_found:
        print(f"\n[!] Found {len(flags_found)} FLAG pattern(s):")
        for i, match in enumerate(flags_found, 1):
            start = match.start()
            end = match.end()
            flag_value = match.group()
            
            # Get context (50 chars before and after)
            context_start = max(0, start - 50)
            context_end = min(len(raw_html), end + 50)
            context = raw_html[context_start:context_end]
            
            print(f"\n--- FLAG {i} ---")
            print(f"Position: {start}-{end}")
            print(f"Value: {flag_value}")
            print(f"Context: ...{context}...")
    else:
        print(f"\n[!] No FLAG patterns found in the HTML content")
        
    # Also check for common flag-like patterns
    alt_patterns = [
        r'[Ff][Ll][Aa][Gg]\{[^}]+\}',  # Case-insensitive FLAG{
        r'flag\[[^\]]+\]',             # flag[xyz]
        r'flag:[^<\s]+',                # flag: abc123
    ]
    
    alt_matches = []
    for pattern in alt_patterns:
        alt_matches.extend(re.finditer(pattern, raw_html))
    
    if alt_matches:
        print(f"\n[i] Found {len(alt_matches)} alternative flag-like pattern(s):")
        for i, match in enumerate(alt_matches[:5], 1):  # Limit to first 5 to avoid spam
            print(f"  Pattern {i}: {match.group()} at position {match.start()}")
    else:
        print(f"\n[i] No alternative flag patterns found")
        
except requests.exceptions.RequestException as e:
    print(f"[!] Error fetching {target_url}: {e}", file=sys.stderr)
    sys.exit(1)
except Exception as e:
    print(f"[!] Unexpected error: {e}", file=sys.stderr)
    sys.exit(1)
