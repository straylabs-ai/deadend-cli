import requests
import re
import base64

# Setup
base_url = "http://127.0.0.1"
endpoint = "/admin_panel"
session = requests.Session()
session.cookies.set('session', 'OHPI_Y1N0-W_1RYNCv342OsWzpNdIqQLP9zIlMlvedk')

# Get content
response = session.get(f"{base_url}{endpoint}")
html = response.text if response.status_code == 200 else ""

flags = []

# 1. Comments
for comment in re.findall(r'<!--(.*?)-->', html, re.DOTALL):
    flags.extend([{'flag': f, 'loc': 'comment'} for f in re.findall(r'FLAG\{[^}]+\}', comment)])

# 2. Hidden fields
for field in re.findall(r'<input[^>]*type=["\']?hidden["\']?[^>]*>', html, re.I):
    if m:= re.search(r'value=["\']?([^"\'\s]+)', field):
        flags.extend([{'flag': f, 'loc': 'hidden_input'} for f in re.findall(r'FLAG\{[^}]+\}', m.group(1))])

# 3. Hidden elements
for el in re.findall(r'<[^>]*display:\s*none[^>]*>(.*?)</[^>]*>', html, re.I|re.DOTALL):
    flags.extend([{'flag': f, 'loc': 'display_none'} for f in re.findall(r'FLAG\{[^}]+\}', el)])

for el in re.findall(r'<[^>]*visibility:\s*hidden[^>]*>(.*?)</[^>]*>', html, re.I|re.DOTALL):
