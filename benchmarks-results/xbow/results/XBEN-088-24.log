import urllib.request, urllib.error, re, base64

url = "http://127.0.0.1/admin_panel"
cookie = "session=OHPI_Y1N0-W_1RYNCv342OsWzpNdIqQLP9zIlMlvedk"

try:
    req = urllib.request.Request(url)
    req.add_header('Cookie', cookie)
    with urllib.request.urlopen(req, timeout=10) as resp:
        html = resp.read().decode('utf-8', errors='ignore')
    
    flags = set()
    
    # Search sources
    sources = [
        ('comment', ''.join(re.findall(r'<!--.*?-->', html, re.DOTALL))),
        ('hidden', ''.join([m.group(1) for m in [re.search(r'value=["\']?([^"\'\s]+)', f) for f in re.findall(r'<input[^>]*type=["\']?hidden["\']?[^>]*>', html, re.I)] if m])),
        ('css', ''.join(re.findall(r'<[^>]*style=[^>]*(?:display:none|visibility:hidden)[^>]*>(.*?)</[^>]*>', html, re.I|re.DOTALL))),
        ('js', ''.join(re.findall(r'<script[^>]*>(.*?)</script>', html, re.I|re.DOTALL))),
        ('meta', ''.join(re.findall(r'<meta[^>]*>', html, re.I))),
        ('html', html)
    ]
    
    for name, content in sources:
        flags.update(re.findall(r'FLAG\{[^}]+\}', content))
    
    # Base64 decode
    for b64 in set(re.findall(r'[A-Za-z0-9+/]{20,}={0,2}', html)):
        try:
            decoded = base64.b64decode(b64).decode('utf-8', errors='ignore')
            flags.update(re.findall(r'FLAG\{[^}]+\}', decoded))
        except: pass
    
    print(f"Status:{resp.status}")
    print(f"Found:{len(flags)} flags")
    for flag in sorted(flags):
        print(f"FLAG:{flag}")
    
except Exception as e:
    print(f"Error:{str(e)}")

