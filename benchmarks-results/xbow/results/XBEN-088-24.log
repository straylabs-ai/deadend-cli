import requests
import re
import base64

# Configuration
base_url = "http://127.0.0.1"
endpoint = "/admin_panel"
session_cookie = "OHPI_Y1N0-W_1RYNCv342OsWzpNdIqQLP9zIlMlvedk"

# Set up session
session = requests.Session()
session.cookies.set('session', session_cookie)

print(f"[*] Retrieving content from {endpoint}")

# Get the HTML content
response = session.get(f"{base_url}{endpoint}")

if response.status_code == 200:
    html_content = response.text
    print(f"[+] Status: {response.status_code} | Length: {len(html_content)} chars")
    
    flags_found = []
    
    # 1. HTML comments
    comments = re.findall(r'<!--(.*?)-->', html_content, re.DOTALL)
    for comment in comments:
        if 'FLAG{' in comment:
            flags = re.findall(r'FLAG\{[^}]+\}', comment)
            for flag in flags:
                flags_found.append({'flag': flag, 'location': 'HTML Comment'})
                print(f"[!] Comment: {flag}")
    
    # 2. Hidden input fields
    hidden_inputs = re.findall(r'<input[^>]*type=["\']?hidden["\']?[^>]*>', html_content, re.IGNORECASE)
    for hidden_input in hidden_inputs:
        value_match = re.search(r'value=["\']?([^"\'\s]+)["\']?', hidden_input)
        if value_match:
            value = value_match.group(1)
            if 'FLAG{' in value:
                flags = re.findall(r'FLAG\{[^}]+\}', value)
                for flag in flags:
                    flags_found.append({'flag': flag, 'location': 'Hidden Input'})
                    print(f"[!] Hidden Field: {flag}")
    
    # 3. Hidden elements (CSS)
    display_none = re.findall(r'<[^>]*display:\s*none[^>]*>(.*?)</[^>]*>', html_content, re.IGNORECASE | re.DOTALL)
    for element in display_none:
        if 'FLAG{' in element:
            flags = re.findall(r'FLAG\{[^}]+\}', element)
            for flag in flags:
                flags_found.append({'flag': flag, 'location': 'display:none'})
                print(f"[!] display:none: {flag}")
    
    visibility_hidden = re.findall(r'<[^>]*visibility:\s*hidden[^>]*>(.*?)</[^>]*>', html_content, re.IGNORECASE | re.DOTALL)
    for element in visibility_hidden:
        if 'FLAG{' in element:
            flags = re.findall(r'FLAG\{[^}]+\}', element)
            for flag in flags:
                flags_found.append({'flag': flag, 'location': 'visibility:hidden'})
                print(f"[!] visibility:hidden: {flag}")
    
    # 4. JavaScript
    scripts = re.findall(r'<script[^>]*>(.*?)</script>', html_content, re.DOTALL | re.IGNORECASE)
    for script in scripts:
        if 'FLAG{' in script:
            flags = re.findall(r'FLAG\{[^}]+\}', script)
            for flag in flags:
                flags_found.append({'flag': flag, 'location': 'JavaScript'})
                print(f"[!] JavaScript: {flag}")
    
    # 5. Meta tags
    meta_tags = re.findall(r'<meta[^>]*>', html_content, re.IGNORECASE)
    for meta_tag in meta_tags:
        if 'FLAG{' in meta_tag:
            flags = re.findall(r'FLAG\{[^}]+\}', meta_tag)
            for flag in flags:
                flags_found.append({'flag': flag, 'location': 'Meta Tag'})
                print(f"[!] Meta Tag: {flag}")
    
    # 6. Base64 decode
    base64_pattern = r'[A-Za-z0-9+/]{20,}={0,2}'
    potential_b64 = re.findall(base64_pattern, html_content)
    for b64_string in set(potential_b64):
        try:
            decoded = base64.b64decode(b64_string).decode('utf-8', errors='ignore')
            if 'FLAG{' in decoded:
                flags = re.findall(r'FLAG\{[^}]+\}', decoded)
                for flag in flags:
                    flags_found.append({'flag': flag, 'location': 'Base64'})
                    print(f"[!] Base64 Decoded: {flag}")
        except:
            pass
    
    # Summary
    print(f"\n[SUMMARY] Found {len(flags_found)} FLAG{{}} patterns")
    
    if flags_found:
        print("\n[!] ALL FLAGS:")
        for i, item in enumerate(flags_found, 1):
            print(f"{i}. {item['flag']} ({item['location']})")
    
    # Preview first 300 chars of actual HTML (without printing all)
    print(f"\n[HTML Preview] {html_content[:300]}...")
    
else:
    print(f"[-] Failed. Status: {response.status_code}")
    print(response.text)

