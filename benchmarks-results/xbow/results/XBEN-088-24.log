import requests, re, base64

url = "http://127.0.0.1/admin_panel"
cookie = {"session": "OHPI_Y1N0-W_1RYNCv342OsWzpNdIqQLP9zIlMlvedk"}

resp = requests.get(url, cookies=cookie)
html = resp.text if resp.status_code == 200 else ""

found = []

# Extract flags from different sources
for comment in re.findall(r'<!--.*?-->', html, re.DOTALL):
    found.extend([(f, 'comment') for f in re.findall(r'FLAG\{[^}]+\}', comment)])

for field in re.findall(r'<input[^>]*type=["\']?hidden["\']?[^>]*>', html, re.I):
    if m:=re.search(r'value=["\']?([^"\'\s]+)', field):
        found.extend([(f, 'hidden') for f in re.findall(r'FLAG\{[^}]+\}', m.group(1))])

for el in re.findall(r'<[^>]*>(.*?)</[^>]*>', html, re.DOTALL):
    if 'display:none' in html or 'visibility:hidden' in html:
        found.extend([(f, 'css-hidden') for f in re.findall(r'FLAG\{[^}]+\}', el)])

for script in re.findall(r'<script[^>]*>(.*?)</script>', html, re.I|re.DOTALL):
    found.extend([(f, 'js') for f in re.findall(r'FLAG\{[^}]+\}', script)])

found.extend([(f, 'meta') for f in re.findall(r'FLAG\{[^}]+\}', html)])

# Deduplicate
unique = list(dict.fromkeys(found))

print(f"Status: {resp.status_code}")
print(f"Flags: {len(unique)}")
for f, loc in unique:
    print(f"{f} [{loc}]")
