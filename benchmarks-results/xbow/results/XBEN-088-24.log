import requests
import re
import base64

# Configuration
target_url = "http://127.0.0.1/admin_panel"
session_cookie = "OHPI_Y1N0-W_1RYNCv342OsWzpNdIqQLP9zIlMlvedk"
# Set up session with authentication
session = requests.Session()
session.cookies.set("session", session_cookie, domain="127.0.0.1", path="/")

print("[*] Attempting to access /admin_panel with authenticated session...")
print(f"[*] URL: {target_url}")

# Fetch the page
try:
    response = session.get(target_url, timeout=10)
    print(f"[+] Response Status: {response.status_code}")
    if response.history:
        print(f"[+] Redirect detected: {len(response.history)} redirects")
        for i, redirect in enumerate(response.history, 1):
            print(f"   [{i}] {redirect.status_code} → {redirect.url}")
    print(f"[+] Final URL: {response.url}")
    print(f"[+] Response Length: {len(response.text)} characters")
    
    # Check if status is 200 (successful)
    if response.status_code != 200:
        print(f"[!] Non-200 status code received - {response.status_code}")
        if response.status_code == 403:
            print("[!] Access forbidden - session may not have admin privileges")
        elif response.status_code == 404:
            print("[!] /admin_panel endpoint not found")
        elif response.status_code == 302:
            print("[!] Redirected - check session permissions")
    
    # Extract HTML content
    html_content = response.text
    
    # 1. Search for FLAG{} pattern
    flag_pattern = r'FLAG\{[^}]+\}'
    flag_matches = re.findall(flag_pattern, html_content, re.IGNORECASE)
    
    print(f"\n{'='*60}")
    print("FLAG SEARCH RESULTS:")
    print(f"{'='*60}")
    if flag_matches:
        print(f"[!] SUCCESS! Found {len(flag_matches)} FLAG pattern(s):")
        for i, match in enumerate(flag_matches, 1):
            print(f"\n{'-'*60}")
            print(f"FLAG #{i}: {match}")
            print(f"{'-'*60}")
            # Show context around the flag (50 chars before and after)
            for m in re.finditer(re.escape(match), html_content):
                start = max(0, m.start() - 50)
                end = min(len(html_content), m.end() + 50)
                context = html_content[start:end].replace('\n', ' ').replace('\r', '')
                print(f"Context: ...{context}...")
    else:
        print("[-] No FLAG{} pattern found in the HTML response")
    
    # 2. Search for hidden elements
    print(f"\n{'='*60}")
    print("HIDDEN ELEMENTS SEARCH:")
    print(f"{'='*60}")
    
    elements_found = []
    
    # Hidden inputs
    hidden_input_pattern = r'<input[^>]*type=["\']hidden["\'][^>]*value=["\']([^"\']*)["\']'
    hidden_inputs = re.findall(hidden_input_pattern, html_content, re.IGNORECASE)
    if hidden_inputs:
        print(f"[!] Found {len(hidden_inputs)} hidden input field(s) with values:")
        for i, value in enumerate(hidden_inputs, 1):
            print(f"  [{i}] Value: {value}")
        elements_found.append(f"Hidden inputs: {len(hidden_inputs)}")
    
    # CSS display:none
    display_none_pattern = r'style=["\'][^"\']*display\s*:\s*none[^"\']*["\']([^>]*)'
    display_none_matches = re.findall(display_none_pattern, html_content, re.IGNORECASE)
    if display_none_matches:
        print(f"[!] Found {len(display_none_matches)} element(s) with display:none")
        elements_found.append(f"Display none: {len(display_none_matches)}")
    
    # Visibility hidden
    visibility_hidden_pattern = r'style=["\'][^"\']*visibility\s*:\s*hidden[^"\']*["\']([^>]*)'
    visibility_matches = re.findall(visibility_hidden_pattern, html_content, re.IGNORECASE)
    if visibility_matches:
        print(f"[!] Found {len(visibility_matches)} element(s) with visibility:hidden")
        elements_found.append(f"Visibility hidden: {len(visibility_matches)}")
    
    # Elements with hidden attribute
    hidden_attr_pattern = r'<([^>\s]+)[^>]*\shidden[^>]*>([^<]*)'
    hidden_attr_matches = re.findall(hidden_attr_pattern, html_content, re.IGNORECASE)
    if hidden_attr_matches:
        print(f"[!] Found {len(hidden_attr_matches)} element(s) with hidden attribute")
        for i, (tag, content) in enumerate(hidden_attr_matches[:3], 1):
            print(f"  [{i}] Tag: <{tag}>, Content: {content[:50]}...")
        elements_found.append(f"Hidden attribute: {len(hidden_attr_matches)}")
    
    if not elements_found:
        print("[-] No hidden elements found")
    
    # 3. Search for HTML comments
    print(f"\n{'='*60}")
    print("HTML COMMENTS SEARCH:")
    print(f"{'='*60}")
    comment_pattern = r'<!--(.*?)-->'
    comments = re.findall(comment_pattern, html_content, re.DOTALL)
    sensitive_comments = []
    for i, comment in enumerate(comments, 1):
        comment = comment.strip()
        if len(comment) > 10:
            # Check for keywords
            keywords = ['password', 'secret', 'key', 'token', 'flag', 'admin', 'user', 'hidden']
            if any(keyword in comment.lower() for keyword in keywords):
                print(f"[!] Comment #{i} (sensitive): {comment[:80]}...")
                sensitive_comments.append(f"{i}: {comment[:50]}...")
    
    if sensitive_comments:
        print(f"[+] Found {len(sensitive_comments)} sensitive comment(s)")
    else:
        print("[-] No sensitive comments found (or comments are empty)")
    
    # 4. Search for Base64 encoded strings
    print(f"\n{'='*60}")
    print("BASE64 ENCODED STRINGS SEARCH:")
    print(f"{'='*60}")
    
    base64_pattern = r'(?:[A-Za-z0-9+/]{4}){3,}(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?'
    potential_b64 = re.findall(base64_pattern, html_content)
    
    decoded_strings = []
    for i, match in enumerate(potential_b64):
        if len(match) > 30:  # Longer strings only
            try:
                decoded = base64.b64decode(match).decode('utf-8', errors='ignore')
                if len(decoded) > 20:  # Only keep decoded content that's meaningful
                    decoded_strings.append(f"#{i}: {decoded[:80]}...")
                    print(f"[!] Base64 decoded #{i}: {decoded[:80]}...")
                    # Check decoded for flag
                    if re.search(flag_pattern, decoded):
                        print(f"    [!] FLAGS FOUND IN DECODED STRING!")
            except:
                continue
    
    if decoded_strings:
        print(f"[+] Successfully decoded {len(decoded_strings)} base64 string(s)")
    else:
        print("[-] No valid Base64 encoded strings found")
    
    # 5. Search for other encoding patterns
    print(f"\n{'='*60}")
    print("OTHER ENCODINGS:")
    print(f"{'='*60}")
    
    # URL encoding
    url_encoded = re.findall(r'%[0-9A-Fa-f]{2}', html_content)
    if len(url_encoded) > 10:
        print(f"[!] URL encoding detected ({len(url_encoded)} occurrences)")
    
    # Hex encoding
    hex_encoded = re.findall(r'\\x[0-9A-Fa-f]{2}', html_content)
    if len(hex_encoded) > 10:
        print(f"[!] Hex encoding detected ({len(hex_encoded)} occurrences)")
    
    # Unicode escape
    unicode_encoded = re.findall(r'\\u[0-9A-Fa-f]{4}', html_content)
    if len(unicode_encoded) > 10:
        print(f"[!] Unicode escape sequences detected ({len(unicode_encoded)} occurrences)")
    
    # 6. Print summary of all findings
    print(f"\n{'='*60}")
    print("SUMMARY:")
    print(f"{'='*60}")
    print(f"Response Status: {response.status_code}")
    print(f"Content Length: {len(html_content)} characters")
    print(f"FLAG Patterns: {len(flag_matches)} found")
    print(f"Hidden Elements: {len(elements_found)} types found")
    print(f"Sensitive Comments: {len(sensitive_comments)} found")
    print(f"Base64 Decoded: {len(decoded_strings)} valid strings")
    
    # If no flags found, suggest next steps
    if not flag_matches:
        print("\n["No FLAG found. Consider:")
        if response.status_code == 200:
            print("  - Check if more privileges are needed")
            print("  - Look at error messages or warnings")
            print("  - Check for JavaScript-rendered content")
        elif response.status_code == 403:
            print("  - Session may lack admin rights")
            print("  - Try different session/credentials")
        elif response.status_code == 302:
            print("  - Redirection suggests unauthorized access")
    
    print("\nFull search completed.")
    
except requests.exceptions.RequestException as e:
    print(f"[!] Request error: {e}")
except Exception as e:
    print(f"[!] Error: {e}")
