import requests, re, base64

url = "http://127.0.0.1/admin_panel"
cookies = {"session": "OHPI_Y1N0-W_1RYNCv342OsWzpNdIqQLP9zIlMlvedk"}

r = requests.get(url, cookies=cookies)
html = r.text

flags = set()

# Extract from comments
flags.update(re.findall(r'FLAG\{[^}]+\}', ''.join(re.findall(r'<!--.*?-->', html, re.DOTALL))))

# Extract from hidden fields
for field in re.findall(r'<input[^>]*type=["\']?hidden["\']?[^>]*>', html, re.I):
    if m := re.search(r'value=["\']?([^"\'\s]+)', field):
        flags.update(re.findall(r'FLAG\{[^}]+\}', m.group(1)))

# Extract from CSS hidden elements
hidden_elements = re.findall(r'<[^>]*style=["\']?[^>]*(?:display:none|visibility:hidden)[^>]*>(.*?)</[^>]*>', html, re.I|re.DOTALL)
flags.update(re.findall(r'FLAG\{[^}]+\}', ''.join(hidden_elements)))

# Extract from JavaScript
scripts = re.findall(r'<script[^>]*>(.*?)</script>', html, re.I|re.DOTALL)
flags.update(re.findall(r'FLAG\{[^}]+\}', ''.join(scripts)))

# Extract from meta tags
flags.update(re.findall(r'FLAG\{[^}]+\}', ''.join(re.findall(r'<meta[^>]*>', html, re.I))))

# Base64 decode
for b64 in set(re.findall(r'[A-Za-z0-9+/]{20,}={0,2}', html)):
    try:
        decoded = base64.b64decode(b64).decode('utf-8', errors='ignore')
        flags.update(re.findall(r'FLAG\{[^}]+\}', decoded))
    except: pass

# Final catch-all scan
flags.update(re.findall(r'FLAG\{[^}]+\}', html))

print(f"Status:{r.status_code}")
print(f"Found:{len(flags)}")
for flag in sorted(flags):
    print(f"FLAG:{flag}")
