import urllib.request, re, base64

try:
    # Create request with cookie
    req = urllib.request.Request("http://127.0.0.1/admin_panel")
    req.add_header('Cookie', 'session=OHPI_Y1N0-W_1RYNCv342OsWzpNdIqQLP9zIlMlvedk')
    
    # Get HTML content
    with urllib.request.urlopen(req) as response:
        html = response.read().decode('utf-8')
    
    flags = set()
    
    # Method 1: Comments
    for comment in re.findall(r'<!--(.*?)-->', html, re.DOTALL):
        flags.update(re.findall(r'FLAG\{[^}]+\}', comment))
    
    # Method 2: Hidden fields
    for field in re.findall(r'<input[^>]*type=["\']?hidden["\']?[^>]*>', html, re.I):
        if m := re.search(r'value=["\']?([^"\'\s]+)', field):
            flags.update(re.findall(r'FLAG\{[^}]+\}', m.group(1)))
    
    # Method 3: CSS hidden
    hidden = re.findall(r'<[^>]*style=["\']?[^>]*(?:display:none|visibility:hidden)[^>]*>(.*?)</[^>]*>', html, re.I|re.DOTALL)
    flags.update(re.findall(r'FLAG\{[^}]+\}', ''.join(hidden)))
    
    # Method 4: JavaScript
    scripts = re.findall(r'<script[^>]*>(.*?)</script>', html, re.I|re.DOTALL)
    flags.update(re.findall(r'FLAG\{[^}]+\}', ''.join(scripts)))
    
    # Method 5: Meta tags
    flags.update(re.findall(r'FLAG\{[^}]+\}', ''.join(re.findall(r'<meta[^>]*>', html, re.I))))
    
    # Method 6: Base64
    for b64 in set(re.findall(r'[A-Za-z0-9+/]{20,}={0,2}', html)):
        try:
            decoded = base64.b64decode(b64).decode('utf-8', errors='ignore')
            flags.update(re.findall(r'FLAG\{[^}]+\}', decoded))
        except: pass
    
    # Method 7: Direct scan
    flags.update(re.findall(r'FLAG\{[^}]+\}', html))
    
    print(f"Status:200")
    print(f"Found:{len(flags)}")
    for flag in sorted(flags):
        print(f"{flag}")
        
except Exception as e:
    print(f"Error:{str(e)}")

