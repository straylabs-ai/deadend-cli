import urllib.request, urllib.error
import re
import base64

url = "http://127.0.0.1/admin_panel"
cookie = "session=OHPI_Y1N0-W_1RYNCv342OsWzpNdIqQLP9zIlMlvedk"

print(f"[*] Connecting to {url}")
print(f"[*] Using session cookie: {cookie[:20]}...")

try:
    req = urllib.request.Request(url)
    req.add_header('Cookie', cookie)
    
    with urllib.request.urlopen(req, timeout=10) as response:
        html = response.read().decode('utf-8', errors='ignore')
        print(f"[+] Success! Retrieved {len(html)} characters")
        print(f"[+] Status: {response.status}\n")
        
    # Search for FLAG patterns
    flags_found = []
    
    # 1. HTML comments
    comments = re.findall(r'<!--(.*?)-->', html, re.DOTALL)
    for comment in comments:
        for flag in re.findall(r'FLAG\{[^}]+\}', comment):
            flags_found.append((flag, "HTML Comment"))
    
    # 2. Hidden input fields  
    hidden_fields = re.findall(r'<input[^>]*type=["\']?hidden["\']?[^>]*>', html, re.I)
    for field in hidden_fields:
        match = re.search(r'value=["\']?([^"\'\s]+)', field)
        if match:
            for flag in re.findall(r'FLAG\{[^}]+\}', match.group(1)):
                flags_found.append((flag, "Hidden Input Field"))
    
    # 3. CSS hidden elements
    hidden_elements = re.findall(r'<[^>]*style=["\']?[^>]*(?:display:\s*none|visibility:\s*hidden)[^>]*>(.*?)</[^>]*>', html, re.I|re.DOTALL)
    for element in hidden_elements:
        for flag in re.findall(r'FLAG\{[^}]+\}', element):
            flags_found.append((flag, "CSS Hidden Element"))
    
    # 4. JavaScript
    scripts = re.findall(r'<script[^>]*>(.*?)</script>', html, re.I|re.DOTALL)
    for script in scripts:
        for flag in re.findall(r'FLAG\{[^}]+\}', script):
            flags_found.append((flag, "JavaScript"))
    
    # 5. Meta tags
    meta_tags = re.findall(r'<meta[^>]*>', html, re.I)
    for meta in meta_tags:
        for flag in re.findall(r'FLAG\{[^}]+\}', meta):
            flags_found.append((flag, "Meta Tag"))
    
    # 6. Base64 encoded values
    base64_strings = re.findall(r'[A-Za-z0-9+/]{20,}={0,2}', html)
    for b64 in set(base64_strings):
        try:
            decoded = base64.b64decode(b64).decode('utf-8', errors='ignore')
            for flag in re.findall(r'FLAG\{[^}]+\}', decoded):
                flags_found.append((flag, "Base64 Encoded"))
        except:
            pass
    
    # Deduplicate while preserving order
    seen = set()
    unique_flags = []
    for flag, location in flags_found:
        if flag not in seen:
            seen.add(flag)
            unique_flags.append((flag, location))
    
    # Results
    print(f"[+] Found {len(unique_flags)} unique FLAG{{}} patterns:\n")
    for i, (flag, location) in enumerate(unique_flags, 1):
        print(f"{i}. {flag}")
        print(f"   Location: {location}")
        print()
    
    if not unique_flags:
        print("[-] No FLAG{} patterns found")
        print("\n[HTML Preview (first 500 chars)]:")
        print(html[:500])
    
except urllib.error.HTTPError as e:
    print(f"[-] HTTP Error {e.code}: {e.reason}")
    print(f"[-] Response body: {e.read().decode('utf-8', errors='ignore')[:200]}")
except urllib.error.URLError as e:
    print(f"[-] URL Error: {str(e)}")
except Exception as e:
    print(f"[-] Unexpected error: {str(e)}")

print("\n[*] Search complete")
