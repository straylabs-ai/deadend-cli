import requests
import json

# Target URL
url = "http://127.0.0.1:5003/add_url"

# Session cookie from context
cookies = {
    "session": "eyJfZnJlc2giOmZhbHNlfQ.aVpTCA.s-VGf6vmfbtBjEeQRdAqLSxxbxE"
}

# Form data to submit
data = {
    "url": "http://example.com"
}

try:
    # Send POST request
    response = requests.post(
        url,
        data=data,
        cookies=cookies,
        allow_redirects=False
    )
    
    # Print detailed response information
    print(f"[+] POST {url}")
    print(f"[+] Form Data: {data}")
    print(f"\n[+] Status Code: {response.status_code}")
    print(f"[+] Response Time: {response.elapsed.total_seconds()}s")
    
    print(f"\n[+] Response Headers:")
    for header, value in response.headers.items():
        print(f"  {header}: {value}")
    
    if response.cookies:
        print(f"\n[+] Response Cookies:")
        for cookie_name, cookie_value in response.cookies.items():
            print(f"  {cookie_name}: {cookie_value}")
    
    print(f"\n[+] Response Body:")
    print(response.text)
    
    # Analyze validation behavior
    print(f"\n[+] Analysis:")
    print(f"  - Content-Type: {response.headers.get('Content-Type', 'Not specified')}")
    print(f"  - Content-Length: {len(response.content)} bytes")
    
    # Check for validation indicators in response
    if "success" in response.text.lower():
        print(f"  - Response indicates SUCCESS")
    if "error" in response.text.lower():
        print(f"  - Response indicates ERROR")
    if "added" in response.text.lower():
        print(f"  - Response indicates URL was ADDED")
    if "invalid" in response.text.lower():
        print(f"  - Response indicates INVALID input")
    if "200" in response.text:
        print(f"  - Response mentions status code 200 (validation check)")
    if "status" in response.text.lower():
        print(f"  - Response mentions 'status' (possible validation)")
    
    # Check if redirected
    if response.status_code in [301, 302, 303, 307, 308]:
        print(f"  - REDIRECT detected to: {response.headers.get('Location', 'unknown')}")

except requests.exceptions.RequestException as e:
    print(f"[!] Request failed: {e}")
except Exception as e:
    print(f"[!] Unexpected error: {e}")

