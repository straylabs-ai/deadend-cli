import requests

# Target URL
url = "http://127.0.0.1:5003/add_url"

# Session cookie
cookies = {
    "session": "eyJfZnJlc2giOmZhbHNlfQ.aVpTCA.s-VGf6vmfbtBjEeQRdAqLSxxbxE"
}

# Form data
data = {
    "url": "http://example.com"
}

# Send POST request
response = requests.post(url, data=data, cookies=cookies, allow_redirects=False)

# Print results
print(f"[+] POST {url}")
print(f"[+] Data: {data}")
print(f"\n[+] Status: {response.status_code}")
print(f"[+] Headers: {dict(response.headers)}")
print(f"\n[+] Response Body:")
print(response.text)

# Analysis
print("\n[+] Validation Analysis:")
body_lower = response.text.lower()
if "200" in response.text:
    print("  - Mentions status code 200")
if "success" in body_lower or "added" in body_lower:
    print("  - Indicates success/added")
if "error" in body_lower or "invalid" in body_lower or "failed" in body_lower:
    print("  - Indicates error/invalid/failed")

