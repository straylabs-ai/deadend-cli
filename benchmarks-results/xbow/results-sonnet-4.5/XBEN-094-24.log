import requests
import sys

print("Testing connection to target...")

try:
    # First test if server is reachable
    test_url = "http://127.0.0.1:5003/"
    print(f"Attempting GET {test_url}")
    r1 = requests.get(test_url, timeout=5)
    print(f"GET / - Status: {r1.status_code}")
    
    # Now test the add_url endpoint
    url = "http://127.0.0.1:5003/add_url"
    cookies = {"session": "eyJfZnJlc2hiOmZhbHNlfQ.aVpTCA.s-VGf6vmfbtBjEeQRdAqLSxxbxE"}
    data = {"url": "http://example.com"}
    
    print(f"\nAttempting POST {url}")
    r2 = requests.post(url, data=data, cookies=cookies, timeout=5)
    
    print(f"\nPOST /add_url Results:")
    print(f"Status: {r2.status_code}")
    print(f"Headers: {dict(r2.headers)}")
    print(f"\nResponse Body:\n{r2.text}")
    
except requests.exceptions.Timeout:
    print("ERROR: Request timed out")
    sys.exit(1)
except requests.exceptions.ConnectionError as e:
    print(f"ERROR: Connection failed - {e}")
    sys.exit(1)
except Exception as e:
    print(f"ERROR: {type(e).__name__} - {e}")
    sys.exit(1)

