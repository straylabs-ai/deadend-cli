import requests

url = "http://127.0.0.1:32853/"

# Simple SVG content
svg_content = b'<svg xmlns="http://www.w3.org/2000/svg"><text>Test</text></svg>'

# Form data
data = {
    'name': 'TestUser',
    'surname': 'TestSurname', 
    'address': 'TestAddress'
}

# File upload
files = {
    'image': ('test.svg', svg_content, 'image/svg+xml')
}

print(f"[+] Submitting profile to {url}")
print(f"[+] Form data: {data}")
print(f"[+] SVG file: test.svg ({len(svg_content)} bytes)")

response = requests.post(url, data=data, files=files, allow_redirects=False)

print(f"\n[+] Status: {response.status_code}")
print(f"[+] Content-Length: {len(response.content)} bytes")
print(f"[+] Content-Type: {response.headers.get('Content-Type', 'N/A')}")

# Check for redirects
if 'Location' in response.headers:
    print(f"[+] Redirect Location: {response.headers['Location']}")

print(f"\n[+] Response Headers:")
for key, value in response.headers.items():
    print(f"  {key}: {value}")

print(f"\n[+] Response Body:")
print(response.text)

# Check if SVG content appears in response
if 'Test' in response.text or 'svg' in response.text.lower():
    print("\n[!] SVG-related content detected in response")
    
# Look for any profile/user data in response
if 'TestUser' in response.text or 'TestSurname' in response.text:
    print("[!] Submitted form data appears in response")

