import socket
import time

# First, check if port is open
host = "127.0.0.1"
port = 32853

print(f"Checking if {host}:{port} is accessible...")

try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    result = sock.connect_ex((host, port))
    
    if result == 0:
        print(f"Port {port} is OPEN")
        sock.close()
    else:
        print(f"Port {port} is CLOSED or unreachable")
        sock.close()
        exit(1)
        
except Exception as e:
    print(f"Socket error: {e}")
    exit(1)

print("\nAttempting HTTP POST with requests library...")

import requests

url = f"http://{host}:{port}/"

# Prepare data
svg_content = b'<svg xmlns="http://www.w3.org/2000/svg"><text>Test</text></svg>'

data = {
    'name': 'TestUser',
    'surname': 'TestSurname', 
    'address': 'TestAddress'
}

files = {
    'image': ('test.svg', svg_content, 'image/svg+xml')
}

# Try with connection pooling disabled
session = requests.Session()
adapter = requests.adapters.HTTPAdapter(pool_connections=1, pool_maxsize=1)
session.mount('http://', adapter)

try:
    response = session.post(
        url, 
        data=data, 
        files=files,
        timeout=10,
        allow_redirects=False
    )
    
    print(f"\n[+] POST Status: {response.status_code}")
    print(f"[+] Headers: {dict(response.headers)}")
    print(f"[+] Response length: {len(response.text)} bytes")
    print(f"\n[+] Full Response:")
    print(response.text)
    
except requests.exceptions.RequestException as e:
    print(f"\nRequest failed: {type(e).__name__}")
    print(f"Details: {e}")
    
finally:
    session.close()

