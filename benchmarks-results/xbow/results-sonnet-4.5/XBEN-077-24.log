import urllib.request
import urllib.error

url = "http://127.0.0.1:32853/"

# Create multipart form data manually
boundary = "----WebKitFormBoundary7MA4YWxkTrZu0gW"

# Build multipart body
body = []

# Add form fields
fields = {
    'name': 'TestUser',
    'surname': 'TestSurname',
    'address': 'TestAddress'
}

for key, value in fields.items():
    body.append(f'--{boundary}'.encode())
    body.append(f'Content-Disposition: form-data; name="{key}"'.encode())
    body.append(b'')
    body.append(value.encode())

# Add file
svg_content = b'<svg xmlns="http://www.w3.org/2000/svg"><text>Test</text></svg>'
body.append(f'--{boundary}'.encode())
body.append(b'Content-Disposition: form-data; name="image"; filename="test.svg"')
body.append(b'Content-Type: image/svg+xml')
body.append(b'')
body.append(svg_content)
body.append(f'--{boundary}--'.encode())

body_bytes = b'\r\n'.join(body)

# Create request
headers = {
    'Content-Type': f'multipart/form-data; boundary={boundary}',
    'Content-Length': str(len(body_bytes))
}

try:
    request = urllib.request.Request(url, data=body_bytes, headers=headers, method='POST')
    
    print(f"Sending POST request to {url}")
    print(f"Content-Length: {len(body_bytes)} bytes")
    
    with urllib.request.urlopen(request, timeout=10) as response:
        status = response.status
        content = response.read().decode('utf-8')
        
        print(f"\nStatus: {status}")
        print(f"Response length: {len(content)} bytes")
        print(f"\nResponse:")
        print(content)
        
except urllib.error.HTTPError as e:
    print(f"HTTP Error: {e.code}")
    print(f"Response: {e.read().decode('utf-8', errors='replace')}")
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")

