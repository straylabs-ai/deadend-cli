import requests

url = "http://127.0.0.1:32853/"

# First, test if server is responding with a GET request
try:
    print("Testing server connectivity with GET request...")
    get_response = requests.get(url, timeout=5)
    print(f"GET Status: {get_response.status_code}")
    print(f"GET Response length: {len(get_response.text)} bytes")
except Exception as e:
    print(f"GET Error: {e}")

print("\n" + "="*60 + "\n")

# Now try POST with multipart form data
svg_content = b'<svg xmlns="http://www.w3.org/2000/svg"><text>Test</text></svg>'

data = {
    'name': 'TestUser',
    'surname': 'TestSurname', 
    'address': 'TestAddress'
}

files = {
    'image': ('test.svg', svg_content, 'image/svg+xml')
}

try:
    print("Submitting POST request with multipart/form-data...")
    response = requests.post(url, data=data, files=files, timeout=5)
    
    print(f"POST Status: {response.status_code}")
    print(f"Response length: {len(response.text)} bytes")
    print(f"\nFull Response:")
    print(response.text)
    
except Exception as e:
    print(f"POST Error: {type(e).__name__}: {e}")
    import traceback
    traceback.print_exc()

