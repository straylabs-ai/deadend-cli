import socket

# Minimal HTTP POST test
host = "127.0.0.1"
port = 32853

print(f"Attempting raw HTTP POST to {host}:{port}")

# Create socket
sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
sock.settimeout(10)

try:
    # Connect
    print("Connecting...")
    sock.connect((host, port))
    print("Connected successfully")
    
    # Prepare minimal HTTP POST
    boundary = "------------------------1234567890"
    
    body_parts = []
    
    # Add form fields
    for field, value in [('name', 'TestUser'), ('surname', 'TestSurname'), ('address', 'TestAddress')]:
        body_parts.append(f'--{boundary}\r\n')
        body_parts.append(f'Content-Disposition: form-data; name="{field}"\r\n\r\n')
        body_parts.append(f'{value}\r\n')
    
    # Add SVG file
    svg_content = '<svg xmlns="http://www.w3.org/2000/svg"><text>Test</text></svg>'
    body_parts.append(f'--{boundary}\r\n')
    body_parts.append('Content-Disposition: form-data; name="image"; filename="test.svg"\r\n')
    body_parts.append('Content-Type: image/svg+xml\r\n\r\n')
    body_parts.append(f'{svg_content}\r\n')
    body_parts.append(f'--{boundary}--\r\n')
    
    body = ''.join(body_parts)
    body_bytes = body.encode('utf-8')
    
    # Build HTTP request
    request = f'POST / HTTP/1.1\r\n'
    request += f'Host: {host}:{port}\r\n'
    request += f'Content-Type: multipart/form-data; boundary={boundary}\r\n'
    request += f'Content-Length: {len(body_bytes)}\r\n'
    request += 'Connection: close\r\n'
    request += '\r\n'
    
    # Send request
    print("Sending HTTP request...")
    sock.sendall(request.encode('utf-8'))
    sock.sendall(body_bytes)
    
    # Receive response
    print("Receiving response...")
    response = b''
    while True:
        chunk = sock.recv(4096)
        if not chunk:
            break
        response += chunk
    
    response_text = response.decode('utf-8', errors='replace')
    
    print("\n" + "="*60)
    print("RESPONSE:")
    print("="*60)
    print(response_text)
    
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")
    import traceback
    traceback.print_exc()
    
finally:
    sock.close()

