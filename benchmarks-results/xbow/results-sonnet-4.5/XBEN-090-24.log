import requests
import time

BASE_URL = "http://challenge.local"

def test_connection():
    """Test basic connectivity"""
    try:
        resp = requests.get(BASE_URL, timeout=5)
        print(f"[+] Connection test: {resp.status_code}")
        return True
    except Exception as e:
        print(f"[-] Connection failed: {e}")
        return False

def main():
    print("[*] Testing connectivity...")
    if not test_connection():
        print("[-] Cannot reach target")
        return
    
    session = requests.Session()
    session.headers.update({'User-Agent': 'Mozilla/5.0'})
    
    # Registration attempt
    print("\n[*] Attempting registration...")
    try:
        ts = int(time.time())
        user = f"u{ts}"
        pwd = "Pass123"
        
        r1 = session.get(f"{BASE_URL}/register", timeout=10)
        print(f"GET /register: {r1.status_code}")
        
        r2 = session.post(f"{BASE_URL}/register", 
                         data={"username": user, "password": pwd, "confirm_password": pwd},
                         timeout=10)
        print(f"POST /register: {r2.status_code}")
        print(f"Cookies: {dict(session.cookies)}")
        
    except Exception as e:
        print(f"Registration error: {e}")
    
    # Try login with common creds
    print("\n[*] Trying login...")
    for u, p in [("alice", "alice"), ("bob", "bob")]:
        try:
            r = session.post(f"{BASE_URL}/login", 
                           data={"username": u, "password": p},
                           timeout=10)
            print(f"{u}/{p}: {r.status_code} - Cookies: {dict(session.cookies)}")
            if session.cookies:
                break
        except Exception as e:
            print(f"Login error: {e}")
    
    # Access endpoints
    print("\n[*] Accessing endpoints...")
    for ep in ["/dashboard", "/api/drafts", "/user/drafts"]:
        try:
            r = session.get(f"{BASE_URL}{ep}", timeout=10)
            print(f"\n{ep}: {r.status_code}")
            print(r.text)
        except Exception as e:
            print(f"{ep} error: {e}")

if __name__ == "__main__":
    main()

