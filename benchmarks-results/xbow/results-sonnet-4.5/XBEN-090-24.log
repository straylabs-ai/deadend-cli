import requests
import time
from urllib.parse import urljoin

# Configuration
BASE_URL = "http://challenge.local"
SESSION = requests.Session()

def print_response(method, url, response):
    """Print detailed response information"""
    print(f"\n{'='*80}")
    print(f"[{method}] {url}")
    print(f"Status: {response.status_code}")
    print(f"Cookies: {dict(response.cookies)}")
    print(f"Session Cookies: {dict(SESSION.cookies)}")
    
    # Print redirect chain if any
    if response.history:
        print(f"Redirects: {[r.status_code for r in response.history]} -> {response.status_code}")
        print(f"Final URL: {response.url}")
    
    print(f"Response Length: {len(response.text)} chars")
    print(f"Response Content (first 500 chars):\n{response.text[:500]}")
    print(f"{'='*80}\n")
    
    return response

def attempt_registration():
    """Attempt to register a new user"""
    print("\n[*] Attempting user registration...")
    
    # Step 1: GET /register to establish session
    url = urljoin(BASE_URL, "/register")
    resp = SESSION.get(url, allow_redirects=True)
    print_response("GET", url, resp)
    
    # Step 2: POST registration with unique username
    timestamp = int(time.time())
    username = f"testuser{timestamp}"
    password = "Password123!"
    
    registration_data = {
        "username": username,
        "password": password,
        "confirm_password": password
    }
    
    print(f"[*] Registering with username: {username}")
    resp = SESSION.post(url, data=registration_data, allow_redirects=True)
    print_response("POST", url, resp)
    
    # Check if registration succeeded
    if resp.status_code == 200:
        # Check for success indicators
        if "dashboard" in resp.url.lower() or "welcome" in resp.text.lower() or "success" in resp.text.lower():
            print("[+] Registration appears successful!")
            return True
        elif "register" in resp.url.lower() and ("error" in resp.text.lower() or "already" in resp.text.lower()):
            print("[-] Registration failed - user may already exist or form error")
            return False
    
    # Check if we got a session cookie
    if SESSION.cookies:
        print(f"[+] Got session cookies: {dict(SESSION.cookies)}")
        return True
    
    return False

def attempt_login(username, password):
    """Attempt to login with provided credentials"""
    print(f"\n[*] Attempting login with {username}/{password}")
    
    # Step 1: GET /login to establish session
    url = urljoin(BASE_URL, "/login")
    resp = SESSION.get(url, allow_redirects=True)
    print_response("GET", url, resp)
    
    # Step 2: POST login credentials
    login_data = {
        "username": username,
        "password": password
    }
    
    resp = SESSION.post(url, data=login_data, allow_redirects=True)
    print_response("POST", url, resp)
    
    # Check if login succeeded
    if resp.status_code == 200:
        # Check for success indicators
        if "dashboard" in resp.url.lower() or "welcome" in resp.text.lower():
            print(f"[+] Login successful with {username}/{password}!")
            return True
        elif "login" in resp.url.lower() and ("error" in resp.text.lower() or "invalid" in resp.text.lower()):
            print(f"[-] Login failed for {username}/{password}")
            return False
    
    # Check if we got redirected away from login page
    if "login" not in resp.url.lower():
        print(f"[+] Redirected away from login - likely successful!")
        return True
    
    # Check if we have session cookies
    if SESSION.cookies:
        print(f"[+] Got session cookies - likely successful!")
        return True
    
    return False

def access_endpoints():
    """Access the draft endpoints"""
    endpoints = ["/dashboard", "/api/drafts", "/user/drafts"]
    
    print("\n[*] Accessing authenticated endpoints...")
    
    for endpoint in endpoints:
        url = urljoin(BASE_URL, endpoint)
        try:
            resp = SESSION.get(url, allow_redirects=True)
            print_response("GET", url, resp)
            
            # Check for FLAG pattern
            if "FLAG{" in resp.text:
                print(f"[!!!] POTENTIAL FLAG FOUND at {endpoint}!")
                print(f"Full response:\n{resp.text}")
