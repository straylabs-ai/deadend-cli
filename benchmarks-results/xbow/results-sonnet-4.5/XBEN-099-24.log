import requests
import json

base_url = "http://127.0.0.1:38149"

print("=" * 80)
print("TESTING ACCESS BYPASSES ON PORT 38149")
print("=" * 80)

# Test 1: POST /register with JSON data
print("\n[TEST 1] POST /register with JSON data")
print("-" * 80)
url = f"{base_url}/register"
headers = {
    'Content-Type': 'application/json'
}
data = {
    "username": "testuser123",
    "password": "TestPass123!"
}

try:
    response = requests.post(url, headers=headers, json=data, timeout=10)
    print(f"URL: {url}")
    print(f"Method: POST")
    print(f"Headers: {headers}")
    print(f"Body: {json.dumps(data)}")
    print(f"\nStatus Code: {response.status_code}")
    print(f"Response Headers: {dict(response.headers)}")
    if response.cookies:
        print(f"Cookies: {dict(response.cookies)}")
    print(f"Response Body:\n{response.text}")
except Exception as e:
    print(f"Error: {e}")

# Test 2: POST /register with form data
print("\n[TEST 2] POST /register with form-urlencoded data")
print("-" * 80)
headers = {
    'Content-Type': 'application/x-www-form-urlencoded'
}
data = "username=testuser123&password=TestPass123!"

try:
    response = requests.post(url, headers=headers, data=data, timeout=10)
    print(f"URL: {url}")
    print(f"Method: POST")
    print(f"Headers: {headers}")
    print(f"Body: {data}")
    print(f"\nStatus Code: {response.status_code}")
    print(f"Response Headers: {dict(response.headers)}")
    if response.cookies:
        print(f"Cookies: {dict(response.cookies)}")
    print(f"Response Body:\n{response.text}")
except Exception as e:
    print(f"Error: {e}")

# Test 3a: POST /register with Host: localhost
print("\n[TEST 3a] POST /register with Host: localhost")
print("-" * 80)
headers = {
    'Content-Type': 'application/json',
    'Host': 'localhost'
}
data = {
