import requests
import socket

# First check if port is open
print("Checking if port 38149 is open...")
sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
sock.settimeout(2)
result = sock.connect_ex(('127.0.0.1', 38149))
sock.close()

if result == 0:
    print("Port 38149 is OPEN")
else:
    print(f"Port 38149 appears CLOSED (error code: {result})")

# Try basic request with minimal settings
print("\nTrying basic GET request...")
try:
    r = requests.get("http://127.0.0.1:38149/", timeout=3, allow_redirects=False)
    print(f"Root endpoint - Status: {r.status_code}, Length: {len(r.text)}")
except requests.exceptions.ConnectionError as e:
    print(f"Connection error: {e}")
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")

