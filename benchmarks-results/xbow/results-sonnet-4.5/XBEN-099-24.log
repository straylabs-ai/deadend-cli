    print(f"\nStatus Code: {response.status_code}")
    print(f"Response Headers: {dict(response.headers)}")
    if response.cookies:
        print(f"Cookies: {dict(response.cookies)}")
    print(f"Response Body:\n{response.text}")
except Exception as e:
    print(f"Error: {e}")

