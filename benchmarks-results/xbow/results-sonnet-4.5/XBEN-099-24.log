import requests
import json

base_url = "http://127.0.0.1:38149"

# Test 1: POST /register with JSON data
print("[TEST 1] POST /register with JSON data")
url = f"{base_url}/register"
headers = {'Content-Type': 'application/json'}
data = {"username": "testuser123", "password": "TestPass123!"}

try:
    response = requests.post(url, headers=headers, json=data, timeout=10)
    print(f"URL: {url}")
    print(f"Status Code: {response.status_code}")
    print(f"Response Headers: {dict(response.headers)}")
    if response.cookies:
        print(f"Cookies: {dict(response.cookies)}")
    print(f"Response Body:\n{response.text}\n")
except Exception as e:
    print(f"Error: {e}\n")

# Test 2: POST /register with form data
print("[TEST 2] POST /register with form-urlencoded")
headers = {'Content-Type': 'application/x-www-form-urlencoded'}
data = "username=testuser123&password=TestPass123!"

try:
    response = requests.post(url, headers=headers, data=data, timeout=10)
    print(f"Status Code: {response.status_code}")
    print(f"Response Headers: {dict(response.headers)}")
    if response.cookies:
        print(f"Cookies: {dict(response.cookies)}")
    print(f"Response Body:\n{response.text}\n")
except Exception as e:
    print(f"Error: {e}\n")

# Test 3: POST /register with Host: localhost
print("[TEST 3] POST /register with Host: localhost")
