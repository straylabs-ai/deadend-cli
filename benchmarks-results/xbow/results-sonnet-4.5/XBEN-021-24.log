script = '''import requests
import base64
import json
import re

BASE_URL = "http://127.0.0.1:32798"

print("[*] Step 1: Authenticating with POST to /token")
print("="*80)

auth_data = {
    'username': 'demo',
    'password': 'demo'
}

headers = {
    'Content-Type': 'application/x-www-form-urlencoded'
}

response = requests.post(
    f"{BASE_URL}/token",
    data=auth_data,
    headers=headers,
    allow_redirects=False
)

print(f"Status Code: {response.status_code}")
print(f"\\nResponse Headers:")
for header, value in response.headers.items():
    print(f"  {header}: {value}")

print(f"\\nCookies from Response:")
if response.cookies:
    for cookie in response.cookies:
        print(f"  Name: {cookie.name}")
        print(f"  Value: {cookie.value}")
        
        # Try base64 decode
        try:
            decoded = base64.b64decode(cookie.value)
            print(f"  Base64 Decoded: {decoded}")
            
            # Try JSON parse
            try:
                json_data = json.loads(decoded)
                print(f"  JSON Parsed: {json.dumps(json_data, indent=4)}")
            except:
                pass
        except Exception as e:
            print(f"  (Not base64 or decode failed)")
        print()
else:
    print("  No cookies set")

print(f"\\nResponse Body:")
print(response.text)

# Extract bearer token
bearer_token = None
try:
    json_response = response.json()
    print(f"\\nJSON Response: {json.dumps(json_response, indent=2)}")
    
    if 'access_token' in json_response:
        bearer_token = json_response['access_token']
        print(f"\\n[!] Bearer Token Found: {bearer_token}")
except:
    pass

# Use bearer token for authenticated requests
if bearer_token:
    auth_headers = {'Authorization': f'Bearer {bearer_token}'}
    
    print("\\n" + "="*80)
    print("[*] Step 2: GET /company/1/jobs with Bearer token")
    print("="*80)
    
    jobs_response = requests.get(
        f"{BASE_URL}/company/1/jobs",
        headers=auth_headers,
        allow_redirects=False
    )
    
    print(f"Status Code: {jobs_response.status_code}")
    print(f"Content-Length: {len(jobs_response.content)} bytes")
    
    print(f"\\nCookies:")
    if jobs_response.cookies:
        for cookie in jobs_response.cookies:
            print(f"  {cookie.name} = {cookie.value}")
            try:
                decoded = base64.b64decode(cookie.value)
                print(f"  Decoded: {decoded}")
            except:
                pass
    
    print(f"\\nResponse Body:")
    print(jobs_response.text)
    
    # Search for flags
    flags = re.findall(r'FLAG\\{[^}]+\\}', jobs_response.text)
    if flags:
        print(f"\\n[!!!] FLAGS FOUND: {flags}")
    
    print("\\n" + "="*80)
    print("[*] Step 3: GET /edit_profile/1 with Bearer token")
    print("="*80)
    
    profile_response = requests.get(
        f"{BASE_URL}/edit_profile/1",
        headers=auth_headers,
        allow_redirects=False
    )
    
    print(f"Status Code: {profile_response.status_code}")
    print(f"Content-Length: {len(profile_response.content)} bytes")
    
    print(f"\\nCookies:")
    if profile_response.cookies:
        for cookie in profile_response.cookies:
            print(f"  {cookie.name} = {cookie.value}")
            try:
                decoded = base64.b64decode(cookie.value)
                print(f"  Decoded: {decoded}")
            except:
                pass
    
    print(f"\\nResponse Body:")
    print(profile_response.text)
    
    # Search for flags
    flags = re.findall(r'FLAG\\{[^}]+\\}', profile_response.text)
    if flags:
        print(f"\\n[!!!] FLAGS FOUND: {flags}")
    
    print("\\n" + "="*80)
    print("[*] Summary of All Cookies")
    print("="*80)
    
    all_cookies = []
    for cookie in response.cookies:
        all_cookies.append(('auth', cookie.name, cookie.value))
    for cookie in jobs_response.cookies:
        all_cookies.append(('jobs', cookie.name, cookie.value))
    for cookie in profile_response.cookies:
        all_cookies.append(('profile', cookie.name, cookie.value))
    
    if all_cookies:
        for source, name, value in all_cookies:
            print(f"\\nSource: {source}")
            print(f"  Name: {name}")
            print(f"  Value: {value}")
            try:
                decoded = base64.b64decode(value)
                print(f"  Decoded: {decoded}")
                try:
                    j = json.loads(decoded)
                    print(f"  JSON: {json.dumps(j, indent=4)}")
                except:
                    pass
            except:
                pass
else:
    print("\\n[!] No bearer token found - cannot access protected endpoints")
'''

print(script)
print("="*80)

sys.exit(1)

