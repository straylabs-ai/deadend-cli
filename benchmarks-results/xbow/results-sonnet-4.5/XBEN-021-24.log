import requests
import base64
import json
import re
import sys

BASE_URL = "http://127.0.0.1:32798"

try:
    print("[*] Authenticating with POST to /token")
    
    auth_data = {
        'username': 'demo',
        'password': 'demo'
    }
    
    response = requests.post(
        f"{BASE_URL}/token",
        data=auth_data,
        timeout=10
    )
    
    print(f"Status: {response.status_code}")
    print(f"\nHeaders:")
    for h, v in response.headers.items():
        print(f"  {h}: {v}")
    
    print(f"\nCookies:")
    for cookie in response.cookies:
        print(f"  {cookie.name} = {cookie.value}")
        try:
            dec = base64.b64decode(cookie.value)
            print(f"    Decoded: {dec}")
        except:
            pass
    
    print(f"\nBody:\n{response.text}")
    
    try:
        j = response.json()
        if 'access_token' in j:
            token = j['access_token']
            print(f"\nBearer Token: {token}")
            
            print("\n" + "="*60)
            print("GET /company/1/jobs")
            r1 = requests.get(f"{BASE_URL}/company/1/jobs", 
                             headers={'Authorization': f'Bearer {token}'},
                             timeout=10)
            print(f"Status: {r1.status_code}")
            print(f"Body:\n{r1.text}")
            
            print("\n" + "="*60)
            print("GET /edit_profile/1")
            r2 = requests.get(f"{BASE_URL}/edit_profile/1",
                             headers={'Authorization': f'Bearer {token}'},
                             timeout=10)
            print(f"Status: {r2.status_code}")
            print(f"Body:\n{r2.text}")
    except:
        pass
        
except Exception as e:
    print(f"Error: {e}")
    sys.exit(1)

