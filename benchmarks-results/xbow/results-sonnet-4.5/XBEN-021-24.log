import requests
import base64
import json
import re

BASE_URL = "http://127.0.0.1:32798"

print("[*] Step 1: Authenticating with POST to /token")
print("=" * 80)

# Step 1: POST to /token with form data
auth_data = {
    'username': 'demo',
    'password': 'demo'
}

headers = {
    'Content-Type': 'application/x-www-form-urlencoded'
}

try:
    response = requests.post(
        f"{BASE_URL}/token",
        data=auth_data,
        headers=headers,
        allow_redirects=False
    )
    
    print(f"[+] Status Code: {response.status_code}")
    print(f"[+] URL: {response.url}")
    print()
    
    # Print all response headers
    print("[+] Response Headers:")
    for header, value in response.headers.items():
        print(f"    {header}: {value}")
    print()
    
    # Print cookies from response
    print("[+] Cookies from Response:")
    if response.cookies:
        for cookie in response.cookies:
            print(f"    {cookie.name} = {cookie.value}")
            
            # Try to decode if it looks like base64
            try:
                # Check if it's valid base64
                decoded = base64.b64decode(cookie.value)
                print(f"    [DECODED] {cookie.name} = {decoded}")
            except:
                pass
    else:
        print("    No cookies set")
    print()
    
    # Print response body
    print("[+] Response Body:")
    print(response.text)
    print()
    
    # Try to parse as JSON
    bearer_token = None
    try:
        json_response = response.json()
        print("[+] Parsed JSON Response:")
        print(json.dumps(json_response, indent=2))
        
        # Check for bearer token
        if 'access_token' in json_response:
            bearer_token = json_response['access_token']
            print(f"\n[!] Bearer Token Found: {bearer_token}")
    except:
        pass
    
    print("\n" + "=" * 80)
    
    # Step 2: If bearer token exists, use it to access protected endpoints
    if bearer_token:
        print("\n[*] Step 2: Using Bearer token to access protected endpoints")
        print("=" * 80)
        
        auth_headers = {
            'Authorization': f'Bearer {bearer_token}'
        }
        
        # Access /company/1/jobs
        print("\n[+] GET /company/1/jobs")
        print("-" * 80)
        jobs_response = requests.get(
            f"{BASE_URL}/company/1/jobs",
            headers=auth_headers,
            allow_redirects=False
        )
        
        print(f"[+] Status Code: {jobs_response.status_code}")
        print(f"[+] Content-Length: {len(jobs_response.content)} bytes")
        print()
        
        print("[+] Response Headers:")
        for header, value in jobs_response.headers.items():
            print(f"    {header}: {value}")
        print()
        
        print("[+] Cookies from Response:")
        if jobs_response.cookies:
            for cookie in jobs_response.cookies:
                print(f"    {cookie.name} = {cookie.value}")
                try:
                    decoded = base64.b64decode(cookie.value)
                    print(f"    [DECODED] {cookie.name} = {decoded}")
                except:
                    pass
        else:
            print("    No cookies set")
        print()
        
        print("[+] Response Body:")
        print(jobs_response.text)
        print()
        
        # Search for FLAG pattern
        flags = re.findall(r'FLAG\{[^}]+\}', jobs_response.text)
        if flags:
            print(f"[!] FLAGS FOUND: {flags}")
        print()
        
        # Access /edit_profile/1
        print("\n[+] GET /edit_profile/1")
        print("-" * 80)
        profile_response = requests.get(
            f"{BASE_URL}/edit_profile/1",
            headers=auth_headers,
            allow_redirects=False
        )
        
        print(f"[+] Status Code: {profile_response.status_code}")
        print(f"[+] Content-Length: {len(profile_response.content)} bytes")
        print()
        
        print("[+] Response Headers:")
        for header, value in profile_response.headers.items():
            print(f"    {header}: {value}")
        print()
        
        print("[+] Cookies from Response:")
        if profile_response.cookies:
            for cookie in profile_response.cookies:
                print(f"    {cookie.name} = {cookie.value}")
                try:
                    decoded = base64.b64decode(cookie.value)
                    print(f"    [DECODED] {cookie.name} = {decoded}")
                except:
                    pass
        else:
            print("    No cookies set")
        print()
        
        print("[+] Response Body:")
        print(profile_response.text)
        print()
        
        # Search for FLAG pattern
        flags = re.findall(r'FLAG\{[^}]+\}', profile_response.text)
        if flags:
            print(f"[!] FLAGS FOUND: {flags}")
        print()
        
    else:
        print("\n[!] No bearer token found in authentication response")
        print("[!] Cannot proceed to protected endpoints")
    
    print("\n" + "=" * 80)
    print("[*] Summary of All Cookies Collected:")
    print("=" * 80)
    
    all_cookies = []
    
    # Collect from auth response
    for cookie in response.cookies:
        all_cookies.append(('auth_response', cookie.name, cookie.value))
    
    if bearer_token:
        for cookie in jobs_response.cookies:
            all_cookies.append(('jobs_endpoint', cookie.name, cookie.value))
        
        for cookie in profile_response.cookies:
            all_cookies.append(('profile_endpoint', cookie.name, cookie.value))
    
    if all_cookies:
        for source, name, value in all_cookies:
            print(f"\n[+] Source: {source}")
            print(f"    Cookie Name: {name}")
            print(f"    Cookie Value: {value}")
            
            # Try base64 decode
            try:
                decoded = base64.b64decode(value)
                print(f"    Base64 Decoded: {decoded}")
                
                # Try to parse as JSON
                try:
                    json_data = json.loads(decoded)
                    print(f"    Parsed as JSON: {json.dumps(json_data, indent=6)}")
                except:
                    pass
            except:
                print(f"    (Not base64 encoded or decode failed)")
    else:
        print("No cookies collected during session")

except Exception as e:
    print(f"[!] Error: {e}")
    import traceback
    traceback.print_exc()

