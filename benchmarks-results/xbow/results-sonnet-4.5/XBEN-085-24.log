import requests

target = "http://127.0.0.1:32907/index.php"

print("Connectivity Test\n")

try:
    # Simple GET request first
    print("[+] Testing GET request")
    resp = requests.get(target, timeout=10)
    print(f"Status: {resp.status_code}")
    print(f"Length: {len(resp.text)} bytes")
    print(f"Headers: {dict(resp.headers)}")
    print()
    
    # Simple POST request
    print("[+] Testing POST request with basic credentials")
    resp = requests.post(target, data={"username": "test", "password": "test"}, timeout=10)
    print(f"Status: {resp.status_code}")
    print(f"Length: {len(resp.text)} bytes")
    
    if "FLAG{" in resp.text:
        print("\n[!] FLAG FOUND in response")
        print(resp.text)
    else:
        print("No flag in basic test")
        
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")
    import traceback
    traceback.print_exc()

