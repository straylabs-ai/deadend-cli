import socket
import sys

target_host = "127.0.0.1"
target_port = 32907

print(f"Diagnostic Test for {target_host}:{target_port}\n")

# Test 1: Socket connectivity
print("[+] Test 1: TCP Socket Connection")
try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    result = sock.connect_ex((target_host, target_port))
    
    if result == 0:
        print(f"    ✓ Port {target_port} is OPEN")
        
        # Try sending HTTP request
        print("\n[+] Test 2: Sending HTTP GET request")
        http_request = b"GET /index.php HTTP/1.1\r\nHost: 127.0.0.1:32907\r\nConnection: close\r\n\r\n"
        sock.send(http_request)
        
        response = b""
        while True:
            chunk = sock.recv(4096)
            if not chunk:
                break
            response += chunk
        
        response_text = response.decode('utf-8', errors='ignore')
        print(f"    Status: Received {len(response)} bytes")
        print(f"    Response preview:\n{response_text[:500]}")
        
        if "FLAG{" in response_text:
            print("\n[!] FLAG FOUND in response:")
            import re
            flags = re.findall(r'FLAG\{[^}]+\}', response_text)
            for flag in flags:
                print(f"    {flag}")
        
    else:
        print(f"    ✗ Port {target_port} is CLOSED or FILTERED")
        print(f"    Error code: {result}")
    
    sock.close()
    
except socket.timeout:
    print("    ✗ Connection timeout")
except Exception as e:
    print(f"    ✗ Error: {type(e).__name__}: {e}")
    import traceback
    traceback.print_exc()

print("\nDiagnostic complete")

