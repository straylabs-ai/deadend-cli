import requests
import json

base_url = "http://127.0.0.1:8000"

print("STEP 1: Testing Authentication Endpoint")
print("-" * 60)

# Step 1: Authenticate
token_url = f"{base_url}/token"
auth_data = {
    "username": "demo",
    "password": "demo"
}

headers = {
    "Content-Type": "application/x-www-form-urlencoded"
}

print(f"\nPOST {token_url}")
print(f"Data: username=demo, password=demo")

auth_response = requests.post(
    token_url,
    data=auth_data,
    headers=headers,
    allow_redirects=False
)

print(f"\nStatus Code: {auth_response.status_code}")
print(f"Response Headers:")
for header, value in auth_response.headers.items():
    print(f"  {header}: {value}")

print(f"\nResponse Cookies: {dict(auth_response.cookies) if auth_response.cookies else 'None'}")

print(f"\nResponse Body:")
print(auth_response.text)

# Parse JSON
token = None
try:
    auth_json = auth_response.json()
    print(f"\nParsed JSON:")
    print(json.dumps(auth_json, indent=2))
    
    if "access_token" in auth_json:
        token = auth_json["access_token"]
        print(f"\nExtracted Token: {token}")
except:
    pass

print("\n" + "=" * 60)
print("STEP 2: Testing /company/1/jobs WITHOUT Auth")
print("-" * 60)

jobs_url = f"{base_url}/company/1/jobs"
print(f"\nGET {jobs_url} (no auth)")

no_auth_response = requests.get(jobs_url, allow_redirects=False)

print(f"\nStatus Code: {no_auth_response.status_code}")
print(f"Content Length: {len(no_auth_response.content)} bytes")
print(f"\nResponse Body:")
print(no_auth_response.text)

print("\n" + "=" * 60)
print("STEP 3: Testing /company/1/jobs WITH Auth")
print("-" * 60)

if token:
    print(f"\nGET {jobs_url} (Bearer token)")
    
    auth_headers = {
        "Authorization": f"Bearer {token}"
    }
    
    auth_response_jobs = requests.get(
        jobs_url,
        headers=auth_headers,
        allow_redirects=False
    )
    
    print(f"\nStatus Code: {auth_response_jobs.status_code}")
    print(f"Content Length: {len(auth_response_jobs.content)} bytes")
    print(f"\nResponse Body:")
    print(auth_response_jobs.text)
else:
    print("\nNo token extracted, cannot test authenticated access")

print("\n" + "=" * 60)
print("SUMMARY")
print("-" * 60)
