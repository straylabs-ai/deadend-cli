import requests
import json

base_url = "http://127.0.0.1:8000"

print("=" * 80)
print("STEP 1: Testing Authentication Endpoint")
print("=" * 80)

# Step 1: Send POST request to /token
token_url = f"{base_url}/token"
auth_data = {
    "username": "demo",
    "password": "demo"
}

headers = {
    "Content-Type": "application/x-www-form-urlencoded"
}

print(f"\n[+] POST {token_url}")
print(f"[+] Data: {auth_data}")
print(f"[+] Headers: {headers}")

try:
    auth_response = requests.post(
        token_url,
        data=auth_data,
        headers=headers,
        allow_redirects=False
    )
    
    print(f"\n[+] Authentication Response:")
    print(f"    Status Code: {auth_response.status_code}")
    print(f"    Response Time: {auth_response.elapsed.total_seconds()}s")
    
    print(f"\n[+] Response Headers:")
    for header, value in auth_response.headers.items():
        print(f"    {header}: {value}")
    
    print(f"\n[+] Response Cookies:")
    if auth_response.cookies:
        for cookie_name, cookie_value in auth_response.cookies.items():
            print(f"    {cookie_name}: {cookie_value}")
    else:
        print("    No cookies set")
    
    print(f"\n[+] Response Body:")
    print(auth_response.text)
    
    # Try to parse as JSON
    try:
        auth_json = auth_response.json()
        print(f"\n[+] Parsed JSON:")
        print(json.dumps(auth_json, indent=2))
        
        # Extract token if present
        token = None
        if "access_token" in auth_json:
            token = auth_json["access_token"]
            print(f"\n[+] Access Token Found: {token}")
        elif "token" in auth_json:
            token = auth_json["token"]
            print(f"\n[+] Token Found: {token}")
            
    except Exception as e:
        print(f"    (Not JSON or parse error: {e})")
        token = None
        auth_json = None

except Exception as e:
    print(f"[-] Authentication request failed: {e}")
    auth_response = None
    token = None
    auth_json = None

print("\n" + "=" * 80)
print("STEP 2: Testing /company/1/jobs WITHOUT Authentication")
print("=" * 80)

jobs_url = f"{base_url}/company/1/jobs"

print(f"\n[+] GET {jobs_url}")
print("[+] No authentication headers/cookies")

try:
    no_auth_response = requests.get(
        jobs_url,
        allow_redirects=False
    )
    
    print(f"\n[+] Response (No Auth):")
    print(f"    Status Code: {no_auth_response.status_code}")
    print(f"    Content Length: {len(no_auth_response.content)} bytes")
    print(f"    Response Time: {no_auth_response.elapsed.total_seconds()}s")
    
    print(f"\n[+] Response Headers:")
    for header, value in no_auth_response.headers.items():
        print(f"    {header}: {value}")
    
    print(f"\n[+] Response Body:")
    print(no_auth_response.text)
    
except Exception as e:
    print(f"[-] Request failed: {e}")
    no_auth_response = None

print("\n" + "=" * 80)
print("STEP 3: Testing /company/1/jobs WITH Authentication")
print("=" * 80)

if auth_response and auth_response.status_code == 200:
    # Try multiple authentication methods
    
    # Method 1: Using Bearer token (if we extracted one)
    if token:
        print(f"\n[Method 1] Using Bearer Token")
        print(f"[+] GET {jobs_url}")
        print(f"[+] Authorization: Bearer {token}")
        
        auth_headers = {
            "Authorization": f"Bearer {token}"
        }
        
        try:
            bearer_response = requests.get(
                jobs_url,
                headers=auth_headers,
                allow_redirects=False
            )
            
            print(f"\n[+] Response (Bearer Token):")
            print(f"    Status Code: {bearer_response.status_code}")
            print(f"    Content Length: {len(bearer_response.content)} bytes")
            print(f"    Response Time: {bearer_response.elapsed.total_seconds()}s")
            
            print(f"\n[+] Response Body:")
            print(bearer_response.text)
            
        except Exception as e:
            print(f"[-] Request failed: {e}")
    
    # Method 2: Using cookies (if any were set)
    if auth_response.cookies:
        print(f"\n[Method 2] Using Session Cookies")
        print(f"[+] GET {jobs_url}")
        print(f"[+] Cookies: {dict(auth_response.cookies)}")
        
        try:
            cookie_response = requests.get(
                jobs_url,
                cookies=auth_response.cookies,
                allow_redirects=False
            )
            
            print(f"\n[+] Response (Session Cookies):")
            print(f"    Status Code: {cookie_response.status_code}")
            print(f"    Content Length: {len(cookie_response.content)} bytes")
            print(f"    Response Time: {cookie_response.elapsed.total_seconds()}s")
            
            print(f"\n[+] Response Body:")
            print(cookie_response.text)
            
        except Exception as e:
            print(f"[-] Request failed: {e}")
else:
    print("\n[!] Authentication failed or returned non-200 status")
    print("[!] Cannot test authenticated access")

print("\n" + "=" * 80)
print("SUMMARY OF FINDINGS")
print("=" * 80)

if auth_response:
    print(f"\n[+] Authentication Endpoint (/token):")
    print(f"    Status: {auth_response.status_code}")
    print(f"    Returns JSON: {auth_json is not None}")
    if auth_json:
        print(f"    Token Type: {auth_json.get('token_type', 'N/A')}")
        print(f"    Access Token Present: {'access_token' in auth_json}")
    print(f"    Sets Cookies: {len(auth_response.cookies) > 0}")

if no_auth_response:
    print(f"\n[+] Jobs Endpoint Without Auth:")
    print(f"    Status: {no_auth_response.status_code}")
    print(f"    Accessible: {no_auth_response.status_code == 200}")

print("\n[+] Authentication appears to be:")
if auth_response and auth_response.status_code == 200 and token:
    print("    TOKEN-BASED (Bearer token in JSON response)")
elif auth_response and auth_response.cookies:
    print("    COOKIE-BASED (Session cookie set)")
else:
    print("    UNKNOWN or FAILED")

