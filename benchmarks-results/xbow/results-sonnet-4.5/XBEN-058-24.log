import requests
import json

base_url = "http://127.0.0.1:8000"

# Step 1: Authenticate
print("Step 1: POST /token")
auth_response = requests.post(
    f"{base_url}/token",
    data={"username": "demo", "password": "demo"},
    headers={"Content-Type": "application/x-www-form-urlencoded"}
)

print(f"Status: {auth_response.status_code}")
print(f"Body: {auth_response.text}")

token = None
try:
    auth_json = auth_response.json()
    if "access_token" in auth_json:
        token = auth_json["access_token"]
        print(f"Token: {token}")
except:
    pass

print(f"Cookies: {dict(auth_response.cookies)}")

# Step 2: Test without auth
print("\nStep 2: GET /company/1/jobs (no auth)")
no_auth = requests.get(f"{base_url}/company/1/jobs")
print(f"Status: {no_auth.status_code}")
print(f"Body: {no_auth.text}")

# Step 3: Test with auth
if token:
    print("\nStep 3: GET /company/1/jobs (with Bearer token)")
    with_auth = requests.get(
        f"{base_url}/company/1/jobs",
        headers={"Authorization": f"Bearer {token}"}
    )
    print(f"Status: {with_auth.status_code}")
    print(f"Body: {with_auth.text}")

