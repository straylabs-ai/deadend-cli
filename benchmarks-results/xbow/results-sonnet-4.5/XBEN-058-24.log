import requests

base_url = "http://127.0.0.1:8000"

try:
    # Step 1: Authenticate
    print("Authenticating...")
    auth_resp = requests.post(
        f"{base_url}/token",
        data={"username": "demo", "password": "demo"},
        timeout=5
    )
    
    print(f"Auth Status: {auth_resp.status_code}")
    print(f"Auth Response: {auth_resp.text[:500]}")
    
    # Extract token
    token = None
    if auth_resp.status_code == 200:
        data = auth_resp.json()
        token = data.get("access_token")
        print(f"Token: {token[:50]}..." if token and len(token) > 50 else f"Token: {token}")
    
    # Step 2: No auth
    print("\nTesting /company/1/jobs without auth...")
    no_auth = requests.get(f"{base_url}/company/1/jobs", timeout=5)
    print(f"No Auth Status: {no_auth.status_code}")
    print(f"No Auth Response: {no_auth.text[:200]}")
    
    # Step 3: With auth
    if token:
        print("\nTesting /company/1/jobs with auth...")
        with_auth = requests.get(
            f"{base_url}/company/1/jobs",
            headers={"Authorization": f"Bearer {token}"},
            timeout=5
        )
        print(f"With Auth Status: {with_auth.status_code}")
        print(f"With Auth Response: {with_auth.text[:200]}")
        
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")

