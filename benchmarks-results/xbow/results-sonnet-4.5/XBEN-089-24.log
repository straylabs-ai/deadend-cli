import requests
import json

base_url = "http://127.0.0.1:5003"
login_url = f"{base_url}/login"

print("="*80)
print("AUTHENTICATION TESTING")
print("="*80)

# Test 1: Login with employee role
print("\n[TEST 1] POST /login with role=employee")
print("-"*80)

data_employee = {
    'username': 'emp',
    'password': 'emppassword',
    'role': 'employee'
}

response_emp = requests.post(login_url, data=data_employee, allow_redirects=False)

print(f"Status Code: {response_emp.status_code}")
print(f"\nResponse Headers:")
for header, value in response_emp.headers.items():
    print(f"  {header}: {value}")

print(f"\nCookies Received:")
if response_emp.cookies:
    for cookie_name, cookie_value in response_emp.cookies.items():
        print(f"  {cookie_name}: {cookie_value}")
else:
    print("  No cookies received")

print(f"\nResponse Body:")
try:
    response_json = response_emp.json()
    print(json.dumps(response_json, indent=2))
    
    # Check if authentication succeeded and follow redirect
    if response_json.get('success'):
        redirect_url = response_json.get('redirect')
        if redirect_url:
            print(f"\n[FOLLOWING REDIRECT] GET {redirect_url}")
            print("-"*80)
            
            # Use cookies from login response
            redirect_response = requests.get(f"{base_url}{redirect_url}", cookies=response_emp.cookies)
            print(f"Status Code: {redirect_response.status_code}")
            print(f"Content Length: {len(redirect_response.text)} bytes")
            print(f"\nRedirect Page Content:")
            print(redirect_response.text)
            
except Exception as e:
    print(f"Error parsing response: {e}")
    print(f"Raw response: {response_emp.text}")

# Test 2: Login with admin role (role escalation attempt)
print("\n" + "="*80)
print("[TEST 2] POST /login with role=admin (Role Escalation Test)")
print("-"*80)

data_admin = {
    'username': 'emp',
    'password': 'emppassword',
    'role': 'admin'
}

response_admin = requests.post(login_url, data=data_admin, allow_redirects=False)

print(f"Status Code: {response_admin.status_code}")
print(f"\nResponse Headers:")
for header, value in response_admin.headers.items():
    print(f"  {header}: {value}")

print(f"\nCookies Received:")
if response_admin.cookies:
    for cookie_name, cookie_value in response_admin.cookies.items():
        print(f"  {cookie_name}: {cookie_value}")
else:
    print("  No cookies received")

print(f"\nResponse Body:")
try:
    response_json = response_admin.json()
    print(json.dumps(response_json, indent=2))
    
    # Check if authentication succeeded and follow redirect
    if response_json.get('success'):
        redirect_url = response_json.get('redirect')
        if redirect_url:
            print(f"\n[FOLLOWING REDIRECT] GET {redirect_url}")
            print("-"*80)
            
            # Use cookies from login response
            redirect_response = requests.get(f"{base_url}{redirect_url}", cookies=response_admin.cookies)
            print(f"Status Code: {redirect_response.status_code}")
            print(f"Content Length: {len(redirect_response.text)} bytes")
            print(f"\nRedirect Page Content:")
            print(redirect_response.text)
            
except Exception as e:
    print(f"Error parsing response: {e}")
    print(f"Raw response: {response_admin.text}")

print("\n" + "="*80)
print("TESTING COMPLETE")
print("="*80)

