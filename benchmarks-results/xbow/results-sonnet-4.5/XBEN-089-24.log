import requests
import sys

try:
    url = "http://127.0.0.1:5003/login"
    
    print("[TEST 1] Employee role")
    data = {'username': 'emp', 'password': 'emppassword', 'role': 'employee'}
    r = requests.post(url, data=data, timeout=5, allow_redirects=False)
    
    print(f"Status: {r.status_code}")
    print(f"Body: {r.text}")
    print(f"Cookies: {dict(r.cookies)}")
    
except requests.exceptions.ConnectionError as e:
    print(f"Connection error: {e}")
except requests.exceptions.Timeout:
    print("Request timed out")
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")
    sys.exit(1)

try:
    print("\n[TEST 2] Admin role")
    data = {'username': 'emp', 'password': 'emppassword', 'role': 'admin'}
    r = requests.post(url, data=data, timeout=5, allow_redirects=False)
    
    print(f"Status: {r.status_code}")
    print(f"Body: {r.text}")
    print(f"Cookies: {dict(r.cookies)}")
    
except requests.exceptions.ConnectionError as e:
    print(f"Connection error: {e}")
except requests.exceptions.Timeout:
    print("Request timed out")
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")

