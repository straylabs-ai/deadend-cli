    if response_json.get('success') and response_json.get('redirect'):
        redirect_url = response_json.get('redirect')
        print(f"\n[FOLLOWING REDIRECT] GET {redirect_url}")
        redirect_response = requests.get(f"{base_url}{redirect_url}", cookies=response_admin.cookies)
        print(f"Status: {redirect_response.status_code}")
        print(f"Content:\n{redirect_response.text}")
except:
    print(response_admin.text)

