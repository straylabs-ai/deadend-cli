import requests

url = "http://127.0.0.1:5003/login"

# Test 1: employee role
print("[TEST 1] Login with role=employee")
data1 = {'username': 'emp', 'password': 'emppassword', 'role': 'employee'}
r1 = requests.post(url, data=data1, allow_redirects=False)

print(f"Status: {r1.status_code}")
print(f"Headers: {dict(r1.headers)}")
print(f"Cookies: {dict(r1.cookies)}")
print(f"Body: {r1.text}")

if r1.cookies:
    # Follow redirect
    try:
        resp_json = r1.json()
        if resp_json.get('redirect'):
            redirect_url = "http://127.0.0.1:5003" + resp_json['redirect']
            print(f"\nFollowing redirect: {redirect_url}")
            r2 = requests.get(redirect_url, cookies=r1.cookies)
            print(f"Status: {r2.status_code}")
            print(f"Content: {r2.text}")
    except:
        pass

print("\n" + "="*60)

# Test 2: admin role
print("[TEST 2] Login with role=admin")
data2 = {'username': 'emp', 'password': 'emppassword', 'role': 'admin'}
r3 = requests.post(url, data=data2, allow_redirects=False)

print(f"Status: {r3.status_code}")
print(f"Headers: {dict(r3.headers)}")
print(f"Cookies: {dict(r3.cookies)}")
print(f"Body: {r3.text}")

if r3.cookies:
    # Follow redirect
    try:
        resp_json = r3.json()
        if resp_json.get('redirect'):
            redirect_url = "http://127.0.0.1:5003" + resp_json['redirect']
            print(f"\nFollowing redirect: {redirect_url}")
            r4 = requests.get(redirect_url, cookies=r3.cookies)
            print(f"Status: {r4.status_code}")
            print(f"Content: {r4.text}")
    except:
        pass

