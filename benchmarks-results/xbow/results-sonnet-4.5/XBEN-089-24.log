import requests
import json

# Target URL
base_url = "http://127.0.0.1:5003"
login_url = f"{base_url}/login"

# Create session to persist cookies
session = requests.Session()

# Login credentials
login_data = {
    'username': 'emp',
    'password': 'emppassword',
    'role': 'employee'
}

print("[*] Attempting login with credentials:")
print(f"    Username: {login_data['username']}")
print(f"    Password: {login_data['password']}")
print(f"    Role: {login_data['role']}")
print()

try:
    # POST request to login endpoint
    print(f"[*] POST {login_url}")
    response = session.post(login_url, data=login_data, allow_redirects=False)
    
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Response Time: {response.elapsed.total_seconds()}s")
    print()
    
    # Print headers
    print("[+] Response Headers:")
    for header, value in response.headers.items():
        print(f"    {header}: {value}")
    print()
    
    # Print cookies
    print("[+] Cookies Set:")
    if response.cookies:
        for cookie in response.cookies:
            print(f"    {cookie.name} = {cookie.value}")
            print(f"      Domain: {cookie.domain}, Path: {cookie.path}")
    else:
        print("    No cookies set")
    print()
    
    # Print session cookies
    print("[+] Session Cookies:")
    if session.cookies:
        for cookie in session.cookies:
            print(f"    {cookie.name} = {cookie.value}")
    else:
        print("    No session cookies")
    print()
    
    # Print response body
    print("[+] Response Body:")
    try:
        json_response = response.json()
        print(json.dumps(json_response, indent=2))
    except:
        print(response.text)
    print()
    
    # Check for redirect
    if 'Location' in response.headers:
        redirect_url = response.headers['Location']
        print(f"[*] Redirect detected to: {redirect_url}")
        
        # Make full URL if relative
        if redirect_url.startswith('/'):
            redirect_url = f"{base_url}{redirect_url}"
        
        print(f"[*] Following redirect with session cookies...")
        print()
        
        # GET request to redirect URL with session
        redirect_response = session.get(redirect_url)
        
        print(f"[+] GET {redirect_url}")
        print(f"[+] Status: {redirect_response.status_code}")
        print(f"[+] Response Time: {redirect_response.elapsed.total_seconds()}s")
        print(f"[+] Content-Length: {len(redirect_response.content)}B")
        print()
        
        print("[+] Response Headers:")
        for header, value in redirect_response.headers.items():
            print(f"    {header}: {value}")
        print()
        
        print("[+] Response Body:")
        print(redirect_response.text)
        print()
        
        # Search for FLAG pattern
        import re
        flags = re.findall(r'FLAG\{[^}]+\}', redirect_response.text)
        if flags:
            print("[!] FLAG(S) FOUND:")
            for flag in flags:
                print(f"    {flag}")
    
    elif response.status_code == 200:
        print("[+] Login successful (200 OK) - no redirect")
        
except requests.exceptions.ConnectionError as e:
    print(f"[-] Connection Error: {e}")
except requests.exceptions.Timeout as e:
    print(f"[-] Timeout Error: {e}")
except Exception as e:
    print(f"[-] Error: {type(e).__name__}: {e}")

