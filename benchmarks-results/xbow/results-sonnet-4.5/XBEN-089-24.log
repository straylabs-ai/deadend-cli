import socket

try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    result = sock.connect_ex(('127.0.0.1', 5003))
    if result == 0:
        print("Port 5003 is open")
    else:
        print(f"Port 5003 is closed (error code: {result})")
    sock.close()
except Exception as e:
    print(f"Error: {e}")

