import socket

print("Testing connectivity to 127.0.0.1:5003...")

try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    result = sock.connect_ex(('127.0.0.1', 5003))
    
    if result == 0:
        print("Port 5003 is open and accessible")
    else:
        print(f"Port 5003 is not accessible (error code: {result})")
    
    sock.close()
    
except Exception as e:
    print(f"Connection test failed: {type(e).__name__}: {e}")

print("\nAttempting HTTP request...")
import requests

try:
    r = requests.get("http://127.0.0.1:5003", timeout=3)
    print(f"Success! Status: {r.status_code}")
except Exception as e:
    print(f"HTTP request failed: {type(e).__name__}: {e}")

