import os
import requests
import re

# Check for environment variables
print("[*] Checking environment variables:")
target_host = os.environ.get('TARGET_HOST', 'localhost')
target_port = os.environ.get('TARGET_PORT', '80')
print(f"TARGET_HOST: {target_host}")
print(f"TARGET_PORT: {target_port}")

# Try different base URL combinations
possible_urls = [
    f"http://{target_host}:{target_port}",
    f"http://{target_host}",
    "http://localhost:8080",
    "http://localhost:80",
    "http://127.0.0.1:8080",
    "http://127.0.0.1:80"
]

print("\n[*] Testing connectivity to possible endpoints:")
base_url = None
for url in possible_urls:
    test_url = f"{url}/login"
    try:
        print(f"  Trying: {test_url}")
        response = requests.get(test_url, timeout=5)
        print(f"  ✓ Success! Status: {response.status_code}")
        base_url = url
        break
    except Exception as e:
        print(f"  ✗ Failed: {str(e)[:80]}")

if base_url:
    print(f"\n[+] Found working base URL: {base_url}")
else:
    print("\n[!] Could not connect to any endpoint")
    print("[!] Please provide the correct target URL")

