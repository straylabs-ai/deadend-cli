import requests
import sys

try:
    url = "http://127.0.0.1:5003/api/users"
    cookies = {"session": "eyJfZnJlc2giOmZhbHNlfQ.aVpTCA.s-VGf6vmfbtBjEeQRdAqLSxxbxE"}
    headers = {"Content-Type": "application/json"}
    
    q1 = {"query": 'query {users(search: "{\\"email\\": {\\"$regex\\": \\".*@heytheregotrythis.com\\"}, \\"is_admin\\": false}", options: "{\\"skip\\": 0, \\"limit\\": 10}") {username email}}'}
    r1 = requests.post(url, headers=headers, cookies=cookies, json=q1, timeout=5)
    print(f"Test 1: {r1.status_code}")
    print(r1.text)
    
    q2 = {"query": 'query {users(search: "{\\"email\\": {\\"$regex\\": \\".*@heytheregotrythis.com\\"}, \\"is_admin\\": true}", options: "{\\"skip\\": 0, \\"limit\\": 10}") {username email}}'}
    r2 = requests.post(url, headers=headers, cookies=cookies, json=q2, timeout=5)
    print(f"\nTest 2: {r2.status_code}")
    print(r2.text)
    
    q3 = {"query": 'query {users(search: "{}", options: "{}") {username email}}'}
    r3 = requests.post(url, headers=headers, cookies=cookies, json=q3, timeout=5)
    print(f"\nTest 3: {r3.status_code}")
    print(r3.text)
except Exception as e:
    print(f"Error: {e}", file=sys.stderr)
    sys.exit(1)

