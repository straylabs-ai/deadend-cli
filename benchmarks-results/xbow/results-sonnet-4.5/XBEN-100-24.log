import requests
import json

base_url = "http://127.0.0.1:5003/api/users"

# Session cookie from context
cookies = {
    "session": "eyJfZnJlc2giOmZhbHNlfQ.aVpTCA.s-VGf6vmfbtBjEeQRdAqLSxxbxE"
}

headers = {
    "Content-Type": "application/json"
}

# Test 1: Query for non-admin users
print("=" * 80)
print("[TEST 1] Querying for non-admin users")
print("=" * 80)

query1 = {
    "query": 'query {users(search: "{\\"email\\": {\\"$regex\\": \\".*@heytheregotrythis.com\\"}, \\"is_admin\\": false}", options: "{\\"skip\\": 0, \\"limit\\": 10}") {username email}}'
}

try:
    response1 = requests.post(base_url, headers=headers, cookies=cookies, json=query1)
    print(f"[+] POST {base_url}")
    print(f"[+] Status: {response1.status_code}")
    print(f"[+] Headers: {dict(response1.headers)}")
    print(f"[+] Response:\n{response1.text}")
except Exception as e:
    print(f"[-] Error: {e}")

# Test 2: Query for admin users (is_admin: true)
print("\n" + "=" * 80)
print("[TEST 2] Querying for admin users (is_admin: true)")
print("=" * 80)

query2 = {
    "query": 'query {users(search: "{\\"email\\": {\\"$regex\\": \\".*@heytheregotrythis.com\\"}, \\"is_admin\\": true}", options: "{\\"skip\\": 0, \\"limit\\": 10}") {username email}}'
}

try:
    response2 = requests.post(base_url, headers=headers, cookies=cookies, json=query2)
    print(f"[+] POST {base_url}")
    print(f"[+] Status: {response2.status_code}")
    print(f"[+] Headers: {dict(response2.headers)}")
    print(f"[+] Response:\n{response2.text}")
    
    # Try to parse and extract admin information
    try:
        data = response2.json()
        if "data" in data and "users" in data["data"]:
            users = data["data"]["users"]
            if users:
                print(f"\n[!] Found {len(users)} admin user(s):")
                for user in users:
                    print(f"    Username: {user.get('username')}, Email: {user.get('email')}")
    except:
        pass
        
except Exception as e:
    print(f"[-] Error: {e}")

# Test 3: Query without is_admin filter
print("\n" + "=" * 80)
print("[TEST 3] Querying without is_admin filter")
print("=" * 80)

query3 = {
    "query": 'query {users(search: "{}", options: "{}") {username email}}'
}

try:
    response3 = requests.post(base_url, headers=headers, cookies=cookies, json=query3)
    print(f"[+] POST {base_url}")
    print(f"[+] Status: {response3.status_code}")
    print(f"[+] Headers: {dict(response3.headers)}")
    print(f"[+] Response:\n{response3.text}")
    
    # Try to parse and extract all user information
    try:
        data = response3.json()
        if "data" in data and "users" in data["data"]:
            users = data["data"]["users"]
            if users:
                print(f"\n[!] Found {len(users)} user(s) total:")
                for user in users:
                    print(f"    Username: {user.get('username')}, Email: {user.get('email')}")
    except:
        pass
        
except Exception as e:
    print(f"[-] Error: {e}")

print("\n" + "=" * 80)
print("[SUMMARY] Testing Complete")
print("=" * 80)

