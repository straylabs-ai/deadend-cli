import socket
import time

host = '127.0.0.1'
port = 32843

# Minimal PNG
png = bytes([
    0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A,
    0x00, 0x00, 0x00, 0x0D, 0x49, 0x48, 0x44, 0x52,
    0x00, 0x00, 0x00, 0x01, 0x00, 0x00, 0x00, 0x01,
    0x08, 0x06, 0x00, 0x00, 0x00, 0x1F, 0x15, 0xC4,
    0x89, 0x00, 0x00, 0x00, 0x0A, 0x49, 0x44, 0x41,
    0x54, 0x78, 0x9C, 0x63, 0x00, 0x01, 0x00, 0x00,
    0x05, 0x00, 0x01, 0x0D, 0x0A, 0x2D, 0xB4, 0x00,
    0x00, 0x00, 0x00, 0x49, 0x45, 0x4E, 0x44, 0xAE,
    0x42, 0x60, 0x82
])

print(f"[+] PNG size: {len(png)} bytes")
print(f"[+] Target: {host}:{port}")

# Build multipart body
boundary = 'WebKitBoundary123456'
body = (
    f'--{boundary}\r\n'
    f'Content-Disposition: form-data; name="userfile"; filename="test.png"\r\n'
    f'Content-Type: image/png\r\n'
    f'\r\n'
).encode() + png + f'\r\n--{boundary}--\r\n'.encode()

# Build HTTP request
request = (
    f'POST /index.php HTTP/1.1\r\n'
    f'Host: {host}:{port}\r\n'
    f'Content-Type: multipart/form-data; boundary={boundary}\r\n'
    f'Content-Length: {len(body)}\r\n'
    f'Connection: close\r\n'
    f'\r\n'
).encode() + body

print(f"[+] Request size: {len(request)} bytes")

try:
    # Create socket
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.settimeout(15)
    
    print(f"[+] Connecting to {host}:{port}...")
    s.connect((host, port))
    print("[+] Connected")
    
    print("[+] Sending request...")
    s.sendall(request)
    print("[+] Request sent")
    
    print("[+] Waiting for response...")
    response = b''
    while True:
        try:
            chunk = s.recv(4096)
            if not chunk:
                break
            response += chunk
        except socket.timeout:
            break
    
    s.close()
    
    print(f"[+] Received {len(response)} bytes")
    
    # Parse response
    response_str = response.decode('utf-8', errors='replace')
    
    if '\r\n\r\n' in response_str:
        headers, body = response_str.split('\r\n\r\n', 1)
        print(f"\n[+] Response Headers:\n{headers}")
        print(f"\n[+] Response Body:\n{body}")
    else:
        print(f"\n[+] Full Response:\n{response_str}")
    
except Exception as e:
    print(f"[-] Error: {type(e).__name__}: {e}")
    import traceback
    traceback.print_exc()

