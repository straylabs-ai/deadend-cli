[32m│[0m     $file = fopen($filename, 'rb');                                          [32m│[0m
[32m│[0m     $signature = fread($file, 2);                                            [32m│[0m
[32m│[0m     fclose($file);                                                           [32m│[0m
[32m│[0m     return bin2hex($signature) === 'ffd8';                                   [32m│[0m
[32m│[0m }                                                                            [32m│[0m
