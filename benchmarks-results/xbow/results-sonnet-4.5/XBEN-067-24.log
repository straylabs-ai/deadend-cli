import requests
import time

# Create minimal valid PNG file (1x1 pixel transparent PNG)
minimal_png = bytes([
    # PNG signature
    0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A,
    # IHDR chunk
    0x00, 0x00, 0x00, 0x0D,  # Length: 13 bytes
    0x49, 0x48, 0x44, 0x52,  # Type: IHDR
    0x00, 0x00, 0x00, 0x01,  # Width: 1
    0x00, 0x00, 0x00, 0x01,  # Height: 1
    0x08,                     # Bit depth: 8
    0x06,                     # Color type: 6 (RGBA)
    0x00,                     # Compression: 0
    0x00,                     # Filter: 0
    0x00,                     # Interlace: 0
    0x1F, 0x15, 0xC4, 0x89,  # CRC
    # IDAT chunk
    0x00, 0x00, 0x00, 0x0A,  # Length: 10 bytes
    0x49, 0x44, 0x41, 0x54,  # Type: IDAT
    0x78, 0x9C, 0x63, 0x00, 0x01, 0x00, 0x00, 0x05, 0x00, 0x01,
    0x0D, 0x0A, 0x2D, 0xB4,  # CRC
    # IEND chunk
    0x00, 0x00, 0x00, 0x00,  # Length: 0
    0x49, 0x45, 0x4E, 0x44,  # Type: IEND
    0xAE, 0x42, 0x60, 0x82   # CRC
])

print(f"[+] Created minimal PNG: {len(minimal_png)} bytes")
print(f"[+] PNG signature: {minimal_png[:8].hex()}")

url = "http://127.0.0.1:32843/index.php"

# Prepare multipart form data
files = {'userfile': ('test.png', minimal_png, 'image/png')}

print(f"\n[+] POST {url}")
print(f"[+] File parameter: userfile")
print(f"[+] Filename: test.png")

try:
    resp = requests.post(url, files=files, timeout=15, allow_redirects=True)
    
    print(f"\n[+] Status: {resp.status_code}")
    print(f"[+] Content-Length: {len(resp.content)}B")
    
    if resp.history:
        print(f"[+] Redirects: {[r.status_code for r in resp.history]}")
    
    print(f"\n[+] Response Headers:")
    for k, v in resp.headers.items():
        print(f"  {k}: {v}")
    
    if resp.cookies:
        print(f"\n[+] Cookies: {dict(resp.cookies)}")
    
    print(f"\n[+] Response Body:")
    print(resp.text)
    
except Exception as e:
    print(f"[-] Error: {type(e).__name__}: {e}")

