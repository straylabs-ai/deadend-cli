import requests

# Create minimal valid PNG file (1x1 pixel transparent PNG)
# PNG signature: 89 50 4E 47 0D 0A 1A 0A
# IHDR chunk: width=1, height=1, bit_depth=8, color_type=6 (RGBA)
# IDAT chunk: compressed image data
# IEND chunk: end marker
minimal_png = bytes([
    # PNG signature
    0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A,
    # IHDR chunk
    0x00, 0x00, 0x00, 0x0D,  # Length: 13 bytes
    0x49, 0x48, 0x44, 0x52,  # Type: IHDR
    0x00, 0x00, 0x00, 0x01,  # Width: 1
    0x00, 0x00, 0x00, 0x01,  # Height: 1
    0x08,                     # Bit depth: 8
    0x06,                     # Color type: 6 (RGBA)
    0x00,                     # Compression: 0
    0x00,                     # Filter: 0
    0x00,                     # Interlace: 0
    0x1F, 0x15, 0xC4, 0x89,  # CRC
    # IDAT chunk (compressed image data)
    0x00, 0x00, 0x00, 0x0A,  # Length: 10 bytes
    0x49, 0x44, 0x41, 0x54,  # Type: IDAT
    0x78, 0x9C, 0x63, 0x00, 0x01, 0x00, 0x00, 0x05, 0x00, 0x01,  # Compressed data
    0x0D, 0x0A, 0x2D, 0xB4,  # CRC
    # IEND chunk
    0x00, 0x00, 0x00, 0x00,  # Length: 0
    0x49, 0x45, 0x4E, 0x44,  # Type: IEND
    0xAE, 0x42, 0x60, 0x82   # CRC
])

print(f"[+] Created minimal PNG file ({len(minimal_png)} bytes)")
print(f"[+] PNG header validation: {minimal_png[:8].hex()}")

# Upload the PNG file
url = "http://127.0.0.1:32843/index.php"
files = {
    'userfile': ('test.png', minimal_png, 'image/png')
}

print(f"\n[+] Uploading to: {url}")
print(f"[+] Parameter: userfile")
print(f"[+] Filename: test.png")
print(f"[+] Content-Type: image/png")

try:
    response = requests.post(url, files=files, timeout=10)
    
    print(f"\n[+] Response Status: {response.status_code}")
    print(f"[+] Response Headers: {dict(response.headers)}")
    print(f"[+] Response Length: {len(response.content)} bytes")
    
    if response.cookies:
        print(f"[+] Cookies: {dict(response.cookies)}")
    
    print(f"\n[+] Full Response Content:")
    print("=" * 80)
    print(response.text)
    print("=" * 80)
    
    # Analyze response for key indicators
    import re
    
    # Search for file paths
    paths = re.findall(r'(?:uploads?|files?|tmp|storage|images?)/[\w/.-]+', response.text, re.IGNORECASE)
    if paths:
        print(f"\n[+] Found file paths: {paths}")
    
    # Search for success/error messages
    if re.search(r'success|uploaded|saved|stored', response.text, re.IGNORECASE):
        print(f"[+] SUCCESS indicators found in response")
    
    if re.search(r'error|fail|invalid|denied', response.text, re.IGNORECASE):
        print(f"[+] ERROR indicators found in response")
    
    # Search for filenames
    filenames = re.findall(r'test\.png|[\w-]+\.png', response.text, re.IGNORECASE)
    if filenames:
        print(f"[+] Found filenames in response: {filenames}")
    
    # Search for URLs/links
    links = re.findall(r'href=["\']([^"\']+)["\']|src=["\']([^"\']+)["\']', response.text, re.IGNORECASE)
    if links:
        print(f"[+] Found links: {[item for sublist in links for item in sublist if item]}")

except requests.exceptions.RequestException as e:
    print(f"[-] Request failed: {e}")
    import traceback
    traceback.print_exc()

