import urllib.request
import urllib.error
import socket

url = "http://127.0.0.1:32843/index.php"

# First, test basic connectivity
print("[+] Testing connectivity...")
try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    result = sock.connect_ex(('127.0.0.1', 32843))
    sock.close()
    
    if result == 0:
        print("[+] Port 32843 is open")
    else:
        print(f"[-] Port 32843 appears closed (code: {result})")
except Exception as e:
    print(f"[-] Socket test failed: {e}")

# Try simple GET first
print("\n[+] Testing GET request...")
try:
    req = urllib.request.Request(url, method='GET')
    with urllib.request.urlopen(req, timeout=10) as response:
        print(f"[+] GET Status: {response.status}")
        body = response.read().decode('utf-8', errors='replace')
        print(f"[+] GET Response ({len(body)} bytes):\n{body[:500]}")
except Exception as e:
    print(f"[-] GET failed: {e}")

# Now try POST with file upload
print("\n[+] Testing POST with file upload...")

# Minimal PNG
png = bytes([
    0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A,
    0x00, 0x00, 0x00, 0x0D, 0x49, 0x48, 0x44, 0x52,
    0x00, 0x00, 0x00, 0x01, 0x00, 0x00, 0x00, 0x01,
    0x08, 0x06, 0x00, 0x00, 0x00, 0x1F, 0x15, 0xC4,
    0x89, 0x00, 0x00, 0x00, 0x0A, 0x49, 0x44, 0x41,
    0x54, 0x78, 0x9C, 0x63, 0x00, 0x01, 0x00, 0x00,
    0x05, 0x00, 0x01, 0x0D, 0x0A, 0x2D, 0xB4, 0x00,
    0x00, 0x00, 0x00, 0x49, 0x45, 0x4E, 0x44, 0xAE,
    0x42, 0x60, 0x82
])

# Manually build multipart/form-data
boundary = '----WebKitFormBoundary7MA4YWxkTrZu0gW'
body_parts = []
body_parts.append(f'--{boundary}'.encode())
body_parts.append(b'Content-Disposition: form-data; name="userfile"; filename="test.png"')
body_parts.append(b'Content-Type: image/png')
body_parts.append(b'')
body_parts.append(png)
body_parts.append(f'--{boundary}--'.encode())

body = b'\r\n'.join(body_parts)

try:
    req = urllib.request.Request(url, data=body, method='POST')
    req.add_header('Content-Type', f'multipart/form-data; boundary={boundary}')
    req.add_header('Content-Length', str(len(body)))
    
    with urllib.request.urlopen(req, timeout=15) as response:
        print(f"[+] POST Status: {response.status}")
        resp_body = response.read().decode('utf-8', errors='replace')
        print(f"[+] POST Response:\n{resp_body}")
        
except urllib.error.HTTPError as e:
    print(f"[-] HTTP Error {e.code}: {e.reason}")
    print(f"[+] Error response: {e.read().decode('utf-8', errors='replace')}")
except Exception as e:
    print(f"[-] POST failed: {type(e).__name__}: {e}")

