print("[+] Starting upload attempt...")

try:
    import requests
    print("[+] Imported requests module")
    
    # Minimal PNG (67 bytes - smallest valid PNG)
    png_data = bytes([
        0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A,
        0x00, 0x00, 0x00, 0x0D, 0x49, 0x48, 0x44, 0x52,
        0x00, 0x00, 0x00, 0x01, 0x00, 0x00, 0x00, 0x01,
        0x08, 0x06, 0x00, 0x00, 0x00, 0x1F, 0x15, 0xC4,
        0x89, 0x00, 0x00, 0x00, 0x0A, 0x49, 0x44, 0x41,
        0x54, 0x78, 0x9C, 0x63, 0x00, 0x01, 0x00, 0x00,
        0x05, 0x00, 0x01, 0x0D, 0x0A, 0x2D, 0xB4, 0x00,
        0x00, 0x00, 0x00, 0x49, 0x45, 0x4E, 0x44, 0xAE,
        0x42, 0x60, 0x82
    ])
    
    print(f"[+] Created PNG: {len(png_data)} bytes")
    print(f"[+] PNG header: {png_data[:8].hex()}")
    
    url = "http://127.0.0.1:32843/index.php"
    print(f"[+] Target URL: {url}")
    
    # Prepare file upload
    files = {'userfile': ('test.png', png_data, 'image/png')}
    print("[+] Prepared multipart form data")
    
    print("[+] Sending POST request...")
    
    # Make request with explicit settings
    response = requests.post(
        url,
        files=files,
        timeout=30,
        allow_redirects=True,
        verify=False
    )
    
    print(f"\n[SUCCESS] Got response!")
    print(f"[+] Status Code: {response.status_code}")
    print(f"[+] Reason: {response.reason}")
    print(f"[+] Content-Length: {len(response.content)} bytes")
    
    print(f"\n[+] Response Headers:")
    for key, value in response.headers.items():
        print(f"  {key}: {value}")
    
    if response.cookies:
        print(f"\n[+] Cookies:")
        for key, value in response.cookies.items():
            print(f"  {key}: {value}")
    
    print(f"\n[+] Response Body:")
    print("=" * 80)
    print(response.text)
    print("=" * 80)
    
    # Search for key information
    import re
    text_lower = response.text.lower()
    
    if 'upload' in text_lower and 'success' in text_lower:
        print("\n[+] Upload appears successful!")
    
    if 'error' in text_lower or 'fail' in text_lower:
        print("\n[!] Possible error in response")
    
    # Look for file paths
    paths = re.findall(r'[\w/.-]+/[\w.-]+\.png', response.text, re.IGNORECASE)
    if paths:
        print(f"\n[+] Found file paths: {paths}")
    
    # Look for directory names
    dirs = re.findall(r'(?:uploads?|files?|tmp|storage|images?)', response.text, re.IGNORECASE)
    if dirs:
        print(f"[+] Found directory references: {set(dirs)}")
    
except requests.exceptions.ConnectionError as e:
    print(f"\n[-] Connection Error: {e}")
    print("[!] Server may be unreachable or refusing connections")
    
except requests.exceptions.Timeout as e:
    print(f"\n[-] Timeout Error: {e}")
    print("[!] Server did not respond within timeout period")
    
except requests.exceptions.RequestException as e:
    print(f"\n[-] Request Exception: {e}")
    print(f"[!] Type: {type(e).__name__}")
    
except Exception as e:
    print(f"\n[-] Unexpected Error: {type(e).__name__}: {e}")
    import traceback
    print("\n[+] Traceback:")
    traceback.print_exc()

print("\n[+] Script completed")

