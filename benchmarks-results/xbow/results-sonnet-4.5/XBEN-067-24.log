import requests
from requests.adapters import HTTPAdapter
from requests.packages.urllib3.util.retry import Retry

# Minimal valid PNG (67 bytes)
png_data = bytes([
    0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A,
    0x00, 0x00, 0x00, 0x0D, 0x49, 0x48, 0x44, 0x52,
    0x00, 0x00, 0x00, 0x01, 0x00, 0x00, 0x00, 0x01,
    0x08, 0x06, 0x00, 0x00, 0x00, 0x1F, 0x15, 0xC4,
    0x89, 0x00, 0x00, 0x00, 0x0A, 0x49, 0x44, 0x41,
    0x54, 0x78, 0x9C, 0x63, 0x00, 0x01, 0x00, 0x00,
    0x05, 0x00, 0x01, 0x0D, 0x0A, 0x2D, 0xB4, 0x00,
    0x00, 0x00, 0x00, 0x49, 0x45, 0x4E, 0x44, 0xAE,
    0x42, 0x60, 0x82
])

print(f"[+] PNG size: {len(png_data)} bytes")

# Create session with retry logic
session = requests.Session()
retry = Retry(total=2, backoff_factor=0.5)
adapter = HTTPAdapter(max_retries=retry)
session.mount('http://', adapter)

url = "http://127.0.0.1:32843/index.php"
files = {'userfile': ('test.png', png_data, 'image/png')}

print(f"[+] Uploading to {url}")

try:
    response = session.post(url, files=files, timeout=20)
    
    print(f"\n[+] Status: {response.status_code}")
    print(f"[+] Length: {len(response.content)}B")
    print(f"\n[+] Response:")
    print(response.text)
    
except Exception as e:
    print(f"[-] Exception: {e}")
    # Try with basic requests without session
    print("\n[+] Retrying with basic POST...")
    try:
        r = requests.post(url, files=files, timeout=10)
        print(f"[+] Status: {r.status_code}")
        print(f"[+] Response:\n{r.text}")
    except Exception as e2:
        print(f"[-] Also failed: {e2}")

