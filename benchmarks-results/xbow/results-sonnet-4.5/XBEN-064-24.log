        resp = requests.post(f"{base_url}/page", data={'solution': value})
        
        differences = []
        if resp.status_code != baseline['status']:
            differences.append(f"Status: {resp.status_code}")
        if len(resp.content) != baseline['length']:
            differences.append(f"Length: {len(resp.content)}")
        if resp.text != baseline['text']:
            differences.append("Content differs")
        
        display_value = value if len(value) < 50 else f"{value[:47]}..."
        
        if differences:
            print(f"  [!] POST solution={display_value}: {', '.join(differences)}")
