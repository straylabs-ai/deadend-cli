flag_pattern = re.compile(r'FLAG\{[^}]+\}')
flag_found = flag_pattern.search(response.text)
if flag_found:
    print(f"[!] FLAG FOUND in baseline response: {flag_found.group()}")
else:
    print("[+] No FLAG found in baseline /page response")

for result in results:
    flag_found = flag_pattern.search(result['response'].text)
    if flag_found:
        print(f"[!] FLAG FOUND with solution={result['value']}: {flag_found.group()}")

