print(f"[+] Content-Length: {len(response.content)}")
print(f"[+] Headers: {dict(response.headers)}")

if response.cookies:
    print(f"[+] Cookies: {dict(response.cookies)}")

print(f"\n[+] Full HTML Response:")
print("-" * 80)
print(response.text)
print("-" * 80)

# Parse for JavaScript elements
parser = JSExtractor()
parser.feed(response.text)

print(f"\n[+] JavaScript Analysis:")
if parser.scripts:
    print(f"\n  Scripts found: {len(parser.scripts)}")
    for i, script in enumerate(parser.scripts):
        print(f"\n  Script {i+1}:")
        for key, value in script.items():
            if key == 'code':
                print(f"    {key}:\n{value}")
            else:
                print(f"    {key}: {value}")

if parser.event_handlers:
    print(f"\n  Event handlers found: {len(parser.event_handlers)}")
    for handler in parser.event_handlers:
        print(f"    {handler}")

if parser.data_attrs:
    print(f"\n  Data attributes found: {len(parser.data_attrs)}")
    for attr in parser.data_attrs:
        print(f"    {attr}")

# Extract any URLs, endpoints, or interesting patterns
urls = re.findall(r'(?:href|src|action)=["\']([^"\']+)["\']', response.text)
if urls:
    print(f"\n[+] URLs/Endpoints found in HTML:")
    for url in set(urls):
        print(f"    {url}")

# Extract form fields
forms = re.findall(r'<form[^>]*>(.*?)</form>', response.text, re.DOTALL | re.IGNORECASE)
if forms:
    print(f"\n[+] Forms found: {len(forms)}")
    for i, form in enumerate(forms):
        print(f"\n  Form {i+1}:")
        inputs = re.findall(r'<input[^>]*>', form, re.IGNORECASE)
        for inp in inputs:
            print(f"    {inp}")

print("\n" + "=" * 80)
print("STEP 2: Testing various solution values")
