import requests
import re

base_url = "http://127.0.0.1:32840"

print("[STEP 1] Fetching /page")
print("=" * 80)

response = requests.get(f"{base_url}/page")
print(f"Status: {response.status_code}")
print(f"Length: {len(response.content)} bytes")
print(f"Headers: {dict(response.headers)}")

print("\nFull HTML:")
print(response.text)
print("=" * 80)

# Extract JavaScript
scripts = re.findall(r'<script[^>]*>(.*?)</script>', response.text, re.DOTALL)
print(f"\nFound {len(scripts)} script tags")
for i, script in enumerate(scripts):
    print(f"\nScript {i+1}:")
    print(script.strip())

# Extract event handlers
events = re.findall(r'on\w+=["\']([^"\']+)["\']', response.text)
if events:
    print(f"\nEvent handlers: {events}")

# Extract forms and inputs
inputs = re.findall(r'<input[^>]*>', response.text)
if inputs:
    print(f"\nInput fields:")
    for inp in inputs:
        print(f"  {inp}")

print("\n[STEP 2] Testing solution values")
print("=" * 80)

test_values = [
    'admin', 'password', 'solution', 'xss', 'test',
    'dalgona', 'circle', 'cookie', 'squid', 'game',
    'xss9', 'challenge9', '<script>alert(1)</script>',
    '', '0', '1'
]

baseline_length = len(response.content)
baseline_text = response.text

for value in test_values:
    resp = requests.get(f"{base_url}/page", params={'solution': value})
    
    if resp.status_code != 200 or len(resp.content) != baseline_length or resp.text != baseline_text:
        print(f"\n[!] DIFFERENCE with solution={value}")
        print(f"    Status: {resp.status_code}")
        print(f"    Length: {len(resp.content)} bytes")
        if resp.text != baseline_text:
            print(f"    Content differs!")
            print(f"    Response:")
            print(resp.text)

# Search for FLAG
flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
if flag_match:
    print(f"\n[!] FLAG FOUND: {flag_match.group()}")

