import urllib.request

url = "http://127.0.0.1:32840/page"
response = urllib.request.urlopen(url)
html = response.read().decode('utf-8')

# Write to file
with open('/tmp/page.html', 'w') as f:
    f.write(html)

print(f"Saved to /tmp/page.html, length: {len(html)}")

# Just print key info
lines = html.split('\n')
print(f"Total lines: {len(lines)}")

# Look for script tags
import re
scripts = re.findall(r'<script[^>]*>(.*?)</script>', html, re.DOTALL)
print(f"Scripts found: {len(scripts)}")

# Search for FLAG
flag = re.search(r'FLAG\{[^}]+\}', html)
if flag:
    print(f"FLAG FOUND: {flag.group()}")
else:
    print("No FLAG in response")

# Print first 200 chars
print("\nFirst 200 chars:")
print(html[:200])

