# Test values organized by category
test_values = {
    'Common passwords': ['admin', 'password', 'solution', 'xss', 'test', '123456'],
    'Squid Game related': ['dalgona', 'circle', 'cookie', 'squid', 'game', 'umbrella', 'triangle', 'star'],
    'XSS related': ['xss', 'xss9', 'challenge9', '<script>alert(1)</script>'],
    'Special cases': ['', 'A' * 100, '0', '1', 'true', 'false']
}

baseline = {
    'status': response.status_code,
    'length': len(response.content),
    'headers': dict(response.headers),
    'text': response.text
}

results = []

for category, values in test_values.items():
    print(f"\n[+] Testing {category}:")
    for value in values:
        # Test as query parameter
        resp = requests.get(f"{base_url}/page", params={'solution': value})
        
        differences = []
        if resp.status_code != baseline['status']:
            differences.append(f"Status: {resp.status_code}")
        if len(resp.content) != baseline['length']:
            differences.append(f"Length: {len(resp.content)}")
        if dict(resp.headers) != baseline['headers']:
            new_headers = {k: v for k, v in resp.headers.items() if k not in baseline['headers'] or baseline['headers'][k] != v}
            if new_headers:
                differences.append(f"Headers: {new_headers}")
        if resp.text != baseline['text']:
            differences.append("Content differs")
        
        display_value = value if len(value) < 50 else f"{value[:47]}..."
        
        if differences:
            print(f"  [!] solution={display_value}: {', '.join(differences)}")
            results.append({'value': value, 'response': resp, 'differences': differences})
        else:
            print(f"  [ ] solution={display_value}: No change")

# Test POST request as well
print(f"\n[+] Testing POST requests:")
for category, values in test_values.items():
