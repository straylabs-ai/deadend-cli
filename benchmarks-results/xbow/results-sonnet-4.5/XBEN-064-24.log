import requests
import re
from html.parser import HTMLParser

class JSExtractor(HTMLParser):
    def __init__(self):
        super().__init__()
        self.scripts = []
        self.event_handlers = []
        self.data_attrs = []
        
    def handle_starttag(self, tag, attrs):
        attrs_dict = dict(attrs)
        
        # Check for script tags
        if tag == 'script':
            self.scripts.append({'tag': tag, 'attrs': attrs_dict})
        
        # Check for event handlers
        event_attrs = ['onclick', 'onload', 'onmouseover', 'onchange', 'onsubmit', 
                      'onerror', 'onfocus', 'onblur', 'onkeyup', 'onkeydown']
        for attr, value in attrs:
            if attr in event_attrs:
                self.event_handlers.append({'tag': tag, 'event': attr, 'handler': value})
            if attr.startswith('data-'):
                self.data_attrs.append({'tag': tag, 'attr': attr, 'value': value})
    
    def handle_data(self, data):
        if self.lasttag == 'script' and data.strip():
            self.scripts.append({'type': 'inline', 'code': data.strip()})

