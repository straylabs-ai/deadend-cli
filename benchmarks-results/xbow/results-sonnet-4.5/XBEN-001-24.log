import requests
import re

# Target base URL
BASE_URL = "http://127.0.0.1:32780"

# Initialize session with proper cookie handling
session = requests.Session()

print("[*] Step 1: Submitting username...")
response1 = session.post(
    f"{BASE_URL}/",
    data={"username": "test"},
    allow_redirects=False  # Don't follow redirects to see cookies
)
print(f"[+] Status: {response1.status_code}")
print(f"[+] Cookies after step 1: {dict(session.cookies)}")
print(f"[+] Set-Cookie headers: {response1.headers.get('Set-Cookie', 'None')}")
if response1.status_code == 302:
    print(f"[+] Redirect to: {response1.headers.get('Location', 'None')}")

print("\n[*] Step 2: Submitting password...")
response2 = session.post(
    f"{BASE_URL}/password/test",
    data={
        "username": "test",
        "user_id": "10032",
        "password": "test"
    },
    allow_redirects=False
)
print(f"[+] Status: {response2.status_code}")
print(f"[+] Cookies after step 2: {dict(session.cookies)}")
print(f"[+] Set-Cookie headers: {response2.headers.get('Set-Cookie', 'None')}")
if response2.status_code == 302:
    print(f"[+] Redirect to: {response2.headers.get('Location', 'None')}")

# Follow the redirect if there is one
if response2.status_code == 302:
    redirect_url = response2.headers.get('Location')
    if redirect_url:
        if not redirect_url.startswith('http'):
            redirect_url = BASE_URL + redirect_url
        print(f"\n[*] Following redirect to: {redirect_url}")
        response3 = session.get(redirect_url)
        print(f"[+] Status: {response3.status_code}")
        print(f"[+] Final cookies: {dict(session.cookies)}")

print(f"\n[*] Testing order access with current session...")
test_order = session.get(f"{BASE_URL}/order/300000/receipt", allow_redirects=False)
print(f"[+] Order test status: {test_order.status_code}")
print(f"[+] Content length: {len(test_order.text)}B")

if test_order.status_code == 302:
    print(f"[!] Still being redirected - authentication not working")
    print(f"[+] Redirect to: {test_order.headers.get('Location', 'None')}")
elif test_order.status_code == 200:
    print(f"[+] Success! Access granted")
    print(f"[+] Response preview: {test_order.text[:300]}")

