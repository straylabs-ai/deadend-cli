import requests
from bs4 import BeautifulSoup
import re
from urllib.parse import urljoin, urlparse, parse_qs

# Target URL
base_url = "http://127.0.0.1:32780/"

# Create session to maintain cookies
session = requests.Session()

print("[*] Sending POST request to authenticate...")
print(f"[*] URL: {base_url}")
print(f"[*] Form data: username=test")
print()

# Send POST request with form data
try:
    response = session.post(
        base_url,
        data={"username": "test"},
        allow_redirects=True
    )
    
    print(f"[+] Request completed")
    print(f"[+] Final URL after redirects: {response.url}")
    print(f"[+] Status Code: {response.status_code}")
    print(f"[+] Response Time: {response.elapsed.total_seconds()}s")
    print()
    
    # Extract session cookies
    print("="*80)
    print("SESSION COOKIES")
    print("="*80)
    if session.cookies:
        for cookie in session.cookies:
            print(f"[+] Cookie: {cookie.name} = {cookie.value}")
            print(f"    Domain: {cookie.domain}, Path: {cookie.path}")
    else:
        print("[-] No session cookies received")
    print()
    
    # Determine authentication status
    print("="*80)
    print("AUTHENTICATION STATUS")
    print("="*80)
    auth_indicators = [
        ("welcome", True),
        ("dashboard", True),
        ("logout", True),
        ("logged in", True),
        ("login failed", False),
        ("invalid", False),
        ("error", False)
    ]
    
    response_lower = response.text.lower()
    auth_status = "UNKNOWN"
    
    for indicator, is_success in auth_indicators:
        if indicator in response_lower:
            auth_status = "SUCCESS" if is_success else "FAILED"
            print(f"[+] Authentication: {auth_status}")
            print(f"[+] Indicator found: '{indicator}'")
            break
    
    if auth_status == "UNKNOWN":
        if response.status_code == 200:
            auth_status = "LIKELY SUCCESS (200 OK)"
        print(f"[+] Authentication: {auth_status}")
    print()
    
    # Parse HTML
    soup = BeautifulSoup(response.text, 'html.parser')
    
    # Extract all links
    print("="*80)
    print("DISCOVERED ENDPOINTS AND LINKS")
    print("="*80)
    links = set()
    for tag in soup.find_all(['a', 'link', 'script', 'img', 'form']):
        href = tag.get('href') or tag.get('src') or tag.get('action')
        if href:
            full_url = urljoin(response.url, href)
            links.add(full_url)
    
    for link in sorted(links):
        print(f"[+] {link}")
    print(f"\n[+] Total unique URLs found: {len(links)}")
    print()
    
    # Extract ID parameters
    print("="*80)
    print("ID PARAMETERS FOUND")
    print("="*80)
    id_patterns = [
        r'[?&](id|user_id|trade_id|transaction_id|account_id|profile_id|item_id|order_id)=(\d+)',
        r'/(\d+)(?:/|$)',  # Numeric path segments
    ]
    
    id_params = set()
    
    # Check all links for ID parameters
    for link in links:
        parsed = urlparse(link)
        query_params = parse_qs(parsed.query)
        
        # Check query parameters
        for param, values in query_params.items():
            if 'id' in param.lower() or param.lower() in ['user', 'trade', 'transaction', 'account']:
                for value in values:
                    id_params.add(f"{param}={value} (in {link})")
        
        # Check for numeric path segments
        path_segments = [s for s in parsed.path.split('/') if s.isdigit()]
        for segment in path_segments:
            id_params.add(f"Path segment: {segment} (in {link})")
    
    # Also scan response body for ID patterns
    for pattern in id_patterns:
        matches = re.finditer(pattern, response.text)
        for match in matches:
            if len(match.groups()) >= 2:
                id_params.add(f"{match.group(1)}={match.group(2)} (in response body)")
            elif len(match.groups()) == 1:
                id_params.add(f"Numeric value: {match.group(1)} (in response body)")
    
    if id_params:
        for param in sorted(id_params):
            print(f"[+] {param}")
    else:
        print("[-] No ID parameters found")
    print()
    
    # Extract forms
    print("="*80)
    print("FORMS DISCOVERED")
    print("="*80)
    forms = soup.find_all('form')
    if forms:
        for i, form in enumerate(forms, 1):
            print(f"\n[+] Form #{i}")
            print(f"    Action: {form.get('action', 'Not specified')}")
            print(f"    Method: {form.get('method', 'GET').upper()}")
            inputs = form.find_all(['input', 'textarea', 'select'])
            if inputs:
                print(f"    Input fields:")
                for inp in inputs:
                    name = inp.get('name', 'unnamed')
                    inp_type = inp.get('type', inp.name)
                    value = inp.get('value', '')
                    print(f"      - {name} (type: {inp_type}, value: {value})")
    else:
        print("[-] No forms found")
    print()
    
    # Response headers
    print("="*80)
    print("RESPONSE HEADERS")
    print("="*80)
    for header, value in response.headers.items():
        print(f"[+] {header}: {value}")
    print()
    
    # Full HTML response
    print("="*80)
    print("FULL HTML RESPONSE")
    print("="*80)
    print(response.text)
    
except requests.exceptions.RequestException as e:
    print(f"[-] Request failed: {e}")
except Exception as e:
    print(f"[-] Error: {e}")
    import traceback
    traceback.print_exc()

