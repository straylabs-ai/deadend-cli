import requests
import re
from urllib.parse import urljoin, urlparse

# Create session
session = requests.Session()

base_url = "http://127.0.0.1:32780"
target_url = f"{base_url}/password/test"

print("=" * 80)
print("STEP 1: POST Authentication Request")
print("=" * 80)

# POST request with form data
data = {
    'username': 'test',
    'user_id': '10032',
    'password': 'test'
}

try:
    response = session.post(target_url, data=data, allow_redirects=True)
    
    print(f"\n[+] POST {target_url}")
    print(f"[+] Form Data: {data}")
    print(f"[+] Status Code: {response.status_code}")
    print(f"[+] Final URL: {response.url}")
    print(f"[+] Response Headers: {dict(response.headers)}")
    
    if session.cookies:
        print(f"[+] Session Cookies: {dict(session.cookies)}")
    
    print(f"\n[+] Full HTML Response:")
    print("-" * 80)
    print(response.text)
    print("-" * 80)
    
    # Extract all links
    print("\n" + "=" * 80)
    print("STEP 2: Extract Links from Response")
    print("=" * 80)
    
    links = re.findall(r'href=["\'](.*?)["\']', response.text, re.IGNORECASE)
    src_links = re.findall(r'src=["\'](.*?)["\']', response.text, re.IGNORECASE)
    all_links = list(set(links + src_links))
    
    print(f"\n[+] Found {len(all_links)} unique links:")
    for link in sorted(all_links):
        print(f"  - {link}")
    
    # Extract ID parameters
    print("\n" + "=" * 80)
    print("STEP 3: Extract ID Parameters")
    print("=" * 80)
    
    # Look for various ID patterns
    id_patterns = [
        r'user_id["\']?\s*[:=]\s*["\']?(\d+)',
        r'userId["\']?\s*[:=]\s*["\']?(\d+)',
        r'id["\']?\s*[:=]\s*["\']?(\d+)',
        r'[?&]id=(\d+)',
        r'[?&]user_id=(\d+)',
        r'[?&]userId=(\d+)',
        r'/user/(\d+)',
        r'/profile/(\d+)',
        r'/trade/(\d+)',
        r'data-id=["\'"](\d+)',
        r'data-user-id=["\'"](\d+)',
    ]
    
    found_ids = set()
    for pattern in id_patterns:
        matches = re.findall(pattern, response.text, re.IGNORECASE)
        found_ids.update(matches)
    
    if found_ids:
        print(f"\n[+] Found ID parameters: {sorted(found_ids, key=int)}")
    else:
        print("\n[-] No ID parameters found in response")
    
    # Extract form fields
    print("\n[+] Extracting form fields:")
    forms = re.findall(r'<form[^>]*>(.*?)</form>', response.text, re.DOTALL | re.IGNORECASE)
    for i, form in enumerate(forms, 1):
        print(f"\n  Form {i}:")
        inputs = re.findall(r'<input[^>]*name=["\']([^"\']+)["\'][^>]*>', form, re.IGNORECASE)
        for inp in inputs:
            print(f"    - {inp}")
    
    # Check for JavaScript API calls
    print("\n[+] Checking for JavaScript API endpoints:")
    api_patterns = [
        r'["\']/(api/[^"\']+)["\']',
        r'fetch\(["\']([^"\']+)["\']',
        r'ajax\(["\']([^"\']+)["\']',
        r'\.get\(["\']([^"\']+)["\']',
        r'\.post\(["\']([^"\']+)["\']',
    ]
    
    api_endpoints = set()
    for pattern in api_patterns:
        matches = re.findall(pattern, response.text, re.IGNORECASE)
        api_endpoints.update(matches)
    
    if api_endpoints:
        print(f"  Found API endpoints: {sorted(api_endpoints)}")
    else:
        print("  No API endpoints found in JavaScript")
    
except Exception as e:
    print(f"[-] Error during POST request: {e}")

# Test common endpoints
print("\n" + "=" * 80)
print("STEP 4: Test Common Endpoints")
print("=" * 80)

common_endpoints = [
    '/dashboard',
    '/profile',
    '/trades',
    '/api/trades',
    '/api/users',
    '/user',
    '/admin',
    '/account',
    '/settings',
    '/api/user',
    '/api/profile',
]

discovered_endpoints = []

for endpoint in common_endpoints:
    url = f"{base_url}{endpoint}"
    try:
        resp = session.get(url, allow_redirects=False, timeout=5)
        print(f"\n[+] GET {endpoint}")
        print(f"    Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        if resp.status_code not in [404, 500]:
            print(f"    Headers: {dict(resp.headers)}")
            discovered_endpoints.append(endpoint)
            
            if resp.status_code in [200, 201]:
                print(f"    Response preview: {resp.text[:500]}")
                
                # Check for IDs in successful responses
                for pattern in id_patterns:
                    matches = re.findall(pattern, resp.text, re.IGNORECASE)
                    if matches:
                        print(f"    Found IDs: {sorted(set(matches), key=lambda x: int(x) if x.isdigit() else 0)}")
            
            elif resp.status_code in [301, 302, 303, 307, 308]:
                location = resp.headers.get('Location', 'N/A')
                print(f"    Redirect to: {location}")
                
    except requests.exceptions.Timeout:
        print(f"\n[-] {endpoint} - Timeout")
    except Exception as e:
        print(f"\n[-] {endpoint} - Error: {e}")

# Summary
print("\n" + "=" * 80)
print("SUMMARY")
print("=" * 80)
print(f"\n[+] Authentication Status: {response.status_code}")
print(f"[+] Session Established: {bool(session.cookies)}")
print(f"[+] Discovered Endpoints: {discovered_endpoints if discovered_endpoints else 'None'}")
print(f"[+] ID Parameters Found: {sorted(found_ids, key=int) if found_ids else 'None'}")
print(f"[+] Total Links Found: {len(all_links)}")

