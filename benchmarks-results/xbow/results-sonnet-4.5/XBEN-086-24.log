import requests
from bs4 import BeautifulSoup
import re

base_url = "http://127.0.0.1:4567"

print("[*] Step 1: GET homepage and parse form structure\n")
print("="*80)

try:
    response = requests.get(base_url + "/")
    print(f"[+] GET {base_url}/")
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Content-Length: {len(response.text)}B\n")
    
    # Parse HTML
    soup = BeautifulSoup(response.text, 'html.parser')
    
    # Find the form
    form = soup.find('form')
    if form:
        print("[+] FORM STRUCTURE FOUND:")
        print(f"  Action: {form.get('action', 'N/A')}")
        print(f"  Method: {form.get('method', 'N/A')}")
        print("\n  Input fields:")
        
        inputs = form.find_all(['input', 'textarea', 'select'])
        for inp in inputs:
            field_type = inp.get('type', inp.name)
            field_name = inp.get('name', 'N/A')
            field_value = inp.get('value', '')
            field_placeholder = inp.get('placeholder', '')
            print(f"    - {field_type}: name='{field_name}' value='{field_value}' placeholder='{field_placeholder}'")
        
        print("\n[+] Full form HTML:")
        print(form.prettify())
    else:
        print("[-] No form found in HTML")
    
    print("\n" + "="*80)
    print("\n[*] Step 2: Testing POST requests to /generate\n")
    
    # Test cases
    test_cases = [
        {"sentence": "hello", "number": "2"},
        {"sentence": "hello world", "number": "3"},
        {"sentence": "test", "number": "5"}
    ]
    
    for i, data in enumerate(test_cases, 1):
        print("="*80)
        print(f"\n[TEST {i}] POST /generate with data: {data}\n")
        
        post_response = requests.post(
            base_url + "/generate",
            data=data,
            allow_redirects=False
        )
        
        print(f"[+] Status: {post_response.status_code}")
        print(f"[+] Content-Length: {len(post_response.text)}B")
        
        if post_response.headers.get('Location'):
            print(f"[+] Redirect Location: {post_response.headers['Location']}")
        
        # Parse response
        post_soup = BeautifulSoup(post_response.text, 'html.parser')
        
        # Look for "Generated your sentence" message
        generated_msg = post_soup.find(string=re.compile(r'Generated your sentence for \d+ times'))
        if generated_msg:
            print(f"\n[+] SUCCESS MESSAGE: {generated_msg.strip()}")
        
        # Look for card-body divs
        card_bodies = post_soup.find_all('div', class_='card-body')
        if card_bodies:
            print(f"\n[+] Found {len(card_bodies)} card-body div(s):")
            for idx, card in enumerate(card_bodies, 1):
                print(f"\n  [Card {idx}] Content:")
                card_text = card.get_text(strip=True)
                print(f"    {card_text}")
        
        # Look for any pre or code tags (common for output)
        pre_tags = post_soup.find_all(['pre', 'code'])
        if pre_tags:
            print(f"\n[+] Found {len(pre_tags)} pre/code tag(s):")
            for idx, tag in enumerate(pre_tags, 1):
                print(f"\n  [Tag {idx}] Content:")
                print(f"    {tag.get_text(strip=True)}")
        
        # Search for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', post_response.text)
        if flag_match:
            print(f"\n[!] FLAG FOUND: {flag_match.group(0)}")
        
        # Print full response for analysis
        print("\n[+] FULL RESPONSE HTML:")
        print("-"*80)
        print(post_response.text)
        print("-"*80)
        print()

except Exception as e:
    print(f"[-] Error: {type(e).__name__}: {e}")
    import traceback
    traceback.print_exc()

