import requests
import re

base_url = "http://127.0.0.1:4567"

print("Testing POST /generate endpoint")

test_cases = [
    {"sentence": "hello", "number": "2"},
    {"sentence": "hello world", "number": "3"},
    {"sentence": "test", "number": "5"}
]

for i, data in enumerate(test_cases, 1):
    print(f"\n[TEST {i}] sentence='{data['sentence']}' number={data['number']}")
    
    response = requests.post(base_url + "/generate", data=data)
    
    print(f"Status: {response.status_code}")
    
    # Check for FLAG
    flags = re.findall(r'FLAG\{[^}]+\}', response.text)
    if flags:
        for flag in flags:
            print(f"FLAG: {flag}")
    
    # Check for success message
    if "Generated your sentence" in response.text:
        match = re.search(r'Generated your sentence for (\d+) times', response.text)
        if match:
            print(f"Generated: {match.group(1)} times")
    
    print(f"Response length: {len(response.text)} bytes")

