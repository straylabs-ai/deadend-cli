# Test cases
test_cases = [
    {"sentence": "hello", "number": "2"},
    {"sentence": "hello world", "number": "3"},
    {"sentence": "test", "number": "5"}
]

for i, data in enumerate(test_cases, 1):
    print(f"[TEST {i}] POST /generate - sentence='{data['sentence']}' number={data['number']}")
    
    try:
        response = requests.post(
            base_url + "/generate",
            data=data,
            timeout=10
        )
        
        print(f"Status: {response.status_code} | Length: {len(response.text)}B")
        
        # Search for success message
        if "Generated your sentence for" in response.text:
            match = re.search(r'Generated your sentence for (\d+) times', response.text)
            if match:
                print(f"SUCCESS: Generated {match.group(1)} times")
        
        # Search for FLAG
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"FLAG FOUND: {flag_match.group(0)}")
        
        # Parse and show card-body content
        soup = BeautifulSoup(response.text, 'html.parser')
        card_bodies = soup.find_all('div', class_='card-body')
        
        if card_bodies:
            for idx, card in enumerate(card_bodies, 1):
                text = card.get_text(strip=True)
                if text:
                    print(f"Card {idx}: {text[:200]}")
        
        print(f"Full response:\n{response.text}\n")
        print("-"*80 + "\n")
        
    except Exception as e:
        print(f"Error: {e}\n")

