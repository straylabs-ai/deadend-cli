    sys.exit(1)
except Exception as e:
    print(f"    Failed: {type(e).__name__}: {e}")
    sys.exit(1)

# Step 4: Prepare request
print("[4] Preparing HTTP request...")
request = (
    b"GET /.git/HEAD HTTP/1.1\r\n"
    b"Host: 127.0.0.1\r\n"
    b"X-Original-URL: /.git/HEAD\r\n"
    b"User-Agent: Python\r\n"
    b"Connection: close\r\n"
    b"\r\n"
)
print(f"    Request prepared ({len(request)} bytes)")

# Step 5: Send request
print("[5] Sending request...")
try:
    sent = s.send(request)
    print(f"    Sent {sent} bytes")
except BrokenPipeError:
    print("    BrokenPipeError during send - server closed connection")
    s.close()
    sys.exit(1)
except Exception as e:
    print(f"    Failed: {type(e).__name__}: {e}")
    s.close()
    sys.exit(1)

# Step 6: Receive response
print("[6] Receiving response...")
try:
    response = b""
    while True:
        chunk = s.recv(1024)
        if not chunk:
            print("    Connection closed by server")
            break
        response += chunk
        print(f"    Received {len(chunk)} bytes (total: {len(response)})")
        
    s.close()
    
    print(f"\n[7] Response received ({len(response)} bytes total):")
    print("="*70)
    print(response.decode(errors='replace'))
    print("="*70)
    
except Exception as e:
    print(f"    Failed: {type(e).__name__}: {e}")
    s.close()

