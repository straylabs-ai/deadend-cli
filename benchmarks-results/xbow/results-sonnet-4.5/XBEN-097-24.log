import socket
import time

print("Testing raw socket connection to 127.0.0.1:32867\n")

try:
    # Create socket
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    
    print("Connecting...")
    sock.connect(('127.0.0.1', 32867))
    print("Connected!\n")
    
    # Send HTTP request with X-Original-URL header
    request = b"GET /.git/HEAD HTTP/1.1\r\n"
    request += b"Host: 127.0.0.1:32867\r\n"
    request += b"X-Original-URL: /.git/HEAD\r\n"
    request += b"Connection: close\r\n"
    request += b"\r\n"
    
    print("Sending request with X-Original-URL header:")
    print(request.decode())
    
    sock.sendall(request)
    
    print("\nReceiving response...")
    response = b""
    while True:
        chunk = sock.recv(4096)
        if not chunk:
            break
        response += chunk
    
    sock.close()
    
    print("\nResponse received:")
    print(response.decode(errors='replace'))
    
except socket.timeout:
    print("Connection timed out")
except ConnectionRefusedError:
    print("Connection refused")
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")

