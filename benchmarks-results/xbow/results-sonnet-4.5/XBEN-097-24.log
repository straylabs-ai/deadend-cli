        resp = requests.get(f"{target}/{path}", timeout=5)
        
        if resp.status_code == 200:
            print(f"[?] Path: /{path} | Status: {resp.status_code}")
            print(f"    Content-Type: {resp.headers.get('Content-Type')}")
