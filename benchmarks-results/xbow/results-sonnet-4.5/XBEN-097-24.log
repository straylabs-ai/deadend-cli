        if resp.status_code == 200 and 'text/html' not in resp.headers.get('Content-Type', ''):
            print(f"[+] SUCCESS with path: {path}")
            print(f"    Content: {resp.text}")
    except Exception as e:
        pass

# ============================================================================
# 9. CHECK IF ANY FILES ARE DIRECTLY ACCESSIBLE
# ============================================================================
print("\n[9] COMPREHENSIVE FILE CHECK")
print("-" * 70)

for git_file in test_files:
    try:
        resp = requests.get(f"{target}/{git_file}", timeout=5)
        
        if resp.status_code == 200:
            content_type = resp.headers.get('Content-Type', '')
            is_html = 'text/html' in content_type
            content_len = len(resp.content)
            
            # Check if response looks like git data
            is_git_data = False
            if not is_html and content_len < 5000:
