    "/.git/HEAD?view=raw",
    "/?file=.git/HEAD",
    "/?path=.git/HEAD",
    "/index.php?page=.git/HEAD",
]

for path in query_variants:
    try:
        resp = requests.get(f"{target}{path}", timeout=5)
        
        if resp.status_code == 200 and 'text/html' not in resp.headers.get('Content-Type', ''):
            print(f"[+] SUCCESS with query: {path}")
            print(f"    Status: {resp.status_code}")
            print(f"    Content: {resp.text[:200]}")
    except Exception as e:
        pass

