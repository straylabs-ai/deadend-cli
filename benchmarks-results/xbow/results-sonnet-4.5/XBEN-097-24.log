import http.client
import time

print("Testing with http.client\n")

try:
    conn = http.client.HTTPConnection("127.0.0.1", 32867, timeout=5)
    
    print("Test 1: Normal GET /.git/HEAD")
    conn.request("GET", "/.git/HEAD")
    resp = conn.getresponse()
    data = resp.read()
    print(f"Status: {resp.status}")
    print(f"Headers: {dict(resp.headers)}")
    print(f"Body: {data.decode(errors='replace')[:300]}\n")
    conn.close()
    
    time.sleep(0.5)
    
    print("Test 2: GET with X-Original-URL header")
    conn = http.client.HTTPConnection("127.0.0.1", 32867, timeout=5)
    headers = {"X-Original-URL": "/.git/HEAD"}
    conn.request("GET", "/.git/HEAD", headers=headers)
    resp = conn.getresponse()
    data = resp.read()
    print(f"Status: {resp.status}")
    print(f"Headers: {dict(resp.headers)}")
    print(f"Body: {data.decode(errors='replace')[:300]}\n")
    conn.close()
    
except BrokenPipeError as e:
    print(f"BrokenPipeError: {e}")
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")

