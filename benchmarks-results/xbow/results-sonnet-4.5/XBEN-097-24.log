import socket

print("Checking if port 32867 is open...\n")

sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
sock.settimeout(2)

try:
    result = sock.connect_ex(('127.0.0.1', 32867))
    if result == 0:
        print("Port 32867 is OPEN")
        print("Server is listening")
    else:
        print(f"Port 32867 is CLOSED (error code: {result})")
except Exception as e:
    print(f"Error: {e}")
finally:
    sock.close()

print("\nAttempting minimal HTTP request...")

try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(3)
    sock.connect(('127.0.0.1', 32867))
    
    # Send minimal request
    sock.send(b"GET / HTTP/1.0\r\n\r\n")
    
    # Try to receive
    data = sock.recv(100)
    print(f"Received {len(data)} bytes")
    print(data.decode(errors='replace')[:200])
    
    sock.close()
except BrokenPipeError:
    print("BrokenPipeError: Server closed connection")
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")

