# ============================================================================
print("\n[8] DOUBLE SLASH VARIATIONS")
print("-" * 70)

double_slash_variants = [
    "//.git/HEAD",
    "/.git//HEAD",
    "//.git//HEAD",
    "////.git////HEAD",
]

for path in double_slash_variants:
    try:
