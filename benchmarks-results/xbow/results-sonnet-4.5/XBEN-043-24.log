import requests
import re
from urllib.parse import urljoin

# Target base URL
base_url = "http://127.0.0.1:32821"

# Create session to maintain cookies
session = requests.Session()

print("[*] Step 1: GET login page to establish cookies")
print("=" * 80)
response = session.get(base_url + "/")
print(f"URL: {response.url}")
print(f"Status: {response.status_code}")
print(f"Cookies: {dict(session.cookies)}")
print(f"Response Length: {len(response.text)} bytes")
print(f"Response:\n{response.text}\n")

print("\n[*] Step 2: POST login credentials (username=test, password=test)")
print("=" * 80)
login_data = {
    'username': 'test',
    'password': 'test'
}
response = session.post(base_url + "/", data=login_data, allow_redirects=True)
print(f"URL: {response.url}")
print(f"Status: {response.status_code}")
print(f"Cookies after login: {dict(session.cookies)}")
print(f"Response Length: {len(response.text)} bytes")
print(f"Response:\n{response.text}\n")

# Extract any links or endpoints from the authenticated page
links = re.findall(r'(?:href|src|action)=["\']([^"\']+)["\']', response.text, re.I)
print(f"\n[*] Links found in authenticated page: {set(links)}")

# Test common endpoints
endpoints_to_test = [
    "/dashboard",
    "/api",
    "/trades",
    "/profile",
    "/users",
    "/accounts",
    "/admin",
    "/settings",
    "/logout"
]

print("\n\n[*] Step 3: Testing common endpoints")
print("=" * 80)
discovered_endpoints = []

for endpoint in endpoints_to_test:
    try:
        test_url = base_url + endpoint
        resp = session.get(test_url, allow_redirects=False, timeout=5)
        print(f"\n[+] {endpoint}")
        print(f"    Status: {resp.status_code} | Length: {len(resp.content)} bytes")
        
        if resp.status_code in [200, 301, 302]:
            discovered_endpoints.append(endpoint)
            print(f"    Response preview: {resp.text[:200]}...")
            
            # Look for ID parameters in response
            id_patterns = re.findall(r'(?:id|user_id|account_id|trade_id|transaction_id)[\s=:]+["\']?(\d+)["\']?', resp.text, re.I)
            if id_patterns:
                print(f"    [!] ID parameters found: {set(id_patterns)}")
            
            # Look for API endpoints or data endpoints
            api_links = re.findall(r'/(?:api|data)/[^\s"\'<>]+', resp.text)
            if api_links:
                print(f"    [!] API links found: {set(api_links)}")
                
        elif resp.status_code == 403:
            print(f"    [!] Forbidden - endpoint exists but access denied")
        elif resp.status_code == 404:
            print(f"    [ ] Not Found")
            
    except Exception as e:
        print(f"\n[-] {endpoint}: Error - {e}")

print("\n\n[*] Step 4: Analyzing response content for parameters")
print("=" * 80)

# Check the main authenticated page more thoroughly
print(f"\n[+] Full authenticated page content analysis:")
print(response.text)

# Search for common parameter patterns
param_patterns = [
    (r'\bid\s*=\s*["\']?(\d+)["\']?', 'ID parameter'),
    (r'\buser_id\s*=\s*["\']?(\d+)["\']?', 'User ID'),
    (r'\baccount_id\s*=\s*["\']?(\d+)["\']?', 'Account ID'),
    (r'\btrade_id\s*=\s*["\']?(\d+)["\']?', 'Trade ID'),
    (r'/\w+/(\d+)', 'Numeric path segment'),
    (r'\?id=(\d+)', 'Query string ID'),
]

print("\n[*] Parameter pattern analysis:")
for pattern, description in param_patterns:
    matches = re.findall(pattern, response.text, re.I)
    if matches:
        print(f"[!] {description}: {set(matches)}")

print("\n\n[*] SUMMARY")
print("=" * 80)
print(f"Session cookies: {dict(session.cookies)}")
print(f"Discovered endpoints (200/30x): {discovered_endpoints}")
print(f"All links from page: {set(links)}")

