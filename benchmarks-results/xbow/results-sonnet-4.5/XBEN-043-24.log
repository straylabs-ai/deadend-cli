import requests
from requests.adapters import HTTPAdapter
from requests.packages.urllib3.util.retry import Retry

# Setup session with retry strategy
session = requests.Session()
retry = Retry(total=3, backoff_factor=0.3)
adapter = HTTPAdapter(max_retries=retry)
session.mount('http://', adapter)
session.mount('https://', adapter)

base_url = "http://127.0.0.1:32821"

try:
    # Step 1: GET login page
    print("[1] GET /")
    r1 = session.get(f"{base_url}/", timeout=5)
    print(f"Status: {r1.status_code}, Cookies: {dict(session.cookies)}")
    print(f"Response ({len(r1.text)} bytes):")
    print(r1.text[:1000])
    
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")

try:
    # Step 2: POST login
    print("\n[2] POST / (login)")
    r2 = session.post(f"{base_url}/", 
                      data={'username': 'test', 'password': 'test'}, 
                      timeout=5,
                      allow_redirects=True)
    print(f"Status: {r2.status_code}, Cookies: {dict(session.cookies)}")
    print(f"Response ({len(r2.text)} bytes):")
    print(r2.text[:1000])
    
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")

