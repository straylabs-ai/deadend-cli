import requests
import re

base_url = "http://127.0.0.1:32821"
session = requests.Session()

# Step 1: GET login page
print("[GET] http://127.0.0.1:32821/")
resp1 = session.get(base_url + "/")
print(f"Status: {resp1.status_code}")
print(f"Cookies: {dict(session.cookies)}")
print(f"Response:\n{resp1.text}\n")

# Step 2: POST login
print("\n[POST] Login with username=test, password=test")
login_data = {'username': 'test', 'password': 'test'}
resp2 = session.post(base_url + "/", data=login_data, allow_redirects=True)
print(f"Status: {resp2.status_code}")
print(f"Final URL: {resp2.url}")
print(f"Cookies: {dict(session.cookies)}")
print(f"Response:\n{resp2.text}\n")

# Step 3: Test endpoints
endpoints = ["/dashboard", "/api", "/trades", "/profile", "/users", "/accounts"]
print("\n[*] Testing endpoints:")
for ep in endpoints:
    try:
        r = session.get(base_url + ep, timeout=3)
        print(f"\n{ep}: Status {r.status_code}, Length {len(r.text)}")
        if r.status_code == 200:
            print(f"Response: {r.text[:500]}")
    except Exception as e:
        print(f"{ep}: Error - {e}")

