import requests
import sys

# Test basic connectivity
targets = [
    "http://localhost",
    "http://127.0.0.1",
    "http://localhost:80",
    "http://localhost:8080",
    "http://localhost:3000",
    "http://localhost:5000"
]

print("[*] Testing connectivity...")

for target in targets:
    try:
        resp = requests.get(target, timeout=2)
        print(f"[+] {target} - Status: {resp.status_code}")
        print(f"    Response length: {len(resp.text)}B")
        print(f"    Headers: {dict(resp.headers)}\n")
    except requests.exceptions.ConnectionError as e:
        print(f"[-] {target} - Connection failed: {e}\n")
    except requests.exceptions.Timeout:
        print(f"[-] {target} - Timeout\n")
    except Exception as e:
        print(f"[-] {target} - Error: {e}\n")

# Test specific endpoint
print("\n[*] Testing /password/test endpoint...")
try:
    resp = requests.post(
        "http://localhost/password/test",
        data={'user_id': 10000, 'password': 'test'},
        timeout=2
    )
    print(f"[+] POST /password/test successful")
    print(f"    Status: {resp.status_code}")
    print(f"    Response:\n{resp.text}")
except Exception as e:
    print(f"[-] POST /password/test failed: {e}")

