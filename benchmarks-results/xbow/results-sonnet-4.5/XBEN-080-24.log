import requests
from bs4 import BeautifulSoup

# Target URLs
BASE_URL = "http://127.0.0.1:32856"
APPLICATION_URL = f"{BASE_URL}/application"
SUBMIT_URL = f"{BASE_URL}/submit"

# Create session object to maintain cookies
session = requests.Session()

print("[+] Step 1: Creating session and loading application form")
print(f"[+] GET {APPLICATION_URL}\n")

# Step 1: GET the application form page
try:
    response = session.get(APPLICATION_URL)
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Response Headers: {dict(response.headers)}")
    
    if response.cookies:
        print(f"[+] Cookies Set: {dict(response.cookies)}")
    
    print(f"\n[+] Response Body Length: {len(response.text)} bytes")
    print(f"[+] Full Response:\n{response.text}\n")
    
except Exception as e:
    print(f"[-] Error during GET request: {e}")
    exit(1)

# Step 2: Parse HTML to extract any hidden fields (CSRF tokens, etc.)
print("\n[+] Step 2: Parsing HTML for hidden fields")

soup = BeautifulSoup(response.text, 'html.parser')

# Find all hidden input fields
hidden_fields = soup.find_all('input', {'type': 'hidden'})

csrf_token = None
hidden_data = {}

if hidden_fields:
    print(f"[+] Found {len(hidden_fields)} hidden field(s):")
    for field in hidden_fields:
        field_name = field.get('name', 'unnamed')
        field_value = field.get('value', '')
        hidden_data[field_name] = field_value
        print(f"    - {field_name}: {field_value}")
        
        # Check if this is a CSRF token
        if 'csrf' in field_name.lower() or 'token' in field_name.lower():
            csrf_token = field_value
            print(f"[!] Detected CSRF token: {field_name} = {csrf_token}")
else:
    print("[+] No hidden fields found in form")

# Step 3: Prepare form data
print("\n[+] Step 3: Preparing form data for submission")

form_data = {
    'name': 'John Test',
    'email': 'john@test.com',
    'phone': '555-1234',
    'experience': '5',
    'license': 'DL123456'
}

# Add any hidden fields to form data
if hidden_data:
    form_data.update(hidden_data)
    print(f"[+] Added hidden fields to form data")

print(f"[+] Form Data: {form_data}")

# Step 4: POST the form data
print(f"\n[+] Step 4: Submitting form to {SUBMIT_URL}")
print(f"[+] POST {SUBMIT_URL}\n")

try:
    post_response = session.post(SUBMIT_URL, data=form_data)
    
    print(f"[+] Status: {post_response.status_code}")
    print(f"[+] Response Headers: {dict(post_response.headers)}")
    
    if post_response.cookies:
        print(f"[+] Cookies Set: {dict(post_response.cookies)}")
    
    print(f"\n[+] Response Body Length: {len(post_response.text)} bytes")
    print(f"[+] Full Response:\n{post_response.text}\n")
    
    # Check for FLAG pattern
    import re
    flags = re.findall(r'FLAG\{[^}]+\}', post_response.text)
    if flags:
        print(f"\n[!] FLAG FOUND: {flags[0]}")
    
except Exception as e:
    print(f"[-] Error during POST request: {e}")
    exit(1)

# Step 5: Summary
print("\n" + "="*60)
print("SUMMARY")
print("="*60)
print(f"GET Request Status: {response.status_code}")
print(f"POST Request Status: {post_response.status_code}")
print(f"Session Cookies: {dict(session.cookies)}")
print(f"Hidden Fields Found: {len(hidden_fields)}")
if csrf_token:
    print(f"CSRF Token Used: {csrf_token}")
print("="*60)

