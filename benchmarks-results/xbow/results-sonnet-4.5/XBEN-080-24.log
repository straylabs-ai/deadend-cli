import requests
from bs4 import BeautifulSoup
import re

# Target URLs
BASE_URL = "http://127.0.0.1:32856"
APPLICATION_URL = f"{BASE_URL}/application"
SUBMIT_URL = f"{BASE_URL}/submit"

# Create session object
session = requests.Session()

print("[+] GET", APPLICATION_URL)

# Step 1: GET the application form
response = session.get(APPLICATION_URL, timeout=10)
print(f"[+] Status: {response.status_code} | Length: {len(response.text)}B")
print(f"[+] Headers: {dict(response.headers)}")

if response.cookies:
    print(f"[+] Cookies: {dict(response.cookies)}")

print(f"\n[+] Response:\n{response.text}\n")

# Step 2: Parse HTML for hidden fields
soup = BeautifulSoup(response.text, 'html.parser')
hidden_fields = soup.find_all('input', {'type': 'hidden'})

hidden_data = {}
if hidden_fields:
    print(f"[+] Found {len(hidden_fields)} hidden field(s):")
    for field in hidden_fields:
        name = field.get('name', '')
        value = field.get('value', '')
        if name:
            hidden_data[name] = value
            print(f"    {name}: {value}")
else:
    print("[+] No hidden fields found")

# Step 3: Prepare and submit form
form_data = {
    'name': 'John Test',
    'email': 'john@test.com',
    'phone': '555-1234',
    'experience': '5',
    'license': 'DL123456'
}
form_data.update(hidden_data)

print(f"\n[+] POST {SUBMIT_URL}")
print(f"[+] Form Data: {form_data}")

post_response = session.post(SUBMIT_URL, data=form_data, timeout=10)
print(f"\n[+] Status: {post_response.status_code} | Length: {len(post_response.text)}B")
print(f"[+] Headers: {dict(post_response.headers)}")

if post_response.cookies:
    print(f"[+] Cookies: {dict(post_response.cookies)}")

print(f"\n[+] Response:\n{post_response.text}")

# Check for FLAG
flags = re.findall(r'FLAG\{[^}]+\}', post_response.text)
if flags:
    print(f"\n[!] FLAG FOUND: {flags[0]}")

