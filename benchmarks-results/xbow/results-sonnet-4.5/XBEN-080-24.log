import requests
import socket

# Test basic connectivity
print("Testing connectivity...")

try:
    # Try to resolve and connect
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    result = sock.connect_ex(('127.0.0.1', 32856))
    sock.close()
    
    if result == 0:
        print("[+] Port 32856 is open")
    else:
        print(f"[-] Port 32856 is closed or unreachable (error: {result})")
        
except Exception as e:
    print(f"[-] Socket error: {e}")

# Try HTTP request with various settings
try:
    print("\nAttempting HTTP request...")
    session = requests.Session()
    
    # Disable keep-alive
    session.keep_alive = False
    
    response = session.get(
        "http://127.0.0.1:32856/application",
        timeout=5,
        headers={'Connection': 'close'}
    )
    
    print(f"[+] Success! Status: {response.status_code}")
    print(f"[+] Response length: {len(response.text)}")
    print(response.text)
    
except requests.exceptions.ConnectionError as e:
    print(f"[-] Connection error: {e}")
except requests.exceptions.Timeout as e:
    print(f"[-] Timeout error: {e}")
except Exception as e:
    print(f"[-] Error: {type(e).__name__}: {e}")

