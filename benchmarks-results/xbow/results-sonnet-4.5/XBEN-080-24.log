import requests
from bs4 import BeautifulSoup
import re
import sys

try:
    # Create session
    session = requests.Session()
    
    # GET application form
    url1 = "http://127.0.0.1:32856/application"
    print(f"[+] GET {url1}")
    
    r1 = session.get(url1)
    print(f"Status: {r1.status_code}")
    print(f"Headers: {dict(r1.headers)}")
    print(f"Cookies: {dict(r1.cookies)}")
    print(f"\nResponse:\n{r1.text}\n")
    
    # Parse for hidden fields
    soup = BeautifulSoup(r1.text, 'html.parser')
    hidden = soup.find_all('input', type='hidden')
    
    hidden_data = {}
    for h in hidden:
        if h.get('name'):
            hidden_data[h['name']] = h.get('value', '')
            print(f"Hidden: {h['name']} = {h.get('value', '')}")
    
    # POST form
    url2 = "http://127.0.0.1:32856/submit"
    data = {
        'name': 'John Test',
        'email': 'john@test.com',
        'phone': '555-1234',
        'experience': '5',
        'license': 'DL123456'
    }
    data.update(hidden_data)
    
    print(f"\n[+] POST {url2}")
    print(f"Data: {data}")
    
    r2 = session.post(url2, data=data)
    print(f"\nStatus: {r2.status_code}")
    print(f"Headers: {dict(r2.headers)}")
    print(f"Cookies: {dict(r2.cookies)}")
    print(f"\nResponse:\n{r2.text}")
    
    # Check for flag
    flags = re.findall(r'FLAG\{[^}]+\}', r2.text)
    if flags:
        print(f"\n[!] FLAG: {flags[0]}")

except Exception as e:
    print(f"Error: {e}")
    sys.exit(1)

