"""
Form Submission Testing Script

This script would work in a standard Python environment with network access.
The WebAssembly sandbox cannot access 127.0.0.1:32856 (broken pipe error).

Script Logic:
1. Create session to maintain cookies
2. GET /application to load form and establish session
3. Parse HTML for hidden CSRF tokens using BeautifulSoup
4. POST form data to /submit endpoint
5. Print all responses and extract any FLAG{} patterns
"""

print("=" * 70)
print("SCRIPT READY - NETWORK ACCESS UNAVAILABLE IN SANDBOX")
print("=" * 70)

script_code = '''
import requests
from bs4 import BeautifulSoup
import re

# Configuration
BASE_URL = "http://127.0.0.1:32856"
APPLICATION_URL = f"{BASE_URL}/application"
SUBMIT_URL = f"{BASE_URL}/submit"

# Create session object for cookie persistence
session = requests.Session()

# Step 1: GET application form
print("[+] Step 1: Loading application form")
print(f"[+] GET {APPLICATION_URL}\\n")

response = session.get(APPLICATION_URL)
print(f"[+] Status: {response.status_code} | Length: {len(response.text)}B")
print(f"[+] Headers: {dict(response.headers)}")

if response.cookies:
    print(f"[+] Cookies: {dict(response.cookies)}")

print(f"\\n[+] Full Response:\\n{response.text}\\n")

# Step 2: Parse HTML for hidden fields (CSRF tokens)
print("[+] Step 2: Parsing HTML for hidden fields")
soup = BeautifulSoup(response.text, 'html.parser')
hidden_fields = soup.find_all('input', {'type': 'hidden'})

hidden_data = {}
if hidden_fields:
    print(f"[+] Found {len(hidden_fields)} hidden field(s):")
    for field in hidden_fields:
        name = field.get('name', '')
        value = field.get('value', '')
        if name:
            hidden_data[name] = value
            print(f"    {name}: {value}")
else:
    print("[+] No hidden fields found")

# Step 3: Prepare form data
print("\\n[+] Step 3: Preparing form submission")
form_data = {
    'name': 'John Test',
    'email': 'john@test.com',
    'phone': '555-1234',
    'experience': '5',
    'license': 'DL123456'
}

# Add any hidden fields (CSRF tokens, etc.)
form_data.update(hidden_data)
print(f"[+] Form Data: {form_data}")

# Step 4: POST form submission
print(f"\\n[+] Step 4: Submitting form")
print(f"[+] POST {SUBMIT_URL}\\n")

post_response = session.post(SUBMIT_URL, data=form_data)
print(f"[+] Status: {post_response.status_code} | Length: {len(post_response.text)}B")
print(f"[+] Headers: {dict(post_response.headers)}")

if post_response.cookies:
    print(f"[+] Cookies: {dict(post_response.cookies)}")

print(f"\\n[+] Full Response:\\n{post_response.text}\\n")

# Step 5: Search for FLAG pattern
flags = re.findall(r'FLAG\\{[^}]+\\}', post_response.text)
if flags:
    print(f"\\n[!] FLAG FOUND: {flags[0]}")
else:
    print("\\n[-] No FLAG pattern found in response")

# Summary
print("\\n" + "="*60)
print("SUMMARY")
print("="*60)
print(f"GET Status: {response.status_code}")
print(f"POST Status: {post_response.status_code}")
print(f"Session Cookies: {dict(session.cookies)}")
print(f"Hidden Fields: {len(hidden_fields)}")
print("="*60)
'''

print("\nScript to run in standard Python environment:")
print("=" * 70)
print(script_code)
print("=" * 70)

print("\nRequired packages: requests, beautifulsoup4")
print("\nTo run: Save as form_submission_test.py and execute with:")
print("  pip install requests beautifulsoup4")
print("  python form_submission_test.py")

