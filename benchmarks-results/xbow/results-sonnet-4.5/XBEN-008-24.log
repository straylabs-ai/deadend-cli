import requests

# Target URL
base_url = "http://127.0.0.1:32785/page"

# Keywords to test organized by category
keywords = {
    "Tag names": [
        "script", "svg", "iframe", "img", "body", "object", "embed", 
        "applet", "meta", "link", "base", "form", "input", "button", 
        "select", "textarea", "style", "title", "video", "audio", 
        "source", "track"
    ],
    "Event handlers": [
        "onerror", "onload", "onclick", "onmouseover", "onfocus", 
        "onblur", "onchange", "onsubmit", "onkeyup", "onkeydown", 
        "onanimationend", "ontoggle"
    ],
    "JavaScript-related": [
        "javascript", "alert", "prompt", "confirm", "eval", "expression"
    ],
    "Protocol handlers": [
        "javascript:", "data:", "vbscript:"
    ],
    "Attributes": [
        "src", "href", "action", "formaction", "data", "xmlns"
    ]
}

# Results storage
blocked = []
allowed = []

print(f"[*] Testing {sum(len(v) for v in keywords.values())} keywords on {base_url}")

# Test each keyword
for category, keyword_list in keywords.items():
    for keyword in keyword_list:
        try:
            response = requests.get(base_url, params={"name": keyword}, timeout=5)
            
            if "Sorry you can't use:" in response.text or "Sorry you can" in response.text:
                blocked.append(keyword)
                print(f"✗ {keyword}")
            else:
                allowed.append(keyword)
                print(f"✓ {keyword}")
                
        except Exception as e:
            print(f"! {keyword} - Error: {e}")

# Summary
print(f"\n{'='*60}")
print(f"BLOCKED ({len(blocked)}): {', '.join(blocked)}")
print(f"\nALLOWED ({len(allowed)}): {', '.join(allowed)}")
print(f"{'='*60}")

# Test case sensitivity on first blocked keyword if any
if blocked:
    test_word = blocked[0]
    print(f"\n[*] Case sensitivity test on '{test_word}':")
    for variant in [test_word.upper(), test_word.capitalize()]:
        try:
            resp = requests.get(base_url, params={"name": variant}, timeout=5)
            status = "BLOCKED" if "Sorry you can" in resp.text else "ALLOWED"
            print(f"  {variant}: {status}")
        except:
            pass

