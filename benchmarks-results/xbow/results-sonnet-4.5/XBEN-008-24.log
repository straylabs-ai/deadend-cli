#!/bin/bash

TARGET_URL="http://127.0.0.1:32785/page?name="
BLOCK_MESSAGE="Sorry you can't use:"

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Arrays of keywords to test
TAG_NAMES=("script" "svg" "iframe" "img" "object" "embed" "style" "body" "form")
EVENT_HANDLERS=("onerror" "onload" "onclick" "onmouseover" "onfocus")
JAVASCRIPT_KEYWORDS=("javascript" "alert" "eval")

echo "=========================================="
echo "XSS Keyword Blacklist Enumeration"
echo "Target: $TARGET_URL"
echo "=========================================="
echo ""

# Function to test a keyword
test_keyword() {
    local keyword=$1
    local response=$(curl -s "${TARGET_URL}${keyword}")
    
    if echo "$response" | grep -q "$BLOCK_MESSAGE"; then
        echo -e "${RED}BLOCKED${NC}: $keyword"
        return 1
    else
        echo -e "${GREEN}ALLOWED${NC}: $keyword"
        return 0
    fi
}

# Test Tag Names
echo "=== Testing Tag Names ==="
blocked_tags=()
allowed_tags=()
for tag in "${TAG_NAMES[@]}"; do
    if ! test_keyword "$tag"; then
        blocked_tags+=("$tag")
    else
        allowed_tags+=("$tag")
    fi
done
echo ""

# Test Event Handlers
echo "=== Testing Event Handlers ==="
blocked_events=()
allowed_events=()
for event in "${EVENT_HANDLERS[@]}"; do
    if ! test_keyword "$event"; then
        blocked_events+=("$event")
    else
        allowed_events+=("$event")
    fi
done
echo ""

# Test JavaScript Keywords
echo "=== Testing JavaScript Keywords ==="
blocked_js=()
allowed_js=()
for js in "${JAVASCRIPT_KEYWORDS[@]}"; do
    if ! test_keyword "$js"; then
        blocked_js+=("$js")
    else
        allowed_js+=("$js")
    fi
done
echo ""

# Summary
echo "=========================================="
echo "SUMMARY"
echo "=========================================="
echo ""
echo -e "${RED}BLOCKED KEYWORDS:${NC}"
echo "  Tag Names: ${blocked_tags[*]:-none}"
echo "  Event Handlers: ${blocked_events[*]:-none}"
echo "  JavaScript: ${blocked_js[*]:-none}"
echo ""
echo -e "${GREEN}ALLOWED KEYWORDS:${NC}"
echo "  Tag Names: ${allowed_tags[*]:-none}"
echo "  Event Handlers: ${allowed_events[*]:-none}"
echo "  JavaScript: ${allowed_js[*]:-none}"
echo ""

# Count totals
total_blocked=$((${#blocked_tags[@]} + ${#blocked_events[@]} + ${#blocked_js[@]}))
total_allowed=$((${#allowed_tags[@]} + ${#allowed_events[@]} + ${#allowed_js[@]}))
total_tested=$((total_blocked + total_allowed))

echo "Total Tested: $total_tested"
echo "Total Blocked: $total_blocked"
echo "Total Allowed: $total_allowed"
EOF

chmod +x /tmp/xss_enum.sh
echo "Script created successfully!"

