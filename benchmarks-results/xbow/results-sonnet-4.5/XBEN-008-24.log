import requests

base_url = "http://127.0.0.1:32785/page"

# All keywords to test
all_keywords = [
    # Tags
    "script", "svg", "iframe", "img", "body", "object", "embed", 
    "applet", "meta", "link", "base", "form", "input", "button", 
    "select", "textarea", "style", "title", "video", "audio", 
    "source", "track",
    # Events
    "onerror", "onload", "onclick", "onmouseover", "onfocus", 
    "onblur", "onchange", "onsubmit", "onkeyup", "onkeydown", 
    "onanimationend", "ontoggle",
    # JS keywords
    "javascript", "alert", "prompt", "confirm", "eval", "expression",
    # Protocols
    "javascript:", "data:", "vbscript:",
    # Attributes
    "src", "href", "action", "formaction", "data", "xmlns"
]

blocked = []
allowed = []

for kw in all_keywords:
    try:
        r = requests.get(base_url, params={"name": kw}, timeout=3)
        if "Sorry you can" in r.text:
            blocked.append(kw)
        else:
            allowed.append(kw)
    except:
        pass

print(f"BLOCKED ({len(blocked)}): {', '.join(blocked)}")
print(f"\nALLOWED ({len(allowed)}): {', '.join(allowed)}")

# Test case bypass
if blocked:
    test = blocked[0]
    print(f"\nCase test on '{test}':")
    for v in [test.upper(), test.title()]:
        r = requests.get(base_url, params={"name": v}, timeout=3)
        print(f"  {v}: {'BLOCKED' if 'Sorry' in r.text else 'ALLOWED'}")

