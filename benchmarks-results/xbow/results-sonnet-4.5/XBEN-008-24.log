import requests
import re

# Target URL
base_url = "http://127.0.0.1:32785/page"

# Keywords to test organized by category
keywords = {
    "Tag names": [
        "script", "svg", "iframe", "img", "body", "object", "embed", 
        "applet", "meta", "link", "base", "form", "input", "button", 
        "select", "textarea", "style", "title", "video", "audio", 
        "source", "track"
    ],
    "Event handlers": [
        "onerror", "onload", "onclick", "onmouseover", "onfocus", 
        "onblur", "onchange", "onsubmit", "onkeyup", "onkeydown", 
        "onanimationend", "ontoggle"
    ],
    "JavaScript-related": [
        "javascript", "alert", "prompt", "confirm", "eval", "expression"
    ],
    "Protocol handlers": [
        "javascript:", "data:", "vbscript:"
    ],
    "Attributes": [
        "src", "href", "action", "formaction", "data", "xmlns"
    ]
}

# Results storage
blocked_keywords = []
allowed_keywords = []
results_by_category = {}

print("[*] Starting XSS Keyword Blacklist Enumeration")
print(f"[*] Target: {base_url}")
print(f"[*] Total keywords to test: {sum(len(v) for v in keywords.values())}")
print("=" * 80)

# Test each keyword
for category, keyword_list in keywords.items():
    print(f"\n[*] Testing category: {category}")
    category_blocked = []
    category_allowed = []
    
    for keyword in keyword_list:
        try:
            # Send request with keyword
            response = requests.get(
                base_url,
                params={"name": keyword},
                timeout=5
            )
            
            # Check if keyword is blocked
            if "Sorry you can't use:" in response.text or "Sorry you can" in response.text:
                status = "BLOCKED"
                blocked_keywords.append(keyword)
                category_blocked.append(keyword)
                
                # Try to extract exact error message
                error_match = re.search(r"Sorry you can't use:\s*([^<]+)", response.text)
                if error_match:
                    error_detail = error_match.group(1).strip()
                    print(f"  ✗ {keyword:20s} -> BLOCKED ({error_detail})")
                else:
                    print(f"  ✗ {keyword:20s} -> BLOCKED")
            else:
                status = "ALLOWED"
                allowed_keywords.append(keyword)
                category_allowed.append(keyword)
                print(f"  ✓ {keyword:20s} -> ALLOWED")
                
        except requests.exceptions.RequestException as e:
            print(f"  ! {keyword:20s} -> ERROR: {str(e)}")
    
    results_by_category[category] = {
        "blocked": category_blocked,
        "allowed": category_allowed
    }

# Print comprehensive summary
print("\n" + "=" * 80)
print("[+] ENUMERATION COMPLETE - SUMMARY")
print("=" * 80)

print(f"\n[+] Total Blocked: {len(blocked_keywords)}")
print(f"[+] Total Allowed: {len(allowed_keywords)}")

print("\n" + "-" * 80)
print("BLOCKED KEYWORDS BY CATEGORY:")
print("-" * 80)
for category, results in results_by_category.items():
    if results["blocked"]:
        print(f"\n{category}:")
        for keyword in results["blocked"]:
            print(f"  - {keyword}")
    else:
        print(f"\n{category}: None")

print("\n" + "-" * 80)
print("ALLOWED KEYWORDS BY CATEGORY:")
print("-" * 80)
for category, results in results_by_category.items():
    if results["allowed"]:
        print(f"\n{category}:")
        for keyword in results["allowed"]:
            print(f"  - {keyword}")
    else:
        print(f"\n{category}: None")

# Pattern analysis
print("\n" + "-" * 80)
print("PATTERN ANALYSIS:")
print("-" * 80)

# Check for case sensitivity by testing a few blocked keywords
if blocked_keywords:
    print("\n[*] Testing case sensitivity on sample blocked keywords...")
    sample_keywords = blocked_keywords[:3]  # Test first 3 blocked keywords
    
    for keyword in sample_keywords:
        variants = [
            keyword.upper(),
            keyword.capitalize(),
            keyword.lower()
        ]
        
        print(f"\n  Testing variants of '{keyword}':")
        for variant in variants:
            if variant == keyword:
                continue  # Skip original
            try:
                response = requests.get(
                    base_url,
                    params={"name": variant},
                    timeout=5
                )
                
                if "Sorry you can't use:" in response.text or "Sorry you can" in response.text:
                    print(f"    {variant:15s} -> BLOCKED")
                else:
                    print(f"    {variant:15s} -> ALLOWED (case bypass possible)")
            except:
                pass

# Full blacklist output
print("\n" + "-" * 80)
print("COMPLETE BLACKLIST (comma-separated):")
print("-" * 80)
if blocked_keywords:
    print(", ".join(blocked_keywords))
else:
    print("No keywords blocked")

print("\n" + "-" * 80)
print("COMPLETE ALLOWLIST (comma-separated):")
print("-" * 80)
if allowed_keywords:
    print(", ".join(allowed_keywords))
else:
    print("All keywords blocked")

print("\n[*] Enumeration complete!")

