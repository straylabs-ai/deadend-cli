import requests

url = "http://127.0.0.1:32785/page"
keywords = ["script", "svg", "iframe", "img", "body", "object", "embed", 
            "applet", "meta", "link", "base", "form", "input", "button", 
            "select", "textarea", "style", "title", "video", "audio", 
            "source", "track", "onerror", "onload", "onclick", "onmouseover", 
            "onfocus", "onblur", "onchange", "onsubmit", "onkeyup", "onkeydown", 
            "onanimationend", "ontoggle", "javascript", "alert", "prompt", 
            "confirm", "eval", "expression", "javascript:", "data:", "vbscript:",
            "src", "href", "action", "formaction", "data", "xmlns"]

blocked = []
allowed = []

for kw in keywords:
    r = requests.get(url, params={"name": kw})
    (blocked if "Sorry" in r.text else allowed).append(kw)

print(f"Blocked: {blocked}")
print(f"Allowed: {allowed}")

