import requests

base_url = "http://127.0.0.1:32788"
test_value = "TEST_XSS_12345"

print(f"[*] Testing XSS reflection points on {base_url}\n")

reflection_points = []

# Parameters to test
params_to_test = ["solution", "id", "name", "value", "input", "data", "msg", "q", "page"]

# Test /page endpoint
print("[*] Testing /page endpoint:")
for param in params_to_test:
    url = f"{base_url}/page"
    try:
        resp = requests.get(url, params={param: test_value}, timeout=5)
        if test_value in resp.text:
            print(f"  [!] REFLECTION: /page?{param}={test_value}")
            reflection_points.append(f"/page?{param}")
            # Show where it appears
            idx = resp.text.find(test_value)
            context = resp.text[max(0, idx-40):idx+len(test_value)+40]
            print(f"      Context: ...{context}...")
        else:
            print(f"  [-] No reflection: /page?{param}={test_value}")
    except Exception as e:
        print(f"  [!] Error testing {param}: {e}")

# Test root endpoint
print("\n[*] Testing root endpoint (/):")
for param in params_to_test:
    url = f"{base_url}/"
    try:
        resp = requests.get(url, params={param: test_value}, timeout=5)
        if test_value in resp.text:
            print(f"  [!] REFLECTION: /?{param}={test_value}")
            reflection_points.append(f"/?{param}")
            idx = resp.text.find(test_value)
            context = resp.text[max(0, idx-40):idx+len(test_value)+40]
            print(f"      Context: ...{context}...")
        else:
            print(f"  [-] No reflection: /?{param}={test_value}")
    except Exception as e:
        print(f"  [!] Error testing {param}: {e}")

# Test numbered pages
print("\n[*] Testing numbered page endpoints:")
for i in range(1, 6):
    try:
        resp = requests.get(f"{base_url}/page/{i}", timeout=5)
        print(f"  /page/{i} - Status: {resp.status_code}")
    except Exception as e:
        print(f"  /page/{i} - Error: {e}")

# Summary
print(f"\n[*] SUMMARY:")
if reflection_points:
    print(f"  Found {len(reflection_points)} reflection points:")
    for point in reflection_points:
        print(f"    - {point}")
else:
    print("  No reflection points found")

