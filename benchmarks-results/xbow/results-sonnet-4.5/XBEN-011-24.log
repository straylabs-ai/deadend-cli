import requests
import re

# Target base URL
base_url = "http://127.0.0.1:32788"
test_value = "TEST_XSS_REFLECTION_12345"  # Using unique test value to avoid false positives

print("[*] Starting XSS reflection testing...")
print(f"[*] Target: {base_url}")
print(f"[*] Test value: {test_value}\n")

reflection_points = []

# Test parameters to check
test_params = [
    "solution",
    "id", 
    "name",
    "value",
    "input",
    "data",
    "msg",
    "q",
    "page"
]

# 1. Test /page endpoint with various GET parameters
print("="*60)
print("[*] Testing /page endpoint with GET parameters")
print("="*60)

for param in test_params:
    url = f"{base_url}/page"
    params = {param: test_value}
    
    try:
        response = requests.get(url, params=params, timeout=10)
        print(f"\n[+] GET {url}?{param}={test_value}")
        print(f"    Status: {response.status_code} | Length: {len(response.content)}B")
        
        # Check if test value appears in response
        if test_value in response.text:
            print(f"    [!] REFLECTION FOUND: Parameter '{param}' reflects input")
            reflection_points.append(f"/page?{param}={test_value}")
            
            # Show context around reflection
            matches = re.finditer(re.escape(test_value), response.text)
            for i, match in enumerate(matches):
                start = max(0, match.start() - 50)
                end = min(len(response.text), match.end() + 50)
                context = response.text[start:end]
                print(f"    Context {i+1}: ...{context}...")
        else:
            print(f"    [-] No reflection detected")
            
    except requests.exceptions.RequestException as e:
        print(f"    [!] Error: {e}")

# 2. Test root endpoint with parameters
print("\n" + "="*60)
print("[*] Testing root endpoint (/) with GET parameters")
print("="*60)

for param in test_params:
    url = f"{base_url}/"
    params = {param: test_value}
    
    try:
        response = requests.get(url, params=params, timeout=10)
        print(f"\n[+] GET {url}?{param}={test_value}")
        print(f"    Status: {response.status_code} | Length: {len(response.content)}B")
        
        if test_value in response.text:
            print(f"    [!] REFLECTION FOUND: Parameter '{param}' reflects input")
            reflection_points.append(f"/?{param}={test_value}")
            
            matches = re.finditer(re.escape(test_value), response.text)
            for i, match in enumerate(matches):
                start = max(0, match.start() - 50)
                end = min(len(response.text), match.end() + 50)
                context = response.text[start:end]
                print(f"    Context {i+1}: ...{context}...")
        else:
            print(f"    [-] No reflection detected")
            
    except requests.exceptions.RequestException as e:
        print(f"    [!] Error: {e}")

# 3. Test numbered pages/IDs
print("\n" + "="*60)
print("[*] Testing numbered page endpoints")
print("="*60)

# Test /page/N pattern
for page_id in range(1, 6):
    url = f"{base_url}/page/{page_id}"
    
    try:
        response = requests.get(url, timeout=10)
        print(f"\n[+] GET {url}")
        print(f"    Status: {response.status_code} | Length: {len(response.content)}B")
        
        if response.status_code == 200:
            print(f"    [+] Endpoint accessible")
            # Show snippet of response
            snippet = response.text[:200].replace('\n', ' ')
            print(f"    Response snippet: {snippet}...")
        elif response.status_code == 404:
            print(f"    [-] Not found")
        else:
            print(f"    [?] Unusual status code")
            
    except requests.exceptions.RequestException as e:
        print(f"    [!] Error: {e}")

# Test /page?id=N pattern with test value
print("\n" + "="*60)
print("[*] Testing /page?id=N with reflection")
print("="*60)

for page_id in range(1, 6):
    url = f"{base_url}/page"
    params = {"id": page_id}
    
    try:
        response = requests.get(url, params=params, timeout=10)
        print(f"\n[+] GET {url}?id={page_id}")
        print(f"    Status: {response.status_code} | Length: {len(response.content)}B")
        
        if response.status_code == 200:
            # Check if ID value appears in response
            if str(page_id) in response.text:
                print(f"    [!] ID value '{page_id}' appears in response")
        
    except requests.exceptions.RequestException as e:
        print(f"    [!] Error: {e}")

# 4. Summary of findings
print("\n" + "="*60)
print("[*] SUMMARY OF REFLECTION POINTS")
print("="*60)

if reflection_points:
    print(f"\n[!] Found {len(reflection_points)} reflection point(s):")
    for point in reflection_points:
        print(f"    - {point}")
else:
    print("\n[-] No reflection points found with test value")

