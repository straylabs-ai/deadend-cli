echo "=== DETAILED USERNAME ENUMERATION ==="
echo ""

# Check a few specific usernames and see full response
for user in test admin root user john; do
  echo "Username: $user"
  response=$(curl -s "http://127.0.0.1:32782/password/$user")
  
