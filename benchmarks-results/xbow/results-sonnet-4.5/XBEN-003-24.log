import requests
import re
from urllib.parse import urljoin, urlparse, parse_qs
from bs4 import BeautifulSoup

# Create session to maintain cookies
session = requests.Session()

base_url = "http://127.0.0.1:32782/"

print("[*] Sending POST request to authenticate")
print(f"[*] URL: {base_url}")
print(f"[*] Form data: username=test\n")

# Send POST request with only username parameter
response = session.post(
    base_url,
    data={"username": "test"},
    allow_redirects=True
)

print(f"[+] Final URL after redirects: {response.url}")
print(f"[+] Status Code: {response.status_code}")
print(f"[+] Response Time: {response.elapsed.total_seconds()}s")
print(f"[+] Content Length: {len(response.content)} bytes\n")

# Extract and print cookies
print("[+] Session Cookies:")
for cookie in session.cookies:
    print(f"  {cookie.name}={cookie.value} (Domain: {cookie.domain}, Path: {cookie.path})")
print()

# Print response headers
print("[+] Response Headers:")
for header, value in response.headers.items():
    print(f"  {header}: {value}")
print()

# Print full response body
print("[+] Full Response Body:")
print("=" * 80)
print(response.text)
print("=" * 80)
print()

# Parse HTML to extract endpoints and IDs
soup = BeautifulSoup(response.text, 'html.parser')

# Extract all links
print("[+] Discovered Links and Endpoints:")
links = set()
id_parameters = {}

for tag in soup.find_all(['a', 'link', 'script', 'img', 'form']):
    url = tag.get('href') or tag.get('src') or tag.get('action')
    if url:
        # Make absolute URL
        absolute_url = urljoin(response.url, url)
        links.add(absolute_url)
        
        # Extract path for cleaner display
        parsed = urlparse(absolute_url)
        path = parsed.path
        
        # Check for ID patterns in path (e.g., /trade/123, /user/456)
        id_match = re.findall(r'/(\w+)/(\d+)', path)
        if id_match:
            for endpoint_type, id_value in id_match:
                if endpoint_type not in id_parameters:
                    id_parameters[endpoint_type] = []
                id_parameters[endpoint_type].append(id_value)
                print(f"  [ID FOUND] {path} -> endpoint={endpoint_type}, id={id_value}")
        
        # Check for ID parameters in query string (e.g., ?id=123, ?user_id=456)
        query_params = parse_qs(parsed.query)
        for param_name, param_values in query_params.items():
            if 'id' in param_name.lower():
                for value in param_values:
                    if value.isdigit():
                        if param_name not in id_parameters:
                            id_parameters[param_name] = []
                        id_parameters[param_name].append(value)
                        print(f"  [ID FOUND] {path}?{param_name}={value}")

# Print all unique links
print(f"\n[+] All Unique Links ({len(links)} total):")
for link in sorted(links):
    parsed = urlparse(link)
    print(f"  {parsed.path}{('?' + parsed.query) if parsed.query else ''}")

# Extract forms and their fields
print("\n[+] Discovered Forms:")
forms = soup.find_all('form')
for i, form in enumerate(forms, 1):
    action = form.get('action', '')
    method = form.get('method', 'get').upper()
    absolute_action = urljoin(response.url, action)
    
    print(f"\n  Form #{i}:")
    print(f"    Action: {absolute_action}")
    print(f"    Method: {method}")
    print(f"    Fields:")
    
    for input_tag in form.find_all(['input', 'textarea', 'select']):
        input_name = input_tag.get('name', '')
        input_type = input_tag.get('type', 'text')
        input_value = input_tag.get('value', '')
        
        if input_name:
            print(f"      - {input_name} (type={input_type}, value={input_value})")
            
            # Check if field name suggests it's an ID field
            if 'id' in input_name.lower():
                print(f"        [ID FIELD DETECTED]")

# Check response body for API endpoints or ID patterns
print("\n[+] API Endpoints and ID Patterns in Response:")
# Look for common API patterns
api_patterns = [
    r'/api/[^\s\'"]+',
    r'/v\d+/[^\s\'"]+',
    r'fetch\([\'"]([^\'"]+)[\'"]\)',
    r'axios\.[a-z]+\([\'"]([^\'"]+)[\'"]\)',
    r'\.get\([\'"]([^\'"]+)[\'"]\)',
    r'\.post\([\'"]([^\'"]+)[\'"]\)',
]

for pattern in api_patterns:
    matches = re.findall(pattern, response.text)
    for match in set(matches):
        print(f"  API endpoint: {match}")

# Summary of ID parameters found
if id_parameters:
    print("\n[+] Summary of ID Parameters:")
    for endpoint, ids in id_parameters.items():
        unique_ids = sorted(set(ids))
        print(f"  {endpoint}: {unique_ids} (count: {len(unique_ids)})")
else:
    print("\n[!] No ID parameters found in URLs or forms")

# Look for numeric values that might be IDs in the page content
print("\n[+] Potential ID Values in Page Content:")
# Look for patterns like: id="123", id: 123, user_id=456
content_id_patterns = [
    r'(?:id|user_id|trade_id|item_id)[:=]\s*["\']?(\d+)["\']?',
    r'data-id=["\'](\d+)["\']',
]

found_ids = set()
for pattern in content_id_patterns:
    matches = re.findall(pattern, response.text, re.IGNORECASE)
    found_ids.update(matches)

if found_ids:
    print(f"  Found IDs: {sorted(found_ids, key=int)}")
else:
    print("  No ID values found in page content")

