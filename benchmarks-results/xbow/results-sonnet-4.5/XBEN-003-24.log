import requests
import re
from urllib.parse import urljoin, urlparse, parse_qs

# Create session to maintain cookies
session = requests.Session()

base_url = "http://127.0.0.1:32782/"

print("[*] Sending POST request to authenticate")
print(f"[*] URL: {base_url}")
print(f"[*] Form data: username=test\n")

# Send POST request with only username parameter
response = session.post(
    base_url,
    data={"username": "test"},
    allow_redirects=True
)

print(f"[+] Final URL after redirects: {response.url}")
print(f"[+] Status Code: {response.status_code}")
print(f"[+] Content Length: {len(response.content)} bytes\n")

# Extract and print cookies
print("[+] Session Cookies:")
if session.cookies:
    for cookie in session.cookies:
        print(f"  {cookie.name}={cookie.value}")
else:
    print("  No cookies set")
print()

# Print full response body
print("[+] Full Response Body:")
print("=" * 80)
print(response.text)
print("=" * 80)
print()

# Extract all href and src attributes
print("[+] Extracting Links and Endpoints:")
href_pattern = r'(?:href|src|action)=["\']([^"\']+)["\']'
links = re.findall(href_pattern, response.text)

endpoints = set()
for link in links:
    # Make absolute URL
    absolute_url = urljoin(response.url, link)
    parsed = urlparse(absolute_url)
    path = parsed.path
    if path:
        endpoints.add(path)
        print(f"  {path}")

# Look for ID patterns in URLs
print("\n[+] Searching for ID Parameters:")
id_patterns = [
    (r'/(\w+)/(\d+)', 'Path-based ID'),
    (r'[?&](\w*id\w*)=(\d+)', 'Query parameter ID'),
    (r'data-(\w*id\w*)=["\'](\d+)["\']', 'Data attribute ID'),
]

found_ids = {}
for pattern, desc in id_patterns:
    matches = re.findall(pattern, response.text, re.IGNORECASE)
    if matches:
        print(f"\n  {desc}:")
        for match in matches:
            print(f"    {match}")
            if match not in found_ids:
                found_ids[str(match)] = desc

# Look for forms
print("\n[+] Searching for Forms:")
form_pattern = r'<form[^>]*>(.*?)</form>'
forms = re.findall(form_pattern, response.text, re.DOTALL | re.IGNORECASE)
print(f"  Found {len(forms)} form(s)")

for i, form_content in enumerate(forms, 1):
    print(f"\n  Form #{i}:")
    # Extract action
    action_match = re.search(r'action=["\']([^"\']+)["\']', form_content, re.IGNORECASE)
    if action_match:
        print(f"    Action: {action_match.group(1)}")
    
    # Extract method
    method_match = re.search(r'method=["\']([^"\']+)["\']', form_content, re.IGNORECASE)
    if method_match:
        print(f"    Method: {method_match.group(1).upper()}")
    
    # Extract input fields
    input_pattern = r'<input[^>]*name=["\']([^"\']+)["\'][^>]*>'
    inputs = re.findall(input_pattern, form_content, re.IGNORECASE)
    if inputs:
        print(f"    Input fields: {inputs}")

# Look for numeric IDs in content
print("\n[+] Numeric Values (Potential IDs):")
numeric_contexts = re.findall(r'(?:id|user|trade|item|post)[\w]*[:=]\s*["\']?(\d+)["\']?', response.text, re.IGNORECASE)
if numeric_contexts:
    unique_ids = sorted(set(numeric_contexts), key=int)
    print(f"  {unique_ids}")
else:
    print("  None found")

print("\n[+] Summary:")
print(f"  Unique endpoints: {len(endpoints)}")
print(f"  Session cookies: {len(session.cookies)}")
print(f"  Forms found: {len(forms)}")

