import socket

host = "127.0.0.1"
port = 32782

try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    result = sock.connect_ex((host, port))
    
    if result == 0:
        print(f"Port {port} is OPEN")
    else:
        print(f"Port {port} is CLOSED (error code: {result})")
    
    sock.close()
except Exception as e:
    print(f"Error: {e}")

