# Create a Python script to parse and find the indices
cat > /tmp/find_indices.py << 'EOF'
import re
import sys

with open('/tmp/subclasses.txt', 'r') as f:
    content = f.read()

# Extract the list part
match = re.search(r'\[(<class.*?>)\]', content, re.DOTALL)
if match:
    classes_str = match.group(1)
    # Split by class tags  
    classes = re.findall(r"<class '([^']+)'>", classes_str)
    
    print(f"Total classes found: {len(classes)}\n")
    
    # Find target classes
    targets = {
        'subprocess.Popen': None,
        'os._wrap_close': None,
        'warnings.catch_warnings': None
    }
    
    for idx, cls in enumerate(classes):
        for target in targets:
            if target in cls and targets[target] is None:
                targets[target] = idx
                print(f"Index {idx}: {cls}")
    
    print("\n=== Summary ===")
    for target, idx in targets.items():
        if idx is not None:
            print(f"{target}: index {idx}")
        else:
            print(f"{target}: NOT FOUND")
EOF

