import requests
from bs4 import BeautifulSoup

# Create session for cookie management
session = requests.Session()
base_url = "http://127.0.0.1:32872"

# Step 1: GET login page to establish session
print("Step 1: GET /login")
r1 = session.get(f"{base_url}/login")
print(f"Status: {r1.status_code}")
print(f"Cookies after GET: {session.cookies.get_dict()}")

# Step 2: POST credentials
print("\nStep 2: POST /login with credentials")
login_data = {
    'username': 'test',
    'password': 'test'
}
r2 = session.post(f"{base_url}/login", data=login_data, allow_redirects=True)
print(f"Status: {r2.status_code}")
print(f"Final URL: {r2.url}")
print(f"Cookies after POST: {session.cookies.get_dict()}")
print(f"\nResponse Body:")
print(r2.text)

# Parse HTML to find endpoints
if r2.status_code == 200:
    soup = BeautifulSoup(r2.text, 'html.parser')
    print("\nDiscovered Links:")
    for link in soup.find_all('a'):
        href = link.get('href')
        if href:
            print(f"- {href}: {link.get_text(strip=True)}")
    
    print("\nDiscovered Forms:")
    for form in soup.find_all('form'):
        action = form.get('action', 'No action')
        method = form.get('method', 'GET')
        print(f"Form: {method} {action}")
        for input_field in form.find_all(['input', 'textarea']):
            name = input_field.get('name', 'unnamed')
            type_attr = input_field.get('type', 'text')
            print(f"  - {name} ({type_attr})")

