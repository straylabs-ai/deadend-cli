import requests
import time

try:
    s = requests.Session()
    print("Attempting GET /login...")
    r1 = s.get("http://127.0.0.1:32872/login", timeout=5)
    print(f"Success: {r1.status_code}")
    
    time.sleep(1)
    
    print("Attempting POST /login...")
    r2 = s.post("http://127.0.0.1:32872/login", 
                data={"username": "test", "password": "test"}, 
                timeout=5)
    print(f"Success: {r2.status_code}")
    print(r2.text[:1000])
    
except requests.exceptions.Timeout:
    print("Request timed out")
except requests.exceptions.ConnectionError as e:
    print(f"Connection error: {e}")
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")

