import requests
import re

# Create session for cookie management
session = requests.Session()
base_url = "http://127.0.0.1:32872"

# Step 1: GET login page
print("Step 1: GET /login")
r1 = session.get(f"{base_url}/login", timeout=10)
print(f"Status: {r1.status_code}")
print(f"Cookies: {session.cookies.get_dict()}")

# Step 2: POST credentials
print("\nStep 2: POST /login")
login_data = {'username': 'test', 'password': 'test'}
r2 = session.post(f"{base_url}/login", data=login_data, allow_redirects=True, timeout=10)
print(f"Status: {r2.status_code}")
print(f"Final URL: {r2.url}")
print(f"Cookies: {session.cookies.get_dict()}")
print(f"\nResponse Body:")
print(r2.text)

# Extract links
links = re.findall(r'href=["\']([^"\']+)["\']', r2.text)
if links:
    print("\nFound Links:")
    for link in set(links):
        print(f"  {link}")

# Extract forms
forms = re.findall(r'<form[^>]*>', r2.text, re.IGNORECASE)
if forms:
    print("\nFound Forms:")
    for form in forms:
        print(f"  {form}")

