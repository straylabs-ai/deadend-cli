    "Employee", "Employee1", "Staff", "Salary", "Wages", "Benefits",
    # Years
    "2020", "2021", "2022", "2023", "2024", "2025", "admin2024", "admin2025",
    # Simple
    "a", "aa", "aaa", "aaaa", "aaaaa", "aaaaaa", "aaaaaaa", "aaaaaaaa",
    "password1", "password12", "password123", "admin1", "admin12", "admin123",
]

all_passwords = list(set(rockyou_top + more_passwords))

print(f"[*] Cracking MD5: {hash_to_crack}")
print(f"[*] Testing {len(all_passwords)} passwords from common databases...\n")

found = None
for pwd in all_passwords:
    h = hashlib.md5(pwd.encode()).hexdigest()
    if h == hash_to_crack:
        found = pwd
        print(f"\n[+] *** HASH CRACKED! ***")
        print(f"[+] Password: {pwd}")
        print(f"[+] MD5: {h}")
        break

if not found:
    print("[-] Not found in common password lists")
    print("\n[*] Trying alphanumeric combinations (lowercase + numbers)...")
    
    # Try short alphanumeric combinations
    import itertools
    
    # 4-character alphanumeric
    chars = string.ascii_lowercase + string.digits
    count = 0
    for length in range(1, 6):  # 1 to 5 characters
        print(f"\n[*] Trying {length}-character combinations...")
        for combo in itertools.product(chars, repeat=length):
            pwd = ''.join(combo)
            h = hashlib.md5(pwd.encode()).hexdigest()
            count += 1
            
            if h == hash_to_crack:
                found = pwd
                print(f"\n[+] *** HASH CRACKED! ***")
                print(f"[+] Password: {pwd}")
                print(f"[+] MD5: {h}")
                print(f"[+] Tested: {count} combinations")
                break
            
            if count % 10000 == 0:
                print(f"    Tested {count} combinations...")
        
        if found:
            break
        
        # Stop if taking too long
        if count > 100000:
            print(f"[-] Stopped after {count} attempts (would take too long)")
            break

if not found:
    print("\n[-] Unable to crack hash with current approach")
    print("[*] Recommendation: Use online hash cracking services or larger wordlists")

