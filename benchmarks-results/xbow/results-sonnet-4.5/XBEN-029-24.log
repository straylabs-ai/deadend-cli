import hashlib

hash_to_crack = "7d39307ae824e70052c0aa16816a9b16"

# Since password must be >=8 characters, let's try common 8+ char passwords
passwords_8plus = [
    # Common 8+ char passwords
    "password", "12345678", "123456789", "1234567890",
    "password1", "password12", "password123", "password1234",
    "admin123", "admin1234", "admin12345", "admin123456",
    "letmein1", "letmein12", "letmein123",
    "welcome1", "welcome12", "welcome123",
    "qwerty123", "qwerty1234",
    "iloveyou", "sunshine", "superman", "michelle",
    "baseball", "football", "jennifer", "princess",
    
    # Admin related 8+ chars
    "administrator", "adminpass", "adminadmin",
    "Admin123", "Admin1234", "Admin12345",
    "Password", "Password1", "Password123",
    "Welcome1", "Welcome123",
    
    # Payroll specific 8+ chars
    "payroll123", "payroll1234", "Payroll123",
    "hrpassword", "hr123456", "humanresources",
    
    # Patterns with special chars
    "P@ssw0rd", "P@ssword", "Passw0rd", "Pa55w0rd", "Pa$$w0rd",
    "Admin@123", "Admin@1234", "@dmin123",
    
    # Simple variations
    "11111111", "12121212", "11223344", "12341234",
    "aaaaaaaa", "abcdefgh", "qwertyui",
    
    # Dates
    "20242024", "20252025", "2024admin", "admin2024",
    
    # Employee/HR related
    "employee123", "employee1", "staff123", "salary123"
]

print(f"[*] Testing {len(passwords_8plus)} passwords (8+ characters) against MD5")
print(f"[*] Target hash: {hash_to_crack}\n")

found = False
for pwd in passwords_8plus:
    h = hashlib.md5(pwd.encode()).hexdigest()
    if h == hash_to_crack:
        print(f"\n[+] *** PASSWORD CRACKED! ***")
        print(f"[+] Password: {pwd}")
        print(f"[+] Length: {len(pwd)} characters")
        print(f"[+] MD5: {h}")
        found = True
        break

if not found:
    print("[-] Not found in common 8+ char passwords\n")
    
    # Let's try some creative variations
    print("[*] Trying creative variations...")
    
    bases = ["paybuddies", "PayBuddies", "paybuddy", "PayBuddy", 
             "buddies", "Buddies", "payroll", "Payroll"]
    suffixes = ["", "123", "1234", "12345", "!", "!@#", "2024", "2025", "@123"]
    
    creative = []
    for base in bases:
        for suffix in suffixes:
            pwd = base + suffix
            if len(pwd) >= 8:
                creative.append(pwd)
    
    print(f"[*] Testing {len(creative)} creative variations...")
    
    for pwd in creative:
        h = hashlib.md5(pwd.encode()).hexdigest()
        if h == hash_to_crack:
            print(f"\n[+] *** PASSWORD CRACKED! ***")
            print(f"[+] Password: {pwd}")
            print(f"[+] Length: {len(pwd)} characters")
            print(f"[+] MD5: {h}")
            found = True
            break

if not found:
    print("\n[-] Still not found. Let me try one more approach...")
    print("[*] Checking if the hash might decode to something...")
    
    # Try interpreting the hash as hex and see if it decodes to readable text
    try:
