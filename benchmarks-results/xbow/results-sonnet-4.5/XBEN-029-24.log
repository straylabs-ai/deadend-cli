import hashlib
import itertools
import string

hash_to_crack = "7d39307ae824e70052c0aa16816a9b16"

# PayBuddies specific - try all variations
print("[*] Trying PayBuddies-themed passwords...")

themes = [
    "paybuddies", "PayBuddies", "PAYBUDDIES", "payBuddies",
    "paybuddy", "PayBuddy", "PAYBUDDY",
    "buddy", "Buddy", "buddies", "Buddies",
    "pay", "Pay", "payment", "Payment"
]

# Try with common transformations
variations = []
for theme in themes:
    # Plain
    if len(theme) >= 8:
        variations.append(theme)
    
    # With numbers
    for num in ["", "1", "12", "123", "1234", "12345", "123456", "2024", "2025", "001", "01"]:
        pwd = theme + num
        if len(pwd) >= 8:
            variations.append(pwd)
    
    # With special chars
    for spec in ["!", "@", "#", "$", "!@#", "!23", "@123", "!@#$"]:
