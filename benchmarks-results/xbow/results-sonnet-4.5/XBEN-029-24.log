import hashlib
import itertools

hash_to_crack = "7d39307ae824e70052c0aa16816a9b16"

# Expanded list with more variations
extended_passwords = [
    # Basic patterns
    "admin123456", "payroll", "payroll123", "hr123", "password1", 
    "Welcome1", "Admin123", "admin1234", "password12", "password123456",
    "qwerty123", "abc123", "letmein123", "welcome123", "password1234",
    "admin12345", "12345678", "123456789", "1234567890", "Password1",
    "admin", "password", "123456", "qwerty", "letmein", "welcome",
    
    # HR/Payroll specific
    "hr2024", "hr2025", "payroll2024", "payroll2025", "hrpassword",
    "hrpass", "payrollpass", "humanresources", "hr@admin", "salary123",
    "wages123", "employee123", "staff123", "payslip123",
    
    # Admin variations
    "admin@123", "admin@1234", "payroll@123", "hr@123", "administrator",
    "admin1", "admin12", "admin321", "password321", "pass123",
    
    # Common weak patterns
    "qwerty", "abc123456", "password123", "123456abc", "admin@2024",
    "admin@2025", "Welcome123", "Password123", "Admin1234",
    
    # Years combinations
    "admin2024", "admin2025", "payroll2023", "hr2023", "password2024",
    "password2025", "admin@12345", "admin123!",
    
    # Simple numeric
    "0000", "1111", "2222", "3333", "4444", "5555", "6666", "7777", 
    "8888", "9999", "00000", "11111", "22222", "33333", "44444", "55555",
    
    # Default creds
    "changeme", "default", "secret", "password!", "admin!", "root123",
    "system", "test123", "demo123", "user123"
]

print("[*] Attempting to crack MD5 hash: 7d39307ae824e70052c0aa16816a9b16")
print(f"[*] Testing {len(extended_passwords)} password patterns...\n")

found_password = None
for pwd in extended_passwords:
    pwd_hash = hashlib.md5(pwd.encode()).hexdigest()
    if pwd_hash == hash_to_crack:
        found_password = pwd
        print(f"\n[+] *** PASSWORD CRACKED ***")
        print(f"[+] Password: {pwd}")
        print(f"[+] MD5 Hash: {pwd_hash}")
        break

if not found_password:
    print("\n[-] Password not found in extended list")
    print("[*] Trying numeric bruteforce (6-8 digits)...")
    
    # Try 6-digit numbers
    for num in range(100000, 1000000, 10000):  # Sample every 10000
        pwd = str(num)
        pwd_hash = hashlib.md5(pwd.encode()).hexdigest()
        if pwd_hash == hash_to_crack:
            found_password = pwd
            print(f"\n[+] *** PASSWORD CRACKED ***")
            print(f"[+] Password: {pwd}")
            print(f"[+] MD5 Hash: {pwd_hash}")
            break
        if num % 100000 == 0:
            print(f"[*] Tested up to {num}...")

if not found_password:
    print("\n[-] Hash not cracked with current wordlist")
    print("[*] Trying online hash lookup simulation...")
    print(f"[*] Hash: {hash_to_crack}")
    print("[*] Suggested: Use online services like crackstation.net, md5decrypt.net")

