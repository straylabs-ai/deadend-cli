import requests
import re
import hashlib

cookies = {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"}

# Get full page source
main_page = requests.get("http://127.0.0.1:32892/", cookies=cookies)
print("[*] Full page HTML:\n")
print(main_page.text)
print("\n" + "="*80 + "\n")

# Look for inline JavaScript
print("[*] Looking for inline JavaScript...")
inline_js = re.findall(r'<script[^>]*>(.*?)</script>', main_page.text, re.DOTALL)
if inline_js:
    print("[*] Inline JavaScript found:")
    for idx, js in enumerate(inline_js, 1):
        if js.strip() and 'jquery' not in js.lower() and 'bootstrap' not in js.lower():
            print(f"\n--- Script {idx} ---")
            print(js.strip())
            print()

# Check all external JS files
js_files = ['https://code.jquery.com/jquery-3.7.1.min.js', 'https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js']

# Check for local JS files
local_js = re.findall(r'<script[^>]*src=["\'](?!https?://)(.*?)["\']', main_page.text)
print(f"\n[*] Local JavaScript files: {local_js}")

for js_file in local_js:
    print(f"\n[*] Fetching: {js_file}")
    try:
        js_resp = requests.get(f"http://127.0.0.1:32892/{js_file}", cookies=cookies)
        if js_resp.status_code == 200:
            print(f"[+] Content of {js_file}:")
            print(js_resp.text)
    except Exception as e:
        print(f"[-] Error fetching {js_file}: {e}")

