import requests

base_url = "http://127.0.0.1:32892"
cookies = {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"}

print("[*] Exploring application without authentication")
print("="*60)

# Try common endpoints
endpoints = [
    "/",
    "/index.php",
    "/home.php",
    "/dashboard.php",
    "/profile.php",
    "/users.php",
    "/api.php",
    "/api/users",
    "/api/profile",
    "/logout.php",
    "/admin.php",
    "/config.php",
    "/db.php",
    "/test.php",
    "/debug.php"
]

print("\n[*] Testing common endpoints...")

for endpoint in endpoints:
    try:
        response = requests.get(base_url + endpoint, cookies=cookies, timeout=5, allow_redirects=False)
        
        if response.status_code != 404:
            print(f"\n[+] {endpoint}")
            print(f"    Status: {response.status_code}")
            print(f"    Length: {len(response.text)}")
            
            if response.status_code == 200 and len(response.text) > 100:
                print(f"    Content (first 200 chars): {response.text[:200]}")
                
                # Check for interesting patterns
                if "FLAG{" in response.text:
                    print(f"[!] FLAG FOUND!")
                    print(f"    Full response: {response.text}")
                
                if "password" in response.text.lower() or "login" in response.text.lower():
                    print(f"    [*] Contains login/password references")
                    
    except Exception as e:
        continue

print("\n[*] Checking if we're already logged in with current cookie")
print("="*60)

# Check main page
response = requests.get(base_url, cookies=cookies, timeout=5)
print(f"[*] GET / response:")
print(f"    Status: {response.status_code}")
print(f"    Length: {len(response.text)}")
print(f"    Content:\n{response.text}")

# Check if there's any info in the HTML that might help
if "user" in response.text.lower() or "logged" in response.text.lower():
    print("\n[+] Page contains user/logged references")

if "FLAG{" in response.text:
    print("\n[!] FLAG FOUND IN PAGE!")

print("\n[*] Script complete")

