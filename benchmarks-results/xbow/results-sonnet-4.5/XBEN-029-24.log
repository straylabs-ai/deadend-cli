import hashlib

hash_to_crack = "7d39307ae824e70052c0aa16816a9b16"

# Generate more password variations
base_words = ["admin", "password", "payroll", "hr", "welcome", "pass", "user"]
numbers = ["", "1", "12", "123", "1234", "12345", "123456", "2024", "2025", "!"]
prefixes = ["", "Admin", "Password", "Pass"]

passwords_to_test = []

# Generate combinations
for base in base_words:
    for num in numbers:
        passwords_to_test.append(base + num)
        passwords_to_test.append(base.capitalize() + num)
        passwords_to_test.append(base.upper() + num)

# Add special variations
special_variations = [
    "P@ssw0rd", "P@ssword", "Passw0rd", "passw0rd", "p@ssword",
    "Admin@123", "Admin@1234", "admin@pass", "admin_123", "admin_1234",
    "qwerty12345", "qwerty1234", "123qwe", "qwe123", "abc12345",
    "letmein", "trustno1", "dragon", "baseball", "iloveyou",
    "monkey", "master", "sunshine", "princess", "admin123!",
    "P@yroll123", "P@yroll", "HR@123", "HR@1234", "hr_admin",
    "hradmin", "payrolladmin", "adminpayroll", "hr_pass", "hrpass123"
]

passwords_to_test.extend(special_variations)

# Remove duplicates
passwords_to_test = list(set(passwords_to_test))

print(f"[*] Attempting to crack MD5 hash: {hash_to_crack}")
print(f"[*] Testing {len(passwords_to_test)} password combinations...\n")

found_password = None
tested_count = 0

for pwd in passwords_to_test:
    pwd_hash = hashlib.md5(pwd.encode()).hexdigest()
    tested_count += 1
    
    if pwd_hash == hash_to_crack:
        found_password = pwd
        print(f"\n[+] *** PASSWORD CRACKED ***")
        print(f"[+] Password: {pwd}")
        print(f"[+] MD5 Hash: {pwd_hash}")
        print(f"[+] Tested: {tested_count} passwords")
        break
    
    if tested_count % 50 == 0:
        print(f"[*] Tested {tested_count} passwords...")

if not found_password:
    print(f"\n[-] Password not found after testing {tested_count} combinations")
    print("\n[*] Let me try common rockyou patterns...")
    
    # Common rockyou.txt patterns
    rockyou_common = [
        "123456", "password", "12345678", "qwerty", "123456789",
        "12345", "1234", "111111", "1234567", "dragon", "123123",
        "baseball", "iloveyou", "trustno1", "1234567890", "sunshine",
        "master", "123321", "666666", "photoshop", "111111",
        "131313", "654321", "superman", "qazwsx", "michael",
        "football", "letmein", "shadow", "monkey", "abc123",
        "pass", "fuckme", "6969", "jordan", "harley", "ranger",
        "iwantu", "jennifer", "hunter", "fuck", "2000", "test"
    ]
    
    for pwd in rockyou_common:
        pwd_hash = hashlib.md5(pwd.encode()).hexdigest()
        if pwd_hash == hash_to_crack:
            found_password = pwd
            print(f"\n[+] *** PASSWORD CRACKED ***")
            print(f"[+] Password: {pwd}")
            print(f"[+] MD5 Hash: {pwd_hash}")
            break

if not found_password:
    print("\n[-] Hash still not cracked. Need larger wordlist or online lookup service.")

