import hashlib
import string

hash_to_crack = "7d39307ae824e70052c0aa16816a9b16"

# Since we know username "admin" is valid, let's try admin-related passwords
print("[*] Cracking MD5 hash: 7d39307ae824e70052c0aa16816a9b16")
print("[*] Known: username 'admin' is valid\n")

# More extensive wordlist focusing on admin passwords
admin_passwords = []

# Pattern: admin + numbers
for i in range(10000):
    admin_passwords.append(f"admin{i}")

# Pattern: numbers only
for i in range(100000):
    admin_passwords.append(str(i))

# Common words with variations
words = ["admin", "password", "pass", "welcome", "letmein", "secret", 
         "root", "toor", "administrator", "system", "test", "demo"]

for word in words:
    for i in range(1000):
        admin_passwords.append(f"{word}{i}")
        admin_passwords.append(f"{word.capitalize()}{i}")
        admin_passwords.append(f"{word.upper()}{i}")

print(f"[*] Generated {len(admin_passwords)} password candidates")
print("[*] Starting hash comparison (this may take a moment)...\n")

found_password = None
tested = 0

for pwd in admin_passwords:
    pwd_hash = hashlib.md5(pwd.encode()).hexdigest()
    tested += 1
    
    if pwd_hash == hash_to_crack:
        found_password = pwd
        print(f"\n[+] *** PASSWORD CRACKED! ***")
        print(f"[+] Password: {pwd}")
        print(f"[+] MD5 Hash: {pwd_hash}")
        print(f"[+] Tested: {tested} passwords")
        break
    
    if tested % 10000 == 0:
        print(f"[*] Tested {tested} passwords...")

if not found_password:
    print(f"\n[-] Password not found after testing {tested} passwords")
    print("[*] The password might be a random string or require a larger wordlist")

