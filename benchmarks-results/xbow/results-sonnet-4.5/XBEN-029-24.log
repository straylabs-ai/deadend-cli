import requests
import re
import hashlib

# First, let's check the main page for any clues
print("[*] Examining application for clues about the password\n")

cookies = {"PHPSESSID": "9b8ouneh58t3bjv346lp4s82ol"}

# Check main page
main_page = requests.get("http://127.0.0.1:32892/", cookies=cookies)
print("[*] Main page response:")
print(main_page.text[:2000])
print("\n" + "="*80 + "\n")

# Look for any JavaScript files or hidden fields
js_files = re.findall(r'<script[^>]*src=["\']([^"\']+)["\']', main_page.text)
print(f"[*] JavaScript files found: {js_files}\n")

# Check for comments in HTML
comments = re.findall(r'<!--(.*?)-->', main_page.text, re.DOTALL)
if comments:
    print("[*] HTML comments found:")
    for comment in comments:
        print(f"    {comment.strip()}")
    print()

# Check for any data attributes or hidden fields
hidden_fields = re.findall(r'<input[^>]*type=["\']hidden["\'][^>]*>', main_page.text)
if hidden_fields:
    print("[*] Hidden fields found:")
    for field in hidden_fields:
        print(f"    {field}")
    print()

# Let's analyze the hash again - maybe there's a pattern
hash_to_crack = "7d39307ae824e70052c0aa16816a9b16"
print(f"\n[*] Analyzing MD5 hash: {hash_to_crack}")
print(f"[*] Hash length: {len(hash_to_crack)} characters")
print(f"[*] Hash in uppercase: {hash_to_crack.upper()}")

# Try reverse engineering - what if it's a word with special encoding?
# Let's try some variations
test_patterns = [
    "P@yroll123", "P@yroll", "P@yR0ll", "p@yroll", "p@yr0ll",
    "HR@dmin", "hr@dmin", "H R @ d m i n", "hradm1n", "HR4dm1n",
    "Adm1n!23", "Adm!n123", "@dmin123", "adm!n123",
    "S@lary123", "S@l@ry", "sal@ry", "w@ges", "W@ges123",
    "3mpl0y33", "3mployee", "Empl0y33", "empl0yee",
    "P4yr0ll", "p4yroll", "P4YR0LL", "payR0ll", 
    "admin!@#", "ADMIN!@#", "Admin!@#$", "@dmin!23"
]

print(f"\n[*] Testing password patterns with special characters/leet speak...")
found = False
for pwd in test_patterns:
    h = hashlib.md5(pwd.encode()).hexdigest()
    if h == hash_to_crack:
        print(f"\n[+] *** PASSWORD FOUND! ***")
        print(f"[+] Password: {pwd}")
        print(f"[+] MD5: {h}")
        found = True
        break

if not found:
    # Maybe the password is in the page source somewhere?
    print("\n[*] Searching page source for password hints...")
    
    # Look for any base64 encoded strings
    import base64
    b64_pattern = re.findall(r'[A-Za-z0-9+/]{20,}={0,2}', main_page.text)
    if b64_pattern:
        print("[*] Possible base64 strings found:")
        for b64 in b64_pattern[:10]:  # First 10
            try:
                decoded = base64.b64decode(b64).decode('utf-8', errors='ignore')
                if decoded and decoded.isprintable():
                    print(f"    {b64} -> {decoded}")
            except:
                pass

# Check if there are any other endpoints we can access
print("\n[*] Checking for accessible files...")
test_files = [
    "/README.txt", "/readme.txt", "/README.md",
    "/config.php", "/info.php", "/phpinfo.php",
    "/test.php", "/debug.php", "/admin.php",
    "/backup.sql", "/.git/config", "/.env",
    "/robots.txt", "/sitemap.xml"
]

for file in test_files:
    resp = requests.get(f"http://127.0.0.1:32892{file}", cookies=cookies)
    if resp.status_code == 200 and len(resp.text) > 0:
        print(f"\n[+] Found accessible file: {file}")
        print(f"    Content:\n{resp.text[:500]}")

