import requests
import json
import base64
from urllib.parse import urlencode

BASE_URL = "http://127.0.0.1:5003"
session = requests.Session()

# Set the existing session cookie
session.cookies.set('session', 'eyJfZnJlc2giOmZhbHNlfQ.aVpBkw.Gcl2QhY06fdBJpSbG9Wtdp3FE8A', domain='127.0.0.1', path='/')

print("[*] Testing login endpoint with multiple credential formats\n")

# Test credentials
credentials = [
    ("user", "user"),
    ("User", "User"),
    ("USER", "USER"),
    ("admin", "admin"),
    ("test", "test")
]

def decode_jwt(token):
    """Decode JWT token without verification"""
    try:
        parts = token.split('.')
        if len(parts) != 3:
            return None
        
        # Decode header
        header_padding = parts[0] + '=' * (4 - len(parts[0]) % 4)
        header = base64.urlsafe_b64decode(header_padding)
        
        # Decode payload
        payload_padding = parts[1] + '=' * (4 - len(parts[1]) % 4)
        payload = base64.urlsafe_b64decode(payload_padding)
        
        return {
            'header': json.loads(header),
            'payload': json.loads(payload),
            'signature': parts[2]
        }
    except Exception as e:
        print(f"[!] JWT decode error: {e}")
        return None

def extract_tokens(response):
    """Extract JWT tokens from cookies and headers"""
    tokens = {}
    
    # Check cookies
    for cookie in response.cookies:
        if 'token' in cookie.name.lower() or 'jwt' in cookie.name.lower() or 'auth' in cookie.name.lower():
            tokens[f"cookie_{cookie.name}"] = cookie.value
    
    # Check headers
    for header, value in response.headers.items():
        if 'token' in header.lower() or 'authorization' in header.lower():
            tokens[f"header_{header}"] = value
    
    # Check response body for tokens
    try:
        body = response.json()
        for key in ['token', 'jwt', 'access_token', 'auth_token', 'session_token']:
            if key in body:
                tokens[f"body_{key}"] = body[key]
    except:
        pass
    
    return tokens

def test_login(username, password, method="form"):
    """Test login with different formats"""
    url = f"{BASE_URL}/login"
    
    if method == "form":
        print(f"[*] Testing POST {url} with form data: {username}:{password}")
        data = {'username': username, 'password': password}
        headers = {'Content-Type': 'application/x-www-form-urlencoded'}
        response = session.post(url, data=data, headers=headers, allow_redirects=False)
    elif method == "json":
        print(f"[*] Testing POST {url} with JSON: {username}:{password}")
        data = {'username': username, 'password': password}
        headers = {'Content-Type': 'application/json'}
        response = session.post(url, json=data, headers=headers, allow_redirects=False)
    
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Headers: {dict(response.headers)}")
    print(f"[+] Cookies: {dict(response.cookies)}")
    
    # Check for redirect
    if 'Location' in response.headers:
        print(f"[+] Redirect to: {response.headers['Location']}")
    
    # Print response body
    print(f"[+] Response body:\n{response.text}\n")
    
    # Extract and decode tokens
    tokens = extract_tokens(response)
    if tokens:
        print("[!] TOKENS FOUND:")
        for token_name, token_value in tokens.items():
            print(f"  {token_name}: {token_value}")
            decoded = decode_jwt(token_value)
            if decoded:
                print(f"    JWT Header: {json.dumps(decoded['header'], indent=6)}")
                print(f"    JWT Payload: {json.dumps(decoded['payload'], indent=6)}")
                print(f"    JWT Signature: {decoded['signature']}")
    
    return response

print("="*80)
print("PHASE 1: Testing login with form data")
print("="*80)

for username, password in credentials:
    response = test_login(username, password, method="form")
    if response.status_code in [200, 302]:
        print(f"[!] SUCCESS with {username}:{password} (form data)")
        break
    print("-"*80)

print("\n" + "="*80)
print("PHASE 2: Testing login with JSON")
print("="*80)

for username, password in credentials:
    response = test_login(username, password, method="json")
    if response.status_code in [200, 302]:
        print(f"[!] SUCCESS with {username}:{password} (JSON)")
        break
    print("-"*80)

print("\n" + "="*80)
print("PHASE 3: Attempting registration")
print("="*80)

# Try to register
register_endpoints = ['/register', '/api/register', '/signup']
for endpoint in register_endpoints:
    url = f"{BASE_URL}{endpoint}"
    print(f"\n[*] Testing POST {url}")
    
    # Try form data
    data = {'username': 'user', 'password': 'user'}
    response = session.post(url, data=data, allow_redirects=False)
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Response: {response.text[:500]}")
    
    if response.status_code in [200, 201, 302]:
        print(f"[!] Registration endpoint found: {endpoint}")
        print(f"[+] Full response:\n{response.text}")
        
        # Try login again after registration
        print("\n[*] Attempting login after registration...")
        login_response = test_login('user', 'user', method="form")
        break

print("\n" + "="*80)
print("PHASE 4: Accessing protected resources")
print("="*80)

# Try to access profile
profile_url = f"{BASE_URL}/profile"
print(f"\n[*] GET {profile_url}")
response = session.get(profile_url, allow_redirects=False)
print(f"[+] Status: {response.status_code}")
print(f"[+] Headers: {dict(response.headers)}")
print(f"[+] Cookies: {dict(response.cookies)}")
print(f"[+] Response:\n{response.text}")

# Check for tokens in profile response
tokens = extract_tokens(response)
if tokens:
    print("\n[!] TOKENS FOUND IN PROFILE:")
    for token_name, token_value in tokens.items():
        print(f"  {token_name}: {token_value}")
        decoded = decode_jwt(token_value)
        if decoded:
            print(f"    JWT Header: {json.dumps(decoded['header'], indent=6)}")
            print(f"    JWT Payload: {json.dumps(decoded['payload'], indent=6)}")
            print(f"    JWT Signature: {decoded['signature']}")

print("\n" + "="*80)
print("PHASE 5: Session cookie analysis")
print("="*80)

# Analyze all session cookies
print("\n[*] All session cookies:")
for cookie in session.cookies:
    print(f"\n  Cookie: {cookie.name}")
    print(f"  Value: {cookie.value}")
    print(f"  Domain: {cookie.domain}")
    print(f"  Path: {cookie.path}")
    
    # Try to decode if it looks like base64/JWT
    decoded = decode_jwt(cookie.value)
    if decoded:
        print(f"  JWT Header: {json.dumps(decoded['header'], indent=4)}")
        print(f"  JWT Payload: {json.dumps(decoded['payload'], indent=4)}")
        print(f"  JWT Signature: {decoded['signature']}")

print("\n[*] Testing complete")

