import requests
import json
import base64

BASE_URL = "http://127.0.0.1:5003"

def decode_jwt(token):
    """Decode JWT token without verification"""
    try:
        parts = token.split('.')
        if len(parts) != 3:
            return None
        
        # Decode header
        header_padding = parts[0] + '=' * (4 - len(parts[0]) % 4)
        header = base64.urlsafe_b64decode(header_padding)
        
        # Decode payload
        payload_padding = parts[1] + '=' * (4 - len(parts[1]) % 4)
        payload = base64.urlsafe_b64decode(payload_padding)
        
        return {
            'header': json.loads(header),
            'payload': json.loads(payload),
            'signature': parts[2]
        }
    except Exception as e:
        return None

print("[PHASE 1] Testing login with form data")

# Test 1: Form data with user:user
url = f"{BASE_URL}/login"
data = {'username': 'user', 'password': 'user'}
response = requests.post(url, data=data, allow_redirects=False)

print(f"POST {url} (form data)")
print(f"Status: {response.status_code}")
print(f"Headers: {dict(response.headers)}")
print(f"Cookies: {dict(response.cookies)}")
print(f"Response:\n{response.text}\n")

# Check for JWT in cookies
for cookie in response.cookies:
    decoded = decode_jwt(cookie.value)
    if decoded:
        print(f"JWT in cookie '{cookie.name}':")
        print(f"  Header: {json.dumps(decoded['header'])}")
        print(f"  Payload: {json.dumps(decoded['payload'])}")
        print(f"  Signature: {decoded['signature']}\n")

print("\n[PHASE 2] Testing login with JSON")

# Test 2: JSON data with user:user
response = requests.post(url, json=data, allow_redirects=False)

print(f"POST {url} (JSON)")
print(f"Status: {response.status_code}")
print(f"Cookies: {dict(response.cookies)}")
print(f"Response:\n{response.text}\n")

print("\n[PHASE 3] Testing with uppercase credentials")

# Test 3: Uppercase variations
for username, password in [('User', 'User'), ('USER', 'USER')]:
    data = {'username': username, 'password': password}
    response = requests.post(url, data=data, allow_redirects=False)
    print(f"POST {url} ({username}:{password})")
    print(f"Status: {response.status_code}")
    if response.status_code == 200 or response.status_code == 302:
        print(f"Response:\n{response.text}\n")

print("\n[PHASE 4] Attempting registration")

# Test 4: Try to register
register_url = f"{BASE_URL}/register"
data = {'username': 'user', 'password': 'user'}
response = requests.post(register_url, data=data, allow_redirects=False)

print(f"POST {register_url}")
print(f"Status: {response.status_code}")
print(f"Response:\n{response.text}\n")

# If registration works, try login again
if response.status_code in [200, 201, 302]:
    print("[*] Registration successful, trying login again")
    response = requests.post(f"{BASE_URL}/login", data=data, allow_redirects=False)
    print(f"POST {BASE_URL}/login")
    print(f"Status: {response.status_code}")
    print(f"Cookies: {dict(response.cookies)}")
    print(f"Response:\n{response.text}\n")

print("\n[PHASE 5] Accessing /profile")

# Test 5: Access profile
profile_url = f"{BASE_URL}/profile"
response = requests.get(profile_url, allow_redirects=False)

print(f"GET {profile_url}")
print(f"Status: {response.status_code}")
print(f"Cookies: {dict(response.cookies)}")
print(f"Response:\n{response.text}\n")

print("[*] Testing complete")

