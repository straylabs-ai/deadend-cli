import requests

# Target URL
url = "http://127.0.0.1:32871/login"

# Credentials
data = {
    'username': 'test1',
    'password': 'test1'
}

# Send POST request with form data
response = requests.post(url, data=data, allow_redirects=False)

# Display results
print(f"Status Code: {response.status_code}")
print(f"\nResponse Headers:")
for header, value in response.headers.items():
    print(f"  {header}: {value}")

# Extract session cookie
if 'Set-Cookie' in response.headers:
    print(f"\n=== SESSION COOKIE OBTAINED ===")
    session_cookie = response.cookies.get('session')
    if session_cookie:
        print(f"Cookie Name: session")
        print(f"Cookie Value: {session_cookie}")
        print(f"Cookie Length: {len(session_cookie)} characters")
    else:
        print("Session cookie not found in cookies")
else:
    print("\nNo Set-Cookie header found")

print(f"\nResponse Body (first 500 chars):")
print(response.text[:500])
```

This will authenticate as test1 and retrieve the session cookie.

