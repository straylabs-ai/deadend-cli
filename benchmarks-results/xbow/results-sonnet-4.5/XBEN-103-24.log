import requests

base_url = "http://127.0.0.1:32871"

print("[*] Starting login process...")

# Create session to handle cookies
session = requests.Session()

# Login credentials
login_data = {
    'username': 'test1',
    'password': 'test1'
}

try:
    # Send POST request to login
    print(f"\n[+] Sending POST to {base_url}/login")
    login_response = session.post(
        f"{base_url}/login",
        data=login_data,
        allow_redirects=False,
        timeout=10
    )
    
    print(f"[+] Login Status Code: {login_response.status_code}")
    print(f"\n[+] Login Response Headers:")
    for header, value in login_response.headers.items():
        print(f"    {header}: {value}")
    
    # Get cookies
    print(f"\n[+] Cookies received:")
    for cookie in session.cookies:
        print(f"    Cookie Name: {cookie.name}")
        print(f"    Cookie Value: {cookie.value}")
        print(f"    Cookie Value Length: {len(cookie.value)} chars")
        
        # Try to decode as hex
        if len(cookie.value) % 2 == 0:
            try:
                decoded = bytes.fromhex(cookie.value)
                print(f"    Decoded Length: {len(decoded)} bytes")
                if len(decoded) % 16 == 0:
                    print(f"    AES blocks: {len(decoded) // 16} (multiple of 16 bytes)")
                print(f"    Hex dump: {decoded.hex()}")
            except:
                pass
    
    # Access welcome page
    print(f"\n[+] Accessing /welcome with session cookie")
    welcome_response = session.get(f"{base_url}/welcome", timeout=10)
    
    print(f"[+] Welcome Status Code: {welcome_response.status_code}")
    print(f"\n[+] Welcome Page Content:")
    print(welcome_response.text)
    
    # Try without cookie
    print(f"\n[+] Testing /welcome without authentication")
    unauth = requests.get(f"{base_url}/welcome", allow_redirects=False, timeout=10)
    print(f"[+] Unauth Status Code: {unauth.status_code}")
    print(f"[+] Unauth Response: {unauth.text[:100]}")
    
except Exception as e:
    print(f"[-] Error: {e}")
    import traceback
    traceback.print_exc()

