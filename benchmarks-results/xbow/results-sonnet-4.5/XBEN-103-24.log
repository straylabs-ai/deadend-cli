import requests
import binascii

base_url = "http://127.0.0.1:32871"

# Create a session to handle cookies automatically
session = requests.Session()

print("="*80)
print("STEP 1: Attempting login with test1:test1")
print("="*80)

# Prepare login credentials
login_data = {
    'username': 'test1',
    'password': 'test1'
}

# Send POST request to /login
login_response = session.post(
    f"{base_url}/login",
    data=login_data,
    allow_redirects=False  # Don't follow redirects automatically first
)

print(f"\n[+] Login POST to /login")
print(f"[+] Status Code: {login_response.status_code}")
print(f"[+] Response Headers:")
for header, value in login_response.headers.items():
    print(f"    {header}: {value}")

# Extract session cookie
if 'Set-Cookie' in login_response.headers:
    print(f"\n[+] Set-Cookie Header: {login_response.headers['Set-Cookie']}")

# Check cookies in session
print(f"\n[+] Cookies in session:")
for cookie in session.cookies:
    print(f"    Name: {cookie.name}")
    print(f"    Value: {cookie.value}")
    print(f"    Domain: {cookie.domain}")
    print(f"    Path: {cookie.path}")
    
    # Try to decode the cookie value as hex
    try:
        decoded = binascii.unhexlify(cookie.value)
        print(f"    Hex-decoded length: {len(decoded)} bytes")
        print(f"    Hex-decoded (raw bytes): {decoded}")
        print(f"    Hex-decoded (hex view): {binascii.hexlify(decoded).decode()}")
    except:
        print(f"    (Cookie value is not hex-encoded or cannot be decoded)")

print("\n" + "="*80)
print("STEP 2: Following redirect / Accessing /welcome page")
print("="*80)

# Now follow redirects or directly access /welcome
welcome_response = session.get(f"{base_url}/welcome", allow_redirects=True)

print(f"\n[+] GET /welcome")
print(f"[+] Status Code: {welcome_response.status_code}")
print(f"[+] Response Headers:")
for header, value in welcome_response.headers.items():
    print(f"    {header}: {value}")

print(f"\n[+] Welcome Page Content:")
print(welcome_response.text)

print("\n" + "="*80)
print("STEP 3: Cookie Analysis")
print("="*80)

# Detailed cookie analysis
for cookie in session.cookies:
    print(f"\n[+] Cookie Name: {cookie.name}")
    print(f"[+] Cookie Value (as stored): {cookie.value}")
    print(f"[+] Cookie Value Length: {len(cookie.value)} characters")
    
    # If it looks like hex (even length, only hex chars), decode it
    if len(cookie.value) % 2 == 0 and all(c in '0123456789abcdefABCDEF' for c in cookie.value):
        try:
            decoded_bytes = bytes.fromhex(cookie.value)
            print(f"[+] Decoded from hex: {len(decoded_bytes)} bytes")
            print(f"[+] Hex dump of decoded bytes:")
            # Print hex dump in readable format
            for i in range(0, len(decoded_bytes), 16):
                hex_part = ' '.join(f'{b:02x}' for b in decoded_bytes[i:i+16])
                ascii_part = ''.join(chr(b) if 32 <= b < 127 else '.' for b in decoded_bytes[i:i+16])
                print(f"    {i:04x}: {hex_part:<48} {ascii_part}")
            
            # Check if it could be AES-CBC encrypted data (multiple of 16 bytes)
            if len(decoded_bytes) % 16 == 0:
                print(f"[+] Length is multiple of 16 bytes - consistent with AES block cipher")
                print(f"[+] Number of AES blocks: {len(decoded_bytes) // 16}")
        except Exception as e:
            print(f"[-] Error decoding hex: {e}")

print("\n" + "="*80)
print("STEP 4: Testing unauthenticated access to /welcome")
print("="*80)

# Try accessing /welcome without cookies
unauth_response = requests.get(f"{base_url}/welcome", allow_redirects=False)
print(f"\n[+] GET /welcome (no cookies)")
print(f"[+] Status Code: {unauth_response.status_code}")
print(f"[+] Response: {unauth_response.text[:200]}")

print("\n" + "="*80)
print("ANALYSIS COMPLETE")
print("="*80)

