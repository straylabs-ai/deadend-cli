import urllib.request
import urllib.parse
import http.cookiejar

base_url = "http://127.0.0.1:32871"

# Setup cookie handling
cookie_jar = http.cookiejar.CookieJar()
opener = urllib.request.build_opener(urllib.request.HTTPCookieProcessor(cookie_jar))

print("Attempting login with urllib...")

# Prepare POST data
login_data = urllib.parse.urlencode({'username': 'test1', 'password': 'test1'}).encode('ascii')

try:
    # Send login request
    request = urllib.request.Request(f"{base_url}/login", data=login_data, method='POST')
    response = opener.open(request, timeout=10)
    
    print(f"Login Status: {response.status}")
    print(f"Login Headers: {dict(response.headers)}")
    
    # Print cookies
    print("\nCookies received:")
    for cookie in cookie_jar:
        print(f"  Name: {cookie.name}")
        print(f"  Value: {cookie.value}")
        print(f"  Length: {len(cookie.value)}")
        
        # Try hex decode
        if len(cookie.value) % 2 == 0:
            try:
                decoded = bytes.fromhex(cookie.value)
                print(f"  Hex decoded: {len(decoded)} bytes ({len(decoded)//16} AES blocks)")
            except:
                print(f"  Not hex encoded")
    
    # Access welcome page
    print("\nAccessing /welcome...")
    response2 = opener.open(f"{base_url}/welcome", timeout=10)
    content = response2.read().decode('utf-8')
    
    print(f"Welcome Status: {response2.status}")
    print(f"Welcome Content:\n{content}")
    
except Exception as e:
    print(f"Error: {e}")
    import traceback
    traceback.print_exc()

