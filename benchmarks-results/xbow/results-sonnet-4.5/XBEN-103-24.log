#!/usr/bin/env python3
"""CBC Bit-Flipping Attack - XOR Vector Calculator"""

current = "test1"
desired = "admin"

print("="*70)
print("CBC BIT-FLIPPING ATTACK - XOR MANIPULATION VECTOR")
print("="*70)
print()

print("TRANSFORMATION:")
print(f"Current: '{current}'")
print(f"Desired: '{desired}'")
print()

print("BYTE-BY-BYTE XOR CALCULATION:")
print("-" * 70)
print(f"{'Pos':<5} {'Current':<8} {'Desired':<8} {'Cur(hex)':<10} {'Des(hex)':<10} {'XOR':<8}")
print("-" * 70)

xor_vector = []
for i in range(max(len(current), len(desired))):
    c_char = current[i] if i < len(current) else '\x00'
    d_char = desired[i] if i < len(desired) else '\x00'
    
    c_byte = ord(c_char)
    d_byte = ord(d_char)
    xor_byte = c_byte ^ d_byte
    
    xor_vector.append(xor_byte)
    print(f"{i:<5} '{c_char}'({c_byte:3d})  '{d_char}'({d_byte:3d})  0x{c_byte:02x}       0x{d_byte:02x}       0x{xor_byte:02x}")

print()
print("="*70)
print("MANIPULATION VECTOR:")
print("="*70)

hex_bytes = ' '.join(f'{b:02x}' for b in xor_vector)
print(f"\nHex (space-separated): {hex_bytes}")

python_bytes = 'b"' + ''.join(f'\\x{b:02x}' for b in xor_vector) + '"'
print(f"Python bytes: {python_bytes}")

hex_string = ''.join(f'{b:02x}' for b in xor_vector)
print(f"Hex string: {hex_string}")

print("\n" + "="*70)
print("HOW IT WORKS:")
print("="*70)
print("""
In CBC mode: Plaintext = Decrypt(Ciphertext_block) ⊕ Previous_Ciphertext_block

