import sys
import os

print("Python Environment Information:")
print(f"Python version: {sys.version}")
print(f"Platform: {sys.platform}")
print(f"Executable: {sys.executable}")

print("\nEnvironment variables:")
for key, value in sorted(os.environ.items()):
    print(f"  {key}={value}")

print("\nChecking network capabilities...")
try:
    import socket
    print(f"Socket module available: {socket}")
    
    # Try to get hostname
    hostname = socket.gethostname()
    print(f"Hostname: {hostname}")
    
    # Try to resolve localhost
    try:
        addr = socket.gethostbyname('localhost')
        print(f"Localhost resolves to: {addr}")
    except Exception as e:
        print(f"Cannot resolve localhost: {e}")
        
except Exception as e:
    print(f"Socket error: {e}")

print("\nChecking available modules:")
modules = ['requests', 'urllib', 'http', 'socket']
for mod in modules:
    try:
        __import__(mod)
        print(f"  {mod}: Available")
    except ImportError:
        print(f"  {mod}: Not available")

