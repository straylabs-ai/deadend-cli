#!/usr/bin/env python3
"""
CBC Bit-Flipping Attack - XOR Manipulation Vector Calculator

This script calculates the XOR manipulation vector needed to transform
one plaintext to another by manipulating the previous ciphertext block.

Educational demonstration of CBC mode vulnerability without authentication.
"""

def calculate_xor_vector(current_plaintext, desired_plaintext):
    """
    Calculate XOR manipulation vector for bit-flipping attack.
    
    In CBC mode:
    - Plaintext[i] = Decrypt(Ciphertext[i]) XOR Ciphertext[i-1]
    - To change Plaintext[i], we modify Ciphertext[i-1]
    - Manipulation = Current_Plaintext XOR Desired_Plaintext
    """
    
    # Ensure same length (pad if needed)
    max_len = max(len(current_plaintext), len(desired_plaintext))
    current = current_plaintext.ljust(max_len, '\x00')
    desired = desired_plaintext.ljust(max_len, '\x00')
    
    print("="*70)
    print("CBC BIT-FLIPPING ATTACK - XOR MANIPULATION VECTOR")
    print("="*70)
    print()
    
    print("ATTACK PRINCIPLE:")
    print("-" * 70)
    print("In CBC mode: P[i] = Decrypt(C[i]) ⊕ C[i-1]")
    print("To change P[i] from 'A' to 'B':")
    print("  1. Calculate: flip_vector = 'A' ⊕ 'B'")
    print("  2. Apply: C[i-1] = C[i-1] ⊕ flip_vector")
    print("  3. Result: New P[i] = Decrypt(C[i]) ⊕ (C[i-1] ⊕ flip_vector)")
    print("             = Decrypt(C[i]) ⊕ C[i-1] ⊕ flip_vector")
    print("             = 'A' ⊕ flip_vector = 'A' ⊕ 'A' ⊕ 'B' = 'B'")
    print()
    
    print("TRANSFORMATION:")
    print("-" * 70)
    print(f"Current Plaintext:  '{current_plaintext}'")
    print(f"Desired Plaintext:  '{desired_plaintext}'")
    print()
    
    print("BYTE-BY-BYTE CALCULATION:")
    print("-" * 70)
    print(f"{'Pos':<5} {'Current':<10} {'Desired':<10} {'Cur Hex':<10} {'Des Hex':<10} {'XOR Result':<12}")
    print("-" * 70)
    
    xor_vector = []
    
    for i in range(max_len):
        current_char = current[i]
        desired_char = desired[i]
        
        current_byte = ord(current_char)
        desired_byte = ord(desired_char)
        xor_byte = current_byte ^ desired_byte
        
        xor_vector.append(xor_byte)
        
        # Display character or hex for non-printable
        current_display = current_char if current_char.isprintable() and current_char != '\x00' else f"\\x{current_byte:02x}"
        desired_display = desired_char if desired_char.isprintable() and desired_char != '\x00' else f"\\x{desired_byte:02x}"
        
        print(f"{i:<5} {current_display:<10} {desired_display:<10} 0x{current_byte:02x} ({current_byte:3d})  0x{desired_byte:02x} ({desired_byte:3d})  0x{xor_byte:02x} ({xor_byte:3d})")
    
    print()
    print("="*70)
    print("MANIPULATION VECTOR (XOR VALUES):")
    print("="*70)
    print()
    
    # Hex bytes format
    hex_bytes = ' '.join(f'{b:02x}' for b in xor_vector)
    print(f"Hex bytes (space-separated): {hex_bytes}")
    print()
    
    # Python bytes literal
    python_bytes = 'b"' + ''.join(f'\\x{b:02x}' for b in xor_vector) + '"'
    print(f"Python bytes literal: {python_bytes}")
    print()
    
    # Hex string (no spaces)
    hex_string = ''.join(f'{b:02x}' for b in xor_vector)
    print(f"Hex string: {hex_string}")
    print()
    
    # Binary representation
    print("Binary representation:")
    for i, b in enumerate(xor_vector):
        char_info = f"('{current[i]}' -> '{desired[i]}')" if i < len(current_plaintext) and i < len(desired_plaintext) else ""
        print(f"  Byte {i}: {b:08b}  (0x{b:02x})  {char_info}")
    print()
    
    print("="*70)
    print("HOW TO APPLY THE ATTACK:")
    print("="*70)
    print()
    print("1. IDENTIFY TARGET BLOCK:")
    print("   - Locate the ciphertext block that decrypts to 'test1'")
    print("   - Identify the PREVIOUS ciphertext block (or IV if it's the first block)")
    print()
    print("2. APPLY MANIPULATION:")
    print("   - XOR the previous block with the manipulation vector above")
    print("   - Formula: modified_block = previous_block ⊕ manipulation_vector")
    print()
    print("3. RESULT:")
    print("   - The target block will now decrypt to 'admin' (with possible corruption)")
    print("   - The previous block's plaintext will be corrupted (CBC property)")
    print()
    
    print("EXAMPLE CODE:")
    print("-" * 70)
    print(f"""
# Assuming you have the ciphertext
ciphertext = b"..."  # Your full ciphertext
manipulation_vector = {python_bytes}

# If 'test1' is in block i, modify block i-1 (or IV if i=0)
block_size = 16  # Common for AES
target_block_index = 1  # Example: 'test1' is in block 1
