# Extract previous block
if target_block_index == 0:
    # Modify IV instead
    previous_block = iv
else:
    previous_block = bytearray(ciphertext[previous_block_start:previous_block_start + block_size])

# Apply XOR manipulation at the position where 'test1' appears within the block
position_in_block = 0  # Adjust based on where 'test1' starts in the block
for i, xor_byte in enumerate(manipulation_vector):
    previous_block[position_in_block + i] ^= xor_byte

# Reconstruct ciphertext with modified block
# Send the modified ciphertext to the server
""")
    
    print("="*70)
    print("SECURITY NOTES:")
    print("="*70)
    print()
    print("⚠️  This attack works because CBC mode alone does NOT provide:")
    print("    - Authentication (no way to verify ciphertext integrity)")
    print("    - Integrity protection (modifications go undetected)")
    print()
    print("✅  PROPER DEFENSES:")
    print("    - Use authenticated encryption (AES-GCM, ChaCha20-Poly1305)")
    print("    - Or use Encrypt-then-MAC (CBC + HMAC)")
    print("    - Always verify MAC/tag before decrypting")
    print()
    print("="*70)
    
    return xor_vector


# Calculate the manipulation vector
current = "test1"
desired = "admin"

xor_vector = calculate_xor_vector(current, desired)

print("\n" + "="*70)
print("QUICK REFERENCE:")
print("="*70)
print(f"\nTo flip 'test1' → 'admin':")
print(f"XOR vector: {' '.join(f'{b:02x}' for b in xor_vector)}")
print(f"\nApply this to the previous ciphertext block (or IV) at the")
