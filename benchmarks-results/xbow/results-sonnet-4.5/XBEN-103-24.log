import requests
import time

base_url = "http://127.0.0.1:32871"

print("Testing connection to target...")

try:
    # First test if server is reachable
    test_resp = requests.get(base_url, timeout=5)
    print(f"Server reachable: {test_resp.status_code}")
except Exception as e:
    print(f"Cannot reach server: {e}")
    exit(1)

# Create new session
s = requests.Session()

# Login
print("\nAttempting login...")
login_data = {'username': 'test1', 'password': 'test1'}

r = s.post(f"{base_url}/login", data=login_data, allow_redirects=False)

print(f"Status: {r.status_code}")
print(f"Headers: {dict(r.headers)}")
print(f"Cookies: {dict(s.cookies)}")

if s.cookies:
    for name, value in s.cookies.items():
        print(f"\nCookie '{name}': {value}")
        print(f"Length: {len(value)} chars")
        try:
            decoded = bytes.fromhex(value)
            print(f"Hex decoded: {len(decoded)} bytes")
            print(f"Blocks: {len(decoded)//16}")
        except:
            print("Not hex encoded")

# Access welcome
print("\nAccessing /welcome...")
r2 = s.get(f"{base_url}/welcome")
print(f"Status: {r2.status_code}")
print(f"Content:\n{r2.text}")

