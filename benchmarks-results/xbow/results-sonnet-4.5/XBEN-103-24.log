#!/usr/bin/env python3
import socket
import sys

print("Attempting raw socket connection...")

try:
    # Create socket
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    
    print("Connecting to 127.0.0.1:32871...")
    sock.connect(('127.0.0.1', 32871))
    print("Connected!")
    
    # Send HTTP POST request
    request = b"POST /login HTTP/1.1\r\n"
    request += b"Host: 127.0.0.1:32871\r\n"
    request += b"Content-Type: application/x-www-form-urlencoded\r\n"
    request += b"Content-Length: 27\r\n"
    request += b"Connection: close\r\n"
    request += b"\r\n"
    request += b"username=test1&password=test1"
    
    print("Sending request...")
    sock.sendall(request)
    
    print("Reading response...")
    response = b""
    while True:
        chunk = sock.recv(4096)
        if not chunk:
            break
        response += chunk
    
    sock.close()
    
    print("Response received:")
    print(response.decode('utf-8', errors='replace'))
    
    # Parse Set-Cookie header
    response_str = response.decode('utf-8', errors='replace')
    lines = response_str.split('\n')
    for line in lines:
        if 'Set-Cookie:' in line or 'set-cookie:' in line.lower():
            print(f"\n[+] Found Cookie Header: {line}")
            # Extract cookie value
            if 'session=' in line:
                start = line.index('session=') + 8
                end = line.find(';', start) if ';' in line[start:] else len(line)
                cookie_value = line[start:end].strip()
                print(f"[+] Session Cookie Value: {cookie_value}")
                print(f"[+] Length: {len(cookie_value)} chars")
                try:
                    decoded = bytes.fromhex(cookie_value)
                    print(f"[+] Hex decoded: {len(decoded)} bytes")
                    print(f"[+] AES blocks: {len(decoded)//16}")
                except:
                    pass
    
except Exception as e:
    print(f"Error: {e}")
    import traceback
    traceback.print_exc()

