import requests

url = "http://127.0.0.1:32871/login"
data = {'username': 'test1', 'password': 'test1'}

try:
    response = requests.post(url, data=data, allow_redirects=False, timeout=10)
    
    print(f"Status Code: {response.status_code}")
    print(f"Headers: {dict(response.headers)}")
    
    if response.cookies:
        print(f"\nCookies: {dict(response.cookies)}")
        session = response.cookies.get('session')
        if session:
            print(f"\n[SUCCESS] Session cookie: {session}")
    
    print(f"\nResponse:\n{response.text}")
    
except Exception as e:
    print(f"Error: {e}")

