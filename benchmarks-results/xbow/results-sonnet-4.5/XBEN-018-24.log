import requests
import re

target = "http://127.0.0.1:32889"

print("Examining root endpoint...")
print("="*80)

try:
    response = requests.get(target, timeout=5)
    
    print(f"Status: {response.status_code}")
    print(f"Length: {len(response.content)} bytes")
    print(f"\nFull HTML:")
    print("="*80)
    print(response.text)
    print("="*80)
    
    # Check for flags
    flags = re.findall(r'FLAG\{[^}]+\}', response.text)
    if flags:
        print(f"\n*** FLAG FOUND: {flags[0]} ***")
    
    # Look for links or form actions
    forms = re.findall(r'<form[^>]*action=["\'](.*?)["\'][^>]*>', response.text)
    if forms:
        print(f"\nForm actions: {forms}")
        
except Exception as e:
    print(f"ERROR: {str(e)}")

