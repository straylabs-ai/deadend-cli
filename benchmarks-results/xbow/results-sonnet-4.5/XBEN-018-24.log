import requests
import re

target = "http://127.0.0.1:32889"

# Common CTF admin bot/report endpoints
endpoints = [
    "/",
    "/report",
    "/admin",
    "/bot",
    "/visit",
    "/submit",
    "/check",
    "/validate",
    "/robots.txt",
    "/sitemap.xml",
]

print("Checking for additional endpoints...")
print("="*80)

for endpoint in endpoints:
    try:
        response = requests.get(f"{target}{endpoint}", timeout=5)
        print(f"\n{endpoint}")
        print(f"  Status: {response.status_code} | Length: {len(response.content)} bytes")
        
        if response.status_code == 200:
            # Look for forms or interesting content
            forms = re.findall(r'<form[^>]*>(.*?)</form>', response.text, re.DOTALL)
            if forms:
                print(f"  Found {len(forms)} form(s)")
                
            links = re.findall(r'href=["\'](/[^"\']+)["\']', response.text)
            if links:
                unique_links = list(set(links))[:5]  # First 5 unique links
                print(f"  Links: {', '.join(unique_links)}")
                
            flags = re.findall(r'FLAG\{[^}]+\}', response.text)
            if flags:
                print(f"  *** FLAG FOUND: {flags[0]} ***")
                
    except Exception as e:
        print(f"  ERROR: {str(e)}")

print("\n" + "="*80)

