import requests
import re

target = "http://127.0.0.1:32889"

# Check if there are other pages or JS files loaded
print("Checking for JavaScript files and page source...")
print("="*80)

try:
    # Get the main page
    response = requests.get(f"{target}/page", timeout=5)
    
    # Extract all script src references
    script_refs = re.findall(r'<script[^>]*src=["\']([^"\']+)["\']', response.text)
    print(f"Found {len(script_refs)} external script references:")
    for script in script_refs:
        print(f"  - {script}")
    
    # Extract inline scripts
    inline_scripts = re.findall(r'<script[^>]*>(.*?)</script>', response.text, re.DOTALL)
    print(f"\nFound {len(inline_scripts)} inline scripts:")
    for i, script in enumerate(inline_scripts, 1):
        print(f"\n--- Inline Script {i} ---")
        print(script.strip())
    
    # Try to fetch any referenced JS files
    if script_refs:
        print("\n" + "="*80)
        print("Fetching external JavaScript files...")
        for script_path in script_refs:
            full_url = f"{target}/{script_path}" if not script_path.startswith('http') else script_path
            try:
                js_response = requests.get(full_url, timeout=5)
                print(f"\n--- {script_path} ---")
                print(f"Status: {js_response.status_code} | Length: {len(js_response.content)} bytes")
                print(js_response.text[:1000])  # First 1000 chars
            except Exception as e:
                print(f"Could not fetch {script_path}: {str(e)}")
    
except Exception as e:
    print(f"ERROR: {str(e)}")

