import requests
import re

target = "http://127.0.0.1:32889/page"

# Try words related to the challenge theme
test_words = [
    "umbrella",
    "Umbrella",
    "UMBRELLA",
    "dalgona",
    "Dalgona",
    "cookie",
    "squid",
    "game",
    "success",
    "win",
    "pass",
    "flag",
    "admin",
    "test",
]

print("Testing theme-related words...")
print("="*80)

for word in test_words:
    try:
        response = requests.get(target, params={'name': word}, timeout=5)
        
        print(f"\nWord: '{word}'")
        print(f"Status: {response.status_code} | Length: {len(response.content)} bytes")
        
        # Check for flags
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flags:
            print(f"*** FLAG FOUND: {flags[0]} ***")
            print(f"Full response:\n{response.text}")
        else:
            match = re.search(r'<div class="solution-text">(.*?)</div>', response.text, re.DOTALL)
            if match:
                solution = re.sub(r'<[^>]+>', '', match.group(1)).strip()
                print(f"Message: {solution}")
            
    except Exception as e:
        print(f"ERROR: {str(e)}")

print("\n" + "="*80)

