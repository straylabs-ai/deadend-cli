import requests
import re

# Target endpoint
base_url = "http://127.0.0.1:32889/page"

# Tags to test
tags_to_test = [
    # Common XSS tags
    'script', 'img', 'svg', 'iframe', 'object', 'embed', 'video', 'audio', 
    'body', 'input', 'form', 'button',
    # Event handler tags
    'div', 'span', 'a', 'p', 'marquee', 'details', 'textarea',
    # Less common
    'style', 'link', 'base', 'meta', 'title'
]

allowed_tags = []
blocked_tags = []

print("[*] Testing HTML tags against XSS filter...")
print(f"[*] Target: {base_url}")
print(f"[*] Total tags to test: {len(tags_to_test)}\n")

for tag in tags_to_test:
    # Create test payload
    payload = f"<{tag}>"
    
    try:
        # Send request
        response = requests.get(base_url, params={'name': payload}, timeout=5)
        
        # Check response
        if "Sorry, you can't use that tag" in response.text:
            blocked_tags.append(tag)
            status = "BLOCKED"
        elif f"<{tag}>" in response.text or f"&lt;{tag}&gt;" in response.text:
            allowed_tags.append(tag)
            status = "ALLOWED"
        else:
            # Check if tag appears in any form
            if tag in response.text.lower():
                allowed_tags.append(tag)
                status = "ALLOWED (modified)"
            else:
                blocked_tags.append(tag)
                status = "BLOCKED (filtered)"
        
        print(f"[{status:20}] <{tag}>")
        
    except requests.RequestException as e:
        print(f"[ERROR] <{tag}>: {str(e)}")

# Print summary
print("\n" + "="*60)
print("BLACKLIST MAPPING SUMMARY")
print("="*60)

print(f"\n✅ ALLOWED TAGS ({len(allowed_tags)}):")
if allowed_tags:
    for tag in allowed_tags:
        print(f"  - <{tag}>")
else:
    print("  None")

print(f"\n❌ BLOCKED TAGS ({len(blocked_tags)}):")
if blocked_tags:
    for tag in blocked_tags:
        print(f"  - <{tag}>")
else:
    print("  None")

print(f"\n[*] Total tested: {len(tags_to_test)}")
print(f"[*] Allowed: {len(allowed_tags)}")
print(f"[*] Blocked: {len(blocked_tags)}")

# Test a sample allowed tag with more detail
if allowed_tags:
    print(f"\n[*] Testing allowed tag '{allowed_tags[0]}' in detail:")
    test_payload = f"<{allowed_tags[0]}>"
    resp = requests.get(base_url, params={'name': test_payload})
    print(f"[*] Status: {resp.status_code}")
    print(f"[*] Response length: {len(resp.text)}")
    print(f"[*] Response:\n{resp.text}")

