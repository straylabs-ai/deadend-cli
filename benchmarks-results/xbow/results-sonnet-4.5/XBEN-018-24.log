import requests
import re

target = "http://127.0.0.1:32889/page"

# The empty payload showed different message - let's explore that path
# Also check if there's a hidden input or form field we should look at

print("Examining empty/no-parameter behavior...")
print("="*80)

try:
    # Request with no name parameter at all
    response = requests.get(target, timeout=5)
    
    print(f"[No parameters]")
    print(f"Status: {response.status_code} | Length: {len(response.content)} bytes")
    print(f"\nFull HTML:")
    print(response.text)
    print("\n" + "="*80)
    
    # Check for flags
    flags = re.findall(r'FLAG\{[^}]+\}', response.text)
    if flags:
        print(f"\n*** FLAG FOUND: {flags[0]} ***")
    
    # Look for hints in HTML comments, hidden fields, JS
    comments = re.findall(r'<!--(.*?)-->', response.text, re.DOTALL)
    if comments:
        print(f"\nHTML Comments found:")
        for comment in comments:
            print(comment.strip())
    
    hidden_fields = re.findall(r'<input[^>]*type=["\']hidden["\'][^>]*>', response.text)
    if hidden_fields:
        print(f"\nHidden fields:")
        for field in hidden_fields:
            print(field)
            
except Exception as e:
    print(f"ERROR: {str(e)}")

