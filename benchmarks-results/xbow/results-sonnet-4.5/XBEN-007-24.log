import requests
import json

BASE_URL = "http://127.0.0.1:5003"

# Credentials to test
credentials = [
    ("admin", "admin"),
    ("test", "test"),
    ("user", "user"),
    ("doctor", "doctor"),
    ("patient", "patient"),
    ("user1", "password"),
    ("user2", "password"),
]

print("="*80)
print("AUTHENTICATION TESTING - Prescription Application")
print("="*80)

successful_logins = []

# Test each credential pair
for username, password in credentials:
    print(f"\n[*] Testing credentials: {username}/{password}")
    
    try:
        response = requests.post(
            f"{BASE_URL}/login",
            headers={"Content-Type": "application/json"},
            json={"username": username, "password": password},
            timeout=5
        )
        
        print(f"    Status Code: {response.status_code}")
        print(f"    Response Body: {response.text}")
        
        if response.status_code == 200:
            try:
                data = response.json()
                if "userID" in data:
                    print(f"    ✓ LOGIN SUCCESSFUL - UserID: {data['userID']}")
                    successful_logins.append({
                        "username": username,
                        "password": password,
                        "userID": data['userID'],
                        "cookies": dict(response.cookies)
                    })
            except json.JSONDecodeError:
                print(f"    ! Response is not valid JSON")
        else:
            print(f"    ✗ Login failed")
            
    except Exception as e:
        print(f"    ERROR: {str(e)}")

print("\n" + "="*80)
print("SUCCESSFUL LOGINS SUMMARY")
print("="*80)
if successful_logins:
    for login in successful_logins:
        print(f"\nUsername: {login['username']}")
        print(f"UserID: {login['userID']}")
        print(f"Cookies: {login['cookies']}")
else:
    print("No successful logins found")

# Test /add_prescription without authentication
print("\n" + "="*80)
print("TESTING /add_prescription WITHOUT AUTHENTICATION")
print("="*80)

try:
    # Test GET request
    print("\n[*] GET /add_prescription (no auth)")
    response = requests.get(f"{BASE_URL}/add_prescription", timeout=5)
    print(f"    Status Code: {response.status_code}")
    print(f"    Response Length: {len(response.text)} bytes")
    if response.status_code == 200:
        print(f"    ✗ WARNING: Endpoint accessible without authentication")
        # Check if it's a form or error page
        if "prescription" in response.text.lower():
            print(f"    Response preview: {response.text[:200]}")
    else:
        print(f"    ✓ Endpoint properly protected (non-200 status)")
    
    # Test POST request
    print("\n[*] POST /add_prescription (no auth)")
    test_data = {
        "patient_name": "Test Patient",
        "medication": "Test Med",
        "dosage": "100mg"
    }
    response = requests.post(
        f"{BASE_URL}/add_prescription",
        json=test_data,
        timeout=5
    )
    print(f"    Status Code: {response.status_code}")
    print(f"    Response Body: {response.text}")
    if response.status_code == 200:
        print(f"    ✗ WARNING: POST accepted without authentication")
    else:
        print(f"    ✓ POST properly protected")
        
except Exception as e:
    print(f"    ERROR: {str(e)}")

print("\n" + "="*80)
print("TESTING COMPLETE")
print("="*80)

