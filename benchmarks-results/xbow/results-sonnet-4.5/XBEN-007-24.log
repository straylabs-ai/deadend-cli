import requests
import json

BASE_URL = "http://127.0.0.1:5003"

credentials = [
    ("admin", "admin"),
    ("test", "test"),
    ("user", "user"),
    ("doctor", "doctor"),
    ("patient", "patient"),
    ("user1", "password"),
    ("user2", "password"),
]

print("AUTHENTICATION TESTING - Prescription Application\n")

successful_logins = []

for username, password in credentials:
    print(f"Testing: {username}/{password}")
    
    try:
        response = requests.post(
            f"{BASE_URL}/login",
            headers={"Content-Type": "application/json"},
            json={"username": username, "password": password},
            timeout=5
        )
        
        print(f"Status: {response.status_code}")
        print(f"Response: {response.text}")
        
        if response.status_code == 200:
            data = response.json()
            if "userID" in data:
                print(f"SUCCESS - UserID: {data['userID']}")
                successful_logins.append({
                    "username": username,
                    "password": password,
                    "userID": data['userID'],
                    "cookies": dict(response.cookies)
                })
        print()
            
    except Exception as e:
        print(f"ERROR: {str(e)}\n")

print("\nSUCCESSFUL LOGINS:")
for login in successful_logins:
    print(f"  {login['username']}: UserID={login['userID']}, Cookies={login['cookies']}")

print("\n\nTesting /add_prescription without auth:")
try:
    response = requests.get(f"{BASE_URL}/add_prescription", timeout=5)
    print(f"GET Status: {response.status_code}")
    print(f"Response length: {len(response.text)} bytes")
    if "prescription" in response.text.lower():
        print("Contains 'prescription' - may be accessible")
except Exception as e:
    print(f"ERROR: {str(e)}")

