#!/usr/bin/env python3
"""
Authentication Testing Script for Prescription Application
Tests various credentials and endpoint protection
"""

import requests
import json
from typing import List, Dict, Tuple

BASE_URL = "http://127.0.0.1:5003"

CREDENTIALS: List[Tuple[str, str]] = [
    ("admin", "admin"),
    ("test", "test"),
    ("user", "user"),
    ("doctor", "doctor"),
    ("patient", "patient"),
    ("user1", "password"),
    ("user2", "password"),
]

def test_login(username: str, password: str) -> Dict:
    """Test login with given credentials"""
    print(f"\n[*] Testing credentials: {username}/{password}")
    
    try:
        response = requests.post(
            f"{BASE_URL}/login",
            headers={"Content-Type": "application/json"},
            json={"username": username, "password": password},
            timeout=10
        )
        
        result = {
            "username": username,
            "password": password,
            "status_code": response.status_code,
            "response_text": response.text,
            "cookies": dict(response.cookies),
            "success": False,
            "userID": None
        }
        
        print(f"    Status: {response.status_code}")
        print(f"    Response: {response.text}")
        
        if response.status_code == 200:
            try:
                data = response.json()
                if "userID" in data:
                    result["success"] = True
                    result["userID"] = data["userID"]
                    print(f"    ✓ SUCCESS - UserID: {data['userID']}")
            except json.JSONDecodeError:
                print(f"    ! Invalid JSON response")
        
        return result
        
    except requests.exceptions.ConnectionError:
        print(f"    ✗ Connection failed - server may not be running")
        return None
    except requests.exceptions.Timeout:
        print(f"    ✗ Request timeout")
        return None
    except Exception as e:
        print(f"    ✗ Error: {str(e)}")
        return None

def test_unauth_access() -> None:
    """Test accessing /add_prescription without authentication"""
    print("\n" + "="*70)
    print("Testing /add_prescription without authentication")
    print("="*70)
    
    # Test GET
    print("\n[*] GET /add_prescription")
    try:
        response = requests.get(f"{BASE_URL}/add_prescription", timeout=10)
        print(f"    Status: {response.status_code}")
        print(f"    Response length: {len(response.text)} bytes")
        
        if response.status_code == 200:
            print(f"    ✗ WARNING: Endpoint returns 200 without auth")
            if len(response.text) < 500:
                print(f"    Response: {response.text}")
        else:
            print(f"    ✓ Protected (status {response.status_code})")
            
    except Exception as e:
        print(f"    Error: {str(e)}")
    
    # Test POST
    print("\n[*] POST /add_prescription")
    try:
        response = requests.post(
            f"{BASE_URL}/add_prescription",
            json={
                "patient_name": "Test Patient",
                "medication": "Test Med",
                "dosage": "100mg"
            },
            timeout=10
        )
        print(f"    Status: {response.status_code}")
        print(f"    Response: {response.text}")
        
        if response.status_code == 200:
            print(f"    ✗ WARNING: POST accepted without auth")
        else:
            print(f"    ✓ Protected")
            
    except Exception as e:
        print(f"    Error: {str(e)}")

def main():
    print("="*70)
    print("PRESCRIPTION APPLICATION - AUTHENTICATION TESTING")
    print("="*70)
    print(f"Target: {BASE_URL}")
    
    # Test all credentials
    results = []
    for username, password in CREDENTIALS:
        result = test_login(username, password)
        if result:
            results.append(result)
    
    # Summary
    print("\n" + "="*70)
    print("SUCCESSFUL LOGINS SUMMARY")
    print("="*70)
    
    successful = [r for r in results if r["success"]]
    
    if successful:
        for login in successful:
            print(f"\n✓ {login['username']}")
            print(f"  UserID: {login['userID']}")
            print(f"  Cookies: {login['cookies']}")
    else:
        print("\nNo successful logins found")
    
    # Test unauthorized access
    test_unauth_access()
    
    print("\n" + "="*70)
    print("TESTING COMPLETE")
    print("="*70)

if __name__ == "__main__":
    main()

