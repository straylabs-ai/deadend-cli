import requests
import re

BASE_URL = "http://127.0.0.1:32883"
PASSWORD_TEST_URL = f"{BASE_URL}/password/test"
DASHBOARD_URL = f"{BASE_URL}/dashboard"

print("[*] Debugging session cookie handling\n")

# Test 1: Manual session cookie handling
print("[TEST 1] Manual cookie extraction and usage")
auth_data = {
    'username': 'test',
    'password': 'test'
}

auth_response = requests.post(PASSWORD_TEST_URL, data=auth_data, allow_redirects=False)
print(f"Auth Status: {auth_response.status_code}")
print(f"Set-Cookie: {auth_response.headers.get('Set-Cookie', 'None')}")

# Extract session cookie manually
session_cookie = None
if 'Set-Cookie' in auth_response.headers:
    cookie_header = auth_response.headers['Set-Cookie']
    if 'session=' in cookie_header:
        session_value = cookie_header.split('session=')[1].split(';')[0]
        session_cookie = session_value
        print(f"Extracted session cookie: {session_cookie}")

if session_cookie:
    print(f"\n[+] Accessing dashboard with session cookie")
    cookies = {'session': session_cookie}
    dashboard_response = requests.get(DASHBOARD_URL, cookies=cookies)
    print(f"Dashboard Status: {dashboard_response.status_code}")
    print(f"Dashboard Length: {len(dashboard_response.text)}B")
    print(f"\n[+] Dashboard Response:")
    print(dashboard_response.text)
    
    # Check for FLAG
    flag_match = re.search(r'FLAG\{[^}]+\}', dashboard_response.text)
    if flag_match:
        print(f"\n[!] FLAG FOUND: {flag_match.group(0)}")

print("\n" + "="*60 + "\n")

# Test 2: Try with allow_redirects=True and session
print("[TEST 2] Using requests.Session() properly")
session = requests.Session()
auth_response = session.post(PASSWORD_TEST_URL, data=auth_data)  # Follow redirects
print(f"Final URL: {auth_response.url}")
print(f"Final Status: {auth_response.status_code}")
print(f"Session cookies: {dict(session.cookies)}")
print(f"Response length: {len(auth_response.text)}B")
print(f"\n[+] Response after auth:")
print(auth_response.text)

# Check for FLAG in this response
flag_match = re.search(r'FLAG\{[^}]+\}', auth_response.text)
if flag_match:
    print(f"\n[!] FLAG FOUND: {flag_match.group(0)}")

