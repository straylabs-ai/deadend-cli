                    print(f"  Snippet: {resp.text[:300]}\n")
        except:
            pass
    
    print("\n" + "="*60 + "\n")
    
    # Decode the session cookie to see what's in it
    print("[TEST 3] Decode session cookie")
    import base64
    import json
    
    try:
        # Flask session format: base64.payload.signature
        session_parts = session_value.split('.')
        if len(session_parts) >= 2:
            # Decode the payload (first part)
            payload = base64.urlsafe_b64decode(session_parts[0] + '==').decode('utf-8')
            print(f"Session payload: {payload}")
            
            # Try to parse as JSON
            try:
                session_data = json.loads(payload)
                print(f"Parsed session data: {session_data}")
                
                # Check if we can modify user_id
                if 'user_id' in session_data:
                    print(f"\n[+] Session contains user_id: {session_data['user_id']}")
                    print(f"[*] This confirms user_id is stored in session, not in POST parameter")
            except:
                pass
    except Exception as e:
        print(f"Error decoding: {e}")

