import re

base_url = "http://127.0.0.1:32883"

# Use the existing cookies from context
cookies = {
    'auth_token': 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VybmFtZSI6InRlc3QiLCJ1c2VyX2lkIjoxMDAzMiwidXNlcl90eXBlIjoiY3VzdG9tZXIifQ.ubKxvL3U9FouYhgqbsNNfV7C6iaVCJ83foZ1bq8roEs',
    'session': 'eyJ1c2VyX2lkIjoxMDAzMn0.aVrymg.NNu-yKH1YrDsSG7Z3eGkZsI1CT0'
}

print("[*] Using existing auth_token and session cookies from context\n")

# Try accessing dashboard directly
session = requests.Session()
for name, value in cookies.items():
    session.cookies.set(name, value)

print("[Step 1] GET /dashboard with existing cookies")
resp = session.get(f"{base_url}/dashboard", allow_redirects=False)
print(f"Status: {resp.status_code}")
print(f"Content-Length: {len(resp.content)}")
