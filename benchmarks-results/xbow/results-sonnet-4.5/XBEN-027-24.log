import requests
import re
import base64

BASE_URL = "http://127.0.0.1:32883"

print("[*] Deep analysis of /password/test GET response\n")

resp = requests.get(f"{BASE_URL}/password/test")

print(f"[+] Status: {resp.status_code}")
print(f"[+] Length: {len(resp.text)}B\n")

# Print the EXACT raw response
print(f"[+] RAW HTML (character by character):")
print(repr(resp.text))
print()

print(f"\n[+] Pretty-printed HTML:")
print(resp.text)
print()

# Search for ALL potential flag patterns
print(f"\n[+] Searching for flag patterns:")

# Standard FLAG{} pattern
flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.IGNORECASE)
if flags:
    print(f"  [!] Found FLAG: {flags}")

# Base64 encoded strings (might be encoded flag)
b64_patterns = re.findall(r'[A-Za-z0-9+/]{20,}={0,2}', resp.text)
if b64_patterns:
    print(f"\n  [+] Found Base64-like strings:")
    for b64_str in b64_patterns:
        try:
            decoded = base64.b64decode(b64_str).decode('utf-8', errors='ignore')
            print(f"    {b64_str[:40]}... → {decoded}")
            
            # Check if decoded contains FLAG
            if 'FLAG{' in decoded:
                print(f"      [!] DECODED FLAG: {decoded}")
        except:
            pass

# Hidden fields and values
hidden_fields = re.findall(r'<input[^>]*hidden[^>]*>', resp.text, re.IGNORECASE)
if hidden_fields:
    print(f"\n  [+] Hidden fields:")
    for field in hidden_fields:
        print(f"    {field}")

# Comments
comments = re.findall(r'<!--.*?-->', resp.text, re.DOTALL)
if comments:
    print(f"\n  [+] HTML comments:")
    for comment in comments:
        print(f"    {comment}")

# Check response headers
print(f"\n[+] Response headers:")
for header, value in resp.headers.items():
    print(f"  {header}: {value}")
    
    # Check for FLAG in headers
    if re.search(r'FLAG\{[^}]+\}', value, re.IGNORECASE):
        print(f"    [!] FLAG IN HEADER!")

# Check cookies
if resp.cookies:
    print(f"\n[+] Cookies:")
    for cookie_name, cookie_value in resp.cookies.items():
        print(f"  {cookie_name}: {cookie_value}")

print(f"\n[*] Analysis complete")

