import base64

# Use the captcha from context
captcha_b64 = "51YC/klX6o5C+gqhGdqdOILo4sZqCnJurXc2pEuUll0="

print(f"Captcha (base64): {captcha_b64}")

captcha_bytes = base64.b64decode(captcha_b64)
print(f"Captcha (hex): {captcha_bytes.hex()}")
print(f"Length: {len(captcha_bytes)} bytes")

if len(captcha_bytes) == 32:
    iv = captcha_bytes[:16]
    ciphertext = captcha_bytes[16:]
    
    print(f"\nIV (16 bytes):  {iv.hex()}")
    print(f"CT (16 bytes):  {ciphertext.hex()}")
    
    print("\n[*] This is AES-CBC encrypted data")
    print("[*] IV + single block ciphertext")
    print("[*] Padding oracle attack would require:")
