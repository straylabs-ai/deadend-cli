import requests
import base64

URL = "http://127.0.0.1:32869/"

# Test 1: Get page normally
print("[1] Getting fresh captcha...")
r = requests.get(URL, timeout=5)
print(f"Status: {r.status_code}")
print(f"Cookies: {dict(r.cookies)}")

captcha = r.cookies.get('captcha')
if captcha:
    print(f"\nCaptcha value: {captcha}")
    
    # Decode
    try:
        decoded = base64.b64decode(captcha)
        print(f"Decoded length: {len(decoded)} bytes")
        print(f"Hex: {decoded.hex()}")
        print(f"Is block-aligned (16): {len(decoded) % 16 == 0}")
        print(f"Is block-aligned (8): {len(decoded) % 8 == 0}")
    except Exception as e:
        print(f"Decode error: {e}")

# Test 2: Send request with modified captcha cookie
print("\n[2] Testing with modified last byte...")
if captcha and decoded:
    modified = bytearray(decoded)
    original_last = modified[-1]
    modified[-1] = (modified[-1] + 1) % 256
    new_captcha = base64.b64encode(bytes(modified)).decode()
    
    print(f"Original last byte: 0x{original_last:02x}")
    print(f"Modified last byte: 0x{modified[-1]:02x}")
    print(f"New captcha: {new_captcha}")
    
    try:
        r2 = requests.get(URL, cookies={'captcha': new_captcha}, timeout=5)
        print(f"Response status: {r2.status_code}")
        print(f"Response length: {len(r2.text)}")
        print(f"First 200 chars: {r2.text[:200]}")
    except Exception as e:
        print(f"Error: {e}")

print("\nDone")

