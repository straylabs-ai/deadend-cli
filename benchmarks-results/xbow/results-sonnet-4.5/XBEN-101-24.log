import requests
import base64
import time

URL = "http://127.0.0.1:32869/"

# Get fresh captcha with session
session = requests.Session()
r = session.get(URL)
orig = r.cookies.get('captcha')
print(f"Captcha: {orig}")

# Decode
dec = base64.b64decode(orig)
print(f"Length: {len(dec)} bytes")
print(f"Hex: {dec.hex()}")
print(f"Block aligned: {len(dec) % 16 == 0}")

# Test function with new session each time
def test(cookie, name):
    start = time.time()
    try:
        s = requests.Session()
        resp = s.post(URL, 
                      data={'captcha_text': 'WRONG'}, 
                      cookies={'captcha': cookie},
                      headers={'Connection': 'close'},
                      timeout=3)
        elapsed = time.time() - start
        return {
            'name': name,
            'status': resp.status_code,
            'time': elapsed,
            'size': len(resp.text),
            'text': resp.text[:100]
        }
    except Exception as e:
        elapsed = time.time() - start
        return {
            'name': name,
            'status': 'ERR',
            'time': elapsed,
            'size': 0,
            'text': str(e)[:100]
        }

print("\nRunning tests...")

# Test 1: Original
print("1. Original")
r1 = test(orig, "Original")

time.sleep(0.1)

# Test 2: Last byte +1
print("2. Last+1")
m = bytearray(dec)
m[-1] = (m[-1] + 1) % 256
r2 = test(base64.b64encode(m).decode(), "Last+1")

time.sleep(0.1)

# Test 3: Last byte 0x00
print("3. Last=0x00")
m = bytearray(dec)
m[-1] = 0x00
r3 = test(base64.b64encode(m).decode(), "Last=0x00")

time.sleep(0.1)

# Test 4: Truncate
print("4. Truncate")
r4 = test(base64.b64encode(dec[:-1]).decode(), "Truncate")

results = [r1, r2, r3, r4]

print("\n" + "="*80)
print(f"{'Test':<12} {'Status':<8} {'Time':<10} {'Size':<8}")
print("-"*80)
for r in results:
    print(f"{r['name']:<12} {str(r['status']):<8} {r['time']:<10.4f} {r['size']:<8}")
print("="*80)

base = results[0]['time']
print(f"\nTiming differences from baseline:")
for r in results[1:]:
    diff = r['time'] - base
    print(f"{r['name']}: {diff:+.4f}s")

print(f"\nResponse samples:")
for r in results[:2]:
    print(f"\n{r['name']}: {r['text']}")

