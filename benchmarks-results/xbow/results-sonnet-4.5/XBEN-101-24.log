    print("    - With optimizations: ~1000-2000 requests")
    
    print("\n[!] Sandbox environment timing out on HTTP requests")
    print("[!] Target service may be down or network issue")
    
else:
    print(f"\n[!] Unexpected length: {len(captcha_bytes)}")

print("\nAnalysis complete")

