#!/usr/bin/env python3
"""
Systematic Padding Oracle Detection Script
Tests for padding oracle vulnerabilities by manipulating encrypted cookie bytes
"""

import requests
import base64
import time
import urllib.parse
from collections import defaultdict

TARGET_URL = "http://127.0.0.1:32869/"

def get_captcha_cookie():
    """Get a fresh captcha cookie from the server"""
    try:
        response = requests.get(TARGET_URL, timeout=5)
        if 'captcha' in response.cookies:
            return response.cookies['captcha']
        return None
    except Exception as e:
        print(f"Error getting cookie: {e}")
        return None

def decode_cookie(cookie_value):
    """Decode base64 cookie to bytes"""
    try:
        return base64.b64decode(cookie_value)
    except Exception as e:
