import requests
import base64

URL = "http://127.0.0.1:32869/"

r = requests.get(URL)
print(f"Status: {r.status_code}")
print(f"Cookies: {dict(r.cookies)}")

cap = r.cookies.get('captcha', '')
print(f"\nCaptcha cookie: {cap}")

if cap:
    cb = base64.b64decode(cap)
    print(f"Decoded: {cb.hex()}")
    print(f"Length: {len(cb)}")

print("\nDone")

