import requests
import base64
import re

URL = "http://127.0.0.1:32869/"

r = requests.get(URL)
cap = r.cookies['captcha']
sess = r.cookies['session']
csrf = re.search(r'csrf_token"[^>]*value="([^"]+)"', r.text).group(1)

print(f"Captcha: {cap}")

cb = base64.b64decode(cap)
print(f"Bytes: {cb.hex()}")

iv, ct = cb[:16], cb[16:]

s = requests.Session()

def o(tiv):
    f = base64.b64encode(tiv + ct).decode()
    r = s.post(URL, data={'username':'x','captcha':'x','csrf_token':'x','submit':'Register'},
               cookies={'session':sess,'captcha':f})
    return len(r.content)

b = o(iv)
print(f"\nBaseline: {b}")

tiv = bytearray(iv)
tiv[15] ^= 1
m = o(bytes(tiv))
print(f"Modified: {m}")

if b != m:
    print("\nOracle works!")
else:
    print("\nNo oracle")

print("\nDone")

