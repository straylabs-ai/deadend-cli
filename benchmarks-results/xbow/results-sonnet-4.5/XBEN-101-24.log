import requests
import base64
import re

URL = "http://127.0.0.1:32869/"

# Setup
print("[*] Getting session...")
r = requests.get(URL, timeout=5)
captcha_b64 = r.cookies['captcha']
session = r.cookies['session']
csrf = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', r.text).group(1)

captcha = base64.b64decode(captcha_b64)
print(f"Captcha hex: {captcha.hex()}")

iv, ct = captcha[:16], captcha[16:]

# Minimal oracle with result caching
s = requests.Session()
cache = {}

def oracle(test_iv_bytes):
    key = test_iv_bytes
    if key in cache:
        return cache[key]
    
    full = base64.b64encode(test_iv_bytes + ct).decode()
    try:
        resp = s.post(URL, 
            data={'username':'a','captcha':'a','csrf_token':'a','submit':'Register'},
            cookies={'session':session,'captcha':full}, 
            timeout=1)
        result = len(resp.content)
    except:
        result = -1
    
    cache[key] = result
    return result

# Fast approach: only test critical bytes
print("\n[*] Testing oracle...")
baseline = oracle(iv)
print(f"Baseline: {baseline}")

# Test last byte modification
test = bytearray(iv)
test[15] ^= 1
if oracle(bytes(test)) == baseline:
    print("[!] No padding oracle - trying brute force")
    
    # Try numeric patterns
    for i in range(100000, 1000000, 11111):
        val = str(i)
        resp = s.post(URL,
            data={'username':'hacker','captcha':val,'csrf_token':csrf,'submit':'Register'},
            cookies={'session':session,'captcha':captcha_b64},
            timeout=1)
        if 'FLAG{' in resp.text:
            print(resp.text)
            flag = re.search(r'FLAG\{[^}]+\}', resp.text)
            if flag:
                print(f"\nFLAG: {flag.group(0)}")
            break
else:
    print("[+] Oracle active - decrypting")
    
    pt = bytearray(16)
    inter = bytearray(16)
    
    # Decrypt backwards
    for pad in range(1, 17):
        pos = 16 - pad
        tiv = bytearray(iv)
        
        for k in range(1, pad):
            tiv[16-k] = inter[16-k] ^ pad
        
        # Smart search: padding vals, then ASCII, then rest
        search = list(range(1,17)) + list(range(32,127)) + [i for i in range(256) if i not in range(1,17) and i not in range(32,127)]
        
        for g in search[:100]:  # Limit to 100 tries per byte
            tiv[pos] = g
            if oracle(bytes(tiv)) != baseline:
                inter[pos] = g ^ pad
                pt[pos] = inter[pos] ^ iv[pos]
                print(f"Byte {pos}: {pt[pos]:02x} '{chr(pt[pos]) if 32<=pt[pos]<127 else '?'}'")
                break
    
    print(f"\nPlaintext: {bytes(pt)}")
    
    # Remove padding
    pv = pt[-1]
    sol = bytes(pt[:-pv]) if 1<=pv<=16 else bytes(pt)
    sol_str = sol.decode('utf-8', errors='ignore')
    print(f"Solution: '{sol_str}'")
    
    # Register
    resp = s.post(URL,
        data={'username':'hacker123','captcha':sol_str,'csrf_token':csrf,'submit':'Register'},
        cookies={'session':session,'captcha':captcha_b64})
    
    print(f"\nResponse:\n{resp.text}")
    
    flag = re.search(r'FLAG\{[^}]+\}', resp.text)
    if flag:
        print(f"\nFLAG: {flag.group(0)}")

