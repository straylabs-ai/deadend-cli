                    char = chr(plaintext[byte_pos]) if 32 <= plaintext[byte_pos] < 127 else '.'
                    print(f"[+] Byte {16-byte_pos}: 0x{plaintext[byte_pos]:02x} = '{char}'")
                    found = True
                    break
    
    if not found:
        print(f"[!] Could not find byte at position {byte_pos}")

# Remove PKCS7 padding
print(f"\n[*] Raw plaintext: {plaintext.hex()}")
print(f"[*] Last byte (padding): {plaintext[-1]}")

if 1 <= plaintext[-1] <= 16:
    pad_len = plaintext[-1]
    plaintext = plaintext[:-pad_len]

try:
    solution = plaintext.decode('utf-8')
    print(f"\n[+] DECRYPTED CAPTCHA SOLUTION: '{solution}'")
    
    # Register user with real solution
    print("\n[*] Registering user with decrypted captcha...")
    final = s.post(TARGET, data={
