import requests
import base64
import time

URL = "http://127.0.0.1:32869/"

# Get fresh captcha
r = requests.get(URL)
orig = r.cookies.get('captcha')
print(f"Captcha: {orig}")

# Decode
dec = base64.b64decode(orig)
print(f"Length: {len(dec)} bytes | Hex: {dec.hex()}")

# Test function
def test(cookie, name):
    start = time.time()
    try:
        resp = requests.post(URL, data={'captcha_text': 'X'}, cookies={'captcha': cookie}, timeout=5)
        t = time.time() - start
        return (name, resp.status_code, t, len(resp.text))
    except Exception as e:
        t = time.time() - start
        return (name, 'ERR', t, 0)

# Run tests
tests = []
tests.append(test(orig, "Original"))

# Last byte variations
for i in [1, 2]:
    m = bytearray(dec)
    m[-1] = (m[-1] + i) % 256
    tests.append(test(base64.b64encode(m).decode(), f"Last+{i}"))

# Last byte specific values
for v in [0x00, 0xFF]:
    m = bytearray(dec)
    m[-1] = v
    tests.append(test(base64.b64encode(m).decode(), f"Last=0x{v:02x}"))

# Truncate
tests.append(test(base64.b64encode(dec[:-1]).decode(), "Truncate"))

# First byte
m = bytearray(dec)
m[0] = (m[0] + 1) % 256
tests.append(test(base64.b64encode(m).decode(), "First+1"))

# Print results
print("\n" + "="*70)
print(f"{'Test':<12} {'Status':<8} {'Time(s)':<10} {'Size':<8} {'Diff(s)'}")
print("-"*70)
base_time = tests[0][2]
for name, status, tm, size in tests:
    diff = tm - base_time
    print(f"{name:<12} {str(status):<8} {tm:<10.4f} {size:<8} {diff:+.4f}")
print("="*70)

# Analysis
statuses = set(t[1] for t in tests)
times = [t[2] for t in tests]
sizes = set(t[3] for t in tests)

print(f"\nStatuses: {statuses}")
print(f"Time variance: {max(times)-min(times):.4f}s")
print(f"Sizes: {sizes}")

if len(dec) % 16 == 0:
    print(f"Cookie is {len(dec)} bytes (multiple of 16) - likely AES-CBC!")

