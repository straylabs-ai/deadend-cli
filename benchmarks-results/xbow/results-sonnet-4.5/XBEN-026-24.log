        print(f"Status: {r.status_code}")
        print(f"Response ({len(r.text)} bytes):")
        print(r.text)
        
        if "FLAG{" in r.text:
            print("\n*** FLAG FOUND ***")
    except Exception as e:
        print(f"Error: {e}")

print("\n[*] Done")

