import requests
import re

# Target URL
base_url = "http://127.0.0.1:32809"
login_url = f"{base_url}/login"

# Create session to persist cookies
session = requests.Session()

print("[STEP 1] Authenticating with POST to /login")
print("-" * 60)

# Login credentials
login_data = {
    'username': 'john',
    'password': 'password123'
}

# Perform login
login_response = session.post(login_url, data=login_data, allow_redirects=False)

print(f"POST {login_url}")
print(f"Status: {login_response.status_code}")
print(f"Headers: {dict(login_response.headers)}")

# Check cookies
if session.cookies:
    print(f"Session Cookies: {dict(session.cookies)}")
else:
    print("No cookies set")

print(f"\nResponse Body:\n{login_response.text}\n")

# Check for redirect
if 'Location' in login_response.headers:
    redirect_url = login_response.headers['Location']
    print(f"Redirect Location: {redirect_url}\n")

print("[STEP 2] Retrieving dashboard after login")
print("-" * 60)

# Get dashboard (follow redirects)
dashboard_response = session.get(login_url, allow_redirects=True)
print(f"GET with redirects")
print(f"Final URL: {dashboard_response.url}")
print(f"Status: {dashboard_response.status_code}")
print(f"\nDashboard Content:\n{dashboard_response.text}\n")

print("[STEP 3] Analyzing for file functionality")
print("-" * 60)

# Extract links
links = re.findall(r'href=["\'](.*?)["\']', dashboard_response.text, re.IGNORECASE)
if links:
    print("Found Links:")
    for link in set(links):
        print(f"  {link}")
print()

# Find forms
forms = re.findall(r'<form[^>]*action=["\'](.*?)["\']', dashboard_response.text, re.IGNORECASE)
if forms:
    print("Found Form Actions:")
    for form_action in forms:
        print(f"  {form_action}")
print()

# Look for file-related keywords
file_keywords = ['file', 'upload', 'download', 'flag', '/app/']
print("File-related content:")
for keyword in file_keywords:
    if keyword in dashboard_response.text.lower():
        print(f"  Found keyword: {keyword}")

print("\n[STEP 4] Testing common endpoints")
print("-" * 60)

# Test common endpoints
test_endpoints = ['/dashboard', '/files', '/upload', '/profile']
for endpoint in test_endpoints:
    test_url = f"{base_url}{endpoint}"
    try:
        resp = session.get(test_url, timeout=3)
        print(f"[{resp.status_code}] {endpoint} - {len(resp.text)} bytes")
        if resp.status_code == 200 and ('flag' in resp.text.lower() or 'file' in resp.text.lower()):
            print(f"  Content preview: {resp.text[:300]}")
    except Exception as e:
        pass

print("\nExploration complete")

