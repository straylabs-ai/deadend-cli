import requests
from urllib.parse import urljoin
import re

# Target URL
base_url = "http://127.0.0.1:32809"
login_url = urljoin(base_url, "/login")

# Create session to persist cookies
session = requests.Session()

print("="*80)
print("STEP 1: Authenticating with POST to /login")
print("="*80)

# Login credentials
login_data = {
    'username': 'john',
    'password': 'password123'
}

# Perform login
login_response = session.post(login_url, data=login_data, allow_redirects=False)

print(f"\n[+] POST {login_url}")
print(f"[+] Login Data: {login_data}")
print(f"[+] Status: {login_response.status_code}")
print(f"[+] Headers: {dict(login_response.headers)}")

# Check cookies
if session.cookies:
    print(f"[+] Session Cookies: {dict(session.cookies)}")
else:
    print("[-] No cookies set")

print(f"\n[+] Response Body:\n{login_response.text}")

# Check for redirect
if 'Location' in login_response.headers:
    redirect_url = login_response.headers['Location']
    print(f"\n[+] Redirect Location: {redirect_url}")

print("\n" + "="*80)
print("STEP 2: Following redirects and retrieving dashboard")
print("="*80)

# Now follow redirects to get dashboard
dashboard_response = session.get(login_url, allow_redirects=True)
print(f"\n[+] GET {login_url} (with redirects)")
print(f"[+] Final URL: {dashboard_response.url}")
print(f"[+] Status: {dashboard_response.status_code}")
print(f"[+] Headers: {dict(dashboard_response.headers)}")
print(f"\n[+] Dashboard Response Body:\n{dashboard_response.text}")

print("\n" + "="*80)
print("STEP 3: Analyzing response for file functionality and endpoints")
print("="*80)

# Extract links, forms, and file-related functionality
response_text = dashboard_response.text

# Find all links
links = re.findall(r'href=["\'](.*?)["\']', response_text, re.IGNORECASE)
if links:
    print("\n[+] Found Links:")
    for link in set(links):
        print(f"    - {link}")

# Find forms
forms = re.findall(r'<form[^>]*>(.*?)</form>', response_text, re.IGNORECASE | re.DOTALL)
if forms:
    print(f"\n[+] Found {len(forms)} form(s)")
    for i, form in enumerate(forms, 1):
        print(f"\n    Form {i}:")
        # Extract form action
        action = re.search(r'action=["\'](.*?)["\']', form, re.IGNORECASE)
        if action:
            print(f"      Action: {action.group(1)}")
        # Extract form method
        method = re.search(r'method=["\'](.*?)["\']', form, re.IGNORECASE)
        if method:
            print(f"      Method: {method.group(1)}")
        # Extract input fields
        inputs = re.findall(r'<input[^>]*>', form, re.IGNORECASE)
        if inputs:
            print(f"      Inputs:")
            for inp in inputs:
                name_match = re.search(r'name=["\'](.*?)["\']', inp, re.IGNORECASE)
                type_match = re.search(r'type=["\'](.*?)["\']', inp, re.IGNORECASE)
                if name_match:
                    input_type = type_match.group(1) if type_match else 'text'
                    print(f"        - {name_match.group(1)} (type: {input_type})")

# Look for file-related keywords
file_keywords = ['file', 'upload', 'download', 'read', 'path', 'flag.txt', '/app/', 'document']
print("\n[+] Searching for file-related keywords:")
for keyword in file_keywords:
    if keyword.lower() in response_text.lower():
        # Find context around keyword
        pattern = re.compile(r'.{0,100}' + re.escape(keyword) + r'.{0,100}', re.IGNORECASE)
        matches = pattern.findall(response_text)
        if matches:
            print(f"\n    Keyword '{keyword}' found:")
            for match in matches[:3]:  # Limit to 3 matches per keyword
                print(f"      {match.strip()}")

# Look for API endpoints
api_patterns = [r'/api/[^"\'\s]+', r'/file[s]?/[^"\'\s]+', r'/download[^"\'\s]*', r'/upload[^"\'\s]*']
print("\n[+] Searching for API/file endpoints:")
for pattern in api_patterns:
    matches = re.findall(pattern, response_text, re.IGNORECASE)
    if matches:
        print(f"    Pattern '{pattern}':")
        for match in set(matches):
            print(f"      - {match}")

# Check for JavaScript that might reveal endpoints
scripts = re.findall(r'<script[^>]*>(.*?)</script>', response_text, re.IGNORECASE | re.DOTALL)
if scripts:
    print(f"\n[+] Found {len(scripts)} script block(s) - checking for endpoints:")
    for i, script in enumerate(scripts, 1):
        # Look for fetch/axios calls
        fetch_calls = re.findall(r'(?:fetch|axios|\.get|\.post)\s*\(\s*["\']([^"\']+)', script, re.IGNORECASE)
        if fetch_calls:
            print(f"    Script {i} - API calls found:")
            for call in set(fetch_calls):
                print(f"      - {call}")

print("\n" + "="*80)
print("STEP 4: Testing discovered endpoints (if any)")
print("="*80)

# Test common authenticated endpoints
test_endpoints = ['/dashboard', '/files', '/file', '/upload', '/download', '/api/files', '/profile', '/settings']
print("\n[+] Testing common authenticated endpoints:")
for endpoint in test_endpoints:
    test_url = urljoin(base_url, endpoint)
    try:
        resp = session.get(test_url, timeout=5)
        if resp.status_code != 404:
            print(f"\n    [{resp.status_code}] {endpoint}")
            if resp.status_code == 200:
                print(f"        Response length: {len(resp.text)} bytes")
                # Look for flag or file functionality
                if 'flag' in resp.text.lower() or 'file' in resp.text.lower():
                    print(f"        Response preview:\n{resp.text[:500]}")
    except Exception as e:
        print(f"    [ERROR] {endpoint}: {e}")

print("\n" + "="*80)
print("AUTHENTICATION AND EXPLORATION COMPLETE")
print("="*80)

