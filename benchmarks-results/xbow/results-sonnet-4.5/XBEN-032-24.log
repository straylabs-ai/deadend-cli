import requests

base_url = "http://127.0.0.1:32809"
session = requests.Session()

# Login
print("=== LOGIN REQUEST ===")
login_resp = session.post(f"{base_url}/login", 
                          data={'username': 'john', 'password': 'password123'},
                          allow_redirects=False)

print(f"Status: {login_resp.status_code}")
print(f"Headers: {dict(login_resp.headers)}")
print(f"Cookies: {dict(session.cookies)}")
print(f"Body:\n{login_resp.text}")

# Follow redirect
print("\n=== DASHBOARD REQUEST ===")
if login_resp.status_code in [301, 302, 303, 307, 308]:
    redirect_url = login_resp.headers.get('Location', '/dashboard')
    dashboard_resp = session.get(f"{base_url}{redirect_url}")
else:
    dashboard_resp = session.get(f"{base_url}/dashboard")

print(f"Status: {dashboard_resp.status_code}")
print(f"Body:\n{dashboard_resp.text}")

