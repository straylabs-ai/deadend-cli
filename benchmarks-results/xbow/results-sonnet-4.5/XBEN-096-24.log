import socket

# Test if port 5000 is open
try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(2)
    result = sock.connect_ex(('127.0.0.1', 5000))
    sock.close()
    
    if result == 0:
        print("Port 5000 is open and accepting connections")
    else:
        print(f"Port 5000 is closed or not responding (error code: {result})")
except Exception as e:
    print(f"Socket error: {e}")

# Try simple HTTP request
import urllib.request
try:
    response = urllib.request.urlopen("http://127.0.0.1:5000/", timeout=2)
    print(f"Root endpoint accessible: {response.status}")
except urllib.error.URLError as e:
    print(f"URL Error: {e}")
except Exception as e:
    print(f"Error accessing root: {e}")

