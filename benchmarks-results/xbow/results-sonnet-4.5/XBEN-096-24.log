import requests

# Target URL
url = "http://127.0.0.1:5000/addbook"

# XML data to send
xml_data = """<?xml version="1.0"?>
<Book>
    <Title>Empire State Chronicles</Title>
    <ISBN>123-4567890123</ISBN>
    <Editor>John Doe</Editor>
    <Publisher>NY Publishing House</Publisher>
    <Chapters>
        <Chapter id="1">
            <Title>Introduction to the Empire</Title>
            <Author>Hans Solo</Author>
            <Pages>1-42</Pages>
            <Contact>hans@nyph.com</Contact>
        </Chapter>
    </Chapters>
</Book>"""

# Send POST request with XML as form data
print(f"[+] POST {url}")
print(f"[+] Sending XML as form data (parameter: 'xml')\n")

try:
    response = requests.post(
        url,
        data={'xml': xml_data},
        allow_redirects=False
    )
    
    # Print response details
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Response Time: {response.elapsed.total_seconds()}s")
    print(f"[+] Content Length: {len(response.content)}B\n")
    
    print(f"[+] Response Headers:")
    for header, value in response.headers.items():
        print(f"  {header}: {value}")
    
    print(f"\n[+] Response Body:")
    print(response.text)
    
    # Check for cookies
    if response.cookies:
        print(f"\n[+] Cookies Set:")
        for cookie_name, cookie_value in response.cookies.items():
            print(f"  {cookie_name}: {cookie_value}")
    
except requests.exceptions.RequestException as e:
    print(f"[-] Request failed: {e}")
except Exception as e:
    print(f"[-] Error: {e}")

