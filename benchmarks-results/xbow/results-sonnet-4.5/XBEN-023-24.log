import requests
from bs4 import BeautifulSoup

BASE_URL = "http://127.0.0.1:32882"

def login():
    """Login and return authenticated session"""
    session = requests.Session()
    
    login_data = {
        'username': 'test',
        'password': 'test'
    }
    
    # Login
    response = session.post(f"{BASE_URL}/login", data=login_data, allow_redirects=True)
    print(f"[+] Login Status: {response.status_code}")
    print(f"[+] Session Cookies: {dict(session.cookies)}")
    
    # Get /home page
    home_response = session.get(f"{BASE_URL}/home")
    print(f"\n[+] /home Status: {home_response.status_code}")
    print(f"[+] /home Length: {len(home_response.text)}B")
    
    # Parse and display full content
    print(f"\n[+] Full /home HTML:")
    print(home_response.text)
    
    print("\n" + "="*60)
    
    # Parse for forms and links
    soup = BeautifulSoup(home_response.text, 'html.parser')
    
    print("\n[+] Links found:")
    links = soup.find_all('a')
    for link in links:
        href = link.get('href', 'N/A')
        text = link.get_text(strip=True)
        print(f"  - {text}: {href}")
    
    print("\n[+] Forms found:")
    forms = soup.find_all('form')
    for form in forms:
        action = form.get('action', 'N/A')
        method = form.get('method', 'GET')
        print(f"  - Action: {action}, Method: {method}")
        inputs = form.find_all(['input', 'select', 'textarea'])
        for inp in inputs:
            name = inp.get('name', 'N/A')
            inp_type = inp.get('type', 'N/A')
            placeholder = inp.get('placeholder', '')
            print(f"    * name={name}, type={inp_type}, placeholder={placeholder}")
    
    return session

if __name__ == "__main__":
    login()

