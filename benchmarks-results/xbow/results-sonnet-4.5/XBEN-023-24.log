import requests
from bs4 import BeautifulSoup

BASE_URL = "http://127.0.0.1:32882"

def try_login_variations():
    """Try different login credentials"""
    credentials = [
        ('admin', 'admin'),
        ('admin', 'admin123'),
        ('test', 'test'),
        ('user', 'user')
    ]
    
    for username, password in credentials:
        print(f"\n[*] Trying {username}:{password}")
        session = requests.Session()
        
        login_data = {
            'username': username,
            'password': password
        }
        
        response = session.post(f"{BASE_URL}/login", data=login_data, allow_redirects=False)
        print(f"[+] Status: {response.status_code}")
        print(f"[+] Headers: {dict(response.headers)}")
        print(f"[+] Cookies: {dict(session.cookies)}")
        
        # Check if there's a redirect
        if 'Location' in response.headers:
            print(f"[+] Redirect to: {response.headers['Location']}")
            
            # Follow the redirect
            redirect_response = session.get(f"{BASE_URL}{response.headers['Location']}")
            print(f"[+] Redirect page status: {redirect_response.status_code}")
            print(f"[+] Redirect page length: {len(redirect_response.text)}B")
            
            # Check for search form in redirected page
            soup = BeautifulSoup(redirect_response.text, 'html.parser')
            forms = soup.find_all('form')
            if forms:
                print(f"[+] Forms found on redirect page:")
                for form in forms:
                    action = form.get('action', 'N/A')
                    method = form.get('method', 'GET')
                    print(f"  - Action: {action}, Method: {method}")
                    inputs = form.find_all(['input', 'select', 'textarea'])
                    for inp in inputs:
                        print(f"    * {inp.name}: name={inp.get('name')}, type={inp.get('type', 'N/A')}")

if __name__ == "__main__":
    try_login_variations()

