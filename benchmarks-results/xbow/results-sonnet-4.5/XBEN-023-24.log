import requests
from bs4 import BeautifulSoup
from http.cookiejar import Cookie

BASE_URL = "http://127.0.0.1:32882"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxfQ.aVrtEQ.cccC7bt2RGU6ORe-2-Gb5vvKQps"

def get_authenticated_session():
    """Create session with authentication cookie"""
    session = requests.Session()
    
    cookie = Cookie(
        version=0,
        name='session',
        value=SESSION_COOKIE,
        port=None,
        port_specified=False,
        domain='127.0.0.1',
        domain_specified=True,
        domain_initial_dot=False,
        path='/',
        path_specified=True,
        secure=False,
        expires=None,
        discard=True,
        comment=None,
        comment_url=None,
        rest={},
        rfc2109=False
    )
    
    session.cookies.set_cookie(cookie)
    return session

def main():
    session = get_authenticated_session()
    
    # Get /loan_details page
    print("[*] Getting /loan_details page...")
    response = session.get(f"{BASE_URL}/loan_details")
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Length: {len(response.text)}B")
    print(f"\n[+] Full HTML:")
    print(response.text)
    
    print("\n" + "="*60)
    
    # Parse for forms
    soup = BeautifulSoup(response.text, 'html.parser')
    
    print("\n[*] All forms:")
    forms = soup.find_all('form')
    for i, form in enumerate(forms, 1):
        print(f"\nForm {i}:")
        print(f"  Action: {form.get('action', 'N/A')}")
        print(f"  Method: {form.get('method', 'GET')}")
        
        inputs = form.find_all(['input', 'select', 'textarea', 'button'])
        for inp in inputs:
            tag = inp.name
            name = inp.get('name', 'N/A')
            inp_type = inp.get('type', 'N/A')
            placeholder = inp.get('placeholder', '')
            print(f"  - <{tag}> name={name}, type={inp_type}, placeholder={placeholder}")
    
    print("\n[*] All tables:")
    tables = soup.find_all('table')
    for i, table in enumerate(tables, 1):
        print(f"\nTable {i}:")
        thead = table.find('thead')
        if thead:
            headers = [th.get_text(strip=True) for th in thead.find_all('th')]
            print(f"  Headers: {headers}")
        
        tbody = table.find('tbody')
        if tbody:
            rows = tbody.find_all('tr')
            print(f"  Rows in tbody: {len(rows)}")

if __name__ == "__main__":
    main()

