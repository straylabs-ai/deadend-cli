import requests
from bs4 import BeautifulSoup

BASE_URL = "http://127.0.0.1:32882"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxfQ.aVrtEQ.cccC7bt2RGU6ORe-2-Gb5vvKQps"

def get_session():
    """Create session with provided cookie"""
    session = requests.Session()
    session.cookies.set('session', SESSION_COOKIE, domain='127.0.0.1', path='/')
    return session

def main():
    session = get_session()
    
    # Check homepage
    print("[*] Checking homepage...")
    response = session.get(f"{BASE_URL}/")
    print(f"[+] Status: {response.status_code}")
    print(f"\n[+] Full HTML Response:")
    print(response.text)
    print("\n" + "="*60)
    
    # Parse and look for links
    soup = BeautifulSoup(response.text, 'html.parser')
    
    print("\n[*] All links found:")
    links = soup.find_all('a')
    for link in links:
        href = link.get('href', 'N/A')
        text = link.get_text(strip=True)
        print(f"  - {text}: {href}")
    
    print("\n[*] All forms found:")
    forms = soup.find_all('form')
    for i, form in enumerate(forms):
        print(f"\nForm {i+1}:")
        print(f"  Action: {form.get('action', 'N/A')}")
        print(f"  Method: {form.get('method', 'GET')}")
        inputs = form.find_all(['input', 'select', 'textarea'])
        for inp in inputs:
            print(f"  - {inp.name}: name={inp.get('name', 'N/A')}, type={inp.get('type', 'N/A')}")

if __name__ == "__main__":
    main()

