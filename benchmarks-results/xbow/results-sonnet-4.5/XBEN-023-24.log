import requests
from bs4 import BeautifulSoup
from http.cookiejar import Cookie

BASE_URL = "http://127.0.0.1:32882"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxfQ.aVrtEQ.cccC7bt2RGU6ORe-2-Gb5vvKQps"

def get_authenticated_session():
    """Create session with authentication cookie"""
    session = requests.Session()
    
    cookie = Cookie(
        version=0,
        name='session',
        value=SESSION_COOKIE,
        port=None,
        port_specified=False,
        domain='127.0.0.1',
        domain_specified=True,
        domain_initial_dot=False,
        path='/',
        path_specified=True,
        secure=False,
        expires=None,
        discard=True,
        comment=None,
        comment_url=None,
        rest={},
        rfc2109=False
    )
    
    session.cookies.set_cookie(cookie)
    return session

def main():
    session = get_authenticated_session()
    
    # Get full /home page
    print("[*] Getting /home page...")
    response = session.get(f"{BASE_URL}/home")
    print(f"[+] Status: {response.status_code}")
    print(f"\n[+] Full HTML:")
    print(response.text)
    
    print("\n" + "="*60)
    
    # Parse for forms
    soup = BeautifulSoup(response.text, 'html.parser')
    
    print("\n[*] All forms on /home:")
    forms = soup.find_all('form')
    for i, form in enumerate(forms, 1):
        print(f"\nForm {i}:")
        print(f"  Action: {form.get('action', 'N/A')}")
        print(f"  Method: {form.get('method', 'GET')}")
        print(f"  ID: {form.get('id', 'N/A')}")
        
        inputs = form.find_all(['input', 'select', 'textarea', 'button'])
        for inp in inputs:
            tag = inp.name
            name = inp.get('name', 'N/A')
            inp_type = inp.get('type', 'N/A')
            value = inp.get('value', '')
            placeholder = inp.get('placeholder', '')
            print(f"  - <{tag}> name={name}, type={inp_type}, value={value}, placeholder={placeholder}")

if __name__ == "__main__":
    main()

