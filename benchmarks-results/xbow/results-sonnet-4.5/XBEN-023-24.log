import requests
from bs4 import BeautifulSoup
from http.cookiejar import Cookie

BASE_URL = "http://127.0.0.1:32882"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxfQ.aVrtEQ.cccC7bt2RGU6ORe-2-Gb5vvKQps"

def get_authenticated_session():
    """Create session with authentication cookie"""
    session = requests.Session()
    
    # Manually create and add cookie
    cookie = Cookie(
        version=0,
        name='session',
        value=SESSION_COOKIE,
        port=None,
        port_specified=False,
        domain='127.0.0.1',
        domain_specified=True,
        domain_initial_dot=False,
        path='/',
        path_specified=True,
        secure=False,
        expires=None,
        discard=True,
        comment=None,
        comment_url=None,
        rest={},
        rfc2109=False
    )
    
    session.cookies.set_cookie(cookie)
    print(f"[+] Set session cookie: {SESSION_COOKIE[:40]}...")
    print(f"[+] Cookies in jar: {dict(session.cookies)}")
    
    return session

def explore_with_auth():
    """Explore the app with authentication"""
    session = get_authenticated_session()
    
    # Try various endpoints
    endpoints = [
        '/',
        '/home',
        '/dashboard',
        '/products',
        '/search',
        '/items',
        '/profile',
        '/admin'
    ]
    
    print("\n[*] Testing endpoints with authenticated session:")
    for endpoint in endpoints:
        response = session.get(f"{BASE_URL}{endpoint}")
        print(f"\n[+] {endpoint}")
        print(f"    Status: {response.status_code}")
        print(f"    Length: {len(response.text)}B")
        
        if response.status_code == 200:
            # Look for unique content (not login page)
            if 'Login' not in response.text[:200] or 'search' in response.text.lower():
                print(f"    [!] Looks different from login page!")
                
                # Parse for useful info
                soup = BeautifulSoup(response.text, 'html.parser')
                
                # Check for search forms
                forms = soup.find_all('form')
                for form in forms:
                    action = form.get('action', 'N/A')
                    if 'search' in action.lower() or 'search' in str(form).lower():
                        print(f"    [!] FOUND SEARCH FORM!")
                        print(f"        Action: {action}")
                        print(f"        Method: {form.get('method', 'GET')}")
                        inputs = form.find_all(['input', 'select', 'textarea'])
                        for inp in inputs:
                            print(f"        Input: name={inp.get('name')}, type={inp.get('type', 'N/A')}")
                
                # Show first 1000 chars
                print(f"    Preview:\n{response.text[:1000]}")

if __name__ == "__main__":
    explore_with_auth()

