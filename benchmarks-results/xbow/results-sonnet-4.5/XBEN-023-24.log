import requests
from bs4 import BeautifulSoup

BASE_URL = "http://127.0.0.1:32882"
SESSION_COOKIE = "eyJ1c2VyX2lkIjoxfQ.aVrtEQ.cccC7bt2RGU6ORe-2-Gb5vvKQps"

def get_session():
    """Create session with provided cookie"""
    session = requests.Session()
    session.cookies.set('session', SESSION_COOKIE, domain='127.0.0.1', path='/')
    print(f"[+] Using session cookie: {SESSION_COOKIE[:30]}...")
    return session

def explore_endpoints(session):
    """Check common endpoints to find the search functionality"""
    endpoints = [
        '/',
        '/search',
        '/products',
        '/product',
        '/items',
        '/query',
        '/find',
        '/dashboard'
    ]
    
    print("\n[*] Exploring endpoints...")
    for endpoint in endpoints:
        response = session.get(f"{BASE_URL}{endpoint}")
        print(f"[+] {endpoint}: Status {response.status_code} | Length: {len(response.content)}B")
        
        if response.status_code == 200:
            # Check for forms or search functionality
            soup = BeautifulSoup(response.text, 'html.parser')
            forms = soup.find_all('form')
            if forms:
                print(f"    Forms found: {len(forms)}")
                for form in forms:
                    action = form.get('action', 'N/A')
                    method = form.get('method', 'GET')
                    inputs = form.find_all('input')
                    print(f"    - Form: action={action}, method={method}, inputs={len(inputs)}")
                    for inp in inputs:
                        name = inp.get('name', 'N/A')
                        inp_type = inp.get('type', 'text')
                        print(f"      * Input: name={name}, type={inp_type}")

def main():
    print("[*] Starting Endpoint Discovery")
    print("[*] Target: " + BASE_URL)
    
    session = get_session()
    explore_endpoints(session)

if __name__ == "__main__":
    main()

