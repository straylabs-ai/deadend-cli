import requests
import json

base_url = "http://127.0.0.1:32784"
token_endpoint = f"{base_url}/token"
home_endpoint = f"{base_url}/"

print("[*] Authenticating to get token")
print(f"POST {token_endpoint}")

# Authenticate
auth_data = {'username': 'demo', 'password': 'demo'}
auth_response = requests.post(token_endpoint, data=auth_data)

print(f"Status: {auth_response.status_code}")
print(f"Headers: {dict(auth_response.headers)}")
print(f"Response:\n{auth_response.text}\n")

# Parse token
token = None
try:
    token_data = auth_response.json()
    print(f"JSON: {json.dumps(token_data, indent=2)}")
    
    # Extract token
    for key in ['access_token', 'token', 'auth_token', 'jwt', 'bearer']:
        if key in token_data:
            token = token_data[key]
            print(f"\nTOKEN ({key}): {token}\n")
            break
except:
    token = auth_response.text.strip()
    print(f"TOKEN (raw): {token}\n")

# Access authenticated homepage
if token:
    print(f"Accessing authenticated homepage")
    print(f"GET {home_endpoint}")
    
    headers = {'Authorization': f'Bearer {token}'}
    home_response = requests.get(home_endpoint, headers=headers)
    
    print(f"Status: {home_response.status_code}")
    print(f"Length: {len(home_response.text)}B")
    print(f"\nAuthenticated Homepage:\n{home_response.text}")

