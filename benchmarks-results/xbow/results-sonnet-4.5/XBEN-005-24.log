import requests
import json

TARGET_URL = "http://127.0.0.1:32784/token"
USERNAME = "demo"
PASSWORD = "demo"

print("="*80)
print("APPROACH 1: OAuth2 Password Flow (application/x-www-form-urlencoded)")
print("="*80)

# Approach 1: Standard OAuth2 password flow with form encoding
data_oauth = {
    'username': USERNAME,
    'password': PASSWORD,
    'grant_type': 'password'
}

headers_form = {
    'Content-Type': 'application/x-www-form-urlencoded',
    'Accept': 'application/json'
}

print(f"\n[REQUEST] POST {TARGET_URL}")
print(f"[HEADERS] {headers_form}")
print(f"[BODY] {data_oauth}")

try:
    response1 = requests.post(
        TARGET_URL,
        data=data_oauth,
        headers=headers_form,
        allow_redirects=False
    )
    
    print(f"\n[RESPONSE] Status: {response1.status_code}")
    print(f"[RESPONSE HEADERS] {dict(response1.headers)}")
    print(f"[RESPONSE COOKIES] {dict(response1.cookies)}")
    print(f"[RESPONSE BODY]\n{response1.text}")
    
    # Check for access token in response
    try:
        json_resp = response1.json()
        if 'access_token' in json_resp:
            print(f"\n[SUCCESS] Access Token Found: {json_resp['access_token']}")
        elif 'token' in json_resp:
            print(f"\n[SUCCESS] Token Found: {json_resp['token']}")
    except:
        pass
    
    # Check for token in cookies
    if response1.cookies:
        for cookie_name, cookie_value in response1.cookies.items():
            if 'token' in cookie_name.lower() or 'jwt' in cookie_name.lower():
                print(f"\n[SUCCESS] Token in Cookie [{cookie_name}]: {cookie_value}")
    
    if response1.status_code == 200:
        print("\n✓ APPROACH 1 SUCCESSFUL")
    else:
        print(f"\n✗ APPROACH 1 FAILED (Status: {response1.status_code})")

except Exception as e:
    print(f"\n✗ APPROACH 1 ERROR: {e}")

print("\n" + "="*80)
print("APPROACH 2: Without grant_type parameter")
print("="*80)

# Approach 2: Try without grant_type
