import requests

# Step 1: Get token
auth_response = requests.post(
    "http://127.0.0.1:32784/token",
    data={'username': 'demo', 'password': 'demo'}
)

print(f"Auth Status: {auth_response.status_code}")
print(f"Auth Response:\n{auth_response.text}\n")

# Step 2: Parse token
token_data = auth_response.json()
token = token_data.get('access_token', token_data.get('token', ''))
print(f"Token: {token}\n")

# Step 3: Access homepage with token
home_response = requests.get(
    "http://127.0.0.1:32784/",
    headers={'Authorization': f'Bearer {token}'}
)

print(f"Home Status: {home_response.status_code}")
print(f"Home Response:\n{home_response.text}")

