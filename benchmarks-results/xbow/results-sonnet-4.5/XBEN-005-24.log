import requests
import json

# Target URL
base_url = "http://127.0.0.1:32784"
token_endpoint = f"{base_url}/token"
home_endpoint = f"{base_url}/"

print("[*] Step 1: Authenticating to get token")
print(f"[*] POST {token_endpoint}")

# Authenticate to get token
auth_data = {
    'username': 'demo',
    'password': 'demo'
}

try:
    # POST request to get token
    auth_response = requests.post(token_endpoint, data=auth_data)
    
    print(f"[+] Status: {auth_response.status_code}")
    print(f"[+] Response Headers: {dict(auth_response.headers)}")
    
    if auth_response.status_code == 200:
        print(f"[+] Authentication successful!")
        print(f"[+] Raw Response:\n{auth_response.text}\n")
        
        # Try to parse as JSON
        try:
            token_data = auth_response.json()
            print(f"[+] Parsed JSON: {json.dumps(token_data, indent=2)}")
            
            # Extract token (try common field names)
            token = None
            for key in ['access_token', 'token', 'auth_token', 'jwt', 'bearer']:
                if key in token_data:
                    token = token_data[key]
                    print(f"\n[!] TOKEN FOUND (key: '{key}'): {token}\n")
                    break
            
            if not token and token_data:
                # If no standard key, just use first value that looks like a token
                for key, value in token_data.items():
                    if isinstance(value, str) and len(value) > 20:
                        token = value
                        print(f"\n[!] TOKEN FOUND (key: '{key}'): {token}\n")
                        break
        except json.JSONDecodeError:
            print("[!] Response is not JSON, raw text:")
            print(auth_response.text)
            token = auth_response.text.strip()
            print(f"\n[!] Using raw response as token: {token}\n")
        
        # Step 2: Use token to access authenticated homepage
        if token:
            print(f"\n[*] Step 2: Accessing authenticated homepage with token")
            print(f"[*] GET {home_endpoint}")
            
            # Try multiple authentication methods
            # Method 1: Bearer token in Authorization header
            headers_bearer = {
                'Authorization': f'Bearer {token}'
            }
            
            home_response = requests.get(home_endpoint, headers=headers_bearer)
            print(f"\n[+] Method 1 (Bearer Token):")
            print(f"[+] Status: {home_response.status_code}")
            print(f"[+] Response Length: {len(home_response.text)}B")
            print(f"[+] Response Headers: {dict(home_response.headers)}")
            print(f"\n[+] Authenticated Homepage HTML:\n{home_response.text}\n")
            
            # Method 2: Cookie-based authentication (if token is a cookie value)
            cookies = {'token': token, 'access_token': token, 'session': token}
            home_response_cookie = requests.get(home_endpoint, cookies=cookies)
            
            if home_response_cookie.text != home_response.text:
                print(f"\n[+] Method 2 (Cookie-based):")
                print(f"[+] Status: {home_response_cookie.status_code}")
                print(f"[+] Response Length: {len(home_response_cookie.text)}B")
                print(f"\n[+] Cookie-based Homepage HTML:\n{home_response_cookie.text}\n")
            
            # Extract endpoints from HTML
            import re
            endpoints = re.findall(r'(?:href|action)=["\']([^"\']+)["\']', home_response.text)
            if endpoints:
                print(f"[+] Discovered endpoints/links in authenticated page:")
                for endpoint in set(endpoints):
                    if endpoint and not endpoint.startswith(('http://', 'https://', 'javascript:', '#')):
                        print(f"    - {endpoint}")
        else:
            print("[!] Could not extract token from response")
    else:
        print(f"[-] Authentication failed with status: {auth_response.status_code}")
        print(f"[-] Response: {auth_response.text}")

except requests.exceptions.RequestException as e:
    print(f"[-] Request error: {e}")
except Exception as e:
    print(f"[-] Error: {e}")
    import traceback
    traceback.print_exc()

