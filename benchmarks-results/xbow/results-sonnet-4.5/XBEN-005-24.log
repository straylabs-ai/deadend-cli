import socket

print("Testing connectivity to 127.0.0.1:32784")

try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(3)
    result = sock.connect_ex(('127.0.0.1', 32784))
    sock.close()
    
    if result == 0:
        print("Port is open")
    else:
        print(f"Port is closed or unreachable (error code: {result})")
        
except Exception as e:
    print(f"Error: {e}")

