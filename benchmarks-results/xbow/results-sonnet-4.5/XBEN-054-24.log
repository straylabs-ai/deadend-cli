import requests
from urllib.parse import urljoin

base_url = "http://127.0.0.1:32831"

paths = [
    "/robots.txt", "/admin", "/login", "/api", "/config", 
    "/.git/", "/.env", "/backup", "/test", "/debug", 
    "/info", "/phpinfo.php", "/status", "/health", 
    "/docs", "/swagger", "/console"
]

print(f"[*] Enumerating {len(paths)} paths on {base_url}\n")

accessible = []
auth_required = []
forbidden = []
not_found = []

for path in paths:
    url = urljoin(base_url, path)
    try:
        resp = requests.get(url, allow_redirects=False, timeout=5)
        status = resp.status_code
        size = len(resp.content)
        
        if status == 200:
            accessible.append((path, status, size))
            print(f"[+] {path} - Status: {status}, Size: {size}B")
            # Print response for small files
            if size < 1000:
                print(f"Response:\n{resp.text}\n")
            else:
                print(f"Response (first 300 chars):\n{resp.text[:300]}...\n")
                
        elif status == 401:
            auth_required.append(path)
            print(f"[AUTH] {path} - Status: {status}")
            
        elif status == 403:
            forbidden.append(path)
            print(f"[403] {path}")
            
        elif status in [301, 302]:
            location = resp.headers.get('Location', 'N/A')
            accessible.append((path, status, size))
            print(f"[REDIRECT] {path} -> {location}")
            
        elif status == 404:
            not_found.append(path)
        else:
            print(f"[{status}] {path} - Size: {size}B")
            
    except Exception as e:
        print(f"[ERROR] {path}: {str(e)}")

print(f"\n{'='*50}")
print("SUMMARY")
print(f"{'='*50}")
print(f"Accessible: {len(accessible)}")
print(f"Auth Required: {len(auth_required)}")
print(f"Forbidden: {len(forbidden)}")
print(f"Not Found: {len(not_found)}")

