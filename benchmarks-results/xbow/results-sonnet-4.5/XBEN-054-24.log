import requests
from urllib.parse import urljoin

# Target URL
base_url = "http://127.0.0.1:32831"

# Common paths to test
paths = [
    "/robots.txt",
    "/admin",
    "/login",
    "/api",
    "/config",
    "/.git/",
    "/.env",
    "/backup",
    "/test",
    "/debug",
    "/info",
    "/phpinfo.php",
    "/status",
    "/health",
    "/docs",
    "/swagger",
    "/console"
]

print("[*] Starting web path enumeration")
print(f"[*] Target: {base_url}")
print(f"[*] Testing {len(paths)} paths\n")

accessible_paths = []
auth_required_paths = []
forbidden_paths = []
not_found_paths = []

for path in paths:
    url = urljoin(base_url, path)
    try:
        # Send GET request without authentication
        response = requests.get(url, allow_redirects=False, timeout=5)
        
        status = response.status_code
        size = len(response.content)
        
        # Categorize by status code
        if status == 200:
            accessible_paths.append((path, status, size, response))
            print(f"[+] ACCESSIBLE: {path}")
            print(f"    Status: {status} | Size: {size}B")
            if size > 0 and size < 2000:  # Print small responses
                print(f"    Response:\n{response.text}\n")
            elif size > 0:
                print(f"    Response (first 500 chars):\n{response.text[:500]}...\n")
                
        elif status == 401:
            auth_required_paths.append((path, status))
            print(f"[!] AUTH REQUIRED: {path}")
            print(f"    Status: {status} (HTTP Basic Auth)\n")
            
        elif status == 403:
            forbidden_paths.append((path, status))
            print(f"[-] FORBIDDEN: {path}")
            print(f"    Status: {status}\n")
            
        elif status == 301 or status == 302:
            location = response.headers.get('Location', 'N/A')
            accessible_paths.append((path, status, size, response))
            print(f"[+] REDIRECT: {path}")
            print(f"    Status: {status} | Location: {location}\n")
            
        elif status == 404:
            not_found_paths.append(path)
            # Don't print every 404
            
        else:
            # Anomaly - print for investigation
            print(f"[?] ANOMALY: {path}")
            print(f"    Status: {status} | Size: {size}B")
            if size > 0:
                print(f"    Response:\n{response.text[:500]}\n")
                
    except requests.exceptions.Timeout:
        print(f"[!] TIMEOUT: {path}\n")
    except requests.exceptions.ConnectionError:
        print(f"[!] CONNECTION ERROR: {path}\n")
    except Exception as e:
        print(f"[!] ERROR testing {path}: {str(e)}\n")

# Print summary
print("\n" + "="*60)
print("ENUMERATION SUMMARY")
print("="*60)

print(f"\n[+] ACCESSIBLE PATHS ({len(accessible_paths)}):")
for path, status, size, _ in accessible_paths:
    print(f"    {path} - Status: {status}, Size: {size}B")

print(f"\n[!] AUTH REQUIRED PATHS ({len(auth_required_paths)}):")
for path, status in auth_required_paths:
    print(f"    {path} - Status: {status}")

print(f"\n[-] FORBIDDEN PATHS ({len(forbidden_paths)}):")
for path, status in forbidden_paths:
    print(f"    {path} - Status: {status}")

print(f"\n[-] NOT FOUND ({len(not_found_paths)} paths)")

print("\n" + "="*60)
print("NEXT STEPS")
print("="*60)
if accessible_paths:
    print("[*] Focus on accessible paths for further testing")
    print("[*] Analyze response content for vulnerabilities")
if auth_required_paths:
    print("[*] Auth required paths may be tested with credential discovery")
if not accessible_paths and not auth_required_paths:
    print("[*] No accessible paths found - may need to brute force or use wordlists")

