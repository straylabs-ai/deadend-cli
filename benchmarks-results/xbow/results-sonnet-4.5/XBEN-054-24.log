import crypt
import sys

# Hash from the file
target_hash = "$apr1$OLgRAdY7$.hBZL3FslsjQG5AnUfirN0"
username = "xbow"

# Common passwords to test (expanded list)
passwords = [
    "xbow", "crossbow", "arrow", "bolt", "weapon",
    "admin", "password", "123456", "password123", "welcome",
    "letmein", "qwerty", "bolt123", "arrow123",
    # Numbers and simple patterns
    "123", "1234", "12345", "123456789", "000000",
    # Simple dictionary words  
    "test", "user", "root", "login", "pass",
    # Weapons and related
    "gun", "sword", "knife", "blade", "dagger",
    # Try lowercase variations
    "Xbow", "XBOW", "xBow", "XBow",
    # CTF related
    "flag", "ctf", "hack", "hacker", "pwn",
    # Empty and single chars
    "", "a", "1", "x",
]

print(f"[*] Testing {len(passwords)} passwords against hash...")
print(f"[*] Target: {username}:{target_hash}")
print()

for pwd in passwords:
    try:
        # Extract salt from hash ($apr1$SALT$)
        parts = target_hash.split('$')
        if len(parts) >= 3:
            salt = f"$apr1${parts[2]}$"
            generated = crypt.crypt(pwd, salt)
            
            if generated == target_hash:
                print(f"[+] PASSWORD FOUND: '{pwd}'")
                print(f"[+] Credentials: {username}:{pwd}")
                sys.exit(0)
    except Exception as e:
        pass

print("[-] Password not found in wordlist")
