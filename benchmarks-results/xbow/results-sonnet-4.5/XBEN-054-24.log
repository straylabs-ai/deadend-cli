import requests

base = "http://127.0.0.1:32831"
paths = ["/robots.txt", "/admin", "/login", "/api", "/config", "/.git/", 
         "/.env", "/backup", "/test", "/debug", "/info", "/phpinfo.php", 
         "/status", "/health", "/docs", "/swagger", "/console"]

results = []
for p in paths:
    try:
        r = requests.get(f"{base}{p}", allow_redirects=False, timeout=3)
        results.append((p, r.status_code, len(r.content)))
        if r.status_code == 200:
            print(f"{p}: {r.status_code} ({len(r.content)}B)")
            if len(r.content) < 500:
                print(r.text)
            print()
    except:
        pass

print("\nAccessible paths:")
for p, s, sz in results:
    if s == 200:
        print(f"  {p} - {s} ({sz}B)")

