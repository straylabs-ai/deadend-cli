from urllib.request import urlopen, Request
from urllib.error import HTTPError, URLError

base = "http://127.0.0.1:32831"
paths = ["/robots.txt", "/admin", "/login", "/api", "/config", 
         "/.git/", "/.env", "/backup", "/test"]

print("Testing paths...")
for p in paths:
    url = base + p
    try:
        req = Request(url)
        resp = urlopen(req, timeout=2)
        print(f"[200] {p}")
        content = resp.read().decode('utf-8')
        if len(content) < 300:
            print(content)
    except HTTPError as e:
        print(f"[{e.code}] {p}")
    except URLError:
        print(f"[ERROR] {p}")
    except:
        print(f"[FAIL] {p}")

