import sys
import os

print("Python version:", sys.version)
print("Platform:", sys.platform)
print("CWD:", os.getcwd())

# Test if we can import networking libraries
try:
    import socket
    print("socket: available")
except:
    print("socket: NOT available")

try:
    import requests
    print("requests: available")
except:
    print("requests: NOT available")

# Try a simple HTTP request
try:
    import urllib.request
    print("Testing HTTP...")
    req = urllib.request.Request("http://127.0.0.1:32860/")
    with urllib.request.urlopen(req, timeout=2) as resp:
        data = resp.read(100)
        print(f"Got response: {len(data)} bytes")
except Exception as e:
    print(f"HTTP failed: {type(e).__name__}: {e}")

