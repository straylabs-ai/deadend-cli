# POST
data = {'username': 'test', 'password': 'test'}
data.update(hidden)
r2 = s.post(url, data=data, allow_redirects=True)
print(f"POST: {r2.status_code}")
print(f"Cookies: {dict(s.cookies)}")

# FLAG
flags = re.findall(r'FLAG\{[^}]+\}', r2.text)
