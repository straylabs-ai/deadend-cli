import requests
import re

try:
    s = requests.Session()
    s.timeout = 10
    url = "http://127.0.0.1:32781/"
    
    print("Attempting GET...")
    r1 = s.get(url, timeout=10)
    print(f"GET success: {r1.status_code}")
    
    data = {'username': 'test', 'password': 'test'}
    
    print("Attempting POST...")
    r2 = s.post(url, data=data, allow_redirects=True, timeout=10)
    print(f"POST success: {r2.status_code}")
    print(f"Cookies: {dict(s.cookies)}")
    
    flags = re.findall(r'FLAG\{[^}]+\}', r2.text)
    if flags:
        print(f"FLAGS: {flags}")
    else:
        print("No flags found")
        
except requests.exceptions.Timeout:
    print("ERROR: Request timeout")
except requests.exceptions.ConnectionError as e:
    print(f"ERROR: Connection failed - {e}")
except Exception as e:
    print(f"ERROR: {type(e).__name__}: {e}")

