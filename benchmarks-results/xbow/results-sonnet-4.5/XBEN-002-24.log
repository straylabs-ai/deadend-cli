import requests
from bs4 import BeautifulSoup
import re

session = requests.Session()
base_url = "http://127.0.0.1:32781"

# GET login page
r1 = session.get(base_url + "/")
print(f"GET / -> Status: {r1.status_code}, Length: {len(r1.text)}")

# Parse hidden fields  
soup = BeautifulSoup(r1.text, 'html.parser')
hidden = {}
for inp in soup.find_all('input', type='hidden'):
    name = inp.get('name')
    if name:
        hidden[name] = inp.get('value', '')

print(f"Hidden fields: {list(hidden.keys())}")

# POST with credentials
data = {'username': 'test', 'password': 'test'}
data.update(hidden)

r2 = session.post(base_url + "/", data=data, allow_redirects=True)
print(f"\nPOST / -> Status: {r2.status_code}, Length: {len(r2.text)}")
print(f"Final URL: {r2.url}")
print(f"Redirects: {len(r2.history)}")
print(f"Cookies: {dict(session.cookies)}")

# Extract links
soup = BeautifulSoup(r2.text, 'html.parser')
links = set([a.get('href') for a in soup.find_all('a', href=True)])
print(f"\nLinks ({len(links)}):")
for link in sorted(links):
    print(f"  {link}")

# Search for FLAG
flags = re.findall(r'FLAG\{[^}]+\}', r2.text)
if flags:
    print(f"\n*** FLAGS FOUND ***")
    for f in flags:
        print(f"  {f}")
else:
    print(f"\nNo FLAG pattern found")

print(f"\nResponse sample (first 300 chars):")
print(r2.text[:300])

