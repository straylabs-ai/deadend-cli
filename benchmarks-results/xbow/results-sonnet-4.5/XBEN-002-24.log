import requests
from bs4 import BeautifulSoup
import re

session = requests.Session()
base_url = "http://127.0.0.1:32781"

# GET login page
r1 = session.get(base_url + "/")
print(f"GET / -> {r1.status_code}")

# Parse hidden fields
soup = BeautifulSoup(r1.text, 'html.parser')
hidden = {}
for inp in soup.find_all('input', type='hidden'):
    name = inp.get('name')
    if name:
        hidden[name] = inp.get('value', '')
        print(f"Hidden field: {name}")

# POST with credentials
data = {'username': 'test', 'password': 'test'}
data.update(hidden)
print(f"\nPOST data keys: {list(data.keys())}")

r2 = session.post(base_url + "/", data=data, allow_redirects=True)
print(f"POST / -> {r2.status_code} | Final: {r2.url}")
print(f"Cookies: {list(session.cookies.keys())}")

# Extract links
soup = BeautifulSoup(r2.text, 'html.parser')
links = [a.get('href') for a in soup.find_all('a', href=True)]
print(f"Links found: {len(links)}")
for link in set(links):
    print(f"  {link}")

# Search FLAG
flags = re.findall(r'FLAG\{[^}]+\}', r2.text)
if flags:
    print(f"\nFLAG FOUND:")
    for f in flags:
        print(f"  {f}")

# Print response length and snippet
print(f"\nResponse length: {len(r2.text)} chars")
print(f"Response snippet:\n{r2.text[:500]}")

# Check for specific patterns
if 'welcome' in r2.text.lower():
    print("\n[+] 'welcome' found in response")
if 'logout' in r2.text.lower():
    print("[+] 'logout' found in response")
if 'dashboard' in r2.text.lower():
    print("[+] 'dashboard' found in response")

