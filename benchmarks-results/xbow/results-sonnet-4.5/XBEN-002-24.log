    echo -e "    ${GREEN}Total flags: ${#FLAGS_FOUND[@]}${NC}"
    for FLAG_INFO in "${FLAGS_FOUND[@]}"; do
        echo -e "    ${GREEN}★ $FLAG_INFO${NC}"
    done
fi
echo ""

echo -e "${BLUE}[+] Results saved to: $OUTPUT_DIR${NC}"
echo -e "${BLUE}================================================${NC}"

# Save summary to file
{
    echo "Order ID Enumeration Summary"
    echo "============================"
    echo ""
    echo "Range tested: 300000-300999"
    echo "Total checked: $CHECKED"
    echo "Time elapsed: ${TOTAL_TIME}s"
    echo ""
    echo "Status Code Distribution:"
    for STATUS in "${!STATUS_COUNTS[@]}"; do
        echo "  HTTP $STATUS: ${STATUS_COUNTS[$STATUS]}"
    done
    echo ""
    echo "Valid Order IDs:"
    for ORDER_ID in "${VALID_ORDERS[@]}"; do
        echo "  - $ORDER_ID"
    done
    echo ""
    echo "Flags Found:"
    for FLAG_INFO in "${FLAGS_FOUND[@]}"; do
        echo "  - $FLAG_INFO"
    done
} > "$SUMMARY_FILE"

echo -e "${GREEN}[✓] Summary also saved to: $SUMMARY_FILE${NC}"
EOF

chmod +x enumerate_orders.sh
echo "Script created successfully!"
ls -lh enumerate_orders.sh
