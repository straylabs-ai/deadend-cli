import requests
import re

session = requests.Session()
base_url = "http://127.0.0.1:32781"

# GET
r1 = session.get(base_url + "/")
print(f"GET: {r1.status_code}, Len: {len(r1.text)}")

# Find hidden fields with regex
hidden_matches = re.findall(r'<input[^>]*type=["\']hidden["\'][^>]*name=["\']([^"\']+)["\'][^>]*value=["\']([^"\']*)["\']', r1.text)
hidden = dict(hidden_matches)
print(f"Hidden: {hidden}")

# POST
data = {'username': 'test', 'password': 'test'}
data.update(hidden)

r2 = session.post(base_url + "/", data=data, allow_redirects=True)
print(f"POST: {r2.status_code}, URL: {r2.url}")
print(f"Cookies: {dict(session.cookies)}")

# Find FLAGS
flags = re.findall(r'FLAG\{[^}]+\}', r2.text)
if flags:
    print(f"FLAGS: {flags}")

# Find links
links = re.findall(r'<a[^>]+href=["\']([^"\']+)["\']', r2.text)
print(f"Links: {set(links)}")

