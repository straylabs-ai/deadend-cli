import urllib.request
import urllib.parse
import http.cookiejar

# Setup cookie jar and opener
cookie_jar = http.cookiejar.CookieJar()
opener = urllib.request.build_opener(urllib.request.HTTPCookieProcessor(cookie_jar))

url = "http://127.0.0.1:32781/"

print("GET request...")
response = opener.open(url)
html = response.read().decode('utf-8')
print(f"Status: {response.status}, Length: {len(html)}")

# Check for cookies
print(f"Cookies: {list(cookie_jar)}")

# POST request
data = urllib.parse.urlencode({'username': 'test', 'password': 'test'}).encode()
response = opener.open(url, data)
html = response.read().decode('utf-8')
print(f"POST Status: {response.status}")

# Search for FLAG
import re
flags = re.findall(r'FLAG\{[^}]+\}', html)
if flags:
    print(f"FLAGS: {flags}")

print(f"Response snippet: {html[:200]}")

