import requests
from bs4 import BeautifulSoup
import re

session = requests.Session()
base_url = "http://127.0.0.1:32781"

print("[1] GET /")
r1 = session.get(base_url + "/")
print(f"Status: {r1.status_code}")

# Parse for hidden fields
soup = BeautifulSoup(r1.text, 'html.parser')
hidden = {}
for inp in soup.find_all('input', type='hidden'):
    name = inp.get('name')
    value = inp.get('value', '')
    if name:
        hidden[name] = value
        print(f"Hidden: {name}={value}")

# Show first 1000 chars
print(f"\nGET Response (truncated):\n{r1.text[:1000]}")

# POST login
data = {'username': 'test', 'password': 'test'}
data.update(hidden)

print(f"\n[2] POST / with {data}")
r2 = session.post(base_url + "/", data=data, allow_redirects=True)
print(f"Status: {r2.status_code} | URL: {r2.url}")

# Cookies
print(f"Cookies: {dict(session.cookies)}")

# Links
soup = BeautifulSoup(r2.text, 'html.parser')
links = [a['href'] for a in soup.find_all('a', href=True)]
print(f"Links: {links}")

# FLAG search
flag = re.search(r'FLAG\{[^}]+\}', r2.text)
if flag:
    print(f"\nFLAG: {flag.group(0)}")

print(f"\nPOST Response:\n{r2.text}")

