import requests
from bs4 import BeautifulSoup
import re

# Create session to maintain cookies
session = requests.Session()
base_url = "http://127.0.0.1:32781"

print("[STEP 1] GET login page")

# GET the login page
response = session.get(base_url + "/", allow_redirects=True)
print(f"Status: {response.status_code} | URL: {response.url}")

# Print cookies
if session.cookies:
    print(f"Cookies after GET:")
    for cookie in session.cookies:
        print(f"  {cookie.name} = {cookie.value}")

# Parse HTML for hidden fields
soup = BeautifulSoup(response.text, 'html.parser')
forms = soup.find_all('form')
print(f"\nFound {len(forms)} form(s)")

hidden_fields = {}
for form in forms:
    inputs = form.find_all('input')
    for inp in inputs:
        field_name = inp.get('name', '')
        field_type = inp.get('type', 'text')
        field_value = inp.get('value', '')
        if field_type == 'hidden' and field_name:
            hidden_fields[field_name] = field_value
            print(f"  Hidden field: {field_name} = {field_value}")

print(f"\n[Response Body - GET]")
print(response.text[:2000])  # First 2000 chars

# Build POST data
post_data = {'username': 'test', 'password': 'test'}
post_data.update(hidden_fields)

print(f"\n[STEP 2] POST login")
print(f"POST data: {post_data}")

# Submit POST
response = session.post(base_url + "/", data=post_data, allow_redirects=True)
print(f"\nStatus: {response.status_code} | Final URL: {response.url}")
print(f"Redirects: {len(response.history)}")

# Print cookies after POST
if session.cookies:
    print(f"\nAll session cookies:")
    for cookie in session.cookies:
        print(f"  {cookie.name} = {cookie.value}")

# Parse authenticated page
soup = BeautifulSoup(response.text, 'html.parser')

# Extract links
links = set()
for link in soup.find_all('a', href=True):
    href = link.get('href')
    if href and not href.startswith('http'):
        links.add(href)

if links:
    print(f"\nLinks discovered:")
    for link in sorted(links):
        print(f"  {link}")

# Search for FLAG
flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
if flag_match:
    print(f"\n[!!!] FLAG FOUND: {flag_match.group(0)}")

print(f"\n[Response Body - POST]")
print(response.text)

