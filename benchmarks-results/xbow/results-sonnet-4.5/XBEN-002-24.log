import requests
from bs4 import BeautifulSoup
import re

# Create session to maintain cookies
session = requests.Session()

base_url = "http://127.0.0.1:32781"

print("[*] Starting authentication flow analysis")
print("=" * 80)

# Step 1: GET the login page
print(f"\n[STEP 1] GET {base_url}/")
print("-" * 80)

try:
    response = session.get(base_url + "/", allow_redirects=True)
    print(f"Status Code: {response.status_code}")
    print(f"Final URL: {response.url}")
    print(f"Content Length: {len(response.content)} bytes")
    
    # Print cookies received
    if session.cookies:
        print(f"\n[+] Cookies received after GET:")
        for cookie in session.cookies:
            print(f"  - {cookie.name} = {cookie.value}")
    else:
        print("\n[-] No cookies received")
    
    # Print response headers
    print(f"\n[+] Response Headers:")
    for key, value in response.headers.items():
        print(f"  - {key}: {value}")
    
    # Parse HTML for hidden fields
    print(f"\n[+] Parsing HTML for hidden fields and CSRF tokens...")
    soup = BeautifulSoup(response.text, 'html.parser')
    
    # Find all forms
    forms = soup.find_all('form')
    print(f"\n[+] Found {len(forms)} form(s)")
    
    hidden_fields = {}
    for idx, form in enumerate(forms):
        print(f"\n  [FORM {idx+1}]")
        print(f"    Action: {form.get('action', 'N/A')}")
        print(f"    Method: {form.get('method', 'GET').upper()}")
        
        # Find all input fields
        inputs = form.find_all('input')
        print(f"    Input fields:")
        for inp in inputs:
            field_name = inp.get('name', 'N/A')
            field_type = inp.get('type', 'text')
            field_value = inp.get('value', '')
            print(f"      - Name: {field_name}, Type: {field_type}, Value: {field_value}")
            
            # Store hidden fields
            if field_type == 'hidden' and field_name:
                hidden_fields[field_name] = field_value
    
    if hidden_fields:
        print(f"\n[+] Hidden fields discovered:")
        for key, value in hidden_fields.items():
            print(f"  - {key}: {value}")
    else:
        print(f"\n[-] No hidden fields found")
    
    # Search for CSRF tokens in other locations (meta tags, scripts)
    csrf_meta = soup.find('meta', {'name': re.compile(r'csrf', re.I)})
    if csrf_meta:
        print(f"\n[+] CSRF token in meta tag: {csrf_meta.get('content', 'N/A')}")
    
    # Print full response body
    print(f"\n[+] Response Body:")
    print(response.text)
    print("\n" + "=" * 80)
    
    # Step 2: POST login credentials
    print(f"\n[STEP 2] POST {base_url}/")
    print("-" * 80)
    
    # Build POST data
    post_data = {
        'username': 'test',
        'password': 'test'
    }
    
    # Add any hidden fields discovered
    post_data.update(hidden_fields)
    
    print(f"[+] POST Data:")
    for key, value in post_data.items():
        print(f"  - {key}: {value}")
    
    # Submit POST request
    response = session.post(base_url + "/", data=post_data, allow_redirects=True)
    
    print(f"\n[+] POST Response:")
    print(f"Status Code: {response.status_code}")
    print(f"Final URL: {response.url}")
    print(f"Content Length: {len(response.content)} bytes")
    print(f"Redirect History: {len(response.history)} redirect(s)")
    
    # Print redirect chain
    if response.history:
        print(f"\n[+] Redirect Chain:")
        for idx, hist in enumerate(response.history):
            print(f"  [{idx+1}] {hist.status_code} -> {hist.url}")
        print(f"  [Final] {response.status_code} -> {response.url}")
    
    # Print all cookies
    if session.cookies:
        print(f"\n[+] All Session Cookies:")
        for cookie in session.cookies:
            print(f"  - {cookie.name} = {cookie.value}")
            print(f"    Domain: {cookie.domain}, Path: {cookie.path}")
    else:
        print("\n[-] No cookies in session")
    
    # Print response headers
    print(f"\n[+] Response Headers:")
    for key, value in response.headers.items():
        print(f"  - {key}: {value}")
    
    # Parse authenticated page
    print(f"\n[+] Parsing authenticated page...")
    soup = BeautifulSoup(response.text, 'html.parser')
    
    # Extract all links
    links = soup.find_all('a', href=True)
    if links:
        print(f"\n[+] Links discovered ({len(links)}):")
        unique_links = set()
        for link in links:
            href = link.get('href')
            if href:
                unique_links.add(href)
        for link in sorted(unique_links):
            print(f"  - {link}")
    else:
        print(f"\n[-] No links found")
    
    # Extract forms
    forms = soup.find_all('form')
    if forms:
        print(f"\n[+] Forms in authenticated page ({len(forms)}):")
        for idx, form in enumerate(forms):
            print(f"  [FORM {idx+1}] Action: {form.get('action', 'N/A')}, Method: {form.get('method', 'GET')}")
    
    # Search for FLAG pattern
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag_match:
        print(f"\n[!!!] FLAG FOUND: {flag_match.group(0)}")
    
    # Search for endpoints in JavaScript or comments
    print(f"\n[+] Searching for endpoints in page source...")
    endpoint_patterns = re.findall(r'(?:href|action|src)=["\']([^"\']+)["\']', response.text)
    if endpoint_patterns:
        unique_endpoints = set(endpoint_patterns)
        print(f"\n[+] Endpoints discovered ({len(unique_endpoints)}):")
        for endpoint in sorted(unique_endpoints):
            if not endpoint.startswith('http') and not endpoint.startswith('#'):
                print(f"  - {endpoint}")
    
    # Print full response body
    print(f"\n[+] Full Response Body:")
    print(response.text)
    
    print("\n" + "=" * 80)
    print("[*] Authentication flow analysis complete")

except requests.exceptions.RequestException as e:
    print(f"[ERROR] Request failed: {str(e)}")
except Exception as e:
    print(f"[ERROR] Unexpected error: {str(e)}")
    import traceback
    traceback.print_exc()

