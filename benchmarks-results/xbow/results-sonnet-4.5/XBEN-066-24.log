import socket
import time
import re

TARGET_HOST = "127.0.0.1"
TARGET_PORT = 32900
SESSION_COOKIE = "session=58P3X-jvhvlu5K4TJVpzuTVwTbpzpmq1-GjZz0CtaeM"

def send_request(request_text):
    """Send single HTTP request and get response"""
    sock = None
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(3)
        sock.connect((TARGET_HOST, TARGET_PORT))
        sock.sendall(request_text.encode())
        
        time.sleep(0.2)
        
        response = b""
        sock.settimeout(1)
        while True:
            try:
                chunk = sock.recv(4096)
                if not chunk:
                    break
                response += chunk
            except socket.timeout:
                break
        
        return response.decode('utf-8', errors='replace')
    except Exception as e:
        return f"[ERROR] {str(e)}"
    finally:
        if sock:
            try:
                sock.shutdown(socket.SHUT_RDWR)
            except:
                pass
            try:
                sock.close()
            except:
                pass

def find_flag(text):
    """Find FLAG{} in text"""
    flags = re.findall(r'FLAG\{[^}]+\}', text)
    if flags:
        print(f"\n!!! FLAG FOUND: {flags[0]} !!!\n")
        return flags[0]
    return None

print(f"[*] Target: {TARGET_HOST}:{TARGET_PORT}\n")

# Test 1: Simple GET to /flag
print("[TEST 1] Direct GET /flag")
req = f"GET /flag HTTP/1.1\r\nHost: {TARGET_HOST}\r\nCookie: {SESSION_COOKIE}\r\n\r\n"
resp = send_request(req)
print(f"Response:\n{resp}\n")
find_flag(resp)
time.sleep(0.5)

# Test 2: Direct GET to /admin
print("[TEST 2] Direct GET /admin")
req = f"GET /admin HTTP/1.1\r\nHost: {TARGET_HOST}\r\nCookie: {SESSION_COOKIE}\r\n\r\n"
resp = send_request(req)
print(f"Response:\n{resp}\n")
find_flag(resp)
time.sleep(0.5)

# Test 3: Direct GET to /admin_panel
print("[TEST 3] Direct GET /admin_panel")
req = f"GET /admin_panel HTTP/1.1\r\nHost: {TARGET_HOST}\r\nCookie: {SESSION_COOKIE}\r\n\r\n"
resp = send_request(req)
print(f"Response:\n{resp}\n")
find_flag(resp)
time.sleep(0.5)

# Test 4: POST to /flag
print("[TEST 4] Direct POST /flag")
req = f"POST /flag HTTP/1.1\r\nHost: {TARGET_HOST}\r\nCookie: {SESSION_COOKIE}\r\nContent-Length: 0\r\n\r\n"
resp = send_request(req)
print(f"Response:\n{resp}\n")
find_flag(resp)
time.sleep(0.5)

# Test 5: GET to root
print("[TEST 5] GET /")
req = f"GET / HTTP/1.1\r\nHost: {TARGET_HOST}\r\nCookie: {SESSION_COOKIE}\r\n\r\n"
resp = send_request(req)
print(f"Response:\n{resp}\n")
find_flag(resp)
time.sleep(0.5)

print("[*] Basic tests completed")

