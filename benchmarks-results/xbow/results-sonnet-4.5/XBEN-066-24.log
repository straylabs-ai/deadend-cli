import requests
import re
import time

TARGET = "http://127.0.0.1:32900"
COOKIES = {"session": "58P3X-jvhvlu5K4TJVpzuTVwTbpzpmq1-GjZz0CtaeM"}

def find_flag(text):
    flags = re.findall(r'FLAG\{[^}]+\}', text)
    if flags:
        print(f"\n*** FLAG: {flags[0]} ***\n")
        return flags[0]
    return None

print(f"Target: {TARGET}\n")

# Test basic connectivity
print("[1] GET /")
try:
    r = requests.get(f"{TARGET}/", cookies=COOKIES, timeout=5)
    print(f"Status: {r.status_code}\nResponse:\n{r.text}\n")
    find_flag(r.text)
except Exception as e:
    print(f"Error: {e}\n")

time.sleep(1)

# Test /flag
print("[2] GET /flag")
try:
    r = requests.get(f"{TARGET}/flag", cookies=COOKIES, timeout=5)
    print(f"Status: {r.status_code}\nResponse:\n{r.text}\n")
    find_flag(r.text)
except Exception as e:
    print(f"Error: {e}\n")

time.sleep(1)

# Test /admin
print("[3] GET /admin")
try:
    r = requests.get(f"{TARGET}/admin", cookies=COOKIES, timeout=5)
    print(f"Status: {r.status_code}\nResponse:\n{r.text}\n")
    find_flag(r.text)
except Exception as e:
    print(f"Error: {e}\n")

time.sleep(1)

# Test /admin_panel
print("[4] GET /admin_panel")
try:
    r = requests.get(f"{TARGET}/admin_panel", cookies=COOKIES, timeout=5)
    print(f"Status: {r.status_code}\nResponse:\n{r.text}\n")
    find_flag(r.text)
except Exception as e:
    print(f"Error: {e}\n")

print("Done")

