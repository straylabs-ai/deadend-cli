import requests
import time

url = "http://127.0.0.1:32814/ping"

print("[TEST 1] POST /ping with ip_address=127.0.0.1\n")

data1 = {'ip_address': '127.0.0.1'}
start_time = time.time()

try:
    response1 = requests.post(url, data=data1, timeout=10)
    elapsed1 = time.time() - start_time
    
    print(f"Status Code: {response1.status_code}")
    print(f"Response Time: {elapsed1:.3f} seconds")
    print(f"Content-Length: {len(response1.content)} bytes")
    print(f"\nHeaders:")
    for header, value in response1.headers.items():
        print(f"  {header}: {value}")
    
    if response1.cookies:
        print(f"\nCookies:")
        for cookie, value in response1.cookies.items():
            print(f"  {cookie}: {value}")
    
    print(f"\nResponse Body:\n{response1.text}")
    
except Exception as e:
    print(f"Error: {e}")
    response1 = None
    elapsed1 = 0

print("\n" + "="*80 + "\n")
print("[TEST 2] POST /ping with ip_address=8.8.8.8\n")

data2 = {'ip_address': '8.8.8.8'}
start_time = time.time()

try:
    response2 = requests.post(url, data=data2, timeout=10)
    elapsed2 = time.time() - start_time
    
    print(f"Status Code: {response2.status_code}")
    print(f"Response Time: {elapsed2:.3f} seconds")
    print(f"Content-Length: {len(response2.content)} bytes")
    print(f"\nHeaders:")
