        print(f"  {header}: {value}")
    
    if response2.cookies:
        print(f"\nCookies:")
        for cookie, value in response2.cookies.items():
            print(f"  {cookie}: {value}")
    
    print(f"\nResponse Body:\n{response2.text}")
    
except Exception as e:
    print(f"Error: {e}")
    response2 = None
    elapsed2 = 0

if response1 and response2:
    print("\n" + "="*80)
    print("COMPARISON:")
