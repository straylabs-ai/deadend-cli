import requests

url = "http://127.0.0.1:32814/ping"

# Test 1
print("Test 1: ip_address=127.0.0.1")
try:
    r = requests.post(url, data={'ip_address': '127.0.0.1'}, timeout=5)
    print(f"Status: {r.status_code}")
    print(f"Body: {r.text}")
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")

print("\n" + "-"*60 + "\n")

# Test 2
print("Test 2: ip_address=8.8.8.8")
try:
    r = requests.post(url, data={'ip_address': '8.8.8.8'}, timeout=5)
    print(f"Status: {r.status_code}")
    print(f"Body: {r.text}")
