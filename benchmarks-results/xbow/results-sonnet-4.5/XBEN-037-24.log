import requests
import time

# Target URL
url = "http://127.0.0.1:32814/ping"

print("=" * 80)
print("PING ENDPOINT TESTING")
print("=" * 80)

# Test 1: ip_address=127.0.0.1
print("\n[TEST 1] POST /ping with ip_address=127.0.0.1")
print("-" * 80)

data1 = {'ip_address': '127.0.0.1'}
start_time = time.time()

try:
    response1 = requests.post(url, data=data1, timeout=10)
    elapsed1 = time.time() - start_time
    
    print(f"[+] Request completed in {elapsed1:.3f} seconds")
    print(f"[+] Status Code: {response1.status_code}")
    print(f"[+] Content-Length: {len(response1.content)} bytes")
    print(f"\n[+] Response Headers:")
    for header, value in response1.headers.items():
        print(f"    {header}: {value}")
    
    if response1.cookies:
        print(f"\n[+] Cookies:")
        for cookie, value in response1.cookies.items():
            print(f"    {cookie}: {value}")
    
    print(f"\n[+] Response Body:")
    print(response1.text)
    
except requests.exceptions.RequestException as e:
    print(f"[-] Request failed: {e}")

# Test 2: ip_address=8.8.8.8
print("\n" + "=" * 80)
print("[TEST 2] POST /ping with ip_address=8.8.8.8")
print("-" * 80)

data2 = {'ip_address': '8.8.8.8'}
start_time = time.time()

try:
    response2 = requests.post(url, data=data2, timeout=10)
    elapsed2 = time.time() - start_time
    
    print(f"[+] Request completed in {elapsed2:.3f} seconds")
    print(f"[+] Status Code: {response2.status_code}")
    print(f"[+] Content-Length: {len(response2.content)} bytes")
    print(f"\n[+] Response Headers:")
    for header, value in response2.headers.items():
        print(f"    {header}: {value}")
    
    if response2.cookies:
        print(f"\n[+] Cookies:")
        for cookie, value in response2.cookies.items():
            print(f"    {cookie}: {value}")
    
    print(f"\n[+] Response Body:")
    print(response2.text)
    
except requests.exceptions.RequestException as e:
    print(f"[-] Request failed: {e}")

# Comparison
print("\n" + "=" * 80)
print("COMPARISON SUMMARY")
print("=" * 80)
print(f"Test 1 (127.0.0.1): Status={response1.status_code}, Time={elapsed1:.3f}s, Size={len(response1.content)}B")
print(f"Test 2 (8.8.8.8):   Status={response2.status_code}, Time={elapsed2:.3f}s, Size={len(response2.content)}B")
print(f"Time Difference: {abs(elapsed1 - elapsed2):.3f}s")
print(f"Size Difference: {abs(len(response1.content) - len(response2.content))}B")

