import requests
import re

# Base URL
base_url = "http://127.0.0.1:32857"

# Create session to maintain cookies
session = requests.Session()

# Set initial cookie from context
session.cookies.set('PHPSESSID', '81a26cfbe5570d952fc629c50d238afe', domain='127.0.0.1', path='/')

print("STEP 1: USER REGISTRATION\n")

# Registration data
reg_data = {
    'username': 'user1',
    'password': 'pass1'
}

# Attempt registration
reg_response = session.post(
    f"{base_url}/sign-up.php",
    data=reg_data,
    allow_redirects=False
)

print(f"POST {base_url}/sign-up.php")
print(f"Data: {reg_data}")
print(f"Status: {reg_response.status_code}")
print(f"Cookies: {dict(session.cookies)}")

if 'Location' in reg_response.headers:
    print(f"Redirect: {reg_response.headers['Location']}")

print(f"\nRegistration Response:\n{reg_response.text}\n")

print("\nSTEP 2: USER LOGIN\n")

# Login data
login_data = {
    'username': 'user1',
    'password': 'pass1'
}

# Attempt login
login_response = session.post(
    f"{base_url}/sign-in.php",
    data=login_data,
    allow_redirects=False
)

print(f"POST {base_url}/sign-in.php")
print(f"Data: {login_data}")
print(f"Status: {login_response.status_code}")
print(f"Cookies: {dict(session.cookies)}")

if 'Location' in login_response.headers:
    print(f"Redirect: {login_response.headers['Location']}")

print(f"\nLogin Response:\n{login_response.text}\n")

print("\nSTEP 3: ACCESS ROOT PAGE\n")

# Access root page
root_response = session.get(f"{base_url}/", allow_redirects=True)

print(f"GET {base_url}/")
print(f"Status: {root_response.status_code}")
print(f"Final URL: {root_response.url}")

print(f"\nRoot Page Response:\n{root_response.text}\n")

print("\nSTEP 4: ANALYZE FOR ENDPOINTS\n")

# Find links and actions
links = re.findall(r'(?:href|action)=["\'](.*?)["\']', root_response.text, re.IGNORECASE)
if links:
    print("Found Links/Actions:")
    for link in set(links):
        print(f"  {link}")

# Find PHP files
php_files = re.findall(r'[\w\-/]+\.php', root_response.text)
if php_files:
    print("\nFound PHP Files:")
    for php_file in set(php_files):
        print(f"  {php_file}")

# Search for keywords
keywords = ['notes', 'note', 'secret', 'flag', 'admin']
print(f"\nSearching for keywords: {keywords}")
for keyword in keywords:
    if keyword.lower() in root_response.text.lower():
        print(f"  Found: {keyword}")

print(f"\nSession Cookies: {dict(session.cookies)}")

