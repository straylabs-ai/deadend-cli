import requests
import re

base_url = "http://127.0.0.1:32857"
session = requests.Session()
session.cookies.set('PHPSESSID', '81a26cfbe5570d952fc629c50d238afe', domain='127.0.0.1', path='/')

# Register
reg_response = session.post(f"{base_url}/sign-up.php", data={'username': 'user1', 'password': 'pass1'}, allow_redirects=False)
print(f"Registration Status: {reg_response.status_code}")
if 'Location' in reg_response.headers:
    print(f"Registration Redirect: {reg_response.headers['Location']}")
print(f"Registration Body: {reg_response.text[:500]}")

# Login
login_response = session.post(f"{base_url}/sign-in.php", data={'username': 'user1', 'password': 'pass1'}, allow_redirects=False)
print(f"\nLogin Status: {login_response.status_code}")
print(f"Login Cookies: {dict(session.cookies)}")
if 'Location' in login_response.headers:
    print(f"Login Redirect: {reg_response.headers['Location']}")

# Access root
root_response = session.get(f"{base_url}/", allow_redirects=True)
print(f"\nRoot Status: {root_response.status_code}")
print(f"\nRoot Page Content:\n{root_response.text}")

# Find endpoints
links = set(re.findall(r'(?:href|action)=["\'](.*?)["\']', root_response.text, re.IGNORECASE))
print(f"\nFound Links: {links}")

