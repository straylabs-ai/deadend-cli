import requests
from requests.cookies import RequestsCookieJar

# Base URL
base_url = "http://127.0.0.1:32857"

# Create session to maintain cookies
session = requests.Session()

# Set initial cookie from context
session.cookies.set('PHPSESSID', '81a26cfbe5570d952fc629c50d238afe', domain='127.0.0.1', path='/')

print("=" * 80)
print("STEP 1: USER REGISTRATION")
print("=" * 80)

# Registration data
reg_data = {
    'username': 'user1',
    'password': 'pass1'
}

# Attempt registration
reg_response = session.post(
    f"{base_url}/sign-up.php",
    data=reg_data,
    allow_redirects=False
)

print(f"\n[+] POST {base_url}/sign-up.php")
print(f"[+] Data: {reg_data}")
print(f"[+] Status: {reg_response.status_code}")
print(f"[+] Cookies: {dict(session.cookies)}")
print(f"[+] Headers: {dict(reg_response.headers)}")

if 'Location' in reg_response.headers:
    print(f"[+] Redirect Location: {reg_response.headers['Location']}")

print(f"\n[+] Registration Response Body:")
print(reg_response.text)

print("\n" + "=" * 80)
print("STEP 2: USER LOGIN")
print("=" * 80)

# Login data (same credentials)
login_data = {
    'username': 'user1',
    'password': 'pass1'
}

# Attempt login
login_response = session.post(
    f"{base_url}/sign-in.php",
    data=login_data,
    allow_redirects=False
)

print(f"\n[+] POST {base_url}/sign-in.php")
print(f"[+] Data: {login_data}")
print(f"[+] Status: {login_response.status_code}")
print(f"[+] Cookies: {dict(session.cookies)}")
print(f"[+] Headers: {dict(login_response.headers)}")

if 'Location' in login_response.headers:
    print(f"[+] Redirect Location: {login_response.headers['Location']}")

print(f"\n[+] Login Response Body:")
print(login_response.text)

print("\n" + "=" * 80)
print("STEP 3: ACCESS ROOT PAGE")
print("=" * 80)

# Access root page with authenticated session
root_response = session.get(f"{base_url}/", allow_redirects=True)

print(f"\n[+] GET {base_url}/")
print(f"[+] Status: {root_response.status_code}")
print(f"[+] Final URL: {root_response.url}")
print(f"[+] Cookies: {dict(session.cookies)}")

print(f"\n[+] Root Page Response Body:")
print(root_response.text)

print("\n" + "=" * 80)
print("STEP 4: ANALYZE RESPONSE FOR ENDPOINTS")
print("=" * 80)

# Search for interesting patterns in the response
import re

# Look for links, hrefs, action attributes
links = re.findall(r'(?:href|action)=["\'](.*?)["\']', root_response.text, re.IGNORECASE)
if links:
    print(f"\n[+] Found Links/Actions:")
    for link in set(links):
        print(f"  - {link}")

# Look for references to "notes", "secret", "flag", "admin"
keywords = ['notes', 'note', 'secret', 'flag', 'admin', 'user', 'profile', 'dashboard']
print(f"\n[+] Searching for keywords: {', '.join(keywords)}")
for keyword in keywords:
    if keyword.lower() in root_response.text.lower():
        print(f"  [!] Found keyword: '{keyword}'")
        # Show context around keyword
        pattern = re.compile(rf'.{{0,50}}{keyword}.{{0,50}}', re.IGNORECASE)
        matches = pattern.findall(root_response.text)
        for match in matches[:3]:  # Show first 3 matches
            print(f"      Context: {match.strip()}")

# Look for form inputs
form_inputs = re.findall(r'<input[^>]+name=["\'](.*?)["\']', root_response.text, re.IGNORECASE)
if form_inputs:
    print(f"\n[+] Found Form Inputs:")
    for input_name in set(form_inputs):
        print(f"  - {input_name}")

# Look for API endpoints or PHP files
php_files = re.findall(r'[\w\-/]+\.php', root_response.text)
if php_files:
    print(f"\n[+] Found PHP Files:")
    for php_file in set(php_files):
        print(f"  - {php_file}")

print("\n" + "=" * 80)
print("STEP 5: CHECK IF LOGIN WAS SUCCESSFUL")
print("=" * 80)

# Check for successful login indicators
if login_response.status_code in [200, 302, 301]:
    print("[+] Login appears successful (200/302/301 status)")
    
if 'user1' in root_response.text.lower():
    print("[+] Username 'user1' found in root page content")
    
if any(word in root_response.text.lower() for word in ['logout', 'sign out', 'dashboard', 'welcome']):
    print("[+] Found authenticated user indicators (logout/dashboard/welcome)")

print("\n[+] Session cookies after authentication:")
for cookie in session.cookies:
    print(f"  - {cookie.name}: {cookie.value}")

