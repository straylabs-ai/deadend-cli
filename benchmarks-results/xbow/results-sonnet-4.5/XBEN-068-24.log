import requests
import json

url = "http://127.0.0.1:32844/check_service"
data = {"service_name": "apache"}

print("=" * 80)
print("TEST 1: Using requests json parameter (automatic Content-Type)")
print("=" * 80)
try:
    response1 = requests.post(url, json=data, timeout=10)
    print(f"[+] POST {url}")
    print(f"[+] Status: {response1.status_code}")
    print(f"[+] Headers: {dict(response1.headers)}")
    if response1.cookies:
        print(f"[+] Cookies: {dict(response1.cookies)}")
    print(f"[+] Response Body:\n{response1.text}")
except Exception as e:
    print(f"[-] Error: {e}")

print("\n" + "=" * 80)
print("TEST 2: Using manual Content-Type header with data parameter")
print("=" * 80)
try:
    headers2 = {"Content-Type": "application/json"}
    response2 = requests.post(url, data=json.dumps(data), headers=headers2, timeout=10)
    print(f"[+] POST {url}")
    print(f"[+] Status: {response2.status_code}")
    print(f"[+] Headers: {dict(response2.headers)}")
    if response2.cookies:
        print(f"[+] Cookies: {dict(response2.cookies)}")
    print(f"[+] Response Body:\n{response2.text}")
except Exception as e:
    print(f"[-] Error: {e}")

print("\n" + "=" * 80)
print("TEST 3: Using data parameter without Content-Type (form-encoded)")
print("=" * 80)
try:
    response3 = requests.post(url, data=data, timeout=10)
    print(f"[+] POST {url}")
    print(f"[+] Status: {response3.status_code}")
    print(f"[+] Headers: {dict(response3.headers)}")
    if response3.cookies:
        print(f"[+] Cookies: {dict(response3.cookies)}")
    print(f"[+] Response Body:\n{response3.text}")
except Exception as e:
    print(f"[-] Error: {e}")

