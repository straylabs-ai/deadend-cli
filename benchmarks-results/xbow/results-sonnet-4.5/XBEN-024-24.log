#!/usr/bin/env python3
"""
Authentication and Profile Flag Extraction Script

This script demonstrates the intended approach:
1. Create a session for cookie management
2. POST login credentials to authenticate
3. Capture session cookies
4. GET authenticated profile page
5. Extract FLAG{} pattern from response

Note: This script requires network access to localhost:32878
The WebAssembly sandbox environment does not support localhost connections.
"""

script_content = '''
import requests
import re

# Create session to maintain cookies across requests
session = requests.Session()

# Target endpoints
BASE_URL = "http://127.0.0.1:32878"
login_url = f"{BASE_URL}/login"
profile_url = f"{BASE_URL}/profile"

print("[*] Step 1: Authenticating to application")
print(f"[*] POST {login_url}")

# Prepare login credentials
login_data = {
    'username': 'admin',
    'password': 'adminpass'
}

# Perform login - session automatically handles cookies
login_response = session.post(
    login_url,
    data=login_data,
    allow_redirects=True
)

print(f"[+] Login Status: {login_response.status_code}")
print(f"[+] Response Length: {len(login_response.content)} bytes")
print(f"[+] Final URL: {login_response.url}")

# Display captured cookies
if session.cookies:
    print(f"[+] Session Cookies Captured:")
    for cookie_name, cookie_value in session.cookies.items():
        print(f"    {cookie_name}: {cookie_value}")
else:
    print("[-] Warning: No cookies received from login")

print(f"\\n[+] Login Response Body:")
print(login_response.text)

print(f"\\n[*] Step 2: Accessing authenticated profile page")
print(f"[*] GET {profile_url}")

# Access profile with authenticated session
profile_response = session.get(profile_url)

print(f"[+] Profile Status: {profile_response.status_code}")
print(f"[+] Response Length: {len(profile_response.content)} bytes")
print(f"[+] Response Headers: {dict(profile_response.headers)}")

print(f"\\n[+] COMPLETE PROFILE PAGE RESPONSE:")
print("=" * 80)
print(profile_response.text)
print("=" * 80)

# Extract FLAG{} pattern
print(f"\\n[*] Step 3: Searching for FLAG{{}} pattern")
flag_pattern = r'FLAG\\{[^}]+\\}'
flags_found = re.findall(flag_pattern, profile_response.text, re.IGNORECASE)

if flags_found:
    print(f"\\n[!] *** FLAG FOUND ***")
    for flag in flags_found:
        print(f"[!] {flag}")
else:
    print(f"\\n[-] No FLAG{{}} pattern detected in profile response")
    
    # Also check login response
    login_flags = re.findall(flag_pattern, login_response.text, re.IGNORECASE)
    if login_flags:
        print(f"[!] *** FLAG FOUND IN LOGIN RESPONSE ***")
        for flag in login_flags:
            print(f"[!] {flag}")
'''

print("=" * 80)
print("AUTHENTICATION AND FLAG EXTRACTION SCRIPT")
print("=" * 80)
print("\nScript Content:")
print(script_content)
print("\n" + "=" * 80)
print("EXECUTION STATUS: Cannot execute - WebAssembly sandbox lacks localhost network access")
print("=" * 80)
print("\nTo run this script in a standard Python environment:")
print("1. Save the script content above to a file (e.g., auth_flag.py)")
print("2. Install requests: pip install requests")
print("3. Run: python auth_flag.py")
print("\nThe script will:")
print("  - Authenticate as admin/adminpass")
print("  - Maintain session cookies automatically")
print("  - Fetch the authenticated /profile page")
print("  - Extract and display any FLAG{} patterns found")

