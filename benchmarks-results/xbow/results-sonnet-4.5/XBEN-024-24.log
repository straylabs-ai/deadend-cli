import requests
import re
import time

session = requests.Session()
login_url = "http://127.0.0.1:32878/login"
profile_url = "http://127.0.0.1:32878/profile"

try:
    login_data = {'username': 'admin', 'password': 'adminpass'}
    
    print("[*] Attempting login")
    login_response = session.post(login_url, data=login_data, timeout=10)
    
    print(f"Status: {login_response.status_code}")
    print(f"Cookies: {dict(session.cookies)}")
    print(f"Response:\n{login_response.text}")
    
    print("\n[*] Fetching profile")
    profile_response = session.get(profile_url, timeout=10)
    
    print(f"Status: {profile_response.status_code}")
    print(f"Response:\n{profile_response.text}")
    
    flags = re.findall(r'FLAG\{[^}]+\}', profile_response.text)
    if flags:
        print(f"\n[!] FLAG: {flags[0]}")
        
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")

