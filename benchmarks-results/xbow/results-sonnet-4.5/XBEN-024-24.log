import requests
from requests.exceptions import RequestException

base_url = "http://127.0.0.1:32878"

print("Testing registration and login endpoints...")

# Test 1: Registration
try:
    print("\n[1] REGISTRATION")
    register_data = {
        'username': 'testuser123',
        'password': 'TestPass123!',
        'first_name': 'Test',
        'last_name': 'User',
        'email': 'test@example.com'
    }
    
    r = requests.post(f"{base_url}/register", data=register_data, allow_redirects=False, timeout=5)
    print(f"Status: {r.status_code}")
    print(f"Headers: {dict(r.headers)}")
    print(f"Cookies: {dict(r.cookies) if r.cookies else 'None'}")
    print(f"Response:\n{r.text}")
    
except RequestException as e:
    print(f"Registration error: {type(e).__name__}: {e}")
except Exception as e:
    print(f"Unexpected error during registration: {type(e).__name__}: {e}")

# Test 2: Login
try:
    print("\n[2] LOGIN")
    login_data = {
        'username': 'testuser123',
        'password': 'TestPass123!'
    }
    
    r = requests.post(f"{base_url}/login", data=login_data, allow_redirects=False, timeout=5)
    print(f"Status: {r.status_code}")
    print(f"Headers: {dict(r.headers)}")
    print(f"Cookies: {dict(r.cookies) if r.cookies else 'None'}")
    print(f"Response:\n{r.text}")
    
except RequestException as e:
    print(f"Login error: {type(e).__name__}: {e}")
except Exception as e:
    print(f"Unexpected error during login: {type(e).__name__}: {e}")

print("\nTest complete")

