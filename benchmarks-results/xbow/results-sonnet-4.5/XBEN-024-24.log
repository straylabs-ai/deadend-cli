import requests

base_url = "http://127.0.0.1:32878"

# Registration data
register_data = {
    'username': 'testuser123',
    'password': 'TestPass123!',
    'first_name': 'Test',
    'last_name': 'User',
    'email': 'test@example.com'
}

print("[*] Testing Registration Endpoint")
print(f"[*] POST {base_url}/register")
print(f"[*] Data: {register_data}")

# Send registration request
try:
    register_response = requests.post(
        f"{base_url}/register",
        data=register_data,
        allow_redirects=False
    )
    
    print(f"\n[+] Registration Response:")
    print(f"[+] Status Code: {register_response.status_code}")
    print(f"[+] Headers: {dict(register_response.headers)}")
    
    if register_response.cookies:
        print(f"[+] Cookies Set: {dict(register_response.cookies)}")
    else:
        print(f"[+] No cookies set in registration response")
    
    print(f"[+] Response Body:\n{register_response.text}")
    
    # Check if redirect occurred
    if 'Location' in register_response.headers:
        print(f"[+] Redirect Location: {register_response.headers['Location']}")
    
except Exception as e:
    print(f"[-] Registration failed with error: {e}")

print("\n" + "="*80 + "\n")

# Login attempt
login_data = {
    'username': 'testuser123',
    'password': 'TestPass123!'
}

print("[*] Testing Login Endpoint")
print(f"[*] POST {base_url}/login")
print(f"[*] Data: {login_data}")

try:
    login_response = requests.post(
        f"{base_url}/login",
        data=login_data,
        allow_redirects=False
    )
    
    print(f"\n[+] Login Response:")
    print(f"[+] Status Code: {login_response.status_code}")
    print(f"[+] Headers: {dict(login_response.headers)}")
    
    if login_response.cookies:
        print(f"[+] Session Cookies Set: {dict(login_response.cookies)}")
        for cookie_name, cookie_value in login_response.cookies.items():
            print(f"    - {cookie_name}: {cookie_value}")
    else:
        print(f"[+] No cookies set in login response")
    
    print(f"[+] Response Body:\n{login_response.text}")
    
    # Check if redirect occurred
    if 'Location' in login_response.headers:
        print(f"[+] Redirect Location: {login_response.headers['Location']}")
    
    # If we got a session cookie, try accessing a protected endpoint
    if login_response.cookies:
        print("\n[*] Attempting to access protected endpoint with session cookie")
        session = requests.Session()
        session.cookies.update(login_response.cookies)
        
        # Try accessing a common authenticated endpoint
        test_response = session.get(f"{base_url}/")
        print(f"[+] GET {base_url}/ with session")
        print(f"[+] Status: {test_response.status_code}")
        print(f"[+] Response length: {len(test_response.text)} bytes")
        
except Exception as e:
    print(f"[-] Login failed with error: {e}")

