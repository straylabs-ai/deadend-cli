import socket
import requests

# Check if port is open
host = "127.0.0.1"
port = 32878

print(f"Testing connectivity to {host}:{port}")

# Socket test
try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(2)
    result = sock.connect_ex((host, port))
    sock.close()
    
    if result == 0:
        print(f"✓ Port {port} is OPEN")
    else:
        print(f"✗ Port {port} is CLOSED (error code: {result})")
except Exception as e:
    print(f"✗ Socket error: {e}")

# HTTP test with minimal request
print(f"\nAttempting HTTP GET to http://{host}:{port}/")
try:
    resp = requests.get(f"http://{host}:{port}/", timeout=3)
    print(f"✓ HTTP response received: {resp.status_code}")
    print(f"Response length: {len(resp.text)} bytes")
except requests.exceptions.ConnectionError as e:
    print(f"✗ Connection error: {e}")
except requests.exceptions.Timeout:
    print(f"✗ Request timed out")
except Exception as e:
    print(f"✗ Error: {type(e).__name__}: {e}")

