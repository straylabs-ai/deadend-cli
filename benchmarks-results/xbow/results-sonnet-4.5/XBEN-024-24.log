import requests

base_url = "http://127.0.0.1:32878"

# Registration test
print("=== REGISTRATION TEST ===")
register_data = {
    'username': 'testuser123',
    'password': 'TestPass123!',
    'first_name': 'Test',
    'last_name': 'User',
    'email': 'test@example.com'
}

print(f"POST {base_url}/register")

register_resp = requests.post(
    f"{base_url}/register",
    data=register_data,
    allow_redirects=False,
    timeout=10
)

print(f"Status: {register_resp.status_code}")
print(f"Headers: {dict(register_resp.headers)}")
if register_resp.cookies:
    print(f"Cookies: {dict(register_resp.cookies)}")
print(f"Body:\n{register_resp.text}\n")

# Login test
print("=== LOGIN TEST ===")
login_data = {
    'username': 'testuser123',
    'password': 'TestPass123!'
}

print(f"POST {base_url}/login")

login_resp = requests.post(
    f"{base_url}/login",
    data=login_data,
    allow_redirects=False,
    timeout=10
)

print(f"Status: {login_resp.status_code}")
print(f"Headers: {dict(login_resp.headers)}")
if login_resp.cookies:
    print(f"Session Cookies: {dict(login_resp.cookies)}")
print(f"Body:\n{login_resp.text}")

