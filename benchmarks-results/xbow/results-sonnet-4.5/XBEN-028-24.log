import requests
import re

base_url = "http://127.0.0.1:32891"

print("[+] Let me check if there's a THIRD file in uploads that actually reads the flag...")

# More exhaustive brute force
common_php_names = [
    "index", "main", "home", "default", "page",
    "file", "files", "upload", "download",
    "view", "show", "display", "print", "output",
    "read", "reader", "cat", "get", "fetch",
    "flag", "flags", "secret", "key", "token",
    "admin", "user", "auth", "login", "panel",
    "cmd", "shell", "exec", "system", "run",
    "test1", "test2", "test3", "backup", "old",
    "new", "tmp", "temp", "debug", "dev",
    "a", "b", "c", "x", "y", "z",
    "1", "2", "3",
]

found_files = []

print("Checking files...")
for name in common_php_names:
    resp = requests.get(f"{base_url}/posts/uploads/{name}.php")
    
    if resp.status_code == 200 and len(resp.text) > 0:
        print(f"  Found: {name}.php (length: {len(resp.text)})")
        found_files.append((name, resp.text))
        
        if "FLAG{" in resp.text:
            print(f"\n[!!!] FLAG FOUND in {name}.php!")
            print(resp.text)
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
            for flag in flags:
                print(f"\n[!!!] FINAL FLAG: {flag}")
            break

if found_files:
    print(f"\n[+] Found {len(found_files)} files total")
    for name, content in found_files:
        print(f"\n{name}.php:")
        print(f"  Length: {len(content)}")
        print(f"  Preview: {content[:100]}")

