import requests
import re

base_url = "http://127.0.0.1:32891"

print("[+] Looking for file upload functionality...")

# Check homepage for upload forms
resp = requests.get(base_url)
homepage = resp.text

# Look for file input fields
file_inputs = re.findall(r'<input[^>]*type=["\']file["\'][^>]*>', homepage)
if file_inputs:
    print(f"[+] File inputs found on homepage: {len(file_inputs)}")
    for inp in file_inputs:
        print(f"  {inp}")

# Look for forms with enctype multipart
forms = re.findall(r'<form[^>]*enctype=["\']multipart/form-data["\'][^>]*>.*?</form>', homepage, re.DOTALL)
if forms:
    print(f"[+] Upload forms found: {len(forms)}")
    for form in forms:
        print(f"  {form[:200]}")

# Check ScriptKiddie posts for upload functionality
for post_id in ['ScriptKiddie', 'ScriptKiddie-v2']:
    resp = requests.get(f"{base_url}/post.php", params={'id': post_id})
    
    # Look for upload forms
    file_inputs = re.findall(r'<input[^>]*type=["\']file["\'][^>]*>', resp.text)
    if file_inputs:
        print(f"\n[+] File inputs in {post_id}: {len(file_inputs)}")
        
        # Extract form action
        form_match = re.search(r'<form[^>]*action=["\']([^"\']+)["\'][^>]*>.*?type=["\']file["\']', resp.text, re.DOTALL)
        if form_match:
            action = form_match.group(1)
            print(f"  Form action: {action}")

# Let's look at the actual HTML structure of posts more carefully
print("\n\n[+] Analyzing full HTML structure of ScriptKiddie post...")
resp = requests.get(f"{base_url}/post.php", params={'id': 'ScriptKiddie'})

# Look for javascript that might reveal endpoints
js_matches = re.findall(r'<script[^>]*>(.*?)</script>', resp.text, re.DOTALL)
print(f"\n[+] Script tags found: {len(js_matches)}")

for i, js in enumerate(js_matches):
    if len(js.strip()) > 50 and 'bootstrap' not in js:  # Skip empty and bootstrap
        print(f"\n[Script {i+1}]")
        print(js[:500])

# Look for any API endpoints or AJAX calls
api_patterns = [
    r'fetch\(["\']([^"\']+)["\']',
    r'\.ajax\({[^}]*url:\s*["\']([^"\']+)["\']',
    r'\.get\(["\']([^"\']+)["\']',
    r'\.post\(["\']([^"\']+)["\']',
]

for pattern in api_patterns:
    matches = re.findall(pattern, resp.text)
    if matches:
        print(f"\n[+] API endpoints found: {matches}")

