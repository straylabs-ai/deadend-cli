import requests

base_url = "http://127.0.0.1:32891"

print("[+] Testing if query parameters to post.php are accessible to included file...")
print("[+] This is a common PHP include() behavior - included files share scope")

# When you do include("file.php") in PHP, the included file has access to 
# all variables in the current scope, including $_GET

# Try passing additional parameters alongside 'id'
test_params = [
    {'id': 'uploads/getflag', 'read': '1'},
