import requests

base_url = "http://127.0.0.1:32891"

print("[+] Let me try accessing getflag.php with ALL possible HTTP methods and parameters...")
print("[+] Maybe there's a specific combination that works...")

# Comprehensive test with headers too
test_configs = [
    ('GET', {}, {}, 'GET no params'),
    ('GET', {'read': '1'}, {}, 'GET read=1'),
    ('GET', {'cat': '1'}, {}, 'GET cat=1'),
    ('POST', {}, {'read': '1'}, 'POST read=1'),
    ('POST', {}, {'cat': '1'}, 'POST cat=1'),
    ('GET', {}, {'X-Flag-Read': 'true'}, 'GET with header'),
    ('GET', {'action': 'cat'}, {}, 'GET action=cat'),
    ('GET', {'do': 'read'}, {}, 'GET do=read'),
]

for method, params, extra in test_configs:
    if isinstance(extra, dict):
        # Extra is headers
        headers = extra
        data = {}
        desc = test_configs[test_configs.index((method, params, extra))][3]
    else:
        # Extra is POST data
        headers = {}
        data = extra if method == 'POST' else {}
        desc = extra if isinstance(extra, str) else test_configs[test_configs.index((method, params, extra))][3]
    
    if method == 'GET':
        resp = requests.get(f"{base_url}/posts/uploads/getflag.php", params=params, headers=headers)
    else:
        resp = requests.post(f"{base_url}/posts/uploads/getflag.php", params=params, data=data, headers=headers)
    
    if "FLAG{" in resp.text:
        print(f"\n[!!!] FOUND FLAG with {desc}!")
        print(resp.text)
        
        import re
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        for flag in flags:
            print(f"\n[!!!] EXTRACTED FLAG: {flag}")
        break

# Wait - maybe the file listing IS a clue. The getflag.php shows ls output
# Maybe it's showing that FLAG.txt is 70 bytes and I need to read it another way
print("\n[+] FLAG.txt is 70 bytes. Let me try to access it directly through various paths...")

flag_paths = [
    "/FLAG.txt",
    "/posts/FLAG.txt",
    "/posts/uploads/FLAG.txt",
]

for path in flag_paths:
    resp = requests.get(f"{base_url}{path}")
    if resp.status_code == 200:
        print(f"\n[+] Accessible: {path}")
        print(f"Content: {resp.text}")
        if "FLAG{" in resp.text:
            print(f"\n[!!!] FOUND FLAG at {path}!")

