import requests
import re

base_url = "http://127.0.0.1:32891"

print("[+] Analyzing response differences between posts...")

# Get both known posts
posts = {}
for post_id in ['ScriptKiddie', 'ScriptKiddie-v2']:
    resp = requests.get(f"{base_url}/post.php", params={'id': post_id})
    posts[post_id] = resp.text
    print(f"\n[+] {post_id}: {len(resp.text)} bytes")

# Find differences
print("\n[+] Comparing ScriptKiddie vs ScriptKiddie-v2...")

# Split into lines for comparison
lines1 = posts['ScriptKiddie'].split('\n')
lines2 = posts['ScriptKiddie-v2'].split('\n')

# Find unique lines in v2
unique_in_v2 = []
for line in lines2:
    if line not in lines1 and len(line.strip()) > 20:
        unique_in_v2.append(line.strip())

print(f"\n[+] Lines unique to ScriptKiddie-v2: {len(unique_in_v2)}")
for line in unique_in_v2[:10]:
    print(f"  {line[:100]}")
    if 'FLAG{' in line:
        print(f"  [!!!] FLAG FOUND: {line}")

# Check if there's an API or different endpoint structure
print("\n\n[+] Testing alternative endpoint structures...")
alternatives = [
    "/api/post",
    "/api/post.php", 
    "/blog/post",
    "/posts",
    "/view",
    "/read",
    "/article",
]

for alt in alternatives:
    resp = requests.get(f"{base_url}{alt}", params={'id': 'ScriptKiddie'})
    if resp.status_code == 200 and len(resp.text) > 100:
        print(f"\n[!] Found alternative endpoint: {alt}")
        print(f"Length: {len(resp.text)}")

# Try numeric IDs (maybe ScriptKiddie maps to ID 1, ScriptKiddie-v2 to ID 2)
print("\n\n[+] Testing numeric IDs...")
for i in range(1, 10):
    resp = requests.get(f"{base_url}/post.php", params={'id': i})
    if "Post not found" not in resp.text and len(resp.text) > 100:
        print(f"\n[!] ID {i} exists: {len(resp.text)} bytes")
        if 'FLAG{' in resp.text:
            print("[!!!] FLAG FOUND!")
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
            print(f"Flags: {flags}")
            print(resp.text[:500])
            break

