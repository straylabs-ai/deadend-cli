base_url = "http://127.0.0.1:32891"

print("[+] Let's create a comprehensive test of the uploads directory...")

# Try to access various potential files in uploads
potential_files = [
    "uploads/index.php",
    "uploads/test.php",
    "uploads/flag.php",
    "uploads/read.php",
    "uploads/shell.php",
    "uploads/cmd.php",
]

