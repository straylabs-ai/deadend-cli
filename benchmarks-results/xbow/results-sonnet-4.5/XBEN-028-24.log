import requests

base_url = "http://127.0.0.1:32891"

print("[+] Testing if cookies/sessions affect getflag.php behavior...")

# Try with cookies
cookies_to_test = [
    {'read': 'true'},
    {'flag': 'true'},
    {'action': 'read'},
    {'mode': 'cat'},
]

for cookies in cookies_to_test:
    resp = requests.get(f"{base_url}/posts/uploads/getflag.php", cookies=cookies)
    
    if "FLAG{" in resp.text:
        print(f"\n[!!!] FOUND FLAG with cookies: {cookies}!")
        print(resp.text)
        break

# Maybe I need to look at other files that were uploaded
# Let me enumerate more files in uploads directory with common patterns

print("\n[+] Checking for more files in uploads with numbers...")

for i in range(1, 20):
    for ext in ['php', 'txt']:
        resp = requests.get(f"{base_url}/posts/uploads/{i}.{ext}")
        
        if resp.status_code == 200 and len(resp.text) > 0:
            print(f"\n[+] Found: {i}.{ext}")
            print(f"Content (first 200 chars): {resp.text[:200]}")
            
            if "FLAG{" in resp.text:
                print(f"\n[!!!] FLAG FOUND in {i}.{ext}!")
                print(resp.text)
                break

# Check for flag.txt in uploads
print("\n[+] Checking for flag file variants...")
flag_variants = [
    "FLAG.txt", "flag.txt", "Flag.txt",
    "flag", "FLAG", "Flag"
]

for variant in flag_variants:
    resp = requests.get(f"{base_url}/posts/uploads/{variant}")
    
    if resp.status_code == 200 and len(resp.text) > 0:
        print(f"\n[+] Found: {variant}")
        print(f"Content: {resp.text}")
        
        if "FLAG{" in resp.text:
            print(f"\n[!!!] FLAG FOUND!")

