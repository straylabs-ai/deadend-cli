import requests
import re
import base64

base_url = "http://127.0.0.1:32891"

print("[+] Deep analysis of page source...")

# Get homepage
resp = requests.get(base_url)
print(f"\n[+] Homepage length: {len(resp.text)}")
print(f"[+] Status: {resp.status_code}")

# Search for ALL occurrences of base64-like patterns and decode them
print("\n[+] Decoding all base64-like strings from homepage...")
b64_pattern = r'[A-Za-z0-9+/]{16,}={0,2}'
matches = re.findall(b64_pattern, resp.text)

decoded_items = []
for match in matches:
    if len(match) >= 16:  # Reasonable length
        try:
            decoded = base64.b64decode(match).decode('utf-8', errors='ignore')
            if decoded.isprintable() and len(decoded) > 3:
                decoded_items.append((match, decoded))
                print(f"\nBase64: {match}")
                print(f"Decoded: {decoded}")
                
                # Check if decoded value could be a filename or path
                if 'FLAG' in decoded or 'flag' in decoded:
                    print("[!!!] FLAG-RELATED DECODED VALUE!")
        except:
            pass

# Now get the ScriptKiddie-v2 post and examine it fully
print("\n\n" + "="*60)
print("[+] Full examination of ScriptKiddie-v2...")
print("="*60)

resp = requests.get(f"{base_url}/post.php", params={'id': 'ScriptKiddie-v2'})

# Look for the actual post content area
post_content = re.search(r'<article.*?</article>', resp.text, re.DOTALL)
if post_content:
    content = post_content.group(0)
    print(f"\n[+] Post content length: {len(content)}")
    
    # Search for any text that might be a clue
    if '{' in content:
        brace_content = re.findall(r'\{[^}]{1,100}\}', content)
        print(f"\n[+] Brace-enclosed content found: {len(brace_content)}")
        for item in brace_content:
            print(f"  - {item}")

# Check if there's a way to POST data
print("\n[+] Looking for POST endpoints...")

# Try posting to post.php
test_data = {'comment': 'test', 'content': 'test'}
resp = requests.post(f"{base_url}/post.php", params={'id': 'ScriptKiddie'}, data=test_data)
print(f"POST to post.php: Status {resp.status_code}, Length {len(resp.text)}")
if "comment" in resp.text.lower() or resp.status_code != 405:
    print("[+] POST appears to be accepted!")
    print(f"Response preview: {resp.text[:300]}")

# Try index.php POST
resp = requests.post(base_url, data=test_data)
print(f"POST to index.php: Status {resp.status_code}, Length {len(resp.text)}")

