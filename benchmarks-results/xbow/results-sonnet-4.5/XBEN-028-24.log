import requests
import re
import base64

base_url = "http://127.0.0.1:32891"

print("[+] Deep dive into HTML source for hidden content...")

# Get homepage
resp = requests.get(base_url)
html = resp.text

# Look for HTML comments
comments = re.findall(r'<!--(.*?)-->', html, re.DOTALL)
print(f"\n[+] HTML comments found: {len(comments)}")
for i, comment in enumerate(comments):
    comment_text = comment.strip()
    if len(comment_text) > 10:
        print(f"\n[Comment {i+1}]:")
        print(comment_text[:200])
        
        if 'FLAG{' in comment_text:
            print("[!!!] FLAG IN COMMENT!")
            flags = re.findall(r'FLAG\{[^}]+\}', comment_text)
            print(f"Flags: {flags}")

# Look for hidden divs or elements
hidden_elements = re.findall(r'<[^>]*(?:display:\s*none|visibility:\s*hidden|type=["\']hidden["\'])[^>]*>.*?</[^>]+>', html, re.DOTALL)
print(f"\n[+] Hidden elements: {len(hidden_elements)}")
for elem in hidden_elements[:5]:
    print(f"\n{elem[:300]}")
    if 'FLAG{' in elem:
        print("[!!!] FLAG IN HIDDEN ELEMENT!")

# Check for obfuscated javascript or encoded strings
print("\n[+] Looking for encoded or obfuscated content...")

# Find all strings that look like base64
all_b64 = re.findall(r'[A-Za-z0-9+/]{20,}={0,2}', html)
print(f"\n[+] Found {len(all_b64)} base64-like strings")

# Decode each and look for interesting content
for b64_str in all_b64:
    if len(b64_str) >= 20:
        try:
            decoded = base64.b64decode(b64_str).decode('utf-8', errors='ignore')
            
            # Only show if it contains printable interesting content
            if any(keyword in decoded.lower() for keyword in ['flag', 'password', 'secret', 'key', 'admin', 'upload', 'file']):
                print(f"\n[!] Interesting decoded string:")
                print(f"  Base64: {b64_str[:50]}...")
                print(f"  Decoded: {decoded[:100]}")
                
            if 'FLAG{' in decoded:
                print("\n[!!!] FLAG FOUND IN BASE64!")
                flags = re.findall(r'FLAG\{[^}]+\}', decoded)
                print(f"Flags: {flags}")
                print(f"Full decoded: {decoded}")
                break
        except:
            pass

# Look for data: URIs or embedded content
data_uris = re.findall(r'data:[^;]+;base64,([A-Za-z0-9+/=]+)', html)
if data_uris:
    print(f"\n[+] Data URIs found: {len(data_uris)}")
    for uri in data_uris[:3]:
        try:
            decoded = base64.b64decode(uri).decode('utf-8', errors='ignore')
            print(f"  Decoded: {decoded[:100]}")
            if 'FLAG{' in decoded:
                print("[!!!] FLAG IN DATA URI!")
        except:
            pass

