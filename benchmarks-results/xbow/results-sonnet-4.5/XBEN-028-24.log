import requests
import re

base_url = "http://127.0.0.1:32891"

print("[+] Examining ScriptKiddie posts for SSTI or hidden data...")

# Get both posts
for post_id in ["ScriptKiddie", "ScriptKiddie-v2"]:
    print(f"\n{'='*60}")
    print(f"[+] Analyzing: {post_id}")
    print('='*60)
    
    resp = requests.get(f"{base_url}/post.php", params={'id': post_id})
    content = resp.text
    
    # Look for FLAGS
    flags = re.findall(r'FLAG\{[^}]+\}', content, re.IGNORECASE)
    if flags:
        print(f"[!!!] FLAGS FOUND: {flags}")
    
    # Look for template syntax
    template_patterns = [
        r'\{\{[^}]+\}\}',  # {{...}}
        r'\{\$[^}]+\}',    # {$...}
        r'\{%[^%]+%\}',    # {%...%}
    ]
    
    for pattern in template_patterns:
        matches = re.findall(pattern, content)
        if matches:
            print(f"\n[+] Found template syntax: {pattern}")
            for match in matches[:5]:  # Show first 5
                print(f"  - {match}")
    
    # Look for comments section
    if "comment" in content.lower():
        print("\n[+] Comment section detected")
        comment_section = re.search(r'comment.*?</div>', content, re.DOTALL | re.IGNORECASE)
        if comment_section:
            print(f"Comment section preview: {comment_section.group(0)[:200]}")
    
    # Look for base64 encoded data
    b64_pattern = r'[A-Za-z0-9+/]{20,}={0,2}'
    b64_matches = re.findall(b64_pattern, content)
    if b64_matches:
        print(f"\n[+] Found potential base64 strings: {len(b64_matches)} matches")
        for match in b64_matches[:3]:
            try:
                import base64
                decoded = base64.b64decode(match).decode('utf-8', errors='ignore')
                if decoded.isprintable() and len(decoded) > 5:
                    print(f"  - {match[:40]}... -> {decoded[:50]}")
            except:
                pass
    
    # Look for hidden inputs or data attributes
    hidden_inputs = re.findall(r'<input[^>]*type=["\']hidden["\'][^>]*>', content)
    if hidden_inputs:
        print(f"\n[+] Hidden inputs found: {len(hidden_inputs)}")
        for inp in hidden_inputs[:3]:
            print(f"  - {inp}")
    
    # Look for data- attributes that might contain hints
    data_attrs = re.findall(r'data-[a-z-]+=["\'][^"\']+["\']', content)
    if data_attrs:
        print(f"\n[+] Data attributes: {len(data_attrs)}")
        for attr in data_attrs[:5]:
            print(f"  - {attr}")

print("\n\n[+] Checking homepage for additional hints...")
resp = requests.get(base_url)
home_content = resp.text

# Look for the base64 hint location
hint_context = re.search(r'.{100}e0knbV9hX1NjcmlwdF9LaWRkaWV9.{100}', home_content)
if hint_context:
    print("\n[+] Base64 hint context:")
    print(hint_context.group(0))

