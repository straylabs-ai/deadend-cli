import requests

base_url = "http://127.0.0.1:32891"

print("[+] Let's examine the web application structure more carefully...")

# Check what other endpoints might exist
endpoints_to_check = [
    "/",
    "/index.php",
    "/posts/",
    "/posts/uploads/",
]

for endpoint in endpoints_to_check:
    resp = requests.get(f"{base_url}{endpoint}")
    print(f"\n{endpoint}:")
    print(f"Status: {resp.status_code}")
    print(f"Length: {len(resp.text)}")
    if "FLAG{" in resp.text:
        print(f"[!!!] FOUND FLAG at {endpoint}!")
        print(resp.text)
        break
    # Check for interesting content
    if "upload" in resp.text.lower() or "flag" in resp.text.lower():
        print(f"Interesting keywords found!")
        print(f"Preview: {resp.text[:500]}")

print("\n[+] Maybe finder.php has a different execution mode...")
print("[+] Checking if we can access finder.php with specific file extensions or modes...")

# Try accessing finder with different extensions or paths
finder_variations = [
    "/posts/uploads/finder.php",
    "/posts/uploads/finder.php?",  # Empty query
    "/posts/uploads/finder.php?file=FLAG.txt",
    "/posts/uploads/finder.php?f=FLAG.txt",
    "/posts/uploads/finder.php/FLAG.txt",  # Path info
]

for url in finder_variations:
    full_url = f"{base_url}{url}"
    resp = requests.get(full_url)
    print(f"\n{url}")
    print(f"Status: {resp.status_code} | Length: {len(resp.text)}")
    
    if "FLAG{" in resp.text:
        print(f"[!!!] FOUND FLAG!")
        print(resp.text)
        break
    elif len(resp.text) < 1000 or len(resp.text) > 1200:  # Different from normal 1108
        print(f"Different response size! Content:")
        print(resp.text[:500])

