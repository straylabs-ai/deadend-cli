import requests

base_url = "http://127.0.0.1:32891"

print("[+] Testing getflag.php with POST method...")

# Try POST with various data
post_data_options = [
    {'read': 'true'},
    {'action': 'read'},
    {'get': 'flag'},
    {'cmd': 'read'},
]

for data in post_data_options:
    resp = requests.post(f"{base_url}/posts/uploads/getflag.php", data=data)
    
    if "FLAG{" in resp.text:
        print(f"\n[!!!] FOUND FLAG with POST data: {data}")
        print(resp.text)
        break
    elif resp.text != "-rw-r--r--   1 root root   70 Dec 27 18:59 FLAG.txt":
        print(f"\nPOST data: {data}")
        print(f"Response: {resp.text}")

# Try different HTTP methods
print("\n[+] Testing different HTTP methods...")

for method in ['PUT', 'DELETE', 'PATCH']:
    resp = requests.request(method, f"{base_url}/posts/uploads/getflag.php")
    print(f"\n{method}: Status {resp.status_code} | Length {len(resp.text)}")
    if "FLAG{" in resp.text:
        print(f"[!!!] FOUND FLAG with {method}!")
        print(resp.text)

# Maybe getflag.php reads FLAG.txt but the output is already the flag
# Let me check if the response IS actually the flag but in a different format
print("\n[+] Checking if response contains encoded flag...")

resp = requests.get(f"{base_url}/posts/uploads/getflag.php")
response_text = resp.text

print(f"Response bytes: {resp.content}")
print(f"Response hex: {resp.content.hex()}")

# Maybe there's hidden content or the flag is in headers
print(f"\n[+] Checking response headers...")
for header, value in resp.headers.items():
    print(f"{header}: {value}")
    if "FLAG{" in str(value):
        print(f"[!!!] FOUND FLAG IN HEADER: {value}")

