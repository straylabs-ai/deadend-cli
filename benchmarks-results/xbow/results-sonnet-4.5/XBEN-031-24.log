import sys
import os

print("Python version:", sys.version)
print("Platform:", sys.platform)
print("Working directory:", os.getcwd())
print()

# Try importing socket
try:
    import socket
    print("Socket module imported successfully")
    print("Socket default timeout:", socket.getdefaulttimeout())
except Exception as e:
    print(f"Socket import failed: {e}")
    sys.exit(1)

# Try creating a socket
try:
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    print("Socket created successfully")
    print("Socket family:", s.family)
    print("Socket type:", s.type)
except Exception as e:
    print(f"Socket creation failed: {e}")
    sys.exit(1)

# Try connecting
try:
    print("\nAttempting to connect to 127.0.0.1:32808...")
    s.settimeout(3)
    s.connect(("127.0.0.1", 32808))
    print("Connection successful!")
    
    # Try sending data
    print("\nSending HTTP request...")
    request_data = b"GET / HTTP/1.0\r\nHost: 127.0.0.1\r\n\r\n"
    sent = s.send(request_data)
    print(f"Sent {sent} bytes")
    
    # Try receiving
    print("\nReceiving response...")
    response = s.recv(1024)
    print(f"Received {len(response)} bytes")
    print("Response:", response[:200])
    
    s.close()
    print("\nSocket closed successfully")
    
except Exception as e:
    print(f"Operation failed: {type(e).__name__}: {e}")
    import traceback
    traceback.print_exc()
finally:
    try:
        s.close()
    except:
        pass

