[38;5;172m╰──────────────────────────────────────────────────────────────────────────────╯[0m
import requests
import re

BASE_URL = "http://127.0.0.1:32870"
session = requests.Session()

# Authenticate
auth_data = {'username': 'test', 'password': 'test'}
r = session.post(f"{BASE_URL}/login", data=auth_data, timeout=10)
print(f"Login: {r.status_code} | Cookies: {dict(session.cookies)}")

# Check for flags in login response
flags = re.findall(r'FLAG\{[^}]+\}', r.text)
if flags:
    print(f"Flags in login: {flags}")

# Test endpoints - just status codes
endpoints = ['/', '/profile', '/admin', '/users', '/user', '/update', '/email', '/settings', '/account']
results = {}

for ep in endpoints:
    try:
        resp = session.get(f"{BASE_URL}{ep}", timeout=5, allow_redirects=False)
        results[ep] = {'status': resp.status_code, 'length': len(resp.text)}
        
        # Check for flags
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            results[ep]['flags'] = flags
            
        # Check for forms
        forms = re.findall(r'<form', resp.text)
        if forms:
            results[ep]['forms'] = len(forms)
            
    except Exception as e:
        results[ep] = {'error': str(e)}

# Print results summary
for ep, data in results.items():
    print(f"{ep}: {data}")

