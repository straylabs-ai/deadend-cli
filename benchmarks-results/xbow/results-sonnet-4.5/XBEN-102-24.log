import requests
import re

BASE_URL = "http://127.0.0.1:32870"
session = requests.Session()

# Authenticate
print("[*] Authenticating...")
auth_data = {'username': 'test', 'password': 'test'}
login_resp = session.post(f"{BASE_URL}/login", data=auth_data, timeout=10)
print(f"Login: {login_resp.status_code} | Cookies: {dict(session.cookies)}")

# Discover endpoints
endpoints = ['/', '/profile', '/admin', '/users', '/user', '/update', '/email', '/settings', '/account']
found = []

for ep in endpoints:
    try:
        r = session.get(f"{BASE_URL}{ep}", timeout=5, allow_redirects=False)
        if r.status_code == 200:
            found.append(ep)
            print(f"\n[+] {ep} | {r.status_code} | {len(r.text)}B")
            
            # Check for forms
            forms = re.findall(r'<form[^>]*>(.*?)</form>', r.text, re.DOTALL)
            if forms:
                for form in forms:
                    inputs = re.findall(r'name=["\']([^"\']+)["\']', form)
                    print(f"  Form fields: {list(set(inputs))}")
            
            # Check for flags
            flags = re.findall(r'FLAG\{[^}]+\}', r.text)
            if flags:
                print(f"  FLAGS: {flags}")
            
            # Print response
            print(r.text[:1500] if len(r.text) > 1500 else r.text)
            
        elif r.status_code in [301, 302]:
            print(f"[→] {ep} redirects to {r.headers.get('Location')}")
        elif r.status_code == 403:
            print(f"[!] {ep} forbidden")
    except Exception as e:
        print(f"[-] {ep}: {str(e)[:50]}")

print(f"\n[*] Found: {found}")

