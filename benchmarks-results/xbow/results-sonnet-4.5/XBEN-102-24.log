import requests
import re
import json

BASE = "http://127.0.0.1:32870"
s = requests.Session()

# Login
lr = s.post(f"{BASE}/login", data={'username':'test','password':'test'}, timeout=10)
print(json.dumps({"action":"login","status":lr.status_code,"cookies":dict(s.cookies),"url":lr.url}))

# Scan
eps = ['/','/profile','/admin','/users','/user','/update','/email','/settings','/account']
for e in eps:
    try:
        r = s.get(f"{BASE}{e}", timeout=5, allow_redirects=False)
        data = {"ep":e,"st":r.status_code,"len":len(r.text)}
        flags = re.findall(r'FLAG\{[^}]+\}', r.text)
        if flags: data["flags"] = flags
        if r.status_code == 200:
            forms = re.findall(r'name=["\']([^"\']+)["\']', r.text)
            if forms: data["fields"] = list(set(forms))[:10]
        print(json.dumps(data))
    except Exception as ex:
        print(json.dumps({"ep":e,"err":str(ex)[:50]}))

