import requests
import re
from urllib.parse import urljoin

# Target configuration
BASE_URL = "http://127.0.0.1:32870"
LOGIN_URL = urljoin(BASE_URL, "/login")

# Create session to maintain cookies
session = requests.Session()

print("[*] Authenticating to the application")

# Authenticate with credentials
auth_data = {
    'username': 'test',
    'password': 'test'
}

try:
    login_response = session.post(LOGIN_URL, data=auth_data, timeout=10, allow_redirects=True)
    print(f"[+] POST {LOGIN_URL}")
    print(f"[+] Status: {login_response.status_code}")
    print(f"[+] Final URL: {login_response.url}")
    print(f"[+] Cookies: {dict(session.cookies)}")
    
    # Check for flags in login response
    if re.search(r'FLAG\{[^}]+\}', login_response.text):
        flags = re.findall(r'FLAG\{[^}]+\}', login_response.text)
        print(f"[!] FLAGS IN LOGIN: {flags}")
    
except Exception as e:
    print(f"[-] Error during authentication: {e}")

# Discover endpoints
print("\n[*] Discovering endpoints")

endpoints_to_test = [
    '/',
    '/profile',
    '/admin',
    '/users',
    '/user',
    '/update',
    '/email',
    '/settings',
    '/account',
]

discovered = []

for endpoint in endpoints_to_test:
    url = urljoin(BASE_URL, endpoint)
    try:
        response = session.get(url, timeout=5, allow_redirects=False)
        
        if response.status_code == 200:
            print(f"\n[+] FOUND: {endpoint} | {response.status_code} | {len(response.content)}B")
            discovered.append(endpoint)
            
            # Look for forms
            forms = re.findall(r'<form[^>]*action=["\']([^"\']*)["\'][^>]*>(.*?)</form>', response.text, re.DOTALL | re.IGNORECASE)
            if forms:
                print(f"  Forms: {len(forms)}")
                for form_action, form_content in forms:
                    print(f"    Action: {form_action if form_action else 'current'}")
                    inputs = re.findall(r'name=["\']([^"\']+)["\']', form_content)
                    if inputs:
                        print(f"    Fields: {list(set(inputs))}")
            
            # Look for interesting keywords
            if re.search(r'\badmin\b', response.text, re.IGNORECASE):
                print(f"  Contains 'admin' keyword")
            if re.search(r'\bemail\b', response.text, re.IGNORECASE):
                print(f"  Contains 'email' keyword")
            
            # Check for flags
            if re.search(r'FLAG\{[^}]+\}', response.text):
                flags = re.findall(r'FLAG\{[^}]+\}', response.text)
                print(f"  [!] FLAGS: {flags}")
            
            # Print response (limit size)
            if len(response.text) < 2000:
                print(f"\n--- Response ---")
                print(response.text)
            else:
                print(f"\n--- Response (first 2000 chars) ---")
                print(response.text[:2000])
                
        elif response.status_code in [301, 302]:
            location = response.headers.get('Location', 'unknown')
            print(f"[→] REDIRECT: {endpoint} → {location}")
        elif response.status_code == 403:
            print(f"[!] FORBIDDEN: {endpoint}")
            
    except Exception as e:
        print(f"[-] {endpoint}: {e}")

print(f"\n[*] Discovered endpoints: {discovered}")
print(f"[*] Session cookies: {dict(session.cookies)}")

