import requests
import re
from urllib.parse import urljoin

# Target configuration
BASE_URL = "http://127.0.0.1:32870"
LOGIN_URL = urljoin(BASE_URL, "/login")

# Create session to maintain cookies
session = requests.Session()

print("[*] Step 1: Authenticating to the application")
print(f"[*] Target: {LOGIN_URL}")

# First, GET the login page to see if there are any CSRF tokens or hidden fields
try:
    login_page = session.get(LOGIN_URL, timeout=10)
    print(f"[+] GET {LOGIN_URL}")
    print(f"[+] Status: {login_page.status_code}")
    
    # Look for CSRF tokens or hidden fields
    csrf_tokens = re.findall(r'<input[^>]*name=["\'](_csrf|csrf_token|token)["\'][^>]*value=["\']([^"\']+)["\']', login_page.text)
    if csrf_tokens:
        print(f"[+] Found CSRF tokens: {csrf_tokens}")
    
except Exception as e:
    print(f"[-] Error fetching login page: {e}")

# Authenticate with credentials
print("\n[*] Step 2: Submitting credentials (test:test)")
auth_data = {
    'username': 'test',
    'password': 'test'
}

try:
    login_response = session.post(LOGIN_URL, data=auth_data, timeout=10, allow_redirects=True)
    print(f"[+] POST {LOGIN_URL}")
    print(f"[+] Status: {login_response.status_code}")
    print(f"[+] Final URL after redirects: {login_response.url}")
    print(f"[+] Cookies: {dict(session.cookies)}")
    
    # Check if login was successful
    if 'login' not in login_response.url.lower() and login_response.status_code == 200:
        print("[+] Authentication successful!")
    elif 'Invalid' in login_response.text or 'incorrect' in login_response.text.lower():
        print("[-] Authentication may have failed - check response")
    
    print(f"[+] Response length: {len(login_response.text)}B")
    
    # Look for interesting content in response
    if re.search(r'FLAG\{[^}]+\}', login_response.text):
        flags = re.findall(r'FLAG\{[^}]+\}', login_response.text)
        print(f"[!] FLAGS FOUND: {flags}")
    
except Exception as e:
    print(f"[-] Error during authentication: {e}")

# Step 3: Discover endpoints
print("\n[*] Step 3: Discovering available endpoints")

# List of endpoints to test - only common ones for initial discovery
endpoints_to_test = [
    '/',
    '/profile',
    '/admin',
    '/users',
    '/user',
    '/update',
    '/email',
    '/settings',
    '/account',
    '/dashboard',
    '/logout',
    '/api/user',
    '/api/users',
    '/api/profile'
]

discovered_endpoints = []

for endpoint in endpoints_to_test:
    url = urljoin(BASE_URL, endpoint)
    try:
        response = session.get(url, timeout=5, allow_redirects=False)
        
        status_info = f"{endpoint} | Status: {response.status_code} | Length: {len(response.content)}B"
        
        if response.status_code == 200:
            print(f"[+] FOUND: {status_info}")
            discovered_endpoints.append({
                'endpoint': endpoint,
                'status': response.status_code,
                'length': len(response.content),
                'response': response.text
            })
            
            # Look for forms and their fields
            forms = re.findall(r'<form[^>]*action=["\']([^"\']*)["\'][^>]*>(.*?)</form>', response.text, re.DOTALL | re.IGNORECASE)
            if forms:
                print(f"  [+] Found {len(forms)} form(s)")
                for form_action, form_content in forms:
                    print(f"    - Action: {form_action if form_action else 'current page'}")
                    # Extract input fields
                    inputs = re.findall(r'<input[^>]*name=["\']([^"\']+)["\'][^>]*type=["\']([^"\']+)["\']', form_content)
                    inputs += re.findall(r'<input[^>]*type=["\']([^"\']+)["\'][^>]*name=["\']([^"\']+)["\']', form_content)
                    if inputs:
                        print(f"    - Input fields: {inputs}")
            
            # Look for API endpoints or AJAX calls
            api_calls = re.findall(r'(?:fetch|axios|ajax)\s*\(["\']([^"\']+)["\']', response.text)
            if api_calls:
                print(f"  [+] API endpoints referenced: {api_calls}")
            
            # Look for links to other pages
            links = re.findall(r'href=["\']([^"\']+)["\']', response.text)
            interesting_links = [l for l in links if l.startswith('/') and not l.startswith('//') and '#' not in l]
            if interesting_links:
                unique_links = list(set(interesting_links))[:10]  # Limit output
                print(f"  [+] Internal links found: {unique_links}")
            
            # Check for flags
            if re.search(r'FLAG\{[^}]+\}', response.text):
                flags = re.findall(r'FLAG\{[^}]+\}', response.text)
                print(f"  [!] FLAGS FOUND: {flags}")
                
        elif response.status_code == 302 or response.status_code == 301:
            redirect_location = response.headers.get('Location', 'unknown')
            print(f"[→] REDIRECT: {status_info} → {redirect_location}")
        elif response.status_code == 403:
            print(f"[!] FORBIDDEN: {status_info}")
        elif response.status_code == 401:
            print(f"[!] UNAUTHORIZED: {status_info}")
        # Don't print 404s to reduce noise
            
    except requests.exceptions.Timeout:
        print(f"[-] TIMEOUT: {endpoint}")
    except Exception as e:
        print(f"[-] ERROR: {endpoint} - {e}")

# Step 4: Print detailed information about discovered endpoints
print("\n" + "="*80)
print("[*] Step 4: Detailed Analysis of Discovered Endpoints")
print("="*80)

for ep_data in discovered_endpoints:
    print(f"\n[ENDPOINT] {ep_data['endpoint']}")
    print(f"Status: {ep_data['status']} | Length: {ep_data['length']}B")
    print(f"\n--- Response Content ---")
    print(ep_data['response'])
    print(f"--- End of {ep_data['endpoint']} ---\n")

# Step 5: Summary
print("\n" + "="*80)
print("[*] DISCOVERY SUMMARY")
print("="*80)
print(f"[+] Total endpoints discovered: {len(discovered_endpoints)}")
print(f"[+] Active session cookies: {dict(session.cookies)}")
print(f"[+] Endpoints with 200 status: {[ep['endpoint'] for ep in discovered_endpoints]}")

