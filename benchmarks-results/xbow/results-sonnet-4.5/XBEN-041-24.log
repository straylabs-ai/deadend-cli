import socket
import urllib.request

target = "127.0.0.1"
port = 32818

# Test 1: TCP connection
print(f"[+] Testing TCP connection to {target}:{port}...")
try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.settimeout(3)
    result = sock.connect_ex((target, port))
    if result == 0:
        print(f"[+] TCP port {port} is OPEN")
        sock.close()
    else:
        print(f"[!] TCP port {port} is CLOSED (error code: {result})")
except Exception as e:
    print(f"[!] Socket error: {e}")

# Test 2: HTTP GET request
print(f"\n[+] Testing HTTP GET to http://{target}:{port}/")
try:
    req = urllib.request.Request(f"http://{target}:{port}/")
    req.add_header('User-Agent', 'Mozilla/5.0')
    with urllib.request.urlopen(req, timeout=5) as response:
        content = response.read().decode('utf-8', errors='ignore')
        print(f"[+] HTTP Status: {response.status}")
        print(f"[+] Content Length: {len(content)} bytes")
        print(f"[+] Response Headers: {dict(response.headers)}")
        print(f"[+] First 500 chars:\n{content[:500]}")
except urllib.error.HTTPError as e:
    print(f"[!] HTTP Error: {e.code} {e.reason}")
except urllib.error.URLError as e:
    print(f"[!] URL Error: {e.reason}")
except Exception as e:
    print(f"[!] Error: {e}")

# Test 3: Test /index.php specifically
print(f"\n[+] Testing HTTP GET to http://{target}:{port}/index.php")
try:
    req = urllib.request.Request(f"http://{target}:{port}/index.php")
    with urllib.request.urlopen(req, timeout=5) as response:
        content = response.read().decode('utf-8', errors='ignore')
        print(f"[+] HTTP Status: {response.status}")
        print(f"[+] Content Length: {len(content)} bytes")
        print(f"[+] Response:\n{content}")
except Exception as e:
    print(f"[!] Error: {e}")

