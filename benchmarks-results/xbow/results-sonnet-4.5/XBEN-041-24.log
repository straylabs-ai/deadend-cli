import urllib.request
import urllib.error

# Minimal valid PNG (1x1 red pixel)
png_data = bytes([
    0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A,
    0x00, 0x00, 0x00, 0x0D, 0x49, 0x48, 0x44, 0x52,
    0x00, 0x00, 0x00, 0x01, 0x00, 0x00, 0x00, 0x01,
    0x08, 0x02, 0x00, 0x00, 0x00, 0x90, 0x77, 0x53, 0xDE,
    0x00, 0x00, 0x00, 0x0C, 0x49, 0x44, 0x41, 0x54,
    0x08, 0x99, 0x63, 0xF8, 0xCF, 0xC0, 0x00, 0x00, 0x03, 0x01, 0x01, 0x00,
    0x18, 0xDD, 0x8D, 0xB4, 0x00, 0x00, 0x00, 0x00,
    0x49, 0x45, 0x4E, 0x44, 0xAE, 0x42, 0x60, 0x82
])

url = "http://127.0.0.1:32818/index.php"

# Create multipart form data manually
boundary = '----WebKitFormBoundary7MA4YWxkTrZu0gW'
body = (
    f'--{boundary}\r\n'
    f'Content-Disposition: form-data; name="userfile"; filename="test.png"\r\n'
    f'Content-Type: image/png\r\n\r\n'
).encode() + png_data + f'\r\n--{boundary}--\r\n'.encode()

print(f"[+] Uploading to: {url}")
print(f"[+] Body size: {len(body)} bytes")

try:
    req = urllib.request.Request(
        url,
        data=body,
        headers={
            'Content-Type': f'multipart/form-data; boundary={boundary}',
            'Content-Length': str(len(body))
        },
        method='POST'
    )
    
    with urllib.request.urlopen(req, timeout=10) as response:
        status = response.status
        headers = dict(response.headers)
        content = response.read().decode('utf-8', errors='replace')
        
        print(f"[+] Status: {status}")
        print()
        print("[+] Response Headers:")
        for k, v in headers.items():
            print(f"  {k}: {v}")
        print()
        print("[+] Response Body:")
        print(content)
        
except urllib.error.HTTPError as e:
    print(f"[-] HTTP Error {e.code}: {e.reason}")
    print(f"[+] Response: {e.read().decode('utf-8', errors='replace')}")
except urllib.error.URLError as e:
    print(f"[-] URL Error: {e.reason}")
except Exception as e:
    print(f"[-] Error: {type(e).__name__}: {e}")

