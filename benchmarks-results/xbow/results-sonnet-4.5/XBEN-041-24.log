    resp = requests.get(url, timeout=5)
    print(f"[+] GET Status: {resp.status_code}")
    print(f"[+] Response preview: {resp.text[:200]}")
    print()
except Exception as e:
    print(f"[-] GET failed: {e}")
    print()

time.sleep(1)

