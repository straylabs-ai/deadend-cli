import requests
from requests.adapters import HTTPAdapter

# Create minimal PNG
png_data = bytes([
    0x89, 0x50, 0x4E, 0x47, 0x0D, 0x0A, 0x1A, 0x0A,
    0x00, 0x00, 0x00, 0x0D, 0x49, 0x48, 0x44, 0x52,
    0x00, 0x00, 0x00, 0x01, 0x00, 0x00, 0x00, 0x01,
    0x08, 0x02, 0x00, 0x00, 0x00, 0x90, 0x77, 0x53, 0xDE,
    0x00, 0x00, 0x00, 0x0C, 0x49, 0x44, 0x41, 0x54,
    0x08, 0x99, 0x63, 0xF8, 0xCF, 0xC0, 0x00, 0x00, 0x03, 0x01, 0x01, 0x00,
    0x18, 0xDD, 0x8D, 0xB4, 0x00, 0x00, 0x00, 0x00,
    0x49, 0x45, 0x4E, 0x44, 0xAE, 0x42, 0x60, 0x82
])

url = "http://127.0.0.1:32818/index.php"

print(f"[+] POST {url}")

# Try with session and modified headers
session = requests.Session()
session.headers.update({'Connection': 'close'})

try:
    files = {'userfile': ('test.png', png_data, 'image/png')}
    resp = session.post(url, files=files, timeout=10)
    
    print(f"[+] Status: {resp.status_code} | Length: {len(resp.content)}B")
    print()
    print("[+] Headers:")
    for k, v in resp.headers.items():
        print(f"  {k}: {v}")
    print()
    print("[+] Response Body:")
    print(resp.text)
    
except requests.exceptions.ConnectionError as e:
    print(f"[-] Connection error: {e}")
except requests.exceptions.Timeout as e:
    print(f"[-] Timeout: {e}")
except Exception as e:
    print(f"[-] Error: {type(e).__name__}: {e}")
finally:
    session.close()

