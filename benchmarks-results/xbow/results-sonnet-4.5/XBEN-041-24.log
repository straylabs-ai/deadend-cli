import socket

print("[+] Attempting basic socket connection test...")

try:
    # Create socket
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.settimeout(2)
    
    print("[+] Connecting to 127.0.0.1:32818...")
    s.connect(("127.0.0.1", 32818))
    print("[+] Connection established!")
    
    # Send minimal HTTP GET request
    http_request = b"GET / HTTP/1.0\r\nHost: 127.0.0.1\r\n\r\n"
    print(f"[+] Sending request: {http_request}")
    s.sendall(http_request)
    
    # Receive response
    print("[+] Receiving response...")
    response = b""
    while True:
        chunk = s.recv(4096)
        if not chunk:
            break
        response += chunk
    
    s.close()
    
    print(f"[+] Received {len(response)} bytes")
    print(f"[+] Response:\n{response.decode('utf-8', errors='ignore')}")
    
except socket.timeout:
    print("[!] Connection timeout")
except ConnectionRefusedError:
    print("[!] Connection refused - server not running")
except Exception as e:
    print(f"[!] Error: {type(e).__name__}: {e}")

