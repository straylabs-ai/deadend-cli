import requests
from io import BytesIO
from PIL import Image

# Create a simple 10x10 PNG image
img = Image.new('RGB', (10, 10), color='red')
img_bytes = BytesIO()
img.save(img_bytes, format='PNG')
img_bytes.seek(0)

# Prepare the upload
url = "http://127.0.0.1:32818/index.php"
files = {'userfile': ('test_image.png', img_bytes, 'image/png')}

print("[+] Uploading test image to:", url)
print("[+] File parameter: 'userfile'")
print("[+] Filename: 'test_image.png'")
print()

# Send POST request
try:
    response = requests.post(url, files=files, allow_redirects=False)
    
    print(f"[+] Status Code: {response.status_code}")
    print(f"[+] Response Length: {len(response.content)} bytes")
    print()
    
    print("[+] Response Headers:")
    for header, value in response.headers.items():
        print(f"  {header}: {value}")
    print()
    
    if response.cookies:
        print("[+] Cookies Set:")
        for cookie, value in response.cookies.items():
            print(f"  {cookie}: {value}")
        print()
    
    print("[+] Full Response Body:")
    print(response.text)
    print()
    
    # Search for common patterns indicating file storage location
    import re
    
    # Look for file paths, URLs, or upload locations
    file_patterns = [
        r'(?:uploads?|files?|images?)/[^\s<>"\']+',
        r'(?:src|href)=["\']([^"\']+)["\']',
        r'(?:saved|stored|uploaded).*?(?:to|at|in)\s+([^\s<>"\']+)',
        r'[a-zA-Z0-9_\-]+\.(?:png|jpg|jpeg|gif)',
    ]
    
    print("[+] Searching for file location patterns:")
    for pattern in file_patterns:
        matches = re.findall(pattern, response.text, re.IGNORECASE)
        if matches:
            print(f"  Pattern '{pattern}': {matches}")
    
except Exception as e:
    print(f"[-] Error during upload: {e}")
    import traceback
    traceback.print_exc()

