import requests
import re

url = "http://127.0.0.1:32848/index.php"
headers = {'Content-Type': 'application/x-www-form-urlencoded'}
data = 'username=admin&password=sup3rsecr3t&login=Login'

response = requests.post(url, data=data, headers=headers)

# Write response to file
with open('/tmp/response.txt', 'w') as f:
    f.write(response.text)

print(f"Status: {response.status_code}")
print(f"Response saved to /tmp/response.txt ({len(response.text)} bytes)")

# Search for flags
flags = re.findall(r'FLAG\{[^}]+\}', response.text)

if flags:
    print("\nFLAGS FOUND:")
    for flag in flags:
        print(flag)
else:
    print("\nNo FLAG{} pattern found")
    
    # Show a small sample
    sample_size = min(200, len(response.text))
    print(f"\nFirst {sample_size} chars:")
    print(response.text[:sample_size])

