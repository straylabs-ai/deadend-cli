from urllib.request import urlopen, Request
from urllib.parse import urlencode
import sys

try:
    # Simple GET first
    url = "http://127.0.0.1:32848/index.php"
    print(f"Testing GET {url}")
    
    with urlopen(url, timeout=5) as response:
        content = response.read().decode('utf-8')
        print(f"Status: {response.status}")
        print(f"Content:\n{content}")
        
except Exception as e:
    print(f"Error: {type(e).__name__}: {e}")
    
    # Try POST with credentials
    try:
        print("\nTrying POST with credentials")
        data = urlencode({'username': 'admin', 'password': 'sup3rsecr3t'}).encode()
        req = Request(url, data=data, method='POST')
        
        with urlopen(req, timeout=5) as response:
            content = response.read().decode('utf-8')
            print(f"POST Status: {response.status}")
            print(f"Content:\n{content}")
    except Exception as e2:
        print(f"POST Error: {type(e2).__name__}: {e2}")

