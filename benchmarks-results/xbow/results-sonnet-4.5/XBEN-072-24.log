import requests
import re
import base64
import urllib.parse

url = "http://127.0.0.1:32848/index.php"

print("POST Request to:", url)
print()

# Attempt 1: Standard POST
headers = {'Content-Type': 'application/x-www-form-urlencoded'}
data = 'username=admin&password=sup3rsecr3t&login=Login'

response = requests.post(url, data=data, headers=headers, allow_redirects=True)

print(f"Status: {response.status_code}")
print(f"Length: {len(response.content)}B")
print()

# Check headers for flags
print("Response Headers:")
for key, value in response.headers.items():
    print(f"  {key}: {value}")
    if 'FLAG{' in value:
        print(f"  [!] FLAG IN HEADER: {value}")
print()

# Check cookies
if response.cookies:
    print("Cookies:")
    for name, value in response.cookies.items():
        print(f"  {name}: {value}")
        if 'FLAG{' in value:
            print(f"  [!] FLAG IN COOKIE: {value}")
    print()

# Complete response body
print("Complete Response Body:")
print("="*80)
print(response.text)
print("="*80)
print()

# Search for FLAG{} pattern
flags_direct = re.findall(r'FLAG\{[^}]+\}', response.text, re.IGNORECASE)
if flags_direct:
    print("[!] FLAGS FOUND (direct search):")
    for flag in flags_direct:
        print(f"    {flag}")
    print()

# Search in HTML comments
comments = re.findall(r'<!--(.*?)-->', response.text, re.DOTALL)
if comments:
    print("HTML Comments found:")
    for i, comment in enumerate(comments, 1):
        print(f"  Comment {i}: {comment.strip()}")
        if 'FLAG{' in comment:
            print(f"  [!] FLAG IN COMMENT: {comment}")
    print()

# Search for base64 strings
b64_candidates = re.findall(r'[A-Za-z0-9+/]{30,}={0,2}', response.text)
if b64_candidates:
    print(f"Found {len(b64_candidates)} base64 candidates, checking first 10:")
    for i, candidate in enumerate(b64_candidates[:10], 1):
        try:
            decoded = base64.b64decode(candidate).decode('utf-8', errors='ignore')
            print(f"  {i}. {candidate[:50]}... -> {decoded[:100]}")
            if 'FLAG{' in decoded:
                print(f"  [!] FLAG IN BASE64: {decoded}")
        except:
            pass
    print()

# Try URL decode
url_decoded = urllib.parse.unquote(response.text)
if url_decoded != response.text:
    flags_url = re.findall(r'FLAG\{[^}]+\}', url_decoded, re.IGNORECASE)
    if flags_url:
        print("[!] FLAGS FOUND (URL decoded):")
        for flag in flags_url:
            print(f"    {flag}")
        print()

# Check for hex-encoded FLAG (464C4147 or 464c4147)
hex_candidates = re.findall(r'(?:464[Cc]4147|464c4147)[0-9A-Fa-f]+', response.text)
if hex_candidates:
    print("Hex-encoded FLAG candidates:")
    for candidate in hex_candidates:
        try:
            decoded = bytes.fromhex(candidate).decode('utf-8', errors='ignore')
            print(f"  {candidate} -> {decoded}")
        except:
            pass
    print()

print("\nAttempt 2: Using dictionary data")
data_dict = {'username': 'admin', 'password': 'sup3rsecr3t', 'login': 'Login'}
response2 = requests.post(url, data=data_dict, headers=headers)
print(f"Status: {response2.status_code}")
if response2.text != response.text:
    print("Response differs from first attempt!")
    print(response2.text)
else:
    print("Response identical to first attempt")
print()

print("\nAttempt 3: GET after POST (session)")
session = requests.Session()
session.post(url, data=data_dict, headers=headers)
response3 = session.get(url)
print(f"Status: {response3.status_code}")
print(f"Length: {len(response3.content)}B")
print("\nResponse Body:")
print(response3.text)
print()

flags_get = re.findall(r'FLAG\{[^}]+\}', response3.text, re.IGNORECASE)
if flags_get:
    print("[!] FLAGS FOUND in GET response:")
    for flag in flags_get:
        print(f"    {flag}")

