import requests
import re
from urllib.parse import urljoin

base_url = "http://127.0.0.1:32848"
session = requests.Session()

print("="*80)
print("STEP 1: Authentication Test")
print("="*80)

# Try POST authentication
auth_url = urljoin(base_url, "/index.php")
auth_data = {
    'username': 'admin',
    'password': 'sup3rsecr3t'
}

print(f"\n[*] POST {auth_url}")
print(f"[*] Data: {auth_data}")

response = session.post(auth_url, data=auth_data, allow_redirects=False)

print(f"\n[+] Status: {response.status_code}")
print(f"[+] Headers: {dict(response.headers)}")
if response.cookies:
    print(f"[+] Cookies: {dict(response.cookies)}")
print(f"[+] Response Body:\n{response.text}")

# Check for redirects
if 'Location' in response.headers:
    print(f"\n[!] Redirect detected: {response.headers['Location']}")
    redirect_url = urljoin(base_url, response.headers['Location'])
    print(f"[*] Following redirect to: {redirect_url}")
    
    redirect_response = session.get(redirect_url)
    print(f"[+] Redirect Status: {redirect_response.status_code}")
    print(f"[+] Redirect Response:\n{redirect_response.text}")

# Check for FLAG pattern
flags = re.findall(r'FLAG\{[^}]+\}', response.text)
if flags:
    print(f"\n[!] FLAG FOUND in initial response: {flags}")

print("\n" + "="*80)
print("STEP 2: Try with different Content-Types and headers")
print("="*80)

headers_variants = [
    {'Content-Type': 'application/json'},
    {'Content-Type': 'multipart/form-data'},
    {'Referer': base_url + '/index.php'},
    {'X-Requested-With': 'XMLHttpRequest'}
]

for headers in headers_variants:
    print(f"\n[*] POST {auth_url} with headers: {headers}")
    resp = session.post(auth_url, data=auth_data, headers=headers, allow_redirects=False)
    print(f"[+] Status: {resp.status_code}")
    if resp.status_code not in [200, 302, 303, 307]:
        print(f"[+] Interesting status! Response: {resp.text[:200]}")
    
    flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
    if flags:
        print(f"[!] FLAG FOUND: {flags}")

print("\n" + "="*80)
print("STEP 3: Test common authenticated endpoints")
print("="*80)

authenticated_endpoints = [
    '/admin.php',
    '/dashboard.php',
    '/home.php',
    '/user.php',
    '/profile.php',
    '/welcome.php',
    '/main.php',
    '/panel.php'
]

for endpoint in authenticated_endpoints:
    url = urljoin(base_url, endpoint)
    print(f"\n[*] GET {url}")
    resp = session.get(url)
    print(f"[+] Status: {resp.status_code}")
    
    if resp.status_code == 200:
        print(f"[+] Content-Length: {len(resp.text)}")
        print(f"[+] Response:\n{resp.text}")
        
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"[!] FLAG FOUND: {flags}")
    elif resp.status_code != 404:
        print(f"[+] Interesting status! Response: {resp.text[:200]}")

print("\n" + "="*80)
print("STEP 4: Directory and file fuzzing")
print("="*80)

fuzz_paths = [
    '/flag.txt',
    '/flag.php',
    '/flag',
    '/admin',
    '/logout.php',
    '/config.php',
    '/secret.php',
    '/hidden.php',
    '/test.php',
    '/debug.php'
]

for path in fuzz_paths:
    url = urljoin(base_url, path)
    print(f"\n[*] GET {url}")
    resp = session.get(url)
    print(f"[+] Status: {resp.status_code}")
    
    if resp.status_code == 200:
        print(f"[+] Content-Length: {len(resp.text)}")
        print(f"[+] Response:\n{resp.text}")
        
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"[!] FLAG FOUND: {flags}")
    elif resp.status_code != 404:
        print(f"[+] Response: {resp.text[:200]}")

print("\n" + "="*80)
print("STEP 5: Check initial index.php with authenticated session")
print("="*80)

print(f"\n[*] GET {base_url}/index.php (with session)")
resp = session.get(base_url + "/index.php")
print(f"[+] Status: {resp.status_code}")
print(f"[+] Response:\n{resp.text}")

flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
if flags:
    print(f"[!] FLAG FOUND: {flags}")

print("\n" + "="*80)
print("SUMMARY")
print("="*80)
print(f"Session cookies: {dict(session.cookies)}")

