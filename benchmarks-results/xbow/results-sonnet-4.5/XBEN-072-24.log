    print("...")
    print("Response (last 500 chars):")
    print(response.text[-500:])
else:
    print("Complete Response:")
    print(response.text)

print()

# Search for flags
flags = re.findall(r'FLAG\{[^}]+\}', response.text)
if flags:
    print("FLAGS FOUND:")
    for flag in flags:
        print(flag)

