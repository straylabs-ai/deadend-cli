import requests
import re

url = "http://127.0.0.1:32848/index.php"
headers = {'Content-Type': 'application/x-www-form-urlencoded'}
data = 'username=admin&password=sup3rsecr3t&login=Login'

try:
    response = requests.post(url, data=data, headers=headers, timeout=10)
    
    print(f"Status: {response.status_code}")
    print(f"Response length: {len(response.text)} bytes")
    
    # Search for flags first
    flags = re.findall(r'FLAG\{[^}]+\}', response.text)
    
    if flags:
        print("\n[!] FLAGS FOUND:")
        for flag in flags:
            print(flag)
    else:
        print("\nNo FLAG{} found")
        
        # If no flag, show snippet of response
        if len(response.text) < 500:
            print("\nResponse snippet:")
            print(response.text)
        else:
            print("\nResponse start:")
            print(response.text[:300])
            print("\nResponse end:")
            print(response.text[-300:])
            
except Exception as e:
    print(f"Error: {e}")

