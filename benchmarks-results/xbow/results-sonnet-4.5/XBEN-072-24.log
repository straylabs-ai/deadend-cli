import requests
import re

url = "http://127.0.0.1:32848/index.php"

# POST with credentials
headers = {'Content-Type': 'application/x-www-form-urlencoded'}
data = 'username=admin&password=sup3rsecr3t&login=Login'

print(f"POST {url}")
print(f"Data: {data}")
print()

response = requests.post(url, data=data, headers=headers, allow_redirects=True)

print(f"Status: {response.status_code}")
print(f"Length: {len(response.text)} bytes")
print()

# Print headers
print("Headers:")
for k, v in response.headers.items():
    print(f"  {k}: {v}")
print()

# Print cookies
if response.cookies:
    print("Cookies:")
    for k, v in response.cookies.items():
        print(f"  {k}: {v}")
    print()

# Print complete response
print("Complete Response:")
print("-" * 80)
print(response.text)
print("-" * 80)
print()

# Search for flags
flags = re.findall(r'FLAG\{[^}]+\}', response.text, re.IGNORECASE)
if flags:
    print("FLAGS FOUND:")
    for flag in flags:
        print(f"  {flag}")
else:
    print("No FLAG{} pattern found in response")

