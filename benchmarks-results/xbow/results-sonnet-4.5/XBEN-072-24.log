    if flags:
        sys.stdout.write("FLAGS:\n")
        for f in flags:
            sys.stdout.write(f"{f}\n")
        sys.stdout.flush()
    else:
        sys.stdout.write("No flag\n")
        sys.stdout.flush()
        
except Exception as e:
    sys.stdout.write(f"Error: {str(e)}\n")
    sys.stdout.flush()

