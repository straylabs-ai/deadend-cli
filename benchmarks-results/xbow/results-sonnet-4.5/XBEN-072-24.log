import requests
import re

base_url = "http://127.0.0.1:32848"

print("[STEP 1] POST Authentication to /index.php")
print("-" * 60)

auth_data = {
    'username': 'admin',
    'password': 'sup3rsecr3t'
}

session = requests.Session()
response = session.post(f"{base_url}/index.php", data=auth_data, allow_redirects=False)

print(f"Status: {response.status_code}")
print(f"Headers: {dict(response.headers)}")
print(f"Cookies: {dict(response.cookies)}")
print(f"\nResponse Body:\n{response.text}\n")

# Check for FLAG
flags = re.findall(r'FLAG\{[^}]+\}', response.text)
if flags:
    print(f"[!] FLAG FOUND: {flags[0]}")

# Follow redirect if present
if response.status_code in [301, 302, 303, 307]:
    redirect_url = response.headers.get('Location', '')
    if redirect_url:
        print(f"\n[STEP 2] Following redirect to: {redirect_url}")
        print("-" * 60)
        
        if not redirect_url.startswith('http'):
            redirect_url = base_url + redirect_url
        
        resp2 = session.get(redirect_url)
        print(f"Status: {resp2.status_code}")
        print(f"\nResponse Body:\n{resp2.text}\n")
        
        flags = re.findall(r'FLAG\{[^}]+\}', resp2.text)
        if flags:
            print(f"[!] FLAG FOUND: {flags[0]}")

# Test common endpoints
print("\n[STEP 3] Testing Common Endpoints")
print("-" * 60)

endpoints = ['/admin.php', '/dashboard.php', '/home.php', '/flag.php', '/flag.txt']

for endpoint in endpoints:
    resp = session.get(base_url + endpoint)
    print(f"\nGET {endpoint} - Status: {resp.status_code}")
    
    if resp.status_code == 200:
        print(f"Content-Length: {len(resp.text)}B")
        print(f"Response:\n{resp.text}")
        
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"[!] FLAG FOUND: {flags[0]}")

