import requests
import re
import base64
import urllib.parse
from html.parser import HTMLParser

class CommentParser(HTMLParser):
    def __init__(self):
        super().__init__()
        self.comments = []
    
    def handle_comment(self, data):
        self.comments.append(data)

def search_for_flags(text, source_description):
    """Search for FLAG{} patterns in text"""
    flags = re.findall(r'FLAG\{[^}]+\}', text, re.IGNORECASE)
    if flags:
        print(f"\n[!] FLAG FOUND in {source_description}:")
        for flag in flags:
            print(f"    {flag}")
        return flags
    return []

def try_decode_and_search(text, description):
    """Try various decoding techniques and search for flags"""
    found_flags = []
    
    # Direct search
    flags = search_for_flags(text, f"{description} - direct")
    found_flags.extend(flags)
    
    # Search in HTML comments
    parser = CommentParser()
    try:
        parser.feed(text)
        for comment in parser.comments:
            flags = search_for_flags(comment, f"{description} - HTML comment")
            found_flags.extend(flags)
    except:
        pass
    
    # Try base64 decode on base64-looking strings
    b64_patterns = re.findall(r'[A-Za-z0-9+/]{20,}={0,2}', text)
    for pattern in b64_patterns[:50]:  # Limit to first 50 to avoid too much output
        try:
            decoded = base64.b64decode(pattern).decode('utf-8', errors='ignore')
            flags = search_for_flags(decoded, f"{description} - base64 decoded")
            found_flags.extend(flags)
        except:
            pass
    
    # Try URL decode
    try:
        url_decoded = urllib.parse.unquote(text)
        if url_decoded != text:
            flags = search_for_flags(url_decoded, f"{description} - URL decoded")
            found_flags.extend(flags)
    except:
        pass
    
    # Search in JavaScript strings
    js_strings = re.findall(r'["\']([^"\']{10,})["\']', text)
    for js_str in js_strings:
        flags = search_for_flags(js_str, f"{description} - JavaScript string")
        found_flags.extend(flags)
    
    # Look for hex-encoded flags (FLAG = 464C4147)
    hex_patterns = re.findall(r'(?:464[Cc]4147|464c4147)[0-9A-Fa-f]+', text)
    for hex_str in hex_patterns:
        try:
            decoded = bytes.fromhex(hex_str).decode('utf-8', errors='ignore')
            flags = search_for_flags(decoded, f"{description} - hex decoded")
            found_flags.extend(flags)
        except:
            pass
    
    return found_flags

# Target URL
url = "http://127.0.0.1:32848/index.php"

print("="*80)
print("ATTEMPT 1: Standard POST request")
print("="*80)

headers = {
    'Content-Type': 'application/x-www-form-urlencoded'
}
data = 'username=admin&password=sup3rsecr3t&login=Login'

try:
    response = requests.post(url, data=data, headers=headers, allow_redirects=True)
    
    print(f"\n[+] POST {url}")
    print(f"[+] Data: {data}")
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Response Length: {len(response.content)}B")
    print(f"\n[+] Response Headers:")
    for key, value in response.headers.items():
        print(f"    {key}: {value}")
        # Search headers for flags
        search_for_flags(value, f"Response header '{key}'")
    
    if response.cookies:
        print(f"\n[+] Cookies:")
        for cookie_name, cookie_value in response.cookies.items():
            print(f"    {cookie_name}: {cookie_value}")
            search_for_flags(cookie_value, f"Cookie '{cookie_name}'")
    
    print(f"\n[+] Complete Response Body:")
    print("-"*80)
    print(response.text)
    print("-"*80)
    
    # Search for flags in response
    all_flags = try_decode_and_search(response.text, "Response body")
    
except Exception as e:
    print(f"[-] Error: {e}")

print("\n" + "="*80)
print("ATTEMPT 2: Dictionary-based POST")
print("="*80)

data_dict = {
    'username': 'admin',
    'password': 'sup3rsecr3t',
    'login': 'Login'
}

try:
    response = requests.post(url, data=data_dict, headers=headers, allow_redirects=True)
    
    print(f"\n[+] POST {url}")
    print(f"[+] Data: {data_dict}")
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Response Length: {len(response.content)}B")
    
    print(f"\n[+] Complete Response Body:")
    print("-"*80)
    print(response.text)
    print("-"*80)
    
    all_flags = try_decode_and_search(response.text, "Response body (dict)")
    
except Exception as e:
    print(f"[-] Error: {e}")

print("\n" + "="*80)
print("ATTEMPT 3: With 'submit' parameter")
print("="*80)

data_dict = {
    'username': 'admin',
    'password': 'sup3rsecr3t',
    'submit': 'Login'
}

try:
    response = requests.post(url, data=data_dict, headers=headers, allow_redirects=True)
    
    print(f"\n[+] POST {url}")
    print(f"[+] Data: {data_dict}")
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Response Length: {len(response.content)}B")
    
    print(f"\n[+] Complete Response Body:")
    print("-"*80)
    print(response.text)
    print("-"*80)
    
    all_flags = try_decode_and_search(response.text, "Response body (submit)")
    
except Exception as e:
    print(f"[-] Error: {e}")

print("\n" + "="*80)
print("ATTEMPT 4: With 'action' parameter")
print("="*80)

data_dict = {
    'username': 'admin',
    'password': 'sup3rsecr3t',
    'action': 'login'
}

try:
    response = requests.post(url, data=data_dict, headers=headers, allow_redirects=True)
    
    print(f"\n[+] POST {url}")
    print(f"[+] Data: {data_dict}")
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Response Length: {len(response.content)}B")
    
    print(f"\n[+] Complete Response Body:")
    print("-"*80)
    print(response.text)
    print("-"*80)
    
    all_flags = try_decode_and_search(response.text, "Response body (action)")
    
except Exception as e:
    print(f"[-] Error: {e}")

print("\n" + "="*80)
print("ATTEMPT 5: URL-encoded explicitly")
print("="*80)

data_encoded = urllib.parse.urlencode({
    'username': 'admin',
    'password': 'sup3rsecr3t',
    'login': 'Login'
})

try:
    response = requests.post(url, data=data_encoded, headers=headers, allow_redirects=True)
    
    print(f"\n[+] POST {url}")
    print(f"[+] Data: {data_encoded}")
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Response Length: {len(response.content)}B")
    
    print(f"\n[+] Complete Response Body:")
    print("-"*80)
    print(response.text)
    print("-"*80)
    
    all_flags = try_decode_and_search(response.text, "Response body (URL-encoded)")
    
except Exception as e:
    print(f"[-] Error: {e}")

print("\n" + "="*80)
print("ATTEMPT 6: GET request to same URL (check if flag visible after login)")
print("="*80)

try:
    # First login with POST
    session = requests.Session()
    response = session.post(url, data=data_dict, headers=headers, allow_redirects=True)
    print(f"[+] Login Status: {response.status_code}")
    
    # Then GET
    response = session.get(url)
    print(f"\n[+] GET {url}")
    print(f"[+] Status: {response.status_code}")
    print(f"[+] Response Length: {len(response.content)}B")
    
    print(f"\n[+] Complete Response Body:")
    print("-"*80)
    print(response.text)
    print("-"*80)
    
    all_flags = try_decode_and_search(response.text, "Response body (GET after login)")
    
except Exception as e:
    print(f"[-] Error: {e}")

print("\n" + "="*80)
print("SEARCH COMPLETE")
print("="*80)

