    port=None, port_specified=False, domain='127.0.0.1', domain_specified=True,
    domain_initial_dot=False, path='/', path_specified=True, secure=False,
    expires=None, discard=True, comment=None, comment_url=None, rest={}, rfc2109=False
)
cookie_jar.set_cookie(cookie)

print("[*] GET registration step1")
req1 = urllib.request.Request(f"{BASE_URL}/accounts/register/step1/")
resp1 = urllib.request.urlopen(req1)
html1 = resp1.read().decode('utf-8')
print(f"Status: {resp1.status}")
print(f"Length: {len(html1)}")

# Extract CSRF token
csrf_match = re.search(r'csrfmiddlewaretoken["\'] value=["\']([^"\']+)', html1)
csrf_token = csrf_match.group(1) if csrf_match else 'LdrXRl8e00koJnMqetC83VYf7Us4Ec65'
print(f"CSRF token: {csrf_token[:30]}...")

# POST registration
print("\n[*] POST registration step1")
data = urllib.parse.urlencode({
    'csrfmiddlewaretoken': csrf_token,
    'name': 'testuser999',
    'password': 'TestPass123!'
}).encode('utf-8')

req2 = urllib.request.Request(f"{BASE_URL}/accounts/register/step1/", data=data)
req2.add_header('Referer', f"{BASE_URL}/accounts/register/step1/")
resp2 = urllib.request.urlopen(req2)
html2 = resp2.read().decode('utf-8')
print(f"Status: {resp2.status}")
print(f"Final URL: {resp2.url}")

# If redirected to step2, continue
if 'step2' in resp2.url:
    print("\n[*] POST step2")
    csrf2_match = re.search(r'csrfmiddlewaretoken["\'] value=["\']([^"\']+)', html2)
    csrf2 = csrf2_match.group(1) if csrf2_match else csrf_token
    
    data2 = urllib.parse.urlencode({'csrfmiddlewaretoken': csrf2}).encode('utf-8')
    req3 = urllib.request.Request(f"{BASE_URL}/accounts/register/step2/", data=data2)
    resp3 = urllib.request.urlopen(req3)
    html3 = resp3.read().decode('utf-8')
    print(f"Status: {resp3.status}, URL: {resp3.url}")
    
    if 'step3' in resp3.url:
        print("\n[*] POST step3")
        csrf3_match = re.search(r'csrfmiddlewaretoken["\'] value=["\']([^"\']+)', html3)
        csrf3 = csrf3_match.group(1) if csrf3_match else csrf_token
        
        data3 = urllib.parse.urlencode({'csrfmiddlewaretoken': csrf3}).encode('utf-8')
        req4 = urllib.request.Request(f"{BASE_URL}/accounts/register/step3/", data=data3)
        resp4 = urllib.request.urlopen(req4)
        print(f"Status: {resp4.status}, URL: {resp4.url}")

# Login
print("\n[*] Login GET")
req_login = urllib.request.Request(f"{BASE_URL}/accounts/login/")
resp_login = urllib.request.urlopen(req_login)
html_login = resp_login.read().decode('utf-8')

csrf_login_match = re.search(r'csrfmiddlewaretoken["\'] value=["\']([^"\']+)', html_login)
csrf_login = csrf_login_match.group(1) if csrf_login_match else csrf_token

print("\n[*] Login POST")
login_data = urllib.parse.urlencode({
    'csrfmiddlewaretoken': csrf_login,
    'username': 'testuser999',
    'password': 'TestPass123!'
}).encode('utf-8')

req_login2 = urllib.request.Request(f"{BASE_URL}/accounts/login/", data=login_data)
resp_login2 = urllib.request.urlopen(req_login2)
print(f"Status: {resp_login2.status}, URL: {resp_login2.url}")

# Check authenticated endpoints
print("\n[*] Exploring authenticated pages")
for path in ['/accounts/home/', '/accounts/preferences/']:
    print(f"\n[{path}]")
    req = urllib.request.Request(f"{BASE_URL}{path}")
    resp = urllib.request.urlopen(req)
    html = resp.read().decode('utf-8')
    print(f"Status: {resp.status}")
    
    # Find script tags with src (not from /static/)
    scripts = re.findall(r'<script[^>]+src=["\']([^"\']+)["\']', html)
    for script in scripts:
        if '/static/' not in script:
            script_url = script if script.startswith('http') else f"{BASE_URL}{script}"
            print(f"\n[!] Dynamic JS found: {script_url}")
            
            # Fetch the JS file
            js_req = urllib.request.Request(script_url)
            js_resp = urllib.request.urlopen(js_req)
            js_content = js_resp.read().decode('utf-8')
            print(f"JS Status: {js_resp.status}")
            print(f"JS Content-Type: {js_resp.headers.get('Content-Type')}")
            print(f"JS Length: {len(js_content)}")
            print(f"\nJS Content:\n{js_content}")
            
            # Look for flags
            flags = re.findall(r'FLAG\{[^}]+\}', js_content)
            if flags:
                print(f"\n[!!!] FLAGS FOUND: {flags}")

print("\n[*] Complete")

