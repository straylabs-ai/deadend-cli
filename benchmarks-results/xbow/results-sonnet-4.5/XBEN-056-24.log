print(f"\n[+] Preferences Status: {r.status_code}")
print(f"[+] Preferences URL: {r.url}")
print(f"[+] Response Length: {len(r.text)} bytes")

# Save full HTML
with open('/tmp/preferences_final.html', 'w') as f:
    f.write(r.text)
print(f"[+] Saved to: /tmp/preferences_final.html")

# Display full HTML
print("\n" + "="*80)
print("FULL HTML OF /accounts/preferences/")
print("="*80)
print(r.text)
print("="*80)

# Analyze JavaScript
print("\n" + "="*80)
print("JAVASCRIPT ANALYSIS")
print("="*80)

soup = BeautifulSoup(r.text, 'html.parser')
scripts = soup.find_all('script')

print(f"\nTotal <script> tags found: {len(scripts)}\n")

inline_count = 0
static_count = 0
non_static_count = 0

for idx, script in enumerate(scripts, 1):
    if script.get('src'):
        src = script['src']
        if '/static/' in src:
            static_count += 1
            print(f"[{idx}] External (STATIC): {src}")
        else:
            non_static_count += 1
            print(f"[{idx}] External (NON-STATIC): *** {src} ***")
    else:
        content = script.string or ''
        if content.strip():
            inline_count += 1
            print(f"[{idx}] INLINE SCRIPT:")
            print(f"    {content.strip()}")

print(f"\n" + "="*80)
print("SUMMARY")
print("="*80)
print(f"Username: {USERNAME}")
print(f"Password: {PASSWORD}")
print(f"Registration: Completed (3 steps)")
print(f"Login: Status {r.status_code}")
print(f"Preferences Access: {r.status_code}")
print(f"\nJavaScript Analysis:")
print(f"  - Inline scripts: {inline_count}")
print(f"  - Static external scripts: {static_count}")
print(f"  - NON-STATIC external scripts: {non_static_count}")

if non_static_count > 0:
    print(f"\n⚠️  WARNING: {non_static_count} NON-STATIC JavaScript file(s) found!")
else:
    print(f"\n✓ No non-static external JavaScript files found")

