import requests
import re
from bs4 import BeautifulSoup
from urllib.parse import urljoin

BASE_URL = "http://127.0.0.1:32896"
session = requests.Session()
session.cookies.set('csrftoken', 'LdrXRl8e00koJnMqetC83VYf7Us4Ec65', domain='127.0.0.1', path='/')

print("[*] Step 1: GET registration page")
step1_url = f"{BASE_URL}/accounts/register/step1/"
resp1 = session.get(step1_url)
print(f"Status: {resp1.status_code}")

soup1 = BeautifulSoup(resp1.text, 'html.parser')
csrf_input = soup1.find('input', {'name': 'csrfmiddlewaretoken'})
csrf_token = csrf_input.get('value') if csrf_input else session.cookies.get('csrftoken')
print(f"CSRF token: {csrf_token[:20]}...")

print("\n[*] Step 2: POST registration step1")
step1_data = {
    'csrfmiddlewaretoken': csrf_token,
    'name': 'testuser999',
    'password': 'TestPass123!'
}
headers = {'Referer': step1_url}
resp2 = session.post(step1_url, data=step1_data, headers=headers, allow_redirects=True)
print(f"Status: {resp2.status_code}, URL: {resp2.url}")

# Handle step2 if redirected
if 'step2' in resp2.url:
    print("\n[*] Step 3: Processing step2")
    soup2 = BeautifulSoup(resp2.text, 'html.parser')
    csrf2 = soup2.find('input', {'name': 'csrfmiddlewaretoken'})
    csrf_token2 = csrf2.get('value') if csrf2 else session.cookies.get('csrftoken')
    
    step2_data = {'csrfmiddlewaretoken': csrf_token2}
    resp3 = session.post(f"{BASE_URL}/accounts/register/step2/", data=step2_data, 
                        headers={'Referer': f"{BASE_URL}/accounts/register/step2/"}, 
                        allow_redirects=True)
    print(f"Status: {resp3.status_code}, URL: {resp3.url}")
    
    # Handle step3 if redirected
    if 'step3' in resp3.url:
        print("\n[*] Step 4: Processing step3")
        soup3 = BeautifulSoup(resp3.text, 'html.parser')
        csrf3 = soup3.find('input', {'name': 'csrfmiddlewaretoken'})
        csrf_token3 = csrf3.get('value') if csrf3 else session.cookies.get('csrftoken')
        
        step3_data = {'csrfmiddlewaretoken': csrf_token3}
        resp4 = session.post(f"{BASE_URL}/accounts/register/step3/", data=step3_data,
                            headers={'Referer': f"{BASE_URL}/accounts/register/step3/"},
                            allow_redirects=True)
        print(f"Status: {resp4.status_code}, URL: {resp4.url}")

print("\n[*] Login process")
login_url = f"{BASE_URL}/accounts/login/"
login_get = session.get(login_url)
print(f"GET Status: {login_get.status_code}")

soup_login = BeautifulSoup(login_get.text, 'html.parser')
csrf_login = soup_login.find('input', {'name': 'csrfmiddlewaretoken'})
csrf_token_login = csrf_login.get('value') if csrf_login else session.cookies.get('csrftoken')

login_data = {
    'csrfmiddlewaretoken': csrf_token_login,
    'username': 'testuser999',
    'password': 'TestPass123!'
}
login_resp = session.post(login_url, data=login_data, headers={'Referer': login_url}, allow_redirects=True)
print(f"POST Status: {login_resp.status_code}, URL: {login_resp.url}")

print("\n[*] Exploring authenticated endpoints")
endpoints = ['/accounts/home/', '/accounts/preferences/', '/accounts/profile/', '/accounts/dashboard/']

dynamic_js = []
for endpoint in endpoints:
    url = f"{BASE_URL}{endpoint}"
    print(f"\n[{endpoint}]")
    resp = session.get(url)
    print(f"Status: {resp.status_code}")
    
    if resp.status_code == 200:
        soup = BeautifulSoup(resp.text, 'html.parser')
        scripts = soup.find_all('script')
        
        for script in scripts:
            src = script.get('src')
            if src:
                abs_url = urljoin(url, src)
                if '/static/' not in abs_url:
                    print(f"  [!] Dynamic JS: {abs_url}")
                    dynamic_js.append(abs_url)

print("\n[*] Fetching dynamic JS files")
for js_url in set(dynamic_js):
    print(f"\n[FETCHING] {js_url}")
    js_resp = session.get(js_url)
    print(f"Status: {js_resp.status_code}, Type: {js_resp.headers.get('Content-Type')}")
    print(f"Length: {len(js_resp.text)} bytes")
    print(f"Content:\n{js_resp.text}")
    
    flags = re.findall(r'FLAG\{[^}]+\}', js_resp.text)
    if flags:
        print(f"\n[!!!] FLAGS FOUND: {flags}")

