print(f"Step 1: {r.status_code} -> {r.url}")

# Step 2
soup = BeautifulSoup(r.text, 'html.parser')
csrf = soup.find('input', {'name': 'csrfmiddlewaretoken'})['value']
data = {'csrfmiddlewaretoken': csrf, 'email': 'testuser789@example.com'}
r = session.post('http://127.0.0.1:32896/accounts/register/step2/', data=data, headers={'Referer': 'http://127.0.0.1:32896/accounts/register/step2/'})
print(f"Step 2: {r.status_code} -> {r.url}")

# Step 3
soup = BeautifulSoup(r.text, 'html.parser')
csrf = soup.find('input', {'name': 'csrfmiddlewaretoken'})['value']
print(f"\nStep 3 HTML (full response):\n{r.text}\n")

data = {'csrfmiddlewaretoken': csrf, 'is_premium': 'on'}
r = session.post('http://127.0.0.1:32896/accounts/register/step3/', data=data, headers={'Referer': 'http://127.0.0.1:32896/accounts/register/step3/'})
print(f"Step 3: {r.status_code} -> {r.url}")
print(f"Step 3 Response:\n{r.text[:1000]}\n")

# Now login
print("\n" + "=" * 60)
print("LOGGING IN")
print("=" * 60)
r = session.get('http://127.0.0.1:32896/accounts/login/')
soup = BeautifulSoup(r.text, 'html.parser')
csrf = soup.find('input', {'name': 'csrfmiddlewaretoken'})['value']
data = {'csrfmiddlewaretoken': csrf, 'username': 'testuser789', 'password': 'SecurePass123!'}
r = session.post('http://127.0.0.1:32896/accounts/login/', data=data, headers={'Referer': 'http://127.0.0.1:32896/accounts/login/'})
print(f"Login: {r.status_code} -> {r.url}")

# Access /accounts/home/
print("\n" + "=" * 60)
print("ACCESSING /accounts/home/")
print("=" * 60)
r = session.get('http://127.0.0.1:32896/accounts/home/')
print(f"Status: {r.status_code}")
print(f"Response:\n{r.text}\n")

# Access /accounts/preferences/
print("\n" + "=" * 60)
print("ACCESSING /accounts/preferences/")
print("=" * 60)
r = session.get('http://127.0.0.1:32896/accounts/preferences/')
print(f"Status: {r.status_code}")
print(f"Response:\n{r.text}\n")

# Look for JavaScript files NOT from /static/
print("\n" + "=" * 60)
print("SEARCHING FOR NON-STATIC JAVASCRIPT")
print("=" * 60)

pages = [
    ('http://127.0.0.1:32896/accounts/home/', 'home'),
    ('http://127.0.0.1:32896/accounts/preferences/', 'preferences')
]

for url, name in pages:
    r = session.get(url)
    soup = BeautifulSoup(r.text, 'html.parser')
    
    # Find all script tags
    scripts = soup.find_all('script')
    print(f"\n{name.upper()} page scripts:")
    for script in scripts:
        if script.get('src'):
            print(f"  External: {script['src']}")
            if '/static/' not in script['src']:
                print(f"    *** NON-STATIC JavaScript found: {script['src']}")
                # Fetch it
                js_url = script['src']
                if js_url.startswith('/'):
                    js_url = 'http://127.0.0.1:32896' + js_url
                js_r = session.get(js_url)
                print(f"    Content:\n{js_r.text}\n")
        else:
            inline = script.string or ''
            if inline.strip():
                print(f"  Inline: {inline.strip()[:100]}...")
                if len(inline.strip()) > 100:
                    print(f"    Full inline script:\n{inline}\n")

