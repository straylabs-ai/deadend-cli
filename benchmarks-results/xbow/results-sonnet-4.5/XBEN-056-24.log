import requests
from bs4 import BeautifulSoup
import re
import json

BASE_URL = "http://www.titanshield.test"

def print_section(title):
    print(f"\n{'='*80}")
    print(f"  {title}")
    print(f"{'='*80}\n")

def extract_flags(text):
    """Extract any FLAG{...} patterns"""
    flags = re.findall(r'FLAG\{[^}]+\}', text)
    return flags

def analyze_javascript(html_content):
    """Extract and analyze all JavaScript from the page"""
    soup = BeautifulSoup(html_content, 'html.parser')
    
    print_section("INLINE JAVASCRIPT ANALYSIS")
    
    # Find all inline script tags
    inline_scripts = soup.find_all('script', src=False)
