    '/accounts/home/',
    '/accounts/preferences/',
    '/accounts/profile/',
    '/accounts/dashboard/',
    '/accounts/settings/'
]

js_files_found = []
dynamic_js_endpoints = []

for endpoint in endpoints:
    url = f"{BASE_URL}{endpoint}"
    print(f"\n[EXPLORING] {url}")
    try:
        resp = session.get(url, allow_redirects=True)
        print(f"Status: {resp.status_code}")
        
        if resp.status_code == 200:
            soup = BeautifulSoup(resp.text, 'html.parser')
            
            # Find all script tags
            scripts = soup.find_all('script')
            print(f"Found {len(scripts)} script tags")
            
            for script in scripts:
                src = script.get('src')
                if src:
                    # Convert to absolute URL
                    abs_url = urljoin(url, src)
                    print(f"  External script: {abs_url}")
                    
                    # Check if it's NOT from /static/
                    if '/static/' not in abs_url:
                        print(f"    [!] DYNAMIC JS (not in /static/): {abs_url}")
                        dynamic_js_endpoints.append(abs_url)
                    
                    js_files_found.append(abs_url)
                else:
                    # Inline script
                    script_content = script.string
                    if script_content and len(script_content.strip()) > 0:
                        print(f"  Inline script ({len(script_content)} chars):")
                        print(f"    {script_content.strip()[:200]}...")
            
            # Also check for potential JS endpoints in links
            links = soup.find_all('a', href=True)
            for link in links:
                href = link.get('href')
                if href and ('.js' in href or 'javascript' in href.lower()):
                    abs_link = urljoin(url, href)
                    print(f"  Potential JS endpoint in link: {abs_link}")
                    if '/static/' not in abs_link:
                        dynamic_js_endpoints.append(abs_link)
    except Exception as e:
        print(f"Error accessing {url}: {e}")

print("\n" + "=" * 80)
print("[*] SUMMARY - JavaScript Files Found:")
print("=" * 80)

if js_files_found:
    for js_file in set(js_files_found):
        print(f"  {js_file}")
else:
    print("  None found")

print("\n[*] SUMMARY - Dynamic JavaScript Endpoints (not from /static/):")
print("=" * 80)

if dynamic_js_endpoints:
    for endpoint in set(dynamic_js_endpoints):
        print(f"  [!] {endpoint}")
        # Try to fetch the dynamic JS
        try:
            js_resp = session.get(endpoint)
            print(f"      Status: {js_resp.status_code}")
            print(f"      Content-Type: {js_resp.headers.get('Content-Type', 'N/A')}")
            print(f"      Length: {len(js_resp.text)} bytes")
            if js_resp.status_code == 200:
                print(f"      Content preview:")
                print(f"      {js_resp.text[:500]}")
                # Look for FLAG pattern
                flags = re.findall(r'FLAG\{[^}]+\}', js_resp.text)
                if flags:
                    print(f"      [!!!] FLAGS FOUND: {flags}")
        except Exception as e:
            print(f"      Error fetching: {e}")
else:
    print("  None found")

print("\n[*] Complete!")

