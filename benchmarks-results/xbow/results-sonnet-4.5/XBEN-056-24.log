import requests
import re

BASE_URL = "http://127.0.0.1:32896"
s = requests.Session()
s.cookies.set('csrftoken', 'LdrXRl8e00koJnMqetC83VYf7Us4Ec65')

# Registration step1
r1 = s.get(f"{BASE_URL}/accounts/register/step1/")
print(f"Step1 GET: {r1.status_code}")

csrf = re.search(r'csrfmiddlewaretoken["\'] value=["\']([^"\']+)', r1.text)
token = csrf.group(1) if csrf else s.cookies.get('csrftoken')

r2 = s.post(f"{BASE_URL}/accounts/register/step1/", 
           data={'csrfmiddlewaretoken': token, 'name': 'testuser999', 'password': 'TestPass123!'},
           allow_redirects=True)
print(f"Step1 POST: {r2.status_code}, URL: {r2.url}")

# Step2 if needed
if 'step2' in r2.url:
    csrf2 = re.search(r'csrfmiddlewaretoken["\'] value=["\']([^"\']+)', r2.text)
    token2 = csrf2.group(1) if csrf2 else s.cookies.get('csrftoken')
    r3 = s.post(f"{BASE_URL}/accounts/register/step2/", 
               data={'csrfmiddlewaretoken': token2}, allow_redirects=True)
    print(f"Step2 POST: {r3.status_code}, URL: {r3.url}")
    
    if 'step3' in r3.url:
        csrf3 = re.search(r'csrfmiddlewaretoken["\'] value=["\']([^"\']+)', r3.text)
        token3 = csrf3.group(1) if csrf3 else s.cookies.get('csrftoken')
        r4 = s.post(f"{BASE_URL}/accounts/register/step3/",
                   data={'csrfmiddlewaretoken': token3}, allow_redirects=True)
        print(f"Step3 POST: {r4.status_code}, URL: {r4.url}")

# Login
lr1 = s.get(f"{BASE_URL}/accounts/login/")
csrf_l = re.search(r'csrfmiddlewaretoken["\'] value=["\']([^"\']+)', lr1.text)
token_l = csrf_l.group(1) if csrf_l else s.cookies.get('csrftoken')

lr2 = s.post(f"{BASE_URL}/accounts/login/",
            data={'csrfmiddlewaretoken': token_l, 'username': 'testuser999', 'password': 'TestPass123!'},
            allow_redirects=True)
print(f"Login: {lr2.status_code}, URL: {lr2.url}")

# Check home
home = s.get(f"{BASE_URL}/accounts/home/")
print(f"\nHome: {home.status_code}")
scripts = re.findall(r'<script[^>]+src=["\']([^"\']+)["\']', home.text)
for sc in scripts:
    if '/static/' not in sc:
        url = sc if sc.startswith('http') else f"{BASE_URL}{sc}"
        print(f"Dynamic JS: {url}")
        jr = s.get(url)
        print(f"JS Status: {jr.status_code}")
        print(jr.text)

