import requests
import re
from bs4 import BeautifulSoup
from urllib.parse import urljoin

# Base URL
BASE_URL = "http://127.0.0.1:32896"

# Create session to maintain cookies
session = requests.Session()

# Set initial CSRF token from storage
session.cookies.set('csrftoken', 'LdrXRl8e00koJnMqetC83VYf7Us4Ec65', domain='127.0.0.1', path='/')

print("[*] Starting registration process...")
print("=" * 80)

# Step 1: GET registration step1 page
print("\n[STEP 1] GET /accounts/register/step1/")
step1_url = f"{BASE_URL}/accounts/register/step1/"
resp1 = session.get(step1_url)
print(f"Status: {resp1.status_code}")
print(f"Cookies: {dict(session.cookies)}")

# Extract CSRF token from form
soup1 = BeautifulSoup(resp1.text, 'html.parser')
csrf_input = soup1.find('input', {'name': 'csrfmiddlewaretoken'})
if csrf_input:
    csrf_token = csrf_input.get('value')
    print(f"Extracted CSRF token: {csrf_token[:20]}...")
else:
    # Try to get from cookie
    csrf_token = session.cookies.get('csrftoken')
    print(f"Using CSRF token from cookie: {csrf_token[:20]}...")

# Step 2: POST to step1 with registration data
print("\n[STEP 2] POST /accounts/register/step1/")
