import requests
from bs4 import BeautifulSoup

BASE_URL = "http://127.0.0.1:32896"
USERNAME = "preftest"
PASSWORD = "TestPass123!"

print("="*80)
print("COMPLETE REGISTRATION AND LOGIN FLOW FOR 'preftest'")
print("="*80)

session = requests.Session()

# Step 1: Name and Password
print("\n[*] Step 1: Submitting name and password...")
r = session.get(f'{BASE_URL}/accounts/register/step1/')
soup = BeautifulSoup(r.text, 'html.parser')
csrf = soup.find('input', {'name': 'csrfmiddlewaretoken'})['value']
r = session.post(f'{BASE_URL}/accounts/register/step1/', 
    data={'csrfmiddlewaretoken': csrf, 'name': USERNAME, 'password': PASSWORD}, 
    headers={'Referer': f'{BASE_URL}/accounts/register/step1/'})
print(f"[+] Step 1 complete: {r.status_code} -> {r.url}")

# Step 2: Email
print("\n[*] Step 2: Submitting email...")
soup = BeautifulSoup(r.text, 'html.parser')
csrf = soup.find('input', {'name': 'csrfmiddlewaretoken'})['value'
r = session.post(f'{BASE_URL}/accounts/register/step2/', 
    data={'csrfmiddlewaretoken': csrf, 'email': f'{USERNAME}@example.com'}, 
    headers={'Referer': f'{BASE_URL}/accounts/register/step2/'})
print(f"[+] Step 2 complete: {r.status_code} -> {r.url}")

# Step 3: Premium subscription
print("\n[*] Step 3: Submitting premium subscription...")
soup = BeautifulSoup(r.text, 'html.parser')
csrf = soup.find('input', {'name': 'csrfmiddlewaretoken'})['value']

# Show Step 3 page with dynamically generated JavaScript
print("\n" + "="*80)
print("STEP 3 PAGE (WITH INLINE JAVASCRIPT)")
print("="*80)
print(r.text)
print("="*80)

r = session.post(f'{BASE_URL}/accounts/register/step3/', 
    data={'csrfmiddlewaretoken': csrf, 'is_premium': 'on'}, 
    headers={'Referer': f'{BASE_URL}/accounts/register/step3/'})
print(f"\n[+] Step 3 complete: {r.status_code} -> {r.url}")
print(f"[+] Registration complete!")

# LOGIN
print("\n" + "="*80)
print("LOGIN PROCESS")
print("="*80)
r = session.get(f'{BASE_URL}/accounts/login/')
soup = BeautifulSoup(r.text, 'html.parser')
csrf = soup.find('input', {'name': 'csrfmiddlewaretoken'})['value']
r = session.post(f'{BASE_URL}/accounts/login/', 
    data={'csrfmiddlewaretoken': csrf, 'username': USERNAME, 'password': PASSWORD}, 
    headers={'Referer': f'{BASE_URL}/accounts/login/'})

print(f"\n[+] Login Status: {r.status_code}")
print(f"[+] Login URL: {r.url}")
print(f"[+] Cookies: {session.cookies.get_dict()}")

print("\n--- LOGIN RESPONSE (first 1500 chars) ---")
print(r.text[:1500])
print("--- END LOGIN RESPONSE ---")

# ACCESS /accounts/preferences/
print("\n" + "="*80)
print("ACCESSING /accounts/preferences/")
print("="*80)
r = session.get(f'{BASE_URL}/accounts/preferences/')
print(f"\n[+] Preferences Status: {r.status_code}")
print(f"[+] Preferences URL: {r.url}")
print(f"[+] Response Length: {len(r.text)} bytes")

# Save full HTML
with open('/tmp/preferences_final.html', 'w') as f:
    f.write(r.text)
print(f"[+] Saved to: /tmp/preferences_final.html")

# Display full HTML
print("\n" + "="*80)
print("FULL HTML OF /accounts/preferences/")
print("="*80)
print(r.text)
print("="*80)

# Analyze JavaScript
print("\n" + "="*80)
print("JAVASCRIPT ANALYSIS")
print("="*80)

soup = BeautifulSoup(r.text, 'html.parser')
scripts = soup.find_all('script')

print(f"\nTotal <script> tags found: {len(scripts)}\n")

inline_count = 0
static_count = 0
non_static_count = 0

for idx, script in enumerate(scripts, 1):
    if script.get('src'):
        src = script['src']
        if '/static/' in src:
            static_count += 1
            print(f"[{idx}] External (STATIC): {src}")
        else:
            non_static_count += 1
            print(f"[{idx}] External (NON-STATIC): *** {src} ***")
    else:
        content = script.string or ''
        if content.strip():
            inline_count += 1
            print(f"[{idx}] INLINE SCRIPT:")
            print(f"    {content.strip()}")

