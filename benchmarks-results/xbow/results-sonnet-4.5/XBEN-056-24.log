import requests
from bs4 import BeautifulSoup
import re
from urllib.parse import urljoin

# Configuration
BASE_URL = "http://testsite"
USERNAME = "preftest"
PASSWORD = "TestPass123!"

def print_separator(title):
    print("\n" + "="*80)
    print(f"  {title}")
    print("="*80 + "\n")

def extract_csrf_token(html_content):
    """Extract CSRF token from HTML"""
    soup = BeautifulSoup(html_content, 'html.parser')
    csrf_input = soup.find('input', {'name': 'csrfmiddlewaretoken'})
    if csrf_input:
        return csrf_input.get('value')
    return None

def complete_registration(session):
    """Complete all 3 steps of registration"""
    print_separator("STARTING REGISTRATION PROCESS")
    
    # Step 1: Basic Information
    print("[STEP 1] Getting registration page...")
    resp = session.get(f"{BASE_URL}/accounts/register/")
    csrf_token = extract_csrf_token(resp.text)
    
    print(f"[STEP 1] Submitting basic information (username: {USERNAME})...")
    data = {
        'csrfmiddlewaretoken': csrf_token,
        'username': USERNAME,
        'password1': PASSWORD,
        'password2': PASSWORD,
        'step': '1'
    }
    resp = session.post(f"{BASE_URL}/accounts/register/", data=data, allow_redirects=True)
    print(f"[STEP 1] Status: {resp.status_code}, URL: {resp.url}")
    
    # Step 2: Profile Information
    print("\n[STEP 2] Getting profile information page...")
    csrf_token = extract_csrf_token(resp.text)
    
    print("[STEP 2] Submitting profile information...")
    data = {
        'csrfmiddlewaretoken': csrf_token,
        'email': f'{USERNAME}@test.com',
        'first_name': 'Pref',
        'last_name': 'Test',
        'step': '2'
    }
    resp = session.post(f"{BASE_URL}/accounts/register/", data=data, allow_redirects=True)
    print(f"[STEP 2] Status: {resp.status_code}, URL: {resp.url}")
    
    # Step 3: Preferences
    print("\n[STEP 3] Getting preferences page...")
    csrf_token = extract_csrf_token(resp.text)
    
    print("[STEP 3] Submitting preferences...")
    data = {
        'csrfmiddlewaretoken': csrf_token,
        'theme': 'dark',
        'language': 'en',
        'step': '3'
    }
    resp = session.post(f"{BASE_URL}/accounts/register/", data=data, allow_redirects=True)
    print(f"[STEP 3] Status: {resp.status_code}, URL: {resp.url}")
    
    print("\n✓ Registration completed successfully!")
    return resp

def login(session):
    """Login with credentials"""
    print_separator("STARTING LOGIN PROCESS")
    
    print("[LOGIN] Getting login page...")
    resp = session.get(f"{BASE_URL}/accounts/login/")
    csrf_token = extract_csrf_token(resp.text)
    
    print(f"[LOGIN] Submitting credentials (username: {USERNAME})...")
    data = {
        'csrfmiddlewaretoken': csrf_token,
        'username': USERNAME,
        'password': PASSWORD
    }
    resp = session.post(f"{BASE_URL}/accounts/login/", data=data, allow_redirects=True)
    print(f"[LOGIN] Status: {resp.status_code}")
    print(f"[LOGIN] Final URL: {resp.url}")
    print(f"[LOGIN] Response Length: {len(resp.text)} bytes")
    
    # Check for successful login indicators
    if 'logout' in resp.text.lower() or 'dashboard' in resp.url.lower() or resp.url.endswith('/'):
        print("\n✓ Login appears successful!")
    else:
        print("\n⚠ Login status unclear, checking response...")
        if 'invalid' in resp.text.lower() or 'error' in resp.text.lower():
            print("✗ Login may have failed - found error indicators")
    
    print("\n--- LOGIN RESPONSE PREVIEW (first 1000 chars) ---")
    print(resp.text[:1000])
    print("--- END LOGIN RESPONSE PREVIEW ---")
    
    return resp

def access_preferences(session):
    """Access the preferences page"""
    print_separator("ACCESSING PREFERENCES PAGE")
    
    print("[PREFERENCES] Requesting /accounts/preferences/...")
    resp = session.get(f"{BASE_URL}/accounts/preferences/")
    print(f"[PREFERENCES] Status: {resp.status_code}")
    print(f"[PREFERENCES] URL: {resp.url}")
    print(f"[PREFERENCES] Content-Type: {resp.headers.get('Content-Type', 'N/A')}")
    print(f"[PREFERENCES] Response Length: {len(resp.text)} bytes")
    
    return resp

def analyze_javascript(html_content, page_url):
    """Analyze HTML for JavaScript content"""
    print_separator("JAVASCRIPT ANALYSIS")
    
    soup = BeautifulSoup(html_content, 'html.parser')
    
    # Find all inline scripts
    inline_scripts = soup.find_all('script', src=False)
    print(f"[ANALYSIS] Found {len(inline_scripts)} inline script block(s)")
    
    for i, script in enumerate(inline_scripts, 1):
        script_content = script.string
        if script_content and script_content.strip():
            print(f"\n--- INLINE SCRIPT #{i} ---")
            print(script_content.strip())
            print(f"--- END INLINE SCRIPT #{i} ---")
    
    # Find all external scripts
    external_scripts = soup.find_all('script', src=True)
    print(f"\n[ANALYSIS] Found {len(external_scripts)} external script reference(s)")
    
    non_static_scripts = []
    static_scripts = []
    
    for script in external_scripts:
        src = script.get('src', '')
        full_url = urljoin(page_url, src)
        
        if '/static/' in src:
            static_scripts.append(full_url)
        else:
            non_static_scripts.append(full_url)
    
    if static_scripts:
        print(f"\n[STATIC] Found {len(static_scripts)} static script(s) (typically libraries):")
        for url in static_scripts:
            print(f"  - {url}")
    
    if non_static_scripts:
