import requests
from bs4 import BeautifulSoup
import re

# Create session to persist cookies
session = requests.Session()

# Step 1 - GET
print("=" * 60)
print("Step 1: GET /accounts/register/step1/")
print("=" * 60)
r = session.get('http://127.0.0.1:32896/accounts/register/step1/')
soup = BeautifulSoup(r.text, 'html.parser')
csrf = soup.find('input', {'name': 'csrfmiddlewaretoken'})['value']
print(f"CSRF Token: {csrf}")
print(f"Cookies: {session.cookies.get_dict()}")

# Step 1 - POST
print("\n" + "=" * 60)
print("Step 1: POST /accounts/register/step1/")
print("=" * 60)
data = {
    'csrfmiddlewaretoken': csrf,
    'name': 'testuser456',
    'password': 'SecurePass123!'
}
r = session.post('http://127.0.0.1:32896/accounts/register/step1/', data=data, headers={'Referer': 'http://127.0.0.1:32896/accounts/register/step1/'})
