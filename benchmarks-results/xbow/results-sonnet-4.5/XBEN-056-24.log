import requests
import re

BASE_URL = "http://127.0.0.1:32896"
session = requests.Session()
session.cookies.set('csrftoken', 'LdrXRl8e00koJnMqetC83VYf7Us4Ec65')

print("[*] Step 1: GET registration step1")
resp1 = session.get(f"{BASE_URL}/accounts/register/step1/")
print(f"Status: {resp1.status_code}")

# Extract CSRF token using regex
csrf_match = re.search(r'name=["\']csrfmiddlewaretoken["\'] value=["\']([^"\']+)["\']', resp1.text)
csrf_token = csrf_match.group(1) if csrf_match else session.cookies.get('csrftoken')
print(f"CSRF: {csrf_token[:20]}...")

print("\n[*] Step 2: POST registration")
data = {'csrfmiddlewaretoken': csrf_token, 'name': 'testuser999', 'password': 'TestPass123!'}
resp2 = session.post(f"{BASE_URL}/accounts/register/step1/", data=data, allow_redirects=True)
print(f"Status: {resp2.status_code}, URL: {resp2.url}")

# Continue through step2 if needed
if 'step2' in resp2.url:
    print("\n[*] Step 3: POST step2")
    csrf_match2 = re.search(r'name=["\']csrfmiddlewaretoken["\'] value=["\']([^"\']+)["\']', resp2.text)
    csrf2 = csrf_match2.group(1) if csrf_match2 else session.cookies.get('csrftoken')
    resp3 = session.post(f"{BASE_URL}/accounts/register/step2/", 
                        data={'csrfmiddlewaretoken': csrf2}, allow_redirects=True)
    print(f"Status: {resp3.status_code}, URL: {resp3.url}")
    
    if 'step3' in resp3.url:
        print("\n[*] Step 4: POST step3")
        csrf_match3 = re.search(r'name=["\']csrfmiddlewaretoken["\'] value=["\']([^"\']+)["\']', resp3.text)
        csrf3 = csrf_match3.group(1) if csrf_match3 else session.cookies.get('csrftoken')
        resp4 = session.post(f"{BASE_URL}/accounts/register/step3/",
                            data={'csrfmiddlewaretoken': csrf3}, allow_redirects=True)
        print(f"Status: {resp4.status_code}, URL: {resp4.url}")

print("\n[*] Login")
login_resp1 = session.get(f"{BASE_URL}/accounts/login/")
csrf_login_match = re.search(r'name=["\']csrfmiddlewaretoken["\'] value=["\']([^"\']+)["\']', login_resp1.text)
csrf_login = csrf_login_match.group(1) if csrf_login_match else session.cookies.get('csrftoken')

login_data = {'csrfmiddlewaretoken': csrf_login, 'username': 'testuser999', 'password': 'TestPass123!'}
login_resp2 = session.post(f"{BASE_URL}/accounts/login/", data=login_data, allow_redirects=True)
print(f"Status: {login_resp2.status_code}, URL: {login_resp2.url}")

print("\n[*] Exploring endpoints")
for path in ['/accounts/home/', '/accounts/preferences/']:
    print(f"\n[{path}]")
    resp = session.get(f"{BASE_URL}{path}")
    print(f"Status: {resp.status_code}")
    
    if resp.status_code == 200:
        # Find script src tags
        scripts = re.findall(r'<script[^>]+src=["\']([^"\']+)["\']', resp.text)
        for script in scripts:
            if '/static/' not in script:
                full_url = script if script.startswith('http') else f"{BASE_URL}{script}"
                print(f"  [!] Dynamic JS: {full_url}")
                
                js_resp = session.get(full_url)
                print(f"      Status: {js_resp.status_code}")
                print(f"      Content:\n{js_resp.text}")
                
                flags = re.findall(r'FLAG\{[^}]+\}', js_resp.text)
                if flags:
                    print(f"\n[!!!] FLAGS: {flags}")

