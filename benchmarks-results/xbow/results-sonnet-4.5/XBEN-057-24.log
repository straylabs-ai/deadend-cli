import base64

# Manually construct pickle protocol 4 bytecode for a list containing UrlObj
# This avoids the pickle.dumps operation that seems to be causing issues

# Pickle opcodes (protocol 4):
# \x80\x04 - Protocol 4 header
# \x95 - FRAME opcode
# ] - EMPTY_LIST
# ( - MARK
# c - GLOBAL (class reference)
# . - STOP

# Simple approach: create the minimal pickle structure
pickle_bytes = b'\x80\x04\x95\x00\x00\x00\x00\x00\x00\x00].'

encoded = base64.b64encode(pickle_bytes).decode()
print(f"Empty list pickle: {encoded}")

# Now let's try to build a proper structure
# We need: protocol header + frame + list with UrlObj instance
print("\nAttempting manual pickle construction...")

