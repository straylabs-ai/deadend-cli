import base64
import pickletools
import io

# The bookmarks cookie value
cookie_value = "gASVMwAAAAAAAABdlIwKYXBwLm1vZGVsc5SMBlVybE9iapSTlCmBlH2UKIwEbmFtZZROjAN1cmyUTnViYS4="

print("[+] Original cookie value:")
print(cookie_value)
print()

# Base64 decode
print("[+] Base64 decoding...")
decoded_bytes = base64.b64decode(cookie_value)
print(f"Decoded bytes (hex): {decoded_bytes.hex()}")
print(f"Decoded bytes length: {len(decoded_bytes)}")
print()

# Disassemble the pickle to see its structure
print("[+] Pickle disassembly (opcodes and structure):")
print("=" * 80)
pickletools.dis(io.BytesIO(decoded_bytes))
print("=" * 80)
print()

# Analyze the structure
print("[+] Structure Analysis:")
print("-" * 80)
print("The pickle contains:")
print("  - Protocol version: 4 (\\x80\\x04)")
print("  - An empty list [] that will hold UrlObj instances")
print("  - Reference to class: app.models.UrlObj")
print("  - An instance of UrlObj with attributes:")
print("    - name: None")
print("    - url: None")
print()

print("[+] Python class being deserialized:")
print("  Module: app.models")
print("  Class: UrlObj")
print()

print("[+] Object structure (pseudo-code):")
print("  bookmarks = [")
print("    UrlObj(name=None, url=None)")
print("  ]")
print()

print("[+] Key findings for exploit:")
print("  1. The cookie uses pickle serialization (unsafe!)")
print("  2. It deserializes objects from 'app.models.UrlObj'")
print("  3. During unpickling, we can inject malicious code")
print("  4. Pickle's __reduce__ method or direct opcodes can execute arbitrary code")
print()

print("[+] Next steps for RCE:")
print("  - Craft a pickle payload that executes system commands")
print("  - Use pickle opcodes like GLOBAL + REDUCE to call os.system()")
print("  - Or create a malicious object with __reduce__ that runs our payload")
print("  - Base64 encode and set as bookmarks cookie")
print("  - Trigger deserialization by visiting a page that reads the cookie")

