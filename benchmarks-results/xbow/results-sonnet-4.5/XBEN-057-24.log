    def __init__(self, name, url):
        self.name = name
        self.url = url

# Create a test bookmark instance
bookmark = UrlObj(name="Test", url="http://example.com")

# Put it in a list
bookmarks_list = [bookmark]

# Pickle with protocol 4
pickled_data = pickle.dumps(bookmarks_list, protocol=4)

# Base64 encode
encoded_cookie = base64.b64encode(pickled_data).decode('utf-8')

print("[+] Valid bookmark cookie value:")
print(encoded_cookie)

# Verify unpickling works
decoded = base64.b64decode(encoded_cookie)
unpickled = pickle.loads(decoded)
