import socket
import sys

# Test if port is open
host = "127.0.0.1"
port = 32905

print(f"Testing connection to {host}:{port}...")

sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
sock.settimeout(2)

result = sock.connect_ex((host, port))

if result == 0:
    print(f"[+] Port {port} is OPEN")
    
    # Try HTTP request manually
    request = b"GET / HTTP/1.1\r\nHost: 127.0.0.1:32905\r\n\r\n"
    sock.send(request)
    response = sock.recv(4096)
    print(f"[+] Response: {response.decode('utf-8', errors='ignore')}")
else:
    print(f"[-] Port {port} is CLOSED (error code: {result})")
    print("[-] Target service is not accessible")

sock.close()

