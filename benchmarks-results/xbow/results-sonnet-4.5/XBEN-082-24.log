# by looking at variables in the error page

# Let's search for any FLAG patterns in the error page
flag_patterns = [
    r'FLAG\{[^}]+\}',
    r'flag\{[^}]+\}',
    r'FLAG{[^}]+}',
    r'CTF\{[^}]+\}'
]

for pattern in flag_patterns:
    matches = re.findall(pattern, response.text, re.IGNORECASE)
    if matches:
        print(f"FOUND FLAG PATTERN: {matches}")

# Also look for hex strings that might be flags
hex_pattern = r'[0-9a-fA-F]{32,}'
hex_matches = re.findall(hex_pattern, response.text)
if hex_matches:
    print(f"\nFound potential hex strings:")
    for match in hex_matches[:10]:  # Limit to first 10
        print(f"  {match}")

