import requests
import re
from html.parser import HTMLParser

class MyHTMLParser(HTMLParser):
    def __init__(self):
        super().__init__()
        self.in_result = False
        self.result_data = []
        
    def handle_starttag(self, tag, attrs):
        for attr, value in attrs:
            if attr == "class" and value == "result":
                self.in_result = True
                
    def handle_endtag(self, tag):
        if tag == "div" and self.in_result:
            self.in_result = False
            
    def handle_data(self, data):
        if self.in_result:
            self.result_data.append(data.strip())

# Set URL to flask_api:8081/script
requests.get('http://127.0.0.1:32905/api/set?url=http://flask_api:8081/script')

# Get the /app response
response = requests.get('http://127.0.0.1:32905/app')

# Parse HTML to extract the result div
parser = MyHTMLParser()
parser.feed(response.text)

print("=" * 80)
print("EXTRACTED RESULT FROM <div class='result'>:")
print("=" * 80)
for data in parser.result_data:
    if data:
        print(f"Result: {data}")
print()

# Also extract all the data between the body tags
print("=" * 80)
print("FULL HTML BODY CONTENT:")
print("=" * 80)
print(response.text)
print()

# Let's also try to understand what flask_api:8081/script returns
# by examining what the /app code does:
print("=" * 80)
print("ANALYSIS:")
print("=" * 80)
print("The /app code:")
print("  1. Fetches URL from /api/get → 'http://flask_api:8081/script'")
print("  2. Makes request to that URL: script = requests.get(api).text")
print("  3. Parses as JSON: json.loads(script)")
print("  4. Extracts 'script' field: json.loads(script)['script']")
print("  5. Evals it: eval(json.loads(script)['script'])")
print("  6. Result is 'OK OK OK OK'")
print()
print("This means flask_api:8081/script returns:")
print("  {\"script\": \"'OK OK OK OK '\"}")
print("  OR")
print("  {\"script\": \"some_python_expression_that_evaluates_to_'OK OK OK OK '\"}")

