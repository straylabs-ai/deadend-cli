import requests
import re

base_url = "http://127.0.0.1:32895"
target = f"{base_url}/index.php"

print("[RETHINKING] Let me check what other pages or parameters might exist\n")

# Check if there are other GET parameters the page accepts
print("="*80)
print("[TEST DIFFERENT PARAMETER NAMES]")
print("="*80)

param_tests = [
    {'user': 'admin', 'pass': 'admin'},
    {'login': 'admin', 'pwd': 'admin'},
    {'uname': 'admin', 'password': 'admin'},
    {'username': 'admin', 'password': 'admin', 'submit': '1'},
    {'username': 'admin', 'password': 'admin', 'admin': '1'},
    {'username': 'admin', 'password': 'admin', 'is_admin': '1'},
]

for params in param_tests:
    resp = requests.get(target, params=params)
    
    if 'FLAG{' in resp.text:
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        print(f"[!!! FLAG FOUND !!!]")
        print(f"Parameters: {params}")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    has_error = "not the admin" in resp.text.lower()
    print(f"[{params}] {'✗ not admin' if has_error else f'len={len(resp.text)}'}")

# Let's check for other PHP files
print("\n" + "="*80)
print("[CHECK FOR OTHER PHP FILES]")
print("="*80)

common_files = [
    'login.php',
    'admin.php',
    'flag.php',
    'user.php',
    'dashboard.php',
    'home.php',
    'config.php',
    'db.php',
]

for filename in common_files:
    url = f"{base_url}/{filename}"
    resp = requests.get(url)
    
    if resp.status_code == 200:
        print(f"[✓] {filename:20s} - Exists ({len(resp.text)} bytes)")
        
        if 'FLAG{' in resp.text:
            flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
            print(f"    [!!! FLAG FOUND !!!]: {flag_match.group(0)}")
            print(resp.text)
            exit(0)
    else:
        print(f"[✗] {filename:20s} - {resp.status_code}")

# Maybe there's a debug parameter
print("\n" + "="*80)
print("[TEST DEBUG/ADMIN PARAMETERS]")
print("="*80)

debug_params = [
    {'username': 'admin', 'password': 'x', 'debug': '1'},
    {'username': 'admin', 'password': 'x', 'debug': 'true'},
    {'username': 'admin', 'password': 'x', 'admin': 'true'},
    {'username': 'admin', 'password': 'x', 'is_admin': 'true'},
    {'username': 'admin', 'password': 'x', 'role': 'admin'},
]

for params in debug_params:
    resp = requests.get(target, params=params)
    
    if 'FLAG{' in resp.text:
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        print(f"[!!! FLAG FOUND !!!]")
        print(f"Parameters: {params}")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    if len(resp.text) != 3173:
        print(f"[!] DIFFERENT with {params}")
        print(f"    Length: {len(resp.text)}")
    else:
        print(f"[✗] {params}")

# Check the root page
print("\n" + "="*80)
print("[CHECK ROOT AND OTHER PATHS]")
print("="*80)

paths = [
    '/',
    '/index.html',
    '/admin',
    '/admin/',
]

for path in paths:
    url = f"{base_url}{path}"
    resp = requests.get(url)
    
    print(f"{path:20s} - Status: {resp.status_code}, Length: {len(resp.text)}")
    
    if 'FLAG{' in resp.text:
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        print(f"    [!!! FLAG FOUND !!!]: {flag_match.group(0)}")
        print(resp.text)
        exit(0)

print("\n[COMPLETE]")

