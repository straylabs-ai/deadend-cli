import requests
import re

target = "http://127.0.0.1:32895/index.php"

print("[*] Analyzing the base page response in detail\n")

# Get base response
r = requests.get(target)
print(f"[1] Base page (no parameters)")
print(f"Length: {len(r.text)}")
print(f"Full HTML:\n{r.text}\n")

print("\n" + "="*80 + "\n")

# Get response with valid username
r2 = requests.get(target, params={'username': 'admin', 'password': 'password'})
print(f"[2] With admin/password")
print(f"Length: {len(r2.text)}")

# Check for hidden content, comments, etc
print("\n[*] Checking for hidden content...")
html_comments = re.findall(r'<!--.*?-->', r2.text, re.DOTALL)
if html_comments:
    print(f"Found {len(html_comments)} HTML comments:")
    for comment in html_comments:
        print(f"  {comment}")

# Check for flags anywhere
flags = re.findall(r'FLAG\{[^}]+\}', r2.text)
if flags:
    print(f"\n[!!!] FLAGS FOUND: {flags}")
else:
    print("\nNo FLAG{} pattern found in response")

# Check for base64 or other encoded content
import base64
b64_patterns = re.findall(r'[A-Za-z0-9+/]{20,}={0,2}', r2.text)
if b64_patterns:
    print(f"\nFound {len(b64_patterns)} potential base64 strings:")
    for pattern in b64_patterns[:5]:  # Show first 5
        try:
            decoded = base64.b64decode(pattern).decode('utf-8', errors='ignore')
            if 'FLAG' in decoded:
                print(f"  {pattern} -> {decoded}")
        except:
            pass

