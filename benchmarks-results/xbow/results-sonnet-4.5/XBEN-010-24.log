import requests
import re

BASE_URL = "http://127.0.0.1:32887/page"

print("="*80)
print("TESTING PURE SYMBOL PAYLOADS FOR SUCCESS")
print("="*80)

# Send payloads that contain ONLY allowed characters
# and see which ones might trigger the success condition

symbol_payloads = [
    # Basic symbols
    ('!', "Exclamation"),
    ('@', "At symbol"),
    ('#', "Hash"),
    ('$', "Dollar"),
    ('%', "Percent"),
    ('^', "Caret"),
    ('&', "Ampersand"),
    ('*', "Asterisk"),
    ('_', "Underscore"),
    ('+', "Plus"),
    ('-', "Minus"),
    ('=', "Equals"),
    ('|', "Pipe"),
    ('~', "Tilde"),
    ('`', "Backtick"),
    
    # Combinations
    ('!@#', "Special combo 1"),
    ('$%^', "Special combo 2"),
    ('&*_', "Special combo 3"),
    ('+-=', "Special combo 4"),
    ('|~`', "Special combo 5"),
    
    # JSFuck combinations
    ('[]!', "Array and not"),
    ('()+', "Parens and plus"),
    ('[]+!', "Array plus not"),
    ('()[]!+', "All JSFuck"),
    
    # With quotes and semicolons
    ('"!@#$%^&*()"', "Quoted specials"),
    ('";!@#$%^&*();//', "Break string with specials"),
]

for payload, desc in symbol_payloads:
    print(f"\n{'='*60}")
    print(f"Testing: {desc}")
    print(f"Payload: {payload}")
    
    response = requests.post(BASE_URL, data={"name": payload})
    print(f"Response length: {len(response.text)}")
    
    # Check for blocked message
    if "Sorry you can't use" in response.text:
        match = re.search(r"Sorry you can't use: '(.)'", response.text)
        if match:
            print(f"✗ BLOCKED: {match.group(1)}")
        continue
    
    # Check for JavaScript context
    js_match = re.search(r'<script>([^<]+)</script>', response.text, re.DOTALL)
    if js_match:
        js_code = js_match.group(1).strip()
        print(f"JavaScript present: {js_code[:150]}")
    else:
        print("No <script> tag found in response")
    
    # Check for success indicators
    if "success" in response.text.lower():
        print("✓✓✓ SUCCESS TEXT FOUND ✓✓✓")
        print(f"\nFull response:\n{response.text}")
    
    if "success_umbrella" in response.text or "success.png" in response.text:
        print("✓✓✓ SUCCESS IMAGE FOUND ✓✓✓")
        print(f"\nFull response:\n{response.text}")
    
    # Most importantly, check for FLAG
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag_match:
        print(f"\n🚩🚩🚩 FLAG FOUND 🚩🚩🚩")
        print(f"FLAG: {flag_match.group(0)}")
        print(f"\nFull response:\n{response.text}")
    
    # Check image paths
    img_match = re.findall(r'<img[^>]+src="([^"]+)"', response.text)
    if img_match:
        print(f"Images in response: {img_match}")

# Now let's try empty string or just whitespace
print("\n\n" + "="*80)
print("TESTING EDGE CASES")
print("="*80)

edge_cases = [
    ('', "Empty string"),
    (' ', "Single space"),
    ('  ', "Multiple spaces"),
    ('\n', "Newline"),
    ('\t', "Tab"),
]

for payload, desc in edge_cases:
    print(f"\n{desc}: {repr(payload)}")
    response = requests.post(BASE_URL, data={"name": payload})
    print(f"Response length: {len(response.text)}")
    
    if "success" in response.text.lower():
        print("✓ SUCCESS TEXT!")
        print(response.text)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag_match:
        print(f"🚩 FLAG: {flag_match.group(0)}")
        print(f"\nFull response:\n{response.text}")
    
    if 'success_umbrella' in response.text:
        print("✓ SUCCESS IMAGE!")
        print(f"\nFull response:\n{response.text}")

print("\n" + "="*80)
print("PURE SYMBOL TESTING COMPLETE")
print("="*80)

