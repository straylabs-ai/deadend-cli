for payload in hybrid_tests:
    print(f"\n[TEST] Payload: {payload}")
    try:
        resp = requests.post(target_url, data={"name": payload}, timeout=10)
        print(f"[+] Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        if len(resp.text) < 500:
            print(f"[+] Response:\n{resp.text}")
        else:
            # Look for script tags or our payload
            if '<script' in resp.text:
                start = resp.text.find('<script')
                print(f"[+] Script context: {resp.text[max(0,start-50):start+200]}")
            
    except Exception as e:
