import requests
import string

# Target configuration
url = "http://127.0.0.1:32887/page"

# Character sets to test
printable_ascii = string.printable[:-5]  # Exclude whitespace chars except space
special_js_chars = "[](){}!+*/-=<>''\";`,.|&^%$#@~\\"

# Combine and deduplicate
all_chars_to_test = sorted(set(printable_ascii + special_js_chars))

print(f"[*] Testing {len(all_chars_to_test)} characters against {url}")
print(f"[*] Looking for blocking message or reflection in response\n")

allowed_chars = []
blocked_chars = []
error_chars = []

for char in all_chars_to_test:
    try:
        # Send POST request with character in 'name' parameter
        data = {'name': char}
        headers = {
            'Content-Type': 'application/x-www-form-urlencoded',
            'User-Agent': 'Mozilla/5.0'
        }
        
        response = requests.post(url, data=data, headers=headers, timeout=5)
        
        # Check for blocking message
        if "Sorry you can't use:" in response.text:
            blocked_chars.append(char)
            status = "BLOCKED"
        else:
            # Check if character reflects in response (potential XSS point)
            allowed_chars.append(char)
            status = "ALLOWED"
        
        # Print result for this character
        char_display = repr(char) if char in [' ', '\t', '\n', '\r'] else char
        print(f"[{status}] Character: {char_display} (ASCII {ord(char)})")
        
    except requests.exceptions.RequestException as e:
        error_chars.append(char)
        print(f"[ERROR] Character: {char} - {str(e)}")

# Print summary
print("\n" + "="*80)
print("SUMMARY")
print("="*80)

print(f"\n[+] ALLOWED Characters ({len(allowed_chars)}):")
print("".join(allowed_chars))
print(f"\nAllowed list: {allowed_chars}")

print(f"\n[-] BLOCKED Characters ({len(blocked_chars)}):")
print("".join(blocked_chars))
print(f"\nBlocked list: {blocked_chars}")

if error_chars:
    print(f"\n[!] ERROR Characters ({len(error_chars)}):")
    print("".join(error_chars))

# Analyze for XSS payload construction
print("\n" + "="*80)
print("XSS PAYLOAD ANALYSIS")
print("="*80)

critical_xss_chars = {
    '<': 'Tag opening',
    '>': 'Tag closing',
    '"': 'Attribute delimiter (double quote)',
    "'": 'Attribute delimiter (single quote)',
    '/': 'Self-closing tag',
    '(': 'Function call',
    ')': 'Function call',
    ';': 'Statement separator',
    '`': 'Template literal',
    '\\': 'Escape character',
    '{': 'Code block/template literal',
    '}': 'Code block/template literal',
    '[': 'Array/property access',
    ']': 'Array/property access',
    '=': 'Assignment/attribute',
    '+': 'Concatenation',
    '*': 'Spread operator',
    '!': 'Negation/important',
    '|': 'Bitwise OR',
    '&': 'Entity/bitwise AND',
    '%': 'Encoding',
    '$': 'Template literal/jQuery'
}

print("\n[*] Critical XSS characters status:")
for char, purpose in critical_xss_chars.items():
    if char in allowed_chars:
        print(f"  ✓ {repr(char)} ALLOWED - {purpose}")
    elif char in blocked_chars:
        print(f"  ✗ {repr(char)} BLOCKED - {purpose}")
    else:
        print(f"  ? {repr(char)} UNKNOWN - {purpose}")

# Check for common XSS patterns
print("\n[*] XSS Pattern Feasibility:")
patterns = {
    'HTML Tags': ['<', '>'],
    'Event Handlers': ['=', '"', "'"],
    'Script Tags': ['<', '>', '/', 's', 'c', 'r', 'i', 'p', 't'],
    'JavaScript Execution': ['(', ')', ';'],
    'Template Literals': ['`', '{', '}', '$'],
    'String Concatenation': ['+', '"', "'"]
}

for pattern_name, required_chars in patterns.items():
    missing = [c for c in required_chars if c not in allowed_chars]
    if not missing:
        print(f"  ✓ {pattern_name}: POSSIBLE (all chars allowed)")
    else:
        print(f"  ✗ {pattern_name}: BLOCKED (missing: {missing})")

print("\n[*] Testing complete!")

