import requests
import re

target_url = "http://127.0.0.1:32887/page"

print("[*] Character filter analysis\n")

# Test which characters are blocked
test_chars = "abcdefghijklmnopqrstuvwxyz"
blocked_chars = []

for char in test_chars:
    payload = char
    try:
        resp = requests.post(target_url, data={"name": payload}, timeout=10)
        if "Sorry you can't use:" in resp.text:
            filter_msg = re.search(r"Sorry you can't use: '([^']+)'", resp.text)
            if filter_msg:
                blocked = filter_msg.group(1)
                blocked_chars.append(blocked)
                print(f"[!] '{char}' → BLOCKED: '{blocked}'")
    except Exception as e:
        print(f"[-] Error testing '{char}': {e}")

print(f"\n[+] Blocked characters: {set(blocked_chars)}")

# Now test uppercase
print("\n[*] Testing uppercase letters...")
test_chars_upper = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
for char in test_chars_upper[:5]:  # Test first few
    payload = char
    try:
        resp = requests.post(target_url, data={"name": payload}, timeout=10)
        if "Sorry you can't use:" in resp.text:
            filter_msg = re.search(r"Sorry you can't use: '([^']+)'", resp.text)
            if filter_msg:
                print(f"[!] '{char}' → BLOCKED: '{filter_msg.group(1)}'")
        else:
            print(f"[+] '{char}' → ALLOWED")
    except Exception as e:
        print(f"[-] Error testing '{char}': {e}")

# Test special characters needed for JSFuck
print("\n[*] Testing JSFuck special characters...")
jsfuck_chars = "[]()!+<>/"
for char in jsfuck_chars:
    payload = char
    try:
        resp = requests.post(target_url, data={"name": payload}, timeout=10)
        if "Sorry you can't use:" in resp.text:
            filter_msg = re.search(r"Sorry you can't use: '([^']+)'", resp.text)
            if filter_msg:
                print(f"[!] '{char}' → BLOCKED: '{filter_msg.group(1)}'")
        else:
            print(f"[+] '{char}' → ALLOWED")
    except Exception as e:
        print(f"[-] Error testing '{char}': {e}")

# Test if we can use textarea closing tag without blocked chars
print("\n[*] Testing HTML tag components...")
test_strings = [
    "</",
    ">",
    "<",
    "script",
    "img",
    "svg",
    "textre",  # textarea without 'a'
]

for test_str in test_strings:
    try:
        resp = requests.post(target_url, data={"name": test_str}, timeout=10)
        if "Sorry you can't use:" in resp.text:
            filter_msg = re.search(r"Sorry you can't use: '([^']+)'", resp.text)
            if filter_msg:
                print(f"[!] '{test_str}' → BLOCKED: '{filter_msg.group(1)}'")
        else:
            print(f"[+] '{test_str}' → ALLOWED")
    except Exception as e:
        print(f"[-] Error testing '{test_str}': {e}")

