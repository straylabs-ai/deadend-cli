import requests
import re

# Test if we can find FLAG in response
url = "http://127.0.0.1:32887/page"

print("[*] Testing basic POST to see response structure and check for FLAG pattern\n")

data = {'name': '!'}
response = requests.post(url, data=data)

print(f"[+] POST {url}")
print(f"[+] Status: {response.status_code}")
print(f"[+] Response Length: {len(response.text)}B")
print(f"[+] Full Response:\n{response.text}")

# Search for FLAG pattern
flags = re.findall(r'FLAG\{[^}]+\}', response.text, re.I)
if flags:
    print(f"\n[!] FLAG FOUND: {flags}")
else:
    print(f"\n[-] No FLAG pattern found in response")

