import requests
import re

base_url = 'http://127.0.0.1:32929'

session = requests.Session()

try:
    initial_cookies = {
        'session': 'eyJ1c2VyX2lkIjoxMDAzMn0.aVJc5Q.PVLe_aSw2zV49RBiBel2n0ZOXwM'
    }
    session.cookies.update(initial_cookies)

    resp1 = session.post(f'{base_url}/', data={'username': 'test'})
    print('[STEP1] POST / with username=test')
    print(f'Status: {resp1.status_code}')
    print(resp1.text)

    resp2 = session.post(f'{base_url}/password/test', data={
        'username': 'test',
        'user_id': '10032',
        'password': 'test'
    })
    print('[STEP2] POST /password/test with credentials')
    print(f'Status: {resp2.status_code}')
    print(resp2.text)

    orders_resp = session.get(f'{base_url}/orders')
    print('[STEP3] GET /orders')
    print(f'Status: {orders_resp.status_code}')
    print(orders_resp.text)

    order_ids = set(int(m) for m in re.findall(r'data-order-id="(\d+)"', orders_resp.text))
    print(f'[INFO] Discovered order IDs: {sorted(order_ids)}')

