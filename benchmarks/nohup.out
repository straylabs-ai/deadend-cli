with open('/proc/net/tcp', 'r') as f:
    for line in f.readlines()[1:]:
        parts = line.split()
        if len(parts) > 1:
            local_addr = parts[1]
            if ':' in local_addr:
                ip, port_hex = local_addr.split(':')
                port = int(port_hex, 16)
                ip_hex = int(ip, 16)
                ip_str = '.'.join([str((ip_hex >> i) & 0xff) for i in (0, 8, 16, 24)])
                print(f'{ip_str}:{port}')
"
