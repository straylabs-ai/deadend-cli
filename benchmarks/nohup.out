import requests
import re

# Try to trigger error pages that might reveal endpoints
base_url = "http://127.0.0.1:32941/"

print("[+] TESTING ERROR-BASED DISCOVERY")
print("=" * 80)

# Try various techniques to make the app reveal endpoints

# 1. Try different HTTP methods on root
test_methods = ['GET', 'POST', 'PUT', 'DELETE', 'PATCH', 'OPTIONS', 'HEAD']
print("\n[TESTING DIFFERENT METHODS ON /]")
for method in test_methods:
    try:
        resp = requests.request(method, base_url, timeout=5)
        # Look for Allow header which reveals supported methods
        allow_header = resp.headers.get('Allow', '')
        if allow_header:
            print(f"[INFO] {method} → Allow: {allow_header}")
        if resp.status_code not in [200, 404]:
            print(f"[UNUSUAL] {method} → Status: {resp.status_code}")
    except Exception as e:
        pass

# 2. Look for framework-specific endpoints
framework_endpoints = [
    # Debug/Development
    '/debug', '/test', '/dev', '/development',
    # Framework defaults
    '/admin', '/manage', '/management',
    '/static', '/media', '/uploads',
    # Auth related
    '/auth', '/login', '/logout', '/register', '/signup',
    '/session', '/token', '/oauth', '/callback',
    # REST common
    '/api', '/v1', '/v2', '/rest', '/ws', '/graphql',
    # Admin panels
    '/admin/', '/django-admin/', '/wp-admin/', '/cpanel/',
    '/phpmyadmin/', '/pma/', '/dbadmin/'
]

print("\n[TESTING FRAMEWORK ENDPOINTS]")
for endpoint in framework_endpoints:
    try:
        resp = requests.get(urllib.parse.urljoin(base_url, endpoint.lstrip('/')), timeout=5)
        if resp.status_code != 404:
            size = len(resp.content)
            print(f"[FOUND] {endpoint} → Status: {resp.status_code} (Size: {size}B)")
            # If redirect, show where
            if resp.status_code in [301, 302, 303, 307, 308]:
                location = resp.headers.get('Location', '')
                print(f"  → Redirects to: {location}")
    except:
        pass

# Try common ID patterns with different values
print("\n[TESTING ID PATTERNS IN DETAIL]")
