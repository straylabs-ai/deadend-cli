# Objective and context

import socket
import threading
import time

def test_port_32947_access():
    """Test different ways to connect to port 32947"""
    print("Testing access to port 32947 using different methods...\n")
    
    # Test 1: Direct connection to see what error we get
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(3)
        result = sock.connect_ex(('127.0.0.1', 32947))
        if result == 0:
            print("✓ Port 32947 is OPEN and accepting connections")
            sock.close()
            
            # Try to make an HTTP request with proper Host header
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            sock.settimeout(3)
            sock.connect(('127.0.0.1', 32947))
            
            # Send request with Host: localhost
            request = b"GET / HTTP/1.1\r\nHost: localhost\r\nUser-Agent: Python-Test\r\nAccept: */*\r\n\r\n"
            sock.send(request)
            response = sock.recv(4096).decode('utf-8', errors='ignore')
            print("\n--- Response from port 32947 ---")
            print(response[:1000])
            sock.close()
        else:
            print("✗ Port 32947 is NOT accessible (connection failed)")
    except Exception as e:
        print(f"✗ Error connecting to port 32947: {e}")
    
    # Test 2: Check if we can bind to port 8000 and create a simple tunnel
    try:
        print("\n--- Testing if we can create a simple proxy on port 8000 ---")
        server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        server.bind(('127.0.0.1', 8000))
        server.listen(1)
        server.close()
        print("✓ Can bind to port 8000")
    except Exception as e:
        print(f"✗ Cannot bind to port 8000: {e}")
    
    print("\nTest completed.")

# Run the test
test_port_32947_access()


