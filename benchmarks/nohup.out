                print(f"    Fuzzable: YES - can test adjacent values")

if len(parts) == 3:
    print(f"\nFormat: Flask SIGNED session")
    print(f"Signed: YES (HMAC-SHA256)")
    print(f"Encrypted: NO")
    print(f"Data: READABLE without secret key")
    print(f"Modification: PROTECTED by signature")
