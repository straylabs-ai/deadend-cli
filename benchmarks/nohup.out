print(f"Response Length: {len(response.content)}B")
print(f"\n[RESPONSE HEADERS]:")
for key, value in response.headers.items():
    print(f"  {key}: {value}")

# Check if we have any session cookies
cookies = session.cookies.get_dict()
print(f"\n[COOKIES RECEIVED]: {len(cookies)}")
for name, value in cookies.items():
    print(f"  {name}: {value[:50]}...")

# Display the response content
print(f"\n[RESPONSE CONTENT]:")
print(response.text[:2000])

# Check for redirect or new page
if response.status_code in [200, 302]:
    print("\n[+] LOGIN SUCCESSFUL - ANALYZING AUTHENTICATED CONTENT")
    print("=" * 80)
    
    # Parse the authenticated page
    soup = BeautifulSoup(response.text, 'html.parser')
    
    # Find all links
    links = soup.find_all('a', href=True)
    print(f"\n[LINKS FOUND ON AUTHENTICATED PAGE]: {len(links)}")
    
    discovered_endpoints = []
    
    for i, link in enumerate(links, 1):
        href = link.get('href')
        text = link.get_text(strip=True)[:60]
        print(f"  {i}. href='{href}' text='{text}'")
        
        # Parse the URL to extract endpoints
        if href and not href.startswith('http') and not href.startswith('#'):
            full_url = urllib.parse.urljoin(base_url, href)
            parsed = urllib.parse.urlparse(full_url)
            path = parsed.path
            query = parsed.query
            
            # Look for ID patterns in the URL
            id_patterns = [
                r'/\D*(\d+)\b',  # /path/123
                r'id=(\d+)',      # id=123
                r'user=(\d+)',    # user=123
            ]
            
            potential_ids = []
            for pattern in id_patterns:
                matches = re.findall(pattern, href)
                potential_ids.extend(matches)
            
            if potential_ids:
                discovered_endpoints.append({
                    'url': full_url,
                    'path': path,
                    'query': query,
                    'ids': potential_ids,
                    'text': text
                })
                print(f"     → IDs Found: {potential_ids}")
    
    # Also check for forms on the authenticated page
    forms = soup.find_all('form')
    print(f"\n[FORMS FOUND ON AUTHENTICATED PAGE]: {len(forms)}")
    for i, form in enumerate(forms, 1):
        action = form.get('action', '')
        method = form.get('method', 'GET').upper()
        print(f"  Form {i}: {method} {action}")
        
        inputs = form.find_all(['input', 'textarea', 'select'])
        for inp in inputs:
            name = inp.get('name', 'unnamed')
            type_attr = inp.get('type', 'text')
            print(f"    - {name} (type={type_attr})")
    
    print("\n" + "=" * 80)
    print("\n[+] SUMMARY OF DISCOVERED ENDPOINTS WITH IDs:")
    
    if discovered_endpoints:
        for endpoint in discovered_endpoints:
            print(f"  {endpoint['path']}")
            if endpoint['query']:
                print(f"    Query: {endpoint['query']}")
            print(f"    IDs: {endpoint['ids']}")
            print(f"    Text: {endpoint['text']}")
    else:
        print("  No endpoints with ID parameters discovered yet.")
        
        # Let's check if the authenticated page has any numeric patterns
        print("\n  [Searching for numeric patterns in authenticated page...]")
