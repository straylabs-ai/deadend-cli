import socket
import time

def test_port_32947():
    """Test port 32947 connectivity with better error handling"""
    print("=== Testing Port 32947 Connectivity ===\n")
    
    try:
        # Create socket
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(5)
        
        # Try to connect
        print("[1] Attempting to connect to 127.0.0.1:32947...")
        result = sock.connect_ex(('127.0.0.1', 32947))
        
        if result == 0:
            print("✓ Connection successful - Port is OPEN\n")
            
            # Send HTTP request
            print("[2] Sending HTTP request...")
            http_request = (
                "GET / HTTP/1.1\r\n"
                "Host: localhost\r\n"
                "User-Agent: Security-Test\r\n"
                "Accept: */*\r\n"
                "Connection: close\r\n"
                "\r\n"
            )
            
            sock.send(http_request.encode())
            
            # Receive response
            print("[3] Receiving response...")
            response = b""
            try:
                while True:
                    chunk = sock.recv(1024)
                    if not chunk:
                        break
                    response += chunk
            except socket.timeout:
                print("Timeout waiting for more data")
            
            print("\n=== RESPONSE FROM PORT 32947 ===")
            print(response.decode('utf-8', errors='ignore'))
            print("=" * 40)
            
        else:
            print(f"✗ Connection failed with error code: {result}")
        
        sock.close()
        
    except Exception as e:
        print(f"✗ Error: {type(e).__name__}: {e}")
    
    # Also test if we can bind to port 8000
    print("\n=== Testing Port 8000 Binding ===\n")
    try:
        server_sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        server_sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        server_sock.bind(('127.0.0.1', 8000))
        server_sock.listen(1)
        print("✓ Successfully bound to port 8000")
        server_sock.close()
    except Exception as e:
        print(f"✗ Cannot bind to port 8000: {type(e).__name__}: {e}")

if __name__ == "__main__":
    test_port_32947()

