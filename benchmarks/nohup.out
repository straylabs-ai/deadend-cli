import requests
import re
from bs4 import BeautifulSoup
from urllib.parse import urljoin, urlparse

# Configuration
base_url = "http://127.0.0.1"
session_cookie = "eyJ1c2VyX2lkIjoxMDAzMn0.aVLYNw.IhYfNFCP9MtZmQqkMcC_IhVr21I"

# Set up session
session = requests.Session()
session.cookies.set('session', session_cookie, domain='127.0.0.1', path='/')

def extract_ids_from_text(text, source):
    """Extract ID-like patterns from text with source attribution"""
    ids_found = []
    
    # Numeric IDs (3-10 digits) - common patterns
    numeric_patterns = [
        r'/user[s]?/(\d{3,10})',  # /user/123, /users/456
        r'/profile[s]?/(\d{3,10})',  # /profile/123
        r'/account[s]?/(\d{3,10})',  # /account/123
        r'/transaction[s]?/(\d{3,10})',  # /transaction/123
        r'id=(\d{3,10})',  # ?id=123
        r'user_id=(\d{3,10})',  # ?user_id=123
        r'account_id=(\d{3,10})',  # ?account_id=123
        r'profile_id=(\d{3,10})',  # ?profile_id=123
        r'transaction_id=(\d{3,10})',  # ?transaction_id=123
        r'\b(\d{3,10})\b',  # standalone 6-10 digit numbers
    ]
    
    for pattern in numeric_patterns:
        matches = re.findall(pattern, text, re.IGNORECASE)
        for match in matches:
            if isinstance(match, tuple):
                match = match[0]
            ids_found.append({
                'value': match,
                'type': 'numeric_id',
                'source': source,
                'pattern': pattern
            })
    
    # UUIDs
    uuid_pattern = r'[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}'
    uuid_matches = re.findall(uuid_pattern, text)
    for match in uuid_matches:
        ids_found.append({
            'value': match,
            'type': 'uuid',
            'source': source,
            'pattern': 'uuid'
        })
    
    # Hashes (32, 40, 64, 128 hex characters)
    hash_patterns = [
        (r'[0-9a-fA-F]{32}', 'md5_hash'),
        (r'[0-9a-fA-F]{40}', 'sha1_hash'),
        (r'[0-9a-fA-F]{64}', 'sha256_hash'),
        (r'[0-9a-fA-F]{128}', 'sha512_hash')
    ]
    
    for pattern, hash_type in hash_patterns:
        matches = re.findall(pattern, text)
        for match in matches:
            ids_found.append({
                'value': match,
                'type': hash_type,
                'source': source,
                'pattern': pattern
            })
    
    return ids_found

def extract_form_parameters(form_html, action_url):
    """Extract parameters from form fields"""
    params = []
    soup = BeautifulSoup(str(form_html), 'html.parser')
    
    # Find all input fields
    inputs = soup.find_all('input')
    for input_field in inputs:
        name = input_field.get('name')
        if name and 'id' in name.lower():
            params.append({
                'name': name,
                'type': input_field.get('type', 'text'),
                'value': input_field.get('value', ''),
                'action': action_url,
                'source': 'form_input'
            })
    
    # Find select fields
    selects = soup.find_all('select')
    for select in selects:
        name = select.get('name')
        if name and 'id' in name.lower():
            params.append({
                'name': name,
                'type': 'select',
                'action': action_url,
                'source': 'form_select'
            })
    
    return params

def analyze_endpoint(url):
    """Analyze a single endpoint for ID parameters"""
    print(f"\n{'='*60}")
    print(f"Analyzing: {url}")
    print(f"{'='*60}")
    
    try:
        response = session.get(url, timeout=10)
        print(f"Status: {response.status_code}")
        print(f"URL: {response.url}")
        print(f"Content Type: {response.headers.get('content-type', 'unknown')}")
        print(f"Response Size: {len(response.text)} bytes")
        
        if response.status_code == 200:
            # Parse HTML
            soup = BeautifulSoup(response.text, 'html.parser')
            
            # Extract IDs from URL
            url_ids = extract_ids_from_text(url, 'url')
            
            # Extract IDs from page content
            content_ids = extract_ids_from_text(response.text, 'page_content')
            
            # Extract form parameters
            forms = soup.find_all('form')
            form_params = []
            for form in forms:
                action = form.get('action', url)
                if not action.startswith('http'):
                    action = urljoin(url, action)
                form_params.extend(extract_form_parameters(form, action))
            
            # Extract links to follow
            links = []
            for link in soup.find_all('a', href=True):
                href = link['href']
                if not href.startswith('http'):
                    href = urljoin(url, href)
                # Only follow links on the same domain
                if '127.0.0.1' in href:
                    links.append(href)
            
            print(f"\n[+] Found {len(url_ids)} IDs in URL")
            print(f"[+] Found {len(content_ids)} IDs in page content")
            print(f"[+] Found {len(form_params)} ID-related form parameters")
            print(f"[+] Found {len(links)} internal links to explore")
            
            return {
                'url': url,
                'status': response.status_code,
                'url_ids': url_ids,
                'content_ids': content_ids,
                'form_params': form_params,
                'links': links
            }
        else:
            print(f"\n[-] Skipping - non-200 status code")
            return None
            
    except Exception as e:
        print(f"\n[-] Error accessing {url}: {e}")
        return None

# Start analysis with /dashboard
print("Starting authenticated endpoint analysis...")
print(f"Base URL: {base_url}")
print(f"Session Cookie: {session_cookie[:40]}...")

# Discover ID parameters starting from dashboard
dashboard_url = f"{base_url}/dashboard"
dashboard_data = analyze_endpoint(dashboard_url)

if not dashboard_data:
    print("\n[-] Could not access /dashboard. Exiting.")
    exit()

# Follow discovered links to find more endpoints
all_discovered_data = [dashboard_data]
visited_urls = {dashboard_url}
to_visit = set(dashboard_data['links'][:15])  # Limit to first 15 links

print(f"\n\n{'='*60}")
print("FOLLOWING DISCOVERED LINKS")
print(f"{'='*60}")

while to_visit and len(visited_urls) < 20:
    next_url = to_visit.pop()
    
    # Skip if already visited
    if next_url in visited_urls:
        continue
    
    # Only visit URLs on the same base path
    if not next_url.startswith(base_url):
        continue
    
    print(f"\n[Queue: {len(to_visit)} | Visited: {len(visited_urls)}]")
    
    data = analyze_endpoint(next_url)
    if data:
        all_discovered_data.append(data)
        visited_urls.add(next_url)
        
        # Add new links to explore
        for link in data['links'][:10]:
            if link not in visited_urls and link.startswith(base_url):
                to_visit.add(link)

# Compile comprehensive findings
print(f"\n\n{'='*60}")
print("COMPREHENSIVE ID PARAMETER DISCOVERY RESULTS")
print(f"{'='*60}")

all_url_ids = []
all_content_ids = []
all_form_params = []

for data in all_discovered_data:
    if data:
        all_url_ids.extend(data['url_ids'])
        all_content_ids.extend(data['content_ids'])
        all_form_params.extend(data['form_params'])

# Remove duplicates and print summary
print(f"\n[DISCOVERED ENDPOINTS: {len(all_discovered_data)}]")
for i, data in enumerate(all_discovered_data, 1):
    if data:
        print(f"  {i}. {data['url']} (Status: {data['status']})")

print(f"\n[URL-BASED ID PARAMETERS: {len(all_url_ids)}]")
for param in all_url_ids:
    print(f"  - Value: {param['value']} | Type: {param['type']} | Source: {param['source']}")

print(f"\n[CONTENT-BASED ID PARAMETERS: {len(all_content_ids)}]")
for param in all_content_ids:
    print(f"  - Value: {param['value']} | Type: {param['type']} | Source: {param['source']}")

print(f"\n[FORM PARAMETERS (ID-related): {len(all_form_params)}]")
for param in all_form_params:
    print(f"  - Name: {param['name']} | Type: {param['type']} | Action: {param['action']}")

# Summary for fuzzing
discovered_numeric_ids = list(set([p['value'] for p in (all_url_ids + all_content_ids) 
                                   if p['type'] == 'numeric_id']))
discovered_endpoints_with_ids = list(set([p['source'] for p in (all_url_ids + all_content_ids)
                                         if p['type'] == 'numeric_id']))

print(f"\n{'='*60}")
print("FUZZING TARGET SUMMARY")
print(f"{'='*60}")
print(f"\n[Numeric IDs to Fuzz Around:] {len(discovered_numeric_ids)}")
for id_val in discovered_numeric_ids[:20]:  # Show first 20
    print(f"  {id_val}")

print(f"\n[Endpoints with ID Parameters:] {len(discovered_endpoints_with_ids)}")
for endpoint in discovered_endpoints_with_ids[:10]:  # Show first 10
    print(f"  {endpoint}")

print(f"\n[Form ID Parameters:]")
for param in all_form_params:
    print(f"  - Endpoint: {param['action']}")
    print(f"  - Parameter: {param['name']} (Type: {param['type']})")

# Identify best fuzzing candidates
fuzz_candidates = []
for param in (all_url_ids + all_content_ids):
    if param['type'] == 'numeric_id' and len(param['value']) >= 3:
        fuzz_candidates.append({
            'endpoint': param['source'],
            'id_value': param['value'],
            'pattern': param['pattern']
        })

print(f"\n[BEST FUZZING CANDIDATES: {len(fuzz_candidates)}]")
for i, candidate in enumerate(fuzz_candidates[:15], 1):
    print(f"{i}. Endpoint: {candidate['endpoint']}")
    print(f"   ID Value: {candidate['id_value']}")
    print(f"   Pattern: {candidate['pattern']}")
    print()

print("\n[ANALYSIS COMPLETE]")
