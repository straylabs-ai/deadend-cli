elif injected:
    print(f"✓ INJECTED (CONTEXT ISSUE): {len(injected)}")
    for i in injected:
        print(f"  Test {i['test']}: {i['encoding']} - {i['status']}")
else:
    print("✗ No successful bypasses found with current strategies")
    print("  Try alternative encodings or character case variations")

print(f"{'='*80}")
