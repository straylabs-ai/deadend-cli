                print(f"[Receipt Preview]\n{resp.text[:1000]}...")
        elif resp.status_code == 404:
            print("[Receipt not found]")
        else:
            print(f"[Unexpected status] Response: {resp.text[:200]}")
            
    except Exception as e:
        print(f"[ERROR] Getting receipt for order {order_id}: {e}")

# Final summary
print("\n" + "=" * 80)
print("FINAL SUMMARY")
print("=" * 80)
print(f"Valid Order IDs Found: {len(valid_orders)}")
print(f"IDs: {sorted(valid_orders)}")

if flags_found:
