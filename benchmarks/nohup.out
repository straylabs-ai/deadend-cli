            print(f"[!] Flags: {flag_matches}")
            print(f"[!] {'='*60}")
            print(f"[!] Full Response:\n{full_response}")
        
        # Track unique responses by content hash
        response_hash = hash(full_response)
        if response_hash not in unique_responses:
            unique_responses[response_hash] = {
                'order_id': order_id,
                'content': full_response,
                'status': response.status_code,
                'length': len(full_response)
            }
        
        print(f"[+] order_id={order_id:3d} | Status={response.status_code} | Length={len(full_response):4d}B | Flags={len(flag_matches)}")
        
    except Exception as e:
        print(f"[!] Error at order_id={order_id}: {str(e)}")

# Analyze unique responses
