import base64
import json
import hmac
import hashlib
import urllib.parse

# Flask session cookie from context
cookie_value = "eyJ1c2VyX2lkIjoxMDAzMn0.aVLcqQ.GOiO-YgoHJypd9IrAVxUQ6Bol_s"

print(f"Flask Session Cookie: {cookie_value}")
print(f"\n{'='*60}")
print("ANALYZING SESSION FORMAT")
print(f"{'='*60}\n")

# Split the cookie into its components
parts = cookie_value.split('.')
print(f"Cookie parts: {len(parts)}")
for i, part in enumerate(parts, 1):
    print(f"  Part {i}: {part} (length: {len(part)})")

print(f"\n{'='*60}")
print("DECODING SESSION PAYLOAD")
print(f"{'='*60}\n")

if len(parts) >= 1:
    # First part is the payload (base64 encoded JSON)
    payload_b64 = parts[0]
    print(f"Payload (Base64): {payload_b64}")
    
    # Add padding if needed for base64 decoding
    missing_padding = len(payload_b64) % 4
    if missing_padding:
        payload_b64 += '=' * (4 - missing_padding)
    
    try:
        # Decode base64
        payload_bytes = base64.urlsafe_b64decode(payload_b64)
        payload_str = payload_bytes.decode('utf-8')
        print(f"Payload (JSON string): {payload_str}")
        
        # Parse JSON
        payload_data = json.loads(payload_str)
        print(f"Payload type: {type(payload_data)}")
        print(f"\nDecoded Data:")
        for key, value in payload_data.items():
            print(f"  {key}: {value} (type: {type(value)})")
            
            # Check for ID-like values
            if isinstance(value, (int, float)):
                print(f"    -> Numeric value: {value}")
            elif isinstance(value, str) and (value.isdigit() or value.isnumeric()):
                print(f"    -> Numeric-like string: {value}")
            elif 'id' in key.lower():
                print(f"    -> Contains 'id' in key name")
        
    except Exception as e:
        print(f"Error decoding payload: {e}")

if len(parts) >= 2:
    print(f"\n{'='*60}")
    print("TIMESTAMP ANALYSIS")
    print(f"{'='*60}\n")
    timestamp_b64 = parts[1]
    print(f"Timestamp (Base64): {timestamp_b64}")
    
    # Add padding if needed
    missing_padding = len(timestamp_b64) % 4
    if missing_padding:
        timestamp_b64 += '=' * (4 - missing_padding)
    
    try:
        timestamp_bytes = base64.urlsafe_b64decode(timestamp_b64)
        timestamp_int = int.from_bytes(timestamp_bytes, 'big')
        print(f"Timestamp value: {timestamp_int}")
        print(f"Human-readable: {timestamp_int} seconds")
    except Exception as e:
        print(f"Could not decode timestamp: {e}")

if len(parts) == 3:
    print(f"\n{'='*60}")
    print("SIGNATURE ANALYSIS")
    print(f"{'='*60}\n")
    signature = parts[2]
    print(f"Signature: {signature}")
    print(f"Signature length: {len(signature)}")
    print(f"Format: This is a Flask SIGNED session cookie")
    print(f"Security: Data is signed with HMAC-SHA256 using Flask secret key")
    print(f"Encryption: Data is NOT encrypted (base64 + JSON only)")
    
    # Try to verify signature (we don't have the secret, but we can analyze format)
    print(f"\nSignature verification: Cannot verify without secret key")
    print(f"However, the structure is: [payload].[timestamp].[signature]")
    print(f"Which confirms this is a SIGNED session cookie")

print(f"\n{'='*60}")
print("SESSION TYPE DETERMINATION")
print(f"{'='*60}\n")
print(f"Type: FLASK SIGNED SESSION COOKIE")
print(f"Structure: base64(payload) + '.' + base64(timestamp) + '.' + signature")
print(f"Encoding: Base64 URL-safe")
print(f"Data Format: JSON")
print(f"Encryption: NO (data is readable)")
print(f"Signature: YES (HMAC-SHA256)")
print(f"\nVulnerability Assessment:")
print(f"  ✓ Data can be READ without secret key")
print(f"  ✗ Data cannot be MODIFIED without secret key (signature validation)")
print(f"  ✓ ID values are directly accessible: user_id={payload_data.get('user_id', 'N/A')}")

print(f"\n{'='*60}")
print("FUZZING POTENTIAL")
print(f"{'='*60}\n")

user_id = payload_data.get('user_id')
if user_id:
    print(f"Found user_id: {user_id}")
    print(f"\nID characteristics:")
    print(f"  - Type: {type(user_id)}")
    print(f"  - Value: {user_id}")
    print(f"  - Incremental pattern: {'Yes' if isinstance(user_id, int) and user_id > 100 else 'Numeric but uncertain'}")
    print(f"  - Range assessment: {user_id} appears to be in higher range (10000+)")
    
    # Test for IDOR by fuzzing user IDs
    print(f"\n\nIDOR FUZZING TEST STRATEGY:")
    print(f"User ID: {user_id}")
    print(f"Adjacent IDs to test:")
    adjacent_ids = []
    for offset in range(-10, 11):
        if offset == 0:
            continue
        test_id = user_id + offset
        adjacent_ids.append(test_id)
        print(f"  - {test_id} (offset: {offset})")
    
    print(f"\nGap filling IDs:")
    # Test around the current ID to find other valid IDs
    gap_start = max(1, user_id - 100)
    gap_end = user_id + 100
    print(f"  - Range to test: {gap_start} to {gap_end}")
    print(f"  - Total IDs in range: {gap_end - gap_start + 1}")
    
    print(f"\nLower range IDs (1-100):")
    for i in range(1, min(101, user_id)):
        print(f"  - {i}")

print(f"\n{'='*60}")
print("METHODOLOGY FOR FURTHER TESTING")
print(f"{'='*60}\n")
print(f"1. Incremental ID testing: Use session cookies with modified user_id values")
print(f"2. IDOR vulnerability: Test if you can access other users' data")
print(f"3. Session manipulation: Attempt to create forged session cookies")
print(f"4. Secret key brute force: If vulnerable, attempt to crack Flask secret key")
print(f"\nCurrent session details saved - ready for IDOR testing."), 
