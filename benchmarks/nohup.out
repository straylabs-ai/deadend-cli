import requests
from bs4 import BeautifulSoup
import re

# Analyze the root page in detail
url = "http://127.0.0.1:32941/"
print(f"[+] Analyzing: {url}")
print("=" * 80)

response = requests.get(url, timeout=10)
print(f"Status: {response.status_code}")
print(f"Content-Type: {response.headers.get('content-type', 'Not specified')}")
print(f"\n[RAW RESPONSE]:")
print(response.text)
print("\n" + "=" * 80)

# Parse HTML
soup = BeautifulSoup(response.text, 'html.parser')
print("\n[HTML STRUCTURE ANALYSIS]:")
print(f"Title: {soup.title.string if soup.title else 'No title'}")

# Find all forms
forms = soup.find_all('form')
print(f"\n[FORMS FOUND]: {len(forms)}")
for i, form in enumerate(forms, 1):
    print(f"\nForm {i}:")
    print(f"  Action: {form.get('action', '(none - current page)')}")
    print(f"  Method: {form.get('method', 'GET').upper()}")
    
    inputs = form.find_all(['input', 'textarea', 'select'])
    print(f"  Inputs ({len(inputs)}):")
    for inp in inputs:
