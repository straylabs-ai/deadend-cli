import re
import urllib.parse
from collections import defaultdict
from urllib.parse import urljoin, urlparse
import requests
from bs4 import BeautifulSoup

class WebCrawler:
    def __init__(self, base_url):
        self.base_url = base_url.rstrip('/')
        self.visited = set()
        self.endpoints = defaultdict(lambda: {'methods': set(), 'parameters': set(), 'id_parameters': []})
        self.to_visit = [base_url]
        self.session = requests.Session()
        self.session.headers.update({
            'User-Agent': 'Security-Testing-Crawler/1.0'
        })
        
    def is_same_origin(self, url):
        """Check if URL belongs to the same origin"""
        return urlparse(url).netloc == urlparse(self.base_url).netloc
    
    def is_id_parameter(self, param_name, param_value=None):
        """Check if parameter appears to be an ID"""
        id_patterns = [
            r'id$', r'_id$', r'user$', r'account$', r'profile$', 
            r'item$', r'product$', r'post$', r'article$', r'page$'
        ]
        
        # Check parameter name
        for pattern in id_patterns:
            if re.search(pattern, param_name, re.IGNORECASE):
                return True
        
        # Check parameter value patterns
        if param_value:
            # Numeric ID
            if re.match(r'^\d+$', str(param_value)):
                return True
            # UUID
            if re.match(r'^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$', str(param_value), re.IGNORECASE):
                return True
            # Hash-like (32 or 40 char hex)
            if re.match(r'^[0-9a-f]{32}$', str(param_value), re.IGNORECASE) or \
               re.match(r'^[0-9a-f]{40}$', str(param_value), re.IGNORECASE):
                return True
        
        return False
    
    def extract_parameters_from_url(self, url):
        """Extract query parameters from URL"""
        parsed = urllib.parse.urlparse(url)
        params = urllib.parse.parse_qs(parsed.query)
        return {k: v[0] for k, v in params.items()}
    
    def extract_parameters_from_form(self, form):
        """Extract parameters from form inputs"""
        params = {}
        for input_tag in form.find_all(['input', 'textarea', 'select']):
            name = input_tag.get('name')
            if name:
                value = input_tag.get('value', '')
                params[name] = value
        return params
    
    def add_endpoint(self, url, method='GET', parameters=None):
        """Add or update endpoint information"""
        # Normalize URL (remove fragments)
        parsed = urlparse(url)
        clean_url = urllib.parse.urlunparse(parsed._replace(fragment=''))
        
        # Only process same-origin URLs
        if not self.is_same_origin(clean_url):
            return
        
        path = parsed.path or '/'
        query_params = self.extract_parameters_from_url(clean_url)
        
        # Combine URL and provided parameters
        all_params = {}
        all_params.update(query_params)
        if parameters:
            all_params.update(parameters)
        
        # Update endpoint info
        self.endpoints[path]['methods'].add(method.upper())
        self.endpoints[path]['parameters'].update(all_params.keys())
        
        # Identify ID parameters
        for param_name, param_value in all_params.items():
            if self.is_id_parameter(param_name, param_value):
                param_info = {
                    'name': param_name,
                    'value': param_value,
                    'type': 'numeric' if re.match(r'^\d+$', str(param_value)) else 
                           'uuid' if re.match(r'^[0-9a-f]{8}-', str(param_value), re.IGNORECASE) else
                           'hash' if re.match(r'^[0-9a-f]{32,40}$', str(param_value), re.IGNORECASE) else
                           'string'
                }
                # Avoid duplicates
                if param_info not in self.endpoints[path]['id_parameters']:
                    self.endpoints[path]['id_parameters'].append(param_info)
        
        # Add to visit queue if not visited
        if clean_url not in self.visited and clean_url not in self.to_visit:
            self.to_visit.append(clean_url)
    
    def crawl_page(self, url):
        """Crawl a single page and extract links/forms"""
        try:
            response = self.session.get(url, timeout=10)
            if response.status_code != 200:
                print(f"[-] Failed to access {url}: Status {response.status_code}")
                return False
            
            print(f"[+] Crawling: {url}")
            soup = BeautifulSoup(response.text, 'html.parser')
            
            # Extract all links
            for link in soup.find_all('a', href=True):
                href = link.get('href')
                full_url = urljoin(url, href)
                self.add_endpoint(full_url, 'GET')
            
            # Extract all forms
            for form in soup.find_all('form'):
                action = form.get('action', '')
                method = form.get('method', 'GET').upper()
                full_url = urljoin(url, action)
                
                form_params = self.extract_parameters_from_form(form)
                self.add_endpoint(full_url, method, form_params)
                
                # Also add link without query params for forms with GET method
                if method == 'GET':
                    parsed = urlparse(full_url)
                    self.add_endpoint(urllib.parse.urlunparse(parsed._replace(query='')), method)
            
            return True
            
        except Exception as e:
            print(f"[-] Error crawling {url}: {str(e)}")
            return False
    
    def crawl(self, max_pages=100):
        """Main crawling loop"""
        print(f"[+] Starting crawl of {self.base_url}")
        print("=" * 80)
        
        pages_crawled = 0
        while self.to_visit and pages_crawled < max_pages:
            url = self.to_visit.pop(0)
            
            if url in self.visited:
                continue
            
            if not self.is_same_origin(url):
                continue
            
            self.visited.add(url)
            self.crawl_page(url)
            pages_crawled += 1
        
        print("=" * 80)
        print(f"[+] Crawl completed. Visited {pages_crawled} pages.")
        return self.get_results()
    
    def get_results(self):
        """Return formatted results"""
        results = []
        
        print("\n[+] DISCOVERED ENDPOINTS:")
        print("=" * 80)
        
        for path, data in sorted(self.endpoints.items()):
            endpoint_info = {
                'path': path,
                'methods': list(data['methods']),
                'parameters': list(data['parameters']),
                'id_parameters': data['id_parameters'],
                'has_id_params': len(data['id_parameters']) > 0
            }
            results.append(endpoint_info)
            
            # Print formatted output
            print(f"\n[ENDPOINT] {path}")
            print(f"  Methods: {', '.join(sorted(data['methods']))}")
            if data['parameters']:
                print(f"  Parameters: {', '.join(sorted(data['parameters']))}")
            if data['id_parameters']:
                print(f"  ⚠ ID PARAMETERS FOUND ({len(data['id_parameters'])}):")
                for idx, param in enumerate(data['id_parameters'], 1):
                    print(f"    {idx}. {param['name']} = {param['value']} (type: {param['type']})")
        
        print("\n" + "=" * 80)
        
        # Summary statistics
        total_endpoints = len(results)
        endpoints_with_ids = sum(1 for r in results if r['has_id_params'])
        total_id_params = sum(len(r['id_parameters']) for r in results)
        
        print(f"\n[SUMMARY]")
        print(f"  Total endpoints discovered: {total_endpoints}")
        print(f"  Endpoints with ID parameters: {endpoints_with_ids}")
        print(f"  Total ID parameters found: {total_id_params}")
        
        return results

# Execute crawler
if __name__ == "__main__":
    base_url = "http://127.0.0.1:32941/"
    crawler = WebCrawler(base_url)
    results = crawler.crawl(max_pages=50)
    
    # Print detailed results for verification
    print("\n[+] DETAILED RESULTS FOR FUZZING PHASE:")
    print("=" * 80)
    for endpoint in results:
        if endpoint['has_id_params']:
            print(f"\n[FUZZ TARGET] {endpoint['path']}")
            print(f"  Methods: {', '.join(endpoint['methods'])}")
            print(f"  ID Parameters:")
            for param in endpoint['id_parameters']:
                print(f"    - {param['name']} (current: {param['value']}, type: {param['type']})")
    
    print("\n[+] CRAWLING COMPLETE - READY FOR FUZZING PHASE")
