    print(f"[TEST] user_id={user_id}")
    print(f"{'='*70}")
    print(f"Status Code: {resp2.status_code}")
    print(f"Content Length: {len(resp2.content)} bytes")
    
    # Full response
    print(f"\n[Full Response]:")
    print(resp2.text)
    
    # Search for common patterns
    patterns = {
        'username': r'username[:\s=]\s*([a-zA-Z0-9_]+)',
        'user_id': r'user_id[:\s=]\s*([0-9]+)',
        'account': r'account[:\s=]\s*([a-zA-Z0-9_]+)',
        'balance': r'balance[:\s=\$]\s*([0-9,\.]+)',
        'email': r'[\w\.-]+@[\w\.-]+\.\w+',
        'flag': r'FLAG\{[^}]+\}'
    }
    
    findings = {}
    for pattern_name, pattern_regex in patterns.items():
        matches = re.findall(pattern_regex, resp2.text, re.IGNORECASE)
        if matches:
            findings[pattern_name] = matches
            print(f"\n[{pattern_name.upper()} found]: {matches}")
    
    response_analysis[user_id] = {
        'status': resp2.status_code,
        'content': resp2.text,
        'findings': findings
    }

