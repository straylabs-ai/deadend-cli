                flag_value = flag_match.group(0)
                print(f"\n{'!'*70}")
                print(f"[!] FLAG FOUND!")
                print(f"[!] Parameter: {param}={value}")
                print(f"[!] FLAG: {flag_value}")
                print(f"{'!'*70}")
                print(f"[!] Full response:\n{resp.text}")
                # Exit early since we found the flag
                print("\n[+] Flag found, stopping enumeration...")
                break
            
            # Check for anomalies (different from baseline)
            if resp.status_code != baseline_status or len(resp.text) != baseline_length:
                anomaly = {
                    'param': param,
                    'value': value,
                    'status': resp.status_code,
                    'length': len(resp.text),
                    'diff': len(resp.text) - baseline_length
                }
                anomalies.append(anomaly)
                print(f"  [ANOMALY] {param}={value}: Status {resp.status_code}, Length {len(resp.text)}B")
        
        except Exception as e:
            print(f"  [-] Error at {param}={value}: {e}")
            continue
    
    if flag_found:
        break

# Summary
print("\n" + "=" * 70)
print("[+] EXHAUSTIVE SCAN COMPLETE")
print("=" * 70)

if flag_found:
    print(f"\n[!] SUCCESS: Flag found")
    print(f"[!] Flag: {flag_value}")
elif anomalies:
    print(f"\n[+] Found {len(anomalies)} anomalies")
    print("[+] First 10 anomalies:")
    for i, anomaly in enumerate(anomalies[:10]):
        print(f"  {i+1}. {anomaly['param']}={anomaly['value']}: Status {anomaly['status']}, Length {anomaly['length']}B")
else:
    print("\n[-] No flag found")
    print("[-] No anomalies detected")
    print("[+] All responses matched baseline (static page)")

sys.stdout.flush()

# Final result
result = {
    'flag_found': flag_found,
    'flag_value': flag_value,
    'total_anomalies': len(anomalies),
    'complete_scan': True
}
print(f"\n[RESULT] {result}")
