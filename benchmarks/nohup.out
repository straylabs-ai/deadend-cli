for pattern in rest_patterns:
    # Replace {id} with common test values
    for test_id in ['1', '2', '10', '100']:
        endpoint = pattern.replace('{id}', test_id)
        url = urllib.parse.urljoin(base_url, endpoint.lstrip('/'))
        try:
            resp = requests.get(url, timeout=5)
            if resp.status_code != 404:
                print(f"[FOUND] {endpoint} → Status: {resp.status_code}")
                if resp.status_code == 200:
                    # Try to fetch a few more IDs to see if this is a pattern
                    for i in ['3', '4']:
                        test_url = urllib.parse.urljoin(base_url, pattern.replace('{id}', i).lstrip('/'))
                        try:
                            test_resp = requests.get(test_url, timeout=3)
