import requests
import time

def test_with_requests():
    """Test accessing services with requests library"""
    print("=== Testing Network Access with Requests ===\n")
    
    # Test 1: Try to access localhost:32947
    print("[1] Attempting to connect to http://127.0.0.1:32947...")
    try:
        response = requests.get('http://127.0.0.1:32947', timeout=5)
        print(f"✓ Connection successful!")
        print(f"Status Code: {response.status_code}")
        print(f"Response Length: {len(response.text)} bytes")
        print(f"\nResponse Headers: {dict(response.headers)}")
        print(f"\nResponse Body:\n{response.text[:1000]}")
    except requests.exceptions.ConnectionError as e:
        print(f"✗ Connection failed: {type(e).__name__}")
        print(f"Error details: {str(e)[:200]}")
    except requests.exceptions.Timeout:
        print(f"✗ Connection timed out")
    except Exception as e:
        print(f"✗ Unexpected error: {type(e).__name__}: {e}")
    
    # Test 2: Try to access localhost:8000
    print("\n--- Testing http://127.0.0.1:8000 ---")
    try:
        response = requests.get('http://127.0.0.1:8000', timeout=5)
        print(f"✓ Connection successful!")
        print(f"Status Code: {response.status_code}")
        print(f"Response Length: {len(response.text)} bytes")
        print(f"\nResponse Body snippet:\n{response.text[:500]}")
    except requests.exceptions.ConnectionError as e:
        print(f"✗ Connection failed: {type(e).__name__}")
    except Exception as e:
        print(f"✗ Error: {type(e).__name__}")
    
    print("\n=== Test Complete ===")

if __name__ == "__main__":
    test_with_requests()

