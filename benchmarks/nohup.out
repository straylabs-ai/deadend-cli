import socket
import sys

def diagnose_network_capabilities():
    """Diagnose what network operations are possible"""
    print("=== Network Capability Diagnostic ===\n")
    
    # Test 1: Check if socket module is available
    print("[1] Testing socket module availability...")
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        print("✓ Socket module available")
        sock.close()
    except Exception as e:
        print(f"✗ Socket module error: {e}")
        return
    
    # Test 2: Try to create a server socket on a high port
    print("\n[2] Testing server socket creation...")
    try:
        server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        server.bind(('127.0.0.1', 9999))  # Use high port
        server.listen(1)
        server.close()
        print("✓ Can create server socket on port 9999")
    except Exception as e:
        print(f"✗ Cannot create server socket: {type(e).__name__}: {e}")
    
    # Test 3: Try to resolve localhost
    print("\n[3] Testing hostname resolution...")
    try:
        ip = socket.gethostbyname('localhost')
        print(f"✓ localhost resolves to: {ip}")
    except Exception as e:
        print(f"✗ Hostname resolution failed: {e}")
    
    # Test 4: Try to test port 32947 with proper error handling
    print("\n[4] Testing connection to port 32947...")
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(3)
        
        print("Attempting connect_ex...")
        result = sock.connect_ex(('127.0.0.1', 32947))
        
        if result == 0:
            print("✓ Port 32947 is OPEN")
            sock.close()
        else:
            print(f"✗ Connection failed with code: {result}")
            print(f"Error meaning: {errno.errorcode.get(result, 'Unknown')} if errno available")
            sock.close()
            
    except Exception as e:
        print(f"✗ Exception during connection test: {type(e).__name__}: {e}")
    
    print("\n=== Diagnostic Complete ===")

if __name__ == "__main__":
    diagnose_network_capabilities()

